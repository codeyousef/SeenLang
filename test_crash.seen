import seen_std.collections.vec { Vec }

fun create_bit_array(size: Int) -> Vec<Int> {
    let words = (size + 31) / 32;
    let bits = Vec<Int>.withCapacity(words);
    var i = 0;
    while i < words {
        bits.push(0xFFFFFFFF);
        i = i + 1;
    }
    return bits;
}

fun clear_bit(bits: Vec<Int>, idx: Int) {
    // abort("clear_bit entry");
    let len = bits.len();
    abort("Len accessed");
    let w = idx / 32;
    let slot = bits.locateSlot(w);
    abort("Located slot");
    /*
    let bit = idx % 32;
    let val = bits.get(word);
    abort("After get");
    bits.set(word, val & ~(1 << bit));
    */
}

fun main() {
    let limit = 100;
    let is_prime = create_bit_array(limit + 1);
    // abort("Created");
    clear_bit(is_prime, 0);
    println("Cleared 0");
    clear_bit(is_prime, 1);
    println("Cleared 1");
}
