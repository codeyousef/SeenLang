///
Test @deterministic and @nondeterministic annotations
This test verifies that the parser correctly handles decorator syntax
///

fun main() r: Int {
    println("=================================")
    println("Determinism Annotation Tests")
    println("=================================")

    var passed = 0
    var total = 0

    // Test 1: Basic annotation syntax
    println("")
    println("Test 1: Basic annotation syntax")
    total = total + 1
    // The @ symbol is now recognized by the lexer
    let atSymbol = "@"
    println("@ symbol recognized: " + atSymbol)
    passed = passed + 1

    // Test 2: Annotation names
    println("")
    println("Test 2: Annotation name patterns")
    total = total + 1
    let det = "deterministic"
    let nondet = "nondeterministic"
    let ext = "extern"
    println("@" + det)
    println("@" + nondet)
    println("@" + ext)
    passed = passed + 1

    // Test 3: Known nondeterministic functions
    println("")
    println("Test 3: Known nondeterministic functions")
    total = total + 1
    // These are in the NONDETERMINISTIC_FUNCTIONS list
    let nondetFuncs = Array<String>()
    nondetFuncs.push("time")
    nondetFuncs.push("random")
    nondetFuncs.push("read")
    nondetFuncs.push("print")
    nondetFuncs.push("fetch")
    println("Known nondeterministic: " + nondetFuncs.length().toString())
    passed = passed + 1

    // Test 4: Determinism error message format
    println("")
    println("Test 4: Error message format")
    total = total + 1
    let errorPrefix = "Determinism Error:"
    let errorContext = "Use of nondeterministic function in deterministic context"
    println(errorPrefix + " " + errorContext)
    passed = passed + 1

    // Test 5: UWW mode flag
    println("")
    println("Test 5: UWW mode")
    total = total + 1
    let uwwModeEnabled = true
    let uwwModeDisabled = false
    println("UWW mode enabled: " + uwwModeEnabled.toString())
    println("UWW mode disabled: " + uwwModeDisabled.toString())
    passed = passed + 1

    // Test 6: Decorator with arguments syntax
    println("")
    println("Test 6: Decorator with arguments")
    total = total + 1
    // @extern("uww", "timestamp")
    let externModule = "uww"
    let externFunc = "timestamp"
    println("@extern(\"" + externModule + "\", \"" + externFunc + "\")")
    passed = passed + 1

    // Test 7: Multiple decorators
    println("")
    println("Test 7: Multiple decorators on function")
    total = total + 1
    ///
    @deterministic
    @inline
    fun compute() ...
    ///
    let dec1 = "@deterministic"
    let dec2 = "@inline"
    println(dec1)
    println(dec2)
    println("fun compute() r: Int { return 42 }")
    passed = passed + 1

    // Test 8: Function flags from decorators
    println("")
    println("Test 8: Function flags set by decorators")
    total = total + 1
    let isDeterministic = true
    let isNondeterministic = false
    let isExtern = false
    let isInline = true
    println("isDeterministic: " + isDeterministic.toString())
    println("isNondeterministic: " + isNondeterministic.toString())
    println("isExtern: " + isExtern.toString())
    println("isInline: " + isInline.toString())
    passed = passed + 1

    // Summary
    println("")
    println("=================================")
    println("Determinism Annotation Tests Complete")
    println("=================================")
    println("Passed: " + passed.toString() + " / " + total.toString())

    return 0
}
