///
Test: HashSet should be rejected in deterministic profile
Expected: FAIL with --profile deterministic
Expected: PASS without --profile flag
///

import collections.hashset.{HashSet}

fun main() r: Int {
    ///
    This should be rejected in deterministic profile
    because HashSet has nondeterministic iteration order
    ///
    let set = HashSet<Int>.new()
    set.insert(1)
    set.insert(2)
    set.insert(3)

    // Iteration order is not guaranteed!
    println("Size: " + set.len().toString())

    return 0
}
