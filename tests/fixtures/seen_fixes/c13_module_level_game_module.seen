class Keyboard {
    var pressed: Int

    static fun new() r: Keyboard {
        return Keyboard { pressed: 1 }
    }

    fun update() r: Void {
        this.pressed = this.pressed + 1
    }
}

class Game {
    var keyboard: Keyboard

    static fun new() r: Game {
        return Game { keyboard: Keyboard.new() }
    }
}

var gGame = Game.new()

fun runGlobalGame() r: Int {
    gGame.keyboard.update()
    return gGame.keyboard.pressed
}
