class Keyboard {
    var pressed: Int

    static fun new() r: Keyboard {
        return Keyboard { pressed: 1 }
    }
}

class Mouse {
    var x: Int

    static fun new() r: Mouse {
        return Mouse { x: 2 }
    }
}

class InputState {
    var keyboard: Keyboard
    var mouse: Mouse

    static fun new(keyboard: Keyboard, mouse: Mouse) r: InputState {
        return InputState { keyboard: keyboard, mouse: mouse }
    }
}

fun makeKeyboard() r: Keyboard {
    return Keyboard.new()
}

fun makeMouse() r: Mouse {
    return Mouse.new()
}

fun makeInputState() r: InputState {
    return InputState.new(makeKeyboard(), makeMouse())
}

var gInput = makeInputState()
var gPressed = gInput.keyboard.pressed

fun readPressed() r: Int {
    return gPressed
}
