class Chunk {
    var id: Int

    static fun new(id: Int) r: Chunk {
        return Chunk { id: id }
    }

    fun inBounds(x: Int) r: Bool {
        return chunkInBounds(this, x)
    }
}

fun main() r: Int {
    let chunk = Chunk.new(1)
    if chunk.inBounds(7) {
        return 0
    }
    return 1
}
