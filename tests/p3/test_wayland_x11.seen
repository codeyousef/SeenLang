// : Wayland/X11 bindings — compile-only
// Verifies event constants for both display servers

fun main() r: Int {
    // XCB event types
    let XCB_KEY_PRESS = 2
    let XCB_MOTION_NOTIFY = 6
    let XCB_EXPOSE = 12

    // Wayland event types
    let WL_POINTER_MOTION = 3
    let WL_KEYBOARD_KEY = 6

    if XCB_KEY_PRESS != 2 {
        println("FAIL: XCB_KEY_PRESS constant")
        return 1
    }

    println("PASS: Wayland/X11 bindings test (compile-only)")
    return 0
}
