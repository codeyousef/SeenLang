///
Regression: receiver-free static class calls must keep matching their
emitted ClassName_method signature when they return class instances.
///

class Counter {
    var value: Int

    static fun make(v: Int) r: Counter {
        let c = Counter()
        c.value = v
        return c
    }
}

fun main() r: Int {
    let c = Counter.make(7)
    if c.value == 7 {
        println("PASS: static class return")
        return 0
    }
    println("FAIL: static class return = " + c.value.toString())
    return 1
}
