fun commaGet(data: String, idx: Int) r: String {
    var pos = 0
    var count = 0
    var start = 0
    while pos < data.length() {
        if data.byteAt(pos) == 44 {
            if count == idx {
                return data.substring(start, pos)
            }
            count = count + 1
            start = pos + 1
        }
        pos = pos + 1
    }
    if count == idx {
        return data.substring(start, data.length())
    }
    return ""
}

fun countCommaFields(data: String) r: Int {
    if data == "" {
        return 0
    }
    var count = 1
    var pos = 0
    while pos < data.length() {
        if data.byteAt(pos) == 44 {
            count = count + 1
        }
        pos = pos + 1
    }
    return count
}

fun main() r: Int {
    if commaGet("a,b,c", 1) != "b" {
        return 1
    }
    if countCommaFields("a,b,c") != 3 {
        return 2
    }
    return 0
}