// Regression: parsing 9+ parameters must not corrupt FunctionNode.params.

fun sumNine(a: Int, b: Int, c: Int, d: Int, e: Int, f: Int, g: Int, h: Int, i: Int) r: Int {
    return a + b + c + d + e + f + g + h + i
}

fun main() r: Int {
    let result = sumNine(1, 2, 3, 4, 5, 6, 7, 8, 9)
    if result == 45 {
        println("PASS: high arity params")
        return 0
    }
    println("FAIL: high arity params = " + result.toString())
    return 1
}
