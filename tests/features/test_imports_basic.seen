// Module System Test
// Tests: import statements, symbol resolution, module access
// Expected: Import system works correctly

// Test importing from stdlib
import testing.assert { assertEquals, assertTrue }

fun testBasicImport() r: Bool {
    // Test that imported functions work
    assertEquals(1, 1, "Import from testing module works")
    return true
}

fun testTrueAssertion() r: Bool {
    assertTrue(true, "assertTrue works")
    return true
}

fun main() r: Int {
    println("Testing Module Import System...")

    var passed = 0
    var failed = 0

    // Test 1: Basic import
    println("\n=== Test 1: Basic Import ===")
    if testBasicImport() {
        println("PASS: Can import from stdlib module")
        passed = passed + 1
    } else {
        println("FAIL: Import failed")
        failed = failed + 1
    }

    // Test 2: Selective import
    println("\n=== Test 2: Selective Import ===")
    if testTrueAssertion() {
        println("PASS: Selective import works")
        passed = passed + 1
    } else {
        println("FAIL: Selective import failed")
        failed = failed + 1
    }

    // Test 3: Multiple imports from same module
    println("\n=== Test 3: Multiple Symbol Import ===")
    // Both assertEquals and assertTrue should work
    assertEquals(2 + 2, 4, "Addition works")
    assertTrue(1 < 2, "Comparison works")
    println("PASS: Multiple symbols from same import work")
    passed = passed + 1

    // Summary
    println("\n==================================================")
    println("Module Import Results: " + passed.toString() + "/" + (passed + failed).toString())
    println("==================================================")

    if failed > 0 {
        println("FAIL: Some import tests failed")
        return 1
    }

    println("PASS: All module import tests passed!")
    return 0
}
