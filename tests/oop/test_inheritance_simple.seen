// OOP Inheritance Test (Simplified to avoid String bug)
// Tests: class extension, method override, virtual dispatch with Int returns
// Expected: Inheritance features work correctly

class Shape {
    var x: Int
    var y: Int

    static fun new(x: Int, y: Int) r: Shape {
        return Shape { x: x, y: y }
    }

    fun getX() r: Int {
        return x
    }

    fun getY() r: Int {
        return y
    }

    fun area() r: Int {
        return 0  // Base implementation
    }
}

class Rectangle extends Shape {
    var width: Int
    var height: Int

    static fun new(x: Int, y: Int, width: Int, height: Int) r: Rectangle {
        return Rectangle { x: x, y: y, width: width, height: height }
    }

    override fun area() r: Int {
        return width * height
    }

    fun getWidth() r: Int {
        return width
    }

    fun getHeight() r: Int {
        return height
    }
}

class Circle extends Shape {
    var radius: Int

    static fun new(x: Int, y: Int, radius: Int) r: Circle {
        return Circle { x: x, y: y, radius: radius }
    }

    override fun area() r: Int {
        return radius * radius * 3  // Approximation: π ≈ 3
    }

    fun getRadius() r: Int {
        return radius
    }
}

fun main() r: Int {
    println("Testing OOP Inheritance (Simplified)...")

    var passed = 0
    var failed = 0

    // Test 1: Base class instantiation
    println("\n=== Test 1: Base Class ===")
    let shape = Shape.new(10, 20)
    if shape.getX() == 10 and shape.getY() == 20 {
        println("PASS: Base class works")
        passed = passed + 1
    } else {
        println("FAIL: Base class incorrect")
        failed = failed + 1
    }

    // Test 2: Derived class instantiation
    println("\n=== Test 2: Derived Class (Rectangle) ===")
    let rect = Rectangle.new(0, 0, 5, 10)
    if rect.getX() == 0 and rect.getY() == 0 and rect.getWidth() == 5 and rect.getHeight() == 10 {
        println("PASS: Rectangle instantiated correctly")
        passed = passed + 1
    } else {
        println("FAIL: Rectangle instantiation failed")
        failed = failed + 1
    }

    // Test 3: Inherited methods
    println("\n=== Test 3: Inherited Methods ===")
    if rect.getX() == 0 and rect.getY() == 0 {
        println("PASS: Inherited methods work")
        passed = passed + 1
    } else {
        println("FAIL: Inherited methods failed")
        failed = failed + 1
    }

    // Test 4: Method override
    println("\n=== Test 4: Method Override ===")
    let rectArea = rect.area()
    if rectArea == 50 {
        println("PASS: Rectangle area override works")
        passed = passed + 1
    } else {
        println("FAIL: Rectangle area = " + rectArea.toString() + " expected 50")
        failed = failed + 1
    }

    // Test 5: Base class area
    println("\n=== Test 5: Base Class Method ===")
    if shape.area() == 0 {
        println("PASS: Base class area works")
        passed = passed + 1
    } else {
        println("FAIL: Base class area failed")
        failed = failed + 1
    }

    // Test 6: Second derived class
    println("\n=== Test 6: Second Derived Class (Circle) ===")
    let circle = Circle.new(5, 5, 10)
    if circle.getRadius() == 10 {
        println("PASS: Circle instantiated correctly")
        passed = passed + 1
    } else {
        println("FAIL: Circle instantiation failed")
        failed = failed + 1
    }

    // Test 7: Circle override
    println("\n=== Test 7: Circle Override ===")
    let circleArea = circle.area()
    if circleArea == 300 {
        println("PASS: Circle area override works")
        passed = passed + 1
    } else {
        println("FAIL: Circle area = " + circleArea.toString() + " expected 300")
        failed = failed + 1
    }

    // Test 8: Inherited methods on Circle
    println("\n=== Test 8: Circle Inherited Methods ===")
    if circle.getX() == 5 and circle.getY() == 5 {
        println("PASS: Circle inherited methods work")
        passed = passed + 1
    } else {
        println("FAIL: Circle inherited methods failed")
        failed = failed + 1
    }

    // Test 9: Polymorphism
    println("\n=== Test 9: Polymorphism ===")
    if shape.area() == 0 and rect.area() == 50 and circle.area() == 300 {
        println("PASS: Polymorphism works (virtual dispatch)")
        passed = passed + 1
    } else {
        println("FAIL: Polymorphism failed")
        failed = failed + 1
    }

    // Test 10: Derived-specific methods
    println("\n=== Test 10: Derived-Specific Methods ===")
    if rect.getWidth() == 5 and rect.getHeight() == 10 and circle.getRadius() == 10 {
        println("PASS: Derived-specific methods work")
        passed = passed + 1
    } else {
        println("FAIL: Derived-specific methods failed")
        failed = failed + 1
    }

    // Summary
    println("\n==================================================")
    println("OOP Inheritance Results: " + passed.toString() + "/" + (passed + failed).toString())
    println("==================================================")

    if failed > 0 {
        println("FAIL: Some inheritance tests failed")
        return 1
    }

    println("PASS: All OOP inheritance tests passed!")
    return 0
}
