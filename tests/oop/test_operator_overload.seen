// OOP Operator Overloading Test
// Tests: arithmetic operators, comparison operators on custom types
// Expected: Operator overloading works correctly

class Vector2D {
    var x: Int
    var y: Int

    static fun new(x: Int, y: Int) r: Vector2D {
        return Vector2D { x: x, y: y }
    }

    fun add(other: Vector2D) r: Vector2D {
        return Vector2D.new(x + other.x, y + other.y)
    }

    fun subtract(other: Vector2D) r: Vector2D {
        return Vector2D.new(x - other.x, y - other.y)
    }

    fun multiply(scalar: Int) r: Vector2D {
        return Vector2D.new(x * scalar, y * scalar)
    }

    fun equals(other: Vector2D) r: Bool {
        return x == other.x and y == other.y
    }

    fun magnitude() r: Int {
        return x * x + y * y
    }

    fun greaterThan(other: Vector2D) r: Bool {
        return this.magnitude() > other.magnitude()
    }

    fun lessThan(other: Vector2D) r: Bool {
        return this.magnitude() < other.magnitude()
    }
}

class Fraction {
    var numerator: Int
    var denominator: Int

    static fun new(num: Int, den: Int) r: Fraction {
        return Fraction { numerator: num, denominator: den }
    }

    fun add(other: Fraction) r: Fraction {
        let num = numerator * other.denominator + other.numerator * denominator
        let den = denominator * other.denominator
        return Fraction.new(num, den)
    }

    fun multiply(other: Fraction) r: Fraction {
        return Fraction.new(numerator * other.numerator, denominator * other.denominator)
    }

    fun equals(other: Fraction) r: Bool {
        return numerator * other.denominator == other.numerator * denominator
    }

    fun toFloat() r: Float {
        return numerator.toFloat() / denominator.toFloat()
    }
}

fun main() r: Int {
    println("Testing OOP Operator Overloading...")

    var passed = 0
    var failed = 0

    // Test 1: Vector addition
    println("\n=== Test 1: Vector Addition ===")
    let v1 = Vector2D.new(3, 4)
    let v2 = Vector2D.new(1, 2)
    let v3 = v1.add(v2)
    if v3.x == 4 and v3.y == 6 {
        println("PASS: Vector addition works")
        passed = passed + 1
    } else {
        println("FAIL: Vector addition failed")
        failed = failed + 1
    }

    // Test 2: Vector subtraction
    println("\n=== Test 2: Vector Subtraction ===")
    let v4 = v1.subtract(v2)
    if v4.x == 2 and v4.y == 2 {
        println("PASS: Vector subtraction works")
        passed = passed + 1
    } else {
        println("FAIL: Vector subtraction failed")
        failed = failed + 1
    }

    // Test 3: Scalar multiplication
    println("\n=== Test 3: Scalar Multiplication ===")
    let v5 = v1.multiply(2)
    if v5.x == 6 and v5.y == 8 {
        println("PASS: Scalar multiplication works")
        passed = passed + 1
    } else {
        println("FAIL: Scalar multiplication failed")
        failed = failed + 1
    }

    // Test 4: Equality comparison
    println("\n=== Test 4: Equality Comparison ===")
    let v6 = Vector2D.new(3, 4)
    if v1.equals(v6) and not v1.equals(v2) {
        println("PASS: Equality comparison works")
        passed = passed + 1
    } else {
        println("FAIL: Equality comparison failed")
        failed = failed + 1
    }

    // Test 5: Magnitude comparison
    println("\n=== Test 5: Magnitude Comparison ===")
    if v1.greaterThan(v2) and v2.lessThan(v1) {
        println("PASS: Magnitude comparison works")
        passed = passed + 1
    } else {
        println("FAIL: Magnitude comparison failed")
        failed = failed + 1
    }

    // Test 6: Fraction addition
    println("\n=== Test 6: Fraction Addition ===")
    let f1 = Fraction.new(1, 2)
    let f2 = Fraction.new(1, 3)
    let f3 = f1.add(f2)
    // 1/2 + 1/3 = 3/6 + 2/6 = 5/6
    if f3.numerator == 5 and f3.denominator == 6 {
        println("PASS: Fraction addition works")
        passed = passed + 1
    } else {
        println("FAIL: Fraction addition = " + f3.numerator.toString() + "/" + f3.denominator.toString())
        failed = failed + 1
    }

    // Test 7: Fraction multiplication
    println("\n=== Test 7: Fraction Multiplication ===")
    let f4 = f1.multiply(f2)
    // 1/2 * 1/3 = 1/6
    if f4.numerator == 1 and f4.denominator == 6 {
        println("PASS: Fraction multiplication works")
        passed = passed + 1
    } else {
        println("FAIL: Fraction multiplication failed")
        failed = failed + 1
    }

    // Test 8: Fraction equality
    println("\n=== Test 8: Fraction Equality ===")
    let f5 = Fraction.new(2, 4)
    if f1.equals(f5) {
        println("PASS: Fraction equality works (1/2 == 2/4)")
        passed = passed + 1
    } else {
        println("FAIL: Fraction equality failed (known issue)")
        failed = failed + 1
    }

    // Test 9: Chained operations
    println("\n=== Test 9: Chained Operations ===")
    let v7 = v1.add(v2).multiply(2)
    if v7.x == 8 and v7.y == 12 {
        println("PASS: Chained operations work")
        passed = passed + 1
    } else {
        println("FAIL: Chained operations failed")
        failed = failed + 1
    }

    // Test 10: Complex expression
    println("\n=== Test 10: Complex Expression ===")
    let v8 = v1.add(v2).subtract(v4)
    if v8.x == 2 and v8.y == 4 {
        println("PASS: Complex expressions work")
        passed = passed + 1
    } else {
        println("FAIL: Complex expressions failed")
        failed = failed + 1
    }

    // Summary
    println("\n==================================================")
    println("OOP Operator Overloading Results: " + passed.toString() + "/" + (passed + failed).toString())
    println("==================================================")

    if failed > 0 {
        println("FAIL: Some operator overloading tests failed")
        return 1
    }

    println("PASS: All OOP operator overloading tests passed!")
    return 0
}
