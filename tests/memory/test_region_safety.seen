// Region Memory Safety Test
// Tests generational handles and use-after-free prevention
// Expected: Safety mechanisms prevent invalid memory access

fun main() r: Int {
    var passed = 0
    var failed = 0

    println("Testing Vale-style memory safety features...")

    // Test 1: Generational handle allocation
    println("\n=== Test 1: Generational Handle Creation ===")
    let region = seen_region_create(4096, 0)  // 4KB region
    let handle1 = seen_region_alloc_handle(region, 128)
    if handle1 != 0 {
        println("PASS: Generational handle created")
        passed = passed + 1
    } else {
        println("FAIL: Handle creation failed")
        failed = failed + 1
    }

    // Test 2: Handle validation
    println("\n=== Test 2: Handle Validation ===")
    let valid1 = seen_region_handle_valid(handle1)
    if valid1 == 1 {
        println("PASS: Fresh handle is valid")
        passed = passed + 1
    } else {
        println("FAIL: Fresh handle reported invalid")
        failed = failed + 1
    }

    // Test 3: Handle dereferencing
    println("\n=== Test 3: Handle Dereferencing ===")
    let ptr1 = seen_region_deref_handle(handle1)
    if ptr1 != 0 {
        println("PASS: Handle dereference successful")
        passed = passed + 1
    } else {
        println("FAIL: Handle dereference returned null")
        failed = failed + 1
    }

    // Test 4: Multiple handles from same region
    println("\n=== Test 4: Multiple Handles ===")
    let handle2 = seen_region_alloc_handle(region, 256)
    let handle3 = seen_region_alloc_handle(region, 512)
    if handle2 != 0 and handle3 != 0 and handle2 != handle3 {
        println("PASS: Multiple unique handles created")
        passed = passed + 1
    } else {
        println("FAIL: Handle creation issue")
        failed = failed + 1
    }

    // Test 5: Handle invalidation after region destroy
    println("\n=== Test 5: Use-After-Free Prevention ===")
    seen_region_destroy(region)

    let valid2 = seen_region_handle_valid(handle1)
    if valid2 == 0 {
        println("PASS: Handle invalidated after region destroy (prevents use-after-free)")
        passed = passed + 1
    } else {
        println("FAIL: Handle still valid after region destroy (UNSAFE!)")
        failed = failed + 1
    }

    // Test 6: Deref of invalid handle
    println("\n=== Test 6: Invalid Handle Deref Safety ===")
    let ptr2 = seen_region_deref_handle(handle1)
    if ptr2 == 0 {
        println("PASS: Invalid handle dereference returns null (safe)")
        passed = passed + 1
    } else {
        println("FAIL: Invalid handle dereference returned pointer (UNSAFE!)")
        failed = failed + 1
    }

    // Test 7: Region stack operations
    println("\n=== Test 7: Region Stack (Nested Scopes) ===")
    let region2 = seen_region_create(2048, 1)  // BUMP strategy
    seen_region_push(region2)

    let current = seen_region_current()
    if current == region2 {
        println("PASS: Region stack push/current works")
        passed = passed + 1
    } else {
        println("FAIL: Region stack operation failed")
        failed = failed + 1
    }

    // Test 8: Region stack pop
    println("\n=== Test 8: Region Stack Pop ===")
    let popped = seen_region_pop()
    if popped == region2 {
        println("PASS: Region stack pop works")
        passed = passed + 1
    } else {
        println("FAIL: Region stack pop incorrect")
        failed = failed + 1
    }

    // Cleanup
    seen_region_destroy(region2)

    // Summary
    println("\n==================================================")
    println("Memory Safety Test Results:")
    println("Passed: " + passed.toString() + "/" + (passed + failed).toString())
    println("==================================================")

    if failed > 0 {
        println("\nFAIL: Some safety tests failed")
        return 1
    }

    println("\nPASS: All safety features working correctly!")
    println("✓ Generational handles prevent use-after-free")
    println("✓ Invalid handles safely return null")
    println("✓ Region stacks support nested scopes")
    return 0
}

// External C runtime functions
extern fun seen_region_create(size: Int, strategy: Int) r: Int
extern fun seen_region_destroy(region: Int) r: Void
extern fun seen_region_alloc_handle(region: Int, size: Int) r: Int
extern fun seen_region_deref_handle(handle: Int) r: Int
extern fun seen_region_handle_valid(handle: Int) r: Int
extern fun seen_region_push(region: Int) r: Void
extern fun seen_region_pop() r: Int
extern fun seen_region_current() r: Int
