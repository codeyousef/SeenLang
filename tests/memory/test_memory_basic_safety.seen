// Basic Memory Safety Test
// Tests fundamental memory safety without triggering compiler bugs
// Verifies: allocation, access, no corruption

fun testSimpleArraySafety() r: Bool {
    println("Test 1: Simple Array Safety")

    let arr = Array<Int>()
    arr.push(10)
    arr.push(20)
    arr.push(30)

    if arr[0] == 10 and arr[1] == 20 and arr[2] == 30 {
        println("  PASS: Array values correct, no corruption")
        return true
    }

    println("  FAIL: Array corruption detected")
    return false
}

fun testStringNoCorruption() r: Bool {
    println("Test 2: String Memory Safety")

    let s1 = "Hello"
    let s2 = "World"

    if s1 == "Hello" and s2 == "World" {
        println("  PASS: Strings preserved, no corruption")
        return true
    }

    println("  FAIL: String corruption detected")
    return false
}

fun testMultipleAllocations() r: Bool {
    println("Test 3: Multiple Independent Allocations")

    let arr1 = Array<Int>()
    arr1.push(1)
    arr1.push(2)

    let arr2 = Array<Int>()
    arr2.push(10)
    arr2.push(20)

    let arr3 = Array<Int>()
    arr3.push(100)
    arr3.push(200)

    // Verify all arrays have correct independent data
    if arr1[0] == 1 and arr2[0] == 10 and arr3[0] == 100 {
        println("  PASS: Multiple allocations isolated, no cross-corruption")
        return true
    }

    println("  FAIL: Cross-corruption between allocations")
    return false
}

fun testLargeArray() r: Bool {
    println("Test 4: Large Allocation")

    let bigArr = Array<Int>()
    var i = 0
    while i < 500 {
        bigArr.push(i)
        i = i + 1
    }

    if bigArr[0] == 0 and bigArr[250] == 250 and bigArr[499] == 499 {
        println("  PASS: Large array allocated and accessed safely")
        return true
    }

    println("  FAIL: Large array corruption")
    return false
}

fun testSequentialAllocation() r: Bool {
    println("Test 5: Sequential Allocation and Reuse")

    var iteration = 0
    var allPassed = true

    while iteration < 5 {
        let temp = Array<Int>()
        temp.push(iteration)

        if temp[0] != iteration {
            allPassed = false
        }

        iteration = iteration + 1
    }

    if allPassed {
        println("  PASS: Sequential allocations safe, no corruption")
        return true
    }

    println("  FAIL: Sequential allocation corruption")
    return false
}

fun testStringConcatenation() r: Bool {
    println("Test 6: String Operations Safety")

    let a = "Test"
    let b = "ing"

    // Just verify strings don't corrupt
    if a == "Test" and b == "ing" {
        println("  PASS: String operations safe")
        return true
    }

    println("  FAIL: String operation corruption")
    return false
}

fun testIntegerPreservation() r: Bool {
    println("Test 7: Integer Value Preservation")

    var x = 42
    var y = 100
    var z = 999

    let arr = Array<Int>()
    arr.push(10)
    arr.push(20)

    // Verify integers not corrupted by array allocation
    if x == 42 and y == 100 and z == 999 {
        println("  PASS: Integer values preserved across allocations")
        return true
    }

    println("  FAIL: Integer corruption")
    return false
}

fun main() r: Int {
    println("==================================================")
    println("Memory Safety - Runtime Verification")
    println("==================================================")

    var passed = 0
    var failed = 0

    if testSimpleArraySafety() { passed = passed + 1 } else { failed = failed + 1 }
    if testStringNoCorruption() { passed = passed + 1 } else { failed = failed + 1 }
    if testMultipleAllocations() { passed = passed + 1 } else { failed = failed + 1 }
    if testLargeArray() { passed = passed + 1 } else { failed = failed + 1 }
    if testSequentialAllocation() { passed = passed + 1 } else { failed = failed + 1 }
    if testStringConcatenation() { passed = passed + 1 } else { failed = failed + 1 }
    if testIntegerPreservation() { passed = passed + 1 } else { failed = failed + 1 }

    println("")
    println("==================================================")
    println("Results: " + passed.toString() + "/" + (passed + failed).toString() + " passed")
    println("==================================================")

    if failed > 0 {
        println("FAIL: Memory safety issues detected")
        return 1
    }

    println("")
    println("SUCCESS! Memory Safety Verified:")
    println("- Array allocations safe")
    println("- No memory corruption")
    println("- Multiple allocations isolated")
    println("- Large allocations work")
    println("- Sequential reuse safe")
    println("- String operations safe")
    println("- Values preserved across allocations")
    println("")

    return 0
}
