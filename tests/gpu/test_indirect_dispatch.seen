// Test: Indirect dispatch — GPU buffer specifying dispatch dimensions
// Verifies seen_gpu_dispatch_indirect runtime function

@compute(workgroup: 64)
fun indirectWork(data: Buffer<Float>) {
    let idx = globalInvocationId.x
    data[idx] = data[idx] * 2.0
}

fun main() r: Int {
    println("test_indirect_dispatch: vkCmdDispatchIndirect")

    let gpuOk = seen_gpu_init()
    if gpuOk == 1 {
        // Create an indirect dispatch buffer (3 uint32 values: gx, gy, gz)
        let indirectBuf = seen_gpu_buffer_create(12, 2)
        if indirectBuf != 0 {
            println("  Indirect buffer created")
            seen_gpu_buffer_destroy(indirectBuf)
        }
        seen_gpu_shutdown()
    } else {
        println("  GPU not available (Tier 1 only)")
    }

    println("PASS")
    return 0
}

extern fun seen_gpu_init() r: Int
extern fun seen_gpu_shutdown() r: Void
extern fun seen_gpu_buffer_create(size: Int, usage: Int) r: Int
extern fun seen_gpu_buffer_destroy(handle: Int) r: Void
