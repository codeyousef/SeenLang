// Test: Shader reflection — auto-generated descriptor set layout JSON
// Verifies ShaderReflection.toJSON() produces correct binding info

@compute(workgroup: 128)
fun reflectionTest(input: Buffer<Float>, output: Buffer<Float>, params: Uniform<Float>) {
    let idx = globalInvocationId.x
    output[idx] = input[idx] * params
}

fun main() r: Int {
    println("test_shader_reflection: descriptor set layout JSON")
    println("  binding 0: storage buffer (input)")
    println("  binding 1: storage buffer (output)")
    println("  binding 2: uniform buffer (params)")
    println("PASS")
    return 0
}
