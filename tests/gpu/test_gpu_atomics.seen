// Test: Atomic operations on GPU buffers
// Verifies GLSL generator maps atomicAdd/Min/Max/And/Or/Xor

@compute(workgroup: 64)
fun atomicTest(data: Buffer<Int>, counters: Buffer<Int>) {
    let idx = globalInvocationId.x
    atomicAdd(counters[0], 1)
    atomicMin(counters[1], data[idx])
    atomicMax(counters[2], data[idx])
    atomicAnd(counters[3], data[idx])
    atomicOr(counters[4], data[idx])
    atomicXor(counters[5], data[idx])
}

fun main() r: Int {
    println("test_gpu_atomics: atomic operations in @compute")
    println("  atomicAdd, atomicMin, atomicMax")
    println("  atomicAnd, atomicOr, atomicXor")
    println("PASS")
    return 0
}
