// E2Eテスト: 環境標準ライブラリ（日本語）
// 注: 引数()(args)はランタイムに未定義 → リンカエラーになる
// 動作するその他の環境機能をテスト:
//   - 文字列変換（文字列化）
//   - 整数解析と基本プログラム動作
//   - プログラムのエントリーポイントと終了コード

関数 メイン() r: 整数 {
    // テスト1: プログラムの実行と終了コード
    定数 終了コード = 0
    もし 終了コード == 0 {
        表示("成功: プログラムの起動と終了")
    } そうでなければ {
        表示("失敗: プログラムの起動と終了")
        戻る 1
    }

    // テスト2: 整数から文字列への変換
    定数 数値 = 12345
    定数 数値文字列 = 数値.文字列化()
    もし 数値文字列 == "12345" {
        表示("成功: 整数の文字列化")
    } そうでなければ {
        表示("失敗: 整数の文字列化")
        戻る 1
    }

    // テスト3: 負の整数から文字列への変換
    定数 負数 = -42
    定数 負数文字列 = 負数.文字列化()
    もし 負数文字列 == "-42" {
        表示("成功: 負の整数の文字列化")
    } そうでなければ {
        表示("失敗: 負の整数の文字列化")
        戻る 1
    }

    // テスト4: 文字列連結と整数変換
    定数 メッセージ = "数=" + 数値.文字列化()
    もし メッセージ == "数=12345" {
        表示("成功: 文字列連結と文字列化")
    } そうでなければ {
        表示("失敗: 文字列連結と文字列化")
        戻る 1
    }

    // テスト5: 複数回の表示（基本入出力）
    表示("成功: 複数回の表示呼び出し")

    表示("成功: 全環境ライブラリテスト合格")
    戻る 0
}
