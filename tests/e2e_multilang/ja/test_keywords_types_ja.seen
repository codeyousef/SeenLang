///
E2Eテスト: 型キーワード（日本語）
テスト対象: クラス, 列挙
注: トレイト+実装にコード生成バグ（thisパラメータ欠落）-- 省略
注: 継承（継承キーワード）に継承フィールド代入バグ -- 省略
注: 非ASCII名の複数フィールドにstructIdxバグ -- 単一Intフィールド使用
///

列挙 色 {
    赤,
    緑,
    青
}

クラス 計数器 {
    変数 数値: 整数

    関数 取得() r: 整数 {
        戻る これ.数値
    }
}

関数 計数器作成(値: 整数) r: 計数器 {
    変数 器 = 計数器()
    器.数値 = 値
    戻る 器
}

関数 メイン() r: 整数 {
    // テスト1: 列挙等価性
    定数 色1 = 色.赤
    定数 色2 = 色.赤
    もし 色1 == 色2 {
        表示("成功: 列挙等価性")
    } そうでなければ {
        表示("失敗: 列挙等価性")
        戻る 1
    }

    // テスト2: 列挙不等価性
    定数 色3 = 色.青
    もし 色1 != 色3 {
        表示("成功: 列挙不等価性")
    } そうでなければ {
        表示("失敗: 列挙不等価性")
        戻る 1
    }

    // テスト3: クラス（単一Intフィールド + メソッド）
    定数 器1 = 計数器作成(42)
    もし 器1.取得() == 42 {
        表示("成功: クラスメソッド")
    } そうでなければ {
        表示("失敗: クラスメソッド")
        戻る 1
    }

    // テスト4: 基本型
    定数 値 = 100
    もし 値 == 100 {
        表示("成功: 基本型")
    } そうでなければ {
        表示("失敗: 基本型")
        戻る 1
    }

    表示("成功: 全型キーワードテスト合格")
    戻る 0
}
