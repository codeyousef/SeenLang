///
E2Eテスト: 入出力標準ライブラリ（日本語）
注: __WriteFileは非ASCIIバイトを二重UTF-8エンコードする -- ASCII内容で検証
注: __ReadFileはSeenStringを返すが、コード生成がi64として扱う →
    内容の比較不可。__FileSizeで代わりに検証
///

関数 メイン() r: 整数 {
    定数 パス = "/tmp/seen_e2e_test_ja.txt"
    定数 内容 = "hello from seen e2e test"

    // テスト1: 書込用にファイルを開く
    定数 記述子1 = __OpenFile(パス, "w")
    もし 記述子1 < 0 {
        表示("失敗: 書込用ファイルオープン")
        戻る 1
    }
    表示("成功: 書込用ファイルオープン")

    // テスト2: 内容を書き込む
    定数 書込結果 = __WriteFile(記述子1, 内容)
    定数 閉結果1 = __CloseFile(記述子1)
    もし 書込結果 >= 0 {
        表示("成功: ファイル書込")
    } そうでなければ {
        表示("失敗: ファイル書込")
        戻る 1
    }

    // テスト3: ファイルの存在確認
    もし __FileExists(パス) {
        表示("成功: ファイル存在確認")
    } そうでなければ {
        表示("失敗: ファイル存在確認")
        戻る 1
    }

    // テスト4: サイズ検証（ASCII文字列は1文字1バイト）
    定数 記述子2 = __OpenFile(パス, "r")
    もし 記述子2 < 0 {
        表示("失敗: 読込用ファイルオープン")
        戻る 1
    }
    定数 サイズ = __FileSize(記述子2)
    定数 閉結果2 = __CloseFile(記述子2)
    もし サイズ == 24 {
        表示("成功: ファイルサイズが内容長と一致")
    } そうでなければ {
        表示("失敗: ファイルサイズ、結果=" + サイズ.文字列化())
        戻る 1
    }

    // テスト5: ファイル削除
    __DeleteFile(パス)
    もし __FileExists(パス) {
        表示("失敗: ファイル削除（ファイルがまだ存在する）")
        戻る 1
    } そうでなければ {
        表示("成功: ファイル削除")
    }

    表示("成功: 全入出力ライブラリテスト合格")
    戻る 0
}
