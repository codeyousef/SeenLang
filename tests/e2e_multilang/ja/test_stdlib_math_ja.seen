///
E2Eテスト: 数学演算（日本語）
注: 浮動小数点の標準ライブラリ関数（平方根、正弦、余弦、絶対値、切り捨て、切り上げ、累乗）は
    コード生成バグでi64を返すため、整数演算のみをテスト
注: %（剰余）はバグあり → a - (a/b)*b で代用
///

関数 メイン() r: 整数 {
    // テスト1: 整数の絶対値（条件分岐による）
    変数 甲 = -5
    もし 甲 < 0 {
        甲 = 0 - 甲
    }
    もし 甲 == 5 {
        表示("成功: 整数の絶対値")
    } そうでなければ {
        表示("失敗: 整数の絶対値")
        戻る 1
    }

    // テスト2: 整数の最小値（比較による）
    定数 乙 = 10
    定数 丙 = 20
    変数 最小 = 乙
    もし 丙 < 乙 {
        最小 = 丙
    }
    もし 最小 == 10 {
        表示("成功: 整数の最小値")
    } そうでなければ {
        表示("失敗: 整数の最小値")
        戻る 1
    }

    // テスト3: 整数の最大値（比較による）
    変数 最大 = 乙
    もし 丙 > 乙 {
        最大 = 丙
    }
    もし 最大 == 20 {
        表示("成功: 整数の最大値")
    } そうでなければ {
        表示("失敗: 整数の最大値")
        戻る 1
    }

    // テスト4: 整数の累乗（2^10=1024、ループによる）
    変数 結果 = 1
    変数 回数 = 0
    間 回数 < 10 {
        結果 = 結果 * 2
        回数 = 回数 + 1
    }
    もし 結果 == 1024 {
        表示("成功: 整数の累乗 2^10")
    } そうでなければ {
        表示("失敗: 整数の累乗 2^10、結果=" + 結果.文字列化())
        戻る 1
    }

    // テスト5: 剰余の代用（%はバグあり）
    定数 被除数 = 17
    定数 除数 = 5
    定数 余り = 被除数 - (被除数 / 除数) * 除数
    もし 余り == 2 {
        表示("成功: 整数の剰余代用")
    } そうでなければ {
        表示("失敗: 整数の剰余代用、結果=" + 余り.文字列化())
        戻る 1
    }

    // テスト6: 整数の除算
    定数 除算結果 = 100 / 7
    もし 除算結果 == 14 {
        表示("成功: 整数の除算")
    } そうでなければ {
        表示("失敗: 整数の除算、結果=" + 除算結果.文字列化())
        戻る 1
    }

    // テスト7: 負の数
    定数 負数 = 0 - 42
    もし 負数 == -42 {
        表示("成功: 負の数")
    } そうでなければ {
        表示("失敗: 負の数")
        戻る 1
    }

    // テスト8: 演算の優先順位（乗算は加算より先）
    定数 式 = 2 + 3 * 4
    もし 式 == 14 {
        表示("成功: 演算の優先順位")
    } そうでなければ {
        表示("失敗: 演算の優先順位、結果=" + 式.文字列化())
        戻る 1
    }

    // テスト9: 括弧付き式
    定数 括弧式 = (2 + 3) * 4
    もし 括弧式 == 20 {
        表示("成功: 括弧付き式")
    } そうでなければ {
        表示("失敗: 括弧付き式、結果=" + 括弧式.文字列化())
        戻る 1
    }

    // テスト10: 連鎖した乗算
    定数 連鎖 = 2 * 3 * 4
    もし 連鎖 == 24 {
        表示("成功: 連鎖した乗算")
    } そうでなければ {
        表示("失敗: 連鎖した乗算、結果=" + 連鎖.文字列化())
        戻る 1
    }

    表示("成功: 全数学テスト合格")
    戻る 0
}
