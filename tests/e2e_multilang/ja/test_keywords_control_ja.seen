// E2Eテスト: 制御フローキーワード（日本語）
// テスト対象: 関数, もし, そうでなければ, 間, 中止, 継続, 戻る, 繰返

関数 足し算(甲: 整数, 乙: 整数) r: 整数 {
    戻る 甲 + 乙
}

関数 符号反転(値: 整数) r: 整数 {
    戻る 0 - 値
}

関数 メイン() r: 整数 {
    // テスト1: 関数 + 戻る
    定数 結果 = 足し算(3, 4)
    もし 結果 == 7 {
        表示("成功: 関数+戻る")
    } そうでなければ {
        表示("失敗: 関数+戻る")
        戻る 1
    }

    // テスト2: もし + そうでなければ
    定数 反転値 = 符号反転(5)
    もし 反転値 == -5 {
        表示("成功: もし+そうでなければ")
    } そうでなければ {
        表示("失敗: もし+そうでなければ")
        戻る 1
    }

    // テスト3: 間 + 中止
    変数 回数 = 0
    間 回数 < 100 {
        もし 回数 == 5 {
            中止
        }
        回数 = 回数 + 1
    }
    もし 回数 == 5 {
        表示("成功: 間+中止")
    } そうでなければ {
        表示("失敗: 間+中止")
        戻る 1
    }

    // テスト4: 間 + 継続（奇数の合計 1..10）
    変数 合計 = 0
    変数 番号 = 0
    間 番号 < 10 {
        番号 = 番号 + 1
        定数 余り = 番号 - (番号 / 2) * 2
        もし 余り == 0 {
            継続
        }
        合計 = 合計 + 番号
    }
    もし 合計 == 25 {
        表示("成功: 間+継続")
    } そうでなければ {
        表示("失敗: 間+継続、結果=" + 合計.文字列化())
        戻る 1
    }

    // テスト5: 繰返 + 中止
    変数 計数 = 0
    繰返 {
        計数 = 計数 + 1
        もし 計数 == 3 {
            中止
        }
    }
    もし 計数 == 3 {
        表示("成功: 繰返+中止")
    } そうでなければ {
        表示("失敗: 繰返+中止")
        戻る 1
    }

    // テスト6: 入れ子の間ループ
    変数 外側 = 0
    変数 合計値 = 0
    間 外側 < 3 {
        変数 内側 = 0
        間 内側 < 4 {
            合計値 = 合計値 + 1
            内側 = 内側 + 1
        }
        外側 = 外側 + 1
    }
    もし 合計値 == 12 {
        表示("成功: 入れ子の間")
    } そうでなければ {
        表示("失敗: 入れ子の間")
        戻る 1
    }

    // テスト7: 入れ子からの戻る
    定数 入れ子結果 = 足し算(足し算(1, 2), 足し算(3, 4))
    もし 入れ子結果 == 10 {
        表示("成功: 入れ子の戻る")
    } そうでなければ {
        表示("失敗: 入れ子の戻る")
        戻る 1
    }

    表示("成功: 全制御フローテスト合格")
    戻る 0
}
