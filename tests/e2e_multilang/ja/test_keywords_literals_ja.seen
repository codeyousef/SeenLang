///
E2Eテスト: リテラルキーワード（日本語）
テスト対象: 真, 偽, 空
///

関数 正数判定(数: 整数) r: 整数 {
    もし 数 > 0 {
        戻る 1
    }
    戻る 0
}

関数 メイン() r: 整数 {
    // テスト1: 真（条件式で使用）
    変数 旗 = 0
    もし 真 {
        旗 = 1
    }
    もし 旗 == 1 {
        表示("成功: 真リテラル")
    } そうでなければ {
        表示("失敗: 真リテラル")
        戻る 1
    }

    // テスト2: 偽（条件式で使用）
    変数 旗2 = 1
    もし 偽 {
        旗2 = 0
    }
    もし 旗2 == 1 {
        表示("成功: 偽リテラル")
    } そうでなければ {
        表示("失敗: 偽リテラル")
        戻る 1
    }

    // テスト3: 真 且つ 真
    変数 結果 = 0
    もし 真 且つ 真 {
        結果 = 1
    }
    もし 結果 == 1 {
        表示("成功: 真且つ真")
    } そうでなければ {
        表示("失敗: 真且つ真")
        戻る 1
    }

    // テスト4: 真 且つ 偽
    変数 結果2 = 1
    もし 真 且つ 偽 {
        結果2 = 0
    }
    もし 結果2 == 1 {
        表示("成功: 真且つ偽")
    } そうでなければ {
        表示("失敗: 真且つ偽")
        戻る 1
    }

    // テスト5: 非 偽
    変数 結果3 = 0
    もし 非 偽 {
        結果3 = 1
    }
    もし 結果3 == 1 {
        表示("成功: 非偽")
    } そうでなければ {
        表示("失敗: 非偽")
        戻る 1
    }

    // テスト6: 値の検証
    定数 正 = 正数判定(5)
    もし 正 == 1 {
        表示("成功: 非空値")
    } そうでなければ {
        表示("失敗: 非空値")
        戻る 1
    }

    定数 非正 = 正数判定(-3)
    もし 非正 == 0 {
        表示("成功: 零値")
    } そうでなければ {
        表示("失敗: 零値")
        戻る 1
    }

    表示("成功: 全リテラルキーワードテスト合格")
    戻る 0
}
