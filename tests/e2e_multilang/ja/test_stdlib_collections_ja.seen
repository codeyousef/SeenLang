// E2Eテスト: コレクション標準ライブラリ（日本語）
// テスト対象: Array<整数>, Array<文字列>, HashMap<文字列, 整数>
// 注: HashMap.設定()(put)は存在しない → insert()を使用
// 注: HashMap.取得()(get)はコード生成バグあり → getOrDefault()を使用
// 注: containsKey()はboolを返す → if条件で直接使用

関数 メイン() r: 整数 {
    // テスト1: Array<整数> 追加と取得
    変数 配列 = Array<整数>()
    配列.追加(10)
    配列.追加(20)
    配列.追加(30)
    もし 配列.長さ() == 3 {
        表示("成功: 配列の長さ")
    } そうでなければ {
        表示("失敗: 配列の長さ")
        戻る 1
    }

    定数 最初 = 配列.取得(0)
    もし 最初 == 10 {
        表示("成功: 配列.取得(0)")
    } そうでなければ {
        表示("失敗: 配列.取得(0)")
        戻る 1
    }

    定数 最後 = 配列.取得(2)
    もし 最後 == 30 {
        表示("成功: 配列.取得(2)")
    } そうでなければ {
        表示("失敗: 配列.取得(2)")
        戻る 1
    }

    // テスト2: Array<文字列>
    変数 名前列 = Array<文字列>()
    名前列.追加("こんにちは")
    名前列.追加("世界")
    もし 名前列.長さ() == 2 {
        表示("成功: 文字列配列の長さ")
    } そうでなければ {
        表示("失敗: 文字列配列の長さ")
        戻る 1
    }

    定数 先頭 = 名前列.取得(0)
    もし 先頭 == "こんにちは" {
        表示("成功: 文字列配列.取得")
    } そうでなければ {
        表示("失敗: 文字列配列.取得")
        戻る 1
    }

    // テスト3: HashMap<文字列, 整数>（insertを使用、putは存在しない）
    変数 辞書 = HashMap<文字列, 整数>()
    辞書.insert("甲", 1)
    辞書.insert("乙", 2)
    辞書.insert("丙", 3)

    // getOrDefaultを使用（getはコード生成バグあり）
    定数 甲の値 = 辞書.getOrDefault("甲", -1)
    もし 甲の値 == 1 {
        表示("成功: 辞書.getOrDefault 甲")
    } そうでなければ {
        表示("失敗: 辞書.getOrDefault 甲")
        戻る 1
    }

    定数 乙の値 = 辞書.getOrDefault("乙", -1)
    もし 乙の値 == 2 {
        表示("成功: 辞書.getOrDefault 乙")
    } そうでなければ {
        表示("失敗: 辞書.getOrDefault 乙")
        戻る 1
    }

    // テスト4: HashMap containsKey（boolを返す、if条件で直接使用）
    もし 辞書.containsKey("丙") {
        表示("成功: 辞書.containsKey")
    } そうでなければ {
        表示("失敗: 辞書.containsKey")
        戻る 1
    }

    // テスト5: HashMap size
    定数 大きさ = 辞書.size()
    もし 大きさ == 3 {
        表示("成功: 辞書.size")
    } そうでなければ {
        表示("失敗: 辞書.size、結果=" + 大きさ.文字列化())
        戻る 1
    }

    // テスト6: 存在しないキーはデフォルト値を返す
    定数 不在 = 辞書.getOrDefault("不存在", -999)
    もし 不在 == -999 {
        表示("成功: 辞書 不在キーのデフォルト値")
    } そうでなければ {
        表示("失敗: 辞書 不在キーのデフォルト値")
        戻る 1
    }

    表示("成功: 全コレクションテスト合格")
    戻る 0
}
