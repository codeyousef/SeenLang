// E2Eテスト: 文字列標準ライブラリ（日本語）
// テスト対象: 含む, で始まる, で終わる, 位置検索, .長さ()
// 注: 含む/で始まる/で終わるはboolを返す → if条件で直接使用（変数に格納しない）
// 注: 位置検索は3引数（文字列, 検索語, 開始位置）

関数 メイン() r: 整数 {
    定数 文 = "hello world"

    // テスト1: 文字列の長さ
    定数 文長 = 文.長さ()
    もし 文長 == 11 {
        表示("成功: 文字列の長さ")
    } そうでなければ {
        表示("失敗: 文字列の長さ、結果=" + 文長.文字列化())
        戻る 1
    }

    // テスト2: 含む（boolを返す、if条件で直接使用）
    もし 含む(文, "world") {
        表示("成功: 含む")
    } そうでなければ {
        表示("失敗: 含む")
        戻る 1
    }

    // テスト3: で始まる（boolを返す、if条件で直接使用）
    もし で始まる(文, "hello") {
        表示("成功: で始まる")
    } そうでなければ {
        表示("失敗: で始まる")
        戻る 1
    }

    // テスト4: で終わる（boolを返す、if条件で直接使用）
    もし で終わる(文, "world") {
        表示("成功: で終わる")
    } そうでなければ {
        表示("失敗: で終わる")
        戻る 1
    }

    // テスト5: 位置検索（3引数: 文字列, 検索語, 開始位置）
    定数 位置 = 位置検索(文, "world", 0)
    もし 位置 == 6 {
        表示("成功: 位置検索")
    } そうでなければ {
        表示("失敗: 位置検索、結果=" + 位置.文字列化())
        戻る 1
    }

    // テスト6: 文字列連結
    定数 挨拶 = "こんにちは" + " " + "世界"
    もし 挨拶 == "こんにちは 世界" {
        表示("成功: 文字列連結")
    } そうでなければ {
        表示("失敗: 文字列連結")
        戻る 1
    }

    // テスト7: 含む 否定ケース
    もし 含む(文, "xyz") {
        表示("失敗: 含む否定")
        戻る 1
    } そうでなければ {
        表示("成功: 含む否定")
    }

    // テスト8: 位置検索 見つからない場合は-1を返す
    定数 未発見 = 位置検索(文, "xyz", 0)
    もし 未発見 == -1 {
        表示("成功: 位置検索 見つからない")
    } そうでなければ {
        表示("失敗: 位置検索 見つからない、結果=" + 未発見.文字列化())
        戻る 1
    }

    表示("成功: 全文字列ライブラリテスト合格")
    戻る 0
}
