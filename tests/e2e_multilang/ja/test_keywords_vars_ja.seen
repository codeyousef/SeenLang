// E2Eテスト: 変数宣言キーワード（日本語）
// テスト対象: 定数, 変数
// 注: DSEが変数初期化を消去する場合あり -- 変数 x = A; x = B パターンを避ける

関数 メイン() r: 整数 {
    // テスト1: 定数（不変バインディング）
    定数 甲 = 42
    もし 甲 == 42 {
        表示("成功: 定数バインディング")
    } そうでなければ {
        表示("失敗: 定数バインディング")
        戻る 1
    }

    // テスト2: 変数（可変バインディング）
    変数 乙 = 25
    もし 乙 == 25 {
        表示("成功: 変数バインディング")
    } そうでなければ {
        表示("失敗: 変数バインディング")
        戻る 1
    }

    // テスト3: 定数で式を使用
    定数 丙 = 50 + 50
    もし 丙 == 100 {
        表示("成功: 定数式バインディング")
    } そうでなければ {
        表示("失敗: 定数式バインディング")
        戻る 1
    }

    // テスト4: 変数の加算変更
    変数 丁 = 10
    丁 = 丁 + 5
    もし 丁 == 15 {
        表示("成功: 変数加算変更")
    } そうでなければ {
        表示("失敗: 変数加算変更")
        戻る 1
    }

    // テスト5: 定数と変数の組み合わせ
    定数 一 = 1
    定数 二 = 2
    定数 三 = 3
    変数 四 = 一 + 二 + 三
    もし 四 == 6 {
        表示("成功: 定数と変数の組み合わせ")
    } そうでなければ {
        表示("失敗: 定数と変数の組み合わせ")
        戻る 1
    }

    // テスト6: 変数の合計
    変数 合計 = 1 + 2 + 3 + 4 + 5
    もし 合計 == 15 {
        表示("成功: 変数合計")
    } そうでなければ {
        表示("失敗: 変数合計")
        戻る 1
    }

    表示("成功: 全変数キーワードテスト合格")
    戻る 0
}
