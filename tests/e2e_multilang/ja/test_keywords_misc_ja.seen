///
E2Eテスト: その他のキーワード（日本語）
テスト対象: 且つ, 又は, 非, として, である
///

関数 メイン() r: 整数 {
    // テスト1: 且つ（論理積）
    変数 結果1 = 0
    もし 1 == 1 且つ 2 == 2 {
        結果1 = 1
    }
    もし 結果1 == 1 {
        表示("成功: 且つ演算子")
    } そうでなければ {
        表示("失敗: 且つ演算子")
        戻る 1
    }

    // テスト2: 又は（論理和）
    変数 結果2 = 0
    もし 1 == 2 又は 3 == 3 {
        結果2 = 1
    }
    もし 結果2 == 1 {
        表示("成功: 又は演算子")
    } そうでなければ {
        表示("失敗: 又は演算子")
        戻る 1
    }

    // テスト3: 非（論理否定）
    変数 結果3 = 0
    もし 非 偽 {
        結果3 = 1
    }
    もし 結果3 == 1 {
        表示("成功: 非演算子")
    } そうでなければ {
        表示("失敗: 非演算子")
        戻る 1
    }

    // テスト4: 且つ + 又は 複合
    変数 結果4 = 0
    もし 1 == 1 且つ 2 == 2 又は 3 == 4 {
        結果4 = 1
    }
    もし 結果4 == 1 {
        表示("成功: 且つ+又は複合")
    } そうでなければ {
        表示("失敗: 且つ+又は複合")
        戻る 1
    }

    // テスト5: 非 + 且つ 複合
    変数 結果5 = 0
    もし 非 偽 且つ 1 == 1 {
        結果5 = 1
    }
    もし 結果5 == 1 {
        表示("成功: 非+且つ複合")
    } そうでなければ {
        表示("失敗: 非+且つ複合")
        戻る 1
    }

    // テスト6: として（型変換 — 整数を整数に; 浮動小数はコード生成バグあり）
    定数 整数値 = 42
    定数 整数値二 = 整数値 として 整数
    もし 整数値二 == 42 {
        表示("成功: として型変換")
    } そうでなければ {
        表示("失敗: として型変換")
        戻る 1
    }

    表示("成功: 全その他キーワードテスト合格")
    戻る 0
}
