///
Тест E2E: Ключевые слова типов (Русский)
Ключевые слова: класс, перечисление
ПРИМЕЧАНИЕ: признак+реализовать имеет баг кодогена (отсутствует параметр this) -- пропущен
ПРИМЕЧАНИЕ: наследование (наследует) имеет баг присваивания унаследованных полей -- пропущен
ПРИМЕЧАНИЕ: несколько полей с не-ASCII именами имеют баг structIdx -- один Int-поле
///

перечисление Цвет {
    Красный,
    Зелёный,
    Синий
}

класс Счётчик {
    переменная значение: целое

    функция получить() r: целое {
        вернуть это.значение
    }
}

функция создатьСчётчик(зн: целое) r: Счётчик {
    переменная сч = Счётчик()
    сч.значение = зн
    вернуть сч
}

функция главная() r: целое {
    // Тест 1: перечисление равенство
    пусть ц1 = Цвет.Красный
    пусть ц2 = Цвет.Красный
    если ц1 == ц2 {
        печать("УСПЕХ: равенство перечисления")
    } иначе {
        печать("ПРОВАЛ: равенство перечисления")
        вернуть 1
    }

    // Тест 2: перечисление неравенство
    пусть ц3 = Цвет.Синий
    если ц1 != ц3 {
        печать("УСПЕХ: неравенство перечисления")
    } иначе {
        печать("ПРОВАЛ: неравенство перечисления")
        вернуть 1
    }

    // Тест 3: класс с одним Int-полем + метод
    пусть сч1 = создатьСчётчик(42)
    если сч1.получить() == 42 {
        печать("УСПЕХ: метод класса")
    } иначе {
        печать("ПРОВАЛ: метод класса")
        вернуть 1
    }

    // Тест 4: базовый тип
    пусть зн = 100
    если зн == 100 {
        печать("УСПЕХ: базовый тип")
    } иначе {
        печать("ПРОВАЛ: базовый тип")
        вернуть 1
    }

    печать("УСПЕХ: все тесты ключевых слов типов пройдены")
    вернуть 0
}
