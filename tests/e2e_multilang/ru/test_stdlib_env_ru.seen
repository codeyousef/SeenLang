// Тест E2E: Стандартная библиотека окружения (Русский)
// ПРИМЕЧАНИЕ: аргументы() -> args() не определена в рантайме — вызывает ошибку линковки
// Тестируем другие возможности окружения: в_строку, конкатенация строк, печать

функция главная() r: целое {
    // Тест 1: программа запускается и может вернуть код выхода
    пусть кодВыхода = 0
    если кодВыхода == 0 {
        печать("УСПЕХ: запуск программы и код выхода")
    } иначе {
        печать("ПРОВАЛ: запуск программы и код выхода")
        вернуть 1
    }

    // Тест 2: преобразование целого в строку
    пусть число = 12345
    пусть числоСтр = число.в_строку()
    если числоСтр == "12345" {
        печать("УСПЕХ: целое в_строку")
    } иначе {
        печать("ПРОВАЛ: целое в_строку")
        вернуть 1
    }

    // Тест 3: отрицательное целое в строку
    пусть отр = -42
    пусть отрСтр = отр.в_строку()
    если отрСтр == "-42" {
        печать("УСПЕХ: отрицательное целое в_строку")
    } иначе {
        печать("ПРОВАЛ: отрицательное целое в_строку")
        вернуть 1
    }

    // Тест 4: конкатенация строки с преобразованием целого
    пусть сообщ = "счёт=" + число.в_строку()
    если сообщ == "счёт=12345" {
        печать("УСПЕХ: конкатенация строки с в_строку")
    } иначе {
        печать("ПРОВАЛ: конкатенация строки с в_строку")
        вернуть 1
    }

    // Тест 5: несколько вызовов печать (базовый ввод-вывод)
    печать("УСПЕХ: несколько вызовов печать")

    печать("УСПЕХ: все тесты библиотеки окружения пройдены")
    вернуть 0
}
