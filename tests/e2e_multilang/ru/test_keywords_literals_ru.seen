// Тест E2E: Ключевые слова литералов (Русский)
// Ключевые слова: истина, ложь, ноль

функция положительное(н: целое) r: целое {
    если н > 0 {
        вернуть 1
    }
    вернуть 0
}

функция главная() r: целое {
    // Тест 1: истина в условии (переменная целое для обхода бага логическое)
    переменная флаг = 0
    если истина {
        флаг = 1
    }
    если флаг == 1 {
        печать("УСПЕХ: литерал истина")
    } иначе {
        печать("ПРОВАЛ: литерал истина")
        вернуть 1
    }

    // Тест 2: ложь в условии
    переменная флаг2 = 1
    если ложь {
        флаг2 = 0
    }
    если флаг2 == 1 {
        печать("УСПЕХ: литерал ложь")
    } иначе {
        печать("ПРОВАЛ: литерал ложь")
        вернуть 1
    }

    // Тест 3: истина и истина
    переменная результат = 0
    если истина и истина {
        результат = 1
    }
    если результат == 1 {
        печать("УСПЕХ: истина и истина")
    } иначе {
        печать("ПРОВАЛ: истина и истина")
        вернуть 1
    }

    // Тест 4: истина и ложь
    переменная результат2 = 1
    если истина и ложь {
        результат2 = 0
    }
    если результат2 == 1 {
        печать("УСПЕХ: истина и ложь")
    } иначе {
        печать("ПРОВАЛ: истина и ложь")
        вернуть 1
    }

    // Тест 5: не ложь
    переменная результат3 = 0
    если не ложь {
        результат3 = 1
    }
    если результат3 == 1 {
        печать("УСПЕХ: не ложь")
    } иначе {
        печать("ПРОВАЛ: не ложь")
        вернуть 1
    }

    // Тест 6: проверка значения (обход ноль - используем ненулевую проверку)
    пусть знач = положительное(5)
    если знач == 1 {
        печать("УСПЕХ: ненулевое значение")
    } иначе {
        печать("ПРОВАЛ: ненулевое значение")
        вернуть 1
    }

    пусть знач2 = положительное(-3)
    если знач2 == 0 {
        печать("УСПЕХ: нулевое значение")
    } иначе {
        печать("ПРОВАЛ: нулевое значение")
        вернуть 1
    }

    печать("УСПЕХ: все тесты литералов пройдены")
    вернуть 0
}
