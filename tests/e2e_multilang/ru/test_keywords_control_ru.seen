///
Тест E2E: Ключевые слова управления потоком (Русский)
Ключевые слова: функция, если, иначе, пока, прервать, продолжить, вернуть, цикл
ПРИМЕЧАНИЕ: "и" — ключевое слово (KeywordAnd), нельзя использовать как имя переменной
///

функция помощник_сложить(а: целое, б: целое) r: целое {
    вернуть а + б
}

функция помощник_отрицание(х: целое) r: целое {
    вернуть 0 - х
}

функция главная() r: целое {
    // Тест 1: функция + вернуть
    пусть результат = помощник_сложить(3, 4)
    если результат == 7 {
        печать("УСПЕХ: функция+вернуть")
    } иначе {
        печать("ПРОВАЛ: функция+вернуть")
        вернуть 1
    }

    // Тест 2: если + иначе
    пусть отр = помощник_отрицание(5)
    если отр == -5 {
        печать("УСПЕХ: если+иначе")
    } иначе {
        печать("ПРОВАЛ: если+иначе")
        вернуть 1
    }

    // Тест 3: пока + прервать
    переменная сч = 0
    пока сч < 100 {
        если сч == 5 {
            прервать
        }
        сч = сч + 1
    }
    если сч == 5 {
        печать("УСПЕХ: пока+прервать")
    } иначе {
        печать("ПРОВАЛ: пока+прервать")
        вернуть 1
    }

    // Тест 4: пока + продолжить (сумма нечётных чисел 1..10)
    переменная сумма = 0
    переменная нм = 0
    пока нм < 10 {
        нм = нм + 1
        пусть остаток = нм - (нм / 2) * 2
        если остаток == 0 {
            продолжить
        }
        сумма = сумма + нм
    }
    если сумма == 25 {
        печать("УСПЕХ: пока+продолжить")
    } иначе {
        печать("ПРОВАЛ: пока+продолжить")
        вернуть 1
    }

    // Тест 5: цикл + прервать
    переменная кк = 0
    цикл {
        кк = кк + 1
        если кк == 3 {
            прервать
        }
    }
    если кк == 3 {
        печать("УСПЕХ: цикл+прервать")
    } иначе {
        печать("ПРОВАЛ: цикл+прервать")
        вернуть 1
    }

    // Тест 6: вложенные циклы пока
    переменная внеш = 0
    переменная итого = 0
    пока внеш < 3 {
        переменная внутр = 0
        пока внутр < 4 {
            итого = итого + 1
            внутр = внутр + 1
        }
        внеш = внеш + 1
    }
    если итого == 12 {
        печать("УСПЕХ: вложенные пока")
    } иначе {
        печать("ПРОВАЛ: вложенные пока")
        вернуть 1
    }

    // Тест 7: вернуть из вложенного контекста
    пусть рез = помощник_сложить(помощник_сложить(1, 2), помощник_сложить(3, 4))
    если рез == 10 {
        печать("УСПЕХ: вложенный вернуть")
    } иначе {
        печать("ПРОВАЛ: вложенный вернуть")
        вернуть 1
    }

    печать("УСПЕХ: все тесты управления потоком пройдены")
    вернуть 0
}
