// Тест E2E: Математические операции (Русский)
// ПРИМЕЧАНИЕ: "и" — ключевое слово (KeywordAnd), нельзя использовать как имя переменной
// ПРИМЕЧАНИЕ: Модуль (%) сломан — используем обход: а - (а / б) * б

функция главная() r: целое {
    // Тест 1: целочисленный модуль через условие
    переменная х = -5
    если х < 0 {
        х = 0 - х
    }
    если х == 5 {
        печать("УСПЕХ: целочисленный модуль")
    } иначе {
        печать("ПРОВАЛ: целочисленный модуль")
        вернуть 1
    }

    // Тест 2: целочисленный минимум через сравнение
    пусть а = 10
    пусть б = 20
    переменная мн = а
    если б < а {
        мн = б
    }
    если мн == 10 {
        печать("УСПЕХ: целочисленный минимум")
    } иначе {
        печать("ПРОВАЛ: целочисленный минимум")
        вернуть 1
    }

    // Тест 3: целочисленный максимум через сравнение
    переменная мкс = а
    если б > а {
        мкс = б
    }
    если мкс == 20 {
        печать("УСПЕХ: целочисленный максимум")
    } иначе {
        печать("ПРОВАЛ: целочисленный максимум")
        вернуть 1
    }

    // Тест 4: целочисленная степень (2^10 = 1024) через цикл
    переменная результат = 1
    переменная сч = 0
    пока сч < 10 {
        результат = результат * 2
        сч = сч + 1
    }
    если результат == 1024 {
        печать("УСПЕХ: целочисленная степень 2^10")
    } иначе {
        печать("ПРОВАЛ: целочисленная степень 2^10")
        вернуть 1
    }

    // Тест 5: остаток от деления через обход (% сломан)
    пусть м = 17
    пусть д = 5
    пусть остаток = м - (м / д) * д
    если остаток == 2 {
        печать("УСПЕХ: обход остатка от деления")
    } иначе {
        печать("ПРОВАЛ: обход остатка от деления")
        вернуть 1
    }

    // Тест 6: целочисленное деление
    пусть рездел = 100 / 7
    если рездел == 14 {
        печать("УСПЕХ: целочисленное деление")
    } иначе {
        печать("ПРОВАЛ: целочисленное деление")
        вернуть 1
    }

    // Тест 7: отрицательные числа
    пусть отр = 0 - 42
    если отр == -42 {
        печать("УСПЕХ: отрицательные числа")
    } иначе {
        печать("ПРОВАЛ: отрицательные числа")
        вернуть 1
    }

    // Тест 8: порядок операций (умножение перед сложением)
    пусть выраж = 2 + 3 * 4
    если выраж == 14 {
        печать("УСПЕХ: порядок операций")
    } иначе {
        печать("ПРОВАЛ: порядок операций")
        вернуть 1
    }

    // Тест 9: выражения в скобках
    пусть скобки = (2 + 3) * 4
    если скобки == 20 {
        печать("УСПЕХ: выражения в скобках")
    } иначе {
        печать("ПРОВАЛ: выражения в скобках")
        вернуть 1
    }

    // Тест 10: цепочка умножений
    пусть цепь = 2 * 3 * 4
    если цепь == 24 {
        печать("УСПЕХ: цепочка умножений")
    } иначе {
        печать("ПРОВАЛ: цепочка умножений")
        вернуть 1
    }

    печать("УСПЕХ: все тесты математической библиотеки пройдены")
    вернуть 0
}
