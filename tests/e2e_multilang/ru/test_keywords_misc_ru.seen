///
Тест E2E: Разные ключевые слова (Русский)
Ключевые слова: и, или, не, как
///

функция главная() r: целое {
    // Тест 1: и (and)
    переменная р1 = 0
    если 1 == 1 и 2 == 2 {
        р1 = 1
    }
    если р1 == 1 {
        печать("УСПЕХ: оператор и")
    } иначе {
        печать("ПРОВАЛ: оператор и")
        вернуть 1
    }

    // Тест 2: или (or)
    переменная р2 = 0
    если 1 == 2 или 3 == 3 {
        р2 = 1
    }
    если р2 == 1 {
        печать("УСПЕХ: оператор или")
    } иначе {
        печать("ПРОВАЛ: оператор или")
        вернуть 1
    }

    // Тест 3: не (not)
    переменная р3 = 0
    если не ложь {
        р3 = 1
    }
    если р3 == 1 {
        печать("УСПЕХ: оператор не")
    } иначе {
        печать("ПРОВАЛ: оператор не")
        вернуть 1
    }

    // Тест 4: и + или вместе
    переменная р4 = 0
    если 1 == 1 и 2 == 2 или 3 == 4 {
        р4 = 1
    }
    если р4 == 1 {
        печать("УСПЕХ: и+или вместе")
    } иначе {
        печать("ПРОВАЛ: и+или вместе")
        вернуть 1
    }

    // Тест 5: не с и
    переменная р5 = 0
    если не ложь и 1 == 1 {
        р5 = 1
    }
    если р5 == 1 {
        печать("УСПЕХ: не+и вместе")
    } иначе {
        печать("ПРОВАЛ: не+и вместе")
        вернуть 1
    }

    // Тест 6: как (as) приведение типа (целое в целое; дробное имеет баг)
    пусть целЗнач = 42
    пусть целЗнач2 = целЗнач как целое
    если целЗнач2 == 42 {
        печать("УСПЕХ: приведение типа как")
    } иначе {
        печать("ПРОВАЛ: приведение типа как")
        вернуть 1
    }

    печать("УСПЕХ: все тесты разных ключевых слов пройдены")
    вернуть 0
}
