// Тест E2E: Только разбор ключевых слов (Русский)
// ПРИМЕЧАНИЕ: статический функция добавляет фантомные пустые поля — используем свободные функции
// ПРИМЕЧАНИЕ: Литералы конструктора класса ClassName { поле: знач } возвращают i64 не ptr — присваиваем поля

класс ПростойКонтейнер {
    переменная значение: целое

    функция получитьЗначение() r: целое {
        вернуть это.значение
    }
}

// Свободная функция вместо статический функция (обход бага фантомных полей)
функция создатьКонтейнер(з: целое) r: ПростойКонтейнер {
    переменная к = ПростойКонтейнер()
    к.значение = з
    вернуть к
}

функция главная() r: целое {
    пусть контейнер = создатьКонтейнер(42)
    если контейнер.получитьЗначение() == 42 {
        печать("УСПЕХ: тест разбора ключевых слов")
    } иначе {
        печать("ПРОВАЛ: тест разбора ключевых слов")
        вернуть 1
    }
    вернуть 0
}
