// Тест E2E: Стандартная библиотека коллекций (Русский)
// Типы: Array<целое>, Array<строка>, HashMap<строка, целое>
// Примечание: Array и HashMap остаются на английском (непереведённые обобщённые типы)
// ПРИМЕЧАНИЕ: HashMap.положить() -> put() не существует — используем insert()
// ПРИМЕЧАНИЕ: HashMap.получить_элемент() -> get() генерирует невалидный IR — используем getOrDefault()
// ПРИМЕЧАНИЕ: containsKey возвращает логическое — используем напрямую в если

функция главная() r: целое {
    // Тест 1: Array<целое> добавить и получить_элемент
    переменная массив = Array<целое>()
    массив.добавить(10)
    массив.добавить(20)
    массив.добавить(30)
    если массив.длина() == 3 {
        печать("УСПЕХ: длина массива")
    } иначе {
        печать("ПРОВАЛ: длина массива")
        вернуть 1
    }

    пусть первый = массив.получить_элемент(0)
    если первый == 10 {
        печать("УСПЕХ: получить_элемент(0) массива")
    } иначе {
        печать("ПРОВАЛ: получить_элемент(0) массива")
        вернуть 1
    }

    пусть последний = массив.получить_элемент(2)
    если последний == 30 {
        печать("УСПЕХ: получить_элемент(2) массива")
    } иначе {
        печать("ПРОВАЛ: получить_элемент(2) массива")
        вернуть 1
    }

    // Тест 2: Array<строка>
    переменная имена = Array<строка>()
    имена.добавить("привет")
    имена.добавить("мир")
    если имена.длина() == 2 {
        печать("УСПЕХ: длина массива строк")
    } иначе {
        печать("ПРОВАЛ: длина массива строк")
        вернуть 1
    }

    пусть и0 = имена.получить_элемент(0)
    если и0 == "привет" {
        печать("УСПЕХ: получить_элемент массива строк")
    } иначе {
        печать("ПРОВАЛ: получить_элемент массива строк")
        вернуть 1
    }

    // Тест 3: HashMap<строка, целое> с insert (не положить/put)
    переменная карта = HashMap<строка, целое>()
    карта.insert("а", 1)
    карта.insert("б", 2)
    карта.insert("в", 3)

    // Используем getOrDefault вместо получить_элемент/get (get генерирует невалидный IR)
    пусть за = карта.getOrDefault("а", -1)
    если за == 1 {
        печать("УСПЕХ: getOrDefault хеш-карты")
    } иначе {
        печать("ПРОВАЛ: getOrDefault хеш-карты")
        вернуть 1
    }

    пусть зб = карта.getOrDefault("б", -1)
    если зб == 2 {
        печать("УСПЕХ: getOrDefault б хеш-карты")
    } иначе {
        печать("ПРОВАЛ: getOrDefault б хеш-карты")
        вернуть 1
    }

    // Тест 4: HashMap containsKey (логическое, напрямую в если)
    если карта.containsKey("в") {
        печать("УСПЕХ: containsKey хеш-карты")
    } иначе {
        печать("ПРОВАЛ: containsKey хеш-карты")
        вернуть 1
    }

    // Тест 5: HashMap size
    пусть размер = карта.size()
    если размер == 3 {
        печать("УСПЕХ: size хеш-карты")
    } иначе {
        печать("ПРОВАЛ: size хеш-карты, получено " + размер.в_строку())
        вернуть 1
    }

    // Тест 6: HashMap отсутствующий ключ возвращает значение по умолчанию
    пусть отсутств = карта.getOrDefault("я", -999)
    если отсутств == -999 {
        печать("УСПЕХ: отсутствующий ключ хеш-карты")
    } иначе {
        печать("ПРОВАЛ: отсутствующий ключ хеш-карты")
        вернуть 1
    }

    печать("УСПЕХ: все тесты коллекций пройдены")
    вернуть 0
}
