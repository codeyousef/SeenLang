///
Тест E2E: Стандартная библиотека строк (Русский)
Функции: содержит, начинаетсяС, заканчиваетсяНа, индексВ, длина
ПРИМЕЧАНИЕ: содержит/начинаетсяС/заканчиваетсяНа возвращают логическое — нужно
            использовать напрямую в если, не сохранять в переменную
ПРИМЕЧАНИЕ: индексВ принимает 3 аргумента: (текст, искомое, начальныйИндекс)
///

функция главная() r: целое {
    пусть текст = "hello world"

    // Тест 1: длина строки
    пусть дл = текст.длина()
    если дл == 11 {
        печать("УСПЕХ: длина строки")
    } иначе {
        печать("ПРОВАЛ: длина строки, получено " + дл.в_строку())
        вернуть 1
    }

    // Тест 2: содержит (возвращает логическое, напрямую в если)
    если содержит(текст, "world") {
        печать("УСПЕХ: содержит")
    } иначе {
        печать("ПРОВАЛ: содержит")
        вернуть 1
    }

    // Тест 3: начинаетсяС (возвращает логическое, напрямую в если)
    если начинаетсяС(текст, "hello") {
        печать("УСПЕХ: начинаетсяС")
    } иначе {
        печать("ПРОВАЛ: начинаетсяС")
        вернуть 1
    }

    // Тест 4: заканчиваетсяНа (возвращает логическое, напрямую в если)
    если заканчиваетсяНа(текст, "world") {
        печать("УСПЕХ: заканчиваетсяНа")
    } иначе {
        печать("ПРОВАЛ: заканчиваетсяНа")
        вернуть 1
    }

    // Тест 5: индексВ (3 аргумента: текст, искомое, начальныйИндекс)
    пусть инд = индексВ(текст, "world", 0)
    если инд == 6 {
        печать("УСПЕХ: индексВ")
    } иначе {
        печать("ПРОВАЛ: индексВ, получено " + инд.в_строку())
        вернуть 1
    }

    // Тест 6: конкатенация строк
    пусть приветствие = "привет" + " " + "мир"
    если приветствие == "привет мир" {
        печать("УСПЕХ: конкатенация строк")
    } иначе {
        печать("ПРОВАЛ: конкатенация строк")
        вернуть 1
    }

    // Тест 7: содержит отрицательный случай
    если содержит(текст, "xyz") {
        печать("ПРОВАЛ: содержит отрицательный")
        вернуть 1
    } иначе {
        печать("УСПЕХ: содержит отрицательный")
    }

    // Тест 8: индексВ не найден возвращает -1
    пусть ненайдено = индексВ(текст, "xyz", 0)
    если ненайдено == -1 {
        печать("УСПЕХ: индексВ не найден")
    } иначе {
        печать("ПРОВАЛ: индексВ не найден, получено " + ненайдено.в_строку())
        вернуть 1
    }

    печать("УСПЕХ: все тесты строковой библиотеки пройдены")
    вернуть 0
}
