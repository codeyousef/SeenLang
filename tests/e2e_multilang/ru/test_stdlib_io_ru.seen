// Тест E2E: Стандартная библиотека ввода-вывода (Русский)
// ПРИМЕЧАНИЕ: __WriteFile двойно кодирует не-ASCII байты — используем ASCII содержимое
// ПРИМЕЧАНИЕ: __ReadFile возвращает SeenString, но кодоген обрабатывает как i64 — нельзя
//             использовать содержимое строки. Проверяем через __FileSize.

функция главная() r: целое {
    пусть путь = "/tmp/seen_e2e_test_ru.txt"
    пусть содержимое = "hello from seen e2e test in russian"

    // Тест 1: открыть файл для записи
    пусть фд1 = __OpenFile(путь, "w")
    если фд1 < 0 {
        печать("ПРОВАЛ: открытие файла для записи")
        вернуть 1
    }
    печать("УСПЕХ: открытие файла для записи")

    // Тест 2: записать содержимое
    пусть записано = __WriteFile(фд1, содержимое)
    пусть з1 = __CloseFile(фд1)
    если записано >= 0 {
        печать("УСПЕХ: запись в файл")
    } иначе {
        печать("ПРОВАЛ: запись в файл")
        вернуть 1
    }

    // Тест 3: файл существует
    если __FileExists(путь) {
        печать("УСПЕХ: файл существует")
    } иначе {
        печать("ПРОВАЛ: файл существует")
        вернуть 1
    }

    // Тест 4: прочитать и проверить размер (ASCII = 1 байт на символ)
    пусть фд2 = __OpenFile(путь, "r")
    если фд2 < 0 {
        печать("ПРОВАЛ: открытие файла для чтения")
        вернуть 1
    }
    пусть размер = __FileSize(фд2)
    пусть з2 = __CloseFile(фд2)
    если размер == 35 {
        печать("УСПЕХ: размер файла совпадает с длиной содержимого")
    } иначе {
        печать("ПРОВАЛ: размер файла, получено " + размер.в_строку())
        вернуть 1
    }

    // Тест 5: удалить файл
    __DeleteFile(путь)
    если __FileExists(путь) {
        печать("ПРОВАЛ: удаление файла (файл всё ещё существует)")
        вернуть 1
    } иначе {
        печать("УСПЕХ: удаление файла")
    }

    печать("УСПЕХ: все тесты библиотеки ввода-вывода пройдены")
    вернуть 0
}
