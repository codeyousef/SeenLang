///
Тест E2E: Ключевые слова переменных (Русский)
Ключевые слова: пусть, переменная
ПРИМЕЧАНИЕ: DSE удаляет инициализацию переменных при немедленном переприсваивании
///

функция главная() r: целое {
    // Тест 1: пусть (неизменяемая привязка)
    пусть х = 42
    если х == 42 {
        печать("УСПЕХ: привязка пусть")
    } иначе {
        печать("ПРОВАЛ: привязка пусть")
        вернуть 1
    }

    // Тест 2: переменная (изменяемая привязка)
    переменная у = 25
    если у == 25 {
        печать("УСПЕХ: привязка переменная")
    } иначе {
        печать("ПРОВАЛ: привязка переменная")
        вернуть 1
    }

    // Тест 3: пусть с выражением
    пусть з = 50 + 50
    если з == 100 {
        печать("УСПЕХ: пусть с выражением")
    } иначе {
        печать("ПРОВАЛ: пусть с выражением")
        вернуть 1
    }

    ///
    Тест 4: переменная со сложением
    ПРИМЕЧАНИЕ: "в" — KeywordIn, нельзя использовать как имя переменной
    ///
    переменная кк = 10
    кк = кк + 5
    если кк == 15 {
        печать("УСПЕХ: переменная со сложением")
    } иначе {
        печать("ПРОВАЛ: переменная со сложением")
        вернуть 1
    }

    // Тест 5: пусть и переменная вместе
    пусть а = 1
    пусть б = 2
    пусть ц = 3
    переменная д = а + б + ц
    если д == 6 {
        печать("УСПЕХ: пусть и переменная вместе")
    } иначе {
        печать("ПРОВАЛ: пусть и переменная вместе")
        вернуть 1
    }

    // Тест 6: переменная с суммой
    переменная сум = 1 + 2 + 3 + 4 + 5
    если сум == 15 {
        печать("УСПЕХ: переменная с суммой")
    } иначе {
        печать("ПРОВАЛ: переменная с суммой")
        вернуть 1
    }

    печать("УСПЕХ: все тесты ключевых слов переменных пройдены")
    вернуть 0
}
