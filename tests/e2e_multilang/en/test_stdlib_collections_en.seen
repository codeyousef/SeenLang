///
E2E Test: Collections Standard Library (English)
Types tested: Array<Int>, Array<String>, HashMap<String,Int>
NOTE: HashMap uses insert() not put() (put doesn't exist in runtime)
NOTE: HashMap.get() returns Option<T> which breaks codegen; use getOrDefault()
NOTE: HashMap.containsKey() returns bool, use directly in if condition
///

fun main() r: Int {
    // Test 1: Array<Int> push and get
    var arr = Array<Int>()
    arr.push(10)
    arr.push(20)
    arr.push(30)
    if arr.length() == 3 {
        println("PASS: array length")
    } else {
        println("FAIL: array length")
        return 1
    }

    let first = arr.get(0)
    if first == 10 {
        println("PASS: array get(0)")
    } else {
        println("FAIL: array get(0)")
        return 1
    }

    let last = arr.get(2)
    if last == 30 {
        println("PASS: array get(2)")
    } else {
        println("FAIL: array get(2)")
        return 1
    }

    // Test 2: Array<String>
    var names = Array<String>()
    names.push("hello")
    names.push("world")
    if names.length() == 2 {
        println("PASS: string array length")
    } else {
        println("FAIL: string array length")
        return 1
    }

    let n0 = names.get(0)
    if n0 == "hello" {
        println("PASS: string array get")
    } else {
        println("FAIL: string array get")
        return 1
    }

    // Test 3: HashMap<String,Int> with insert (not put)
    var map = HashMap<String, Int>()
    map.insert("a", 1)
    map.insert("b", 2)
    map.insert("c", 3)

    // Use getOrDefault instead of get (get returns Option<T> which breaks codegen)
    let va = map.getOrDefault("a", -1)
    if va == 1 {
        println("PASS: hashmap getOrDefault a")
    } else {
        println("FAIL: hashmap getOrDefault a")
        return 1
    }

    let vb = map.getOrDefault("b", -1)
    if vb == 2 {
        println("PASS: hashmap getOrDefault b")
    } else {
        println("FAIL: hashmap getOrDefault b")
        return 1
    }

    // Test 4: HashMap containsKey
    if map.containsKey("c") {
        println("PASS: hashmap containsKey")
    } else {
        println("FAIL: hashmap containsKey")
        return 1
    }

    // Test 5: HashMap size
    let sz = map.size()
    if sz == 3 {
        println("PASS: hashmap size")
    } else {
        println("FAIL: hashmap size, got " + sz.toString())
        return 1
    }

    // Test 6: HashMap missing key returns default
    let missing = map.getOrDefault("z", -999)
    if missing == -999 {
        println("PASS: hashmap missing key default")
    } else {
        println("FAIL: hashmap missing key default")
        return 1
    }

    println("PASS: all collection tests passed")
    return 0
}
