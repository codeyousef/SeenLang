// E2E Test: Math Operations (English)
// NOTE: Float stdlib calls (sqrt, sin, cos, abs, floor, ceil, pow) return i64
// instead of double due to codegen bug. Testing integer math only.
// Modulo (%) is broken, using workaround: a - (a/b)*b

fun main() r: Int {
    // Test 1: integer abs via conditional
    var x = -5
    if x < 0 {
        x = 0 - x
    }
    if x == 5 {
        println("PASS: integer abs")
    } else {
        println("FAIL: integer abs")
        return 1
    }

    // Test 2: integer min via comparison
    let a = 10
    let b = 20
    var mn = a
    if b < a {
        mn = b
    }
    if mn == 10 {
        println("PASS: integer min")
    } else {
        println("FAIL: integer min")
        return 1
    }

    // Test 3: integer max via comparison
    var mx = a
    if b > a {
        mx = b
    }
    if mx == 20 {
        println("PASS: integer max")
    } else {
        println("FAIL: integer max")
        return 1
    }

    // Test 4: integer power (2^10 = 1024) via loop
    var result = 1
    var i = 0
    while i < 10 {
        result = result * 2
        i = i + 1
    }
    if result == 1024 {
        println("PASS: integer power 2^10")
    } else {
        println("FAIL: integer power 2^10, got " + result.toString())
        return 1
    }

    // Test 5: modulo via workaround (% is broken)
    let m = 17
    let d = 5
    let remainder = m - (m / d) * d
    if remainder == 2 {
        println("PASS: integer modulo workaround")
    } else {
        println("FAIL: integer modulo workaround, got " + remainder.toString())
        return 1
    }

    // Test 6: integer division
    let div_result = 100 / 7
    if div_result == 14 {
        println("PASS: integer division")
    } else {
        println("FAIL: integer division, got " + div_result.toString())
        return 1
    }

    // Test 7: negative numbers
    let neg = 0 - 42
    if neg == -42 {
        println("PASS: negative numbers")
    } else {
        println("FAIL: negative numbers")
        return 1
    }

    // Test 8: order of operations (multiplication before addition)
    let expr = 2 + 3 * 4
    if expr == 14 {
        println("PASS: order of operations")
    } else {
        println("FAIL: order of operations, got " + expr.toString())
        return 1
    }

    // Test 9: parenthesized expressions
    let paren = (2 + 3) * 4
    if paren == 20 {
        println("PASS: parenthesized expressions")
    } else {
        println("FAIL: parenthesized expressions, got " + paren.toString())
        return 1
    }

    // Test 10: chained multiplication
    let chain = 2 * 3 * 4
    if chain == 24 {
        println("PASS: chained multiplication")
    } else {
        println("FAIL: chained multiplication, got " + chain.toString())
        return 1
    }

    println("PASS: all math tests passed")
    return 0
}
