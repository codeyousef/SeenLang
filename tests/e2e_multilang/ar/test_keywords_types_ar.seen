///
اختبار شامل: كلمات الأنواع (عربي)
الكلمات المختبرة: فئة, تعداد
ملاحظة: سمة+تطبيق فيه خلل (فقدان معامل هذا) -- تم تخطيه
ملاحظة: وراثة (يمتد) فيها خلل في إسناد الحقول الموروثة -- تم تخطيه
ملاحظة: حقول متعددة غير ASCII فيها خلل structIdx -- نستعمل حقل عدد واحد
///

تعداد لون {
    أحمر,
    أخضر,
    أزرق
}

فئة عداد {
    متغير عدة: عدد

    دالة احصل_عدة() ن: عدد {
        رجع هذا.عدة
    }
}

دالة أنشئ_عداد(ق: عدد) ن: عداد {
    متغير عد = عداد()
    عد.عدة = ق
    رجع عد
}

دالة رئيسية() ن: عدد {
    // اختبار 1: تعداد تساوي
    اجعل ل1 = لون.أحمر
    اجعل ل2 = لون.أحمر
    إذا ل1 == ل2 {
        اطبع("نجاح: تساوي تعداد")
    } وإلا {
        اطبع("فشل: تساوي تعداد")
        رجع 1
    }

    // اختبار 2: تعداد عدم تساوي
    اجعل ل3 = لون.أزرق
    إذا ل1 != ل3 {
        اطبع("نجاح: عدم تساوي تعداد")
    } وإلا {
        اطبع("فشل: عدم تساوي تعداد")
        رجع 1
    }

    // اختبار 3: فئة مع حقل عدد واحد + دالة
    اجعل عد1 = أنشئ_عداد(42)
    إذا عد1.احصل_عدة() == 42 {
        اطبع("نجاح: دالة فئة")
    } وإلا {
        اطبع("فشل: دالة فئة")
        رجع 1
    }

    // اختبار 4: نوع أساسي
    اجعل قيم = 100
    إذا قيم == 100 {
        اطبع("نجاح: نوع أساسي")
    } وإلا {
        اطبع("فشل: نوع أساسي")
        رجع 1
    }

    اطبع("نجاح: جميع اختبارات كلمات الأنواع نجحت")
    رجع 0
}
