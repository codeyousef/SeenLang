// اختبار شامل: مكتبة الإدخال/الإخراج القياسية (عربي)
// الدوال المختبرة: __OpenFile, __WriteFile, __CloseFile, __FileSize,
//                   __FileExists, __DeleteFile
// ملاحظة: الدوال العالية المستوى (اكتب_نص, اقرأ_نص, موجود, احذف_ملف)
//         موجودة في seen_std ولكن غير متاحة في التجميع أحادي الملف.
//         نستعمل دوال وقت التشغيل (__) مباشرة.
// ملاحظة: __FileExists/__DeleteFile تعيد منطقي -- نستعملها مباشرة في إذا
// ملاحظة: __ReadFile تعيد نصا لكن المولد يعاملها كـ i64 -- لا يمكن
//         استعمال محتوى النص المعاد. نتحقق عبر __FileSize بدلا.

دالة رئيسية() ن: عدد {
    اجعل مسار = "/tmp/seen_e2e_test_ar.txt"
    اجعل محتوى = "مرحبا من اختبار سين بالعربية"

    // اختبار 1: فتح ملف للكتابة
    اجعل م1 = __OpenFile(مسار, "w")
    إذا م1 < 0 {
        اطبع("فشل: فتح ملف للكتابة")
        رجع 1
    }
    اطبع("نجاح: فتح ملف للكتابة")

    // اختبار 2: كتابة المحتوى
    اجعل مكتوب = __WriteFile(م1, محتوى)
    اجعل إ1 = __CloseFile(م1)
    إذا مكتوب >= 0 {
        اطبع("نجاح: كتابة الملف")
    } وإلا {
        اطبع("فشل: كتابة الملف")
        رجع 1
    }

    // اختبار 3: وجود الملف (منطقي، استعمل مباشرة في إذا)
    إذا __FileExists(مسار) {
        اطبع("نجاح: وجود الملف")
    } وإلا {
        اطبع("فشل: وجود الملف")
        رجع 1
    }

    // اختبار 4: التحقق من الحجم
    اجعل م2 = __OpenFile(مسار, "r")
    إذا م2 < 0 {
        اطبع("فشل: فتح ملف للقراءة")
        رجع 1
    }
    اجعل حجم = __FileSize(م2)
    اجعل إ2 = __CloseFile(م2)
    إذا حجم > 0 {
        اطبع("نجاح: حجم الملف أكبر من صفر")
    } وإلا {
        اطبع("فشل: حجم الملف، حصلت على " + حجم.إلى_نص())
        رجع 1
    }

    // اختبار 5: حذف الملف
    __DeleteFile(مسار)
    إذا __FileExists(مسار) {
        اطبع("فشل: حذف الملف (الملف لا يزال موجودا)")
        رجع 1
    } وإلا {
        اطبع("نجاح: حذف الملف")
    }

    اطبع("نجاح: جميع اختبارات مكتبة الإدخال/الإخراج نجحت")
    رجع 0
}
