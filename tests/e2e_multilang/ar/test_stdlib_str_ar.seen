// اختبار شامل: مكتبة النصوص القياسية (عربي)
// الدوال المختبرة: يحتوي, يبدأ_بـ, ينتهي_بـ, فهرس, طول
// ملاحظة: يحتوي/يبدأ_بـ/ينتهي_بـ تعيد منطقي -- يجب استعمالها مباشرة في إذا
//         لا تخزن في متغير وتقارن بـ == 1 (عدم تطابق i1 مع i64)
// ملاحظة: فهرس تأخذ 3 معاملات: (نص, إبرة, فهرس_بداية)

دالة رئيسية() ن: عدد {
    اجعل نص1 = "hello world"

    // اختبار 1: طول النص
    اجعل ط = نص1.طول()
    إذا ط == 11 {
        اطبع("نجاح: طول النص")
    } وإلا {
        اطبع("فشل: طول النص، حصلت على " + ط.إلى_نص())
        رجع 1
    }

    // اختبار 2: يحتوي (منطقي، استعمل مباشرة في إذا)
    إذا يحتوي(نص1, "world") {
        اطبع("نجاح: يحتوي")
    } وإلا {
        اطبع("فشل: يحتوي")
        رجع 1
    }

    // اختبار 3: يبدأ_بـ (منطقي، استعمل مباشرة في إذا)
    إذا يبدأ_بـ(نص1, "hello") {
        اطبع("نجاح: يبدأ_بـ")
    } وإلا {
        اطبع("فشل: يبدأ_بـ")
        رجع 1
    }

    // اختبار 4: ينتهي_بـ (منطقي، استعمل مباشرة في إذا)
    إذا ينتهي_بـ(نص1, "world") {
        اطبع("نجاح: ينتهي_بـ")
    } وإلا {
        اطبع("فشل: ينتهي_بـ")
        رجع 1
    }

    // اختبار 5: فهرس (3 معاملات: نص, إبرة, فهرس_بداية)
    اجعل فه = فهرس(نص1, "world", 0)
    إذا فه == 6 {
        اطبع("نجاح: فهرس")
    } وإلا {
        اطبع("فشل: فهرس، حصلت على " + فه.إلى_نص())
        رجع 1
    }

    // اختبار 6: ربط النصوص
    اجعل تحية = "مرحبا" + " " + "يا عالم"
    إذا تحية == "مرحبا يا عالم" {
        اطبع("نجاح: ربط النصوص")
    } وإلا {
        اطبع("فشل: ربط النصوص")
        رجع 1
    }

    // اختبار 7: يحتوي حالة سلبية
    إذا يحتوي(نص1, "xyz") {
        اطبع("فشل: يحتوي سلبي")
        رجع 1
    } وإلا {
        اطبع("نجاح: يحتوي سلبي")
    }

    // اختبار 8: فهرس غير موجود يعيد -1
    اجعل غير_موجود = فهرس(نص1, "xyz", 0)
    إذا غير_موجود == -1 {
        اطبع("نجاح: فهرس غير موجود")
    } وإلا {
        اطبع("فشل: فهرس غير موجود، حصلت على " + غير_موجود.إلى_نص())
        رجع 1
    }

    اطبع("نجاح: جميع اختبارات مكتبة النصوص نجحت")
    رجع 0
}
