///
اختبار شامل: كلمات المتغيرات (عربي)
الكلمات المختبرة: اجعل, متغير
ملاحظة: DSE يزيل تهيئة المتغير إذا أعيد تعيينه -- تجنب النمط متغير س = أ; س = ب
///

دالة رئيسية() ن: عدد {
    // اختبار 1: اجعل (ربط غير قابل للتغيير)
    اجعل س = 42
    إذا س == 42 {
        اطبع("نجاح: ربط اجعل")
    } وإلا {
        اطبع("فشل: ربط اجعل")
        رجع 1
    }

    // اختبار 2: متغير (ربط قابل للتغيير)
    متغير ص = 25
    إذا ص == 25 {
        اطبع("نجاح: ربط متغير")
    } وإلا {
        اطبع("فشل: ربط متغير")
        رجع 1
    }

    // اختبار 3: اجعل مع تعبير
    اجعل ع = 50 + 50
    إذا ع == 100 {
        اطبع("نجاح: اجعل مع تعبير")
    } وإلا {
        اطبع("فشل: اجعل مع تعبير")
        رجع 1
    }

    ///
    اختبار 4: متغير مع إضافة
    ملاحظة: "و" هو KeywordAnd -- نستعمل "ق" بدلا
    ///
    متغير ق = 10
    ق = ق + 5
    إذا ق == 15 {
        اطبع("نجاح: متغير مع إضافة")
    } وإلا {
        اطبع("فشل: متغير مع إضافة")
        رجع 1
    }

    // اختبار 5: اجعل ومتغير معا
    اجعل أ = 1
    اجعل ب = 2
    اجعل ج = 3
    متغير د = أ + ب + ج
    إذا د == 6 {
        اطبع("نجاح: اجعل ومتغير معا")
    } وإلا {
        اطبع("فشل: اجعل ومتغير معا")
        رجع 1
    }

    // اختبار 6: متغير مع مجموع
    متغير مج = 1 + 2 + 3 + 4 + 5
    إذا مج == 15 {
        اطبع("نجاح: متغير مع مجموع")
    } وإلا {
        اطبع("فشل: متغير مع مجموع")
        رجع 1
    }

    اطبع("نجاح: جميع اختبارات كلمات المتغيرات نجحت")
    رجع 0
}
