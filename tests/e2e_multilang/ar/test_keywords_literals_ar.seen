///
اختبار شامل: كلمات القيم الحرفية (عربي)
الكلمات المختبرة: صحيح, خطأ, عدم
///

دالة حساب_مزدوج(م: عدد) ن: عدد {
    رجع م + م
}

دالة رئيسية() ن: عدد {
    // اختبار 1: صحيح في شرط
    متغير علم = 0
    إذا صحيح {
        علم = 1
    }
    إذا علم == 1 {
        اطبع("نجاح: قيمة صحيح")
    } وإلا {
        اطبع("فشل: قيمة صحيح")
        رجع 1
    }

    // اختبار 2: خطأ في شرط
    متغير علم2 = 1
    إذا خطأ {
        علم2 = 0
    }
    إذا علم2 == 1 {
        اطبع("نجاح: قيمة خطأ")
    } وإلا {
        اطبع("فشل: قيمة خطأ")
        رجع 1
    }

    // اختبار 3: صحيح و صحيح
    متغير نتيجة = 0
    إذا صحيح و صحيح {
        نتيجة = 1
    }
    إذا نتيجة == 1 {
        اطبع("نجاح: صحيح و صحيح")
    } وإلا {
        اطبع("فشل: صحيح و صحيح")
        رجع 1
    }

    // اختبار 4: صحيح و خطأ
    متغير نتيجة2 = 1
    إذا صحيح و خطأ {
        نتيجة2 = 0
    }
    إذا نتيجة2 == 1 {
        اطبع("نجاح: صحيح و خطأ")
    } وإلا {
        اطبع("فشل: صحيح و خطأ")
        رجع 1
    }

    // اختبار 5: ليس خطأ
    متغير نتيجة3 = 0
    إذا ليس خطأ {
        نتيجة3 = 1
    }
    إذا نتيجة3 == 1 {
        اطبع("نجاح: ليس خطأ")
    } وإلا {
        اطبع("فشل: ليس خطأ")
        رجع 1
    }

    // اختبار 6: دالة مع قيم حرفية
    اجعل قيم = حساب_مزدوج(5)
    إذا قيم == 10 {
        اطبع("نجاح: قيمة دالة")
    } وإلا {
        اطبع("فشل: قيمة دالة")
        رجع 1
    }

    اجعل قيم2 = حساب_مزدوج(0)
    إذا قيم2 == 0 {
        اطبع("نجاح: قيمة صفرية")
    } وإلا {
        اطبع("فشل: قيمة صفرية")
        رجع 1
    }

    اطبع("نجاح: جميع اختبارات القيم الحرفية نجحت")
    رجع 0
}
