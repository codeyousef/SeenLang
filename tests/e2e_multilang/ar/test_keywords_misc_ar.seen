///
اختبار شامل: كلمات متنوعة (عربي)
الكلمات المختبرة: و, أو, ليس, ك, هو
///

دالة رئيسية() ن: عدد {
    // اختبار 1: و
    متغير ن1 = 0
    إذا 1 == 1 و 2 == 2 {
        ن1 = 1
    }
    إذا ن1 == 1 {
        اطبع("نجاح: عامل و")
    } وإلا {
        اطبع("فشل: عامل و")
        رجع 1
    }

    // اختبار 2: أو
    متغير ن2 = 0
    إذا 1 == 2 أو 3 == 3 {
        ن2 = 1
    }
    إذا ن2 == 1 {
        اطبع("نجاح: عامل أو")
    } وإلا {
        اطبع("فشل: عامل أو")
        رجع 1
    }

    // اختبار 3: ليس
    متغير ن3 = 0
    إذا ليس خطأ {
        ن3 = 1
    }
    إذا ن3 == 1 {
        اطبع("نجاح: عامل ليس")
    } وإلا {
        اطبع("فشل: عامل ليس")
        رجع 1
    }

    // اختبار 4: و + أو معا
    متغير ن4 = 0
    إذا 1 == 1 و 2 == 2 أو 3 == 4 {
        ن4 = 1
    }
    إذا ن4 == 1 {
        اطبع("نجاح: و+أو معا")
    } وإلا {
        اطبع("فشل: و+أو معا")
        رجع 1
    }

    // اختبار 5: ليس مع و
    متغير ن5 = 0
    إذا ليس خطأ و 1 == 1 {
        ن5 = 1
    }
    إذا ن5 == 1 {
        اطبع("نجاح: ليس+و معا")
    } وإلا {
        اطبع("فشل: ليس+و معا")
        رجع 1
    }

    // اختبار 6: ك (تحويل نوع — عدد الى عدد; عشري فيه خلل)
    اجعل قيمة_صحيحة = 42
    اجعل قيمة_صحيحة2 = قيمة_صحيحة ك عدد
    إذا قيمة_صحيحة2 == 42 {
        اطبع("نجاح: تحويل بـ ك")
    } وإلا {
        اطبع("فشل: تحويل بـ ك")
        رجع 1
    }

    اطبع("نجاح: جميع الاختبارات المتنوعة نجحت")
    رجع 0
}
