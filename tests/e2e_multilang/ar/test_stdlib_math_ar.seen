///
اختبار شامل: عمليات الرياضيات (عربي)
ملاحظة: دوال المكتبة العشرية (جذر, جيب, جيب_تمام, قيمة_مطلقة, أرضية, سقف, قوة)
تعيد i64 بدلا من double بسبب خلل في المولد. نختبر الرياضيات الصحيحة فقط.
ملاحظة: % (باقي القسمة) معطل -- نستعمل أ - (أ/ب)*ب بدلا
///

دالة رئيسية() ن: عدد {
    // اختبار 1: القيمة المطلقة للعدد الصحيح بالشرط
    متغير س = -5
    إذا س < 0 {
        س = 0 - س
    }
    إذا س == 5 {
        اطبع("نجاح: القيمة المطلقة الصحيحة")
    } وإلا {
        اطبع("فشل: القيمة المطلقة الصحيحة")
        رجع 1
    }

    // اختبار 2: الحد الأدنى بالمقارنة
    اجعل أ = 10
    اجعل ب = 20
    متغير أدنى = أ
    إذا ب < أ {
        أدنى = ب
    }
    إذا أدنى == 10 {
        اطبع("نجاح: الحد الأدنى الصحيح")
    } وإلا {
        اطبع("فشل: الحد الأدنى الصحيح")
        رجع 1
    }

    // اختبار 3: الحد الأقصى بالمقارنة
    متغير أقصى = أ
    إذا ب > أ {
        أقصى = ب
    }
    إذا أقصى == 20 {
        اطبع("نجاح: الحد الأقصى الصحيح")
    } وإلا {
        اطبع("فشل: الحد الأقصى الصحيح")
        رجع 1
    }

    // اختبار 4: القوة الصحيحة (2^10 = 1024) بالحلقة
    متغير نتيجة = 1
    متغير ع = 0
    بينما ع < 10 {
        نتيجة = نتيجة * 2
        ع = ع + 1
    }
    إذا نتيجة == 1024 {
        اطبع("نجاح: القوة الصحيحة 2^10")
    } وإلا {
        اطبع("فشل: القوة الصحيحة 2^10، حصلت على " + نتيجة.إلى_نص())
        رجع 1
    }

    // اختبار 5: باقي القسمة بالبديل (% معطل)
    اجعل م = 17
    اجعل ق = 5
    اجعل باقي = م - (م / ق) * ق
    إذا باقي == 2 {
        اطبع("نجاح: بديل باقي القسمة")
    } وإلا {
        اطبع("فشل: بديل باقي القسمة، حصلت على " + باقي.إلى_نص())
        رجع 1
    }

    // اختبار 6: القسمة الصحيحة
    اجعل نتيجة_قسمة = 100 / 7
    إذا نتيجة_قسمة == 14 {
        اطبع("نجاح: القسمة الصحيحة")
    } وإلا {
        اطبع("فشل: القسمة الصحيحة، حصلت على " + نتيجة_قسمة.إلى_نص())
        رجع 1
    }

    // اختبار 7: الأعداد السالبة
    اجعل سالب = 0 - 42
    إذا سالب == -42 {
        اطبع("نجاح: الأعداد السالبة")
    } وإلا {
        اطبع("فشل: الأعداد السالبة")
        رجع 1
    }

    // اختبار 8: ترتيب العمليات (الضرب قبل الجمع)
    اجعل تعبير = 2 + 3 * 4
    إذا تعبير == 14 {
        اطبع("نجاح: ترتيب العمليات")
    } وإلا {
        اطبع("فشل: ترتيب العمليات، حصلت على " + تعبير.إلى_نص())
        رجع 1
    }

    // اختبار 9: التعبيرات بالأقواس
    اجعل بأقواس = (2 + 3) * 4
    إذا بأقواس == 20 {
        اطبع("نجاح: التعبيرات بالأقواس")
    } وإلا {
        اطبع("فشل: التعبيرات بالأقواس، حصلت على " + بأقواس.إلى_نص())
        رجع 1
    }

    // اختبار 10: الضرب المتسلسل
    اجعل متسلسل = 2 * 3 * 4
    إذا متسلسل == 24 {
        اطبع("نجاح: الضرب المتسلسل")
    } وإلا {
        اطبع("فشل: الضرب المتسلسل، حصلت على " + متسلسل.إلى_نص())
        رجع 1
    }

    اطبع("نجاح: جميع اختبارات الرياضيات نجحت")
    رجع 0
}
