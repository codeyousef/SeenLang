// اختبار شامل: كلمات التحكم بالتدفق (عربي)
// الكلمات المختبرة: دالة, إذا, وإلا, بينما, اكسر, استمر, رجع, حلقة

دالة مساعد_جمع(أ: عدد, ب: عدد) ن: عدد {
    رجع أ + ب
}

دالة مساعد_سالب(س: عدد) ن: عدد {
    رجع 0 - س
}

دالة رئيسية() ن: عدد {
    // اختبار 1: دالة + رجع
    اجعل نتيجة = مساعد_جمع(3, 4)
    إذا نتيجة == 7 {
        اطبع("نجاح: دالة+رجع")
    } وإلا {
        اطبع("فشل: دالة+رجع")
        رجع 1
    }

    // اختبار 2: إذا + وإلا
    اجعل سالب = مساعد_سالب(5)
    إذا سالب == -5 {
        اطبع("نجاح: إذا+وإلا")
    } وإلا {
        اطبع("فشل: إذا+وإلا")
        رجع 1
    }

    // اختبار 3: بينما + اكسر
    متغير ع = 0
    بينما ع < 100 {
        إذا ع == 5 {
            اكسر
        }
        ع = ع + 1
    }
    إذا ع == 5 {
        اطبع("نجاح: بينما+اكسر")
    } وإلا {
        اطبع("فشل: بينما+اكسر")
        رجع 1
    }

    // اختبار 4: بينما + استمر (جمع الفردية 1..10)
    متغير مجموع = 0
    متغير ي = 0
    بينما ي < 10 {
        ي = ي + 1
        اجعل باقي = ي - (ي / 2) * 2
        إذا باقي == 0 {
            استمر
        }
        مجموع = مجموع + ي
    }
    إذا مجموع == 25 {
        اطبع("نجاح: بينما+استمر")
    } وإلا {
        اطبع("فشل: بينما+استمر، حصلت على " + مجموع.إلى_نص())
        رجع 1
    }

    // اختبار 5: حلقة + اكسر
    متغير ك = 0
    حلقة {
        ك = ك + 1
        إذا ك == 3 {
            اكسر
        }
    }
    إذا ك == 3 {
        اطبع("نجاح: حلقة+اكسر")
    } وإلا {
        اطبع("فشل: حلقة+اكسر")
        رجع 1
    }

    // اختبار 6: حلقات بينما متداخلة
    متغير خارجي = 0
    متغير إجمالي = 0
    بينما خارجي < 3 {
        متغير داخلي = 0
        بينما داخلي < 4 {
            إجمالي = إجمالي + 1
            داخلي = داخلي + 1
        }
        خارجي = خارجي + 1
    }
    إذا إجمالي == 12 {
        اطبع("نجاح: بينما متداخلة")
    } وإلا {
        اطبع("فشل: بينما متداخلة")
        رجع 1
    }

    // اختبار 7: رجع من سياق متداخل
    اجعل ن = مساعد_جمع(مساعد_جمع(1, 2), مساعد_جمع(3, 4))
    إذا ن == 10 {
        اطبع("نجاح: رجع متداخل")
    } وإلا {
        اطبع("فشل: رجع متداخل")
        رجع 1
    }

    اطبع("نجاح: جميع اختبارات التحكم بالتدفق نجحت")
    رجع 0
}
