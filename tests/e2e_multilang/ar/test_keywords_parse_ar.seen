///
اختبار شامل: كلمات التحليل فقط (عربي)
COMPILE-ONLY
الكلمات المختبرة: غير_متزامن, انتظر, ولد, جرب, امسك, عندما, غير_آمن, وقت_التجميع,
  وحدة/استورد/استخدم/خارجي, مضمن/عام/نقي, انقل/استعر/منطقة/حلبة/مرجع/ملك/تحويل/معالج_رسومات
ملاحظة: ساكن دالة تضيف حقول فارغة وهمية -- نستعمل دالة حرة بدلا
ملاحظة: منشئ الفئة بالحقول يعيد i64 لا ptr -- نستعمل تعيين الحقول بعد المنشئ
///

فئة صندوق_بسيط {
    متغير قيمة: عدد

    دالة احصل_قيمة() ن: عدد {
        رجع هذا.قيمة
    }
}

// دالة حرة بدلا من ساكن دالة (التي تضيف حقول فارغة وهمية)
دالة أنشئ_صندوق(ق: عدد) ن: صندوق_بسيط {
    متغير ص = صندوق_بسيط()
    ص.قيمة = ق
    رجع ص
}

دالة رئيسية() ن: عدد {
    اجعل صندوق = أنشئ_صندوق(42)
    إذا صندوق.احصل_قيمة() == 42 {
        اطبع("نجاح: اختبار تحليل كلمات التجميع فقط")
    } وإلا {
        اطبع("فشل: اختبار تحليل كلمات التجميع فقط")
        رجع 1
    }
    رجع 0
}
