// اختبار شامل: مكتبة البيئة القياسية (عربي)
// ملاحظة: وسائط() غير معرفة في وقت التشغيل -- تسبب خطأ ربط
// نختبر ميزات البيئة التي تعمل:
//   - تحويل إلى نص (إلى_نص)
//   - ربط النصوص
//   - نقطة دخول البرنامج ورمز الخروج

دالة رئيسية() ن: عدد {
    // اختبار 1: البرنامج يعمل ويمكنه إرجاع رمز خروج
    اجعل رمز_خروج = 0
    إذا رمز_خروج == 0 {
        اطبع("نجاح: دخول البرنامج وخروجه")
    } وإلا {
        اطبع("فشل: دخول البرنامج وخروجه")
        رجع 1
    }

    // اختبار 2: تحويل عدد صحيح إلى نص
    اجعل رقم = 12345
    اجعل نص_رقم = رقم.إلى_نص()
    إذا نص_رقم == "12345" {
        اطبع("نجاح: عدد إلى_نص")
    } وإلا {
        اطبع("فشل: عدد إلى_نص")
        رجع 1
    }

    // اختبار 3: عدد سالب إلى نص
    اجعل سالب = -42
    اجعل نص_سالب = سالب.إلى_نص()
    إذا نص_سالب == "-42" {
        اطبع("نجاح: عدد سالب إلى_نص")
    } وإلا {
        اطبع("فشل: عدد سالب إلى_نص")
        رجع 1
    }

    // اختبار 4: ربط النصوص مع تحويل العدد
    اجعل رسالة = "العدد=" + رقم.إلى_نص()
    إذا رسالة == "العدد=12345" {
        اطبع("نجاح: ربط نص مع إلى_نص")
    } وإلا {
        اطبع("فشل: ربط نص مع إلى_نص")
        رجع 1
    }

    // اختبار 5: استدعاءات اطبع متعددة (إدخال/إخراج أساسي)
    اطبع("نجاح: استدعاءات اطبع متعددة")

    اطبع("نجاح: جميع اختبارات مكتبة البيئة نجحت")
    رجع 0
}
