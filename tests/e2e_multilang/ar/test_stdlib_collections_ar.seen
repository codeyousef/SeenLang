///
اختبار شامل: مكتبة المجموعات القياسية (عربي)
الأنواع المختبرة: Array<عدد>, Array<نص>, HashMap<نص, عدد>
ملاحظة: Array و HashMap تبقى بالإنجليزية (أنواع عامة غير مترجمة)
ملاحظة: ضع (put) غير موجودة في وقت التشغيل -- نستعمل insert بدلا
ملاحظة: احصل (get) للخريطة ينتج IR غير صالح -- نستعمل getOrDefault بدلا
///

دالة رئيسية() ن: عدد {
    // اختبار 1: Array<عدد> أضف و احصل
    متغير مصفوفة = Array<عدد>()
    مصفوفة.أضف(10)
    مصفوفة.أضف(20)
    مصفوفة.أضف(30)
    إذا مصفوفة.طول() == 3 {
        اطبع("نجاح: طول المصفوفة")
    } وإلا {
        اطبع("فشل: طول المصفوفة")
        رجع 1
    }

    اجعل أول = مصفوفة.احصل(0)
    إذا أول == 10 {
        اطبع("نجاح: احصل(0) من المصفوفة")
    } وإلا {
        اطبع("فشل: احصل(0) من المصفوفة")
        رجع 1
    }

    اجعل آخر = مصفوفة.احصل(2)
    إذا آخر == 30 {
        اطبع("نجاح: احصل(2) من المصفوفة")
    } وإلا {
        اطبع("فشل: احصل(2) من المصفوفة")
        رجع 1
    }

    // اختبار 2: Array<نص>
    متغير أسماء = Array<نص>()
    أسماء.أضف("مرحبا")
    أسماء.أضف("عالم")
    إذا أسماء.طول() == 2 {
        اطبع("نجاح: طول مصفوفة النصوص")
    } وإلا {
        اطبع("فشل: طول مصفوفة النصوص")
        رجع 1
    }

    اجعل ا0 = أسماء.احصل(0)
    إذا ا0 == "مرحبا" {
        اطبع("نجاح: احصل من مصفوفة النصوص")
    } وإلا {
        اطبع("فشل: احصل من مصفوفة النصوص")
        رجع 1
    }

    // اختبار 3: HashMap<نص, عدد> مع insert (لا ضع)
    متغير خريطة = HashMap<نص, عدد>()
    خريطة.insert("أ", 1)
    خريطة.insert("ب", 2)
    خريطة.insert("ج", 3)

    // نستعمل getOrDefault بدلا من احصل (احصل ينتج IR غير صالح للخريطة)
    اجعل ق_أ = خريطة.getOrDefault("أ", -1)
    إذا ق_أ == 1 {
        اطبع("نجاح: getOrDefault أ من الخريطة")
    } وإلا {
        اطبع("فشل: getOrDefault أ من الخريطة")
        رجع 1
    }

    اجعل ق_ب = خريطة.getOrDefault("ب", -1)
    إذا ق_ب == 2 {
        اطبع("نجاح: getOrDefault ب من الخريطة")
    } وإلا {
        اطبع("فشل: getOrDefault ب من الخريطة")
        رجع 1
    }

    // اختبار 4: containsKey للخريطة
    إذا خريطة.containsKey("ج") {
        اطبع("نجاح: containsKey في الخريطة")
    } وإلا {
        اطبع("فشل: containsKey في الخريطة")
        رجع 1
    }

    // اختبار 5: حجم الخريطة
    اجعل حجم = خريطة.size()
    إذا حجم == 3 {
        اطبع("نجاح: حجم الخريطة")
    } وإلا {
        اطبع("فشل: حجم الخريطة، حصلت على " + حجم.إلى_نص())
        رجع 1
    }

    // اختبار 6: مفتاح مفقود يعيد القيمة الافتراضية
    اجعل مفقود = خريطة.getOrDefault("ز", -999)
    إذا مفقود == -999 {
        اطبع("نجاح: مفتاح مفقود يعيد الافتراضي")
    } وإلا {
        اطبع("فشل: مفتاح مفقود يعيد الافتراضي")
        رجع 1
    }

    اطبع("نجاح: جميع اختبارات المجموعات نجحت")
    رجع 0
}
