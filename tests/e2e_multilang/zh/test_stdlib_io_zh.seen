// 端到端测试: 输入输出标准库 (中文)
// 注意: 高级封装函数 (写文本, 读文本, 存在, 删除文件) 在单文件编译中不可用
// 改用__前缀的运行时函数: __OpenFile, __WriteFile, __CloseFile, __FileSize,
//   __FileExists, __DeleteFile
// 注意: __FileExists/__DeleteFile返回布尔值, 直接在如果条件中使用
// 注意: __ReadFile返回SeenString但代码生成当作i64处理, 无法使用返回的字符串内容
//       改用__FileSize验证

函数 主函数() r: 整数 {
    让 路径 = "/tmp/seen_e2e_test_zh.txt"
    让 内容 = "你好这是Seen语言中文端到端测试"

    // 测试1: 打开文件写入
    让 文件描述符一 = __OpenFile(路径, "w")
    如果 文件描述符一 < 0 {
        打印("失败: 打开文件写入")
        返回 1
    }
    打印("通过: 打开文件写入")

    // 测试2: 写入内容
    让 写入结果 = __WriteFile(文件描述符一, 内容)
    让 关闭一 = __CloseFile(文件描述符一)
    如果 写入结果 >= 0 {
        打印("通过: 写入文件")
    } 否则 {
        打印("失败: 写入文件")
        返回 1
    }

    // 测试3: 文件存在 (布尔返回值, 直接在如果条件中使用)
    如果 __FileExists(路径) {
        打印("通过: 文件存在")
    } 否则 {
        打印("失败: 文件存在")
        返回 1
    }

    // 测试4: 读取并验证文件大小
    // (由于__ReadFile返回类型缺陷, 无法比较字符串内容)
    让 文件描述符二 = __OpenFile(路径, "r")
    如果 文件描述符二 < 0 {
        打印("失败: 打开文件读取")
        返回 1
    }
    让 文件大小 = __FileSize(文件描述符二)
    让 关闭二 = __CloseFile(文件描述符二)
    如果 文件大小 > 0 {
        打印("通过: 文件大小大于零")
    } 否则 {
        打印("失败: 文件大小, 得到 " + 文件大小.转文本())
        返回 1
    }

    // 测试5: 删除文件
    __DeleteFile(路径)
    如果 __FileExists(路径) {
        打印("失败: 删除文件 (文件仍然存在)")
        返回 1
    } 否则 {
        打印("通过: 删除文件")
    }

    打印("通过: 全部输入输出标准库测试通过")
    返回 0
}
