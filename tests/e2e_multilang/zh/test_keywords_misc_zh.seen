///
端到端测试: 杂项关键字 (中文)
测试关键字: 和, 或, 不, 作为, 是
///

函数 主函数() r: 整数 {
    // 测试1: 和
    变量 结果一 = 0
    如果 1 == 1 和 2 == 2 {
        结果一 = 1
    }
    如果 结果一 == 1 {
        打印("通过: 和运算符")
    } 否则 {
        打印("失败: 和运算符")
        返回 1
    }

    // 测试2: 或
    变量 结果二 = 0
    如果 1 == 2 或 3 == 3 {
        结果二 = 1
    }
    如果 结果二 == 1 {
        打印("通过: 或运算符")
    } 否则 {
        打印("失败: 或运算符")
        返回 1
    }

    // 测试3: 不
    变量 结果三 = 0
    如果 不 假 {
        结果三 = 1
    }
    如果 结果三 == 1 {
        打印("通过: 不运算符")
    } 否则 {
        打印("失败: 不运算符")
        返回 1
    }

    // 测试4: 和 + 或 组合
    变量 结果四 = 0
    如果 1 == 1 和 2 == 2 或 3 == 4 {
        结果四 = 1
    }
    如果 结果四 == 1 {
        打印("通过: 和+或组合")
    } 否则 {
        打印("失败: 和+或组合")
        返回 1
    }

    // 测试5: 不 与 和
    变量 结果五 = 0
    如果 不 假 和 1 == 1 {
        结果五 = 1
    }
    如果 结果五 == 1 {
        打印("通过: 不+和组合")
    } 否则 {
        打印("失败: 不+和组合")
        返回 1
    }

    // 测试6: 作为 类型转换（整数到整数；浮点有代码生成错误）
    让 整数值 = 42
    让 整数值二 = 整数值 作为 整数
    如果 整数值二 == 42 {
        打印("通过: 作为类型转换")
    } 否则 {
        打印("失败: 作为类型转换")
        返回 1
    }

    打印("通过: 全部杂项关键字测试通过")
    返回 0
}
