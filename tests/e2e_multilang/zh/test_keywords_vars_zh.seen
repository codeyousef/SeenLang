///
端到端测试: 变量关键字 (中文)
测试关键字: 让, 变量
注意: DSE会消除变量初始化如果立即重赋值 -- 避免 变量 x = A; x = B 模式
///

函数 主函数() r: 整数 {
    // 测试1: 让 (不可变绑定)
    让 甲 = 42
    如果 甲 == 42 {
        打印("通过: 让绑定")
    } 否则 {
        打印("失败: 让绑定")
        返回 1
    }

    // 测试2: 变量 (可变绑定)
    变量 乙 = 25
    如果 乙 == 25 {
        打印("通过: 变量绑定")
    } 否则 {
        打印("失败: 变量绑定")
        返回 1
    }

    // 测试3: 让带表达式
    让 丙 = 50 + 50
    如果 丙 == 100 {
        打印("通过: 让带表达式")
    } 否则 {
        打印("失败: 让带表达式")
        返回 1
    }

    // 测试4: 变量加法变更
    变量 丁 = 10
    丁 = 丁 + 5
    如果 丁 == 15 {
        打印("通过: 变量加法变更")
    } 否则 {
        打印("失败: 变量加法变更")
        返回 1
    }

    // 测试5: 让和变量组合
    让 一 = 1
    让 二 = 2
    让 三 = 3
    变量 四 = 一 + 二 + 三
    如果 四 == 6 {
        打印("通过: 让和变量组合")
    } 否则 {
        打印("失败: 让和变量组合")
        返回 1
    }

    // 测试6: 变量带求和
    变量 总和 = 1 + 2 + 3 + 4 + 5
    如果 总和 == 15 {
        打印("通过: 变量带求和")
    } 否则 {
        打印("失败: 变量带求和")
        返回 1
    }

    打印("通过: 全部变量关键字测试通过")
    返回 0
}
