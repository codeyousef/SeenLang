// 端到端测试: 数学运算 (中文)
// 注意: 浮点标准库调用 (平方根, 正弦, 余弦, 绝对值, 取整, 上取整, 幂)
// 返回i64而非double, 由代码生成缺陷所致. 仅测试整数数学运算.
// 取模运算 (%) 有缺陷, 使用替代方案: 甲 - (甲/乙) * 乙

函数 主函数() r: 整数 {
    // 测试1: 整数绝对值 (条件判断)
    变量 甲 = -5
    如果 甲 < 0 {
        甲 = 0 - 甲
    }
    如果 甲 == 5 {
        打印("通过: 整数绝对值")
    } 否则 {
        打印("失败: 整数绝对值")
        返回 1
    }

    // 测试2: 整数最小值 (比较)
    让 数甲 = 10
    让 数乙 = 20
    变量 最小 = 数甲
    如果 数乙 < 数甲 {
        最小 = 数乙
    }
    如果 最小 == 10 {
        打印("通过: 整数最小值")
    } 否则 {
        打印("失败: 整数最小值")
        返回 1
    }

    // 测试3: 整数最大值 (比较)
    变量 最大 = 数甲
    如果 数乙 > 数甲 {
        最大 = 数乙
    }
    如果 最大 == 20 {
        打印("通过: 整数最大值")
    } 否则 {
        打印("失败: 整数最大值")
        返回 1
    }

    // 测试4: 整数幂运算 (2^10 = 1024, 循环计算)
    变量 结果 = 1
    变量 计数 = 0
    当 计数 < 10 {
        结果 = 结果 * 2
        计数 = 计数 + 1
    }
    如果 结果 == 1024 {
        打印("通过: 整数幂运算 2^10")
    } 否则 {
        打印("失败: 整数幂运算 2^10, 得到 " + 结果.转文本())
        返回 1
    }

    // 测试5: 取模运算替代方案 (% 有缺陷)
    让 被除数 = 17
    让 除数 = 5
    让 余数 = 被除数 - (被除数 / 除数) * 除数
    如果 余数 == 2 {
        打印("通过: 整数取模替代方案")
    } 否则 {
        打印("失败: 整数取模替代方案, 得到 " + 余数.转文本())
        返回 1
    }

    // 测试6: 整数除法
    让 除法结果 = 100 / 7
    如果 除法结果 == 14 {
        打印("通过: 整数除法")
    } 否则 {
        打印("失败: 整数除法, 得到 " + 除法结果.转文本())
        返回 1
    }

    // 测试7: 负数
    让 负值 = 0 - 42
    如果 负值 == -42 {
        打印("通过: 负数")
    } 否则 {
        打印("失败: 负数")
        返回 1
    }

    // 测试8: 运算优先级 (乘法优先于加法)
    让 表达式 = 2 + 3 * 4
    如果 表达式 == 14 {
        打印("通过: 运算优先级")
    } 否则 {
        打印("失败: 运算优先级, 得到 " + 表达式.转文本())
        返回 1
    }

    // 测试9: 括号表达式
    让 括号 = (2 + 3) * 4
    如果 括号 == 20 {
        打印("通过: 括号表达式")
    } 否则 {
        打印("失败: 括号表达式, 得到 " + 括号.转文本())
        返回 1
    }

    // 测试10: 连续乘法
    让 连乘 = 2 * 3 * 4
    如果 连乘 == 24 {
        打印("通过: 连续乘法")
    } 否则 {
        打印("失败: 连续乘法, 得到 " + 连乘.转文本())
        返回 1
    }

    打印("通过: 全部数学运算测试通过")
    返回 0
}
