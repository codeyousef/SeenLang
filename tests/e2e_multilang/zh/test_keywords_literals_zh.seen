// 端到端测试: 字面量关键字 (中文)
// 测试关键字: 真, 假, 空

函数 是否为正(数: 整数) r: 整数 {
    如果 数 > 0 {
        返回 1
    }
    返回 0
}

函数 主函数() r: 整数 {
    // 测试1: 真 用于条件
    变量 标志 = 0
    如果 真 {
        标志 = 1
    }
    如果 标志 == 1 {
        打印("通过: 真值字面量")
    } 否则 {
        打印("失败: 真值字面量")
        返回 1
    }

    // 测试2: 假 用于条件
    变量 标志二 = 1
    如果 假 {
        标志二 = 0
    }
    如果 标志二 == 1 {
        打印("通过: 假值字面量")
    } 否则 {
        打印("失败: 假值字面量")
        返回 1
    }

    // 测试3: 真 和 真
    变量 结果 = 0
    如果 真 和 真 {
        结果 = 1
    }
    如果 结果 == 1 {
        打印("通过: 真和真")
    } 否则 {
        打印("失败: 真和真")
        返回 1
    }

    // 测试4: 真 和 假
    变量 结果二 = 1
    如果 真 和 假 {
        结果二 = 0
    }
    如果 结果二 == 1 {
        打印("通过: 真和假")
    } 否则 {
        打印("失败: 真和假")
        返回 1
    }

    // 测试5: 不 假
    变量 结果三 = 0
    如果 不 假 {
        结果三 = 1
    }
    如果 结果三 == 1 {
        打印("通过: 不假")
    } 否则 {
        打印("失败: 不假")
        返回 1
    }

    // 测试6: 检查返回值
    让 值甲 = 是否为正(5)
    如果 值甲 == 1 {
        打印("通过: 非零值")
    } 否则 {
        打印("失败: 非零值")
        返回 1
    }

    让 值乙 = 是否为正(-3)
    如果 值乙 == 0 {
        打印("通过: 零值")
    } 否则 {
        打印("失败: 零值")
        返回 1
    }

    打印("通过: 全部字面量关键字测试通过")
    返回 0
}
