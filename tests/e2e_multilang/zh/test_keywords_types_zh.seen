// 端到端测试: 类型关键字 (中文)
// 测试关键字: 类, 枚举
// 注意: 特征+实现有代码生成缺陷（缺少this参数）-- 省略
// 注意: 继承有继承字段赋值缺陷 -- 省略
// 注意: 非ASCII名的多字段有structIdx缺陷 -- 使用单个整数字段

枚举 颜色 {
    红色,
    绿色,
    蓝色
}

类 计数器 {
    变量 数值: 整数

    函数 获取() r: 整数 {
        返回 此.数值
    }
}

函数 创建计数器(值: 整数) r: 计数器 {
    变量 计 = 计数器()
    计.数值 = 值
    返回 计
}

函数 主函数() r: 整数 {
    // 测试1: 枚举相等
    让 颜1 = 颜色.红色
    让 颜2 = 颜色.红色
    如果 颜1 == 颜2 {
        打印("通过: 枚举相等")
    } 否则 {
        打印("失败: 枚举相等")
        返回 1
    }

    // 测试2: 枚举不等
    让 颜3 = 颜色.蓝色
    如果 颜1 != 颜3 {
        打印("通过: 枚举不等")
    } 否则 {
        打印("失败: 枚举不等")
        返回 1
    }

    // 测试3: 类（单个整数字段 + 方法）
    让 计1 = 创建计数器(42)
    如果 计1.获取() == 42 {
        打印("通过: 类方法")
    } 否则 {
        打印("失败: 类方法")
        返回 1
    }

    // 测试4: 基本类型
    让 甲 = 100
    如果 甲 == 100 {
        打印("通过: 基本类型")
    } 否则 {
        打印("失败: 基本类型")
        返回 1
    }

    打印("通过: 全部类型关键字测试通过")
    返回 0
}
