// 端到端测试: 字符串标准库 (中文)
// 测试函数: 包含, 开头是, 结尾是, 索引位置, 长度, 字符串连接
// 注意: 包含/开头是/结尾是返回布尔值, 必须直接在如果条件中使用,
//       不能赋值给变量后与 == 1 比较 (i1与i64不匹配)
// 注意: 索引位置需要3个参数: (文本, 目标, 起始位置)

函数 主函数() r: 整数 {
    让 文本 = "hello world"

    // 测试1: 字符串长度
    让 长 = 文本.长度()
    如果 长 == 11 {
        打印("通过: 字符串长度")
    } 否则 {
        打印("失败: 字符串长度, 得到 " + 长.转文本())
        返回 1
    }

    // 测试2: 包含 (返回布尔值, 直接在如果条件中使用)
    如果 包含(文本, "world") {
        打印("通过: 包含")
    } 否则 {
        打印("失败: 包含")
        返回 1
    }

    // 测试3: 开头是 (返回布尔值, 直接在如果条件中使用)
    如果 开头是(文本, "hello") {
        打印("通过: 开头是")
    } 否则 {
        打印("失败: 开头是")
        返回 1
    }

    // 测试4: 结尾是 (返回布尔值, 直接在如果条件中使用)
    如果 结尾是(文本, "world") {
        打印("通过: 结尾是")
    } 否则 {
        打印("失败: 结尾是")
        返回 1
    }

    // 测试5: 索引位置 (需要3个参数: 文本, 目标, 起始位置)
    让 位置 = 索引位置(文本, "world", 0)
    如果 位置 == 6 {
        打印("通过: 索引位置")
    } 否则 {
        打印("失败: 索引位置, 得到 " + 位置.转文本())
        返回 1
    }

    // 测试6: 字符串连接
    让 问候 = "你好" + " " + "世界"
    如果 问候 == "你好 世界" {
        打印("通过: 字符串连接")
    } 否则 {
        打印("失败: 字符串连接")
        返回 1
    }

    // 测试7: 包含 否定情况
    如果 包含(文本, "xyz") {
        打印("失败: 包含否定")
        返回 1
    } 否则 {
        打印("通过: 包含否定")
    }

    // 测试8: 索引位置 未找到返回-1
    让 未找到 = 索引位置(文本, "xyz", 0)
    如果 未找到 == -1 {
        打印("通过: 索引位置未找到")
    } 否则 {
        打印("失败: 索引位置未找到, 得到 " + 未找到.转文本())
        返回 1
    }

    打印("通过: 全部字符串标准库测试通过")
    返回 0
}
