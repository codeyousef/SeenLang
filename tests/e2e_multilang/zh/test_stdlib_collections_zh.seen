///
端到端测试: 集合标准库 (中文)
测试类型: Array<整数>, Array<字符串>, HashMap<字符串, 整数>
注意: HashMap.放入()不存在, 改用insert()
注意: HashMap.获取()生成无效IR, 改用getOrDefault()
注意: containsKey()返回布尔值, 直接在如果条件中使用
///

函数 主函数() r: 整数 {
    // 测试1: Array<整数> 添加和获取
    变量 数组 = Array<整数>()
    数组.添加(10)
    数组.添加(20)
    数组.添加(30)
    如果 数组.长度() == 3 {
        打印("通过: 数组长度")
    } 否则 {
        打印("失败: 数组长度")
        返回 1
    }

    让 第一个 = 数组.获取(0)
    如果 第一个 == 10 {
        打印("通过: 数组获取(0)")
    } 否则 {
        打印("失败: 数组获取(0)")
        返回 1
    }

    让 最后一个 = 数组.获取(2)
    如果 最后一个 == 30 {
        打印("通过: 数组获取(2)")
    } 否则 {
        打印("失败: 数组获取(2)")
        返回 1
    }

    // 测试2: Array<字符串>
    变量 名字列表 = Array<字符串>()
    名字列表.添加("你好")
    名字列表.添加("世界")
    如果 名字列表.长度() == 2 {
        打印("通过: 字符串数组长度")
    } 否则 {
        打印("失败: 字符串数组长度")
        返回 1
    }

    让 首项 = 名字列表.获取(0)
    如果 首项 == "你好" {
        打印("通过: 字符串数组获取")
    } 否则 {
        打印("失败: 字符串数组获取")
        返回 1
    }

    // 测试3: HashMap<字符串, 整数> 使用insert (放入不存在)
    变量 映射 = HashMap<字符串, 整数>()
    映射.insert("甲", 1)
    映射.insert("乙", 2)
    映射.insert("丙", 3)

    // 使用getOrDefault替代获取 (获取返回Option<T>会导致代码生成崩溃)
    让 值甲 = 映射.getOrDefault("甲", -1)
    如果 值甲 == 1 {
        打印("通过: 映射getOrDefault甲")
    } 否则 {
        打印("失败: 映射getOrDefault甲")
        返回 1
    }

    让 值乙 = 映射.getOrDefault("乙", -1)
    如果 值乙 == 2 {
        打印("通过: 映射getOrDefault乙")
    } 否则 {
        打印("失败: 映射getOrDefault乙")
        返回 1
    }

    // 测试4: HashMap containsKey (返回布尔值, 直接在如果条件中使用)
    如果 映射.containsKey("丙") {
        打印("通过: 映射containsKey")
    } 否则 {
        打印("失败: 映射containsKey")
        返回 1
    }

    // 测试5: HashMap size
    让 大小 = 映射.size()
    如果 大小 == 3 {
        打印("通过: 映射size")
    } 否则 {
        打印("失败: 映射size, 得到 " + 大小.转文本())
        返回 1
    }

    // 测试6: HashMap 缺失键返回默认值
    让 缺失 = 映射.getOrDefault("不存在", -999)
    如果 缺失 == -999 {
        打印("通过: 映射缺失键默认值")
    } 否则 {
        打印("失败: 映射缺失键默认值")
        返回 1
    }

    打印("通过: 全部集合标准库测试通过")
    返回 0
}
