// 端到端测试: 环境标准库 (中文)
// 注意: 参数()函数在运行时未定义, 会导致链接错误
// 改为测试其他环境相关功能: 转文本, 字符串连接, 打印

函数 主函数() r: 整数 {
    // 测试1: 程序入口和退出码
    让 退出码 = 0
    如果 退出码 == 0 {
        打印("通过: 程序入口和退出")
    } 否则 {
        打印("失败: 程序入口和退出")
        返回 1
    }

    // 测试2: 整数转字符串
    让 数字 = 12345
    让 数字文本 = 数字.转文本()
    如果 数字文本 == "12345" {
        打印("通过: 整数转文本")
    } 否则 {
        打印("失败: 整数转文本")
        返回 1
    }

    // 测试3: 负整数转字符串
    让 负数 = -42
    让 负数文本 = 负数.转文本()
    如果 负数文本 == "-42" {
        打印("通过: 负整数转文本")
    } 否则 {
        打印("失败: 负整数转文本")
        返回 1
    }

    // 测试4: 字符串连接与整数转换
    让 消息 = "计数=" + 数字.转文本()
    如果 消息 == "计数=12345" {
        打印("通过: 字符串连接与转文本")
    } 否则 {
        打印("失败: 字符串连接与转文本")
        返回 1
    }

    // 测试5: 多次打印调用 (基本输出)
    打印("通过: 多次打印调用")

    打印("通过: 全部环境标准库测试通过")
    返回 0
}
