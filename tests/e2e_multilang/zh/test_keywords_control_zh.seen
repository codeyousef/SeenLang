// 端到端测试: 控制流关键字 (中文)
// 测试关键字: 函数, 如果, 否则, 当, 中断, 继续, 返回, 循环

函数 辅助求和(甲: 整数, 乙: 整数) r: 整数 {
    返回 甲 + 乙
}

函数 辅助取反(值: 整数) r: 整数 {
    返回 0 - 值
}

函数 主函数() r: 整数 {
    // 测试1: 函数 + 返回
    让 结果 = 辅助求和(3, 4)
    如果 结果 == 7 {
        打印("通过: 函数+返回")
    } 否则 {
        打印("失败: 函数+返回")
        返回 1
    }

    // 测试2: 如果 + 否则
    让 负数 = 辅助取反(5)
    如果 负数 == -5 {
        打印("通过: 如果+否则")
    } 否则 {
        打印("失败: 如果+否则")
        返回 1
    }

    // 测试3: 当 + 中断
    变量 甲 = 0
    当 甲 < 100 {
        如果 甲 == 5 {
            中断
        }
        甲 = 甲 + 1
    }
    如果 甲 == 5 {
        打印("通过: 当+中断")
    } 否则 {
        打印("失败: 当+中断")
        返回 1
    }

    // 测试4: 当 + 继续 (求1到10的奇数之和)
    变量 总和 = 0
    变量 乙 = 0
    当 乙 < 10 {
        乙 = 乙 + 1
        让 余数 = 乙 - (乙 / 2) * 2
        如果 余数 == 0 {
            继续
        }
        总和 = 总和 + 乙
    }
    如果 总和 == 25 {
        打印("通过: 当+继续")
    } 否则 {
        打印("失败: 当+继续, 得到 " + 总和.转文本())
        返回 1
    }

    // 测试5: 循环 + 中断
    变量 丙 = 0
    循环 {
        丙 = 丙 + 1
        如果 丙 == 3 {
            中断
        }
    }
    如果 丙 == 3 {
        打印("通过: 循环+中断")
    } 否则 {
        打印("失败: 循环+中断")
        返回 1
    }

    // 测试6: 嵌套当循环
    变量 外层 = 0
    变量 合计 = 0
    当 外层 < 3 {
        变量 内层 = 0
        当 内层 < 4 {
            合计 = 合计 + 1
            内层 = 内层 + 1
        }
        外层 = 外层 + 1
    }
    如果 合计 == 12 {
        打印("通过: 嵌套当循环")
    } 否则 {
        打印("失败: 嵌套当循环")
        返回 1
    }

    // 测试7: 嵌套返回
    让 嵌套结果 = 辅助求和(辅助求和(1, 2), 辅助求和(3, 4))
    如果 嵌套结果 == 10 {
        打印("通过: 嵌套返回")
    } 否则 {
        打印("失败: 嵌套返回")
        返回 1
    }

    打印("通过: 全部控制流测试通过")
    返回 0
}
