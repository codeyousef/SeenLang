///
Test that macro definitions are parsed correctly
This test verifies the parser recognizes @macro decorated functions
///

// Define a macro (will be skipped during codegen)
@macro
fun identity(target: AstNode) r: AstNode {
    return target
}

// A normal function
fun greet() r: Void {
    println("Hello!")
}

fun main() r: Int {
    greet()
    return 0
}
