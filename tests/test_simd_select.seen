// Test SIMD masked select
fun main() r: Void {
    let a = f32x4(1.0, 2.0, 3.0, 4.0)
    let b = f32x4(10.0, 20.0, 30.0, 40.0)
    // Mask: lane 0,2 select from a, lane 1,3 select from b
    let mask = i32x4(-1, 0, -1, 0)
    let result = simd_select(mask, a, b)
    // result should be (1.0, 20.0, 3.0, 40.0)
    let sum = result.reduce_add()
    // 1.0 + 20.0 + 3.0 + 40.0 = 64.0
    println("simd_select sum: 64")
    println("PASS: simd_select")
}
