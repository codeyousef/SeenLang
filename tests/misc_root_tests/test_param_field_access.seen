class Matrix {
    data: Array<Float>
    rows: Int
    cols: Int
    
    fun new(rows: Int, cols: Int) -> Matrix {
        let size = rows * cols
        let arr = Array<Float>.withCapacity(size)
        var i = 0
        while i < size {
            arr.push(0.0)
            i = i + 1
        }
        Matrix { data: arr, rows: rows, cols: cols }
    }
}

fun simple_test(a: Matrix) -> Void {
    __Print("Entered simple_test\n")
    __PrintInt(a.rows)
    __Print("\n")
}

fun main() -> Int {
    __Print("Creating matrix\n")
    let m = Matrix.new(2, 2)
    __Print("About to call simple_test\n")
    simple_test(m)
    __Print("Done\n")
    return 0
}
