// Test --panic-on-overflow flag with overflow
// When compiled with --panic-on-overflow, this program will panic
// Without the flag, it will print -9223372036854775808 (wrap around)

fun main() r: Int {
    let max = 9223372036854775807  // Int max (2^63 - 1)
    println("Max Int: " + max.toString())

    // This will overflow when --panic-on-overflow is enabled
    let result = max + 1

    // If we get here, overflow checking is not enabled
    println("Result after overflow: " + result.toString())
    return 0
}
