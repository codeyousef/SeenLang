class Matrix {
    data: Array<Float>
    rows: Int
    cols: Int
    
    fun new(rows: Int, cols: Int) -> Matrix {
        let size = rows * cols
        let arr = Array<Float>.withCapacity(size)
        var i = 0
        while i < size {
            arr.push(0.0)
            i = i + 1
        }
        Matrix { data: arr, rows: rows, cols: cols }
    }
}

fun compute_checksum(m: Matrix) -> Float {
    var sum = 0.0
    var i = 0
    while i < m.data.length() {
        sum = sum + m.data[i]
        i = i + 1
    }
    sum
}

fun main() -> Int {
    let m = Matrix.new(5, 5)
    let checksum = compute_checksum(m)
    __PrintFloat(checksum)
    __Print("\n")
    return 0
}
