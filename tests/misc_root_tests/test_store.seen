// Test for @store decorator
// Tests deterministic state management with mutation logging

// A simple game state store
@store
class GameState {
    var score: Int
    var level: Int
    var playerX: Int
    var playerY: Int
    var isGameOver: Bool

    static fun new() r: GameState {
        return GameState{
            score: 0,
            level: 1,
            playerX: 0,
            playerY: 0,
            isGameOver: false
        }
    }

    // Mutation methods - these would be logged
    fun addScore(points: Int) r: Void {
        score = score + points
    }

    fun nextLevel() r: Void {
        level = level + 1
    }

    fun movePlayer(dx: Int, dy: Int) r: Void {
        playerX = playerX + dx
        playerY = playerY + dy
    }

    fun setGameOver() r: Void {
        isGameOver = true
    }

    // Query methods - these don't mutate state
    fun getScore() r: Int {
        return score
    }

    fun getLevel() r: Int {
        return level
    }

    fun getPosition() r: String {
        return "(" + playerX.toString() + ", " + playerY.toString() + ")"
    }
}

// A deterministic inventory store using BTreeMap (allowed)
@store
class Inventory {
    var items: Array<String>
    var quantities: Array<Int>
    var maxSlots: Int

    static fun new(maxSlots: Int) r: Inventory {
        return Inventory{
            items: Array<String>(),
            quantities: Array<Int>(),
            maxSlots: maxSlots
        }
    }

    fun addItem(item: String, quantity: Int) r: Bool {
        // Check if item already exists
        var i = 0
        while i < items.length() {
            if items[i] == item {
                quantities[i] = quantities[i] + quantity
                return true
            }
            i = i + 1
        }

        // Add new item if space available
        if items.length() < maxSlots {
            items.push(item)
            quantities.push(quantity)
            return true
        }

        return false
    }

    fun removeItem(item: String, quantity: Int) r: Bool {
        var i = 0
        while i < items.length() {
            if items[i] == item {
                if quantities[i] >= quantity {
                    quantities[i] = quantities[i] - quantity
                    return true
                }
                return false
            }
            i = i + 1
        }
        return false
    }

    fun getQuantity(item: String) r: Int {
        var i = 0
        while i < items.length() {
            if items[i] == item {
                return quantities[i]
            }
            i = i + 1
        }
        return 0
    }

    fun printInventory() r: Void {
        println("Inventory (" + items.length().toString() + "/" + maxSlots.toString() + " slots):")
        var i = 0
        while i < items.length() {
            println("  " + items[i] + " x" + quantities[i].toString())
            i = i + 1
        }
    }
}

fun main() r: Int {
    println("=== Store Decorator Test ===")
    println("")

    // Test 1: Game State
    println("--- Test 1: Game State Store ---")
    let state = GameState.new()
    println("Initial score: " + state.getScore().toString())
    println("Initial level: " + state.getLevel().toString())
    println("Initial position: " + state.getPosition())

    state.addScore(100)
    state.addScore(50)
    state.movePlayer(5, 3)
    state.nextLevel()

    println("After mutations:")
    println("  Score: " + state.getScore().toString())
    println("  Level: " + state.getLevel().toString())
    println("  Position: " + state.getPosition())
    println("")

    // Test 2: Inventory Store
    println("--- Test 2: Inventory Store ---")
    let inv = Inventory.new(10)

    inv.addItem("Sword", 1)
    inv.addItem("Health Potion", 5)
    inv.addItem("Gold Coin", 100)
    inv.addItem("Health Potion", 3)  // Should stack

    inv.printInventory()

    println("")
    println("Using 2 Health Potions...")
    inv.removeItem("Health Potion", 2)
    inv.printInventory()

    println("")

    // Test 3: Snapshot and restore (auto-generated methods)
    println("--- Test 3: Snapshot/Restore ---")
    let state2 = GameState.new()
    state2.addScore(500)
    state2.movePlayer(10, 20)
    println("Before snapshot:")
    println("  Score: " + state2.getScore().toString())
    println("  Position: " + state2.getPosition())

    // Take snapshot (auto-generated by @store)
    let snap = state2.snapshot()
    println("Snapshot taken")

    // Make more changes
    state2.addScore(1000)
    state2.movePlayer(100, 100)
    println("After more changes:")
    println("  Score: " + state2.getScore().toString())
    println("  Position: " + state2.getPosition())

    // Restore from snapshot (auto-generated by @store)
    state2.restore(snap)
    println("After restore:")
    println("  Score: " + state2.getScore().toString())
    println("  Position: " + state2.getPosition())
    println("")

    println("=== All Store Tests Passed ===")
    return 0
}
