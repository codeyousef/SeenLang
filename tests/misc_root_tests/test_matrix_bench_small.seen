///
Matrix Multiplication Benchmark (SGEMM)
High-performance matrix multiplication with cache blocking
///

class Matrix {
    data: Array<Float>
    rows: Int
    cols: Int
    
    fun new(rows: Int, cols: Int) -> Matrix {
        let size = rows * cols
        let arr = Array<Float>.withCapacity(size)
        var i = 0
        while i < size {
            arr.push(0.0)
            i = i + 1
        }
        Matrix { data: arr, rows: rows, cols: cols }
    }
    
    fun get(row: Int, col: Int) -> Float {
        this.data[row * this.cols + col]
    }
    
    fun set(row: Int, col: Int, value: Float) -> Void {
        this.data[row * this.cols + col] = value
    }
    
    fun fill_random(seed: Int) -> Void {
        var current_seed = seed
        var i = 0
        while i < this.data.length() {
            current_seed = (current_seed * 1103515245 + 12345) & 0x7fffffff
            let value = (current_seed % 10000) as Float / 10000.0
            this.data[i] = value
            i = i + 1
        }
    }
}

fun matrix_multiply(a: Matrix, b: Matrix, c: Matrix) -> Void {
    let block_size = 64
    
    var ii = 0
    while ii < a.rows {
        var jj = 0
        while jj < b.cols {
            var kk = 0
            while kk < a.cols {
                let i_end = min(ii + block_size, a.rows)
                let j_end = min(jj + block_size, b.cols)
                let k_end = min(kk + block_size, a.cols)
                
                var i = ii
                while i < i_end {
                    var j = jj
                    while j < j_end {
                        var sum = c.get(i, j)
                        var k = kk
                        while k < k_end {
                            sum = sum + a.get(i, k) * b.get(k, j)
                            k = k + 1
                        }
                        c.set(i, j, sum)
                        j = j + 1
                    }
                    i = i + 1
                }
                
                kk = kk + block_size
            }
            jj = jj + block_size
        }
        ii = ii + block_size
    }
}

fun min(a: Int, b: Int) -> Int {
    if a < b { a } else { b }
}

fun compute_checksum(m: Matrix) -> Float {
    var sum = 0.0
    var i = 0
    while i < m.data.length() {
        sum = sum + m.data[i]
        i = i + 1
    }
    sum
}

fun main() -> Int {
    let size = 4
    
    __Print("Matrix Multiplication Benchmark (SGEMM)\n")
    __Print("Matrix size: ")
    __PrintInt(size)
    __Print("x")
    __PrintInt(size)
    __Print("\n")
    
    let a = Matrix.new(size, size)
    let b = Matrix.new(size, size)
    let c = Matrix.new(size, size)
    
    a.fill_random(12345)
    b.fill_random(67890)
    
    let warmup_runs = 3
    __Print("Warming up (")
    __PrintInt(warmup_runs)
    __Print(" runs)...\n")
    var w = 0
    while w < warmup_runs {
        matrix_multiply(a, b, c)
        w = w + 1
    }
    
    __Print("Running measured iterations...\n")
    let iterations = 5
    var min_time = 1000000.0
    var i = 0
    while i < iterations {
        let c_fresh = Matrix.new(size, size)
        
        let start = __GetTime()
        matrix_multiply(a, b, c_fresh)
        let end = __GetTime()
        
        let elapsed = (end - start) * 1000.0
        if elapsed < min_time {
            min_time = elapsed
        }
        i = i + 1
    }
    
    let checksum = compute_checksum(c)
    let gflops = (2.0 * (size as Float) * (size as Float) * (size as Float)) / (min_time / 1000.0) / 1000000000.0
    
    __Print("Checksum: ")
    __PrintFloat(checksum)
    __Print("\nMin time: ")
    __PrintFloat(min_time)
    __Print(" ms\n")
    __Print("Performance: ")
    __PrintFloat(gflops)
    __Print(" GFLOPS\n")
    
    return 0
}
