// Test all critical language features for benchmarks

fun testMutableVariables() {
    var x = 10
    x = 20
    x = x + 5
    println("Mutable var test: {x}")
}

fun testWhileLoop() {
    var sum = 0
    var i = 1
    while i <= 10 {
        sum = sum + i
        i = i + 1
    }
    println("While loop sum 1-10: {sum}")
}

fun testArrayIndexing() {
    let arr = [1, 2, 3, 4, 5]
    let first = arr[0]
    let last = arr[4]
    println("Array indexing: first={first}, last={last}")
}

fun testFloatLiterals() {
    let pi = 3.14159
    let e = 2.71828
    let result = pi + e
    println("Float literals: pi={pi}, e={e}, sum={result}")
}

fun testStructMutation() {
    // Simplified - struct definitions need work
    println("Struct test: skipped (needs parser fix)")
}

fun main() {
    println("Testing all critical language features...")
    testMutableVariables()
    testWhileLoop()
    testArrayIndexing()
    testFloatLiterals()
    testStructMutation()
    println("All tests completed!")
}
