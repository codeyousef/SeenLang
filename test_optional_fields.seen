struct ItemNode {
    itemType: String
    name: String
    function: FunctionNode?
}

struct FunctionNode {
    name: String
    params: Array<ParamNode>
}

struct ParamNode {
    name: String
}

fun main() -> Int {
    let fn = FunctionNode{
        name: "test",
        params: Array<ParamNode>()
    }
    
    let item = ItemNode{
        itemType: "Function",
        name: "test",
        function: fn
    }
    
    if item.itemType == "Function" {
        return 1
    }
    
    return 0
}
