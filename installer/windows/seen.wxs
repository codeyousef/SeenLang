<?xml version="1.0" encoding="UTF-8"?>
<Wix xmlns="http://schemas.microsoft.com/wix/2006/wi"
     xmlns:util="http://schemas.microsoft.com/wix/UtilExtension">

  <?define ProductName = "Seen Language" ?>
  <?define Manufacturer = "Seen Language Team" ?>
  <?define UpgradeCode = "A1B2C3D4-E5F6-7890-ABCD-EF1234567890" ?>

  <Product Id="*"
           Name="$(var.ProductName)"
           Language="1033"
           Version="$(var.Version)"
           Manufacturer="$(var.Manufacturer)"
           UpgradeCode="$(var.UpgradeCode)">

    <Package InstallerVersion="200"
             Compressed="yes"
             InstallScope="perMachine"
             Description="Seen Programming Language Compiler and Toolchain"
             Comments="High-performance systems programming language"
             Keywords="programming,language,compiler,systems"
             Platform="$(var.Platform)" />

    <MediaTemplate EmbedCab="yes" CompressionLevel="high" />

    <MajorUpgrade DowngradeErrorMessage="A newer version of [ProductName] is already installed."
                  AllowSameVersionUpgrades="yes" />

    <!-- Icon for Add/Remove Programs -->
    <?if $(var.HasIcon) = "yes" ?>
    <Icon Id="SeenIcon" SourceFile="$(var.IconPath)" />
    <Property Id="ARPPRODUCTICON" Value="SeenIcon" />
    <?endif ?>

    <!-- Properties -->
    <Property Id="WIXUI_INSTALLDIR" Value="INSTALLFOLDER" />
    <Property Id="ARPURLINFOABOUT" Value="https://github.com/codeyousef/SeenLang" />
    <Property Id="ARPCONTACT" Value="https://github.com/codeyousef/SeenLang" />

    <!-- Detect previous installation -->
    <Property Id="INSTALLFOLDER">
      <RegistrySearch Id="FindInstallLocation"
                      Root="HKLM"
                      Key="SOFTWARE\SeenLanguage"
                      Name="InstallPath"
                      Type="raw" />
    </Property>

    <!-- UI -->
    <UIRef Id="WixUI_FeatureTree" />
    <?if $(var.HasLicense) = "yes" ?>
    <WixVariable Id="WixUILicenseRtf" Value="$(var.LicenseRtf)" />
    <?endif ?>

    <!-- Features -->
    <Feature Id="MainFeature"
             Title="Seen Compiler"
             Description="The Seen language compiler and core tools."
             Level="1"
             AllowAdvertise="no">
      <ComponentGroupRef Id="CompilerBinaries" />
      <ComponentRef Id="PathEnvVar" />
      <ComponentRef Id="RegistryEntries" />
      <ComponentRef Id="FileAssociations" />
    </Feature>

    <Feature Id="RuntimeFeature"
             Title="Runtime Headers"
             Description="C runtime headers for FFI and advanced usage."
             Level="1"
             AllowAdvertise="no">
      <ComponentGroupRef Id="RuntimeFiles" />
    </Feature>

    <Feature Id="StdlibFeature"
             Title="Standard Library"
             Description="The Seen standard library source files."
             Level="1"
             AllowAdvertise="no">
      <ComponentGroupRef Id="StdlibFiles" />
    </Feature>

    <Feature Id="LanguagesFeature"
             Title="Language Configurations"
             Description="Multi-language keyword support (English, Arabic, Spanish, Russian, Chinese, Japanese)."
             Level="1"
             AllowAdvertise="no">
      <ComponentGroupRef Id="LanguageFiles" />
    </Feature>

    <Feature Id="DocsFeature"
             Title="Documentation"
             Description="Language guide, API reference, and examples."
             Level="2"
             AllowAdvertise="no">
      <ComponentGroupRef Id="DocFiles" />
    </Feature>

    <Feature Id="StartMenuFeature"
             Title="Start Menu Shortcuts"
             Description="Add Seen Language shortcuts to the Start Menu."
             Level="1"
             AllowAdvertise="no">
      <ComponentRef Id="StartMenuShortcuts" />
    </Feature>

    <!-- Directory structure -->
    <Directory Id="TARGETDIR" Name="SourceDir">
      <Directory Id="ProgramFiles64Folder">
        <Directory Id="INSTALLFOLDER" Name="Seen">
          <Directory Id="BinDir" Name="bin" />
          <Directory Id="LibDir" Name="lib">
            <Directory Id="SeenLibDir" Name="seen">
              <Directory Id="RuntimeDir" Name="runtime" />
              <Directory Id="StdlibDir" Name="std" />
            </Directory>
          </Directory>
          <Directory Id="ShareDir" Name="share">
            <Directory Id="SeenShareDir" Name="seen">
              <Directory Id="LanguagesDir" Name="languages" />
              <Directory Id="DocsDir" Name="docs" />
            </Directory>
          </Directory>
        </Directory>
      </Directory>

      <Directory Id="ProgramMenuFolder">
        <Directory Id="SeenProgramsFolder" Name="Seen Language" />
      </Directory>
    </Directory>

    <!-- Compiler binaries (always present: seen.exe; optional: seen-lsp.exe) -->
    <ComponentGroup Id="CompilerBinaries" Directory="BinDir">
      <Component Id="SeenExe" Guid="B7A1C2D3-E4F5-6789-ABCD-111111111111">
        <File Id="seen_exe"
              Source="$(var.SourceDir)\bin\seen.exe"
              KeyPath="yes" />
      </Component>
    </ComponentGroup>

    <!-- Runtime headers -->
    <ComponentGroup Id="RuntimeFiles" Directory="RuntimeDir">
      <Component Id="RuntimeHeader" Guid="B7A1C2D3-E4F5-6789-ABCD-222222222222">
        <File Id="seen_runtime_h"
              Source="$(var.SourceDir)\lib\seen\runtime\seen_runtime.h"
              KeyPath="yes" />
      </Component>
      <Component Id="RegionHeader" Guid="B7A1C2D3-E4F5-6789-ABCD-222222222233">
        <File Id="seen_region_h"
              Source="$(var.SourceDir)\lib\seen\runtime\seen_region.h" />
        <File Id="seen_gpu_h"
              Source="$(var.SourceDir)\lib\seen\runtime\seen_gpu.h" />
        <File Id="seen_compat_win32_h"
              Source="$(var.SourceDir)\lib\seen\runtime\seen_compat_win32.h" />
      </Component>
    </ComponentGroup>

    <!--
      Stdlib and Language files are harvested dynamically by heat.exe.
      The build script generates stdlib-fragment.wxs and languages-fragment.wxs.
      If heat is not available, these empty groups serve as fallback.
    -->
    <?ifndef HeatGenerated ?>
    <ComponentGroup Id="StdlibFiles" />
    <ComponentGroup Id="LanguageFiles" />
    <ComponentGroup Id="DocFiles" />
    <?endif ?>

    <!-- PATH environment variable -->
    <DirectoryRef Id="INSTALLFOLDER">
      <Component Id="PathEnvVar" Guid="B7A1C2D3-E4F5-6789-ABCD-333333333333">
        <Environment Id="SeenPath"
                     Name="PATH"
                     Value="[BinDir]"
                     Permanent="no"
                     Part="last"
                     Action="set"
                     System="yes" />
        <RegistryValue Root="HKLM"
                       Key="SOFTWARE\SeenLanguage\Components"
                       Name="PathEnvVar"
                       Type="integer"
                       Value="1"
                       KeyPath="yes" />
      </Component>
    </DirectoryRef>

    <!-- Registry entries -->
    <DirectoryRef Id="INSTALLFOLDER">
      <Component Id="RegistryEntries" Guid="B7A1C2D3-E4F5-6789-ABCD-444444444444">
        <RegistryKey Root="HKLM" Key="SOFTWARE\SeenLanguage">
          <RegistryValue Name="InstallPath" Type="string" Value="[INSTALLFOLDER]" />
          <RegistryValue Name="Version" Type="string" Value="$(var.Version)" />
          <RegistryValue Name="BinPath" Type="string" Value="[BinDir]" />
        </RegistryKey>
        <!-- App Paths for command-line discovery -->
        <RegistryKey Root="HKLM" Key="SOFTWARE\Microsoft\Windows\CurrentVersion\App Paths\seen.exe">
          <RegistryValue Type="string" Value="[BinDir]seen.exe" />
          <RegistryValue Name="Path" Type="string" Value="[BinDir]" />
        </RegistryKey>
        <RegistryValue Root="HKLM"
                       Key="SOFTWARE\SeenLanguage\Components"
                       Name="Registry"
                       Type="integer"
                       Value="1"
                       KeyPath="yes" />
      </Component>
    </DirectoryRef>

    <!-- File associations (.seen files) -->
    <DirectoryRef Id="INSTALLFOLDER">
      <Component Id="FileAssociations" Guid="B7A1C2D3-E4F5-6789-ABCD-555555555555">
        <RegistryKey Root="HKCR" Key=".seen">
          <RegistryValue Type="string" Value="SeenSourceFile" />
        </RegistryKey>
        <RegistryKey Root="HKCR" Key="SeenSourceFile">
          <RegistryValue Type="string" Value="Seen Source File" />
        </RegistryKey>
        <RegistryKey Root="HKCR" Key="SeenSourceFile\DefaultIcon">
          <?if $(var.HasIcon) = "yes" ?>
          <RegistryValue Type="string" Value="[BinDir]seen.exe,0" />
          <?else ?>
          <RegistryValue Type="string" Value="[BinDir]seen.exe" />
          <?endif ?>
        </RegistryKey>
        <RegistryKey Root="HKCR" Key="SeenSourceFile\shell\open\command">
          <RegistryValue Type="string" Value="&quot;[BinDir]seen.exe&quot; &quot;%1&quot;" />
        </RegistryKey>
        <RegistryValue Root="HKLM"
                       Key="SOFTWARE\SeenLanguage\Components"
                       Name="FileAssoc"
                       Type="integer"
                       Value="1"
                       KeyPath="yes" />
      </Component>
    </DirectoryRef>

    <!-- Start Menu shortcuts -->
    <DirectoryRef Id="SeenProgramsFolder">
      <Component Id="StartMenuShortcuts" Guid="B7A1C2D3-E4F5-6789-ABCD-666666666666">
        <Shortcut Id="SeenCommandPrompt"
                  Name="Seen Command Prompt"
                  Description="Open command prompt with Seen in PATH"
                  Target="[System64Folder]cmd.exe"
                  Arguments="/k &quot;echo Seen Language Environment&quot;"
                  WorkingDirectory="PersonalFolder" />
        <Shortcut Id="UninstallShortcut"
                  Name="Uninstall Seen Language"
                  Description="Uninstall Seen Language"
                  Target="[System64Folder]msiexec.exe"
                  Arguments="/x [ProductCode]" />
        <RemoveFolder Id="RemoveSeenProgramsFolder" On="uninstall" />
        <RegistryValue Root="HKCU"
                       Key="SOFTWARE\SeenLanguage"
                       Name="StartMenuInstalled"
                       Type="integer"
                       Value="1"
                       KeyPath="yes" />
      </Component>
    </DirectoryRef>

  </Product>
</Wix>
