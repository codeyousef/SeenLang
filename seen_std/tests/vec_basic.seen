import collections.vec.{Vec}

fun expect(condition: Bool, message: String) -> Void {
    if not condition {
        abort(message)
    }
}

fun main() -> Int {
    let vec = Vec<Int>.new()
    expect(vec.isEmpty(), "new vec should be empty")

    vec.push(1)
    vec.push(2)
    vec.push(3)

    expect(vec.len() == 3, "len should reflect pushes")
    expect(vec.get(1) == 2, "index access should return inserted value")

    vec.set(1, 10)
    expect(vec.get(1) == 10, "set should update value")

    let popped = vec.pop()
    expect(popped == 3, "pop should return last element")
    expect(vec.len() == 2, "len should decrement after pop")

    let array = vec.toArray()
    expect(array.length() == 2, "toArray length mismatch")
    expect(array[0] == 1 and array[1] == 10, "toArray contents mismatch")

    vec.clear()
    expect(vec.isEmpty(), "clear should reset vector")

    vec.reserve(64)
    expect(vec.capacity() >= 64, "reserve should grow capacity")

    var index = 0
    while index < 128 {
        vec.push(index)
        index = index + 1
    }
    expect(vec.len() == 128, "len should reflect large push count")
    expect(vec.get(0) == 0 and vec.get(127) == 127, "values should match inserted indices")

    var removed = 0
    while removed < 100 {
        let value = vec.pop()
        expect(value == 127 - removed, "pop should return in reverse insertion order")
        removed = removed + 1
    }
    expect(vec.len() == 28, "length should shrink after pops")
    expect(vec.get(0) == 0 and vec.get(vec.len() - 1) == 27, "remaining elements should stay intact")

    return 0
}
