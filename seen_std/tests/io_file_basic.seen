import io.file.{readText, writeText, writeLines, appendText, createDirectory, deleteFile, exists, size, hash, ensureParentDirectories}

fun expect(condition: Bool, message: String) -> Void {
    if not condition {
        abort(message)
    }
}

fun main() -> Int {
    let dir = "seen_std/tests/tmp_io"
    let filePath = "{dir}/io_test.txt"

    createDirectory(dir)
    deleteFile(filePath)

    expect(writeText(filePath, "alpha"), "writeText should succeed")
    expect(readText(filePath) == "alpha", "readText mismatch")
    expect(exists(filePath), "exists should report written file")
    expect(size(filePath) == 5, "size should reflect byte count")
    let digest = hash(filePath)
    expect(digest.length() > 0, "hash should return digest text")

    let lines = Array<String>()
    lines.push("beta")
    lines.push("gamma")
    expect(writeLines(filePath, lines), "writeLines should succeed")
    expect(readText(filePath) == "beta\ngamma", "writeLines contents mismatch")

    expect(appendText(filePath, "\ndelta"), "appendText should succeed")
    expect(readText(filePath) == "beta\ngamma\ndelta", "appendText mismatch")

    let nestedFile = "{dir}/tree/a/b/file.txt"
    expect(ensureParentDirectories(nestedFile), "ensureParentDirectories should build directories")
    expect(writeText(nestedFile, "nested"), "writeText should handle nested path")
    expect(exists(nestedFile), "nested file should exist")
    expect(deleteFile(nestedFile), "nested file should delete cleanly")

    expect(deleteFile(filePath), "deleteFile should remove file")

    return 0
}
