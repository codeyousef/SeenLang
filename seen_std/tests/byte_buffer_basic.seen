///
ByteArray and ByteBuffer Basic Test
Expected: byte-backed buffers mask values, preserve order, and support primitive widths.
///

import collections.byte_buffer.{ByteArray, ByteBuffer, Int32Buffer, Int64Buffer}

fun expect(condition: Bool, message: String) r: Int {
    if condition {
        println("PASS: " + message)
        return 0
    }
    println("FAIL: " + message)
    return 1
}

fun main() r: Int {
    var failed = 0

    let bytes = ByteArray.withCapacity(2)
    bytes.push(1)
    bytes.push(256 + 2)
    bytes.push(-1)
    failed = failed + expect(bytes.length() == 3, "ByteArray grows")
    failed = failed + expect(bytes.get(0) == 1, "ByteArray first byte")
    failed = failed + expect(bytes.get(1) == 2, "ByteArray masks high bits")
    failed = failed + expect(bytes.get(2) == 255, "ByteArray masks negative byte")

    let slice = bytes.slice(1, 3)
    failed = failed + expect(slice.length() == 2, "ByteArray slice length")
    failed = failed + expect(slice.get(0) == 2 and slice.get(1) == 255, "ByteArray slice values")

    let buffer = ByteBuffer.new()
    buffer.push(10)
    buffer.push(20)
    let appended = ByteBuffer.fromArray([30, 40])
    buffer.append(appended)
    failed = failed + expect(buffer.length() == 4, "ByteBuffer append length")
    buffer.reverse()
    failed = failed + expect(buffer.get(0) == 40 and buffer.get(3) == 10, "ByteBuffer reverse")

    let ints = Int32Buffer.new()
    ints.push(7 as Int32)
    ints.push(9 as Int32)
    failed = failed + expect(ints.length() == 2, "Int32Buffer length")
    failed = failed + expect((ints.get(0) as Int) == 7 and (ints.get(1) as Int) == 9, "Int32Buffer values")

    let wideInts = Int64Buffer.new()
    wideInts.push(1000 as Int64)
    wideInts.push(2000 as Int64)
    failed = failed + expect(wideInts.length() == 2, "Int64Buffer length")
    failed = failed + expect((wideInts.get(0) as Int) < (wideInts.get(1) as Int), "Int64Buffer values")

    if failed > 0 {
        return 1
    }
    return 0
}
