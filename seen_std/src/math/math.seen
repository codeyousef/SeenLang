///
seen_std.math.math
Scalar math utilities (abs/trig/sqrt + integer helpers) for bootstrap code.
///

const PI: Float = 3.14159265358979323846
const TAU: Float = 6.28318530717958647692
const HALF_PI: Float = 1.57079632679489661923
const DEG_TO_RAD: Float = PI / 180.0
const RAD_TO_DEG: Float = 180.0 / PI
const E: Float = 2.71828182845904523536
const EPSILON: Float = 0.0000000000000002220446049250313
const LN2: Float = 0.69314718055994530942
const LN10: Float = 2.30258509299404568402
const LOG2_E: Float = 1.44269504088896340736
const LOG10_E: Float = 0.43429448190325182765
const SQRT2: Float = 1.41421356237309504880
const FRAC_1_PI: Float = 0.31830988618379067154
const FRAC_2_PI: Float = 0.63661977236758134308
const FRAC_1_SQRT2: Float = 0.70710678118654752440

extern "C" fun seen_math_positive_infinity() r: Float
extern "C" fun seen_math_negative_infinity() r: Float
extern "C" fun seen_math_nan() r: Float
extern "C" fun seen_math_sqrt(value: Float) r: Float
extern "C" fun seen_math_sin(value: Float) r: Float
extern "C" fun seen_math_cos(value: Float) r: Float
extern "C" fun seen_math_tan(value: Float) r: Float
extern "C" fun seen_math_asin(value: Float) r: Float
extern "C" fun seen_math_acos(value: Float) r: Float
extern "C" fun seen_math_atan(value: Float) r: Float
extern "C" fun seen_math_atan2(y: Float, x: Float) r: Float
extern "C" fun seen_math_floor(value: Float) r: Float
extern "C" fun seen_math_ceil(value: Float) r: Float
extern "C" fun seen_math_pow(base: Float, exponent: Float) r: Float
extern "C" fun seen_math_exp(value: Float) r: Float
extern "C" fun seen_math_exp2(value: Float) r: Float
extern "C" fun seen_math_log(value: Float) r: Float
extern "C" fun seen_math_log2(value: Float) r: Float
extern "C" fun seen_math_log10(value: Float) r: Float
extern "C" fun seen_math_fmod(x: Float, y: Float) r: Float
extern "C" fun seen_math_cbrt(value: Float) r: Float
extern "C" fun seen_math_hypot(x: Float, y: Float) r: Float
extern "C" fun seen_math_sinh(value: Float) r: Float
extern "C" fun seen_math_cosh(value: Float) r: Float
extern "C" fun seen_math_tanh(value: Float) r: Float
extern "C" fun seen_math_round(value: Float) r: Float
extern "C" fun seen_math_asinh(value: Float) r: Float
extern "C" fun seen_math_acosh(value: Float) r: Float
extern "C" fun seen_math_atanh(value: Float) r: Float
extern "C" fun seen_math_copysign(x: Float, y: Float) r: Float
extern "C" fun seen_math_popcount_i64(value: Int) r: Int
extern "C" fun seen_math_clz_i64(value: Int) r: Int
extern "C" fun seen_math_ctz_i64(value: Int) r: Int
extern "C" fun seen_math_rotate_left_i64(value: Int, shift: Int) r: Int
extern "C" fun seen_math_rotate_right_i64(value: Int, shift: Int) r: Int
extern "C" fun seen_math_byteswap_i64(value: Int) r: Int

let INFINITY: Float = seen_math_positive_infinity()
let NEG_INFINITY: Float = seen_math_negative_infinity()
let NAN: Float = seen_math_nan()

fun abs(value: Float) r: Float {
    if value < 0.0 {
        return -value
    }
    return value
}

fun absInt(value: Int) r: Int {
    if value < 0 {
        return -value
    }
    return value
}

fun min(a: Float, b: Float) r: Float {
    if a < b {
        return a
    }
    return b
}

fun max(a: Float, b: Float) r: Float {
    if a > b {
        return a
    }
    return b
}

fun minInt(a: Int, b: Int) r: Int {
    if a < b {
        return a
    }
    return b
}

fun maxInt(a: Int, b: Int) r: Int {
    if a > b {
        return a
    }
    return b
}

fun clamp01(value: Float) r: Float {
    return clamp(value, 0.0, 1.0)
}

fun sign(value: Float) r: Int {
    if value > 0.0 {
        return 1
    }
    if value < 0.0 {
        return -1
    }
    return 0
}

fun approxEqual(a: Float, b: Float, tolerance: Float = 0.0001) r: Bool {
    return abs(a - b) <= tolerance
}

fun sin(radians: Float) r: Float {
    return seen_math_sin(radians)
}

fun cos(radians: Float) r: Float {
    return seen_math_cos(radians)
}

fun tan(radians: Float) r: Float {
    return seen_math_tan(radians)
}

fun atan(x: Float) r: Float {
    return seen_math_atan(x)
}

fun atan2(y: Float, x: Float) r: Float {
    return seen_math_atan2(y, x)
}

fun asin(x: Float) r: Float {
    if x < -1.0 or x > 1.0 {
        abort("asin: domain error, x must be in [-1, 1]")
    }
    let pi_half = 1.57079632679489661923
    if x == 1.0 {
        return pi_half
    }
    if x == -1.0 {
        return -pi_half
    }
    return seen_math_asin(x)
}

fun acos(x: Float) r: Float {
    if x < -1.0 or x > 1.0 {
        abort("acos: domain error, x must be in [-1, 1]")
    }
    return seen_math_acos(x)
}

fun sqrt(value: Float) r: Float {
    if value < 0.0 {
        abort("sqrt of negative input")
    }
    return seen_math_sqrt(value)
}

fun floor(value: Float) r: Float {
    return seen_math_floor(value)
}

fun ceil(value: Float) r: Float {
    return seen_math_ceil(value)
}

fun round(value: Float) r: Float {
    return seen_math_round(value)
}

fun pow(base: Float, exponent: Float) r: Float {
    if exponent == 0.0 {
        return 1.0
    }
    let fracPart = abs(exponent) - floor(abs(exponent))
    if base < 0.0 and fracPart >= 0.0000000001 {
        abort("pow: negative base with fractional exponent")
    }
    if base == 0.0 and exponent < 0.0 {
        abort("pow division by zero")
    }
    return seen_math_pow(base, exponent)
}

fun exp(value: Float) r: Float {
    return seen_math_exp(value)
}

fun ln(value: Float) r: Float {
    if value <= 0.0 {
        abort("ln expects positive input")
    }
    return seen_math_log(value)
}

fun log(base: Float, value: Float) r: Float {
    return ln(value) / ln(base)
}

fun log2(value: Float) r: Float {
    if value <= 0.0 {
        abort("log2 expects positive input")
    }
    return seen_math_log2(value)
}

fun log10(value: Float) r: Float {
    if value <= 0.0 {
        abort("log10 expects positive input")
    }
    return seen_math_log10(value)
}

fun exp2(value: Float) r: Float {
    return seen_math_exp2(value)
}

fun clamp(value: Float, minValue: Float, maxValue: Float) r: Float {
    if value < minValue {
        return minValue
    }
    if value > maxValue {
        return maxValue
    }
    return value
}

fun clampInt(value: Int, minValue: Int, maxValue: Int) r: Int {
    if value < minValue {
        return minValue
    }
    if value > maxValue {
        return maxValue
    }
    return value
}

fun degToRad(degrees: Float) r: Float {
    let factor = 3.14159265358979323846 / 180.0
    return degrees * factor
}

fun radToDeg(radians: Float) r: Float {
    let factor = 180.0 / 3.14159265358979323846
    return radians * factor
}

fun saturatingAdd(a: Int, b: Int) r: Int {
    let result = a + b
    if (a > 0 and b > 0 and result < 0) {
        return Int.max()
    }
    if (a < 0 and b < 0 and result > 0) {
        return Int.min()
    }
    return result
}

fun saturatingSub(a: Int, b: Int) r: Int {
    let result = a - b
    if (a > 0 and b < 0 and result < 0) {
        return Int.max()
    }
    if (a < 0 and b > 0 and result > 0) {
        return Int.min()
    }
    return result
}

fun saturatingMul(a: Int, b: Int) r: Int {
    if a == 0 or b == 0 {
        return 0
    }
    let result = a * b
    if (a == -1 and b == Int.min()) or (b == -1 and a == Int.min()) {
        return Int.max()
    }
    if (result / b) != a {
        if (a > 0 and b > 0) or (a < 0 and b < 0) {
            return Int.max()
        }
        return Int.min()
    }
    return result
}

fun checkedAdd(a: Int, b: Int) r: Int {
    let result = a + b
    if (a > 0 and b > 0 and result < 0) or (a < 0 and b < 0 and result > 0) {
        abort("checkedAdd overflow")
    }
    return result
}

fun checkedSub(a: Int, b: Int) r: Int {
    let result = a - b
    if (a >= 0 and b < 0 and result < 0) or (a <= 0 and b > 0 and result > 0) {
        abort("checkedSub overflow")
    }
    return result
}

fun checkedMul(a: Int, b: Int) r: Int {
    if a == 0 or b == 0 {
        return 0
    }
    let result = a * b
    if result / b != a {
        abort("checkedMul overflow")
    }
    return result
}

fun wrappingAdd(a: Int, b: Int) r: Int {
    return (a + b) // wrap via overflow semantics
}

fun wrappingSub(a: Int, b: Int) r: Int {
    return (a - b)
}

fun wrappingMul(a: Int, b: Int) r: Int {
    return (a * b)
}

fun checkedDiv(a: Int, b: Int) r: Int {
    if b == 0 {
        abort("division by zero")
    }
    if a == Int.min() and b == -1 {
        abort("division overflow")
    }
    return a / b
}

fun popcount(value: Int) r: Int {
    return seen_math_popcount_i64(value)
}

fun countLeadingZeros(value: Int) r: Int {
    return seen_math_clz_i64(value)
}

fun countTrailingZeros(value: Int) r: Int {
    return seen_math_ctz_i64(value)
}

fun rotateLeft(value: Int, shift: Int) r: Int {
    return seen_math_rotate_left_i64(value, shift)
}

fun rotateRight(value: Int, shift: Int) r: Int {
    return seen_math_rotate_right_i64(value, shift)
}

fun byteswap(value: Int) r: Int {
    return seen_math_byteswap_i64(value)
}

fun lerp(a: Float, b: Float, t: Float) r: Float {
    return a + (b - a) * t
}

fun inverseLerp(a: Float, b: Float, value: Float) r: Float {
    if a == b {
        return 0.0
    }
    return (value - a) / (b - a)
}

fun remap(value: Float, inMin: Float, inMax: Float, outMin: Float, outMax: Float) r: Float {
    let normalized = clamp((value - inMin) / (inMax - inMin), 0.0, 1.0)
    return lerp(outMin, outMax, normalized)
}

fun smoothstep(edge0: Float, edge1: Float, value: Float) r: Float {
    let x = clamp((value - edge0) / (edge1 - edge0), 0.0, 1.0)
    return x * x * (3.0 - 2.0 * x)
}

fun cbrt(value: Float) r: Float {
    return seen_math_cbrt(value)
}

fun hypot(x: Float, y: Float) r: Float {
    return seen_math_hypot(x, y)
}

fun fmod(x: Float, y: Float) r: Float {
    if y == 0.0 {
        abort("fmod: division by zero")
    }
    return seen_math_fmod(x, y)
}

fun copysign(x: Float, y: Float) r: Float {
    return seen_math_copysign(x, y)
}

fun radians(value: Float) r: Float {
    return degToRad(value)
}

fun degrees(value: Float) r: Float {
    return radToDeg(value)
}

fun normalizeAngle(value: Float) r: Float {
    let pi = 3.14159265358979323846
    let tau = 6.28318530717958647692
    var angle = seen_math_fmod(value, tau)
    if angle > pi {
        angle = angle - tau
    }
    if angle < -pi {
        angle = angle + tau
    }
    return angle
}

// --- Hyperbolic functions ---

fun sinh(x: Float) r: Float {
    return seen_math_sinh(x)
}

fun cosh(x: Float) r: Float {
    return seen_math_cosh(x)
}

fun tanh(x: Float) r: Float {
    return seen_math_tanh(x)
}

fun asinh(x: Float) r: Float {
    return seen_math_asinh(x)
}

fun acosh(x: Float) r: Float {
    if x < 1.0 {
        abort("acosh: domain error, x must be >= 1")
    }
    return seen_math_acosh(x)
}

fun atanh(x: Float) r: Float {
    if x <= -1.0 or x >= 1.0 {
        abort("atanh: domain error, x must be in (-1, 1)")
    }
    return seen_math_atanh(x)
}

// --- IEEE 754 classification ---

fun isnan(x: Float) r: Bool {
    return x.isNaN()
}

fun isinf(x: Float) r: Bool {
    return x.isInfinite()
}

fun isfinite(x: Float) r: Bool {
    return not isnan(x) and not isinf(x)
}

// --- Integer utilities ---

fun gcd(a: Int, b: Int) r: Int {
    var x = absInt(a)
    var y = absInt(b)
    while y != 0 {
        let temp = y
        y = x % y
        x = temp
    }
    return x
}

fun lcm(a: Int, b: Int) r: Int {
    if a == 0 or b == 0 {
        return 0
    }
    // Compute as |a / gcd(a,b)| * |b| to avoid overflow
    let g = gcd(a, b)
    return absInt(a / g) * absInt(b)
}
