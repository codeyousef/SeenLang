///
seen_std.collections.bit_set
Bit-packed boolean array for memory-efficient boolean storage.
Used for Sieve of Eratosthenes and other algorithms requiring dense bit storage.
///

fun bitSetWordCount(size: Int) r: Int {
    if size <= 0 {
        return 0
    }
    return (size + 63) / 64
}

fun bitSetMaskForBits(bits: Int) r: Int {
    if bits <= 0 {
        return 0
    }
    if bits >= 64 {
        return -1
    }

    var mask = 0
    var bit = 0
    while bit < bits {
        mask = mask | (1 << bit)
        bit = bit + 1
    }
    return mask
}

fun bitSetCountWordOnes(word: Int, bitLimit: Int) r: Int {
    var count = 0
    var bit = 0
    while bit < bitLimit {
        if (word & (1 << bit)) != 0 {
            count = count + 1
        }
        bit = bit + 1
    }
    return count
}

class BitSet {
    var words: Array<Int>
    var capacity: Int

    fun new(size: Int) -> BitSet {
        let numWords = bitSetWordCount(size)
        let words = Array<Int>()
        var i = 0
        while i < numWords {
            words.push(0)
            i = i + 1
        }
        return BitSet {
            words: words,
            capacity: size
        }
    }

    fun set(this: BitSet, index: Int) -> Void {
        if index < 0 or index >= this.capacity {
            abort("BitSet.set: index out of bounds")
        }
        let wordIndex = index / 64
        let bitIndex = index % 64
        this.words[wordIndex] = this.words[wordIndex] | (1 << bitIndex)
    }

    fun clear(this: BitSet, index: Int) -> Void {
        if index < 0 or index >= this.capacity {
            abort("BitSet.clear: index out of bounds")
        }
        let wordIndex = index / 64
        let bitIndex = index % 64
        this.words[wordIndex] = this.words[wordIndex] & ~(1 << bitIndex)
    }

    fun get(this: BitSet, index: Int) -> Bool {
        if index < 0 or index >= this.capacity {
            abort("BitSet.get: index out of bounds")
        }
        let wordIndex = index / 64
        let bitIndex = index % 64
        return (this.words[wordIndex] & (1 << bitIndex)) != 0
    }

    fun size(this: BitSet) -> Int {
        return this.capacity
    }

    fun countOnes(this: BitSet) -> Int {
        var count = 0
        let wordCount = this.words.length()
        var wordIndex = 0
        while wordIndex < wordCount {
            var bitLimit = 64
            if wordIndex == wordCount - 1 {
                let trailingBits = this.capacity % 64
                if trailingBits != 0 {
                    bitLimit = trailingBits
                }
            }
            count = count + bitSetCountWordOnes(this.words[wordIndex],
                bitLimit)
            wordIndex = wordIndex + 1
        }
        return count
    }

    fun clearAll(this: BitSet) -> Void {
        var i = 0
        while i < this.words.length() {
            this.words[i] = 0
            i = i + 1
        }
    }

    fun setAll(this: BitSet) -> Void {
        let wordCount = this.words.length()
        var i = 0
        while i < wordCount {
            var word = -1
            if i == wordCount - 1 {
                let trailingBits = this.capacity % 64
                if trailingBits != 0 {
                    word = bitSetMaskForBits(trailingBits)
                }
            }
            this.words[i] = word
            i = i + 1
        }
    }
}
