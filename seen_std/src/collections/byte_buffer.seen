extern fun seen_f32_buffer_len(handle: Int) r: Int
extern fun seen_f32_buffer_clear(handle: Int) r: Void
extern fun seen_f32_buffer_push(handle: Int, value: Float) r: Void
extern fun seen_f32_buffer_get(handle: Int, index: Int) r: Float
extern fun seen_f32_buffer_set(handle: Int, index: Int, value: Float) r: Void
extern fun seen_f32_array_from_le_bytes(bytes: Array<Int>, offset: Int, count: Int) r: Array<Float>
extern fun seen_f32_array_to_le_bytes(values: Array<Float>) r: Array<Int>
extern fun seen_f32_array_copy_from_le_bytes(bytes: Array<Int>, offset: Int, count: Int, target: Array<Float>) r: Bool
extern fun seen_f32_array_append_le_bytes(bytes: Array<Int>, values: Array<Float>) r: Bool
extern fun seen_f64_buffer_new(capacity: Int) r: Int
extern fun seen_f64_buffer_len(handle: Int) r: Int
extern fun seen_f64_buffer_clear(handle: Int) r: Void
extern fun seen_f64_buffer_push(handle: Int, value: Float) r: Void
extern fun seen_f64_buffer_get(handle: Int, index: Int) r: Float
extern fun seen_f64_buffer_set(handle: Int, index: Int, value: Float) r: Void

class ByteArray {
    handle: Int

    static fun new(initialCapacity: Int = 16) -> ByteArray {
        return ByteArray.withCapacity(initialCapacity)
    }

    static fun withCapacity(initialCapacity: Int) -> ByteArray {
        return ByteArray {
            handle: seen_byte_array_new(initialCapacity)
        }
    }

    static fun fromInts(bytes: Array<Int>) -> ByteArray {
        let buffer = ByteArray.withCapacity(bytes.length())
        var index = 0
        while index < bytes.length() {
            buffer.push(bytes[index])
            index = index + 1
        }
        return buffer
    }

    fun length() -> Int {
        return seen_byte_array_len(this.handle)
    }

    fun capacity() -> Int {
        return seen_byte_array_capacity(this.handle)
    }

    fun tryReserve(requiredCapacity: Int) -> Bool {
        return seen_byte_array_try_reserve(this.handle, requiredCapacity)
    }

    fun reserve(requiredCapacity: Int) -> Void {
        if not this.tryReserve(requiredCapacity) {
            panic("ByteArray reserve failed")
        }
    }

    fun isEmpty() -> Bool {
        return this.length() == 0
    }

    fun clear() -> Void {
        seen_byte_array_clear(this.handle)
    }

    fun clearAndRelease() -> Void {
        seen_byte_array_release(this.handle)
    }

    fun push(value: Int) -> Void {
        seen_byte_array_push(this.handle, value)
    }

    fun append(other: ByteArray) -> Void {
        seen_byte_array_append(this.handle, other.handle)
    }

    fun get(index: Int) -> Int {
        return seen_byte_array_get(this.handle, index)
    }

    fun set(index: Int, value: Int) -> Void {
        seen_byte_array_set(this.handle, index, value)
    }

    fun fill(value: Int) -> Void {
        seen_byte_array_fill(this.handle, value)
    }

    fun slice(start: Int, end: Int) -> ByteArray {
        return ByteArray {
            handle: seen_byte_array_slice(this.handle, start, end)
        }
    }

    fun reverse() -> Void {
        seen_byte_array_reverse(this.handle)
    }

    fun toIntArray() -> Array<Int> {
        return seen_byte_array_to_int_array(this.handle)
    }
}

