class ByteBuffer {
    bytes: ByteArray

    static fun new(initialCapacity: Int = 16) -> ByteBuffer {
        return ByteBuffer.withCapacity(initialCapacity)
    }

    static fun withCapacity(initialCapacity: Int) -> ByteBuffer {
        return ByteBuffer {
            bytes: ByteArray.withCapacity(initialCapacity)
        }
    }

    static fun fromArray(data: Array<Int>) -> ByteBuffer {
        return ByteBuffer {
            bytes: ByteArray.fromInts(data)
        }
    }

    fun length() -> Int {
        return this.bytes.length()
    }

    fun capacity() -> Int {
        return this.bytes.capacity()
    }

    fun tryReserve(requiredCapacity: Int) -> Bool {
        return this.bytes.tryReserve(requiredCapacity)
    }

    fun reserve(requiredCapacity: Int) -> Void {
        this.bytes.reserve(requiredCapacity)
    }

    fun isEmpty() -> Bool {
        return this.bytes.isEmpty()
    }

    fun push(byte: Int) -> Void {
        this.bytes.push(byte)
    }

    fun append(other: ByteBuffer) -> Void {
        this.bytes.append(other.bytes)
    }

    fun get(index: Int) -> Int {
        return this.bytes.get(index)
    }

    fun set(index: Int, byte: Int) -> Void {
        this.bytes.set(index, byte)
    }

    fun toArray() -> Array<Int> {
        return this.bytes.toIntArray()
    }

    fun toByteArray() -> ByteArray {
        return this.bytes
    }

    fun clear() -> Void {
        this.bytes.clear()
    }

    fun slice(start: Int, end: Int) -> ByteBuffer {
        return ByteBuffer {
            bytes: this.bytes.slice(start, end)
        }
    }

    fun reverse() -> Void {
        this.bytes.reverse()
    }

    fun fill(byte: Int) -> Void {
        this.bytes.fill(byte)
    }
}
