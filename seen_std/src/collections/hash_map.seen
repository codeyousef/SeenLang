// seen_std.collections.hash_map
// Generic HashMap<K, V> with robin-hood hashing for excellent performance.

import collections.vec.{Vec}
import core.option.{Option, Some, None}
import hash.mod.{hashInt, hashString, combineHashes}

class Entry<K, V> {
    var key: K
    var value: V
    var hash: Int
    var distance: Int

    fun new(key: K, value: V, hash: Int) -> Entry<K, V> {
        return Entry<K, V> {
            key: key,
            value: value,
            hash: hash,
            distance: 0
        }
    }
}

class HashMap<K, V> {
    var buckets: Vec<Option<Entry<K, V>>>
    var capacity: Int
    var length: Int
    var loadFactor: Float

    fun new() -> HashMap<K, V> {
        return HashMap<K, V>.withCapacity(16)
    }

    fun withCapacity(cap: Int) -> HashMap<K, V> {
        var buckets = Vec<Option<Entry<K, V>>>.new()
        var i = 0
        while i < cap {
            buckets.push(None<Entry<K, V>>())
            i = i + 1
        }
        return HashMap<K, V> {
            buckets: buckets,
            capacity: cap,
            length: 0,
            loadFactor: 0.75
        }
    }

    fun insert(key: K, value: V) -> Void {
        let currentLoad = (this.length + 1) * 100 / this.capacity
        let maxLoad = 75  // 75% load factor
        if currentLoad > maxLoad {
            this.resize()
        }

        let hash = this.hashKey(key)
        let index = hash % this.capacity
        var entry = Entry<K, V>.new(key, value, hash)
        
        var i = 0
        while i < this.capacity {
            let bucketIndex = (index + i) % this.capacity
            let bucket = this.buckets.get(bucketIndex)

            if bucket.isNone() {
                entry.distance = i
                this.buckets.set(bucketIndex, Some<Entry<K, V>>(entry))
                this.length = this.length + 1
                return
            }

            let existing = bucket.unwrap()
            
            if existing.hash == hash and this.keysEqual(existing.key, key) {
                existing.value = value
                return
            }

            if i > existing.distance {
                entry.distance = i
                this.buckets.set(bucketIndex, Some<Entry<K, V>>(entry))
                entry = existing
                i = existing.distance
            }

            i = i + 1
        }
    }

    fun get(key: K) -> Option<V> {
        let hash = this.hashKey(key)
        let index = hash % this.capacity

        var i = 0
        while i < this.capacity {
            let bucketIndex = (index + i) % this.capacity
            let bucket = this.buckets.get(bucketIndex)

            if bucket.isNone() {
                return None<V>()
            }

            let entry = bucket.unwrap()
            
            if entry.hash == hash and this.keysEqual(entry.key, key) {
                return Some<V>(entry.value)
            }

            if i > entry.distance {
                return None<V>()
            }

            i = i + 1
        }

        return None<V>()
    }

    fun containsKey(key: K) -> Bool {
        return this.get(key).isSome()
    }

    fun remove(key: K) -> Option<V> {
        let hash = this.hashKey(key)
        let index = hash % this.capacity

        var i = 0
        while i < this.capacity {
            let bucketIndex = (index + i) % this.capacity
            let bucket = this.buckets.get(bucketIndex)

            if bucket.isNone() {
                return None<V>()
            }

            let entry = bucket.unwrap()
            
            if entry.hash == hash and this.keysEqual(entry.key, key) {
                let value = entry.value
                this.shiftBack(bucketIndex)
                this.length = this.length - 1
                return Some<V>(value)
            }

            if i > entry.distance {
                return None<V>()
            }

            i = i + 1
        }

        return None<V>()
    }

    fun shiftBack(startIndex: Int) -> Void {
        var i = startIndex
        while i < this.capacity {
            let nextIndex = (i + 1) % this.capacity
            let nextBucket = this.buckets.get(nextIndex)

            if nextBucket.isNone() {
                this.buckets.set(i, None<Entry<K, V>>())
                return
            }

            let nextEntry = nextBucket.unwrap()
            if nextEntry.distance == 0 {
                this.buckets.set(i, None<Entry<K, V>>())
                return
            }

            nextEntry.distance = nextEntry.distance - 1
            this.buckets.set(i, Some<Entry<K, V>>(nextEntry))
            i = nextIndex
        }
    }

    fun resize() -> Void {
        let oldBuckets = this.buckets
        let oldCapacity = this.capacity
        
        this.capacity = this.capacity * 2
        this.buckets = Vec<Option<Entry<K, V>>>.new()
        var i = 0
        while i < this.capacity {
            this.buckets.push(None<Entry<K, V>>())
            i = i + 1
        }
        this.length = 0

        i = 0
        while i < oldCapacity {
            let bucket = oldBuckets.get(i)
            if bucket.isSome() {
                let entry = bucket.unwrap()
                this.insert(entry.key, entry.value)
            }
            i = i + 1
        }
    }

    fun size() -> Int {
        return this.length
    }

    fun isEmpty() -> Bool {
        return this.length == 0
    }

    fun clear() -> Void {
        var i = 0
        while i < this.capacity {
            this.buckets.set(i, None<Entry<K, V>>())
            i = i + 1
        }
        this.length = 0
    }

    fun hashKey(key: K) -> Int {
        return hashInt(0)
    }

    fun keysEqual(k1: K, k2: K) -> Bool {
        return false
    }
}
