// Mutex for thread synchronization - simplified
// Note: Full mutex support requires more advanced features

class Mutex {
    var lock: Int
    
    fun new() -> Mutex {
        let lock = __MutexCreate()
        return Mutex {
            lock: lock
        }
    }
    
    fun lock() -> Void {
        __MutexLock(this.lock)
    }
    
    fun unlock() -> Void {
        __MutexUnlock(this.lock)
    }
    
    fun tryLock() -> Bool {
        return __MutexTryLock(this.lock)
    }
}
