/**
 * Vulkan 1.3+ FFI bindings for Linux.
 *
 * Low-level bindings to Vulkan via libseen_platform.so shim.
 * Provides constants, function declarations, and helper utilities.
 * Prefer the higher-level VulkanRenderer from graphics.renderer.
 *
 * Link with: -lseen_platform (which wraps libvulkan.so.1)
 */

import core.result.{Result, Ok, Err}
import core.unit.{Unit}

// Vulkan result codes
let VK_SUCCESS: Int = 0
let VK_NOT_READY: Int = 1
let VK_TIMEOUT: Int = 2
let VK_EVENT_SET: Int = 3
let VK_EVENT_RESET: Int = 4
let VK_INCOMPLETE: Int = 5
let VK_ERROR_OUT_OF_HOST_MEMORY: Int = -1
let VK_ERROR_OUT_OF_DEVICE_MEMORY: Int = -2
let VK_ERROR_INITIALIZATION_FAILED: Int = -3
let VK_ERROR_DEVICE_LOST: Int = -4
let VK_ERROR_MEMORY_MAP_FAILED: Int = -5
let VK_ERROR_LAYER_NOT_PRESENT: Int = -6
let VK_ERROR_EXTENSION_NOT_PRESENT: Int = -7
