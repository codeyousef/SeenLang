let VK_ERROR_FORMAT_NOT_SUPPORTED: Int = -11
let VK_ERROR_SURFACE_LOST_KHR: Int = -1000000000
let VK_ERROR_OUT_OF_DATE_KHR: Int = -1000001004
let VK_SUBOPTIMAL_KHR: Int = 1000001003

