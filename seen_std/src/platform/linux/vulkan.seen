// ============================================================================
// Helper Functions
// ============================================================================

/**
 * Convert a Vulkan result code to a human-readable string.
 */
fun vk_result_string(result: Int) r: String {
    // Inline constants to work around negative value module constant issues
    // Success codes (0-5)
    if result == 0 { return "VK_SUCCESS" }
    if result == 1 { return "VK_NOT_READY" }
    if result == 2 { return "VK_TIMEOUT" }
    if result == 3 { return "VK_EVENT_SET" }
    if result == 4 { return "VK_EVENT_RESET" }
    if result == 5 { return "VK_INCOMPLETE" }
    // Error codes (negative)
    if result == -1 { return "VK_ERROR_OUT_OF_HOST_MEMORY" }
    if result == -2 { return "VK_ERROR_OUT_OF_DEVICE_MEMORY" }
    if result == -3 { return "VK_ERROR_INITIALIZATION_FAILED" }
    if result == -4 { return "VK_ERROR_DEVICE_LOST" }
    if result == -5 { return "VK_ERROR_MEMORY_MAP_FAILED" }
    if result == -6 { return "VK_ERROR_LAYER_NOT_PRESENT" }
    if result == -7 { return "VK_ERROR_EXTENSION_NOT_PRESENT" }
    if result == -8 { return "VK_ERROR_FEATURE_NOT_PRESENT" }
    if result == -9 { return "VK_ERROR_INCOMPATIBLE_DRIVER" }
    if result == -10 { return "VK_ERROR_TOO_MANY_OBJECTS" }
    if result == -11 { return "VK_ERROR_FORMAT_NOT_SUPPORTED" }
    if result == -1000000000 { return "VK_ERROR_SURFACE_LOST_KHR" }
    if result == -1000001004 { return "VK_ERROR_OUT_OF_DATE_KHR" }
    if result == 1000001003 { return "VK_SUBOPTIMAL_KHR" }
    return "VK_UNKNOWN_ERROR"
}

// Check if result is success
fun vk_succeeded(result: Int) r: Bool {
    return result >= 0
}

// Check if result is an error
fun vk_failed(result: Int) r: Bool {
    return result < 0
}

// Make Vulkan API version
fun vk_make_version(major: Int, minor: Int, patch: Int) r: UInt32 {
    return ((major as UInt32) << 22) | ((minor as UInt32) << 12) | (patch as UInt32)
}

// Vulkan 1.3 API version constant
let VK_API_VERSION_1_3: UInt32 = vk_make_version(1, 3, 0)
let VK_API_VERSION_1_2: UInt32 = vk_make_version(1, 2, 0)
let VK_API_VERSION_1_1: UInt32 = vk_make_version(1, 1, 0)
let VK_API_VERSION_1_0: UInt32 = vk_make_version(1, 0, 0)
