/**
 * Steamworks SDK FFI bindings for Linux.
 *
 * Low-level bindings to the Steamworks API for achievements, stats,
 * cloud saves, friends, and overlay integration. Prefer the higher-level
 * Steam class from platform.linux.steam_wrapper for most use cases.
 *
 * Link with: -lsteam_api
 */

import core.result.{Result, Ok, Err}
import core.unit.{Unit}

// Steam callback types
let k_iSteamUserCallbacks: Int = 100
let k_iSteamGameServerCallbacks: Int = 200
let k_iSteamFriendsCallbacks: Int = 300
let k_iSteamBillingCallbacks: Int = 400
let k_iSteamMatchmakingCallbacks: Int = 500
let k_iSteamContentServerCallbacks: Int = 600
let k_iSteamUtilsCallbacks: Int = 700
let k_iSteamAppsCallbacks: Int = 1000
let k_iSteamUserStatsCallbacks: Int = 1100
let k_iSteamNetworkingCallbacks: Int = 1200
let k_iSteamRemoteStorageCallbacks: Int = 1300

// Friend flags
let k_EFriendFlagNone: Int = 0x00
let k_EFriendFlagBlocked: Int = 0x01
let k_EFriendFlagFriendshipRequested: Int = 0x02
let k_EFriendFlagImmediate: Int = 0x04
let k_EFriendFlagClanMember: Int = 0x08
let k_EFriendFlagOnGameServer: Int = 0x10
let k_EFriendFlagRequestingFriendship: Int = 0x80
let k_EFriendFlagRequestingInfo: Int = 0x100
let k_EFriendFlagIgnored: Int = 0x200
let k_EFriendFlagIgnoredFriend: Int = 0x400
let k_EFriendFlagAll: Int = 0xFFFF

// Persona states
let k_EPersonaStateOffline: Int = 0
let k_EPersonaStateOnline: Int = 1
let k_EPersonaStateBusy: Int = 2
let k_EPersonaStateAway: Int = 3
let k_EPersonaStateSnooze: Int = 4
let k_EPersonaStateLookingToTrade: Int = 5
let k_EPersonaStateLookingToPlay: Int = 6
let k_EPersonaStateInvisible: Int = 7
let k_EPersonaStateMax: Int = 8

// Account types
let k_EAccountTypeInvalid: Int = 0
let k_EAccountTypeIndividual: Int = 1
let k_EAccountTypeMultiseat: Int = 2
let k_EAccountTypeGameServer: Int = 3
let k_EAccountTypeAnonGameServer: Int = 4
let k_EAccountTypePending: Int = 5
let k_EAccountTypeContentServer: Int = 6
let k_EAccountTypeClan: Int = 7
let k_EAccountTypeChat: Int = 8
let k_EAccountTypeConsoleUser: Int = 9
let k_EAccountTypeAnonUser: Int = 10
let k_EAccountTypeMax: Int = 11

// Universe types
let k_EUniverseInvalid: Int = 0
let k_EUniversePublic: Int = 1
let k_EUniverseBeta: Int = 2
let k_EUniverseInternal: Int = 3
let k_EUniverseDev: Int = 4
let k_EUniverseMax: Int = 5

// Overlay positions
let k_EPositionTopLeft: Int = 0
let k_EPositionTopRight: Int = 1
let k_EPositionBottomLeft: Int = 2
let k_EPositionBottomRight: Int = 3

// ============================================================================
// Direct C FFI Declarations - Link to libsteam_api.so
// ============================================================================

// Core Steam API initialization
extern "C" fun SteamAPI_Init() r: Int32
extern "C" fun SteamAPI_Shutdown() r: Void
extern "C" fun SteamAPI_RestartAppIfNecessary(unOwnAppID: UInt32) r: Int32
extern "C" fun SteamAPI_RunCallbacks() r: Void
extern "C" fun SteamAPI_IsSteamRunning() r: Int32

// Client interface access (returns opaque pointers)
extern "C" fun SteamClient() r: *Void
extern "C" fun SteamUser() r: *Void
extern "C" fun SteamFriends() r: *Void
extern "C" fun SteamUtils() r: *Void
extern "C" fun SteamUserStats() r: *Void
extern "C" fun SteamApps() r: *Void
extern "C" fun SteamInput() r: *Void
extern "C" fun SteamRemoteStorage() r: *Void

// ISteamUser functions
extern "C" fun SteamAPI_ISteamUser_GetSteamID(steamUser: *Void) r: UInt64
extern "C" fun SteamAPI_ISteamUser_BLoggedOn(steamUser: *Void) r: Int32
extern "C" fun SteamAPI_ISteamUser_GetPlayerSteamLevel(steamUser: *Void) r: Int32

// ISteamFriends functions
extern "C" fun SteamAPI_ISteamFriends_GetPersonaName(steamFriends: *Void) r: *Char
extern "C" fun SteamAPI_ISteamFriends_GetPersonaState(steamFriends: *Void) r: Int32
extern "C" fun SteamAPI_ISteamFriends_GetFriendCount(steamFriends: *Void, friendFlags: Int32) r: Int32
extern "C" fun SteamAPI_ISteamFriends_SetRichPresence(steamFriends: *Void, key: *Char, value: *Char) r: Int32
extern "C" fun SteamAPI_ISteamFriends_ClearRichPresence(steamFriends: *Void) r: Void
extern "C" fun SteamAPI_ISteamFriends_ActivateGameOverlay(steamFriends: *Void, dialog: *Char) r: Void
extern "C" fun SteamAPI_ISteamFriends_ActivateGameOverlayToWebPage(steamFriends: *Void, url: *Char, mode: Int32) r: Void

// ISteamUtils functions
extern "C" fun SteamAPI_ISteamUtils_GetSecondsSinceAppActive(steamUtils: *Void) r: UInt32
extern "C" fun SteamAPI_ISteamUtils_GetIPCountry(steamUtils: *Void) r: *Char
extern "C" fun SteamAPI_ISteamUtils_GetCurrentBatteryPower(steamUtils: *Void) r: UInt8
extern "C" fun SteamAPI_ISteamUtils_GetAppID(steamUtils: *Void) r: UInt32
extern "C" fun SteamAPI_ISteamUtils_SetOverlayNotificationPosition(steamUtils: *Void, position: Int32) r: Void
extern "C" fun SteamAPI_ISteamUtils_IsOverlayEnabled(steamUtils: *Void) r: Int32
extern "C" fun SteamAPI_ISteamUtils_IsSteamRunningInVR(steamUtils: *Void) r: Int32
extern "C" fun SteamAPI_ISteamUtils_IsSteamInBigPictureMode(steamUtils: *Void) r: Int32
extern "C" fun SteamAPI_ISteamUtils_IsSteamRunningOnSteamDeck(steamUtils: *Void) r: Int32

// ISteamUserStats functions
extern "C" fun SteamAPI_ISteamUserStats_RequestCurrentStats(steamUserStats: *Void) r: Int32
extern "C" fun SteamAPI_ISteamUserStats_GetStatInt32(steamUserStats: *Void, name: *Char, data: *Int32) r: Int32
extern "C" fun SteamAPI_ISteamUserStats_GetStatFloat(steamUserStats: *Void, name: *Char, data: *Float) r: Int32
extern "C" fun SteamAPI_ISteamUserStats_SetStatInt32(steamUserStats: *Void, name: *Char, data: Int32) r: Int32
extern "C" fun SteamAPI_ISteamUserStats_SetStatFloat(steamUserStats: *Void, name: *Char, data: Float) r: Int32
extern "C" fun SteamAPI_ISteamUserStats_GetAchievement(steamUserStats: *Void, name: *Char, achieved: *Int32) r: Int32
extern "C" fun SteamAPI_ISteamUserStats_SetAchievement(steamUserStats: *Void, name: *Char) r: Int32
extern "C" fun SteamAPI_ISteamUserStats_ClearAchievement(steamUserStats: *Void, name: *Char) r: Int32
extern "C" fun SteamAPI_ISteamUserStats_StoreStats(steamUserStats: *Void) r: Int32
extern "C" fun SteamAPI_ISteamUserStats_GetNumAchievements(steamUserStats: *Void) r: UInt32
extern "C" fun SteamAPI_ISteamUserStats_GetAchievementName(steamUserStats: *Void, achievement: UInt32) r: *Char
