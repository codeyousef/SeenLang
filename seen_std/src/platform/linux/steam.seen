extern "C" fun SteamAPI_ISteamRemoteStorage_GetFileSize(steamRemoteStorage: *Void, file: *Char) r: Int32
extern "C" fun SteamAPI_ISteamRemoteStorage_GetFileCount(steamRemoteStorage: *Void) r: Int32
extern "C" fun SteamAPI_ISteamRemoteStorage_IsCloudEnabledForAccount(steamRemoteStorage: *Void) r: Int32
extern "C" fun SteamAPI_ISteamRemoteStorage_IsCloudEnabledForApp(steamRemoteStorage: *Void) r: Int32
extern "C" fun SteamAPI_ISteamRemoteStorage_SetCloudEnabledForApp(steamRemoteStorage: *Void, enabled: Int32) r: Void
extern "C" fun SteamAPI_ISteamRemoteStorage_GetQuota(steamRemoteStorage: *Void, totalBytes: *UInt64, availableBytes: *UInt64) r: Int32

// Versioned interface accessors (for ABI compatibility)
extern "C" fun SteamAPI_SteamUser_v023() r: *Void
extern "C" fun SteamAPI_SteamFriends_v017() r: *Void
extern "C" fun SteamAPI_SteamUtils_v010() r: *Void
extern "C" fun SteamAPI_SteamUserStats_v012() r: *Void
extern "C" fun SteamAPI_SteamApps_v008() r: *Void
extern "C" fun SteamAPI_SteamInput_v006() r: *Void
extern "C" fun SteamAPI_SteamRemoteStorage_v016() r: *Void

// Additional ISteamUtils functions
extern "C" fun SteamAPI_ISteamUtils_GetServerRealTime(utils: *Void) r: UInt32

// Additional ISteamUserStats functions
extern "C" fun SteamAPI_ISteamUserStats_IndicateAchievementProgress(stats: *Void, name: *Char, current: UInt32, max: UInt32) r: Int32

// ISteamInput functions
extern "C" fun SteamAPI_ISteamInput_Init(input: *Void, explicitlyCallRunFrame: Int32) r: Int32
extern "C" fun SteamAPI_ISteamInput_Shutdown(input: *Void) r: Int32
extern "C" fun SteamAPI_ISteamInput_RunFrame(input: *Void, reserved: Int32) r: Void
extern "C" fun SteamAPI_ISteamInput_GetConnectedControllers(input: *Void, handles: *UInt64) r: Int32
extern "C" fun SteamAPI_ISteamInput_TriggerVibration(input: *Void, handle: UInt64, leftSpeed: UInt16, rightSpeed: UInt16) r: Void

// ============================================================================
// Safe Wrapper Functions
// ============================================================================

// Convert C string to Seen String
fun cstr_to_string(cstr: *Char) r: String {
    if cstr == null {
        return ""
    }
    return String.fromCString(cstr)
}

// Safe wrapper for checking if Steam client is running
fun steam_is_running() r: Bool {
    return SteamAPI_IsSteamRunning() != 0
}

// Safe wrapper for checking if Steam needs to restart via Steam client
fun steam_restart_app_if_necessary(appId: Int) r: Bool {
    return SteamAPI_RestartAppIfNecessary(appId as UInt32) != 0
}

// Initialize Steam API
fun steam_init() r: Result<Unit, String> {
    let result = SteamAPI_Init()
    if result == 0 {
        return Err("Failed to initialize Steam API. Make sure Steam is running.")
    }
    return Ok(Unit{})
}

// Shutdown Steam API
fun steam_shutdown() r: Void {
    SteamAPI_Shutdown()
}

// Run Steam callbacks (should be called regularly in game loop)
fun steam_run_callbacks() r: Void {
    SteamAPI_RunCallbacks()
}

// Get current user's Steam ID
fun steam_get_user_id() r: UInt64 {
    let user = SteamUser()
    if user == null {
        return 0
    }
    return SteamAPI_ISteamUser_GetSteamID(user)
}

// Check if user is logged in
fun steam_is_logged_in() r: Bool {
    let user = SteamUser()
    if user == null {
        return false
    }
    return SteamAPI_ISteamUser_BLoggedOn(user) != 0
}

// Get user's persona name (display name)
fun steam_get_persona_name() r: String {
    let friends = SteamFriends()
    if friends == null {
        return ""
    }
    let name = SteamAPI_ISteamFriends_GetPersonaName(friends)
    if name == null {
        return ""
    }
    return String.fromCString(name)
}

// Get friend count
fun steam_get_friend_count() r: Int {
    let friends = SteamFriends()
    if friends == null {
        return 0
    }
    return SteamAPI_ISteamFriends_GetFriendCount(friends, k_EFriendFlagImmediate as Int32) as Int
}

// Set rich presence
fun steam_set_rich_presence(key: String, value: String) r: Bool {
    let friends = SteamFriends()
    if friends == null {
        return false
    }
    return SteamAPI_ISteamFriends_SetRichPresence(friends, key.toCString(), value.toCString()) != 0
}

// Clear rich presence
fun steam_clear_rich_presence() r: Void {
    let friends = SteamFriends()
    if friends != null {
        SteamAPI_ISteamFriends_ClearRichPresence(friends)
    }
}

// Get app ID
fun steam_get_app_id() r: UInt32 {
    let utils = SteamUtils()
    if utils == null {
        return 0
    }
    return SteamAPI_ISteamUtils_GetAppID(utils)
}

// Check if overlay is enabled
fun steam_is_overlay_enabled() r: Bool {
    let utils = SteamUtils()
    if utils == null {
        return false
    }
    return SteamAPI_ISteamUtils_IsOverlayEnabled(utils) != 0
}

// Check if running on Steam Deck
fun steam_is_steam_deck() r: Bool {
    let utils = SteamUtils()
    if utils == null {
        return false
    }
    return SteamAPI_ISteamUtils_IsSteamRunningOnSteamDeck(utils) != 0
}

// Check if in Big Picture mode
fun steam_is_big_picture_mode() r: Bool {
    let utils = SteamUtils()
    if utils == null {
        return false
    }
    return SteamAPI_ISteamUtils_IsSteamInBigPictureMode(utils) != 0
}

// Request current stats from Steam
fun steam_request_stats() r: Bool {
    let stats = SteamUserStats()
    if stats == null {
        return false
    }
    return SteamAPI_ISteamUserStats_RequestCurrentStats(stats) != 0
}

// Store stats to Steam
fun steam_store_stats() r: Bool {
    let stats = SteamUserStats()
    if stats == null {
        return false
    }
    return SteamAPI_ISteamUserStats_StoreStats(stats) != 0
}

// Unlock achievement
fun steam_unlock_achievement(name: String) r: Bool {
    let stats = SteamUserStats()
    if stats == null {
        return false
    }
    let result = SteamAPI_ISteamUserStats_SetAchievement(stats, name.toCString())
    if result != 0 {
        // Store immediately
        let _ = SteamAPI_ISteamUserStats_StoreStats(stats)
        return true
    }
    return false
}

// Check if achievement is unlocked
fun steam_has_achievement(name: String) r: Bool {
    let stats = SteamUserStats()
    if stats == null {
        return false
    }
    var achieved: Int32 = 0
    let result = SteamAPI_ISteamUserStats_GetAchievement(stats, name.toCString(), &achieved)
    return result != 0 and achieved != 0
}

// Get integer stat
fun steam_get_stat_int(name: String) r: Int {
    let stats = SteamUserStats()
    if stats == null {
        return 0
    }
    var value: Int32 = 0
    let _ = SteamAPI_ISteamUserStats_GetStatInt32(stats, name.toCString(), &value)
    return value as Int
}

// Set integer stat
fun steam_set_stat_int(name: String, value: Int) r: Bool {
    let stats = SteamUserStats()
    if stats == null {
        return false
    }
    return SteamAPI_ISteamUserStats_SetStatInt32(stats, name.toCString(), value as Int32) != 0
}

// Get current game language
fun steam_get_game_language() r: String {
    let apps = SteamApps()
    if apps == null {
        return "english"
    }
    let lang = SteamAPI_ISteamApps_GetCurrentGameLanguage(apps)
    if lang == null {
        return "english"
    }
    return String.fromCString(lang)
}

// Check if DLC is installed
fun steam_is_dlc_installed(appId: Int) r: Bool {
    let apps = SteamApps()
    if apps == null {
        return false
    }
    return SteamAPI_ISteamApps_BIsDlcInstalled(apps, appId as UInt32) != 0
}

// Check if cloud save is enabled
fun steam_is_cloud_enabled() r: Bool {
    let storage = SteamRemoteStorage()
    if storage == null {
        return false
    }
    return SteamAPI_ISteamRemoteStorage_IsCloudEnabledForApp(storage) != 0
}

// Check if file exists in cloud
fun steam_cloud_file_exists(file: String) r: Bool {
    let storage = SteamRemoteStorage()
    if storage == null {
        return false
    }
    return SteamAPI_ISteamRemoteStorage_FileExists(storage, file.toCString()) != 0
}

// Delete cloud file
fun steam_cloud_delete_file(file: String) r: Bool {
    let storage = SteamRemoteStorage()
    if storage == null {
        return false
    }
    return SteamAPI_ISteamRemoteStorage_FileDelete(storage, file.toCString()) != 0
}
