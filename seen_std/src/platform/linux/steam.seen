extern "C" fun SteamAPI_ISteamApps_GetAvailableGameLanguages(steamApps: *Void) r: *Char
extern "C" fun SteamAPI_ISteamApps_BIsSubscribedApp(steamApps: *Void, appID: UInt32) r: Int32
