// File I/O operations
import core.result.{Result, Ok, Err}
import core.unit.{Unit}

class File {
    var handle: Int
    var path: String
    
    fun open(path: String) -> Result<File, String> {
        let handle = __OpenFile(path, "r")
        if handle < 0 {
            return Err<File, String>("Failed to open file: " + path)
        }
        return Ok<File, String>(File { handle: handle, path: path })
    }
    
    fun create(path: String) -> Result<File, String> {
        let handle = __OpenFile(path, "w")
        if handle < 0 {
            return Err<File, String>("Failed to create file: " + path)
        }
        return Ok<File, String>(File { handle: handle, path: path })
    }
    
    fun readToString() -> Result<String, String> {
        let content = __ReadFile(this.handle)
        if content == "" and __FileError(this.handle) {
            return Err<String, String>("Failed to read file")
        }
        return Ok<String, String>(content)
    }
    
    fun read_bytes() -> Result<Array<Byte>, String> {
        let bytes = __ReadFileBytes(this.handle)
        if bytes.len() == 0 and __FileError(this.handle) {
            return Err("Failed to read file")
        }
        Ok(bytes)
    }
    
    fun write(content: String) -> Result<Int, String> {
        let written = __WriteFile(this.handle, content)
        if written < 0 {
            return Err("Failed to write to file")
        }
        Ok(written)
    }
    
    fun write_bytes(bytes: Array<Byte>) -> Result<Int, String> {
        let written = __WriteFileBytes(this.handle, bytes)
        if written < 0 {
            return Err("Failed to write bytes to file")
        }
        Ok(written)
    }
    
    fun close() -> Result<Unit, String> {
        let result = __CloseFile(this.handle)
        if result < 0 {
            return Err("Failed to close file")
        }
        Ok(Unit{})
    }
    
    fun size() -> Result<Int, String> {
        let size = __FileSize(this.handle)
        if size < 0 {
            return Err("Failed to get file size")
        }
        Ok(size)
    }
}

fun read_to_string(path: String) -> Result<String, String> {
    match File.open(path) {
        Ok(file) => {
            let content = file.readToString()
            let _ = file.close()
            content
        },
        Err(e) => Err(e)
    }
}

fun write_string(path: String, content: String) -> Result<Unit, String> {
    match File.create(path) {
        Ok(file) => {
            match file.write(content) {
                Ok(_) => {
                    let _ = file.close()
                    Ok(Unit{})
                },
                Err(e) => Err(e)
            }
        },
        Err(e) => Err(e)
    }
}
