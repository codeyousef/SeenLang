///
String escape/unescape utilities for JSON and other formats
Production-quality implementation
///

import str.string.{StringBuilder}

class StringEscape {
    // Escape a string for JSON output
    fun escapeJson(input: String) -> String {
        let builder = StringBuilder.new()
        var i = 0
        var segmentStart = 0
        let len = input.length()
        
        while i < len {
            let ch = input.charAt(i)
            let backslash = 92  // '\'
            let quote = 34      // '"'
            let newline = 10    // '\n'
            let carriageReturn = 13  // '\r'
            let tab = 9         // '\t'
            let backspace = 8   // '\b'
            let formfeed = 12   // '\f'
            var escaped = ""
            
            if ch == quote {
                escaped = "\\\""
            } else if ch == backslash {
                escaped = "\\\\"
            } else if ch == newline {
                escaped = "\\n"
            } else if ch == carriageReturn {
                escaped = "\\r"
            } else if ch == tab {
                escaped = "\\t"
            } else if ch == backspace {
                escaped = "\\b"
            } else if ch == formfeed {
                escaped = "\\f"
            }

            if escaped.length() > 0 {
                if segmentStart < i {
                    builder.append(input.substring(segmentStart, i))
                }
                builder.append(escaped)
                segmentStart = i + 1
            }
            
            i = i + 1
        }
        
        if segmentStart < len {
            builder.append(input.substring(segmentStart, len))
        }
        return builder.toString()
    }
    
    // Check if a string needs escaping for JSON
    fun needsEscaping(input: String): Bool {
        var i = 0
        let len = input.length()
        
        while i < len {
            let ch = input.charAt(i)
            if ch == '"' or ch == '\\' or ch == '\n' or ch == '\r' or ch == '\t' or ch == '\b' or ch == '\f' {
                return true
            }
            i = i + 1
        }
        
        return false
    }
    
    // URL encode a string
    fun urlEncode(input: String): String {
        let builder = StringBuilder.new()
        var i = 0
        var segmentStart = 0
        let len = input.length()
        
        while i < len {
            let ch = input.charAt(i)
            
            if isAlphaNum(ch) or ch == '-' or ch == '_' or ch == '.' or ch == '~' {
                // Keep scanning the unescaped segment.
            } else if ch == ' ' {
                if segmentStart < i {
                    builder.append(input.substring(segmentStart, i))
                }
                builder.append("+")
                segmentStart = i + 1
            } else {
                if segmentStart < i {
                    builder.append(input.substring(segmentStart, i))
                }
                builder.append("%")
                builder.append(toHex(ch / 16))
                builder.append(toHex(ch % 16))
                segmentStart = i + 1
            }
            
            i = i + 1
        }
        
        if segmentStart < len {
            builder.append(input.substring(segmentStart, len))
        }
        return builder.toString()
    }
    
    // HTML escape
    fun escapeHtml(input: String): String {
        let builder = StringBuilder.new()
        var i = 0
        var segmentStart = 0
        let len = input.length()
        
        while i < len {
            let ch = input.charAt(i)
            var escaped = ""
            
            if ch == '<' {
                escaped = "&lt;"
            } else if ch == '>' {
                escaped = "&gt;"
            } else if ch == '&' {
                escaped = "&amp;"
            } else if ch == '"' {
                escaped = "&quot;"
            } else if ch == '\'' {
                escaped = "&#39;"
            }

            if escaped.length() > 0 {
                if segmentStart < i {
                    builder.append(input.substring(segmentStart, i))
                }
                builder.append(escaped)
                segmentStart = i + 1
            }
            
            i = i + 1
        }
        
        if segmentStart < len {
            builder.append(input.substring(segmentStart, len))
        }
        return builder.toString()
    }
    
    // Unescape JSON string
    fun unescapeJson(input: String): String {
        let builder = StringBuilder.new()
        var i = 0
        var segmentStart = 0
        let len = input.length()
        
        while i < len {
            let ch = input.charAt(i)
            
            if ch == '\\' and i + 1 < len {
                let next = input.charAt(i + 1)
                var unescaped = ""
                if next == '"' {
                    unescaped = "\""
                } else if next == '\\' {
                    unescaped = "\\"
                } else if next == 'n' {
                    unescaped = "\n"
                } else if next == 'r' {
                    unescaped = "\r"
                } else if next == 't' {
                    unescaped = "\t"
                } else if next == 'b' {
                    unescaped = "\b"
                } else if next == 'f' {
                    unescaped = "\f"
                }

                if unescaped.length() > 0 {
                    if segmentStart < i {
                        builder.append(input.substring(segmentStart, i))
                    }
                    builder.append(unescaped)
                    i = i + 2
                    segmentStart = i
                } else {
                    i = i + 1
                }
            } else {
                i = i + 1
            }
        }
        
        if segmentStart < len {
            builder.append(input.substring(segmentStart, len))
        }
        return builder.toString()
    }
    
    // Helper: check if character is alphanumeric
    fun isAlphaNum(ch: Int): Bool {
        return (ch >= 48 and ch <= 57) or (ch >= 65 and ch <= 90) or (ch >= 97 and ch <= 122)
    }
    
    // Helper: convert number to hex digit
    fun toHex(n: Int): String {
        if n < 10 {
            return String.fromCharCode(48 + n)
        } else {
            return String.fromCharCode(65 + (n - 10))
        }
    }
}
