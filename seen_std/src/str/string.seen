// seen_std.str.string
// UTF-8 friendly helpers and CString bridges used by bootstrap tooling.

// Disabled during bootstrap - FFI not needed for core functionality
// import ffi.cinterop.{CString, toCString, fromCString}

class StringBuilder {
    var parts: Array<String>
    var totalLength: Int

    fun new() r: StringBuilder {
        return StringBuilder{
            parts: Array<String>(),
            totalLength: 0
        }
    }

    fun append(text: String) r: Void {
        if text.length() == 0 {
            return
        }
        this.totalLength = this.totalLength + text.length()
        this.parts.push(text)
    }

    fun appendChar(ch: Char) r: Void {
        this.totalLength = this.totalLength + 1
        this.parts.push(ch.toString())
    }

    fun appendLine(text: String = "") r: Void {
        if text.length() == 0 {
            append("\n")
        } else {
            append(text + "\n")
        }
    }

    fun appendAll(values: Array<String>) r: Void {
        var i = 0
        while i < values.length() {
            append(values[i])
            i = i + 1
        }
    }

    fun clear() r: Void {
        this.parts = Array<String>()
        this.totalLength = 0
    }

    fun isEmpty() r: Bool {
        return this.totalLength == 0
    }

    fun length() r: Int {
        return this.totalLength
    }

    fun buildAndClear() r: String {
        let built = toString()
        clear()
        return built
    }

    fun toString() r: String {
        let len = this.parts.length()
        if len == 0 { return "" }
        if len == 1 { return this.parts[0] }
        if len == 2 { return this.parts[0] + this.parts[1] }
        // Use binary tree reduction: O(n log n) instead of O(n²)
        return this.reduceToString(0, len)
    }

    // Binary tree reduction for efficient string concatenation
    fun reduceToString(start: Int, end: Int) r: String {
        let count = end - start
        if count == 0 { return "" }
        if count == 1 { return this.parts[start] }
        if count == 2 { return this.parts[start] + this.parts[start + 1] }
        let mid = start + count / 2
        return this.reduceToString(start, mid) + this.reduceToString(mid, end)
    }

    fun copyParts(source: Array<String>) r: Array<String> {
        let copy = Array<String>()
        var i = 0
        while i < source.length() {
            copy.push(source[i])
            i = i + 1
        }
        return copy
    }

    fun mergeAdjacent(values: Array<String>) r: Array<String> {
        let merged = Array<String>()
        var index = 0
        while index < values.length() {
            if index + 1 < values.length() {
                let s = values[index] + values[index + 1]
                println("[DEBUG] mergeAdjacent: pushing len=" + s.length().toString())
                merged.push(s)
                index = index + 2
            } else {
                merged.push(values[index])
                index = index + 1
            }
        }
        return merged
    }
}

fun split(text: String, delimiter: String) r: Array<String> {
    let pieces = Array<String>()
    let delimLength = delimiter.length()
    if delimLength == 0 {
        var i = 0
        while i < text.length() {
            pieces.push("" + text.charAt(i))
            i = i + 1
        }
        return pieces
    }

    var current = ""
    var index = 0
    let limit = text.length()
    while index < limit {
        let nextIndex = index + delimLength
        if nextIndex <= limit and text.substring(index, nextIndex) == delimiter {
            pieces.push(current)
            current = ""
            index = nextIndex
        } else {
            current = current + text.charAt(index)
            index = index + 1
        }
    }
    pieces.push(current)
    return pieces
}

fun utf8ByteLenFromLeadByte(byte: Int) r: Int {
    if byte < 128 {
        return 1
    }
    if byte < 224 {
        return 2
    }
    if byte < 240 {
        return 3
    }
    if byte < 248 {
        return 4
    }
    return 1
}

fun utf8CodepointLength(text: String) r: Int {
    let byteLength = text.length()
    var count = 0
    var byteIndex = 0
    while byteIndex < byteLength {
        byteIndex = byteIndex + utf8ByteLenFromLeadByte(text.byteAt(byteIndex))
        if byteIndex > byteLength {
            byteIndex = byteLength
        }
        count = count + 1
    }
    return count
}

fun utf8ByteIndex(text: String, codepointIndex: Int) r: Int {
    if codepointIndex <= 0 {
        return 0
    }
    let byteLength = text.length()
    var currentCodepoint = 0
    var byteIndex = 0
    while byteIndex < byteLength and currentCodepoint < codepointIndex {
        byteIndex = byteIndex + utf8ByteLenFromLeadByte(text.byteAt(byteIndex))
        if byteIndex > byteLength {
            byteIndex = byteLength
        }
        currentCodepoint = currentCodepoint + 1
    }
    return byteIndex
}

fun substringByCodepoints(text: String, start: Int, end: Int) r: String {
    let startByte = utf8ByteIndex(text, start)
    let endByte = utf8ByteIndex(text, end)
    if startByte >= endByte {
        return ""
    }
    return text.substring(startByte, endByte)
}

fun trim(text: String) r: String {
    return trimEnd(trimStart(text))
}

fun trimStart(text: String) r: String {
    let codepointLength = utf8CodepointLength(text)
    if codepointLength == 0 {
        return text
    }
    var start = 0
    while start < codepointLength and isWhitespace(text.charAt(start)) {
        start = start + 1
    }
    if start == 0 {
        return text
    }
    if start >= codepointLength {
        return ""
    }
    return substringByCodepoints(text, start, codepointLength)
}

fun trimEnd(text: String) r: String {
    let codepointLength = utf8CodepointLength(text)
    if codepointLength == 0 {
        return text
    }
    var end = codepointLength - 1
    while end >= 0 and isWhitespace(text.charAt(end)) {
        end = end - 1
    }
    if end < 0 {
        return ""
    }
    if end == codepointLength - 1 {
        return text
    }
    return substringByCodepoints(text, 0, end + 1)
}

fun isBlank(text: String) r: Bool {
    let codepointLength = utf8CodepointLength(text)
    var i = 0
    while i < codepointLength {
        if not isWhitespace(text.charAt(i)) {
            return false
        }
        i = i + 1
    }
    return true
}

fun contains(text: String, needle: String) r: Bool {
    return indexOf(text, needle, 0) >= 0
}

fun startsWith(text: String, prefix: String) r: Bool {
    if prefix.length() > text.length() {
        return false
    }
    return text.substring(0, prefix.length()) == prefix
}

fun endsWith(text: String, suffix: String) r: Bool {
    if suffix.length() > text.length() {
        return false
    }
    let start = text.length() - suffix.length()
    return text.substring(start, text.length()) == suffix
}

fun indexOf(text: String, needle: String, startIndex: Int = 0) r: Int {
    let needleLength = needle.length()
    if needleLength == 0 {
        if startIndex < 0 {
            return 0
        }
        if startIndex > text.length() {
            return text.length()
        }
        return startIndex
    }
    var start = startIndex
    if start < 0 {
        start = 0
    }
    let limit = text.length() - needleLength
    if limit < 0 {
        return -1
    }
    while start <= limit {
        if text.substring(start, start + needleLength) == needle {
            return start
        }
        start = start + 1
    }
    return -1
}

fun String_charCodeAt(s: String, index: Int) r: Int {
    let ch = s.charAt(index)
    return ch.toInt()
}

fun lastIndexOf(text: String, needle: String) r: Int {
    let needleLength = needle.length()
    if needleLength == 0 {
        return text.length()
    }
    if needleLength > text.length() {
        return -1
    }
    var index = text.length() - needleLength
    while index >= 0 {
        if text.substring(index, index + needleLength) == needle {
            return index
        }
        index = index - 1
    }
    return -1
}

fun lines(text: String, dropEmpty: Bool = false) r: Array<String> {
    let result = Array<String>()
    let codepointLength = utf8CodepointLength(text)
    if codepointLength == 0 {
        if not dropEmpty {
            result.push("")
        }
        return result
    }
    var lineStart = 0
    var index = 0
    while index < codepointLength {
        let ch = text.charAt(index)
        if ch == '\n' or ch == '\r' {
            let line = substringByCodepoints(text, lineStart, index)
            if not(dropEmpty and line.length() == 0) {
                result.push(line)
            }
            if ch == '\r' and index + 1 < codepointLength and text.charAt(index + 1) == '\n' {
                index = index + 1
            }
            lineStart = index + 1
        }
        index = index + 1
    }
    if lineStart <= codepointLength {
        let tail: String = substringByCodepoints(text, lineStart, codepointLength)
        if not(dropEmpty and tail.length() == 0) {
            result.push(tail)
        }
    }
    return result
}

fun splitWhitespace(text: String, dropEmpty: Bool = true) r: Array<String> {
    let result = Array<String>()
    let codepointLength = utf8CodepointLength(text)
    if codepointLength == 0 {
        if not dropEmpty {
            result.push("")
        }
        return result
    }

    var start = 0
    var index = 0
    while index < codepointLength {
        if isWhitespace(text.charAt(index)) {
            if index > start or not dropEmpty {
                result.push(substringByCodepoints(text, start, index))
            }
            index = index + 1
            start = index
        } else {
            index = index + 1
        }
    }

    if start < codepointLength {
        result.push(substringByCodepoints(text, start, codepointLength))
    } else if not dropEmpty {
        result.push("")
    }

    return result
}

fun words(text: String) r: Array<String> {
    return splitWhitespace(text, true)
}

fun replaceFirst(text: String, target: String, replacement: String) r: String {
    let index = indexOf(text, target, 0)
    if index < 0 {
        return text
    }
    let before = text.substring(0, index)
    let after = text.substring(index + target.length(), text.length())
    return before + replacement + after
}

fun replaceAll(text: String, target: String, replacement: String) r: String {
    if target.length() == 0 {
        return text
    }
    let builder = StringBuilder.new()
    let length = text.length()
    let targetLength = target.length()
    var index = 0
    while index <= length - targetLength {
        if text.substring(index, index + targetLength) == target {
            builder.append(replacement)
            index = index + targetLength
        } else {
            builder.appendChar(text.charAt(index))
            index = index + 1
        }
    }
    while index < length {
        builder.appendChar(text.charAt(index))
        index = index + 1
    }
    return builder.toString()
}

fun replace(text: String, target: String, replacement: String) r: String {
    return replaceAll(text, target, replacement)
}

fun removePrefix(text: String, prefix: String) r: String {
    if prefix.length() == 0 or not startsWith(text, prefix) {
        return text
    }
    return text.substring(prefix.length(), text.length())
}

fun removeSuffix(text: String, suffix: String) r: String {
    if suffix.length() == 0 or not endsWith(text, suffix) {
        return text
    }
    return text.substring(0, text.length() - suffix.length())
}

fun ensurePrefix(text: String, prefix: String) r: String {
    if startsWith(text, prefix) {
        return text
    }
    return prefix + text
}

fun ensureSuffix(text: String, suffix: String) r: String {
    if endsWith(text, suffix) {
        return text
    }
    return text + suffix
}

fun padStart(text: String, width: Int, padChar: Char = ' ') r: String {
    if width <= text.length() {
        return text
    }
    let builder = StringBuilder.new()
    var remaining = width - text.length()
    while remaining > 0 {
        builder.appendChar(padChar)
        remaining = remaining - 1
    }
    builder.append(text)
    return builder.toString()
}

fun padEnd(text: String, width: Int, padChar: Char = ' ') r: String {
    if width <= text.length() {
        return text
    }
    let builder = StringBuilder.new()
    builder.append(text)
    var remaining = width - text.length()
    while remaining > 0 {
        builder.appendChar(padChar)
        remaining = remaining - 1
    }
    return builder.toString()
}

fun repeat(text: String, times: Int) r: String {
    if times <= 0 {
        return ""
    }
    var result = ""
    var i = 0
    while i < times {
        result = result + text
        i = i + 1
    }
    return result
}

fun join(parts: Array<String>, separator: String) r: String {
    if parts.length() == 0 {
        return ""
    }
    var result = ""
    var index = 0
    while index < parts.length() {
        result = result + parts[index]
        if index != parts.length() - 1 {
            result = result + separator
        }
        index = index + 1
    }
    return result
}

// Extension method for Array<String>
fun Array<String>.join(separator: String) r: String {
    return join(this, separator)
}

// Extension methods for FFI - disabled during bootstrap due to extension method limitations
