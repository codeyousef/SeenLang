fun isWhitespace(ch: Char) r: Bool {
    if ch == ' ' or ch == '\t' or ch == '\n' or ch == '\r' {
        return true
    }
    let code = ch.toInt()
    if code == 11 or code == 12 {
        return true
    }
    if code == 160 {
        return true
    }
    return false
}

fun String.trim() r: String {
    return trim(this)
}

// Note: String_fromCharCode is provided by the runtime (seen_runtime.c)
// It creates a string from an integer character code (Unicode code point)
// The implementation uses seen_char_to_str which handles UTF-8 encoding

// C-style wrapper for replace
fun String_replace(text: String, target: String, replacement: String) r: String {
    return replaceAll(text, target, replacement)
}

// Extension methods for method-style calls on String
fun String_startsWith(text: String, prefix: String) r: Bool {
    return startsWith(text, prefix)
}

fun String_endsWith(text: String, suffix: String) r: Bool {
    return endsWith(text, suffix)
}

// String case conversion & utility extension methods
// These call C runtime functions (String_*) via codegen builtins.
// The Seen wrappers below are for user programs that import this module.

fun String_toUpperCase(text: String) r: String {
    let builder = StringBuilder.new()
    var i = 0
    while i < text.length() {
        let ch = text.charAt(i)
        let code = ch.toInt()
        if code >= 97 and code <= 122 {
            builder.appendChar(String.fromCharCode(code - 32).charAt(0))
        } else {
            builder.appendChar(ch)
        }
        i = i + 1
    }
    return builder.toString()
}

fun String_toLowerCase(text: String) r: String {
    let builder = StringBuilder.new()
    var i = 0
    while i < text.length() {
        let ch = text.charAt(i)
        let code = ch.toInt()
        if code >= 65 and code <= 90 {
            builder.appendChar(String.fromCharCode(code + 32).charAt(0))
        } else {
            builder.appendChar(ch)
        }
        i = i + 1
    }
    return builder.toString()
}

fun String_reverse(text: String) r: String {
    let len = text.length()
    if len <= 1 {
        return text
    }
    let builder = StringBuilder.new()
    var i = len - 1
    while i >= 0 {
        builder.appendChar(text.charAt(i))
        i = i - 1
    }
    return builder.toString()
}

fun String_isEmpty(text: String) r: Bool {
    return text.length() == 0
}

fun String_count(text: String, needle: String) r: Int {
    let needleLen = needle.length()
    if needleLen == 0 or needleLen > text.length() {
        return 0
    }
    var count = 0
    var i = 0
    let limit = text.length() - needleLen
    while i <= limit {
        if text.substring(i, i + needleLen) == needle {
            count = count + 1
            i = i + needleLen
        } else {
            i = i + 1
        }
    }
    return count
}

fun String_toInt(text: String) r: Int {
    // Parse integer from string - basic decimal parsing
    let len = text.length()
    if len == 0 {
        return 0
    }
    var result = 0
    var i = 0
    var negative = false
    let firstCh = text.charAt(0)
    if firstCh == '-' {
        negative = true
        i = 1
    } else {
        if firstCh == '+' {
            i = 1
        }
    }
    while i < len {
        let ch = text.charAt(i)
        let code = ch.toInt()
        if code >= 48 and code <= 57 {
            result = result * 10 + (code - 48)
        } else {
            // Stop at non-digit
            if negative {
                return 0 - result
            }
            return result
        }
        i = i + 1
    }
    if negative {
        return 0 - result
    }
    return result
}

fun String_toFloat(text: String) r: Float {
    // Basic float parsing - integer part + optional decimal part
    let len = text.length()
    if len == 0 {
        return 0.0
    }
    var intPart = 0
    var fracPart = 0.0
    var fracDiv = 1.0
    var i = 0
    var negative = false
    var inFrac = false
    let firstCh = text.charAt(0)
    if firstCh == '-' {
        negative = true
        i = 1
    } else {
        if firstCh == '+' {
            i = 1
        }
    }
    while i < len {
        let ch = text.charAt(i)
        if ch == '.' {
            inFrac = true
            i = i + 1
        } else {
            let code = ch.toInt()
            if code >= 48 and code <= 57 {
                if inFrac {
                    fracDiv = fracDiv * 10.0
                    fracPart = fracPart + (code - 48).toFloat() / fracDiv
                } else {
                    intPart = intPart * 10 + (code - 48)
                }
                i = i + 1
            } else {
                i = len
            }
        }
    }
    var result = intPart.toFloat() + fracPart
    if negative {
        result = 0.0 - result
    }
    return result
}
