// ToString / FromString conversion utilities
// Complements the From/Into pattern in convert.seen

@trait
class ToString {
    fun toString() r: String {
        return "<object>"
    }
}

@trait
class FromString {
    // Marker trait for types that can be parsed from strings
}

// Convenience free functions following the impl pattern
fun Int_toString(value: Int) r: String {
    return value.toString()
}

fun Float_toString(value: Float) r: String {
    return value.toString()
}

fun Bool_toString(value: Int) r: String {
    if value == 1 {
        return "true"
    }
    return "false"
}

fun Char_toString(value: Int) r: String {
    return value.toString()
}
