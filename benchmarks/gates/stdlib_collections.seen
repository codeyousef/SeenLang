fun checksumArray(values: Array<Int>) r: Int {
    var sum = 0
    var i = 0
    while i < values.length() {
        sum = sum + values[i]
        i = i + 1
    }
    return sum
}

fun main() r: Int {
    let values = Array<Int>()
    var i = 0
    while i < 4096 {
        values.push((i * 17 + 11) % 1009)
        i = i + 1
    }

    var rounds = 0
    var total = 0
    while rounds < 64 {
        var j = 0
        while j < values.length() {
            values[j] = (values[j] + rounds + j) % 4099
            j = j + 1
        }
        total = total + checksumArray(values)
        rounds = rounds + 1
    }

    if total <= 0 {
        return 1
    }
    return 0
}
