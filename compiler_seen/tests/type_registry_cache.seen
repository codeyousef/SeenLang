import codegen.type_registry_cache.{
    resetStructLookupCache, resetFunctionReturnCache, resetFieldInfoCache,
    findCachedStructIndex, cacheStructIndex, findCachedFunctionReturnIndex
}
import codegen.type_registry_core.{
    findStructReg, getFunctionReturnTypeReg, getFieldInfoReg,
    applyStructLayoutRegistrationReg
}
import codegen.ir_field_registry.{
    findCachedIrgenFieldIndexImpl, cacheIrgenFieldIndexImpl,
    findCachedChainedPathTypeRecordImpl, cacheChainedPathTypeImpl
}
import codegen.ir_type_info.{resetTypeInfoLookupCaches, findStructIdx}
import codegen.ir_seen_field_type_lookup.{getSeenFieldTypeImpl}
import codegen.ir_method_return_type_lookup.{getMethodReturnTypeImpl}
import codegen.ir_infer_type.{resetMethodBoolSuffixCache,
    inferMethodCallBoolSuffixImpl}

fun expect(condition: Bool, message: String) r: Void {
    if not condition {
        abort(message)
    }
}

fun testStructLookupCache() r: Void {
    resetStructLookupCache()

    let structNames = Array<String>()
    structNames.push("CacheBox")
    structNames.push("CacheEnvelope")

    expect(findCachedStructIndex("CacheEnvelope", structNames) == -1,
        "struct cache starts empty")

    cacheStructIndex("CacheEnvelope<Int>", 1, structNames)
    expect(findCachedStructIndex("CacheEnvelope<String>", structNames) == 1,
        "generic struct cache uses the base registry name")

    let genericStructNames = Array<String>()
    genericStructNames.push("CacheGeneric")
    genericStructNames.push("CacheGeneric<Int>")
    cacheStructIndex("CacheGeneric<Int>", 1, genericStructNames)
    cacheStructIndex("CacheGeneric<String>", 0, genericStructNames)
    expect(findCachedStructIndex("CacheGeneric<Int>", genericStructNames) == 1,
        "exact generic cache wins over base fallback")
    expect(findCachedStructIndex("CacheGeneric<String>", genericStructNames)
        == 0, "generic base fallback still resolves")

    structNames.push("CacheEnvelope")
    expect(findCachedStructIndex("CacheEnvelope", structNames) == -1,
        "struct cache is guarded by registry length")
    expect(findStructReg("CacheEnvelope", structNames) == 2,
        "struct lookup still resolves the latest matching entry")
    expect(findCachedStructIndex("CacheEnvelope", structNames) == 2,
        "struct lookup caches the latest matching entry")
}

fun testFunctionReturnCache() r: Void {
    resetFunctionReturnCache()

    let funcNames = Array<String>()
    let funcRetTypes = Array<String>()
    funcNames.push("cacheFunc")
    funcRetTypes.push("Int")

    expect(findCachedFunctionReturnIndex("cacheFunc", funcNames) == -2,
        "function return cache starts empty")
    expect(getFunctionReturnTypeReg("cacheFunc", funcNames, funcRetTypes) ==
        "Int", "function return lookup resolves uncached entry")
    expect(findCachedFunctionReturnIndex("cacheFunc", funcNames) == 0,
        "function return lookup populates cache")

    expect(getFunctionReturnTypeReg("missingCacheFunc", funcNames,
        funcRetTypes) == "", "missing function return resolves empty")
    expect(findCachedFunctionReturnIndex("missingCacheFunc", funcNames) == -1,
        "missing function return is cached as a miss")

    funcNames.push("missingCacheFunc")
    funcRetTypes.push("String")
    expect(findCachedFunctionReturnIndex("missingCacheFunc", funcNames) == -2,
        "function return miss is invalidated by registry growth")
    expect(getFunctionReturnTypeReg("missingCacheFunc", funcNames,
        funcRetTypes) == "String", "new function after miss resolves")

    funcNames.push("cacheFunc")
    funcRetTypes.push("Bool")
    expect(getFunctionReturnTypeReg("cacheFunc", funcNames, funcRetTypes) ==
        "Bool", "function return cache respects later duplicate entries")
}

fun testFieldInfoCache() r: Void {
    resetFieldInfoCache()

    let structNames = Array<String>()
    let structFieldNames = Array<String>()
    structNames.push("CacheRecord")
    structFieldNames.push("alpha,beta")

    expect(getFieldInfoReg("CacheRecord", "beta", structNames,
        structFieldNames) == 1, "field lookup resolves dynamic field")

    structNames.push("CacheRecord")
    structFieldNames.push("gamma")
    expect(getFieldInfoReg("CacheRecord", "beta", structNames,
        structFieldNames) == -1, "field cache is guarded by registry length")
    expect(getFieldInfoReg("CacheRecord", "gamma", structNames,
        structFieldNames) == 0, "field lookup resolves latest duplicate")

    let layoutStructNames = Array<String>()
    let structLayouts = Array<String>()
    let layoutFieldNames = Array<String>()
    let structFieldTypes = Array<String>()
    let structSizes = Array<Int>()
    let structMethodNames = Array<String>()
    let structMethodRetTypes = Array<String>()
    layoutStructNames.push("CacheLayout")
    structLayouts.push("")
    layoutFieldNames.push("alpha,beta")
    structFieldTypes.push("Int|Int")
    structSizes.push(0)
    structMethodNames.push("")
    structMethodRetTypes.push("")

    expect(getFieldInfoReg("CacheLayout", "beta", layoutStructNames,
        layoutFieldNames) == 1, "field lookup caches initial layout")
    applyStructLayoutRegistrationReg(0, "CacheLayout", "", "beta,alpha",
        "Int|Int", 0, "", "", structLayouts, layoutFieldNames,
        structFieldTypes, structSizes, structMethodNames, structMethodRetTypes)
    expect(getFieldInfoReg("CacheLayout", "beta", layoutStructNames,
        layoutFieldNames) == 0, "field cache resets after layout rewrite")
}

fun testIrFieldLookupCaches() r: Void {
    let fieldKeys = Array<String>()
    let fieldIdxs = Array<Int>()

    cacheIrgenFieldIndexImpl("CacheState.value", 4, fieldKeys, fieldIdxs)
    expect(findCachedIrgenFieldIndexImpl("CacheState.value", fieldKeys,
        fieldIdxs) == 4, "irgen field cache returns cached index")

    cacheIrgenFieldIndexImpl("CacheState.value", 5, fieldKeys, fieldIdxs)
    expect(findCachedIrgenFieldIndexImpl("CacheState.value", fieldKeys,
        fieldIdxs) == 5, "irgen field cache updates existing entry")

    let pathKeys = Array<String>()
    let pathLens = Array<Int>()
    let pathValues = Array<String>()
    cacheChainedPathTypeImpl("CacheState|next.value", 2, "Int", pathKeys,
        pathLens, pathValues)

    let cachedPath = findCachedChainedPathTypeRecordImpl(
        "CacheState|next.value", 2, pathKeys, pathLens)
    expect(cachedPath >= 0, "chained path cache returns cached record")
    expect(pathValues[cachedPath] == "Int",
        "chained path cache stores result type")
    expect(findCachedChainedPathTypeRecordImpl("CacheState|next.value", 3,
        pathKeys, pathLens) == -1,
        "chained path cache is guarded by registry length")

    cacheChainedPathTypeImpl("CacheState|next.value", 2, "String", pathKeys,
        pathLens, pathValues)
    let updatedPath = findCachedChainedPathTypeRecordImpl(
        "CacheState|next.value", 2, pathKeys, pathLens)
    expect(pathValues[updatedPath] == "String",
        "chained path cache updates existing entry")
}

fun testTypeInfoStructLookupCache() r: Void {
    resetTypeInfoLookupCaches()

    let structNames = Array<String>()
    structNames.push("CacheStruct")
    structNames.push("OtherStruct")

    expect(findStructIdx(structNames, "CacheStruct") == 0,
        "type-info struct lookup resolves uncached entry")
    expect(findStructIdx(structNames, "CacheStruct") == 0,
        "type-info struct lookup returns cached entry")

    let sameLengthStructNames = Array<String>()
    sameLengthStructNames.push("CacheStruct")
    sameLengthStructNames.push("CacheStruct")
    expect(findStructIdx(sameLengthStructNames, "CacheStruct") == 1,
        "type-info struct cache rejects stale same-length duplicate")

    sameLengthStructNames.push("CacheStruct")
    expect(findStructIdx(sameLengthStructNames, "CacheStruct") == 2,
        "type-info struct cache respects registry growth")
}

fun testSeenFieldTypeCache() r: Void {
    resetTypeInfoLookupCaches()

    let structNames = Array<String>()
    let fieldNames = Array<String>()
    let fieldTypes = Array<String>()
    structNames.push("CacheFieldRecord")
    fieldNames.push("alpha,beta")
    fieldTypes.push("Int|String")

    expect(getSeenFieldTypeImpl("CacheFieldRecord", "beta", structNames,
        fieldNames, fieldTypes) == "String",
        "seen field type lookup resolves dynamic field")
    expect(getSeenFieldTypeImpl("CacheFieldRecord", "beta", structNames,
        fieldNames, fieldTypes) == "String",
        "seen field type lookup returns cached field")

    let sameLengthStructNames = Array<String>()
    let sameLengthFieldNames = Array<String>()
    let sameLengthFieldTypes = Array<String>()
    sameLengthStructNames.push("CacheFieldRecord")
    sameLengthFieldNames.push("beta")
    sameLengthFieldTypes.push("Bool")
    expect(getSeenFieldTypeImpl("CacheFieldRecord", "beta",
        sameLengthStructNames, sameLengthFieldNames, sameLengthFieldTypes) ==
        "Bool", "seen field type cache rejects stale same-length layout")

    expect(getSeenFieldTypeImpl("CacheFieldRecord", "missing",
        sameLengthStructNames, sameLengthFieldNames, sameLengthFieldTypes) ==
        "Int", "seen field type cache stores misses as default Int")

    let lateFieldNames = Array<String>()
    let lateFieldTypes = Array<String>()
    lateFieldNames.push("missing")
    lateFieldTypes.push("Float")
    expect(getSeenFieldTypeImpl("CacheFieldRecord", "missing",
        sameLengthStructNames, lateFieldNames, lateFieldTypes) == "Float",
        "seen field type cache rejects stale same-length miss")
}

fun testMethodReturnTypeCache() r: Void {
    resetTypeInfoLookupCaches()

    let structNames = Array<String>()
    let methodNames = Array<String>()
    let methodRetTypes = Array<String>()
    structNames.push("CacheMethodRecord")
    methodNames.push("foo,bar")
    methodRetTypes.push("Int|String")

    expect(getMethodReturnTypeImpl("CacheMethodRecord", "bar", structNames,
        methodNames, methodRetTypes) == "String",
        "method return lookup resolves dynamic method")
    expect(getMethodReturnTypeImpl("CacheMethodRecord", "bar", structNames,
        methodNames, methodRetTypes) == "String",
        "method return lookup returns cached method")

    let sameLengthStructNames = Array<String>()
    let sameLengthMethodNames = Array<String>()
    let sameLengthMethodRetTypes = Array<String>()
    sameLengthStructNames.push("CacheMethodRecord")
    sameLengthMethodNames.push("bar")
    sameLengthMethodRetTypes.push("Bool")
    expect(getMethodReturnTypeImpl("CacheMethodRecord", "bar",
        sameLengthStructNames, sameLengthMethodNames,
        sameLengthMethodRetTypes) == "Bool",
        "method return cache rejects stale same-length method table")

    expect(getMethodReturnTypeImpl("CacheMethodRecord", "missing",
        sameLengthStructNames, sameLengthMethodNames,
        sameLengthMethodRetTypes) == "",
        "method return cache stores missing method")

    let lateMethodNames = Array<String>()
    let lateMethodRetTypes = Array<String>()
    lateMethodNames.push("missing")
    lateMethodRetTypes.push("Float")
    expect(getMethodReturnTypeImpl("CacheMethodRecord", "missing",
        sameLengthStructNames, lateMethodNames, lateMethodRetTypes) ==
        "Float", "method return cache rejects stale same-length miss")

    let duplicateStructNames = Array<String>()
    let duplicateMethodNames = Array<String>()
    let duplicateMethodRetTypes = Array<String>()
    duplicateStructNames.push("CacheMethodRecord")
    duplicateMethodNames.push("bar")
    duplicateMethodRetTypes.push("Int")
    duplicateStructNames.push("CacheMethodRecord")
    duplicateMethodNames.push("bar")
    duplicateMethodRetTypes.push("String")
    expect(getMethodReturnTypeImpl("CacheMethodRecord", "bar",
        duplicateStructNames, duplicateMethodNames,
        duplicateMethodRetTypes) == "String",
        "method return cache respects latest duplicate struct")
}

fun testMethodBoolSuffixCache() r: Void {
    resetMethodBoolSuffixCache()

    let funcNames = Array<String>()
    let funcRetTypes = Array<String>()
    funcNames.push("Owner_isReady")
    funcRetTypes.push("Bool")
    expect(inferMethodCallBoolSuffixImpl("isReady", funcNames,
        funcRetTypes) == "Bool",
        "bool suffix lookup resolves Bool helper")
    expect(inferMethodCallBoolSuffixImpl("isReady", funcNames,
        funcRetTypes) == "Bool",
        "bool suffix lookup returns cached Bool helper")

    let sameLengthRetTypes = Array<String>()
    sameLengthRetTypes.push("Int")
    expect(inferMethodCallBoolSuffixImpl("isReady", funcNames,
        sameLengthRetTypes) == "",
        "bool suffix cache rejects stale same-length return type")

    let missNames = Array<String>()
    let missRetTypes = Array<String>()
    missNames.push("Other_value")
    missRetTypes.push("Bool")
    expect(inferMethodCallBoolSuffixImpl("missing", missNames,
        missRetTypes) == "",
        "bool suffix lookup caches no-match miss")

    let lateNames = Array<String>()
    let lateRetTypes = Array<String>()
    lateNames.push("Owner_missing")
    lateRetTypes.push("Bool")
    expect(inferMethodCallBoolSuffixImpl("missing", lateNames,
        lateRetTypes) == "Bool",
        "bool suffix cache rejects stale same-length no-match miss")

    let latestNames = Array<String>()
    let latestRetTypes = Array<String>()
    latestNames.push("Old_isReady")
    latestRetTypes.push("Bool")
    latestNames.push("New_isReady")
    latestRetTypes.push("Int")
    expect(inferMethodCallBoolSuffixImpl("isReady", latestNames,
        latestRetTypes) == "",
        "bool suffix lookup preserves latest non-Bool helper behavior")
}

fun main() r: Int {
    testStructLookupCache()
    testFunctionReturnCache()
    testFieldInfoCache()
    testIrFieldLookupCaches()
    testTypeInfoStructLookupCache()
    testSeenFieldTypeCache()
    testMethodReturnTypeCache()
    testMethodBoolSuffixCache()
    return 0
}
