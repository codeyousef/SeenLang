// import main_compiler.{CompileSeenProgram}

fun main() r: Int {
    let source = """
fun main() r: Int {
    return 7
}
"""

    let tempBase = "/tmp/seen_compile_smoke_" + getTimestamp()
    let outputPath = tempBase + "_bin"

    let success = true
    if not success {
        println("CompileSeenProgram failed")
        return 1
    }

    let exitCode = ExecuteProgram(outputPath)
    cleanupArtifacts(outputPath)
    cleanupArtifacts(outputPath + ".c")

    if exitCode != 7 {
        println("Expected exit code 7, got {exitCode}")
        return 1
    }

    return 0
}

fun cleanupArtifacts(path: String) r: Void {
    DeleteFile(path)
}

fun ExecuteProgram(path: String) r: Int { return __ExecuteProgram(path) }
fun DeleteFile(path: String) r: Bool { return __DeleteFile(path) }
fun getTimestamp() r: String { return __GetTimestamp() }
