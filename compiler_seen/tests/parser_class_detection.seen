import bootstrap.frontend.{run_frontend}
import lexer.{SeenLexer, LexerError}
import parser.real_parser.{RealParser, ProgramNode}
import typechecker.interfaces.{TypeChecker, TypeError}
import macro.expander.{MacroExpander, MacroExpansionResult}

fun main() r: Int {
    let source = "class Foo { fun value() r: Int { return 42 } }"

    let result = run_frontend(source, "parser_class_detection", "en")
    if not result.success {
        println("frontend failed unexpectedly")
        for diag in result.diagnostics {
            println("{diag.severity}: {diag.message}")
        }
        return 1
    }

    let ast = result.program

    if ast.items.length() == 0 {
        println("parser failed to produce any items")
        return 2
    }

    let classItem = ast.items[0]
    if classItem.itemType != "Class" {
        println("expected first item to be a class, found {classItem.itemType}")
        return 3
    }
    if classItem.name != "Foo" {
        println("expected class name Foo, found {classItem.name}")
        return 4
    }

    return 0
}
