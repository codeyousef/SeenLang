import bootstrap.frontend.{run_frontend}
import lexer.{SeenLexer, LexerError}
import parser.real_parser.{RealParser, ProgramNode}
import typechecker.interfaces.{TypeChecker, TypeError}
import macro.expander.{MacroExpander, MacroExpansionResult}

fun main() r: Int {
    let result = run_frontend("fun demo() r: Int { return 10 }", "inline_demo", "en")
    if not result.success {
        return 1
    }
    if result.program.items.length() == 0 {
        return 2
    }
    let firstItem = result.program.items[0]
    if firstItem.itemType != "Function" or firstItem.name != "demo" {
        return 3
    }
    return 0
}
