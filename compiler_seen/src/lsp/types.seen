    action.diagnostics = Array<Diagnostic>()
    action.edit = null
    return action
}

// ============================================================================
// Initialize Request/Response Types
// ============================================================================

class ClientCapabilities {
    // Simplified - we'll expand as needed
    var supportsWorkspaceFolders: Bool
    var supportsDiagnosticRelatedInformation: Bool
}

// Free function (formerly static method on ClientCapabilities)

fun ClientCapabilities_fromJson(json: JsonValue) r: ClientCapabilities {
    let caps = ClientCapabilities()
    caps.supportsWorkspaceFolders = false
    caps.supportsDiagnosticRelatedInformation = false
    // Parse capabilities as needed
    return caps
}

class InitializeParams {
    var processId: Int
    var rootUri: String
    var capabilities: ClientCapabilities
}

// Free function (formerly static method on InitializeParams)

fun InitializeParams_fromJson(json: JsonValue) r: InitializeParams? {
    if json.isObject() {
        // fall through
    } else {
        return null
    }
    let params = InitializeParams()

    let pidVal = json.get("processId")
    if pidVal != null {
        let pidJsonVal = pidVal.unwrap()
        if pidJsonVal.isNull() {
            params.processId = -1
        } else {
            params.processId = pidJsonVal.getInt()
        }
    } else {
        params.processId = -1
    }

    let rootVal = json.get("rootUri")
    if rootVal != null {
        let rootJsonVal = rootVal.unwrap()
        if rootJsonVal.isNull() {
            params.rootUri = ""
        } else {
            params.rootUri = rootJsonVal.getString()
        }
    } else {
        params.rootUri = ""
    }

    let capsVal = json.get("capabilities")
    if capsVal != null {
        let capsJsonVal = capsVal.unwrap()
        params.capabilities = ClientCapabilities_fromJson(capsJsonVal)
    } else {
        params.capabilities = ClientCapabilities()
        params.capabilities.supportsWorkspaceFolders = false
        params.capabilities.supportsDiagnosticRelatedInformation = false
    }

    return params
}

class ServerCapabilities {
    fun toJson() r: JsonValue {
        let caps = JsonValue_emptyObject()

        // Text document sync - full document sync
        caps.set("textDocumentSync", JsonValue_number(1))

        // Completion support
        let completion = JsonValue_emptyObject()
        completion.set("resolveProvider", JsonValue_bool(false))
        let triggerItems = Array<JsonValue>()
        triggerItems.push(JsonValue_string("."))
        triggerItems.push(JsonValue_string(":"))
        let triggers = JsonValue_array(triggerItems)
        completion.set("triggerCharacters", triggers)
        caps.set("completionProvider", completion)

        // Hover support
        caps.set("hoverProvider", JsonValue_bool(true))

        // Go to definition
        caps.set("definitionProvider", JsonValue_bool(true))

        // Find references
        caps.set("referencesProvider", JsonValue_bool(true))

        // Document symbols
        caps.set("documentSymbolProvider", JsonValue_bool(true))

        // Code actions
        let codeAction = JsonValue_emptyObject()
        let kindItems = Array<JsonValue>()
        kindItems.push(JsonValue_string("quickfix"))
        kindItems.push(JsonValue_string("refactor"))
        let kinds = JsonValue_array(kindItems)
        codeAction.set("codeActionKinds", kinds)
        caps.set("codeActionProvider", codeAction)

        // Document formatting
        caps.set("documentFormattingProvider", JsonValue_bool(true))

        // Rename
        caps.set("renameProvider", JsonValue_bool(true))

        return caps
    }
}

