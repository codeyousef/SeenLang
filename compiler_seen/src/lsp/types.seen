class PublishDiagnosticsParams {
    var uri: String
    var diagnostics: Array<Diagnostic>

    fun toJson() r: JsonValue {
        let obj = JsonValue_emptyObject()
        obj.set("uri", JsonValue_string(this.uri))
        let diagsArrElems = Array<JsonValue>()
        var i = 0
        while i < this.diagnostics.length() {
            diagsArrElems.push(this.diagnostics[i].toJson())
            i = i + 1
        }
        let diagsArr = JsonValue_array(diagsArrElems)
        obj.set("diagnostics", diagsArr)
        return obj
    }
}

// Free function (formerly static method on PublishDiagnosticsParams)

fun PublishDiagnosticsParams_new(uri: String, diagnostics: Array<Diagnostic>) r: PublishDiagnosticsParams {
    let params = PublishDiagnosticsParams()
    params.uri = uri
    params.diagnostics = diagnostics
    return params
}
