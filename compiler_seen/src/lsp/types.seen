class CodeActionParams {
    var textDocument: TextDocumentIdentifier
    var range: Range
    var context: CodeActionContext
}

// Free function (formerly static method on CodeActionParams)

fun CodeActionParams_fromJson(json: JsonValue) r: CodeActionParams? {
    if json.isObject() {
        // fall through
    } else {
        return null
    }
    let tdVal = json.get("textDocument")
    let rangeVal = json.get("range")
    let ctxVal = json.get("context")
    if tdVal == null or rangeVal == null {
        return null
    }
    let id = TextDocumentIdentifier_fromJson(tdVal.unwrap())
    let range = Range_fromJson(rangeVal.unwrap())
    if id == null or range == null {
        return null
    }
    let params = CodeActionParams()
    params.textDocument = id.unwrap()
    params.range = range.unwrap()
    if ctxVal != null {
        params.context = CodeActionContext_fromJson(ctxVal.unwrap())
    } else {
        params.context = CodeActionContext()
        params.context.diagnostics = Array<Diagnostic>()
    }
    return params
}

