// LSP Protocol Types
// Defines all the types needed for Language Server Protocol communication

import json.value.{JsonValue, JsonValue_emptyObject, JsonValue_string, JsonValue_number, JsonValue_bool, JsonValue_emptyArray, JsonValue_array, JsonValue_nullValue}
import json.parser.{parseJson}
import json.builder.{jsonToString}

// ============================================================================
// Core LspPosition Types
// ============================================================================

// LspPosition in a text document (zero-based line and character)
class LspPosition {
    var line: Int
    var character: Int

    fun toJson() r: JsonValue {
        let obj = JsonValue_emptyObject()
        obj.set("line", JsonValue_number(this.line))
        obj.set("character", JsonValue_number(this.character))
        return obj
    }
}

// Free functions (formerly static methods on LspPosition)

fun LspPosition_new(line: Int, character: Int) r: LspPosition {
    let pos = LspPosition()
    pos.line = line
    pos.character = character
    return pos
}

fun LspPosition_fromJson(json: JsonValue) r: LspPosition? {
    if json.isObject() {
        // fall through
    } else {
        return null
    }
    let lineVal = json.get("line")
    let charVal = json.get("character")
    if lineVal == null or charVal == null {
        return null
    }
    let lineJsonVal = lineVal.unwrap()
    let charJsonVal = charVal.unwrap()
    return LspPosition_new(lineJsonVal.getInt(), charJsonVal.getInt())
}

// Range in a text document
class Range {
    var start: LspPosition
    var end: LspPosition

    fun toJson() r: JsonValue {
        let obj = JsonValue_emptyObject()
        obj.set("start", this.start.toJson())
        obj.set("end", this.end.toJson())
        return obj
    }
}

// Free functions (formerly static methods on Range)

fun Range_new(start: LspPosition, end: LspPosition) r: Range {
    let range = Range()
    range.start = start
    range.end = end
    return range
}

fun Range_fromJson(json: JsonValue) r: Range? {
    if json.isObject() {
        // fall through
    } else {
        return null
    }
    let startVal = json.get("start")
    let endVal = json.get("end")
    if startVal == null or endVal == null {
        return null
    }
    let start = LspPosition_fromJson(startVal.unwrap())
    let end = LspPosition_fromJson(endVal.unwrap())
    if start == null or end == null {
        return null
    }
    return Range_new(start.unwrap(), end.unwrap())
}

// Location in a document
class Location {
    var uri: String
    var range: Range

    fun toJson() r: JsonValue {
        let obj = JsonValue_emptyObject()
        obj.set("uri", JsonValue_string(this.uri))
        obj.set("range", this.range.toJson())
        return obj
    }
}

// Free function (formerly static method on Location)

fun Location_new(uri: String, range: Range) r: Location {
    let loc = Location()
    loc.uri = uri
    loc.range = range
    return loc
}

