class DidOpenTextDocumentParams {
    var textDocument: TextDocumentItem
}

// Free function (formerly static method on DidOpenTextDocumentParams)

fun DidOpenTextDocumentParams_fromJson(json: JsonValue) r: DidOpenTextDocumentParams? {
    if json.isObject() {
        // fall through
    } else {
        return null
    }
    let tdVal = json.get("textDocument")
    if tdVal == null {
        return null
    }
    let tdJsonVal = tdVal.unwrap()
    let item = TextDocumentItem_fromJson(tdJsonVal)
    if item == null {
        return null
    }
    let params = DidOpenTextDocumentParams()
    params.textDocument = item.unwrap()
    return params
}

class DidChangeTextDocumentParams {
    var textDocument: VersionedTextDocumentIdentifier
    var contentChanges: Array<TextDocumentContentChangeEvent>
}

// Free function (formerly static method on DidChangeTextDocumentParams)

fun DidChangeTextDocumentParams_fromJson(json: JsonValue) r: DidChangeTextDocumentParams? {
    if json.isObject() {
        // fall through
    } else {
        return null
    }
    let tdVal = json.get("textDocument")
    let changesVal = json.get("contentChanges")
    if tdVal == null or changesVal == null {
        return null
    }
    let tdJsonVal = tdVal.unwrap()
    let versioned = VersionedTextDocumentIdentifier_fromJson(tdJsonVal)
    if versioned == null {
        return null
    }
    let params = DidChangeTextDocumentParams()
    params.textDocument = versioned.unwrap()
    params.contentChanges = Array<TextDocumentContentChangeEvent>()

    let changesJsonVal = changesVal.unwrap()
    if changesJsonVal.isArray() {
        let arr = changesJsonVal.getArray()
        var i = 0
        while i < arr.length() {
            let change = TextDocumentContentChangeEvent_fromJson(arr[i])
            if change != null {
                params.contentChanges.push(change.unwrap())
            }
            i = i + 1
        }
    }
    return params
}

