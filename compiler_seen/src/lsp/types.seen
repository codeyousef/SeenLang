class Hover {
    var contents: MarkupContent
    var range: Range?

    fun toJson() r: JsonValue {
        let obj = JsonValue_emptyObject()
        obj.set("contents", this.contents.toJson())
        if this.range != null {
            let rangeVal = this.range.unwrap()
            obj.set("range", rangeVal.toJson())
        }
        return obj
    }
}

// Free function (formerly static method on Hover)

fun Hover_new(contents: MarkupContent) r: Hover {
    let hover = Hover()
    hover.contents = contents
    hover.range = null
    return hover
}

