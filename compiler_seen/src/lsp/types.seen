    let event = TextDocumentContentChangeEvent()
    let textJsonVal = textVal.unwrap()
    event.text = textJsonVal.getString()
    return event
}

// ============================================================================
// Diagnostic Types
// ============================================================================

// Diagnostic severity constants
let DIAGNOSTIC_ERROR = 1
let DIAGNOSTIC_WARNING = 2
let DIAGNOSTIC_INFORMATION = 3
let DIAGNOSTIC_HINT = 4

class Diagnostic {
    var range: Range
    var severity: Int
    var code: String
    var source: String
    var message: String

    fun toJson() r: JsonValue {
        let obj = JsonValue_emptyObject()
        obj.set("range", this.range.toJson())
        obj.set("severity", JsonValue_number(this.severity))
        obj.set("source", JsonValue_string(this.source))
        obj.set("message", JsonValue_string(this.message))
        if this.code.length() > 0 {
            obj.set("code", JsonValue_string(this.code))
        }
        return obj
    }
}

// Free function (formerly static method on Diagnostic)

fun Diagnostic_new(range: Range, severity: Int, message: String) r: Diagnostic {
    let diag = Diagnostic()
    diag.range = range
    diag.severity = severity
    diag.code = ""
    diag.source = "seen"
    diag.message = message
    return diag
}

// ============================================================================
// Completion Types
// ============================================================================

// Completion item kinds
let COMPLETION_TEXT = 1
let COMPLETION_METHOD = 2
let COMPLETION_FUNCTION = 3
let COMPLETION_CONSTRUCTOR = 4
let COMPLETION_FIELD = 5
let COMPLETION_VARIABLE = 6
let COMPLETION_CLASS = 7
let COMPLETION_INTERFACE = 8
let COMPLETION_MODULE = 9
let COMPLETION_PROPERTY = 10
let COMPLETION_UNIT = 11
let COMPLETION_VALUE = 12
let COMPLETION_ENUM = 13
let COMPLETION_KEYWORD = 14
let COMPLETION_SNIPPET = 15
let COMPLETION_COLOR = 16
let COMPLETION_FILE = 17
let COMPLETION_REFERENCE = 18
let COMPLETION_FOLDER = 19
let COMPLETION_ENUM_MEMBER = 20
let COMPLETION_CONSTANT = 21
let COMPLETION_STRUCT = 22
let COMPLETION_EVENT = 23
let COMPLETION_OPERATOR = 24
let COMPLETION_TYPE_PARAMETER = 25

class CompletionItem {
    var label: String
    var kind: Int
    var detail: String
    var documentation: String
    var insertText: String
    var insertTextFormat: Int  // 1 = PlainText, 2 = Snippet

    fun toJson() r: JsonValue {
        let obj = JsonValue_emptyObject()
        obj.set("label", JsonValue_string(this.label))
        obj.set("kind", JsonValue_number(this.kind))
        if this.detail.length() > 0 {
            obj.set("detail", JsonValue_string(this.detail))
        }
        if this.documentation.length() > 0 {
            let docContent = JsonValue_emptyObject()
            docContent.set("kind", JsonValue_string("markdown"))
            docContent.set("value", JsonValue_string(this.documentation))
            obj.set("documentation", docContent)
        }
        if this.insertText.length() > 0 {
            obj.set("insertText", JsonValue_string(this.insertText))
            obj.set("insertTextFormat", JsonValue_number(this.insertTextFormat))
        }
        return obj
    }
}

// Free function (formerly static method on CompletionItem)

fun CompletionItem_new(label: String, kind: Int) r: CompletionItem {
    let item = CompletionItem()
    item.label = label
    item.kind = kind
    item.detail = ""
    item.documentation = ""
    item.insertText = ""
    item.insertTextFormat = 1
    return item
}

class CompletionList {
    var isIncomplete: Bool
    var items: Array<CompletionItem>

    fun toJson() r: JsonValue {
        let obj = JsonValue_emptyObject()
        obj.set("isIncomplete", JsonValue_bool(this.isIncomplete))
        let itemsArrElems = Array<JsonValue>()
        var i = 0
        while i < this.items.length() {
            itemsArrElems.push(this.items[i].toJson())
            i = i + 1
        }
        let itemsArr = JsonValue_array(itemsArrElems)
        obj.set("items", itemsArr)
        return obj
    }
}

// Free function (formerly static method on CompletionList)

fun CompletionList_new(items: Array<CompletionItem>) r: CompletionList {
    let list = CompletionList()
    list.isIncomplete = false
    list.items = items
    return list
}

