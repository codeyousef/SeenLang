class TextDocumentItem {
    var uri: String
    var languageId: String
    var version: Int
    var text: String
}

// Free function (formerly static method on TextDocumentItem)

fun TextDocumentItem_fromJson(json: JsonValue) r: TextDocumentItem? {
    if json.isObject() {
        // fall through
    } else {
        return null
    }
    let uriVal = json.get("uri")
    let langVal = json.get("languageId")
    let versionVal = json.get("version")
    let textVal = json.get("text")
    if uriVal == null or langVal == null or versionVal == null or textVal == null {
        return null
    }
    let item = TextDocumentItem()
    let uriJsonVal = uriVal.unwrap()
    let langJsonVal = langVal.unwrap()
    let versionJsonVal = versionVal.unwrap()
    let textJsonVal = textVal.unwrap()
    item.uri = uriJsonVal.getString()
    item.languageId = langJsonVal.getString()
    item.version = versionJsonVal.getInt()
    item.text = textJsonVal.getString()
    return item
}

