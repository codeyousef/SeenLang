// Utility functions for tests
fun createIRGenerator() -> IRGenerator {
    return IRGenerator.new()
}

fun createIRModule(name: String) -> IRModule {
    return IRModule.new(name)
}

fun createIRBuilder() -> IRBuilder {
    return IRBuilder.new()
}
