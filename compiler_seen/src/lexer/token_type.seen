enum SeenTokenType {
    IntegerLiteral,
    FloatLiteral,
    StringLiteral,
    BooleanLiteral,
    KeywordFalse,
    Identifier,
    KeywordFun,
    KeywordLet,
    KeywordVar,
    KeywordIf,
    KeywordElse,
    KeywordWhile,
    KeywordFor,
    KeywordIn,
    KeywordReturn,
    KeywordBreak,
    KeywordContinue,
    KeywordClass,
    KeywordInterface,
    KeywordEnum,
    KeywordExtends,
    KeywordImplements,
    KeywordAsync,
    KeywordAwait,
    KeywordSpawn,
    KeywordMatch,
    KeywordTry,
    KeywordCatch,
    KeywordFinally,
    KeywordThrow,
    KeywordImport,
    KeywordUse,
    KeywordExport,
    KeywordAs,
    KeywordIs,
    KeywordNull,
    KeywordTrue,
    KeywordThis,
    KeywordSuper,
    KeywordMove,
    KeywordBorrow,
    Plus,
    Minus,
    Multiply,
    Divide,
    Modulo,
    Equal,
    PlusEqual,
    MinusEqual,
    MultiplyEqual,
    DivideEqual,
    EqualEqual,
    NotEqual,
    LessThan,
    LessEqual,
    GreaterThan,
    GreaterEqual,
    LogicalAnd,
    LogicalOr,
    LogicalNot,
    SafeNavigation,
    Elvis,
    Question,
    LeftParen,
    RightParen,
    LeftBrace,
    RightBrace,
    LeftBracket,
    RightBracket,
    Comma,
    Semicolon,
    Colon,
    Dot,
    Arrow,
    InterpolatedStringStart,
    InterpolatedStringMiddle,
    InterpolatedStringEnd,
    Newline,
    Whitespace,
    Comment,
    Error,
    EndOfFile,
    None
}

fun getLeftParenType() r: SeenTokenType {
    return SeenTokenType.LeftParen
}

fun getRightParenType() r: SeenTokenType {
    return SeenTokenType.RightParen
}

fun getSemicolonType() r: SeenTokenType {
    return SeenTokenType.Semicolon
}

fun getDotType() r: SeenTokenType {
    return SeenTokenType.Dot
}

fun getLeftBraceType() r: SeenTokenType {
    return SeenTokenType.LeftBrace
}

fun getKeywordAsType() r: SeenTokenType {
    return SeenTokenType.KeywordAs
}

fun getIdentifierType() r: SeenTokenType {
    return SeenTokenType.Identifier
}

fun getColonType() r: SeenTokenType {
    return SeenTokenType.Colon
}

fun getRightBraceType() r: SeenTokenType {
    return SeenTokenType.RightBrace
}

fun getCommaType() r: SeenTokenType {
    return SeenTokenType.Comma
}

fun getEndOfFileType() r: SeenTokenType {
    return SeenTokenType.EndOfFile
}
