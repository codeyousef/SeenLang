        keywords.put("التقاط", SeenTokenType.KeywordCatch)    // catch
        keywords.put("أخيرا", SeenTokenType.KeywordFinally)   // finally
        keywords.put("رمي", SeenTokenType.KeywordThrow)       // throw
        keywords.put("استيراد", SeenTokenType.KeywordImport)   // import
        keywords.put("تصدير", SeenTokenType.KeywordExport)    // export
        keywords.put("كـ", SeenTokenType.KeywordAs)           // as
        keywords.put("هو", SeenTokenType.KeywordIs)          // is
        keywords.put("فارغ", SeenTokenType.KeywordNull)       // null
        keywords.put("صحيح", SeenTokenType.KeywordTrue)       // true
        keywords.put("خاطئ", SeenTokenType.KeywordFalse)      // false
