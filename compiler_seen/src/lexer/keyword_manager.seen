    fun getEnglishKeywordType(keyword: String) r: SeenTokenType? {
        // Helper to get English keyword type for translation checking
        let englishKeywords = Map<String, SeenTokenType>.new()
        englishKeywords.put("fun", SeenTokenType.KeywordFun)
        englishKeywords.put("let", SeenTokenType.KeywordLet)
        englishKeywords.put("var", SeenTokenType.KeywordVar)
        englishKeywords.put("if", SeenTokenType.KeywordIf)
        englishKeywords.put("else", SeenTokenType.KeywordElse)
        englishKeywords.put("and", SeenTokenType.LogicalAnd)
        englishKeywords.put("or", SeenTokenType.LogicalOr)
        englishKeywords.put("not", SeenTokenType.LogicalNot)
        
        return englishKeywords.get(keyword)
    }
}