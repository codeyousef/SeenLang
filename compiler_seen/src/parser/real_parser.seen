// =============================================================================
// Stage 2: Recursive-Descent Parser for the Seen Programming Language
// =============================================================================
//
// Input:  Array<Token> produced by the lexer (Stage 1).
// Output: ProgramNode AST consumed by the type-checker (Stage 3) and codegen.
//
// The parser is a single-pass, recursive-descent design.  All AST nodes are
// allocated eagerly as the token stream is consumed; there is no separate
// declaration-collection pass inside this file (the two-pass strategy lives
// in the IR generator, which walks the finished AST twice).
//
// Key AST node types emitted:
//   ProgramNode           -- root; holds an Array<ItemNode>
//   ItemNode              -- top-level declaration (Function, Class, Enum, Import, GlobalVar)
//   FunctionNode          -- function/method with params, return type, body
//   ClassNode             -- class/struct/trait/union with fields and methods
//   StatementNode         -- control flow (If, While, For, Return, Let, Var, ...)
//   ParserExpressionNode  -- expressions (Binary, Call, MemberAccess, Literal, ...)
//
// Operator precedence is implemented via a Pratt-style chain of mutually
// recursive functions:
//   parseExpression -> parseAssignment -> parseOr -> parseAnd -> parseElvis
//   -> parseEquality -> parseComparison -> parseRange -> parseTerm
//   -> parseFactor -> parseShift -> parseBitwise -> parseUnary -> parseCall
//   -> parsePrimary
//
// Multi-language keyword support is achieved by comparing against the
// SeenTokenType enum (populated from TOML keyword files by the lexer),
// never by raw string matching on token values.
//
// IMPORTANT — bootstrap compatibility constraint:
//   checkToken(SeenTokenType.X) is used everywhere instead of calling
//   .getTokenType() on tokens.  The latter triggers a cross-module codegen
//   issue where the returned SeenTokenType enum value is miscompiled.
// =============================================================================

import lexer.interfaces.{Token, Position}
import lexer.token_type.{SeenTokenType, SeenTokenType2, TestEnum, getA, getLeftParenType, getLeftParenType2, getRightParenType, getSemicolonType, getDotType, getLeftBraceType, getKeywordAsType, getIdentifierType, getColonType, getRightBraceType, getCommaType, getEndOfFileType, getKeywordFunType, getKeywordImportType, getKeywordUseType, getKeywordClassType, getAtType}
import core.option.{Option}
import trace.{traceParse, isParserTracingEnabled}

extern fun __Print(s: String)
extern fun __PrintInt(n: Int)



// Minimal AST scaffolding local to the parser
class ProgramNode {
    var items: Array<ItemNode>
    static fun new() r: ProgramNode {
        return ProgramNode{ items: Array<ItemNode>() }
    }
}

class EnumNode {
    var name: String
    var variants: Array<String>

    static fun new() r: EnumNode {
        return EnumNode{ name: "", variants: Array<String>() }
    }
}

// Annotation/Decorator node for @deterministic, @nondeterministic, @extern, etc.
class AnnotationNode {
    var name: String
    var arguments: Array<String>

    static fun new(name: String) r: AnnotationNode {
        return AnnotationNode{ name: name, arguments: Array<String>() }
    }

    fun addArgument(arg: String) r: Void {
        arguments.push(arg)
    }
}

class ItemNode {
    var itemType: String
    var name: String
    var visibility: String
    var importPath: Array<String>
    var importSymbols: Array<ImportSymbolNode>
    var function: FunctionNode
    var classNode: ClassNode
    var enumNode: EnumNode

    static fun new() r: ItemNode {
        return ItemNode{
            itemType: "",
            name: "",
            visibility: "private",
            importPath: Array<String>(),
            importSymbols: Array<ImportSymbolNode>(),
            function: FunctionNode.new(),
            classNode: ClassNode.new(),
            enumNode: EnumNode.new()
        }
    }
}

class ImportSymbolNode {
    var name: String
    var alias: String

    static fun new() r: ImportSymbolNode {
        return ImportSymbolNode{ name: "", alias: "" }
    }
}

class FunctionNode {
    var name: String
    var params: Array<ParamNode>
    var returnType: TypeNode
    var body: BlockNode
    var isAsync: Bool
    var isInline: Bool
    var isStatic: Bool
    var isExtern: Bool
    // Determinism annotations for UWW compatibility
    var isDeterministic: Bool      // @deterministic - function produces same output for same input
    var isNondeterministic: Bool   // @nondeterministic - function uses I/O, random, time, etc.
    var decorators: Array<AnnotationNode>
    // Position tracking for error messages
    var line: Int
    var column: Int
    var isOverride: Bool

    static fun new() r: FunctionNode {
        return FunctionNode{
            name: "",
            params: Array<ParamNode>(),
            returnType: TypeNode.new(),
            body: BlockNode.new(),
            isAsync: false,
            isInline: false,
            isStatic: false,
            isExtern: false,
            isDeterministic: false,
            isNondeterministic: false,
            decorators: Array<AnnotationNode>(),
            line: 0,
            column: 0,
            isOverride: false
        }
    }

    fun hasDecorator(name: String) r: Bool {
        var i = 0
        while i < decorators.length() {
            if decorators[i].name == name {
                return true
            }
            i = i + 1
        }
        return false
    }
}

class ParamNode {
    var name: String
    var paramType: TypeNode
    var isMutable: Bool

    static fun new() r: ParamNode {
        return ParamNode{ name: "", paramType: TypeNode.new(), isMutable: false }
    }
}

data TypeNode { typeName: String; isNullable: Bool }
fun TypeNode.new() r: TypeNode { return TypeNode{ typeName: "Unknown", isNullable: false } }

class BlockNode {
    var statements: Array<StatementNode>

    static fun new() r: BlockNode {
        let block = BlockNode{ statements: Array<StatementNode>() }
        return block
    }
}

class StatementNode {
    var kind: String
    // Let
    var variableName: String
    var variableType: TypeNode
    var initializer: ParserExpressionNode
    // Return
    var returnValue: ParserExpressionNode
    // Expression
    var expression: ParserExpressionNode
    // If
    var condition: ParserExpressionNode
    var thenBranch: BlockNode
    var elseBranch: BlockNode
    // While
    var loopCondition: ParserExpressionNode
    var loopBody: BlockNode

    fun new() r: StatementNode {
        return StatementNode{
            kind: "",
            variableName: "",
            variableType: TypeNode.new(),
            initializer: ParserExpressionNode.new(),
            returnValue: ParserExpressionNode.new(),
            expression: ParserExpressionNode.new(),
            condition: ParserExpressionNode.new(),
            thenBranch: BlockNode.new(),
            elseBranch: BlockNode.new(),
            loopCondition: ParserExpressionNode.new(),
            loopBody: BlockNode.new()
        }
    }
}

class ParserExpressionNode {
    var kind: String
    // Binary - use operands array: [0]=left, [1]=right (avoids Option corruption issue)
    var operands: Array<ParserExpressionNode>
    var operator: String
    // Literal
    var literalValue: String
    var literalType: String
    // Variable
    var variableName: String
    // Call
    var callee: String
    var arguments: Array<ParserExpressionNode>
    // Index access: obj[index] - object is variableName, index in operands[0]
    // Member access: obj.field - object is variableName, member is callee

    static fun new() r: ParserExpressionNode {
        return ParserExpressionNode{
            kind: "None",
            operands: Array<ParserExpressionNode>(),
            operator: "",
            literalValue: "",
            literalType: "",
            variableName: "",
            callee: "",
            arguments: Array<ParserExpressionNode>()
        }
    }
}

class ClassNode {
    var name: String
    var fields: Array<ParamNode>
    var methods: Array<FunctionNode>
    // Decorator/annotation support for determinism checking
    var decorators: Array<AnnotationNode>
    var isNondeterministic: Bool  // @nondeterministic - class uses nondeterministic types
    var parentName: String        // empty = no parent; set by 'extends ParentClass' clause

    static fun new() r: ClassNode {
        return ClassNode{
            name: "",
            fields: Array<ParamNode>(),
            methods: Array<FunctionNode>(),
            decorators: Array<AnnotationNode>(),
            isNondeterministic: false,
            parentName: ""
        }
    }

    fun hasDecorator(name: String) r: Bool {
        var i = 0
        while i < decorators.length() {
            if decorators[i].name == name {
                return true
            }
            i = i + 1
        }
        return false
    }
}
data ImportPathInfo { text: String; segments: Array<String> }
// Use the canonical Token from lexer.interfaces for type consistency

// Recursive-descent parser that converts a flat token stream into a ProgramNode AST.
//
// Key fields:
//   tokens             -- immutable input token array from the lexer
//   current            -- cursor index into `tokens`; advanced by advance()/matchTokenStr()
//   currentProgram     -- accumulates top-level ItemNode declarations during parse()
//   currentBlock       -- the innermost BlockNode being filled; saved/restored on nesting
//   lastStatement      -- scratch StatementNode written to by the *Field() helpers, then
//                         pushed into currentBlock (avoids returning large structs by value,
//                         which triggers memory corruption in the stage1 bootstrap compiler)
//   lastFunction       -- same workaround for FunctionNode
//   pendingDecorators  -- decorators (@name) collected before the next declaration
class RealParser {
    var tokens: Array<Token>
    var current: Int
    var currentProgram: ProgramNode
    var currentBlock: BlockNode
    var lastStatement: StatementNode
    var lastParsedBlock: BlockNode
    var lastFunction: FunctionNode
    var pendingDecorators: Array<AnnotationNode>
    var pendingSealedModifier: Int
    var blockStack: Array<BlockNode>
    var statementStack: Array<StatementNode>
    var blockStackDepth: Int
    var lastParsedTypeName: String
    var lastParsedTypeNullable: Bool
    var pendingFunctionReturnTypeName: String
    var pendingFunctionReturnTypeNullable: Bool
    var pendingFunctionParamTypeNames: Array<String>
    var pendingFunctionParamTypeNullables: Array<Int>

    static fun tokenStartsEffectModifier(rawTokens: Array<Token>, index: Int) r: Bool {
        if index < 0 or index >= rawTokens.length() {
            return false
        }
        let tok = rawTokens[index]
        if tok.getValue() != "effect" {
            return false
        }
        if index + 1 >= rawTokens.length() {
            return false
        }
        return rawTokens[index + 1].getValue() == "("
    }

    static fun rewriteEffectTokens(rawTokens: Array<Token>) r: Array<Token> {
        let rewritten = Array<Token>()
        var i = 0
        while i < rawTokens.length() {
            let tok = rawTokens[i]
            // Do not inspect token enum values here: bootstrap can miscompile
            // cross-module SeenTokenType reads from Token objects.
            if RealParser.tokenStartsEffectModifier(rawTokens, i) {
                rewritten.push(Token.new(getAtType(), "@", tok.getLine(), tok.getColumn(), 1, tok.getFileId()))
                rewritten.push(Token.new(SeenTokenType.Identifier, "using", tok.getLine(), tok.getColumn(), 5, tok.getFileId()))
            } else {
                rewritten.push(tok)
            }
            i = i + 1
        }
        return rewritten
    }

    // ========== UTILITY METHODS (moved to top to ensure Stage1 generates them) ==========

    fun matchTokenStr(tokenType: SeenTokenType) r: Bool {
        if checkToken(tokenType) {
            advance()
            return true
        }
        return false
    }

    // Seen keeps several declaration keywords contextual so existing code can
    // still use names like `data`, `type`, `module`, and `operator` in places
    // where an identifier is expected.
    fun isContextualIdentifierTokenType(tokenTypeStr: String) r: Bool {
        if tokenTypeStr == SeenTokenType.KeywordData.toString() { return true }
        if tokenTypeStr == SeenTokenType.KeywordType.toString() { return true }
        if tokenTypeStr == SeenTokenType.KeywordModule.toString() { return true }
        if tokenTypeStr == SeenTokenType.KeywordOperator.toString() { return true }
        if tokenTypeStr == SeenTokenType.KeywordInline.toString() { return true }
        if tokenTypeStr == SeenTokenType.KeywordGpu.toString() { return true }
        if tokenTypeStr == SeenTokenType.KeywordRegion.toString() { return true }
        if tokenTypeStr == SeenTokenType.KeywordBorrow.toString() { return true }
        if tokenTypeStr == SeenTokenType.KeywordMove.toString() { return true }
        if tokenTypeStr == SeenTokenType.KeywordRef.toString() { return true }
        if tokenTypeStr == SeenTokenType.KeywordOwn.toString() { return true }
        if tokenTypeStr == SeenTokenType.KeywordStruct.toString() { return true }
        if tokenTypeStr == SeenTokenType.KeywordTrait.toString() { return true }
        if tokenTypeStr == SeenTokenType.KeywordUnion.toString() { return true }
        if tokenTypeStr == SeenTokenType.KeywordDistinct.toString() { return true }
        if tokenTypeStr == SeenTokenType.KeywordImpl.toString() { return true }
        if tokenTypeStr == SeenTokenType.KeywordExtension.toString() { return true }
        if tokenTypeStr == SeenTokenType.KeywordSealed.toString() { return true }
        if tokenTypeStr == SeenTokenType.KeywordStatic.toString() { return true }
        if tokenTypeStr == SeenTokenType.KeywordOverride.toString() { return true }
        if tokenTypeStr == SeenTokenType.KeywordPub.toString() { return true }
        if tokenTypeStr == SeenTokenType.KeywordComptime.toString() { return true }
        return false
    }

    fun isIdentifierLikeTokenValue(tokenValue: String) r: Bool {
        if tokenValue == "" {
            return false
        }
        let firstByte = tokenValue.byteAt(0)
        if firstByte >= 48 and firstByte <= 57 { return false }
        if firstByte == 34 or firstByte == 39 { return false }
        if firstByte == 40 or firstByte == 41 { return false }
        if firstByte == 44 or firstByte == 46 or firstByte == 58 or firstByte == 59 { return false }
        if firstByte == 60 or firstByte == 61 or firstByte == 62 or firstByte == 63 { return false }
        if firstByte == 64 { return false }
        if firstByte == 91 or firstByte == 93 { return false }
        if firstByte == 123 or firstByte == 125 { return false }
        if firstByte == 43 or firstByte == 45 or firstByte == 42 or firstByte == 47 { return false }
        if firstByte == 33 or firstByte == 37 or firstByte == 38 or firstByte == 124 or firstByte == 94 or firstByte == 126 { 
            return false 
        }
        return true
    }

    fun checkNameLikeToken() r: Bool {
        if isAtEnd() {
            return false
        }
        return isIdentifierLikeTokenValue(peek().getValue())
    }

    fun consumeNameLike(message: String) r: Token {
        if checkNameLikeToken() {
            return advance()
        }
        return peek()
    }

    fun matchNameValue(expectedName: String) r: Bool {
        if not checkNameLikeToken() {
            return false
        }
        if peek().getValue() == expectedName {
            advance()
            return true
        }
        return false
    }

    fun looksLikeIntegerLiteral(tokenValue: String) r: Bool {
        if tokenValue == "" {
            return false
        }
        let firstByte = tokenValue.byteAt(0)
        return firstByte >= 48 and firstByte <= 57
    }

    fun looksLikeFloatLiteral(tokenValue: String) r: Bool {
        if not looksLikeIntegerLiteral(tokenValue) {
            return false
        }
        return tokenValue.contains(".") or tokenValue.contains("e") or tokenValue.contains("E")
    }

    // Check whether the current token matches the given type WITHOUT advancing.
    //
    // WHY string comparison instead of enum equality:
    //   Calling `.getTokenType()` on a Token and comparing the returned
    //   SeenTokenType directly triggers a cross-module codegen bug in the
    //   stage1 bootstrap compiler (the returned enum i64 gets miscompiled).
    //   Comparing .toString() strings is safe across all compiler versions.
    fun checkToken(tokenType: SeenTokenType) r: Bool {
        if isAtEnd() {
            return false
        }
        let tokTypeStr = peekTokenTypeStr()
        let expectedStr = tokenType.toString()
        if expectedStr == SeenTokenType.Identifier.toString() {
            if tokTypeStr == expectedStr {
                return true
            }
            if isContextualIdentifierTokenType(tokTypeStr) {
                return true
            }
            return isIdentifierLikeTokenValue(peek().getValue())
        }
        return tokTypeStr == expectedStr
    }

    fun advance() r: Token {
        if not isAtEnd() {
            current = current + 1
        }
        return previous()
    }

    fun isAtEnd() r: Bool {
        let len = tokens.length()
        return current >= len - 1
    }

    fun peek() r: Token {
        if current >= tokens.length() {
            return tokens[tokens.length() - 1]
        }
        return tokens[current]
    }

    // Look ahead by offset tokens (0 = current, 1 = next, etc.)
    fun peekAt(offset: Int) r: Token {
        let idx = current + offset
        if idx >= tokens.length() {
            return tokens[tokens.length() - 1]
        }
        return tokens[idx]
    }

    fun peekTokenType() r: SeenTokenType {
        if current >= tokens.length() {
            return tokens[tokens.length() - 1].getType()
        }
        return tokens[current].getType()
    }

    fun peekTokenTypeStr() r: String {
        if current >= tokens.length() {
            return tokens[tokens.length() - 1].getType().toString()
        }
        return tokens[current].getType().toString()
    }

    fun previous() r: Token {
        if current == 0 {
            return tokens[0]
        }
        return tokens[current - 1]
    }

    fun consume(tokenType: SeenTokenType, message: String) r: Token {
        if checkToken(tokenType) {
            return advance()
        }
        return peek()
    }

    fun toArray(raw: List<Token>) r: Array<Token> {
        return Array<Token>()
    }

    fun skipExpression() r: Void {
        while not isAtEnd() {
            let t = peek().getType()
            if t == getCommaType() or t == getRightParenType() or t == getSemicolonType() {
                break
            }
            advance()
        }
    }

    fun joinSegments(values: Array<String>, separator: String) r: String {
        if values.length() == 0 {
            return ""
        }
        var result = values[0]
        var index = 1
        while index < values.length() {
            result = result + separator + values[index]
            index = index + 1
        }
        return result
    }

    // ========== END UTILITY METHODS ==========

    // Main entry point.  Consumes all tokens and returns a ProgramNode whose
    // `items` array contains every top-level declaration (imports, functions,
    // classes, enums, global variables, type aliases, impl blocks, etc.).
    //
    // The loop dispatches on the current token type to the appropriate
    // parseXxxItemInto() helper.  Decorators (@name) are collected into
    // `pendingDecorators` and attached to the next declaration that follows.
    fun parse() r: ProgramNode {
        currentProgram = ProgramNode.new()
        pendingDecorators = Array<AnnotationNode>()
        pendingSealedModifier = 0

        while not isAtEnd() {
            // Use peekTokenTypeStr to avoid creating Token copy that corrupts memory
            let currentTokenTypeStr = peekTokenTypeStr()

            // Handle decorators: @name or @name(args)
            if matchTokenStr(SeenTokenType.AtSymbol) {
                parseDecoratorInto()
                // : Check if last decorator was @cImport — emit as CImport item immediately
                if pendingDecorators.length() > 0 {
                    let lastDec = pendingDecorators[pendingDecorators.length() - 1]
                    if lastDec.name == "cImport" {
                        // Create a function item that acts as a CImport directive
                        let cImportFn = FunctionNode.new()
                        cImportFn.name = "__cImport"
                        let cImportAnn = AnnotationNode.new("cImport")
                        if lastDec.arguments.length() > 0 {
                            cImportAnn.addArgument(lastDec.arguments[0])
                        }
                        cImportFn.decorators.push(cImportAnn)
                        let cImportItem = ItemNode.new()
                        cImportItem.itemType = "Function"
                        cImportItem.name = "__cImport"
                        cImportItem.function = cImportFn
                        currentProgram.items.push(cImportItem)
                        traceParse("push Function __cImport")
                        // Remove the cImport decorator from pending
                        pendingDecorators = Array<AnnotationNode>()
                    }
                }
                continue
            }

            // module declarations: consume 'module x.y.z' silently
            if matchTokenStr(SeenTokenType.KeywordModule) {
                // Consume dotted identifier path (module x.y.z)
                if checkToken(SeenTokenType.Identifier) {
                    advance()
                    while matchTokenStr(SeenTokenType.Dot) {
                        if checkToken(SeenTokenType.Identifier) {
                            advance()
                        }
                    }
                }
                if matchTokenStr(SeenTokenType.Semicolon) { }
                continue
            }

            if matchTokenStr(getKeywordImportType()) {
                parseImportItemInto()
                continue
            }

            if matchTokenStr(getKeywordUseType()) {
                parseImportItemInto()
                continue
            }

            // Consume optional 'pub' modifier
            if matchTokenStr(SeenTokenType.KeywordPub) {
                // Check for 'pub import' — re-export
                if matchTokenStr(getKeywordImportType()) {
                    parseImportItemInto()
                    // Mark last import item as public for re-export
                    if currentProgram.items.length() > 0 {
                        let lastItem = currentProgram.items[currentProgram.items.length() - 1]
                        lastItem.visibility = "public"
                    }
                    continue
                }
                // fall through for other pub declarations
            }

            // Consume optional 'sealed' modifier before class/enum
            if matchTokenStr(SeenTokenType.KeywordSealed) {
                pendingSealedModifier = 1
            }

            if matchTokenStr(SeenTokenType.AtSymbol) {
                parseDecoratorInto()
                if pendingDecorators.length() > 0 {
                    let lastDecAfterSealed = pendingDecorators[pendingDecorators.length() - 1]
                    if lastDecAfterSealed.name == "cImport" {
                        let cImportFnAfterSealed = FunctionNode.new()
                        cImportFnAfterSealed.name = "__cImport"
                        let cImportAnnAfterSealed = AnnotationNode.new("cImport")
                        if lastDecAfterSealed.arguments.length() > 0 {
                            cImportAnnAfterSealed.addArgument(lastDecAfterSealed.arguments[0])
                        }
                        cImportFnAfterSealed.decorators.push(cImportAnnAfterSealed)
                        let cImportItemAfterSealed = ItemNode.new()
                        cImportItemAfterSealed.itemType = "Function"
                        cImportItemAfterSealed.name = "__cImport"
                        cImportItemAfterSealed.function = cImportFnAfterSealed
                        currentProgram.items.push(cImportItemAfterSealed)
                        traceParse("push Function __cImport")
                        pendingDecorators = Array<AnnotationNode>()
                    }
                }
                continue
            }

            if checkToken(SeenTokenType.KeywordEffect) {
                parseEffectModifierInto()
                continue
            }

            // 'type' keyword — type alias: type Foo = Bar<Baz>
            if matchTokenStr(SeenTokenType.KeywordType) {
                if checkToken(SeenTokenType.Identifier) {
                    let typeAliasName = advance().getValue()
                    consume(SeenTokenType.Equal, "Expected '=' in type alias")
                    let typeAliasTarget = parseTypeNode()
                    // Emit as a class with no fields and a @type_alias decorator
                    let typeAliasClass = ClassNode.new()
                    typeAliasClass.name = typeAliasName
                    let typeAliasAnn = AnnotationNode.new("type_alias")
                    typeAliasAnn.addArgument(typeAliasTarget.typeName)
                    typeAliasClass.decorators.push(typeAliasAnn)
                    let typeAliasItem = ItemNode.new()
                    typeAliasItem.itemType = "Class"
                    typeAliasItem.name = typeAliasName
                    typeAliasItem.classNode = typeAliasClass
                    typeAliasItem.visibility = inferVisibility(typeAliasName)
                    currentProgram.items.push(typeAliasItem)
                }
                continue
            }

            // 'distinct' keyword — distinct newtype: distinct Name = Type
            if matchTokenStr(SeenTokenType.KeywordDistinct) {
                if checkToken(SeenTokenType.Identifier) {
                    let distinctName = advance().getValue()
                    consume(SeenTokenType.Equal, "Expected '=' in distinct type")
                    let distinctTarget = parseTypeNode()
                    let distinctClass = ClassNode.new()
                    distinctClass.name = distinctName
                    let distinctAnn = AnnotationNode.new("distinct")
                    distinctAnn.addArgument(distinctTarget.typeName)
                    distinctClass.decorators.push(distinctAnn)
                    // Also add type_alias so LLVM type resolves
                    let distinctAliasAnn = AnnotationNode.new("type_alias")
                    distinctAliasAnn.addArgument(distinctTarget.typeName)
                    distinctClass.decorators.push(distinctAliasAnn)
                    let distinctItem = ItemNode.new()
                    distinctItem.itemType = "Class"
                    distinctItem.name = distinctName
                    distinctItem.classNode = distinctClass
                    distinctItem.visibility = inferVisibility(distinctName)
                    currentProgram.items.push(distinctItem)
                }
                continue
            }

            // 'union' keyword — C-interop union type
            if matchTokenStr(SeenTokenType.KeywordUnion) {
                if checkToken(SeenTokenType.Identifier) {
                    let unionName = advance().getValue()
                    let unionClass = ClassNode.new()
                    unionClass.name = unionName
                    let unionAnn = AnnotationNode.new("union")
                    unionClass.decorators.push(unionAnn)
                    if matchTokenStr(SeenTokenType.LeftBrace) {
                        // Parse fields like a class body
                        while not checkToken(SeenTokenType.RightBrace) and not isAtEnd() {
                            if checkToken(SeenTokenType.Identifier) {
                                let fieldName = advance().getValue()
                                consume(SeenTokenType.Colon, "Expected ':' after union field name")
                                let fieldType = parseTypeNode()
                                let fieldParam = ParamNode.new()
                                fieldParam.name = fieldName
                                fieldParam.paramType = fieldType
                                unionClass.fields.push(fieldParam)
                            }
                            if matchTokenStr(SeenTokenType.Comma) { }
                            if matchTokenStr(SeenTokenType.Semicolon) { }
                        }
                        consume(SeenTokenType.RightBrace, "Expected '}' after union body")
                    }
                    let unionItem = ItemNode.new()
                    unionItem.itemType = "Class"
                    unionItem.name = unionName
                    unionItem.classNode = unionClass
                    unionItem.visibility = inferVisibility(unionName)
                    currentProgram.items.push(unionItem)
                }
                continue
            }

            // Handle 'extern fun' keyword syntax: treat as @extern decorator + fun
            if checkToken(SeenTokenType.Identifier) {
                let peekedVal = peek().getValue()
                if peekedVal == "extern" {
                    advance()
                    let externAnnotation = AnnotationNode.new("extern")
                    pendingDecorators.push(externAnnotation)
                    // Fall through to parse the 'fun' keyword below
                }
            }

            // 'async fun' — push @async decorator and fall through to fun handler
            if checkToken(SeenTokenType.KeywordAsync) {
                let asyncFunPeek = peekAt(1)
                if asyncFunPeek.getType() == getKeywordFunType() {
                    advance()   // consume 'async'
                    let asyncAnn = AnnotationNode.new("async")
                    pendingDecorators.push(asyncAnn)
                    // Fall through — next token is 'fun', matched below
                }
            }

            if matchTokenStr(getKeywordFunType()) {
                parseFunctionItemInto()
                continue
            }

            // 'data struct Name(fields)' — tuple-struct form
            if checkToken(SeenTokenType.KeywordData) {
                let dataStructPeek = peekAt(1)
                if dataStructPeek.getType() == SeenTokenType.KeywordStruct {
                    advance()   // consume 'data'
                    advance()   // consume 'struct'
                    parseDataStructItemInto()
                    continue
                }
            }

            // 'data' alone — also alias for 'class' (legacy usage)
            if matchTokenStr(SeenTokenType.KeywordData) {
                parseClassItemInto()
                continue
            }

            // 'struct' as alias for 'class'
            if matchTokenStr(SeenTokenType.KeywordStruct) {
                parseClassItemInto()
                continue
            }

            // 'trait' keyword — parse trait definition as class with @trait decorator
            if matchTokenStr(SeenTokenType.KeywordTrait) {
                // Add @trait decorator so codegen can distinguish traits from classes
                let traitAnn = AnnotationNode.new("trait")
                pendingDecorators.push(traitAnn)
                parseClassItemInto()
                continue
            }

            // 'impl' blocks — parse methods and attach to target class
            if matchTokenStr(SeenTokenType.KeywordImpl) {
                // Parse: impl TraitName for ClassName { methods... }
                // or:    impl ClassName { methods... }
                var implTraitName = ""
                var implTargetName = ""
                if checkToken(SeenTokenType.Identifier) {
                    implTraitName = advance().getValue()
                }
                // Check for 'for' keyword
                if checkToken(SeenTokenType.KeywordFor) {
                    advance() // consume 'for'
                    if checkToken(SeenTokenType.Identifier) {
                        implTargetName = advance().getValue()
                    }
                } else {
                    // impl ClassName { ... } — target is the trait name
                    implTargetName = implTraitName
                    implTraitName = ""
                }
                // Skip generic constraints like <T: Ord>
                if checkToken(SeenTokenType.LessThan) {
                    var implGenDepth = 1
                    advance()
                    while implGenDepth > 0 and not isAtEnd() {
                        if checkToken(SeenTokenType.LessThan) { implGenDepth = implGenDepth + 1 }
                        if checkToken(SeenTokenType.GreaterThan) { implGenDepth = implGenDepth - 1 }
                        advance()
                    }
                }

                // Parse braced body containing method definitions
                if matchTokenStr(SeenTokenType.LeftBrace) {
                    while not checkToken(SeenTokenType.RightBrace) and not isAtEnd() {
                        // Skip decorators
                        if matchTokenStr(SeenTokenType.AtSymbol) {
                            if checkToken(SeenTokenType.Identifier) {
                                advance()
                            }
                            // Skip decorator args
                            if matchTokenStr(SeenTokenType.LeftParen) {
                                var implDecDepth = 1
                                while implDecDepth > 0 and not isAtEnd() {
                                    if matchTokenStr(SeenTokenType.LeftParen) { implDecDepth = implDecDepth + 1 }
                                    if matchTokenStr(SeenTokenType.RightParen) { implDecDepth = implDecDepth - 1 }
                                    if implDecDepth > 0 { advance() }
                                }
                            }
                            continue
                        }
                        // Skip pub/static/override modifiers
                        if matchTokenStr(SeenTokenType.KeywordPub) { continue }
                        if matchTokenStr(SeenTokenType.KeywordStatic) { continue }
                        if matchTokenStr(SeenTokenType.KeywordOverride) { continue }

                        // Parse function via parseFunctionItemInto (auto-pushes with raw name)
                        // The codegen detects 'this: ClassName' param and generates ClassName_method
                        if matchTokenStr(getKeywordFunType()) {
                            parseFunctionItemInto()
                            continue
                        }
                        // Skip unrecognized tokens to avoid infinite loop
                        advance()
                    }
                    // Consume closing brace
                    if matchTokenStr(SeenTokenType.RightBrace) { }
                }
                continue
            }

            // 'extension' blocks — consume keyword, skip braced body
            if matchTokenStr(SeenTokenType.KeywordExtension) {
                // Consume identifier(s) before brace
                while not isAtEnd() and not checkToken(SeenTokenType.LeftBrace) {
                    advance()
                }
                // Skip braced body by brace-depth counting
                if matchTokenStr(SeenTokenType.LeftBrace) {
                    var extDepth = 1
                    while extDepth > 0 and not isAtEnd() {
                        if matchTokenStr(SeenTokenType.LeftBrace) {
                            extDepth = extDepth + 1
                        } else if matchTokenStr(SeenTokenType.RightBrace) {
                            extDepth = extDepth - 1
                        } else {
                            advance()
                        }
                    }
                }
                continue
            }

            if matchTokenStr(getKeywordClassType()) {
                parseClassItemInto()
                continue
            }

            if matchTokenStr(SeenTokenType.KeywordEnum) {
                parseEnumItemInto()
                continue
            }

            // Handle top-level let declarations (global variables)
            if matchTokenStr(SeenTokenType.KeywordLet) {
                if matchTokenStr(SeenTokenType.KeywordMut) { }  // consume optional mut
                parseTopLevelGlobalDecl(false)
                continue
            }

            // 'const' treated as top-level 'let'
            if matchTokenStr(SeenTokenType.KeywordConst) {
                parseTopLevelGlobalDecl(false)
                continue
            }

            // Handle top-level var declarations (global variables)
            if matchTokenStr(SeenTokenType.KeywordVar) {
                parseTopLevelGlobalDecl(true)
                continue
            }

            // Skip tokens we do not understand yet.
            advance()
        }

        refineTopLevelGlobalTypes()
        // trace.toString())
        return currentProgram
    }

    fun topLevelGlobalInitFunctionName() r: String {
        return "__seen_internal_module_init__"
    }

    fun ensureTopLevelInitFunctionIndex() r: Int {
        var i = 0
        while i < currentProgram.items.length() {
            let item = currentProgram.items[i]
            if item.itemType == "Function" {
                if item.function.name == topLevelGlobalInitFunctionName() {
                    return i
                }
            }
            i = i + 1
        }

        let initItem = ItemNode.new()
        initItem.itemType = "Function"
        initItem.name = topLevelGlobalInitFunctionName()
        initItem.function = FunctionNode.new()
        initItem.function.name = topLevelGlobalInitFunctionName()
        let initReturnType = TypeNode.new()
        initReturnType.typeName = "Void"
        initItem.function.returnType = initReturnType
        initItem.function.decorators.push(AnnotationNode.new("init"))
        currentProgram.items.push(initItem)
        return currentProgram.items.length() - 1
    }

    fun appendTopLevelGlobalInitializer(varName: String, initExpr: ParserExpressionNode) r: Void {
        let initIdx = ensureTopLevelInitFunctionIndex()
        let initStmt = StatementNode.new()
        initStmt.kind = "Assignment"
        initStmt.variableName = varName
        initStmt.initializer = initExpr
        let initItem = currentProgram.items[initIdx]
        initItem.function.body.statements.push(initStmt)
    }

    fun isTopLevelGlobalMutableEncoded(encoded: String) r: Bool {
        if encoded.length() > 0 {
            if encoded.byteAt(0) == 86 {
                return true
            }
        }
        return false
    }

    fun parseTopLevelGlobalEncodedType(encoded: String) r: String {
        var start = 0
        if encoded.length() > 0 {
            let firstByte = encoded.byteAt(0)
            if firstByte == 76 or firstByte == 86 {
                start = 1
            }
        }
        var i = start
        while i < encoded.length() {
            if encoded.byteAt(i) == 58 {
                return encoded.substring(start, i)
            }
            i = i + 1
        }
        return encoded.substring(start, encoded.length())
    }

    fun parseTopLevelGlobalEncodedStaticValue(encoded: String) r: String {
        var i = 0
        while i < encoded.length() {
            if encoded.byteAt(i) == 58 {
                return encoded.substring(i + 1, encoded.length())
            }
            i = i + 1
        }
        return ""
    }

    fun normalizeTopLevelInferredType(typeName: String) r: String {
        if typeName == "" {
            return ""
        }
        var end = typeName.length()
        if end > 0 {
            if typeName.byteAt(end - 1) == 63 {
                end = end - 1
            }
        }
        var i = 0
        while i < end {
            if typeName.byteAt(i) == 60 {
                return typeName.substring(0, i)
            }
            i = i + 1
        }
        return typeName.substring(0, end)
    }

    fun findCurrentProgramFunctionReturnType(functionName: String) r: String {
        var i = currentProgram.items.length() - 1
        while i >= 0 {
            let item = currentProgram.items[i]
            if item.itemType == "Function" {
                if item.function.name == functionName {
                    let returnType = item.function.returnType.typeName
                    if returnType != "" and returnType != "Unknown" {
                        return returnType
                    }
                }
            }
            i = i - 1
        }
        return ""
    }

    fun findCurrentProgramGlobalType(globalName: String) r: String {
        var i = currentProgram.items.length() - 1
        while i >= 0 {
            let item = currentProgram.items[i]
            if item.itemType == "GlobalVar" {
                if item.name == globalName {
                    return parseTopLevelGlobalEncodedType(item.visibility)
                }
            }
            i = i - 1
        }
        return ""
    }

    fun findCurrentProgramFieldType(typeName: String, fieldName: String) r: String {
        let normalizedType = normalizeTopLevelInferredType(typeName)
        if normalizedType == "" {
            return ""
        }
        var i = currentProgram.items.length() - 1
        while i >= 0 {
            let item = currentProgram.items[i]
            if item.itemType == "Class" {
                if item.classNode.name == normalizedType {
                    var fieldIdx = 0
                    while fieldIdx < item.classNode.fields.length() {
                        let field = item.classNode.fields[fieldIdx]
                        if field.name == fieldName {
                            return field.paramType.typeName
                        }
                        fieldIdx = fieldIdx + 1
                    }
                }
            }
            i = i - 1
        }
        return ""
    }

    fun findCurrentProgramMethodReturnType(typeName: String, methodName: String) r: String {
        let normalizedType = normalizeTopLevelInferredType(typeName)
        if normalizedType == "" {
            return ""
        }
        var i = currentProgram.items.length() - 1
        while i >= 0 {
            let item = currentProgram.items[i]
            if item.itemType == "Class" {
                if item.classNode.name == normalizedType {
                    var methodIdx = 0
                    while methodIdx < item.classNode.methods.length() {
                        let method = item.classNode.methods[methodIdx]
                        if method.name == methodName {
                            let returnType = method.returnType.typeName
                            if returnType != "" and returnType != "Unknown" {
                                return returnType
                            }
                        }
                        methodIdx = methodIdx + 1
                    }
                }
            }
            i = i - 1
        }
        return ""
    }

    fun findTopLevelGlobalInitializerExpr(globalName: String) r: ParserExpressionNode {
        var i = 0
        while i < currentProgram.items.length() {
            let item = currentProgram.items[i]
            if item.itemType == "Function" {
                if item.function.name == topLevelGlobalInitFunctionName() {
                    var stmtIdx = 0
                    while stmtIdx < item.function.body.statements.length() {
                        let stmt = item.function.body.statements[stmtIdx]
                        if stmt.kind == "Assignment" and stmt.variableName == globalName {
                            return stmt.initializer
                        }
                        stmtIdx = stmtIdx + 1
                    }
                }
            }
            i = i + 1
        }
        return ParserExpressionNode.new()
    }

    fun shouldRefineTopLevelGlobalType(currentType: String, inferredType: String) r: Bool {
        if inferredType == "" or inferredType == currentType {
            return false
        }
        if currentType == "Int" {
            return true
        }
        if currentType == "ptr" {
            return true
        }
        if currentType == "Array" and inferredType.startsWith("Array<") {
            return true
        }
        return false
    }

    fun refineTopLevelGlobalTypes() r: Void {
        var i = 0
        while i < currentProgram.items.length() {
            let item = currentProgram.items[i]
            if item.itemType == "GlobalVar" {
                let initExpr = findTopLevelGlobalInitializerExpr(item.name)
                if initExpr.kind != "None" {
                    let currentType = parseTopLevelGlobalEncodedType(item.visibility)
                    let inferredType = inferTopLevelGlobalType(initExpr)
                    if shouldRefineTopLevelGlobalType(currentType, inferredType) {
                        let staticValue = parseTopLevelGlobalEncodedStaticValue(item.visibility)
                        var mutPrefix = "L"
                        if isTopLevelGlobalMutableEncoded(item.visibility) {
                            mutPrefix = "V"
                        }
                        item.visibility = mutPrefix + inferredType + ":" + staticValue
                    }
                }
            }
            i = i + 1
        }
    }

    fun inferTopLevelGlobalType(initExpr: ParserExpressionNode) r: String {
        if initExpr.kind == "Literal" {
            if initExpr.literalType != "" {
                return initExpr.literalType
            }
        }
        if initExpr.kind == "StructLiteral" {
            return initExpr.literalType
        }
        if initExpr.kind == "ArrayLiteral" {
            if initExpr.arguments.length() > 0 {
                let elemType = inferTopLevelGlobalType(initExpr.arguments[0])
                if elemType != "" {
                    return "Array<" + elemType + ">"
                }
            }
            return "Array"
        }
        if initExpr.kind == "MethodCall" {
            if initExpr.callee == "new" {
                if initExpr.literalValue != "" {
                    return initExpr.literalValue
                }
                if initExpr.operands.length() > 0 {
                    let recvName = getVariableExprName(initExpr.operands[0])
                    if recvName != "" {
                        return recvName
                    }
                }
            }
            var receiverType = ""
            if initExpr.operands.length() > 0 {
                receiverType = inferTopLevelGlobalType(initExpr.operands[0])
            }
            if receiverType == "" and initExpr.literalValue != "" {
                receiverType = initExpr.literalValue
            }
            if receiverType != "" {
                let methodReturnType = findCurrentProgramMethodReturnType(receiverType, initExpr.callee)
                if methodReturnType != "" {
                    return methodReturnType
                }
            }
        }
        if initExpr.kind == "Call" {
            if initExpr.callee.length() > 0 {
                let functionReturnType = findCurrentProgramFunctionReturnType(initExpr.callee)
                if functionReturnType != "" {
                    return functionReturnType
                }
                let firstChar = initExpr.callee.charAt(0)
                if firstChar >= "A" {
                    if firstChar <= "Z" {
                        return initExpr.callee
                    }
                }
            }
        }
        if initExpr.kind == "VarExpr" or initExpr.kind == "Variable" {
            let varName = getVariableExprName(initExpr)
            if varName.length() > 0 {
                let globalType = findCurrentProgramGlobalType(varName)
                if globalType != "" {
                    return globalType
                }
                let firstChar = varName.charAt(0)
                if firstChar >= "A" {
                    if firstChar <= "Z" {
                        return varName
                    }
                }
            }
        }
        if initExpr.kind == "MemberAccess" {
            if initExpr.operands.length() > 0 {
                let receiverType = inferTopLevelGlobalType(initExpr.operands[0])
                if receiverType != "" {
                    let fieldType = findCurrentProgramFieldType(receiverType, initExpr.variableName)
                    if fieldType != "" {
                        return fieldType
                    }
                }
            }
            if initExpr.literalValue != "" {
                let baseType = findCurrentProgramGlobalType(initExpr.literalValue)
                if baseType != "" {
                    let fieldType = findCurrentProgramFieldType(baseType, initExpr.variableName)
                    if fieldType != "" {
                        return fieldType
                    }
                }
            }
        }
        if initExpr.kind == "Unary" {
            if initExpr.operator == "!" {
                return "Bool"
            }
            if initExpr.operands.length() > 0 {
                return inferTopLevelGlobalType(initExpr.operands[0])
            }
        }
        if initExpr.kind == "Binary" {
            let op = initExpr.operator
            if op == "==" { return "Bool" }
            if op == "!=" { return "Bool" }
            if op == "<" { return "Bool" }
            if op == ">" { return "Bool" }
            if op == "<=" { return "Bool" }
            if op == ">=" { return "Bool" }
            if op == "and" { return "Bool" }
            if op == "or" { return "Bool" }
            if initExpr.operands.length() > 0 {
                let leftType = inferTopLevelGlobalType(initExpr.operands[0])
                if initExpr.operands.length() > 1 {
                    let rightType = inferTopLevelGlobalType(initExpr.operands[1])
                    if leftType == "String" { return "String" }
                    if rightType == "String" { return "String" }
                    if leftType == "Float" { return "Float" }
                    if rightType == "Float" { return "Float" }
                    if leftType != "" { return leftType }
                    if rightType != "" { return rightType }
                }
                if leftType != "" { return leftType }
            }
            return "Int"
        }
        return ""
    }

    fun extractTopLevelStaticInitializer(initExpr: ParserExpressionNode) r: String {
        if initExpr.kind != "Literal" {
            return ""
        }
        if initExpr.literalType == "Int" or initExpr.literalType == "Float" {
            return initExpr.literalValue
        }
        if initExpr.literalType == "Bool" {
            if initExpr.literalValue == "true" {
                return "true"
            }
            return "false"
        }
        return ""
    }

    // Top-level let/const/var declaration
    fun parseTopLevelGlobalDecl(isMutable: Bool) r: Void {
        let gvNameToken = consumeNameLike("Expected variable name")
        let gvName = gvNameToken.getValue()
        var gvType = ""
        if matchTokenStr(SeenTokenType.Colon) {
            let gvTypeNode = parseTypeNode()
            gvType = gvTypeNode.typeName
        }

        var gvHasInitializer = false
        var gvInitExpr = ParserExpressionNode.new()
        if matchTokenStr(SeenTokenType.Equal) {
            gvInitExpr = parseExpression()
            gvHasInitializer = true
        }

        if gvType == "" and gvHasInitializer {
            gvType = inferTopLevelGlobalType(gvInitExpr)
        }
        if gvType == "" {
            gvType = "Int"
        }

        if matchTokenStr(SeenTokenType.Semicolon) { }

        let gvItem = ItemNode.new()
        gvItem.itemType = "GlobalVar"
        gvItem.name = gvName
        var gvPrefix = "L"
        if isMutable { gvPrefix = "V" }
        gvItem.visibility = gvPrefix + gvType + ":" + extractTopLevelStaticInitializer(gvInitExpr)
        currentProgram.items.push(gvItem)

        if gvHasInitializer {
            appendTopLevelGlobalInitializer(gvName, gvInitExpr)
        }
    }

    // Parse a decorator and add to pending decorators
    fun parseDecoratorInto() r: Void {
        // Expect identifier or keyword-as-decorator after @
        var decoratorName = ""
        if checkToken(SeenTokenType.KeywordInline) {
            advance()
            decoratorName = "inline"
        } else {
            let nameToken = consume(SeenTokenType.Identifier, "Expected decorator name after '@'")
            decoratorName = nameToken.getValue()
        }
        let annotation = AnnotationNode.new(decoratorName)

        // Optional: parse arguments in parentheses
        if matchTokenStr(SeenTokenType.LeftParen) {
            while not checkToken(SeenTokenType.RightParen) and not isAtEnd() {
                // Parse argument: value OR key=value
                if checkToken(SeenTokenType.Identifier) {
                    let argToken = advance()
                    // Check if this is key=value syntax
                    if checkToken(SeenTokenType.Equal) {
                        // Skip the '=' and read the actual value
                        advance()
                        if checkToken(SeenTokenType.IntegerLiteral) {
                            let valToken = advance()
                            annotation.addArgument(valToken.getValue())
                        } else if checkToken(SeenTokenType.StringLiteral) {
                            let valToken = advance()
                            annotation.addArgument(valToken.getValue())
                        } else if checkToken(SeenTokenType.Identifier) {
                            let valToken = advance()
                            annotation.addArgument(valToken.getValue())
                        }
                    } else {
                        annotation.addArgument(argToken.getValue())
                    }
                } else if checkToken(SeenTokenType.StringLiteral) {
                    let argToken = advance()
                    annotation.addArgument(argToken.getValue())
                } else if checkToken(SeenTokenType.IntegerLiteral) {
                    let argToken = advance()
                    annotation.addArgument(argToken.getValue())
                } else {
                    // Skip unknown token to avoid infinite loop
                    advance()
                }

                // Skip comma between arguments
                if not matchTokenStr(SeenTokenType.Comma) {
                    break
                }
            }
            consume(SeenTokenType.RightParen, "Expected ')' after decorator arguments")
        }

        pendingDecorators.push(annotation)
    }

    fun parseEffectModifierInto() r: Void {
        consume(SeenTokenType.KeywordEffect, "Expected 'effect'")
        pendingDecorators.push(AnnotationNode.new("effect"))
        let effectIndex = pendingDecorators.length() - 1

        if matchTokenStr(SeenTokenType.LeftParen) {
            while not checkToken(SeenTokenType.RightParen) and not isAtEnd() {
                if checkNameLikeToken() {
                    let effectArg = advance().getValue()
                    pendingDecorators[effectIndex].addArgument(effectArg)
                } else {
                    advance()
                }

                if not matchTokenStr(SeenTokenType.Comma) {
                    break
                }
            }
            consume(SeenTokenType.RightParen, "Expected ')' after effect arguments")
        }
    }

    fun parseFunctionItem() r: ItemNode {
        // trace
        if isAtEnd() {
            return ItemNode.new()
        }

        let nameToken = consume(SeenTokenType.Identifier, "Expected function name")
        let func = FunctionNode.new()
        // Handle data type method syntax: fun TypeName.methodName() -> TypeName_methodName
        var funcName = nameToken.getValue()
        if matchTokenStr(SeenTokenType.Dot) {
            let methodToken = consume(SeenTokenType.Identifier, "Expected method name after dot")
            funcName = funcName + "_" + methodToken.getValue()
        }
        func.name = funcName
        // trace

        // Skip generic type parameters: fun name<T: Ord + Clone>(...)
        if checkToken(SeenTokenType.LessThan) {
            advance()
            var gd = 1
            while gd > 0 and not isAtEnd() {
                if checkToken(SeenTokenType.LessThan) { gd = gd + 1 }
                if checkToken(SeenTokenType.GreaterThan) { gd = gd - 1 }
                advance()
            }
        }

        parseParameterList(func)
        parseOptionalReturnTypeIntoScratch()
        if lastParsedTypeName != "Unknown" {
            func.returnType = parsedScratchTypeNode()
        }

        // Parse optional `where` clause: where T: Trait1 + Trait2, U: Trait3
        if checkToken(SeenTokenType.Identifier) and peek().getValue() == "where" {
            advance()  // consume "where"
            // Collect constraint text until '{' or end of line
            var whereText = ""
            while not checkToken(SeenTokenType.LeftBrace) and not checkToken(SeenTokenType.Semicolon) and not isAtEnd() {
                let wTok = advance()
                whereText = whereText + wTok.getValue()
            }
            if whereText != "" {
                let whereAnn = AnnotationNode.new("where_constraint")
                whereAnn.addArgument(whereText)
                func.decorators.push(whereAnn)
            }
        }

        var funcBodyParsed = false
        if matchTokenStr(SeenTokenType.LeftBrace) {
            // trace
            parseBlockIntoField()
            func.body = lastParsedBlock
            // trace.toString())
            funcBodyParsed = true
        }
        if not funcBodyParsed {
            // trace
            // Abstract function or declaration
            func.body = BlockNode.new()
            if matchTokenStr(SeenTokenType.Semicolon) {
                // Consumed
            }
        }

        traceParsedFunctionShape("parseFunctionItem", func)

        // trace
        let item = ItemNode.new()
        // trace
        item.itemType = "Function"
        // trace
        item.name = func.name
        // trace
        item.visibility = inferVisibility(func.name)
        // trace
        item.function = func
        // trace

        return item
    }

    // Parse a complete function declaration and push it as an ItemNode directly
    // into currentProgram.  Handles generic type parameters, decorators,
    // parameter lists (including the `r: Type` return-type syntax), fat-arrow
    // bodies (`=> expr`), and data-type method syntax (`fun Type.method()`).
    //
    // Uses lastFunction class field instead of a local FunctionNode variable
    // to work around a stage1 bootstrap codegen bug where returning or
    // locally copying large struct values corrupts memory.
    fun parseFunctionItemInto() r: Void {
        if isAtEnd() {
            return
        }

        let nameToken = consume(SeenTokenType.Identifier, "Expected function name")
        // Use class field to avoid local variable corruption
        lastFunction = FunctionNode.new()
        clearPendingFunctionReturnType()
        clearPendingFunctionParamTypes()
        // Handle data type method syntax: fun TypeName.methodName() -> TypeName_methodName
        var funcName = nameToken.getValue()
        if matchTokenStr(SeenTokenType.Dot) {
            let methodToken = consume(SeenTokenType.Identifier, "Expected method name after dot")
            funcName = funcName + "_" + methodToken.getValue()
        }
        lastFunction.name = funcName

        // Skip generic type parameters: fun name<T: Ord + Clone>(...)
        // : Detect variadic generic ...Ts syntax
        if checkToken(SeenTokenType.LessThan) {
            advance()
            var gd = 1
            while gd > 0 and not isAtEnd() {
                // : Detect '...' Identifier for variadic generics
                if checkToken(SeenTokenType.Ellipsis) {
                    advance()
                    if checkToken(SeenTokenType.Identifier) {
                        let packName = peek().getValue()
                        let variadicAnn = AnnotationNode.new("variadic_generic")
                        variadicAnn.addArgument(packName)
                        lastFunction.decorators.push(variadicAnn)
                    }
                }
                if checkToken(SeenTokenType.LessThan) { gd = gd + 1 }
                if checkToken(SeenTokenType.GreaterThan) { gd = gd - 1 }
                advance()
            }
        }

        // Apply pending decorators to this function
        applyDecoratorsToFunction()

        parseParameterListField()
        var resolvedReturnTypeName = pendingFunctionReturnTypeName
        var resolvedReturnTypeNullable = pendingFunctionReturnTypeNullable
        parseOptionalReturnTypeIntoScratch()
        if lastParsedTypeName != "Unknown" {
            resolvedReturnTypeName = lastParsedTypeName
            resolvedReturnTypeNullable = lastParsedTypeNullable
        }

        // Check for '=>' fat-arrow single-expression body (= followed by >)
        var fatArrowBody = false
        if checkToken(SeenTokenType.Equal) {
            let fatArrPeek = peekAt(1)
            if fatArrPeek.getValue() == ">" {
                advance()   // consume '='
                advance()   // consume '>'
                let arrowBodyExpr = parseExpression()
                let arrowRetStmt = StatementNode.new()
                arrowRetStmt.kind = "Return"
                arrowRetStmt.returnValue = arrowBodyExpr
                lastFunction.body = BlockNode.new()
                lastFunction.body.statements.push(arrowRetStmt)
                fatArrowBody = true
            }
        }

        var bodyParsed = false
        if not fatArrowBody {
            if matchTokenStr(SeenTokenType.LeftBrace) {
                parseBlockIntoField()
                lastFunction.body = lastParsedBlock
                bodyParsed = true
            }
            if not bodyParsed {
                lastFunction.body = BlockNode.new()
                if matchTokenStr(SeenTokenType.Semicolon) {
                    // Consumed
                }
            }
        }

        applyPendingFunctionParamTypes()
        if resolvedReturnTypeName != "Unknown" {
            lastParsedTypeName = resolvedReturnTypeName
            lastParsedTypeNullable = resolvedReturnTypeNullable
            lastFunction.returnType = parsedScratchTypeNode()
        }

        traceParsedFunctionShape("parseFunctionItemInto", lastFunction)

        // Push directly to currentProgram instead of returning
        // Use separate allocations to avoid heap corruption from struct literal
        // trace
        let item = ItemNode.new()
        item.itemType = "Function"
        item.name = lastFunction.name
        item.visibility = inferVisibility(lastFunction.name)
        item.function = lastFunction
        // trace
        currentProgram.items.push(item)
        traceParse("push Function " + item.name)
        // trace
    }

    // Apply pending decorators to lastFunction and clear them
    fun applyDecoratorsToFunction() r: Void {
        // Copy all pending decorators to the function
        var i = 0
        while i < pendingDecorators.length() {
            let decorator = pendingDecorators[i]
            lastFunction.decorators.push(decorator)

            // Set convenience flags for common decorators
            if decorator.name == "deterministic" {
                lastFunction.isDeterministic = true
            }
            if decorator.name == "nondeterministic" {
                lastFunction.isNondeterministic = true
            }
            if decorator.name == "extern" {
                lastFunction.isExtern = true
            }
            if decorator.name == "inline" {
                lastFunction.isInline = true
            }
            if decorator.name == "async" {
                lastFunction.isAsync = true
            }
            if decorator.name == "test" {
                // Tests are deterministic by default
                lastFunction.isDeterministic = true
            }

            i = i + 1
        }

        // Clear pending decorators after applying
        pendingDecorators = Array<AnnotationNode>()
    }

    // Apply pending decorators to a ClassNode and clear them
    fun applyDecoratorsToClass(classNode: ClassNode) r: Void {
        // Copy all pending decorators to the class
        var i = 0
        while i < pendingDecorators.length() {
            let decorator = pendingDecorators[i]
            classNode.decorators.push(decorator)

            // Set convenience flags for common decorators
            if decorator.name == "nondeterministic" {
                classNode.isNondeterministic = true
            }

            // For @hot_reload: add sentinel method so IR generator can detect it
            // without accessing classNode.decorators (which is at a broken GEP index
            // due to the static fun phantom field bug in ClassNode).
            if decorator.name == "hot_reload" {
                let sentinel = FunctionNode.new()
                sentinel.name = "__seen_hot_reload_marker__"
                classNode.methods.push(sentinel)
            }

            i = i + 1
        }

        // Clear pending decorators after applying
        pendingDecorators = Array<AnnotationNode>()
    }

    fun applyPendingTypeModifiersToClass(classNode: ClassNode) r: Void {
        if pendingSealedModifier == 1 {
            pendingDecorators.push(AnnotationNode.new("sealed"))
            pendingSealedModifier = 0
        }
        applyDecoratorsToClass(classNode)
    }

    // Parse parameter list into lastFunction (avoids passing FunctionNode by value)
    fun parseParameterListField() r: Void {
        consume(SeenTokenType.LeftParen, "Expected '(' after function name")
        var paramIter = 0
        while not checkToken(SeenTokenType.RightParen) and not isAtEnd() {
            paramIter = paramIter + 1
            if paramIter > 100 {
                break
            }
            // Check for move/borrow/ref/own ownership qualifier
            var paramOwnership = ""
            if matchNameValue("move") {
                paramOwnership = "move"
            }
            if paramOwnership == "" and matchNameValue("borrow") {
                paramOwnership = "borrow"
            }
            if paramOwnership == "" and matchNameValue("ref") {
                paramOwnership = "ref"
            }
            if paramOwnership == "" and matchNameValue("own") {
                paramOwnership = "own"
            }
            // Return type parameter (r: Type syntax)
            if checkNameLikeToken() {
                let prevTok = advance()
                var wasReturnParam = false
                if paramOwnership == "" and (prevTok.getValue() == "r" or prevTok.getValue() == "seen_std.builtins.r") and checkToken(SeenTokenType.Colon) {
                    advance() // consume :
                    parseTypeNodeIntoScratch()
                    capturePendingFunctionReturnTypeFromScratch()
                    wasReturnParam = true
                    continue
                }
                // comptime parameter modifier
                // If identifier is "comptime", consume the next identifier as the real param name
                var isComptimeParam = false
                if not wasReturnParam and prevTok.getValue() == "comptime" {
                    isComptimeParam = true
                    if checkNameLikeToken() {
                        let realTok = advance()
                        let param = ParamNode.new()
                        param.name = realTok.getValue()
                        var paramTypeName = "Unknown"
                        var paramTypeNullable = false
                        if matchTokenStr(SeenTokenType.Colon) {
                            parseTypeNodeIntoScratch()
                            paramTypeName = lastParsedTypeName
                            paramTypeNullable = lastParsedTypeNullable
                        }
                        // Encode comptime in type string prefix
                        if paramTypeName != "" {
                            paramTypeName = "comptime:" + paramTypeName
                        } else {
                            paramTypeName = "comptime:Int"
                        }
                        if matchTokenStr(SeenTokenType.Equal) {
                            let defVal = peek().getValue()
                            paramTypeName = paramTypeName + "~default~" + defVal
                            skipExpression()
                        }
                        lastFunction.params.push(param)
                        addPendingFunctionParamType(paramTypeName, paramTypeNullable)
                        wasReturnParam = true
                    }
                }
                if not wasReturnParam {
                    // Regular parameter - rewind wasn't possible, so parse as param
                    var paramName = prevTok.getValue()
                    // Remap 'self' to 'this' (alias for this-pointer in method declarations)
                    if paramName == "self" { paramName = "this" }
                    let param = ParamNode.new()
                    param.name = paramName
                    var paramTypeName = "Unknown"
                    var paramTypeNullable = false
                    if matchTokenStr(SeenTokenType.Colon) {
                        parseTypeNodeIntoScratch()
                        paramTypeName = lastParsedTypeName
                        paramTypeNullable = lastParsedTypeNullable
                    }
                    // Encode ownership in type string prefix
                    if paramOwnership != "" and paramTypeName != "" {
                        paramTypeName = paramOwnership + ":" + paramTypeName
                    }
                    // Handle default parameter values: encode in type name suffix
                    if matchTokenStr(SeenTokenType.Equal) {
                        let defVal = peek().getValue()
                        paramTypeName = paramTypeName + "~default~" + defVal
                        skipExpression()
                    }
                    lastFunction.params.push(param)
                    addPendingFunctionParamType(paramTypeName, paramTypeNullable)
                }
            }

            if checkToken(SeenTokenType.Comma) {
                advance()
            }
        }
        consume(SeenTokenType.RightParen, "Expected ')' after parameters")
    }

    fun parseClassItem() r: ItemNode {
        if isAtEnd() {
            return ItemNode.new()
        }

        let nameToken = consume(SeenTokenType.Identifier, "Expected class name")
        let classNode = ClassNode.new()
        classNode.name = nameToken.getValue()
        applyPendingTypeModifiersToClass(classNode)
        // trace

        // Skip generic type parameters if present (e.g., class BTreeMap<K, V> { ... })
        if checkToken(SeenTokenType.LessThan) {
            advance()  // consume '<'
            var genericDepth = 1
            while genericDepth > 0 and not isAtEnd() {
                if checkToken(SeenTokenType.LessThan) {
                    genericDepth = genericDepth + 1
                }
                if checkToken(SeenTokenType.GreaterThan) {
                    genericDepth = genericDepth - 1
                }
                advance()
            }
        }

        // Parse class body
        if matchTokenStr(SeenTokenType.LeftBrace) {
            while not checkToken(SeenTokenType.RightBrace) and not isAtEnd() {
                let curTok = peek()
                let curType = curTok.getType().toString()
                let rbStr = SeenTokenType.RightBrace.toString()
                // trace + " rbCheck=(" + curType + "==" + rbStr + ")")
                // Consume optional 'pub' modifier
                if matchTokenStr(SeenTokenType.KeywordPub) {
                    // fall through
                }
                // Check for 'var' or 'let' (field)
                var classTokenHandled = false
                if matchTokenStr(SeenTokenType.AtSymbol) {
                    parseDecoratorInto()
                    classTokenHandled = true
                }
                if not classTokenHandled {
                    if checkToken(SeenTokenType.KeywordEffect) {
                        parseEffectModifierInto()
                        classTokenHandled = true
                    }
                }
                if not classTokenHandled {
                    if matchTokenStr(SeenTokenType.KeywordVar) or matchTokenStr(SeenTokenType.KeywordLet) {
                        if matchTokenStr(SeenTokenType.KeywordMut) { }  // consume optional mut
                        let fieldName = consume(SeenTokenType.Identifier, "Expected field name")
                        consume(SeenTokenType.Colon, "Expected ':' after field name")
                        let fieldType = parseTypeNode()
                        // : Bit field syntax: fieldName: Type : N
                        if checkToken(SeenTokenType.Colon) {
                            advance()
                            if checkToken(SeenTokenType.IntegerLiteral) {
                                let bitWidth = advance().getValue()
                                fieldType.typeName = fieldType.typeName + ":bitfield(" + bitWidth + ")"
                            }
                        }
                        let field = ParamNode.new()
                        field.name = fieldName.getValue()
                        field.paramType = fieldType
                        classNode.fields.push(field)
                        // trace
                        classTokenHandled = true
                    }
                }
                // Check for 'static' method
                if not classTokenHandled {
                    if matchTokenStr(SeenTokenType.KeywordStatic) {
                        if matchTokenStr(SeenTokenType.KeywordFun) {
                            let methodNameTok = consume(SeenTokenType.Identifier, "Expected method name")
                            lastFunction = FunctionNode.new()
                            clearPendingFunctionReturnType()
                            clearPendingFunctionParamTypes()
                            lastFunction.name = methodNameTok.getValue()
                            // Skip generic type parameters
                            if checkToken(SeenTokenType.LessThan) {
                                advance()
                                var gd = 1
                                while gd > 0 and not isAtEnd() {
                                    if checkToken(SeenTokenType.LessThan) { gd = gd + 1 }
                                    if checkToken(SeenTokenType.GreaterThan) { gd = gd - 1 }
                                    advance()
                                }
                            }
                            applyDecoratorsToFunction()
                            parseParameterListField()
                            var resolvedReturnTypeName = pendingFunctionReturnTypeName
                            var resolvedReturnTypeNullable = pendingFunctionReturnTypeNullable
                            parseOptionalReturnTypeIntoScratch()
                            if lastParsedTypeName != "Unknown" {
                                resolvedReturnTypeName = lastParsedTypeName
                                resolvedReturnTypeNullable = lastParsedTypeNullable
                            }
                            if matchTokenStr(SeenTokenType.LeftBrace) {
                                parseBlockIntoField()
                                lastFunction.body = lastParsedBlock
                            } else {
                                lastFunction.body = BlockNode.new()
                            }
                            applyPendingFunctionParamTypes()
                            if resolvedReturnTypeName != "Unknown" {
                                lastParsedTypeName = resolvedReturnTypeName
                                lastParsedTypeNullable = resolvedReturnTypeNullable
                                lastFunction.returnType = parsedScratchTypeNode()
                            }
                            let method = lastFunction
                            method.isStatic = true
                            classNode.methods.push(method)
                        }
                        classTokenHandled = true
                    }
                }
                // Check for 'fun' (instance method)
                // NOTE: Use nested if instead of 'and' to ensure short-circuit (Stage1 bug workaround)
                if not classTokenHandled {
                    if matchTokenStr(SeenTokenType.KeywordFun) {
                        // Inline parse using lastFunction field to avoid memory corruption
                        // Handle 'operator' keyword or normal identifier as method name
                        var methodNameStr2 = ""
                        if checkToken(SeenTokenType.KeywordOperator) {
                            advance()
                            methodNameStr2 = "operator"
                        } else {
                            let methodNameTok2 = consume(SeenTokenType.Identifier, "Expected method name")
                            methodNameStr2 = methodNameTok2.getValue()
                        }
                        if methodNameStr2 == "operator" {
                            if matchTokenStr(SeenTokenType.Plus) { methodNameStr2 = "operator_add" }
                            if methodNameStr2 == "operator" and matchTokenStr(SeenTokenType.Minus) { methodNameStr2 = "operator_sub" }
                            if methodNameStr2 == "operator" and matchTokenStr(SeenTokenType.Multiply) { methodNameStr2 = "operator_mul" }
                            if methodNameStr2 == "operator" and matchTokenStr(SeenTokenType.Divide) { methodNameStr2 = "operator_div" }
                            if methodNameStr2 == "operator" and matchTokenStr(SeenTokenType.Modulo) { methodNameStr2 = "operator_mod" }
                            if methodNameStr2 == "operator" and matchTokenStr(SeenTokenType.EqualEqual) { methodNameStr2 = "operator_eq" }
                            if methodNameStr2 == "operator" and matchTokenStr(SeenTokenType.NotEqual) { methodNameStr2 = "operator_neq" }
                            if methodNameStr2 == "operator" and matchTokenStr(SeenTokenType.LessThan) { methodNameStr2 = "operator_lt" }
                            if methodNameStr2 == "operator" and matchTokenStr(SeenTokenType.GreaterThan) { methodNameStr2 = "operator_gt" }
                            if methodNameStr2 == "operator" and matchTokenStr(SeenTokenType.LessEqual) { methodNameStr2 = "operator_lte" }
                            if methodNameStr2 == "operator" and matchTokenStr(SeenTokenType.GreaterEqual) { methodNameStr2 = "operator_gte" }
                        }
                        lastFunction = FunctionNode.new()
                        clearPendingFunctionReturnType()
                        clearPendingFunctionParamTypes()
                        lastFunction.name = methodNameStr2
                        // Skip generic type parameters
                        if checkToken(SeenTokenType.LessThan) {
                            advance()
                            var gd = 1
                            while gd > 0 and not isAtEnd() {
                                if checkToken(SeenTokenType.LessThan) { gd = gd + 1 }
                                if checkToken(SeenTokenType.GreaterThan) { gd = gd - 1 }
                                advance()
                            }
                        }
                        applyDecoratorsToFunction()
                        parseParameterListField()
                        var resolvedReturnTypeName2 = pendingFunctionReturnTypeName
                        var resolvedReturnTypeNullable2 = pendingFunctionReturnTypeNullable
                        parseOptionalReturnTypeIntoScratch()
                        if lastParsedTypeName != "Unknown" {
                            resolvedReturnTypeName2 = lastParsedTypeName
                            resolvedReturnTypeNullable2 = lastParsedTypeNullable
                        }
                        if matchTokenStr(SeenTokenType.LeftBrace) {
                            parseBlockIntoField()
                            lastFunction.body = lastParsedBlock
                        } else {
                            lastFunction.body = BlockNode.new()
                        }
                        applyPendingFunctionParamTypes()
                        if resolvedReturnTypeName2 != "Unknown" {
                            lastParsedTypeName = resolvedReturnTypeName2
                            lastParsedTypeNullable = resolvedReturnTypeNullable2
                            lastFunction.returnType = parsedScratchTypeNode()
                        }
                        let method = lastFunction
                        method.isStatic = false
                        classNode.methods.push(method)
                        // trace
                        classTokenHandled = true
                    }
                }
                // Accept bare field: identifier: Type (without var/let)
                if not classTokenHandled {
                    if checkToken(SeenTokenType.Identifier) {
                        let curTokVal2 = peek().getValue()
                        if curTokVal2 != "r" and curTokVal2 != "seen_std.builtins.r" and curTokVal2 != "this" {
                            let nextTok2 = peekAt(1)
                            if nextTok2.getType() == SeenTokenType.Colon {
                                let bareFieldName2 = advance()
                                consume(SeenTokenType.Colon, "Expected ':'")
                                let bareFieldType2 = parseTypeNode()
                                // : Bit field syntax: fieldName: Type : N
                                if checkToken(SeenTokenType.Colon) {
                                    advance()
                                    if checkToken(SeenTokenType.IntegerLiteral) {
                                        let bitW2 = advance().getValue()
                                        bareFieldType2.typeName = bareFieldType2.typeName + ":bitfield(" + bitW2 + ")"
                                    }
                                }
                                let bareField2 = ParamNode.new()
                                bareField2.name = bareFieldName2.getValue()
                                bareField2.paramType = bareFieldType2
                                classNode.fields.push(bareField2)
                                if matchTokenStr(SeenTokenType.Semicolon) { }
                                if matchTokenStr(SeenTokenType.Comma) { }
                                classTokenHandled = true
                            }
                        }
                    }
                }
                // : Associated types: type Name = ConcreteType
                if not classTokenHandled {
                    if matchTokenStr(SeenTokenType.KeywordType) {
                        if checkToken(SeenTokenType.Identifier) {
                            let assocTypeName = advance().getValue()
                            if matchTokenStr(SeenTokenType.Assign) {
                                let assocTypeTarget = parseTypeNode()
                                // Store as synthetic field with @type_alias marker
                                let assocField = ParamNode.new()
                                assocField.name = "@type_alias:" + assocTypeName
                                assocField.paramType = assocTypeTarget
                                classNode.fields.push(assocField)
                            }
                        }
                        if matchTokenStr(SeenTokenType.Semicolon) { }
                        classTokenHandled = true
                    }
                }
                if not classTokenHandled {
                    // Skip unknown tokens
                    advance()
                }
            }
            consume(SeenTokenType.RightBrace, "Expected '}' after class body")
        }

        let item = ItemNode.new()
        item.itemType = "Class"
        item.name = classNode.name
        item.visibility = inferVisibility(classNode.name)
        item.classNode = classNode

        return item
    }

    // Parse a class, struct, trait, or data declaration and push it into
    // currentProgram.  Also used for `data` and `struct` keywords (aliases).
    // Parses: generic params, `extends` clause, decorators, braced body
    // containing fields (var/let/bare), static methods, instance methods
    // (including operator overloads), and associated type declarations.
    //
    // NOTE: `if/else if` chains are written as nested `if not handled { if ... }`
    // because the stage1 bootstrap compiler does not short-circuit `and`/`or`.
    fun parseClassItemInto() r: Void {
        if isAtEnd() {
            return
        }

        let nameToken = consume(SeenTokenType.Identifier, "Expected class name")
        let classNode = ClassNode.new()
        classNode.name = nameToken.getValue()

        // Skip generic type parameters if present (e.g., class BTreeMap<K, V> { ... })
        if checkToken(SeenTokenType.LessThan) {
            advance()  // consume '<'
            var genericDepth = 1
            while genericDepth > 0 and not isAtEnd() {
                if checkToken(SeenTokenType.LessThan) {
                    genericDepth = genericDepth + 1
                }
                if checkToken(SeenTokenType.GreaterThan) {
                    genericDepth = genericDepth - 1
                }
                advance()
            }
        }

        // Parse optional 'extends ParentClass' clause
        if checkToken(SeenTokenType.KeywordExtends) {
            advance()  // consume 'extends'
            let parentTok = consume(SeenTokenType.Identifier, "Expected parent class name")
            classNode.parentName = parentTok.getValue()
        }

        // Apply pending decorators and keyword modifiers to this class
        applyPendingTypeModifiersToClass(classNode)

        // Parse class body
        if matchTokenStr(SeenTokenType.LeftBrace) {
            while not checkToken(SeenTokenType.RightBrace) and not isAtEnd() {
                let curTok = peek()
                let curType = curTok.getType().toString()
                // Consume optional 'pub' modifier
                if matchTokenStr(SeenTokenType.KeywordPub) {
                    // fall through
                }
                // Check for 'var' or 'let' (field)
                var classIntoTokenHandled = false
                var sawOverrideInto = 0
                var sawAsyncInto = 0
                if matchTokenStr(SeenTokenType.AtSymbol) {
                    parseDecoratorInto()
                    classIntoTokenHandled = true
                }
                if not classIntoTokenHandled {
                    if checkToken(SeenTokenType.KeywordEffect) {
                        parseEffectModifierInto()
                        classIntoTokenHandled = true
                    }
                }
                if not classIntoTokenHandled {
                    if matchTokenStr(SeenTokenType.KeywordVar) or matchTokenStr(SeenTokenType.KeywordLet) {
                        if matchTokenStr(SeenTokenType.KeywordMut) { }  // consume optional mut
                        let fieldName = consume(SeenTokenType.Identifier, "Expected field name")
                        consume(SeenTokenType.Colon, "Expected ':' after field name")
                        let fieldType = parseTypeNode()
                        // : Bit field syntax: fieldName: Type : N
                        if checkToken(SeenTokenType.Colon) {
                            advance()
                            if checkToken(SeenTokenType.IntegerLiteral) {
                                let bitWidthInto = advance().getValue()
                                fieldType.typeName = fieldType.typeName + ":bitfield(" + bitWidthInto + ")"
                            }
                        }
                        let field = ParamNode.new()
                        field.name = fieldName.getValue()
                        field.paramType = fieldType
                        classNode.fields.push(field)
                        // trace
                        classIntoTokenHandled = true
                    }
                }
                // Check for 'static' method prefix
                if not classIntoTokenHandled {
                    if matchTokenStr(SeenTokenType.KeywordStatic) {
                        if matchTokenStr(SeenTokenType.KeywordFun) {
                            // Inline parse using lastFunction field to avoid memory corruption
                            let methodNameTokInto = consume(SeenTokenType.Identifier, "Expected method name")
                            lastFunction = FunctionNode.new()
                            clearPendingFunctionReturnType()
                            clearPendingFunctionParamTypes()
                            lastFunction.name = methodNameTokInto.getValue()
                            // Skip generic type parameters: fun name<T: Ord>(...)
                            if checkToken(SeenTokenType.LessThan) {
                                advance()
                                var gd = 1
                                while gd > 0 and not isAtEnd() {
                                    if checkToken(SeenTokenType.LessThan) { gd = gd + 1 }
                                    if checkToken(SeenTokenType.GreaterThan) { gd = gd - 1 }
                                    advance()
                                }
                            }
                            applyDecoratorsToFunction()
                            parseParameterListField()
                            var resolvedReturnTypeNameInto = pendingFunctionReturnTypeName
                            var resolvedReturnTypeNullableInto = pendingFunctionReturnTypeNullable
                            parseOptionalReturnTypeIntoScratch()
                            if lastParsedTypeName != "Unknown" {
                                resolvedReturnTypeNameInto = lastParsedTypeName
                                resolvedReturnTypeNullableInto = lastParsedTypeNullable
                            }
                            if matchTokenStr(SeenTokenType.LeftBrace) {
                                parseBlockIntoField()
                                lastFunction.body = lastParsedBlock
                            } else {
                                lastFunction.body = BlockNode.new()
                            }
                            applyPendingFunctionParamTypes()
                            if resolvedReturnTypeNameInto != "Unknown" {
                                lastParsedTypeName = resolvedReturnTypeNameInto
                                lastParsedTypeNullable = resolvedReturnTypeNullableInto
                                lastFunction.returnType = parsedScratchTypeNode()
                            }
                            let method = lastFunction
                            method.isStatic = true
                            classNode.methods.push(method)
                        }
                        classIntoTokenHandled = true
                    }
                }
                // Check for 'override' prefix
                if not classIntoTokenHandled {
                    if matchTokenStr(SeenTokenType.KeywordOverride) {
                        sawOverrideInto = 1
                    }
                }
                // Check for 'async' prefix (still uses KeywordAsync token)
                if not classIntoTokenHandled {
                    if matchTokenStr(SeenTokenType.KeywordAsync) {
                        sawAsyncInto = 1
                    }
                }
                // Check for 'fun' (instance method)
                // NOTE: Use nested if instead of 'and' to ensure short-circuit (Stage1 bug workaround)
                if not classIntoTokenHandled {
                    if matchTokenStr(SeenTokenType.KeywordFun) {
                        // Inline parse using lastFunction field to avoid memory corruption
                        // Handle 'operator' keyword or normal identifier as method name
                        var methodNameStr = ""
                        if checkToken(SeenTokenType.KeywordOperator) {
                            advance()
                            methodNameStr = "operator"
                        } else {
                            let methodNameTokInto2 = consume(SeenTokenType.Identifier, "Expected method name")
                            methodNameStr = methodNameTokInto2.getValue()
                        }
                        if methodNameStr == "operator" {
                            if matchTokenStr(SeenTokenType.Plus) { methodNameStr = "operator_add" }
                            if methodNameStr == "operator" and matchTokenStr(SeenTokenType.Minus) { methodNameStr = "operator_sub" }
                            if methodNameStr == "operator" and matchTokenStr(SeenTokenType.Multiply) { methodNameStr = "operator_mul" }
                            if methodNameStr == "operator" and matchTokenStr(SeenTokenType.Divide) { methodNameStr = "operator_div" }
                            if methodNameStr == "operator" and matchTokenStr(SeenTokenType.Modulo) { methodNameStr = "operator_mod" }
                            if methodNameStr == "operator" and matchTokenStr(SeenTokenType.EqualEqual) { methodNameStr = "operator_eq" }
                            if methodNameStr == "operator" and matchTokenStr(SeenTokenType.NotEqual) { methodNameStr = "operator_neq" }
                            if methodNameStr == "operator" and matchTokenStr(SeenTokenType.LessThan) { methodNameStr = "operator_lt" }
                            if methodNameStr == "operator" and matchTokenStr(SeenTokenType.GreaterThan) { methodNameStr = "operator_gt" }
                            if methodNameStr == "operator" and matchTokenStr(SeenTokenType.LessEqual) { methodNameStr = "operator_lte" }
                            if methodNameStr == "operator" and matchTokenStr(SeenTokenType.GreaterEqual) { methodNameStr = "operator_gte" }
                        }
                        lastFunction = FunctionNode.new()
                        clearPendingFunctionReturnType()
                        clearPendingFunctionParamTypes()
                        lastFunction.name = methodNameStr
                        // Skip generic type parameters: fun name<T: Ord>(...)
                        if checkToken(SeenTokenType.LessThan) {
                            advance()
                            var gd = 1
                            while gd > 0 and not isAtEnd() {
                                if checkToken(SeenTokenType.LessThan) { gd = gd + 1 }
                                if checkToken(SeenTokenType.GreaterThan) { gd = gd - 1 }
                                advance()
                            }
                        }
                        applyDecoratorsToFunction()
                        parseParameterListField()
                        var resolvedReturnTypeNameInto2 = pendingFunctionReturnTypeName
                        var resolvedReturnTypeNullableInto2 = pendingFunctionReturnTypeNullable
                        parseOptionalReturnTypeIntoScratch()
                        if lastParsedTypeName != "Unknown" {
                            resolvedReturnTypeNameInto2 = lastParsedTypeName
                            resolvedReturnTypeNullableInto2 = lastParsedTypeNullable
                        }
                        if matchTokenStr(SeenTokenType.LeftBrace) {
                            parseBlockIntoField()
                            lastFunction.body = lastParsedBlock
                        } else {
                            lastFunction.body = BlockNode.new()
                        }
                        applyPendingFunctionParamTypes()
                        if resolvedReturnTypeNameInto2 != "Unknown" {
                            lastParsedTypeName = resolvedReturnTypeNameInto2
                            lastParsedTypeNullable = resolvedReturnTypeNullableInto2
                            lastFunction.returnType = parsedScratchTypeNode()
                        }
                        let method = lastFunction
                        method.isStatic = false
                        if sawOverrideInto == 1 {
                            method.isOverride = true
                        }
                        if sawAsyncInto == 1 {
                            method.isAsync = true
                        }
                        classNode.methods.push(method)
                        classIntoTokenHandled = true
                    }
                }
                // Accept bare field: identifier: Type (without var/let keyword)
                if not classIntoTokenHandled {
                    if checkToken(SeenTokenType.Identifier) {
                        let curTokVal = peek().getValue()
                        if curTokVal != "r" and curTokVal != "seen_std.builtins.r" and curTokVal != "this" {
                            let nextTok = peekAt(1)
                            if nextTok.getType() == SeenTokenType.Colon {
                                let bareFieldName = advance()
                                consume(SeenTokenType.Colon, "Expected ':'")
                                let bareFieldType = parseTypeNode()
                                // : Bit field syntax
                                if checkToken(SeenTokenType.Colon) {
                                    advance()
                                    if checkToken(SeenTokenType.IntegerLiteral) {
                                        let bitWInto2 = advance().getValue()
                                        bareFieldType.typeName = bareFieldType.typeName + ":bitfield(" + bitWInto2 + ")"
                                    }
                                }
                                let bareField = ParamNode.new()
                                bareField.name = bareFieldName.getValue()
                                bareField.paramType = bareFieldType
                                classNode.fields.push(bareField)
                                if matchTokenStr(SeenTokenType.Semicolon) { }
                                if matchTokenStr(SeenTokenType.Comma) { }
                                classIntoTokenHandled = true
                            }
                        }
                    }
                }
                // : Associated types: type Name = ConcreteType
                if not classIntoTokenHandled {
                    if matchTokenStr(SeenTokenType.KeywordType) {
                        if checkToken(SeenTokenType.Identifier) {
                            let assocTNameInto = advance().getValue()
                            if matchTokenStr(SeenTokenType.Assign) {
                                let assocTTargetInto = parseTypeNode()
                                let assocFieldInto = ParamNode.new()
                                assocFieldInto.name = "@type_alias:" + assocTNameInto
                                assocFieldInto.paramType = assocTTargetInto
                                classNode.fields.push(assocFieldInto)
                            }
                        }
                        if matchTokenStr(SeenTokenType.Semicolon) { }
                        classIntoTokenHandled = true
                    }
                }
                if not classIntoTokenHandled {
                    advance()
                }
            }
            consume(SeenTokenType.RightBrace, "Expected '}' after class body")
        }

        // Push directly to currentProgram instead of returning
        currentProgram.items.push(ItemNode{
            itemType: "Class",
            name: classNode.name,
            visibility: inferVisibility(classNode.name),
            importPath: Array<String>(),
            importSymbols: Array<ImportSymbolNode>(),
            function: FunctionNode.new(),
            classNode: classNode,
            enumNode: EnumNode.new()
        })
        // trace
    }

    fun parseDataStructItemInto() r: Void {
        if isAtEnd() { return }
        let nameToken = consume(SeenTokenType.Identifier, "Expected struct name")
        let classNode = ClassNode.new()
        classNode.name = nameToken.getValue()
        applyPendingTypeModifiersToClass(classNode)

        // Skip optional generic params <T, U>
        if checkToken(SeenTokenType.LessThan) {
            advance()
            var gd = 1
            while gd > 0 and not isAtEnd() {
                if checkToken(SeenTokenType.LessThan) { gd = gd + 1 }
                if checkToken(SeenTokenType.GreaterThan) { gd = gd - 1 }
                advance()
            }
        }

        // Parse parenthesized field list: (name: Type, ...)
        if matchTokenStr(SeenTokenType.LeftParen) {
            while not checkToken(SeenTokenType.RightParen) and not isAtEnd() {
                let fn = consume(SeenTokenType.Identifier, "Expected field name")
                consume(SeenTokenType.Colon, "Expected ':' after field name")
                let ft = parseTypeNode()
                let f = ParamNode.new()
                f.name = fn.getValue()
                f.paramType = ft
                classNode.fields.push(f)
                if not matchTokenStr(SeenTokenType.Comma) { break }
            }
            consume(SeenTokenType.RightParen, "Expected ')'")
        }
        if matchTokenStr(SeenTokenType.Semicolon) { }

        currentProgram.items.push(ItemNode{
            itemType: "Class", name: classNode.name,
            visibility: inferVisibility(classNode.name),
            importPath: Array<String>(),
            importSymbols: Array<ImportSymbolNode>(),
            function: FunctionNode.new(),
            classNode: classNode, enumNode: EnumNode.new()
        })
    }

    fun parseEnumItem() r: ItemNode {
        if isAtEnd() {
            return ItemNode.new()
        }

        if pendingSealedModifier == 1 {
            pendingSealedModifier = 0
        }

        let nameToken = consume(SeenTokenType.Identifier, "Expected enum name")
        let enumNode = EnumNode.new()
        enumNode.name = nameToken.getValue()

        // Parse enum variants inside braces
        if matchTokenStr(SeenTokenType.LeftBrace) {
            while not checkToken(SeenTokenType.RightBrace) and not isAtEnd() {
                if checkToken(SeenTokenType.Identifier) {
                    let variant = advance().getValue()
                    enumNode.variants.push(variant)
                }
                // Skip comma if present
                if matchTokenStr(SeenTokenType.Comma) {
                    // continue
                }
            }
            consume(SeenTokenType.RightBrace, "Expected '}' after enum variants")
        }

        let item = ItemNode.new()
        item.itemType = "Enum"
        item.name = enumNode.name
        item.visibility = inferVisibility(enumNode.name)
        item.enumNode = enumNode

        return item
    }

    // Parse an enum declaration (enum Name { Variant1, Variant2, ... }) and
    // push it into currentProgram.  Variants are plain identifiers collected
    // into EnumNode.variants.
    fun parseEnumItemInto() r: Void {
        if isAtEnd() {
            return
        }

        if pendingSealedModifier == 1 {
            pendingSealedModifier = 0
        }

        let nameToken = consume(SeenTokenType.Identifier, "Expected enum name")
        let enumNode = EnumNode.new()
        enumNode.name = nameToken.getValue()

        // Parse enum variants inside braces
        if matchTokenStr(SeenTokenType.LeftBrace) {
            while not checkToken(SeenTokenType.RightBrace) and not isAtEnd() {
                if checkToken(SeenTokenType.Identifier) {
                    let variant = advance().getValue()
                    enumNode.variants.push(variant)
                }
                if matchTokenStr(SeenTokenType.Comma) {
                    // continue
                }
            }
            consume(SeenTokenType.RightBrace, "Expected '}' after enum variants")
        }

        // Push directly to currentProgram instead of returning
        currentProgram.items.push(ItemNode{
            itemType: "Enum",
            name: enumNode.name,
            visibility: inferVisibility(enumNode.name),
            importPath: Array<String>(),
            importSymbols: Array<ImportSymbolNode>(),
            function: FunctionNode.new(),
            classNode: ClassNode.new(),
            enumNode: enumNode
        })
    }

    fun skipOptionalFunctionBody() r: Void {
        if matchTokenStr(SeenTokenType.LeftBrace) {
            var depth = 1
            while depth > 0 and not isAtEnd() {
                var braceHandled = false
                if matchTokenStr(SeenTokenType.LeftBrace) {
                    depth = depth + 1
                    braceHandled = true
                }
                if not braceHandled and matchTokenStr(SeenTokenType.RightBrace) {
                    depth = depth - 1
                    braceHandled = true
                }
                if not braceHandled {
                    advance()
                }
            }
        }
    }

    fun parseParameterList(func: FunctionNode) r: Void {
        if not matchTokenStr(SeenTokenType.LeftParen) {
            return
        }

        if checkToken(SeenTokenType.RightParen) {
            advance()
            return
        }

        while not isAtEnd() {
            // Check for variadic '...' as final parameter
            if checkToken(SeenTokenType.Ellipsis) {
                advance()
                let variadicAnn = AnnotationNode.new("variadic")
                func.decorators.push(variadicAnn)
                consume(SeenTokenType.RightParen, "Expected ')' after '...'")
                return
            }

            let param = parseParam()
            if (param.name == "r" or param.name == "seen_std.builtins.r") and param.paramType.typeName != "Unknown" {
                func.returnType = param.paramType
            } else if param.name != "" {
                func.params.push(param)
            }

            if matchTokenStr(SeenTokenType.Comma) {
                continue
            }

            consume(SeenTokenType.RightParen, "Expected ')' after parameters")
            break
        }
    }

    fun parseParam() r: ParamNode {
        // Check for move/borrow ownership qualifier before parameter name
        var ownership = ""
        if matchNameValue("move") {
            ownership = "move"
        }
        if ownership == "" and matchNameValue("borrow") {
            ownership = "borrow"
        }
        if not checkNameLikeToken() {
            return ParamNode.new()
        }
        let nameToken = advance()

        var paramRawName = nameToken.getValue()
        // Remap 'self' to 'this' (alias for this-pointer in method declarations)
        if paramRawName == "self" { paramRawName = "this" }
        let param = ParamNode.new()
        param.name = paramRawName
        let parsedParamType = parseOptionalTypeAnnotation()
        var paramTypeName = parsedParamType.typeName

        // Encode ownership in type string prefix for downstream passes
        if ownership != "" and paramTypeName != "" {
            paramTypeName = ownership + ":" + paramTypeName
        }

        // Capture default values in type name suffix
        if matchTokenStr(SeenTokenType.Equal) {
            let defVal = peek().getValue()
            paramTypeName = paramTypeName + "~default~" + defVal
            skipExpression()
        }

        param.paramType = typeNodeWithName(parsedParamType, paramTypeName)

        return param
    }

    fun parseOptionalTypeAnnotation() r: TypeNode {
        if !matchTokenStr(SeenTokenType.Colon) {
            let fallback = TypeNode.new()
            fallback.typeName = "Unknown"
            return fallback
        }

        return parseTypeNode()
    }

    fun parseOptionalReturnTypeIntoScratch() r: Void {
        // Seen uses "r: Type" syntax for return types
        // Check for identifier "r" followed by colon
        if checkToken(SeenTokenType.Identifier) {
            let tok = peek()
            if tok.getValue() == "r" or tok.getValue() == "seen_std.builtins.r" {
                advance() // consume "r"
                if matchTokenStr(SeenTokenType.Colon) {
                    parseTypeNodeIntoScratch()
                    return
                }
            }
        }
        // Also support arrow syntax for compatibility
        if matchTokenStr(SeenTokenType.Arrow) {
            parseTypeNodeIntoScratch()
            return
        }
        // Support colon return type syntax: fun foo(): Int { ... }
        if matchTokenStr(SeenTokenType.Colon) {
            parseTypeNodeIntoScratch()
            return
        }
        lastParsedTypeName = "Unknown"
        lastParsedTypeNullable = false
    }

    fun parseOptionalReturnType() r: TypeNode {
        parseOptionalReturnTypeIntoScratch()
        return parsedScratchTypeNode()
    }

    fun parsedScratchTypeNode() r: TypeNode {
        return TypeNode{ typeName: lastParsedTypeName, isNullable: lastParsedTypeNullable }
    }

    fun formatTypeNodeForTrace(typeNode: TypeNode) r: String {
        if typeNode.typeName == "" {
            return ""
        }
        if typeNode.isNullable {
            return typeNode.typeName + "?"
        }
        return typeNode.typeName
    }

    fun formatParamListForTrace(params: Array<ParamNode>) r: String {
        var summary = ""
        var idx = 0
        while idx < params.length() {
            if idx > 0 {
                summary = summary + ", "
            }
            let param = params[idx]
            summary = summary + param.name + ":" + formatTypeNodeForTrace(param.paramType)
            idx = idx + 1
        }
        return summary
    }

    fun traceParsedFunctionShape(source: String, fn: FunctionNode) r: Void {
        if not isParserTracingEnabled() {
            return
        }

        var msg = source + " name=" + fn.name
        msg = msg + " params=[" + formatParamListForTrace(fn.params) + "]"
        msg = msg + " return=" + formatTypeNodeForTrace(fn.returnType)
        msg = msg + " body=" + fn.body.statements.length().toString()

        if fn.body.statements.length() > 0 {
            let firstStmt = fn.body.statements[0]
            msg = msg + " first=" + firstStmt.kind
            if firstStmt.returnValue.kind != "" and firstStmt.returnValue.kind != "None" {
                msg = msg + " ret=" + firstStmt.returnValue.kind
            }
            if firstStmt.expression.kind != "" and firstStmt.expression.kind != "None" {
                msg = msg + " expr=" + firstStmt.expression.kind
            }
        }

        traceParse(msg)
        return
    }

    fun typeNodeWithName(baseType: TypeNode, typeName: String) r: TypeNode {
        return TypeNode{ typeName: typeName, isNullable: baseType.isNullable }
    }

    fun clearPendingFunctionReturnType() r: Void {
        pendingFunctionReturnTypeName = "Unknown"
        pendingFunctionReturnTypeNullable = false
    }

    fun clearPendingFunctionParamTypes() r: Void {
        pendingFunctionParamTypeNames = Array<String>()
        pendingFunctionParamTypeNullables = Array<Int>()
    }

    fun capturePendingFunctionReturnTypeFromScratch() r: Void {
        pendingFunctionReturnTypeName = lastParsedTypeName
        pendingFunctionReturnTypeNullable = lastParsedTypeNullable
    }

    fun addPendingFunctionParamType(typeName: String, isNullable: Bool) r: Void {
        pendingFunctionParamTypeNames.push(typeName)
        if isNullable {
            pendingFunctionParamTypeNullables.push(1)
        } else {
            pendingFunctionParamTypeNullables.push(0)
        }
    }

    fun applyPendingFunctionParamTypes() r: Void {
        var paramIdx = 0
        while paramIdx < lastFunction.params.length() and paramIdx < pendingFunctionParamTypeNames.length() {
            let param = lastFunction.params[paramIdx]
            lastParsedTypeName = pendingFunctionParamTypeNames[paramIdx]
            lastParsedTypeNullable = pendingFunctionParamTypeNullables[paramIdx] != 0
            param.paramType = parsedScratchTypeNode()
            paramIdx = paramIdx + 1
        }
    }

    fun applyPendingFunctionReturnTypeToLastFunction() r: Void {
        if pendingFunctionReturnTypeName == "Unknown" {
            return
        }
        lastParsedTypeName = pendingFunctionReturnTypeName
        lastParsedTypeNullable = pendingFunctionReturnTypeNullable
        lastFunction.returnType = parsedScratchTypeNode()
    }

    // Parse a type annotation into scratch fields.
    fun parseTypeNodeIntoScratch() r: Void {
        lastParsedTypeName = "Unknown"
        lastParsedTypeNullable = false

        var typeName = "Unknown"

        var typeIdentFound = false

        // : Raw pointer type: *T or *const T
        if checkToken(SeenTokenType.Multiply) {
            advance()
            var ptrPrefix = "*"
            if checkToken(SeenTokenType.KeywordConst) {
                advance()
                ptrPrefix = "*const "
            }
            parseTypeNodeIntoScratch()
            typeName = ptrPrefix + lastParsedTypeName
            typeIdentFound = true
        }

        if not typeIdentFound and checkToken(SeenTokenType.Identifier) {
            let token = advance()
            var name = token.getValue()

            // : dyn Trait — dynamic dispatch
            if name == "dyn" and checkToken(SeenTokenType.Identifier) {
                parseTypeNodeIntoScratch()
                typeName = "dyn " + lastParsedTypeName
                typeIdentFound = true
            }

            if not typeIdentFound {
                // Support qualified names
                while matchTokenStr(SeenTokenType.Dot) {
                    var dotIdentHandled = false
                    if checkToken(SeenTokenType.Identifier) {
                        name = name + "." + advance().getValue()
                        dotIdentHandled = true
                    }
                    if not dotIdentHandled {
                        break
                    }
                }
                // Parse generic parameters <...> and include them in the name
                if matchTokenStr(SeenTokenType.LessThan) {
                    name = name + "<"
                    var depth = 1
                    while depth > 0 and not isAtEnd() {
                        var genericTokenHandled = false
                        if checkToken(SeenTokenType.LessThan) {
                            name = name + "<"
                            advance()
                            depth = depth + 1
                            genericTokenHandled = true
                        }
                        if not genericTokenHandled and checkToken(SeenTokenType.GreaterThan) {
                            name = name + ">"
                            advance()
                            depth = depth - 1
                            genericTokenHandled = true
                        }
                        if not genericTokenHandled and checkToken(SeenTokenType.Identifier) {
                            // : const generic — recognize integer literals inside generic params
                            name = name + advance().getValue()
                            genericTokenHandled = true
                        }
                        if not genericTokenHandled and checkToken(SeenTokenType.Comma) {
                            name = name + ","
                            advance()
                            genericTokenHandled = true
                        }
                        if not genericTokenHandled and checkToken(SeenTokenType.IntegerLiteral) {
                            // : const generic integer parameter (e.g. Grid<Int,8,8>)
                            name = name + advance().getValue()
                            genericTokenHandled = true
                        }
                        if not genericTokenHandled and checkToken(SeenTokenType.Colon) {
                            // : const generic constraint colon (e.g. <const N: Int>)
                            name = name + ":"
                            advance()
                            genericTokenHandled = true
                        }
                        if not genericTokenHandled and checkToken(SeenTokenType.KeywordConst) {
                            // : const keyword in generic params
                            name = name + "const "
                            advance()
                            genericTokenHandled = true
                        }
                        if not genericTokenHandled {
                            advance()
                        }
                    }
                }
                // : Buffer[T], Uniform[T], Image[T] — GPU types with square bracket syntax
                // : SmallVec[T, N] — inline storage with square bracket syntax
                if (name == "Buffer" or name == "Uniform" or name == "Image" or name == "SmallVec") and checkToken(SeenTokenType.LeftBracket) {
                    advance()
                    parseTypeNodeIntoScratch()
                    var bracketTypeStr = lastParsedTypeName
                    // SmallVec[T, N] — also parse the capacity after comma
                    if name == "SmallVec" and checkToken(SeenTokenType.Comma) {
                        advance()
                        parseTypeNodeIntoScratch()
                        bracketTypeStr = bracketTypeStr + ", " + lastParsedTypeName
                    }
                    name = name + "<" + bracketTypeStr + ">"
                    if checkToken(SeenTokenType.RightBracket) {
                        advance()
                    }
                }
                typeName = name
                typeIdentFound = true
            }
        }
        if not typeIdentFound {
            typeName = "Unknown"
        }

        // T? is sugar for Option<T>
        if matchTokenStr(SeenTokenType.Question) {
            lastParsedTypeNullable = true
            typeName = "Option<" + typeName + ">"
        }

        // : T ! ErrorType → Result<T, ErrorType>
        if checkToken(SeenTokenType.LogicalNot) {
            advance()
            let leftTypeName = typeName
            parseTypeNodeIntoScratch()
            typeName = "Result<" + leftTypeName + "," + lastParsedTypeName + ">"
        }

        // : Type | Type → ErrorUnion
        if checkToken(SeenTokenType.BitwiseOr) {
            var unionTypes = typeName
            while checkToken(SeenTokenType.BitwiseOr) {
                advance()
                parseTypeNodeIntoScratch()
                unionTypes = unionTypes + "|" + lastParsedTypeName
            }
            typeName = "ErrorUnion<" + unionTypes + ">"
        }

        lastParsedTypeName = typeName
    }

    // Parse a type annotation and return a TypeNode.
    // Handles: simple names, qualified names (A.B), generic parameters (Map<K,V>),
    // raw pointers (*T, *const T), nullable (T?), Result sugar (T ! E),
    // ErrorUnion (A | B), dyn Trait, const generics, and GPU types with
    // square-bracket syntax (Buffer[T], SmallVec[T, N]).
    fun parseTypeNode() r: TypeNode {
        parseTypeNodeIntoScratch()
        return parsedScratchTypeNode()
    }

    // Parse a brace-delimited block of statements.  The opening `{` has
    // already been consumed by the caller; this method consumes statements
    // until `}` and returns the populated BlockNode.
    //
    // Saves and restores `currentBlock` and `lastStatement` so that nested
    // blocks (e.g. if-inside-while) do not clobber the outer parse state.
    fun parseBlockIntoField() r: Void {
        if blockStackDepth >= blockStack.length() {
            blockStack.push(currentBlock)
            statementStack.push(lastStatement)
        } else {
            blockStack[blockStackDepth] = currentBlock
            statementStack[blockStackDepth] = lastStatement
        }
        blockStackDepth = blockStackDepth + 1
        currentBlock = BlockNode.new()
        var loopCount = 0
        while not checkToken(SeenTokenType.RightBrace) and not isAtEnd() {
            loopCount = loopCount + 1
            if loopCount > 1000 {
                println("[ERROR] parseBlock: too many iterations (>1000), breaking")
                break
            }
            // Parse statement directly into currentBlock to avoid returning StatementNode
            parseStatementInto()
        }
        consume(SeenTokenType.RightBrace, "Expected '}' after block")
        lastParsedBlock = currentBlock
        let restoreIndex = blockStackDepth - 1
        currentBlock = blockStack[restoreIndex]
        lastStatement = statementStack[restoreIndex]
        blockStackDepth = restoreIndex
    }

    fun parseBlock() r: BlockNode {
        parseBlockIntoField()
        return lastParsedBlock
    }

    // Parse one statement and push it into `currentBlock`.
    // Dispatches on the leading keyword token to the appropriate handler.
    // Falls through to parseExpressionStatementField() if no keyword matches.
    //
    // Uses the lastStatement class field as a scratch buffer (filled in by
    // the *Field() helpers) to avoid returning StatementNode by value, which
    // the stage1 bootstrap compiler miscompiles.
    fun parseStatementInto() r: Void {
        lastStatement = StatementNode.new()

        if matchTokenStr(SeenTokenType.KeywordLet) {
            parseLetStatementField()
            currentBlock.statements.push(lastStatement)
            return
        }
        // 'const' treated as 'let' in statement context
        if matchTokenStr(SeenTokenType.KeywordConst) {
            parseLetStatementField()
            currentBlock.statements.push(lastStatement)
            return
        }
        if matchTokenStr(SeenTokenType.KeywordVar) {
            parseVarStatementField()
            currentBlock.statements.push(lastStatement)
            return
        }
        if matchTokenStr(SeenTokenType.KeywordReturn) {
            parseReturnStatementField()
            currentBlock.statements.push(lastStatement)
            return
        }
        if matchTokenStr(SeenTokenType.KeywordIf) {
            parseIfStatementField()
            currentBlock.statements.push(lastStatement)
            return
        }
        if matchTokenStr(SeenTokenType.KeywordWhile) {
            parseStableWhileStatementField()
            currentBlock.statements.push(lastStatement)
            return
        }
        if matchTokenStr(SeenTokenType.KeywordLoop) {
            lastStatement.kind = "While"
            lastStatement.loopCondition = makeLiteral("true", "Bool")
            consume(SeenTokenType.LeftBrace, "Expected '{' after loop")
            parseBlockIntoField()
            lastStatement.loopBody = lastParsedBlock
            currentBlock.statements.push(lastStatement)
            return
        }
        if checkToken(SeenTokenType.Identifier) and peek().getValue() == "parallel_for" {
            advance()  // consume 'parallel_for'
            parseParallelForStatementField()
            currentBlock.statements.push(lastStatement)
            return
        }
        if matchTokenStr(SeenTokenType.KeywordFor) {
            parseForInStatementField()
            currentBlock.statements.push(lastStatement)
            return
        }
        // Comptime block/assert/if (parsed as identifier to avoid keyword loading fragility)
        if checkToken(SeenTokenType.Identifier) and peek().getValue() == "comptime" {
            advance()  // consume 'comptime'
            parseComptimeStatementField()
            currentBlock.statements.push(lastStatement)
            return
        }
        // Continue statement
        if matchTokenStr(SeenTokenType.KeywordContinue) {
            lastStatement.kind = "Continue"
            if matchTokenStr(SeenTokenType.Semicolon) { }
            currentBlock.statements.push(lastStatement)
            return
        }
        // Break statement
        if matchTokenStr(SeenTokenType.KeywordBreak) {
            lastStatement.kind = "Break"
            if matchTokenStr(SeenTokenType.Semicolon) { }
            currentBlock.statements.push(lastStatement)
            return
        }
        // Region block statement
        if checkToken(SeenTokenType.KeywordRegion) {
            advance()
            let regionStmt = parseRegionStatement()
            currentBlock.statements.push(regionStmt)
            return
        }
        // unsafe block: consume keyword, parse body, set kind to "Unsafe"
        if matchTokenStr(SeenTokenType.KeywordUnsafe) {
            lastStatement.kind = "Unsafe"
            if matchTokenStr(SeenTokenType.LeftBrace) {
                let unsafeBlock2 = BlockNode.new()
                while not checkToken(SeenTokenType.RightBrace) and not isAtEnd() {
                    let innerUnsafeStmt = parseStatement()
                    unsafeBlock2.statements.push(innerUnsafeStmt)
                }
                consume(SeenTokenType.RightBrace, "Expected '}' after unsafe block")
                lastStatement.thenBranch = unsafeBlock2
            }
            return
        }
        // defer statement: consume keyword, parse expression/block
        if matchTokenStr(SeenTokenType.KeywordDefer) {
            lastStatement.kind = "Defer"
            if checkToken(SeenTokenType.LeftBrace) {
                advance()
                let deferBlock = BlockNode.new()
                while not checkToken(SeenTokenType.RightBrace) and not isAtEnd() {
                    let deferStmt = parseStatement()
                    deferBlock.statements.push(deferStmt)
                }
                consume(SeenTokenType.RightBrace, "Expected '}' after defer block")
                lastStatement.thenBranch = deferBlock
            } else {
                parseExpressionInto(lastStatement.expression)
            }
            if matchTokenStr(SeenTokenType.Semicolon) { }
            currentBlock.statements.push(lastStatement)
            return
        }
        // errdefer statement: like defer but only runs on error returns
        if matchTokenStr(SeenTokenType.KeywordErrdefer) {
            lastStatement.kind = "Errdefer"
            if checkToken(SeenTokenType.LeftBrace) {
                advance()
                let errdeferBlock = BlockNode.new()
                while not checkToken(SeenTokenType.RightBrace) and not isAtEnd() {
                    let errdeferStmt = parseStatement()
                    errdeferBlock.statements.push(errdeferStmt)
                }
                consume(SeenTokenType.RightBrace, "Expected '}' after errdefer block")
                lastStatement.thenBranch = errdeferBlock
            } else {
                parseExpressionInto(lastStatement.expression)
            }
            if matchTokenStr(SeenTokenType.Semicolon) { }
            currentBlock.statements.push(lastStatement)
            return
        }
        // Throw statement (treated like expression statement but with throw keyword consumed)
        if matchTokenStr(SeenTokenType.KeywordThrow) {
            lastStatement.kind = "Throw"
            parseExpressionInto(lastStatement.expression)
            if matchTokenStr(SeenTokenType.Semicolon) { }
            currentBlock.statements.push(lastStatement)
            return
        }
        // Expression statement
        parseExpressionStatementField()
        currentBlock.statements.push(lastStatement)
    }

    fun parseStatement() r: StatementNode {
        let stmtTok = peek()
        // trace.toString() + " value=" + stmtTok.getValue())
        if matchTokenStr(SeenTokenType.KeywordLet) { return parseLetStatement() }
        // 'const' treated as 'let' in statement context
        if checkToken(SeenTokenType.Identifier) {
            if peek().getValue() == "const" {
                advance()   // consume 'const'
                return parseLetStatement()
            }
        }
        if matchTokenStr(SeenTokenType.KeywordVar) { return parseVarStatement() }
        if matchTokenStr(SeenTokenType.KeywordReturn) {
            // trace
            return parseReturnStatement()
        }
        if matchTokenStr(SeenTokenType.KeywordIf) { return parseIfStatement() }
        if matchTokenStr(SeenTokenType.KeywordWhile) { return parseStableWhileStatement() }
        if matchTokenStr(SeenTokenType.KeywordLoop) {
            let stmt = StatementNode.new()
            stmt.kind = "While"
            stmt.loopCondition = makeLiteral("true", "Bool")
            consume(SeenTokenType.LeftBrace, "Expected '{' after loop")
            parseBlockIntoField()
            stmt.loopBody = lastParsedBlock
            return stmt
        }
        if checkToken(SeenTokenType.Identifier) and peek().getValue() == "parallel_for" {
            advance()  // consume 'parallel_for'
            return parseParallelForStatement()
        }
        if matchTokenStr(SeenTokenType.KeywordFor) { return parseForInStatement() }
        // comptime block/assert/if (parsed as identifier to avoid keyword loading fragility)
        if checkToken(SeenTokenType.Identifier) and peek().getValue() == "comptime" {
            advance()  // consume 'comptime'
            return parseComptimeStatement()
        }
        // try/catch block
        if matchTokenStr(SeenTokenType.KeywordTry) {
            let tryStmt = StatementNode.new()
            tryStmt.kind = "TryCatch"
            if matchTokenStr(SeenTokenType.LeftBrace) {
                parseBlockIntoField()
                tryStmt.thenBranch = lastParsedBlock
            } else {
                tryStmt.thenBranch = BlockNode.new()
            }
            if matchTokenStr(SeenTokenType.KeywordCatch) {
                // Optional catch variable binding: catch (e) { ... } or catch { ... }
                if matchTokenStr(SeenTokenType.LeftParen) {
                    if checkToken(SeenTokenType.Identifier) {
                        tryStmt.variableName = advance().getValue()
                    }
                    consume(SeenTokenType.RightParen, "Expected ')' after catch variable")
                }
                if matchTokenStr(SeenTokenType.LeftBrace) {
                    parseBlockIntoField()
                    tryStmt.elseBranch = lastParsedBlock
                } else {
                    tryStmt.elseBranch = BlockNode.new()
                }
            } else {
                tryStmt.elseBranch = BlockNode.new()
            }
            return tryStmt
        }
        if matchTokenStr(SeenTokenType.KeywordContinue) {
            let stmt = StatementNode.new()
            stmt.kind = "Continue"
            if matchTokenStr(SeenTokenType.Semicolon) { }
            return stmt
        }
        if matchTokenStr(SeenTokenType.KeywordBreak) {
            let stmt = StatementNode.new()
            stmt.kind = "Break"
            if matchTokenStr(SeenTokenType.Semicolon) { }
            return stmt
        }
        if checkToken(SeenTokenType.KeywordRegion) {
            advance()
            return parseRegionStatement()
        }
        // unsafe block in parseStatement
        if matchTokenStr(SeenTokenType.KeywordUnsafe) {
            let unsafeStmt = StatementNode.new()
            unsafeStmt.kind = "Unsafe"
            if matchTokenStr(SeenTokenType.LeftBrace) {
                let unsafeBlock = BlockNode.new()
                while not checkToken(SeenTokenType.RightBrace) and not isAtEnd() {
                    let innerStmt = parseStatement()
                    unsafeBlock.statements.push(innerStmt)
                }
                consume(SeenTokenType.RightBrace, "Expected '}' after unsafe block")
                unsafeStmt.thenBranch = unsafeBlock
            }
            return unsafeStmt
        }
        // defer statement in parseStatement
        if matchTokenStr(SeenTokenType.KeywordDefer) {
            let deferStmt = StatementNode.new()
            deferStmt.kind = "Defer"
            if checkToken(SeenTokenType.LeftBrace) {
                advance()
                let deferBlock = BlockNode.new()
                while not checkToken(SeenTokenType.RightBrace) and not isAtEnd() {
                    let innerStmt = parseStatement()
                    deferBlock.statements.push(innerStmt)
                }
                consume(SeenTokenType.RightBrace, "Expected '}' after defer block")
                deferStmt.thenBranch = deferBlock
            } else {
                deferStmt.expression = parseExpression()
            }
            if matchTokenStr(SeenTokenType.Semicolon) { }
            return deferStmt
        }
        // errdefer statement in parseStatement
        if matchTokenStr(SeenTokenType.KeywordErrdefer) {
            let errdeferStmt = StatementNode.new()
            errdeferStmt.kind = "Errdefer"
            if checkToken(SeenTokenType.LeftBrace) {
                advance()
                let errdeferBlock2 = BlockNode.new()
                while not checkToken(SeenTokenType.RightBrace) and not isAtEnd() {
                    let innerStmt2 = parseStatement()
                    errdeferBlock2.statements.push(innerStmt2)
                }
                consume(SeenTokenType.RightBrace, "Expected '}' after errdefer block")
                errdeferStmt.thenBranch = errdeferBlock2
            } else {
                errdeferStmt.expression = parseExpression()
            }
            if matchTokenStr(SeenTokenType.Semicolon) { }
            return errdeferStmt
        }

        // Expression statement
        return parseExpressionStatement()
    }

    fun parseLetStatement() r: StatementNode {
        let stmt = StatementNode.new()
        stmt.kind = "Let"
        let nameToken = consumeNameLike("Expected variable name")
        stmt.variableName = nameToken.getValue()

        if matchTokenStr(SeenTokenType.Colon) {
            stmt.variableType = parseTypeNode()
        }

        if matchTokenStr(SeenTokenType.Equal) {
            stmt.initializer = parseExpression()
        }

        if matchTokenStr(SeenTokenType.Semicolon) { }
        return stmt
    }

    fun parseVarStatement() r: StatementNode {
        let stmt = StatementNode.new()
        stmt.kind = "Var"
        let nameToken = consumeNameLike("Expected variable name")
        stmt.variableName = nameToken.getValue()

        if matchTokenStr(SeenTokenType.Colon) {
            stmt.variableType = parseTypeNode()
        }

        if matchTokenStr(SeenTokenType.Equal) {
            stmt.initializer = parseExpression()
        }

        if matchTokenStr(SeenTokenType.Semicolon) { }
        return stmt
    }

    // Parse region block: region [strategy] [name] { body }
    fun parseRegionStatement() r: StatementNode {
        let stmt = StatementNode.new()
        stmt.kind = "Region"
        // Optional strategy: bump, stack, cxl_near, cxl_far, auto, gpu
        // : gpu keyword — also accept KeywordGpu token
        if checkToken(SeenTokenType.KeywordGpu) {
            advance()
            stmt.variableType = TypeNode.new()
            stmt.variableType.typeName = "gpu"
            if checkToken(SeenTokenType.Identifier) {
                let nameVal = peek().getValue()
                advance()
                stmt.variableName = nameVal
            }
        }
        if stmt.variableType.typeName == "" and checkToken(SeenTokenType.Identifier) {
            let stratVal = peek().getValue()
            if stratVal == "bump" or stratVal == "stack" or stratVal == "auto" or stratVal == "cxl_near" or stratVal == "cxl_far" or stratVal == "gpu" {
                advance()
                stmt.variableType = TypeNode.new()
                stmt.variableType.typeName = stratVal
                // Optional name after strategy
                if checkToken(SeenTokenType.Identifier) {
                    let nameVal = peek().getValue()
                    advance()
                    stmt.variableName = nameVal
                }
            }
        }
        // Parse body block
        consume(SeenTokenType.LeftBrace, "Expected '{' after region")
        parseBlockIntoField()
        stmt.thenBranch = lastParsedBlock
        return stmt
    }

    // ========== Field methods - fill lastStatement class field (avoids local copy memory corruption) ==========

    fun parseLetStatementField() r: Void {
        // trace
        lastStatement.kind = "Let"
        // 'let mut x' → treat as 'var x' (mutable binding)
        if matchTokenStr(SeenTokenType.KeywordMut) {
            lastStatement.kind = "Var"
        }
        let nameToken = consumeNameLike("Expected variable name")
        lastStatement.variableName = nameToken.getValue()

        if matchTokenStr(SeenTokenType.Colon) {
            lastStatement.variableType = parseTypeNode()
        }

        if matchTokenStr(SeenTokenType.Equal) {
            parseExpressionInto(lastStatement.initializer)
        }

        if matchTokenStr(SeenTokenType.Semicolon) { }
        // trace
    }

    fun parseVarStatementField() r: Void {
        // trace
        lastStatement.kind = "Var"
        let nameToken = consumeNameLike("Expected variable name")
        lastStatement.variableName = nameToken.getValue()

        if matchTokenStr(SeenTokenType.Colon) {
            lastStatement.variableType = parseTypeNode()
        }

        if matchTokenStr(SeenTokenType.Equal) {
            parseExpressionInto(lastStatement.initializer)
        }

        if matchTokenStr(SeenTokenType.Semicolon) { }
        // trace
    }

    fun parseReturnStatementField() r: Void {
        // trace
        lastStatement.kind = "Return"
        if not checkToken(SeenTokenType.Semicolon) and not checkToken(SeenTokenType.RightBrace) {
            parseExpressionInto(lastStatement.returnValue)
        }
        if matchTokenStr(SeenTokenType.Semicolon) { }
        // trace
    }

    fun parseWhileStatementField() r: Void {
        lastStatement.kind = "While"
        parseExpressionInto(lastStatement.loopCondition)
        consume(SeenTokenType.LeftBrace, "Expected '{' after while condition")
        parseBlockIntoField()
        lastStatement.loopBody = lastParsedBlock
        return
    }

    fun parseForInStatementField() r: Void {
        lastStatement.kind = "ForIn"
        // Parse loop variable name -- store in variableName (reuse existing field)
        let varToken = consume(SeenTokenType.Identifier, "Expected loop variable name after 'for'")
        lastStatement.variableName = varToken.getValue()
        // Parse 'in' keyword
        consume(SeenTokenType.KeywordIn, "Expected 'in' after loop variable")
        // Parse iterable expression -- store in expression (reuse existing field)
        parseExpressionInto(lastStatement.expression)
        // Parse loop body -- store in loopBody (reuse existing field)
        consume(SeenTokenType.LeftBrace, "Expected '{' after for-in iterable")
        parseBlockIntoField()
        lastStatement.loopBody = lastParsedBlock
        return
    }

    // parallel_for varName in startExpr..endExpr { body }
    fun parseParallelForStatementField() r: Void {
        lastStatement.kind = "ParallelFor"
        let varToken = consume(SeenTokenType.Identifier, "Expected loop variable name after 'parallel_for'")
        lastStatement.variableName = varToken.getValue()
        consume(SeenTokenType.KeywordIn, "Expected 'in' after parallel_for variable")
        parseExpressionInto(lastStatement.expression)
        consume(SeenTokenType.LeftBrace, "Expected '{' after parallel_for range")
        parseBlockIntoField()
        lastStatement.loopBody = lastParsedBlock
        return
    }

    fun parseParallelForStatement() r: StatementNode {
        let stmt = StatementNode.new()
        stmt.kind = "ParallelFor"
        let varToken = consume(SeenTokenType.Identifier, "Expected loop variable name after 'parallel_for'")
        stmt.variableName = varToken.getValue()
        consume(SeenTokenType.KeywordIn, "Expected 'in' after parallel_for variable")
        stmt.expression = parseExpression()
        consume(SeenTokenType.LeftBrace, "Expected '{' after parallel_for range")
        parseBlockIntoField()
        stmt.loopBody = lastParsedBlock
        return stmt
    }

    // comptime { block } / comptime assert(cond, "msg") / comptime if (cond) { } else { }
    fun parseComptimeStatementField() r: Void {
        // Check if next is 'assert' (not activated as keyword — used as function name in compiler)
        if checkToken(SeenTokenType.Identifier) and peek().getValue() == "assert" {
            advance()  // consume 'assert'
            lastStatement.kind = "ComptimeAssert"
            consume(SeenTokenType.LeftParen, "Expected '(' after comptime assert")
            parseExpressionInto(lastStatement.expression)
            // Optional message argument stored in condition field
            if matchTokenStr(SeenTokenType.Comma) {
                parseExpressionInto(lastStatement.condition)
            }
            consume(SeenTokenType.RightParen, "Expected ')' after comptime assert")
            return
        }
        // Check if next is 'if'
        if matchTokenStr(SeenTokenType.KeywordIf) {
            lastStatement.kind = "ComptimeIf"
            parseExpressionInto(lastStatement.expression)
            consume(SeenTokenType.LeftBrace, "Expected '{' after comptime if condition")
            parseBlockIntoField()
            lastStatement.thenBranch = lastParsedBlock
            if matchTokenStr(SeenTokenType.KeywordElse) {
                consume(SeenTokenType.LeftBrace, "Expected '{' after else")
                parseBlockIntoField()
                lastStatement.elseBranch = lastParsedBlock
            }
            return
        }
        // Default: comptime { block }
        lastStatement.kind = "ComptimeBlock"
        consume(SeenTokenType.LeftBrace, "Expected '{' after comptime")
        parseBlockIntoField()
        lastStatement.thenBranch = lastParsedBlock
        return
    }

    fun parseComptimeStatement() r: StatementNode {
        let stmt = StatementNode.new()
        // Check if next is 'assert' (not activated as keyword — used as function name in compiler)
        if checkToken(SeenTokenType.Identifier) and peek().getValue() == "assert" {
            advance()  // consume 'assert'
            stmt.kind = "ComptimeAssert"
            consume(SeenTokenType.LeftParen, "Expected '(' after comptime assert")
            stmt.expression = parseExpression()
            // Optional message argument stored in condition field
            if matchTokenStr(SeenTokenType.Comma) {
                stmt.condition = parseExpression()
            }
            consume(SeenTokenType.RightParen, "Expected ')' after comptime assert")
            return stmt
        }
        // Check if next is 'if'
        if matchTokenStr(SeenTokenType.KeywordIf) {
            stmt.kind = "ComptimeIf"
            stmt.expression = parseExpression()
            consume(SeenTokenType.LeftBrace, "Expected '{' after comptime if condition")
            parseBlockIntoField()
            stmt.thenBranch = lastParsedBlock
            if matchTokenStr(SeenTokenType.KeywordElse) {
                consume(SeenTokenType.LeftBrace, "Expected '{' after else")
                parseBlockIntoField()
                stmt.elseBranch = lastParsedBlock
            }
            return stmt
        }
        // Default: comptime { block }
        stmt.kind = "ComptimeBlock"
        consume(SeenTokenType.LeftBrace, "Expected '{' after comptime")
        parseBlockIntoField()
        stmt.thenBranch = lastParsedBlock
        return stmt
    }

    fun parseExpressionStatementField() r: Void {
        lastStatement.kind = "Expression"
        parseExpressionInto(lastStatement.expression)
        if matchTokenStr(SeenTokenType.Semicolon) { }
        return
    }

    // Fill expression directly into a ParserExpressionNode field
    // NOTE: Moved before parseIfStatementField to avoid being skipped by parser bug
    fun parseExpressionIntoField(expr: ParserExpressionNode) r: Void {
        // trace
        let result = parseExpression()
        // trace
        // Copy all scalar fields
        expr.kind = result.kind
        expr.operator = result.operator
        expr.literalValue = result.literalValue
        expr.literalType = result.literalType
        expr.variableName = result.variableName
        expr.callee = result.callee
        // Don't copy arrays to avoid memory corruption
        // Copy arrays by iterating (avoids shared data pointer issues)
        // Actually skip this - most expressions don't need array data
        // trace
    }

    // Fills a ParserExpressionNode directly with parsed expression data
    // NOTE: Moved before parseIfStatementField to avoid being merged
    fun parseExpressionInto(expr: ParserExpressionNode) r: Void {
        // trace
        // Parse the expression and copy its fields
        let result = parseExpression()
        // trace
        // Copy all scalar fields
        expr.kind = result.kind
        expr.operator = result.operator
        expr.literalValue = result.literalValue
        expr.literalType = result.literalType
        expr.variableName = result.variableName
        expr.callee = result.callee
        // Copy arrays by iterating (avoids shared data pointer issues)
        let i = 0
        while i < result.operands.length() {
            expr.operands.push(result.operands[i])
            i = i + 1
        }
        let j = 0
        while j < result.arguments.length() {
            expr.arguments.push(result.arguments[j])
            j = j + 1
        }
        // trace
        return
    }

    // NOTE: parseIfStatementField moved to end of class to avoid method merging bug

    // ========== Into methods - fill passed objects instead of returning (avoids memory corruption) ==========

    fun parseLetStatementInto(stmt: StatementNode) r: Void {
        // trace
        stmt.kind = "Let"
        let nameToken = consumeNameLike("Expected variable name")
        stmt.variableName = nameToken.getValue()

        if matchTokenStr(SeenTokenType.Colon) {
            stmt.variableType = parseTypeNode()
        }

        if matchTokenStr(SeenTokenType.Equal) {
            parseExpressionInto(stmt.initializer)
        }

        if matchTokenStr(SeenTokenType.Semicolon) { }
        // trace
    }

    fun parseVarStatementInto(stmt: StatementNode) r: Void {
        // trace
        stmt.kind = "Var"
        let nameToken = consumeNameLike("Expected variable name")
        stmt.variableName = nameToken.getValue()

        if matchTokenStr(SeenTokenType.Colon) {
            stmt.variableType = parseTypeNode()
        }

        if matchTokenStr(SeenTokenType.Equal) {
            parseExpressionInto(stmt.initializer)
        }

        if matchTokenStr(SeenTokenType.Semicolon) { }
        // trace
    }

    fun parseReturnStatementInto(stmt: StatementNode) r: Void {
        // trace
        stmt.kind = "Return"
        // Avoid storing peek() result to prevent Token copy corruption
        if not checkToken(SeenTokenType.Semicolon) and not checkToken(SeenTokenType.RightBrace) {
            // trace
            parseExpressionInto(stmt.returnValue)
            // trace
        }
        if matchTokenStr(SeenTokenType.Semicolon) { }
        // trace
    }

    // NOTE: parseWhile and parseExpressionStatement moved before parseIfStatement to avoid parser bug
    fun parseWhileStatementInto(stmt: StatementNode) r: Void {
        // trace
        stmt.kind = "While"
        parseExpressionInto(stmt.loopCondition)
        consume(SeenTokenType.LeftBrace, "Expected '{' after while condition")
        parseBlockIntoField()
        stmt.loopBody = lastParsedBlock
        // trace
    }

    fun parseForInStatementInto(stmt: StatementNode) r: Void {
        stmt.kind = "ForIn"
        let varToken = consume(SeenTokenType.Identifier, "Expected loop variable name after 'for'")
        stmt.variableName = varToken.getValue()
        consume(SeenTokenType.KeywordIn, "Expected 'in' after loop variable")
        stmt.expression = parseExpression()
        consume(SeenTokenType.LeftBrace, "Expected '{' after for-in iterable")
        parseBlockIntoField()
        stmt.loopBody = lastParsedBlock
        return
    }

    fun parseExpressionStatementInto(stmt: StatementNode) r: Void {
        // trace
        stmt.kind = "Expression"
        parseExpressionInto(stmt.expression)
        if matchTokenStr(SeenTokenType.Semicolon) { }
        // trace
    }

    // NOTE: parseIfStatementInto moved to end of class to avoid method merging bug

    // ========== End of Into methods ==========

    fun parseReturnStatement() r: StatementNode {
        // trace
        let stmt = StatementNode.new()
        // trace
        stmt.kind = "Return"
        // trace
        // Avoid storing peek() result to prevent Token copy corruption
        if not checkToken(SeenTokenType.Semicolon) and not checkToken(SeenTokenType.RightBrace) {
            // trace
            let exprResult = parseExpression()
            // trace
            // Copy fields individually to avoid struct assignment corruption
            // For VarExpr, we only need kind and variableName
            // Avoid copying all fields as String assignment might corrupt memory
            // trace
            stmt.returnValue.kind = exprResult.kind
            // trace
            stmt.returnValue.variableName = exprResult.variableName
            // trace
            // Only copy other fields if needed for this expression type
            if exprResult.kind == "Literal" {
                stmt.returnValue.literalValue = exprResult.literalValue
                stmt.returnValue.literalType = exprResult.literalType
            }
            if exprResult.kind == "Call" or exprResult.kind == "MethodCall" {
                stmt.returnValue.callee = exprResult.callee
            }
            if exprResult.kind == "Binary" {
                stmt.returnValue.operator = exprResult.operator
                // Binary expressions need operands for OR/AND to work
                // Copy element by element to avoid array reference issues
                var opIdx = 0
                while opIdx < exprResult.operands.length() {
                    stmt.returnValue.operands.push(exprResult.operands[opIdx])
                    opIdx = opIdx + 1
                }
            }
            if exprResult.kind == "Unary" {
                stmt.returnValue.operator = exprResult.operator
                var opIdx = 0
                while opIdx < exprResult.operands.length() {
                    stmt.returnValue.operands.push(exprResult.operands[opIdx])
                    opIdx = opIdx + 1
                }
            }
            // trace
            // Copy arguments for calls
            if exprResult.kind == "Call" or exprResult.kind == "MethodCall" {
                stmt.returnValue.arguments = exprResult.arguments
            }
        }
        if matchTokenStr(SeenTokenType.Semicolon) { }
        // trace
        return stmt
    }

    // Parse `while condition { body }`.  Condition is any expression;
    // body is a brace-delimited block.
    fun parseWhileStatement() r: StatementNode {
        let stmt = StatementNode.new()
        stmt.kind = "While"
        stmt.loopCondition = parseExpression()
        consume(SeenTokenType.LeftBrace, "Expected '{' after while condition")
        parseBlockIntoField()
        stmt.loopBody = lastParsedBlock
        return stmt
    }

    // Parse `for varName in iterable { body }`.
    fun parseForInStatement() r: StatementNode {
        let stmt = StatementNode.new()
        stmt.kind = "ForIn"
        let varToken = consume(SeenTokenType.Identifier, "Expected loop variable name after 'for'")
        stmt.variableName = varToken.getValue()
        consume(SeenTokenType.KeywordIn, "Expected 'in' after loop variable")
        stmt.expression = parseExpression()
        consume(SeenTokenType.LeftBrace, "Expected '{' after for-in iterable")
        parseBlockIntoField()
        stmt.loopBody = lastParsedBlock
        return stmt
    }

    fun parseExpressionStatement() r: StatementNode {
        let stmt = StatementNode.new()
        stmt.kind = "Expression"
        stmt.expression = parseExpression()
        if matchTokenStr(SeenTokenType.Semicolon) { }
        return stmt
    }

    // NOTE: parseIfStatement moved to end of class to avoid method merging bug

    // Top of the expression-parsing precedence chain.
    // Delegates to parseAssignment, which in turn cascades down through
    // parseOr -> parseAnd -> ... -> parsePrimary.
    // Returns a fully constructed ParserExpressionNode tree.
    fun parseExpression() r: ParserExpressionNode {
        return parseAssignment()
    }

    // Lowest precedence: simple assignment (=), compound arithmetic assigns
    // (+=, -=, *=, /=), compound bitwise assigns (%=, &=, |=, ^=, <<=, >>=),
    // and the postfix `as` type-cast operator.
    //
    // Compound bitwise assigns use a save/restore cursor pattern because
    // the operators (&, |, ^, <<, >>) are the SAME tokens used by
    // parseBitwise/parseShift.  We must peek ahead for a following `=`
    // to disambiguate, and backtrack if it is absent.
    fun parseAssignment() r: ParserExpressionNode {
        let expr = parseOr()

        // Postfix 'as' type cast — direct value check, no isAtEnd guard (peek() returns EOF safely)
        if peek().getValue() == "as" {
            advance()   // consume 'as'
            let castTN = parseTypeNode()
            let castE = ParserExpressionNode.new()
            castE.kind = "Cast"
            castE.operands.push(expr)
            castE.literalValue = castTN.typeName
            return castE
        }

        // Check for simple assignment
        if matchTokenStr(SeenTokenType.Equal) {
            let value = parseAssignment()

            var assignHandled = false
            if expr.kind == "VarExpr" {
                let assign = ParserExpressionNode.new()
                assign.kind = "Assignment"
                assign.variableName = getVariableExprName(expr)
                assign.operands.push(value) // [0] = rhs value
                return assign
            }
            if not assignHandled and expr.kind == "MemberAccess" {
                // Handle member access assignment: a.b = value
                let assign = ParserExpressionNode.new()
                assign.kind = "MemberAssignment"
                assign.operands.push(expr)  // [0] = lhs (MemberAccess)
                assign.operands.push(value) // [1] = rhs value
                return assign
            }
            if not assignHandled and expr.kind == "IndexAccess" {
                // Handle index access assignment: a[i] = value
                let assign = ParserExpressionNode.new()
                assign.kind = "IndexAssignment"
                assign.operands.push(expr)  // [0] = lhs (IndexAccess)
                assign.operands.push(value) // [1] = rhs value
                return assign
            }
        }

        // Check for compound assignments (+=, -=, *=, /=)
        var compoundOp = ""
        var compoundOpSet = false
        if matchTokenStr(SeenTokenType.PlusEqual) {
            compoundOp = "+"
            compoundOpSet = true
        }
        if not compoundOpSet and matchTokenStr(SeenTokenType.MinusEqual) {
            compoundOp = "-"
            compoundOpSet = true
        }
        if not compoundOpSet and matchTokenStr(SeenTokenType.MultiplyEqual) {
            compoundOp = "*"
            compoundOpSet = true
        }
        if not compoundOpSet and matchTokenStr(SeenTokenType.DivideEqual) {
            compoundOp = "/"
            compoundOpSet = true
        }

        if compoundOp != "" {
            let value = parseAssignment()

            if expr.kind == "VarExpr" {
                // Transform: x += y  =>  x = x + y
                let binaryExpr = ParserExpressionNode.new()
                binaryExpr.kind = "Binary"
                binaryExpr.operator = compoundOp
                binaryExpr.operands.push(expr)  // [0] = left (x)
                binaryExpr.operands.push(value) // [1] = right (y)

                let assign = ParserExpressionNode.new()
                assign.kind = "Assignment"
                assign.variableName = getVariableExprName(expr)
                assign.operands.push(binaryExpr) // [0] = rhs value (x + y)
                return assign
            }
        }

        // Compound modulo + bitwise assigns: %= &= |= ^= <<= >>=
        // Detect as value-based two-token sequences (op followed by =)
        var bwOp = ""
        var bwSet = 0
        if bwSet == 0 {
            if not isAtEnd() {
                if peek().getValue() == "%" {
                    let bwSvMod = current
                    advance()
                    if matchTokenStr(SeenTokenType.Equal) {
                        bwOp = "%"
                        bwSet = 1
                    } else {
                        current = bwSvMod
                    }
                }
            }
        }
        if bwSet == 0 {
            if not isAtEnd() {
                if peek().getValue() == "&" {
                    let bwSvAnd = current
                    advance()
                    if matchTokenStr(SeenTokenType.Equal) {
                        bwOp = "&"
                        bwSet = 1
                    } else {
                        current = bwSvAnd
                    }
                }
            }
        }
        if bwSet == 0 {
            if not isAtEnd() {
                if peek().getValue() == "|" {
                    let bwSvOr = current
                    advance()
                    if matchTokenStr(SeenTokenType.Equal) {
                        bwOp = "|"
                        bwSet = 1
                    } else {
                        current = bwSvOr
                    }
                }
            }
        }
        if bwSet == 0 {
            if not isAtEnd() {
                if peek().getValue() == "^" {
                    let bwSvXor = current
                    advance()
                    if matchTokenStr(SeenTokenType.Equal) {
                        bwOp = "^"
                        bwSet = 1
                    } else {
                        current = bwSvXor
                    }
                }
            }
        }
        if bwSet == 0 {
            if not isAtEnd() {
                if peek().getValue() == "<<" {
                    let bwSvLs = current
                    advance()
                    if matchTokenStr(SeenTokenType.Equal) {
                        bwOp = "<<"
                        bwSet = 1
                    } else {
                        current = bwSvLs
                    }
                }
            }
        }
        if bwSet == 0 {
            if not isAtEnd() {
                if peek().getValue() == ">>" {
                    let bwSvRs = current
                    advance()
                    if matchTokenStr(SeenTokenType.Equal) {
                        bwOp = ">>"
                        bwSet = 1
                    } else {
                        current = bwSvRs
                    }
                }
            }
        }
        if bwSet == 1 {
            let bwRhs = parseAssignment()
            let bwBin = ParserExpressionNode.new()
            bwBin.kind = "Binary"
            bwBin.operator = bwOp
            bwBin.operands.push(expr)
            bwBin.operands.push(bwRhs)
            let bwAsgn = ParserExpressionNode.new()
            bwAsgn.kind = "Assignment"
            bwAsgn.variableName = getVariableExprName(expr)
            bwAsgn.operands.push(bwBin)
            return bwAsgn
        }

        return expr
    }

    fun parseOr() r: ParserExpressionNode {
        var expr = parseAnd()
        while matchTokenStr(SeenTokenType.LogicalOr) {
            let right = parseAnd()
            let newExpr = ParserExpressionNode.new()
            newExpr.kind = "Binary"
            newExpr.operands.push(expr)  // [0] = left
            newExpr.operands.push(right) // [1] = right
            newExpr.operator = "or"
            expr = newExpr
        }
        return expr
    }

    fun parseAnd() r: ParserExpressionNode {
        var expr = parseElvis()
        while matchTokenStr(SeenTokenType.LogicalAnd) {
            let right = parseElvis()
            let newExpr = ParserExpressionNode.new()
            newExpr.kind = "Binary"
            newExpr.operands.push(expr)  // [0] = left
            newExpr.operands.push(right) // [1] = right
            newExpr.operator = "and"
            expr = newExpr
        }
        return expr
    }

    // Parse Elvis operator: left ?: right
    // Parse null-coalescing: left ?? right
    fun parseElvis() r: ParserExpressionNode {
        var expr = parseEquality()
        if matchTokenStr(SeenTokenType.Elvis) {
            let right = parseEquality()
            let elvisExpr = ParserExpressionNode.new()
            elvisExpr.kind = "Elvis"
            elvisExpr.operands.push(expr)   // [0] = left (if not null)
            elvisExpr.operands.push(right)  // [1] = right (default value)
            return elvisExpr
        }
        // Bootstrap workaround: DoubleQuestion (value 107) is outside stage1_frozen's
        // 0-99 range, so in stage2 it has type 0 (IntegerLiteral collision).
        // Guard with string-value check to prevent integer literals being consumed as ??.
        if peek().getValue() == "??" {
            if matchTokenStr(SeenTokenType.DoubleQuestion) {
                let right = parseEquality()
                let qqExpr = ParserExpressionNode.new()
                qqExpr.kind = "NullCoalesce"
                qqExpr.operands.push(expr)   // [0] = left (if not null)
                qqExpr.operands.push(right)  // [1] = right (default value)
                return qqExpr
            }
        }
        return expr
    }

    // WHY sequential `if` instead of `or`:
    // The stage1 frozen bootstrap compiler does not short-circuit `or`
    // expressions.  Writing `if matchTokenStr(A) or matchTokenStr(B)` would
    // execute BOTH matchTokenStr calls even when A already matched, silently
    // consuming an extra token.  All precedence-level methods below therefore
    // use nested `if not matched { if matchTokenStr(...) { ... } }` to
    // guarantee only one token type is consumed per iteration.

    fun parseEquality() r: ParserExpressionNode {
        var expr = parseComparison()
        var matched = true
        while matched {
            matched = false
            if matchTokenStr(SeenTokenType.EqualEqual) {
                matched = true
            }
            if not matched {
                if matchTokenStr(SeenTokenType.NotEqual) {
                    matched = true
                }
            }
            if matched {
                let operator = previous().getValue()
                let right = parseComparison()
                let newExpr = ParserExpressionNode.new()
                newExpr.kind = "Binary"
                newExpr.operands.push(expr)  // [0] = left
                newExpr.operands.push(right) // [1] = right
                newExpr.operator = operator
                expr = newExpr
            }
        }
        // 'is' type test: expr is TypeName
        // Skip if this looks like a when/match pattern arm (is Ident -> or is Ident . or is Ident =>)
        if checkToken(SeenTokenType.KeywordIs) {
            let isP2 = peekAt(2)
            let isP2v = isP2.getValue()
            var skipIsExpr = false
            if isP2v == "->" { skipIsExpr = true }
            if isP2v == "=" { skipIsExpr = true }
            if isP2v == "." { skipIsExpr = true }
            if not skipIsExpr {
                advance() // consume 'is'
                let typeName = consume(SeenTokenType.Identifier, "Expected type name after 'is'").getValue()
                let isExpr = ParserExpressionNode.new()
                isExpr.kind = "IsExpression"
                isExpr.literalValue = typeName
                isExpr.operands.push(expr) // [0] = subject
                expr = isExpr
            }
        }
        return expr
    }

    fun parseComparison() r: ParserExpressionNode {
        var expr = parseRange()
        var matched = true
        while matched {
            matched = false
            if matchTokenStr(SeenTokenType.GreaterThan) {
                matched = true
            }
            if not matched {
                if matchTokenStr(SeenTokenType.GreaterEqual) {
                    matched = true
                }
            }
            if not matched {
                if matchTokenStr(SeenTokenType.LessThan) {
                    matched = true
                }
            }
            if not matched {
                if matchTokenStr(SeenTokenType.LessEqual) {
                    matched = true
                }
            }
            if matched {
                let operator = previous().getValue()
                let right = parseRange()
                let newExpr = ParserExpressionNode.new()
                newExpr.kind = "Binary"
                newExpr.operands.push(expr)  // [0] = left
                newExpr.operands.push(right) // [1] = right
                newExpr.operator = operator
                expr = newExpr
            }
        }
        return expr
    }

    // Parse range expressions: start..end
    // Since there is no DotDot token, detect two consecutive Dot tokens
    fun parseRange() r: ParserExpressionNode {
        var expr = parseTerm()
        // Check for '..' by looking for Dot followed by another Dot (without identifier in between)
        if checkToken(SeenTokenType.Dot) {
            let savedPos = current
            advance() // consume first '.'
            if checkToken(SeenTokenType.Dot) {
                advance() // consume second '.'
                let right = parseTerm()
                let rangeExpr = ParserExpressionNode.new()
                rangeExpr.kind = "Range"
                rangeExpr.operands.push(expr)   // [0] = start
                rangeExpr.operands.push(right)  // [1] = end
                return rangeExpr
            } else {
                // Not a range, backtrack -- it was a member access dot
                current = savedPos
            }
        }
        return expr
    }

    fun parseTerm() r: ParserExpressionNode {
        var expr = parseFactor()
        var matched = true
        while matched {
            matched = false
            if matchTokenStr(SeenTokenType.Plus) {
                matched = true
            }
            if not matched {
                if matchTokenStr(SeenTokenType.Minus) {
                    matched = true
                }
            }
            if matched {
                let operator = previous().getValue()
                let right = parseFactor()
                let newExpr = ParserExpressionNode.new()
                newExpr.kind = "Binary"
                newExpr.operands.push(expr)  // [0] = left
                newExpr.operands.push(right) // [1] = right
                newExpr.operator = operator
                expr = newExpr
            }
        }
        return expr
    }

    fun parseFactor() r: ParserExpressionNode {
        var expr = parseShift()
        var matched = true
        while matched {
            matched = false
            if matchTokenStr(SeenTokenType.Multiply) {
                matched = true
            }
            if not matched {
                if matchTokenStr(SeenTokenType.Divide) {
                    matched = true
                }
            }
            if not matched {
                // Check for % but NOT %= (compound assign — handled in parseAssignment)
                if not isAtEnd() {
                    if peek().getValue() == "%" {
                        if peekAt(1).getValue() != "=" {
                            advance()
                            matched = true
                        }
                    }
                }
            }
            if matched {
                let operator = previous().getValue()
                let right = parseShift()
                let newExpr = ParserExpressionNode.new()
                newExpr.kind = "Binary"
                newExpr.operands.push(expr)
                newExpr.operands.push(right)
                newExpr.operator = operator
                expr = newExpr
            }
        }
        return expr
    }

    // Parse left-shift (<<) and right-shift (>>) binary operators.
    // Tighter than *, /, % but looser than bitwise &, |, ^.
    //
    // Uses value-based string checks (peek().getValue() == "<<") instead of
    // SeenTokenType enum matching for bootstrap compatibility -- the frozen
    // bootstrap compiler may not have enum constants for shift tokens.
    //
    // The lookahead for `=` after the operator is critical: without it,
    // compound assigns like `x <<= 1` would be misparsed as a shift `x << (= 1)`.
    // If the next token after << or >> is `=`, we leave the tokens unconsumed
    // so parseAssignment() handles the compound assign instead.
    fun parseShift() r: ParserExpressionNode {
        var expr = parseBitwise()
        var cont = true
        while cont {
            cont = false
            if not isAtEnd() {
                // Check for << but NOT <<= (compound assign — handled in parseAssignment)
                if peek().getValue() == "<<" {
                    if peekAt(1).getValue() != "=" {
                        advance()
                        let right = parseBitwise()
                        let newExpr = ParserExpressionNode.new()
                        newExpr.kind = "Binary"
                        newExpr.operator = "<<"
                        newExpr.operands.push(expr)
                        newExpr.operands.push(right)
                        expr = newExpr
                        cont = true
                    }
                }
            }
            if not cont {
                if not isAtEnd() {
                    // Check for >> but NOT >>= (compound assign — handled in parseAssignment)
                    if peek().getValue() == ">>" {
                        if peekAt(1).getValue() != "=" {
                            advance()
                            let right = parseBitwise()
                            let newExpr = ParserExpressionNode.new()
                            newExpr.kind = "Binary"
                            newExpr.operator = ">>"
                            newExpr.operands.push(expr)
                            newExpr.operands.push(right)
                            expr = newExpr
                            cont = true
                        }
                    }
                }
            }
        }
        return expr
    }

    // Parse bitwise AND (&), OR (|), and XOR (^) binary operators.
    // Tightest binary precedence level (looser only than unary operators).
    //
    // Same lookahead-for-`=` discipline as parseShift: each operator check
    // peeks at the next token to ensure we do not consume `&=`, `|=`, or `^=`
    // which belong to the compound-assign handling in parseAssignment().
    //
    // Uses value-based string checks for the same bootstrap compatibility
    // reason as parseShift.
    fun parseBitwise() r: ParserExpressionNode {
        var expr = parseUnary()
        var cont = true
        while cont {
            cont = false
            if not isAtEnd() {
                // Check for & but NOT &= (compound assign — handled in parseAssignment)
                if peek().getValue() == "&" {
                    if peekAt(1).getValue() != "=" {
                        advance()
                        let right = parseUnary()
                        let newExpr = ParserExpressionNode.new()
                        newExpr.kind = "Binary"
                        newExpr.operator = "&"
                        newExpr.operands.push(expr)
                        newExpr.operands.push(right)
                        expr = newExpr
                        cont = true
                    }
                }
            }
            if not cont {
                if not isAtEnd() {
                    // Check for | but NOT |= (compound assign — handled in parseAssignment)
                    if peek().getValue() == "|" {
                        if peekAt(1).getValue() != "=" {
                            advance()
                            let right = parseUnary()
                            let newExpr = ParserExpressionNode.new()
                            newExpr.kind = "Binary"
                            newExpr.operator = "|"
                            newExpr.operands.push(expr)
                            newExpr.operands.push(right)
                            expr = newExpr
                            cont = true
                        }
                    }
                }
            }
            if not cont {
                if not isAtEnd() {
                    // Check for ^ but NOT ^= (compound assign — handled in parseAssignment)
                    if peek().getValue() == "^" {
                        if peekAt(1).getValue() != "=" {
                            advance()
                            let right = parseUnary()
                            let newExpr = ParserExpressionNode.new()
                            newExpr.kind = "Binary"
                            newExpr.operator = "^"
                            newExpr.operands.push(expr)
                            newExpr.operands.push(right)
                            expr = newExpr
                            cont = true
                        }
                    }
                }
            }
        }
        return expr
    }
    fun parseUnary() r: ParserExpressionNode {
        // Handle bitwise NOT ~ using token type check (avoids "~" string literal issue
        // with stage1_frozen/production compiler which miscompiles "~" string comparisons)
        if checkToken(SeenTokenType.BitwiseNot) {
            advance()
            let operand = parseUnary()
            let expr = ParserExpressionNode.new()
            expr.kind = "Unary"
            expr.operator = previous().getValue()
            expr.operands.push(operand)
            return expr
        }
        // Handle unary minus/plus
        if matchTokenStr(SeenTokenType.Minus) {
            let operator = "-"
            let operand = parseUnary()
            let expr = ParserExpressionNode.new()
            expr.kind = "Unary"
            expr.operator = operator
            expr.operands.push(operand)
            return expr
        }
        if matchTokenStr(SeenTokenType.Plus) {
            let operator = "+"
            let operand = parseUnary()
            let expr = ParserExpressionNode.new()
            expr.kind = "Unary"
            expr.operator = operator
            expr.operands.push(operand)
            return expr
        }
        // Handle 'not' keyword or '!' for negation
        if matchTokenStr(SeenTokenType.LogicalNot) {
            let operator = "!"
            let operand = parseUnary()
            let expr = ParserExpressionNode.new()
            expr.kind = "Unary"
            expr.operator = operator
            expr.operands.push(operand)
            return expr
        }
        // Handle 'await' keyword as unary prefix operator
        if matchTokenStr(SeenTokenType.KeywordAwait) {
            let operand = parseUnary()
            let expr = ParserExpressionNode.new()
            expr.kind = "Await"
            expr.operands.push(operand)
            return expr
        }
        // Handle address-of (&x) — prefix & creates pointer to variable
        if checkToken(SeenTokenType.BitwiseAnd) {
            advance()
            let operand = parseUnary()
            let expr = ParserExpressionNode.new()
            expr.kind = "Unary"
            expr.operator = "&"
            expr.operands.push(operand)
            return expr
        }
        // Handle pointer dereference (*ptr) — prefix * dereferences pointer
        if checkToken(SeenTokenType.Multiply) {
            advance()
            let operand = parseUnary()
            let expr = ParserExpressionNode.new()
            expr.kind = "Unary"
            expr.operator = "*"
            expr.operands.push(operand)
            return expr
        }
        // Check for 'not' keyword (would need to add this as a token type)
        return parseCall()
    }
    // Parse postfix operators: function calls `(args)`, member access `.field`,
    // method calls `.method(args)`, index access `[expr]`, optional chaining `?.`,
    // static method `::method`, and postfix `?` error propagation.
    //
    // Runs in a loop to handle chains like `a.b[0].c(x).d`.
    //
    // Member access handling:
    //   When a `.identifier` is followed by `(`, the MemberAccess node is
    //   converted in-place to a MethodCall node.  The receiver expression is
    //   stored in literalValue (simple name) or operands[0] (complex expr).
    //
    //   Literal, Unary, and Binary expressions are explicitly allowed as method
    //   receivers (e.g. `'~'.toInt()`, `(a+b).abs()`).  Without the operands
    //   push for these kinds, the receiver would be lost.
    fun parseCall() r: ParserExpressionNode {
        var expr = parsePrimary()

        // Check for function call, member access, method call, and index access
        while true {
            var callTokenHandled = false
            if checkToken(getLeftParenType()) {
                advance() // consume (

                // Check if this is a method call (expr.method())
                var wasMemberAccess = false
                if expr.kind == "MemberAccess" {
                    // trace
                    // Convert MemberAccess to MethodCall in-place to avoid memory corruption
                    expr.kind = "MethodCall"
                    // trace
                    // literalValue already has the receiver name from MemberAccess
                    expr.callee = expr.variableName  // method name
                    // trace
                    // arguments array already exists from MemberAccess creation
                    wasMemberAccess = true
                }
                if not wasMemberAccess {
                    // Regular function call - need a new node
                    let callExpr = ParserExpressionNode.new()
                    callExpr.kind = "Call"
                    callExpr.callee = getVariableExprName(expr)
                    expr = callExpr
                }

                // Parse arguments into the current expr
                // trace
                let emptyArgs = checkToken(getRightParenType())
                if not emptyArgs {
                    // trace
                    expr.arguments.push(parseExpression())
                    while matchTokenStr(getCommaType()) {
                        expr.arguments.push(parseExpression())
                    }
                    // trace
                }

                // trace
                consume(getRightParenType(), "Expected ')' after arguments")
                // trace
                callTokenHandled = true
            }
            // Handle optional chaining: ?.
            if not callTokenHandled and checkToken(SeenTokenType.SafeNavigation) {
                advance() // consume ?.
                var safeNavIdentFound = false
                if checkNameLikeToken() {
                    let memberName = advance().getValue()
                    let memberExpr = ParserExpressionNode.new()
                    memberExpr.kind = "SafeNavigation"
                    memberExpr.variableName = memberName
                    memberExpr.operands.push(expr)  // [0] = receiver
                    expr = memberExpr
                    safeNavIdentFound = true
                }
                if not safeNavIdentFound {
                    break
                }
                callTokenHandled = true
            }
            if not callTokenHandled and checkToken(getDotType()) {
                // Check if this is '..' range syntax — don't consume the dot
                let savedDotPos = current
                advance() // consume first .
                if checkToken(getDotType()) {
                    // This is '..' range syntax, backtrack
                    current = savedDotPos
                    break
                }
                // Postfix .await — create Await expression node
                var dotAwaitHandled = false
                if checkToken(SeenTokenType.KeywordAwait) {
                    advance()   // consume 'await'
                    let postfixAwait = ParserExpressionNode.new()
                    postfixAwait.kind = "Await"
                    postfixAwait.operands.push(expr)
                    expr = postfixAwait
                    dotAwaitHandled = true
                }
                // Not '..', continue with member access (dot already consumed)
                var dotIdentFound = false
                if not dotAwaitHandled and checkNameLikeToken() {
                    let memberName = advance().getValue()
                    let memberExpr = ParserExpressionNode.new()
                    memberExpr.kind = "MemberAccess"
                    // Build full receiver path for chained access like diag.line.field
                    var memberLitSet = false
                    if expr.kind == "MemberAccess" {
                        // Preserve complex receivers like call().field.next so later
                        // stages still see the nested member access tree.
                        if expr.literalValue != "" {
                            memberExpr.literalValue = expr.literalValue + "." + expr.variableName
                        } else {
                            memberExpr.literalValue = ""
                            memberExpr.operands.push(expr)
                        }
                        memberLitSet = true
                    }
                    if not memberLitSet and (expr.kind == "MethodCall" or expr.kind == "Call" or expr.kind == "IndexAccess") {
                        // Chained expression: result.method() or arr[0] - store the expression in operands
                        memberExpr.literalValue = ""  // Signal: use operands[0] as receiver
                        memberExpr.operands.push(expr)
                        memberLitSet = true
                    }
                    if not memberLitSet and (expr.kind == "Literal" or expr.kind == "Unary" or expr.kind == "Binary") {
                        // Literal/expression receiver (e.g. '~'.toInt(), (a+b).method())
                        memberExpr.literalValue = ""
                        memberExpr.operands.push(expr)
                        memberLitSet = true
                    }
                    if not memberLitSet {
                        // Simple variable access
                        memberExpr.literalValue = getVariableExprName(expr)
                    }
                    memberExpr.variableName = memberName         // member/method name
                    expr = memberExpr
                    dotIdentFound = true
                }
                if not dotAwaitHandled {
                    if not dotIdentFound {
                        break
                    }
                }
                callTokenHandled = true
            }
            // Handle :: for static method calls (e.g., JsonParser::new())
            if not callTokenHandled and checkToken(SeenTokenType.Colon) {
                // Look ahead for second colon
                let savedPos = current
                advance() // consume first :
                if checkToken(SeenTokenType.Colon) {
                    advance() // consume second :
                    if checkNameLikeToken() {
                        let memberName = advance().getValue()
                        let memberExpr = ParserExpressionNode.new()
                        memberExpr.kind = "MemberAccess"
                        // For static method calls, literalValue = class name, variableName = method name
                        memberExpr.literalValue = getVariableExprName(expr)
                        memberExpr.variableName = memberName
                        expr = memberExpr
                        callTokenHandled = true
                    } else {
                        // Not an identifier after ::, backtrack
                        current = savedPos
                    }
                } else {
                    // Not a double colon, backtrack
                    current = savedPos
                }
            }
            if not callTokenHandled and checkToken(SeenTokenType.LeftBracket) {
                advance() // consume [
                let indexExpr = parseExpression()
                consume(SeenTokenType.RightBracket, "Expected ']' after index")
                let accessExpr = ParserExpressionNode.new()
                accessExpr.kind = "IndexAccess"
                accessExpr.operands.push(expr)      // [0] = array/object
                accessExpr.operands.push(indexExpr) // [1] = index
                expr = accessExpr
                callTokenHandled = true
            }
            // Postfix '?' error propagation: expr?
            if not callTokenHandled and checkToken(SeenTokenType.Question) {
                advance() // consume '?'
                let tryExpr = ParserExpressionNode.new()
                tryExpr.kind = "TryPropagate"
                tryExpr.operands.push(expr) // [0] = inner
                expr = tryExpr
                callTokenHandled = true
            }
            if not callTokenHandled {
                break
            }
        }

        // trace
        return expr
    }

    // Parse a primary (atomic) expression: literals, identifiers, struct
    // literals, array literals, parenthesized expressions, if-expressions,
    // when/match expressions, closures, interpolated strings, and keywords
    // like `this`, `super`, `spawn`, `transmute`, `gpu`.
    //
    // CRITICAL ORDERING CONSTRAINT (bootstrap compatibility):
    //   Integer, Float, String, Char, and Bool literal checks MUST come
    //   BEFORE any keyword checks (KeywordWhen, KeywordMatch, etc.).
    //
    //   Reason: the pre-refactoring bootstrap compiler's getSeenTokenTypeValue()
    //   returns 0 for any token type it does not recognize.  Since
    //   IntegerLiteral has value 0, a checkToken(KeywordWhen) call in that
    //   compiler actually matches integer tokens.  If we checked keywords
    //   first, integer literals would be incorrectly consumed as `when`
    //   expressions, causing all integer return values to become 0.
    //   Checking literals first ensures they are consumed before any keyword
    //   match can misfire.
    fun parsePrimary() r: ParserExpressionNode {
        // Literal checks FIRST — must come before keyword checks because
        // older bootstrap compilers may assign value 0 to unknown token types
        // (e.g. KeywordWhen), causing them to collide with IntegerLiteral=0.

        // Integer literal
        let currentValue = peek().getValue()

        if checkToken(SeenTokenType.IntegerLiteral) and looksLikeIntegerLiteral(currentValue) and not looksLikeFloatLiteral(currentValue) {
            let token = advance()
            return makeLiteral(token.getValue(), "Int")
        }

        // Float literal
        if checkToken(SeenTokenType.FloatLiteral) and looksLikeFloatLiteral(currentValue) {
            let token = advance()
            return makeLiteral(token.getValue(), "Float")
        }

        // StringLiteral tokens already carry the unquoted payload from the lexer.
        // Do not re-check for surrounding quotes here or they fall through into
        // the name-like path and become VarExpr nodes.
        if checkToken(SeenTokenType.StringLiteral) {
            let token = advance()
            let rawValue = token.getValue()
            // Strip quotes from the token value if present
            var strValue = rawValue
            if rawValue.length() >= 2 {
                if rawValue.startsWith("\"") and rawValue.endsWith("\"") {
                    strValue = rawValue.substring(1, rawValue.length() - 1)
                }
            }
            return makeLiteral(strValue, "String")
        }

        // CharLiteral tokens also carry the raw character payload.
        if checkToken(SeenTokenType.CharLiteral) {
            let token = advance()
            return makeLiteral(token.getValue(), "Char")
        }

        // Boolean literals
        if checkToken(SeenTokenType.KeywordTrue) {
            advance()
            return makeLiteral("true", "Bool")
        }
        if checkToken(SeenTokenType.KeywordFalse) {
            advance()
            return makeLiteral("false", "Bool")
        }

        // `data` is a contextual declaration keyword, but in expression
        // position it must behave like a plain identifier. Handle it before
        // the expression-keyword branches below so bootstrap enum/string
        // mismatches cannot route it into `if`/`when`/`match` parsing.
        if checkNameLikeToken() {
            if peek().getValue() == "data" {
                advance()
                return makeVariable("data")
            }
        }

        // If expression: if condition { expr } else { expr }
        if checkToken(SeenTokenType.KeywordIf) {
            advance() // consume 'if'
            let condition = parseExpression()
            consume(SeenTokenType.LeftBrace, "Expected '{' after if condition")
            // Parse then-block: semicolon-separated exprs, last is the value
            var thenExprs = Array<ParserExpressionNode>()
            while not checkToken(SeenTokenType.RightBrace) and not isAtEnd() {
                let thenE = parseExpression()
                thenExprs.push(thenE)
                if not matchTokenStr(SeenTokenType.Semicolon) { break }
            }
            consume(SeenTokenType.RightBrace, "Expected '}' after then expression")
            consume(SeenTokenType.KeywordElse, "Expected 'else' in if expression")
            consume(SeenTokenType.LeftBrace, "Expected '{' after else")
            var elseExprs = Array<ParserExpressionNode>()
            while not checkToken(SeenTokenType.RightBrace) and not isAtEnd() {
                let elseE = parseExpression()
                elseExprs.push(elseE)
                if not matchTokenStr(SeenTokenType.Semicolon) { break }
            }
            consume(SeenTokenType.RightBrace, "Expected '}' after else expression")
            let ifExpr = ParserExpressionNode.new()
            ifExpr.kind = "IfExpression"
            ifExpr.operands.push(condition)
            // Last expr in each block is the value; prior exprs are side-effect-only
            if thenExprs.length() > 0 {
                ifExpr.operands.push(thenExprs[thenExprs.length() - 1])
            } else {
                ifExpr.operands.push(ParserExpressionNode.new())
            }
            if elseExprs.length() > 0 {
                ifExpr.operands.push(elseExprs[elseExprs.length() - 1])
            } else {
                ifExpr.operands.push(ParserExpressionNode.new())
            }
            // Stash side-effect exprs in arguments[] for codegen
            // Format: [thenSideEffects..., sentinel, elseSideEffects...]
            var thi = 0
            while thi < thenExprs.length() - 1 {
                ifExpr.arguments.push(thenExprs[thi])
                thi = thi + 1
            }
            // Sentinel: empty node to mark boundary between then/else side effects
            let sentinel = ParserExpressionNode.new()
            sentinel.kind = "Sentinel"
            ifExpr.arguments.push(sentinel)
            var eli = 0
            while eli < elseExprs.length() - 1 {
                ifExpr.arguments.push(elseExprs[eli])
                eli = eli + 1
            }
            return ifExpr
        }

        // When expression: when (expr) { is Pattern -> expr ... }
        if checkToken(SeenTokenType.KeywordWhen) {
            return parseWhenExpression()
        }

        // match keyword: match expr { Pattern -> result ... }
        // Subject is unparenthesised (unlike 'when (expr) {}')
        if checkToken(SeenTokenType.KeywordMatch) {
            return parseMatchExpression()
        }

        // Closure literal: |params| body_expr
        if checkToken(SeenTokenType.BitwiseOr) {
            let closureSaved = current
            advance() // consume opening |
            var closureParams = Array<ParserExpressionNode>()
            var closureValid = true
            // Empty params: || expr
            if checkToken(SeenTokenType.BitwiseOr) {
                advance()  // consume closing |
            } else {
                // Parse comma-separated param names
                while not isAtEnd() {
                    if not checkToken(SeenTokenType.Identifier) {
                        closureValid = false
                        break
                    }
                    let cpTok = advance()
                    let cpNode = ParserExpressionNode.new()
                    cpNode.kind = "Literal"
                    cpNode.literalValue = cpTok.getValue()
                    cpNode.literalType = "String"
                    closureParams.push(cpNode)
                    if not matchTokenStr(SeenTokenType.Comma) {
                        break
                    }
                }
                if closureValid {
                    if checkToken(SeenTokenType.BitwiseOr) {
                        advance()
                    } else {
                        closureValid = false
                    }
                }
            }
            if closureValid {
                let closureBody = parseExpression()
                let closureExpr = ParserExpressionNode.new()
                closureExpr.kind = "Closure"
                closureExpr.operands.push(closureBody)
                closureExpr.arguments = closureParams
                return closureExpr
            }
            // Not a closure — backtrack
            current = closureSaved
        }

        // Parenthesized expression
        if checkToken(getLeftParenType()) {
            advance()
            let expr = parseExpression()
            consume(getRightParenType(), "Expected ')' after expression")
            return expr
        }

        // Interpolated string: "Hello {name}!"
        if checkToken(SeenTokenType.InterpolatedStringStart) {
            return parseInterpolatedString()
        }

        // Handle 'this' keyword as a variable reference
        if checkToken(SeenTokenType.KeywordThis) {
            advance()
            return makeVariable("this")
        }

        // Handle 'super' keyword for parent class constructor/method calls
        if checkToken(SeenTokenType.KeywordSuper) {
            advance()
            return makeVariable("super")
        }

        // Handle 'spawn' keyword as function call identifier (spawn(...))
        if checkToken(SeenTokenType.KeywordSpawn) {
            advance()
            return makeVariable("spawn")
        }

        // Handle 'transmute' keyword as builtin function: transmute<Type>(val)
        if checkToken(SeenTokenType.KeywordTransmute) {
            advance()
            var tmName = "transmute"
            // Parse optional generic type: <Type>
            if checkToken(SeenTokenType.LessThan) {
                advance()
                if checkToken(SeenTokenType.Identifier) {
                    let tmType = advance().getValue()
                    tmName = "transmute<" + tmType + ">"
                }
                if checkToken(SeenTokenType.GreaterThan) {
                    advance()
                }
            }
            return makeVariable(tmName)
        }

        // Handle 'gpu' keyword as identifier (used in region gpu { ... })
        if checkToken(SeenTokenType.KeywordGpu) {
            advance()
            return makeVariable("gpu")
        }

        // Identifier (variable or function name or struct literal)
        if checkNameLikeToken() {
            var name = peek().getValue()
            advance()
            // Remap 'self' to 'this' (alias for this-pointer)
            if name == "self" { name = "this" }

            // Check for generic type syntax: Array<Type>() or Map<K,V>{}
            // This needs to be handled before struct literal check
            if checkToken(SeenTokenType.LessThan) {
                // Look ahead to see if this is a generic type or a comparison
                // Generic type pattern: Identifier<Type>() or Identifier<Type>{}
                // We save position, try to parse generic, then decide
                let savedPos = current
                advance() // consume <
                var genericParsed = false

                // Try to parse a type name
                if checkToken(SeenTokenType.Identifier) {
                    let typeParam = advance().getValue()

                    // Handle nested generics like BTreeNode<K, V> or Array<Array<Int>>
                    var fullTypeParam = typeParam
                    if checkToken(SeenTokenType.LessThan) {
                        advance() // consume inner <
                        if checkToken(SeenTokenType.Identifier) {
                            var innerParams = advance().getValue()
                            // Handle multiple inner type params like <K, V>
                            while matchTokenStr(SeenTokenType.Comma) {
                                if checkToken(SeenTokenType.Identifier) {
                                    innerParams = innerParams + ", " + advance().getValue()
                                }
                            }
                            if checkToken(SeenTokenType.GreaterThan) {
                                advance() // consume inner >
                                fullTypeParam = fullTypeParam + "<" + innerParams + ">"
                            }
                        }
                    }

                    // Handle multiple type parameters like Map<K, V> or FixedArray<Int, 4>
                    while matchTokenStr(SeenTokenType.Comma) {
                        if checkToken(SeenTokenType.Identifier) {
                            fullTypeParam = fullTypeParam + ", " + advance().getValue()
                        } else {
                            if checkToken(SeenTokenType.IntegerLiteral) {
                                fullTypeParam = fullTypeParam + ", " + advance().getValue()
                            }
                        }
                    }

                    // Check for closing >
                    var foundClosingGt = false
                    if checkToken(SeenTokenType.GreaterThan) {
                        advance() // consume >
                        foundClosingGt = true

                        // Now check if followed by (), {}, or . to confirm generic type
                        // NOTE: Use nested ifs instead of 'or' to ensure short-circuit (Stage1 bug workaround)
                        var isGenericType = false
                        if checkToken(SeenTokenType.LeftParen) {
                            isGenericType = true
                        }
                        if not isGenericType {
                            if checkToken(SeenTokenType.LeftBrace) {
                                isGenericType = true
                            }
                        }
                        if not isGenericType {
                            if checkToken(SeenTokenType.Dot) {
                                isGenericType = true
                            }
                        }
                        if isGenericType {
                            // This IS a generic type - update name to include type param
                            name = name + "<" + fullTypeParam + ">"
                            // Continue to normal call/struct literal handling below
                            genericParsed = true
                        }
                        if not isGenericType {
                            // Not followed by (), {}, or . - backtrack, treat as comparison
                            current = savedPos
                            genericParsed = true
                        }
                    }
                    if not foundClosingGt {
                        // No closing > - backtrack, treat as comparison
                        current = savedPos
                        genericParsed = true
                    }
                }
                if not genericParsed {
                    // Not an identifier after < - backtrack, treat as comparison
                    current = savedPos
                }
            }

            // Check for struct literal: TypeName{ field: value, ... }
            // Only treat as struct literal if identifier starts with uppercase (type name convention)
            // This prevents `if myVar { ... }` from being parsed as struct literal
            let firstChar = name.charAt(0)
            let isUppercase = firstChar >= "A" and firstChar <= "Z"
            var isStructLiteral = false
            if isUppercase and checkToken(SeenTokenType.LeftBrace) {
                // Lookahead: struct literal requires { IDENTIFIER : pattern
                // This prevents `if X >= MAX_ITEMS { ... }` from treating MAX_ITEMS as struct type
                let savedCurrent = current
                advance() // skip {
                var looksLikeStruct = false
                if checkToken(SeenTokenType.RightBrace) {
                    looksLikeStruct = true
                }
                if checkToken(SeenTokenType.Identifier) {
                    let savedCurrent2 = current
                    advance()
                    if checkToken(SeenTokenType.Colon) {
                        looksLikeStruct = true
                    }
                    current = savedCurrent2
                }
                current = savedCurrent
                if looksLikeStruct {
                    isStructLiteral = true
                }
            }
            if isStructLiteral {
                advance() // consume {
                let structExpr = ParserExpressionNode.new()
                structExpr.kind = "StructLiteral"
                structExpr.literalType = name  // Store type name in literalType

                // Parse field initializers
                if not checkToken(SeenTokenType.RightBrace) {
                    // Parse first field
                    if checkToken(SeenTokenType.Identifier) {
                        let fieldName = advance().getValue()
                        consume(SeenTokenType.Colon, "Expected ':' after field name")
                        let fieldValue = parseExpression()
                        // Create a wrapper expression to hold field name and value separately
                        let fieldExpr = ParserExpressionNode.new()
                        fieldExpr.kind = "StructField"
                        fieldExpr.variableName = fieldName  // Field name
                        fieldExpr.operands.push(fieldValue)  // Value expression
                        structExpr.arguments.push(fieldExpr)
                    }

                    while matchTokenStr(SeenTokenType.Comma) {
                        if checkToken(SeenTokenType.Identifier) {
                            let fieldName = advance().getValue()
                            consume(SeenTokenType.Colon, "Expected ':' after field name")
                            let fieldValue = parseExpression()
                            let fieldExpr = ParserExpressionNode.new()
                            fieldExpr.kind = "StructField"
                            fieldExpr.variableName = fieldName
                            fieldExpr.operands.push(fieldValue)
                            structExpr.arguments.push(fieldExpr)
                        }
                    }
                }

                consume(SeenTokenType.RightBrace, "Expected '}' after struct literal")
                return structExpr
            }

            // Regular identifier/variable - use the same pattern as makeLiteral
            // trace
            return makeVariable(name)
        }

        // Array literal [a, b, c]
        if checkToken(SeenTokenType.LeftBracket) {
            advance() // consume [
            let arrayExpr = ParserExpressionNode.new()
            arrayExpr.kind = "ArrayLiteral"
            // Parse elements
            if not checkToken(SeenTokenType.RightBracket) {
                arrayExpr.arguments.push(parseExpression())
                while matchTokenStr(getCommaType()) {
                    arrayExpr.arguments.push(parseExpression())
                }
            }
            consume(SeenTokenType.RightBracket, "Expected ']' after array elements")
            return arrayExpr
        }

        // Unknown token - advance to avoid infinite loop
        if not isAtEnd() {
            advance()
        }
        return ParserExpressionNode.new()
    }

    fun makeLiteral(value: String, typeName: String) r: ParserExpressionNode {
        return ParserExpressionNode{
            kind: "Literal",
            operands: Array<ParserExpressionNode>(),
            operator: "",
            literalValue: value,
            literalType: typeName,
            variableName: "",
            callee: "",
            arguments: Array<ParserExpressionNode>()
        }
    }

    // Create a variable-reference expression node.
    // The kind is "VarExpr" (not "Variable") because the stage1 bootstrap
    // compiler has a memory-corruption bug triggered by the exact 8-byte
    // string "Variable" when stored in a struct field.
    fun getVariableExprName(expr: ParserExpressionNode) r: String {
        if expr.variableName != "" {
            return expr.variableName
        }
        return expr.literalValue
    }

    fun makeVariable(varName: String) r: ParserExpressionNode {
        let expr = ParserExpressionNode.new()
        expr.kind = "VarExpr"
        expr.operands = Array<ParserExpressionNode>()
        expr.operator = ""
        expr.literalValue = ""
        expr.literalType = ""
        expr.variableName = varName
        expr.callee = ""
        expr.arguments = Array<ParserExpressionNode>()
        return expr
    }

    // Parse an interpolated string like `"Hello {name}!"`.
    // The lexer emits only non-empty InterpolatedStringMiddle tokens, so the
    // parser must synthesize empty leading/trailing parts to preserve ordering.
    // arguments[] always stores string-literal parts with length = exprs + 1,
    // while operands[] stores the embedded expressions between those parts.
    fun parseInterpolatedString() r: ParserExpressionNode {
        // Consume InterpolatedStringStart
        advance()

        let result = ParserExpressionNode.new()
        result.kind = "StringInterpolation"
        // arguments holds the string literal parts, including empty separators.
        // operands holds the expressions to interpolate.

        while not checkToken(SeenTokenType.InterpolatedStringEnd) {
            if isAtEnd() {
                // Unexpected end of input
                break
            }

            // The lexer omits empty middle tokens, so preserve missing separators
            // explicitly to keep parts ordered around each expression.
            if checkToken(SeenTokenType.InterpolatedStringMiddle) {
                let token = advance()
                let strPart = token.getValue()
                let strLiteral = makeLiteral(strPart, "String")
                result.arguments.push(strLiteral)
            } else {
                result.arguments.push(makeLiteral("", "String"))
            }

            if not checkToken(SeenTokenType.InterpolatedStringEnd) {
                let expr = parseExpression()
                result.operands.push(expr)
            }
        }

        if result.arguments.length() == result.operands.length() {
            result.arguments.push(makeLiteral("", "String"))
        }

        // Consume InterpolatedStringEnd
        if checkToken(SeenTokenType.InterpolatedStringEnd) {
            advance()
        }

        return result
    }

    fun parseImportItem() r: ItemNode {
        let pathInfo = parseImportPath()
        let importSymbols = parseImportSymbols(pathInfo)

        matchTokenStr(getSemicolonType())

        let item = ItemNode.new()
        item.itemType = "Import"
        item.name = pathInfo.text
        item.importPath = pathInfo.segments
        item.importSymbols = importSymbols
        item.visibility = ""
        return item
    }

    // Parse an import declaration (import path.to.module.{Symbol1, Symbol2})
    // and push it into currentProgram.  Supports dot-separated paths,
    // Rust-style :: paths, `as` aliases, and braced symbol lists.
    fun parseImportItemInto() r: Void {
        let importSegments = Array<String>()

        if checkToken(getIdentifierType()) {
            importSegments.push(advance().getValue())
        } else {
            if checkToken(SeenTokenType.KeywordAsync) {
                importSegments.push(advance().getValue())
            }
        }

        var importText = joinSegments(importSegments, ".")

        while not isAtEnd() {
            if matchTokenStr(getDotType()) {
                if checkToken(getLeftBraceType()) or checkToken(getKeywordAsType()) {
                    break
                }
                if checkToken(SeenTokenType.KeywordAsync) {
                    let seg = advance()
                    importSegments.push(seg.getValue())
                    importText = importText + "." + seg.getValue()
                    continue
                }
                let segment = consume(getIdentifierType(), "Expected identifier in import path")
                importSegments.push(segment.getValue())
                importText = importText + "." + segment.getValue()
                continue
            }

            if matchTokenStr(getColonType()) and matchTokenStr(getColonType()) {
                if checkToken(getLeftBraceType()) or checkToken(getKeywordAsType()) {
                    break
                }
                let segment = consume(getIdentifierType(), "Expected identifier after '::'")
                importSegments.push(segment.getValue())
                importText = importText + "::" + segment.getValue()
                continue
            }

            break
        }

        let importSymbols = Array<ImportSymbolNode>()
        if matchTokenStr(getKeywordAsType()) and importSegments.length() > 0 {
            let alias = consume(getIdentifierType(), "Expected alias after 'as'")
            let baseName = importSegments[importSegments.length() - 1]
            let symbol = ImportSymbolNode.new()
            symbol.name = baseName
            symbol.alias = alias.getValue()
            importSymbols.push(symbol)
        } else {
            if matchTokenStr(getLeftBraceType()) {
                while not isAtEnd() {
                    if matchTokenStr(getRightBraceType()) {
                        break
                    }

                    let symbolToken = consume(getIdentifierType(), "Expected symbol name")
                    var aliasValue = ""
                    if matchTokenStr(getKeywordAsType()) {
                        let aliasToken = consume(getIdentifierType(), "Expected alias name")
                        aliasValue = aliasToken.getValue()
                    }

                    let symbol = ImportSymbolNode.new()
                    symbol.name = symbolToken.getValue()
                    symbol.alias = aliasValue
                    importSymbols.push(symbol)

                    if matchTokenStr(getCommaType()) {
                        continue
                    }

                    consume(getRightBraceType(), "Expected '}' after import list")
                    break
                }
            } else {
                if importSegments.length() > 0 {
                    let baseName = importSegments[importSegments.length() - 1]
                    let symbol = ImportSymbolNode.new()
                    symbol.name = baseName
                    symbol.alias = ""
                    importSymbols.push(symbol)
                }
            }
        }

        matchTokenStr(getSemicolonType())

        // Push directly to currentProgram instead of returning
        let item = ItemNode.new()
        item.itemType = "Import"
        item.name = importText
        item.visibility = ""
        item.importPath = importSegments
        item.importSymbols = importSymbols
        currentProgram.items.push(item)
        traceParse("push Import " + item.name)
    }

    fun parseImportPath() r: ImportPathInfo {
        let segments = Array<String>()

        if checkToken(getIdentifierType()) {
            segments.push(advance().getValue())
        } else {
            if checkToken(SeenTokenType.KeywordAsync) {
                segments.push(advance().getValue())
            }
        }

        var text = joinSegments(segments, ".")

        while not isAtEnd() {
            if matchTokenStr(getDotType()) {
                if checkToken(getLeftBraceType()) or checkToken(getKeywordAsType()) {
                    break
                }
                if checkToken(SeenTokenType.KeywordAsync) {
                    let seg = advance()
                    segments.push(seg.getValue())
                    text = text + "." + seg.getValue()
                    continue
                }
                let segment = consume(getIdentifierType(), "Expected identifier in import path")
                segments.push(segment.getValue())
                text = text + "." + segment.getValue()
                continue
            }

            if matchTokenStr(getColonType()) and matchTokenStr(getColonType()) {
                if checkToken(getLeftBraceType()) or checkToken(getKeywordAsType()) {
                    break
                }
                let segment = consume(getIdentifierType(), "Expected identifier after '::'")
                segments.push(segment.getValue())
                text = text + "::" + segment.getValue()
                continue
            }

            break
        }

        return ImportPathInfo{
            text: text,
            segments: segments
        }
    }

    fun parseImportSymbols(pathInfo: ImportPathInfo) r: Array<ImportSymbolNode> {
        let symbols = Array<ImportSymbolNode>()

        if matchTokenStr(getKeywordAsType()) and pathInfo.segments.length() > 0 {
            let alias = consume(getIdentifierType(), "Expected alias after 'as'")
            let baseName = pathInfo.segments[pathInfo.segments.length() - 1]
            symbols.push(makeImportSymbol(baseName, alias.getValue()))
            return symbols
        }

        if !matchTokenStr(getLeftBraceType()) {
            if pathInfo.segments.length() > 0 {
                let baseName = pathInfo.segments[pathInfo.segments.length() - 1]
                symbols.push(makeImportSymbol(baseName, ""))
            }
            return symbols
        }

        while not isAtEnd() {
            if matchTokenStr(getRightBraceType()) {
                break
            }

            let symbolToken = consume(getIdentifierType(), "Expected symbol name")
            var aliasValue = ""
            if matchTokenStr(getKeywordAsType()) {
                let aliasToken = consume(getIdentifierType(), "Expected alias name")
                aliasValue = aliasToken.getValue()
            }

            symbols.push(makeImportSymbol(symbolToken.getValue(), aliasValue))

            if matchTokenStr(getCommaType()) {
                continue
            }

            consume(getRightBraceType(), "Expected '}' after import list")
            break
        }

        return symbols
    }

    fun makeImportSymbol(name: String, alias: String) r: ImportSymbolNode {
        let symbol = ImportSymbolNode()
        symbol.name = name
        symbol.alias = alias
        return symbol
    }

    // ========== If-related methods (placed at end of class) ===================
    //
    // WHY these are at the end:
    //   The stage1 frozen bootstrap compiler has a codegen bug where methods
    //   with similar signatures that appear adjacent in source get "merged" --
    //   the body of one overwrites another.  Moving parseIfStatementField,
    //   parseIfStatementInto, and parseIfStatement to the bottom of the class
    //   (far from each other and from similar parse*Statement methods) avoids
    //   the collision.
    // ========================================================================

    // Stable while parsers kept near the bottom of the file to avoid a
    // stage1 bootstrap method-merging bug observed with adjacent parse*Field
    // loop parsers.
    fun parseStableWhileStatementField() r: Void {
        lastStatement.kind = "While"
        parseExpressionInto(lastStatement.loopCondition)
        consume(SeenTokenType.LeftBrace, "Expected '{' after while condition")
        parseBlockIntoField()
        lastStatement.loopBody = lastParsedBlock
        return
    }

    fun parseStableWhileStatementInto(stmt: StatementNode) r: Void {
        stmt.kind = "While"
        parseExpressionInto(stmt.loopCondition)
        consume(SeenTokenType.LeftBrace, "Expected '{' after while condition")
        parseBlockIntoField()
        stmt.loopBody = lastParsedBlock
        return
    }

    fun parseStableWhileStatement() r: StatementNode {
        let stmt = StatementNode.new()
        stmt.kind = "While"
        stmt.loopCondition = parseExpression()
        consume(SeenTokenType.LeftBrace, "Expected '{' after while condition")
        parseBlockIntoField()
        stmt.loopBody = lastParsedBlock
        return stmt
    }

    // Parse `if condition { then } [else { ... }]` into lastStatement.
    fun parseIfStatementField() r: Void {
        lastStatement.kind = "If"
        parseExpressionInto(lastStatement.condition)
        consume(SeenTokenType.LeftBrace, "Expected '{'")
        parseBlockIntoField()
        lastStatement.thenBranch = lastParsedBlock
        // Handle else branch - use checkToken first to avoid advancing prematurely
        if checkToken(SeenTokenType.KeywordElse) {
            advance() // consume 'else'
            if checkToken(SeenTokenType.KeywordIf) {
                advance() // consume 'if'
                // Parse else-if as a nested if in the else branch
                // Uses parseIfStatement() which handles full else-if chains recursively
                let elseBlock = BlockNode.new()
                let nestedIf = parseIfStatement()
                elseBlock.statements.push(nestedIf)
                lastStatement.elseBranch = elseBlock
            } else {
                // Plain else block
                if checkToken(SeenTokenType.LeftBrace) {
                    advance() // consume '{'
                    parseBlockIntoField()
                    lastStatement.elseBranch = lastParsedBlock
                }
            }
        }
        return
    }

    fun parseIfStatementInto(stmt: StatementNode) r: Void {
        stmt.kind = "If"
        parseExpressionInto(stmt.condition)
        consume(SeenTokenType.LeftBrace, "Expected '{'")
        parseBlockIntoField()
        stmt.thenBranch = lastParsedBlock
        // Handle else branch (supports full else-if chains recursively)
        if checkToken(SeenTokenType.KeywordElse) {
            advance() // consume 'else'
            if checkToken(SeenTokenType.KeywordIf) {
                advance() // consume 'if'
                let elseBlock = BlockNode.new()
                let nestedIf = parseIfStatement()
                elseBlock.statements.push(nestedIf)
                stmt.elseBranch = elseBlock
            } else {
                if checkToken(SeenTokenType.LeftBrace) {
                    advance() // consume '{'
                    parseBlockIntoField()
                    stmt.elseBranch = lastParsedBlock
                }
            }
        }
        return
    }

    // Parse an if statement, including `if let` bindings and chained else-if.
    // Else-if is handled by recursively calling parseIfStatement() and
    // wrapping the result in a single-statement else BlockNode.
    //
    // This method is intentionally placed at the END of the class to work
    // around a stage1 bootstrap codegen bug where adjacent methods with
    // similar signatures get "merged" (their bodies are conflated).
    fun parseIfStatement() r: StatementNode {
        let stmt = StatementNode.new()
        // if let pattern: if let name = expr { ... } else { ... }
        if checkToken(SeenTokenType.KeywordLet) {
            advance() // consume 'let'
            stmt.kind = "IfLet"
            // Parse binding name
            let bindToken = consume(SeenTokenType.Identifier, "Expected variable name after 'if let'")
            stmt.variableName = bindToken.getValue()
            consume(SeenTokenType.Equal, "Expected '=' in if let")
            stmt.condition = parseExpression()
            consume(SeenTokenType.LeftBrace, "Expected '{'")
            parseBlockIntoField()
            stmt.thenBranch = lastParsedBlock
            if checkToken(SeenTokenType.KeywordElse) {
                advance()
                if checkToken(SeenTokenType.LeftBrace) {
                    advance()
                    parseBlockIntoField()
                    stmt.elseBranch = lastParsedBlock
                }
            }
            return stmt
        }
        stmt.kind = "If"
        stmt.condition = parseExpression()
        consume(SeenTokenType.LeftBrace, "Expected '{'")
        parseBlockIntoField()
        stmt.thenBranch = lastParsedBlock
        // Handle else branch (supports full else-if chains recursively)
        if checkToken(SeenTokenType.KeywordElse) {
            advance() // consume 'else'
            if checkToken(SeenTokenType.KeywordIf) {
                advance() // consume 'if'
                // Recursive: parse else-if as nested if in else branch
                let elseBlock = BlockNode.new()
                let nestedIf = parseIfStatement()
                elseBlock.statements.push(nestedIf)
                stmt.elseBranch = elseBlock
            } else {
                // Plain else block
                if checkToken(SeenTokenType.LeftBrace) {
                    advance() // consume '{'
                    parseBlockIntoField()
                    stmt.elseBranch = lastParsedBlock
                }
            }
        }
        return stmt
    }

    // -- When / Match expression parsing ------------------------------------

    // Parse a when expression: `when (subject) { is Pattern -> expr, ... }`.
    // The subject is optional and wrapped in parentheses.
    // Returns a WhenExpression node with operands[0] = subject (if present)
    // and arguments[] = array of PatternArm nodes.
    fun parseWhenExpression() r: ParserExpressionNode {
        // Consume 'when' keyword
        advance()

        // Parse optional subject expression — parenthesized or bare
        var hasSubject = false
        var subjectExpr = ParserExpressionNode.new()
        if checkToken(SeenTokenType.LeftParen) {
            advance() // consume '('
            hasSubject = true
            subjectExpr = parseExpression()
            consume(SeenTokenType.RightParen, "Expected ')' after when subject")
        } else {
            if not checkToken(SeenTokenType.LeftBrace) {
                // Bare subject without parens: when expr { ... }
                hasSubject = true
                subjectExpr = parseExpression()
            }
        }

        // Parse the brace-enclosed pattern arms
        consume(SeenTokenType.LeftBrace, "Expected '{' after when expression")

        let whenExpr = ParserExpressionNode.new()
        whenExpr.kind = "WhenExpression"
        // operands[0] = subject expression (if present)
        if hasSubject {
            whenExpr.operands.push(subjectExpr)
        }
        // arguments holds the pattern arms

        // Parse pattern arms until closing brace
        while not checkToken(SeenTokenType.RightBrace) and not isAtEnd() {
            let armExpr = parsePatternArmExpr()
            whenExpr.arguments.push(armExpr)

            // Optional comma between arms
            if matchTokenStr(SeenTokenType.Comma) {
                // continue
            }
        }

        consume(SeenTokenType.RightBrace, "Expected '}' after when expression")
        return whenExpr
    }

    // Parse `match subject { Pattern -> result, ... }`.
    // Identical to when-expression semantics but the subject is NOT
    // parenthesized.  Both produce the same WhenExpression AST node.
    fun parseMatchExpression() r: ParserExpressionNode {
        advance() // consume 'match' keyword

        // Parse subject expression without parentheses
        let subjectExpr = parseExpression()

        consume(SeenTokenType.LeftBrace, "Expected '{' after match subject")

        let matchExpr = ParserExpressionNode.new()
        matchExpr.kind = "WhenExpression"
        matchExpr.operands.push(subjectExpr)

        while not checkToken(SeenTokenType.RightBrace) and not isAtEnd() {
            let armExpr = parsePatternArmExpr()
            matchExpr.arguments.push(armExpr)
            if matchTokenStr(SeenTokenType.Comma) {
                // continue
            }
        }

        consume(SeenTokenType.RightBrace, "Expected '}' after match expression")
        return matchExpr
    }

    // Parse a single pattern arm directly into ParserExpressionNode
    // Returns: kind="PatternArm", variableName=pattern kind, literalValue=type/literal value,
    //          operands[0]=pattern expr, operands[1]=arm result expr
    fun parsePatternArmExpr() r: ParserExpressionNode {
        let armExpr = ParserExpressionNode.new()
        armExpr.kind = "PatternArm"

        // Parse pattern into a Pattern expression node
        let patternExpr = parsePatternExpr()
        armExpr.variableName = patternExpr.variableName  // pattern kind
        armExpr.literalValue = patternExpr.literalValue   // type name or literal value

        // Optional guard clause: 'if guard_expr'
        var guardExpr = ParserExpressionNode.new()
        var hasGuard = false
        if checkToken(SeenTokenType.KeywordIf) {
            advance() // consume 'if'
            guardExpr = parseExpression()
            hasGuard = true
        }

        // Expect arrow -> or fat arrow =>
        if not matchTokenStr(SeenTokenType.Arrow) {
            if checkToken(SeenTokenType.Equal) {
                let eqNext = peekAt(1)
                if eqNext.getValue() == ">" {
                    advance()
                    advance()
                }
            }
        }

        // Parse the result expression or return statement for this arm
        if checkToken(SeenTokenType.KeywordReturn) {
            advance()
            let retExpr = ParserExpressionNode.new()
            retExpr.kind = "ReturnExpr"
            if not checkToken(SeenTokenType.RightBrace) and not checkToken(SeenTokenType.Comma) {
                let retVal = parseExpression()
                retExpr.operands.push(retVal)
            }
            armExpr.operands.push(patternExpr)
            armExpr.operands.push(retExpr)
            if hasGuard {
                armExpr.operands.push(guardExpr)
            }
            return armExpr
        }
        let resultExpr = parseExpression()

        armExpr.operands.push(patternExpr)
        armExpr.operands.push(resultExpr)
        if hasGuard {
            armExpr.operands.push(guardExpr) // [2] = guard condition
        }

        return armExpr
    }

    // Parse a pattern directly into ParserExpressionNode
    // Returns: kind="Pattern", variableName=pattern kind, literalValue=type/literal value,
    //          literalType=type for literals, operands=field bindings
    fun parsePatternExpr() r: ParserExpressionNode {
        let expr = ParserExpressionNode.new()
        expr.kind = "Pattern"

        // Check for 'is' keyword
        if checkToken(SeenTokenType.KeywordIs) {
            advance() // consume 'is'

            // Check if the next token is a literal (is 1, is "hello", is true/false)
            if checkToken(SeenTokenType.IntegerLiteral) {
                expr.variableName = "Literal"
                expr.literalType = "Int"
                expr.literalValue = advance().getValue()
                return expr
            }
            if checkToken(SeenTokenType.StringLiteral) {
                expr.variableName = "Literal"
                expr.literalType = "String"
                expr.literalValue = advance().getValue()
                return expr
            }
            if checkToken(SeenTokenType.KeywordTrue) {
                expr.variableName = "Literal"
                expr.literalType = "Bool"
                expr.literalValue = "true"
                advance()
                return expr
            }
            if checkToken(SeenTokenType.KeywordFalse) {
                expr.variableName = "Literal"
                expr.literalType = "Bool"
                expr.literalValue = "false"
                advance()
                return expr
            }

            // Otherwise it's an enum variant type/constructor name
            expr.variableName = "Is"
            if checkToken(SeenTokenType.Identifier) {
                var patIdent = advance().getValue()
                // Support EnumType.Variant syntax: skip type name, use variant
                if checkToken(SeenTokenType.Dot) {
                    advance()
                    if checkToken(SeenTokenType.Identifier) {
                        patIdent = advance().getValue()
                    }
                }
                expr.literalValue = patIdent
            }

            // Check for destructuring: TypeName(field1, field2, ...)
            if checkToken(SeenTokenType.LeftParen) {
                advance() // consume '('

                // Parse field bindings
                if not checkToken(SeenTokenType.RightParen) {
                    // First field
                    let field = parsePatternFieldExpr()
                    expr.operands.push(field)

                    // Additional fields separated by comma
                    while matchTokenStr(SeenTokenType.Comma) {
                        let nextField = parsePatternFieldExpr()
                        expr.operands.push(nextField)
                    }
                }

                consume(SeenTokenType.RightParen, "Expected ')' after pattern fields")
            }

            return expr
        }

        // Check for 'else' keyword as wildcard pattern
        if checkToken(SeenTokenType.KeywordElse) {
            advance()
            expr.variableName = "Wildcard"
            return expr
        }

        // Check for bare EnumType.Variant pattern (without 'is' keyword)
        if checkToken(SeenTokenType.Identifier) {
            let patVal = peek().getValue()
            let patFirstByte = patVal.byteAt(0)
            if patFirstByte >= 65 and patFirstByte <= 90 {
                let patNext = peekAt(1)
                if patNext.getValue() == "." {
                    advance()
                    advance()
                    expr.variableName = "Is"
                    if checkToken(SeenTokenType.Identifier) {
                        expr.literalValue = advance().getValue()
                    }
                    return expr
                }
            }
        }

        // Check for wildcard pattern: _
        if checkToken(SeenTokenType.Identifier) {
            let ident = peek().getValue()
            if ident == "_" {
                advance()
                expr.variableName = "Wildcard"
                return expr
            }
        }

        // Check for literal pattern (number, string, boolean)
        if checkToken(SeenTokenType.IntegerLiteral) {
            expr.variableName = "Literal"
            expr.literalType = "Int"
            expr.literalValue = advance().getValue()
            return expr
        }
        if checkToken(SeenTokenType.StringLiteral) {
            expr.variableName = "Literal"
            expr.literalType = "String"
            expr.literalValue = advance().getValue()
            return expr
        }
        if checkToken(SeenTokenType.KeywordTrue) {
            expr.variableName = "Literal"
            expr.literalType = "Bool"
            expr.literalValue = "true"
            advance()
            return expr
        }
        if checkToken(SeenTokenType.KeywordFalse) {
            expr.variableName = "Literal"
            expr.literalType = "Bool"
            expr.literalValue = "false"
            advance()
            return expr
        }

        // Default: treat as variable binding pattern
        if checkToken(SeenTokenType.Identifier) {
            expr.variableName = "Variable"
            expr.callee = advance().getValue()
            return expr
        }

        // Unknown pattern - advance to avoid infinite loop
        advance()
        expr.variableName = "Unknown"
        return expr
    }

    // Parse a single field binding into ParserExpressionNode
    // Returns: kind="PatternField", variableName=field name, literalValue=binding name
    fun parsePatternFieldExpr() r: ParserExpressionNode {
        let fieldExpr = ParserExpressionNode.new()
        fieldExpr.kind = "PatternField"

        if checkToken(SeenTokenType.Identifier) {
            let name = advance().getValue()
            fieldExpr.variableName = name
            fieldExpr.literalValue = name  // Default: binding name same as field name

            // Check for explicit binding: fieldName: bindingName
            if matchTokenStr(SeenTokenType.Colon) {
                if checkToken(SeenTokenType.Identifier) {
                    fieldExpr.literalValue = advance().getValue()
                }
            }
        }

        return fieldExpr
    }

    // -- Utility helpers --------------------------------------------------
    fun inferVisibility(name: String) r: String {
        if name.length() == 0 {
            return "private"
        }
        let first = name.charAt(0)
        if first >= 'A' {
            if first <= 'Z' {
                return "public"
            }
        }
        return "private"
    }

    // BOOTSTRAP CONSTRAINT: keep new() at the end of the class. Older bootstrap
    // compilers can silently drop later RealParser methods after parsing the
    // generic Array<...>() initializers in this constructor.
    static fun new(rawTokens: Array<Token>) r: RealParser {
        return RealParser{
            // parseEffectModifierInto() handles KeywordEffect directly, so avoid
            // rebuilding Array<Token> here. Older bootstrap compilers can
            // miscompile rewriteEffectTokens() and drop every token.
            tokens: rawTokens,
            current: 0,
            currentProgram: ProgramNode.new(),
            currentBlock: BlockNode.new(),
            lastStatement: StatementNode.new(),
            lastParsedBlock: BlockNode.new(),
            lastFunction: FunctionNode.new(),
            pendingDecorators: Array<AnnotationNode>(),
            pendingSealedModifier: 0,
            blockStack: Array<BlockNode>(),
            statementStack: Array<StatementNode>(),
            blockStackDepth: 0,
            lastParsedTypeName: "Unknown",
            lastParsedTypeNullable: false,
            pendingFunctionReturnTypeName: "Unknown",
            pendingFunctionReturnTypeNullable: false,
            pendingFunctionParamTypeNames: Array<String>(),
            pendingFunctionParamTypeNullables: Array<Int>()
        }
    }

}


 
