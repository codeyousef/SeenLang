        }
    }
}

// Utility functions
fun WriteFile(path: String, content: String) -> Bool { return __WriteFile(path, content) != 0 }

fun ExecuteCommand(command: String) -> CommandResult {
    let trimmed = trim(command)
    if startsWith(trimmed, "seen ")
        or contains(trimmed, " seen ")
        or contains(trimmed, "seen build")
        or contains(trimmed, "seen_cli")
    {
        println("Stage compiler: refusing to invoke Seen CLI command -> {command}")
        return CommandResult{
            success: false,
            output: "Stage compiler forbids invoking seen/seen_cli commands"
        }
    }

    let result: CommandResult = __ExecuteCommand(command)
    return CommandResult{ success: result.success, output: result.output }
}

data CommandResult {
    success: Bool
    output: String
}

// Command-line argument parser for the compiler
data CompilerArgs {
    command: String
    inputFile: String
    outputFile: String
    language: String
    verbose: Bool
}

fun defaultCompilerArgs() -> CompilerArgs {
    return CompilerArgs{
        command: "compile",
        inputFile: "",
        outputFile: "output",
        language: "en",
        verbose: false
    }
}

fun parseArgs(args: Array<String>) -> CompilerArgs {
    println("DEBUG: Inside parseArgs")
    var compilerArgs = defaultCompilerArgs()
    println("DEBUG: Created default args")
    
    if args.length() > 1 {
        compilerArgs.command = args[1]
    }
    
    if args.length() > 2 {
        compilerArgs.inputFile = args[2]
    }
    
    if args.length() > 3 {
        compilerArgs.outputFile = args[3]
    }
    
    println("DEBUG: Returning args")
    return compilerArgs
}

extern fun __GetCommandLineArg(index: Int) -> String
extern fun __GetCommandLineArgCount() -> Int

// Main entry point - proper compiler interface
fun main() -> Int {
    println("DEBUG: Starting main...")
    let argc = __GetCommandLineArgCount();
    println("DEBUG: Got args. Length: " + argc.toString())
    
    if argc < 2 {
        println("Seen Self-Hosting Compiler v1.0")
        println("Usage: seen compile <input.seen> [output]")
        return 1
    }
    
    // Parse args into local variables
    var cmd = "compile";
    var inputFile = "";
    var outputFile = "a.out";
    
    if argc > 1 {
        cmd = __GetCommandLineArg(1);
    }
    
    if argc > 2 {
        inputFile = __GetCommandLineArg(2);
    }
    
    if argc > 3 {
        outputFile = __GetCommandLineArg(3);
    }
    
    println("DEBUG: Parsed args. Command: " + cmd)
    
    if cmd == "compile" {
        return compileCommand(inputFile, outputFile)
    }
    if cmd == "check" {
        return checkCommand(inputFile)
    }
    if cmd == "run" {
        return runCommand(inputFile)
    }
    if cmd == "bootstrap" {
        return bootstrapCommand()
    }
    if cmd == "debug" {
        println("Debug command works!")
        return 0
    }
    
    println("❌ Unknown command: " + cmd)
    return 1
}

fun compileCommand(inputFile: String, outputFile: String) -> Int {
    println("🚀 Seen Self-Hosting Compiler")
    println("   Compiling: " + inputFile)
    
    let source = ReadFile(inputFile)
    println("   Read " + source.length().toString() + " bytes")
    
    let success = CompileSeenProgram(source, outputFile)
    
    if success {
        println("✅ Compilation successful!")
        return 0
    } else {
        println("❌ Compilation failed!")
        return 1
    }
}

fun checkCommand(inputFile: String) -> Int {
    println("🔍 Seen Type Checker")
    println("   Checking: " + inputFile)
    return 0
}

fun runCommand(inputFile: String) -> Int {
    println("🏃 Seen Compile & Run")
    println("   Processing: " + inputFile)
    return 0;
}

fun bootstrapCommand() -> Int {
    println("🚀 Seen Self-Hosting Compiler Bootstrap")
    println("=========================================")
    
    let testCodePath = "seen_std/tests/minimal_bootstrap.seen"
    let source = ReadFile(testCodePath)
    let success = CompileSeenProgram(source, "bootstrap_test")
    
    if success {
        println("\n✅ BOOTSTRAP SUCCESSFUL!")
        println("   Self-hosting compiler is operational")
        
        // Test the compiled program
        println("\n🧪 Testing compiled output...")
        let testResult = ExecuteCommand("./bootstrap_test")
        
        if testResult.success {
            println("✅ Bootstrap test passed!")
            return 0
        } else {
            println("❌ Bootstrap test failed")
            return 1
        }
    } else {
        println("\n❌ Bootstrap failed")
        return 1
    }
}

// Test the compiler with Seen syntax examples
fun TestCompiler() {
    // Example following Seen syntax design
    let testCodePath = "seen_std/tests/minimal_bootstrap.seen"
    let testCode = ReadFile(testCodePath)
    
    println("=== Testing Compiler with Seen Syntax ===")
    let success = CompileSeenProgram(testCode, "test_output")
    
    if success {
        println("✅ Test compilation successful!")
    } else {
        println("❌ Test compilation failed!")
    }
}

// Runtime bridges
extern fun __FileExists(path: String) -> Bool

fun GetCommandLineArgs() -> Array<String> {
    return __GetCommandLineArgs()
}

fun ReadFile(path: String) -> String {
    return __ReadFile(path)
}
fun readText(path: String) -> String {
    return __ReadFile(path)
}

fun writeText(path: String, contents: String) -> Bool {
    return __WriteFile(path, contents) != 0
}

fun appendText(path: String, contents: String) -> Bool {
    let old = readText(path)
    return writeText(path, old + contents)
}

fun FileExists(path: String) -> Bool {
    return __FileExists(path)
}

fun GetFileSize(path: String) -> Int {
    let content = readText(path)
    return content.length()
}

fun GetFileHash(path: String) -> String {
    return ""
}

fun getCurrentTime() -> Float {
    return __GetTimestamp() as Float
}

fun runCommand(command: String) -> Int {
    let res = __ExecuteCommand(command)
    if res.success { return 0 }
    return 1
}

// MVP: CommandResult-returning version for process module compatibility
fun runCommandWithOutput(command: String) -> CommandResult {
    return __ExecuteCommand(command)
}

fun commandWasSuccessful(exitCode: Int) -> Bool {
    return exitCode == 0
}

fun commandWasSuccessful(result: CommandResult) -> Bool {
    return result.success
}

fun commandOutput(command: String) -> String {
    return __CommandOutput(command)
}

fun commandOutput(result: CommandResult) -> String {
    return result.output
}

fun shellQuote(arg: String) -> String {
    // Simple shell quoting - wrap in single quotes and escape existing single quotes
    return "'" + replace(arg, "'", "'\\''") + "'"
}

fun join(items: Array<String>, separator: String) -> String {
    var result = ""
    var first = true
    for item in items {
        if !first {
            result = result + separator
        }
        result = result + item
        first = false
    }
    return result
}

fun joinLines(lines: Array<String>) -> String {
    var result = ""
    for line in lines {
        result = result + line + "\n"
    }
    return result
}

fun ensureParentDirectories(path: String) -> Bool {
    let dir = dirname(path)
    if dir.length() > 0 {
        return __CreateDirectory(dir)
    }
    return true
}

fun lastSlashIndex(path: String) -> Int {
    var index = path.length() - 1
    while index >= 0 {
        let code = path[index] as Int
        if code == 47 or code == 92 {
            return index
        }
        index = index - 1
    }
    return -1
}

fun dirname(path: String) -> String {
    let idx = lastSlashIndex(path)
    if idx < 0 {
        return ""
    }
    return substring(path, 0, idx)
}

// Hash map utilities
fun nextPowerOfTwo(value: Int) -> Int {
    var size = 1
    while size < value {
        size = size * 2
    }
    return size
}

fun hashString(value: String) -> Int {
    var hash = 0
    var index = 0
    while index < value.length() {
        hash = ((hash * 31) + (value[index] as Int)) % 2147483647
        index = index + 1
    }
    return hash
}

fun defaultCapacity() -> Int {
    return 16
}

fun maxLoadPercent() -> Int {
    return 75
}

fun tombstoneState() -> Int {
    return -1
}

// String utilities
fun isWhitespace(c: Char) -> Bool {
    let code = c as Int
    return code == 32 or code == 9 or code == 10 or code == 13
}

fun substring(s: String, start: Int, end: Int) -> String {
    var res = ""
    var i = start
    while i < end {
        res = res + s[i]
        i = i + 1
    }
    return res
}

fun trimStart(s: String) -> String {
    var i = 0
    while i < s.length() and isWhitespace(s[i]) {
        i = i + 1
    }
    return substring(s, i, s.length())
}

fun trimEnd(s: String) -> String {
    var i = s.length() - 1
    while i >= 0 and isWhitespace(s[i]) {
        i = i - 1
    }
    return substring(s, 0, i + 1)
}

fun trim(value: String) -> String {
    return trimEnd(trimStart(value))
}

fun replace(s: String, old: String, new: String) -> String {
    var res = ""
    var i = 0
    while i < s.length() {
        if i + old.length() <= s.length() and substring(s, i, i + old.length()) == old {
            res = res + new
            i = i + old.length()
        } else {
            res = res + s[i]
            i = i + 1
        }
    }
    return res
}

fun startsWith(text: String, prefix: String) -> Bool {
    if prefix.length() > text.length() {
        return false
    }
    var i = 0
    while i < prefix.length() {
        if text[i] != prefix[i] {
            return false
        }
        i = i + 1
    }
    return true
}

fun contains(text: String, substring: String) -> Bool {
    if substring.length() == 0 {
        return true
    }
    if substring.length() > text.length() {
        return false
    }
    var i = 0
    while i <= text.length() - substring.length() {
        var j = 0
        var isMatch = true
        while j < substring.length() {
            if text[i + j] != substring[j] {
                isMatch = false
                j = substring.length()
            } else {
                j = j + 1
            }
        }
        if isMatch {
            return true
        }
        i = i + 1
    }
    return false
}
