fun sourcesNeedRawVulkanLink(modulePaths: Array<String>) r: Bool {
    var mi = 0
    while mi < modulePaths.length() {
        let modulePath = modulePaths[mi]
        if modulePath.contains("/seen_vk/src/") {
            return true
        }
        let sourceText = readText(modulePath)
        if sourceText.contains("extern fun vk") or
            sourceText.contains("extern \"C\" fun vk") {
            return true
        }
        mi = mi + 1
    }
    return false
}

fun sourcesNeedSdl3Link(modulePaths: Array<String>) r: Bool {
    var mi = 0
    while mi < modulePaths.length() {
        let modulePath = modulePaths[mi]
        if modulePath.contains("/seen_window/src/") {
            return true
        }
        let sourceText = readText(modulePath)
        if sourceText.contains("extern fun SDL_") or
            sourceText.contains("extern \"C\" fun SDL_") {
            return true
        }
        mi = mi + 1
    }
    return false
}

fun appendHostPkgOrFallbackLinkFlag(linkLibs: String, pkg: String,
    fallbackFlag: String) r: String {

    let pkgLibs = pkgConfigOutput("--libs", pkg)
    if pkgLibs != "" {
        return linkLibs + " " + pkgLibs
    }
    return linkLibs + " " + fallbackFlag
}

fun sourcesNeedTeeHardwareRuntime(modulePaths: Array<String>) r: Bool {
    var mi = 0
    while mi < modulePaths.length() {
        let modulePath = modulePaths[mi]
        if modulePath.endsWith("/seen_std/src/security/enclave.seen") {
            return true
        }
        let sourceText = readText(modulePath)
        if sourceText.contains("@enclave") or sourceText.contains("@seal(") or sourceText.contains("@attestation(") {
            return true
        }
        mi = mi + 1
    }
    return false
}

fun buildTargetLinkLibraries(target: String, hasGpuRuntime: Bool) r: String {
    var libs = " -lm -lpthread"
    if target == "windows-x86_64" {
        libs = ""
    } else {
        if target == "android-arm64" {
            libs = " -lm -ldl"
        } else {
            if targetIsIosFamily(target) {
                libs = " -lm"
            } else {
                if target == "macos-arm64" or target == "macos-x86_64" {
                    libs = " -lm"
                }
            }
        }
    }
    if hasGpuRuntime {
        if target == "windows-x86_64" {
            libs = libs + " -lvulkan-1"
        } else {
            if target == "macos-arm64" or target == "macos-x86_64" or targetIsIosFamily(target) {
            } else {
                libs = libs + " -lvulkan"
            }
        }
    }
    return libs
}

fun writeObjectManifest(manifestPath: String, objectFiles: Array<String>,
    sourcePaths: Array<String>) r: Bool {

    if manifestPath == "" {
        return true
    }
    if objectFiles.length() != sourcePaths.length() {
        return false
    }

    let manifestDir = getSourceDir(manifestPath)
    if manifestDir != "" {
        let mkdirResult: CommandResult =
            runCommand("mkdir -p " + shellQuote(manifestDir))
        if not commandWasSuccessful(mkdirResult) {
            return false
        }
    }

    var content = ""
    var i = 0
    while i < objectFiles.length() {
        content = content + objectFiles[i] + "\t" + sourcePaths[i] + "\n"
        i = i + 1
    }
    return writeText(manifestPath, content)
}

fun buildTargetClangArgs(target: String) r: String {
    if target == "" {
        return ""
    }
    if target == "ios-arm64" {
        let sdkResult: CommandResult = runCommand("xcrun --sdk iphoneos --show-sdk-path")
        if commandWasSuccessful(sdkResult) {
            return "-target arm64-apple-ios17.0 -isysroot " + sdkResult.output.trim()
        }
        return "-target arm64-apple-ios17.0"
    }
    if target == "ios-sim-arm64" {
        let sdkResult: CommandResult = runCommand("xcrun --sdk iphonesimulator --show-sdk-path")
        if commandWasSuccessful(sdkResult) {
            return "-target arm64-apple-ios17.0-simulator -isysroot " + sdkResult.output.trim()
        }
        return "-target arm64-apple-ios17.0-simulator"
    }
    if target == "macos-arm64" {
        return "-target arm64-apple-macosx14.0"
    }
    if target == "macos-x86_64" {
        return "-target x86_64-apple-macosx14.0"
    }
    if target == "linux-arm64" {
        if detectHostTargetName() == "linux-arm64" {
            return "--target=aarch64-unknown-linux-gnu"
        }
        let sysroot = getLinuxArm64Sysroot()
        if sysroot != "" {
            var args = "--target=aarch64-unknown-linux-gnu --sysroot=" + sysroot
            let gccToolchain = getLinuxArm64GccToolchain(sysroot)
            if gccToolchain != "" {
                args = args + " --gcc-toolchain=" + gccToolchain
            }
            return args
        }
        return ""
    }
    if target == "linux-x86_64" {
        return "--target=x86_64-unknown-linux-gnu"
    }
    if target == "windows-x86_64" {
        return "--target=x86_64-w64-windows-gnu"
    }
    if target == "android-arm64" {
        let apiLevel = getAndroidApiLevel()
        let sysroot = getAndroidSysroot()
        if sysroot != "" {
            return "--target=aarch64-linux-android" + apiLevel + " --sysroot=" + sysroot
        }
        return ""
    }
    return ""
}

fun buildTargetClangDriver(target: String) r: String {
    if target == "android-arm64" {
        let ndkRoot = getAndroidNdkRoot()
        if ndkRoot != "" {
            let hostTag = getAndroidNdkHostTag()
            let apiLevel = getAndroidApiLevel()
            let wrapper = ndkRoot + "/toolchains/llvm/prebuilt/" + hostTag + "/bin/aarch64-linux-android" + apiLevel + "-clang"
            let wrapperCheck: CommandResult = runCommand("test -x " + wrapper)
            if commandWasSuccessful(wrapperCheck) {
                return wrapper
            }
            let ndkClang = ndkRoot + "/toolchains/llvm/prebuilt/" + hostTag + "/bin/clang"
            let clangCheck: CommandResult = runCommand("test -x " + ndkClang)
            if commandWasSuccessful(clangCheck) {
                return ndkClang
            }
        }
    }
    return "clang"
}

fun resolveLlvmToolFromDir(dir: String, tool: String) r: String {
    if dir == "" {
        return ""
    }
    let candidate = dir + "/" + tool
    let candidateCheck: CommandResult = runCommand("test -x " + candidate)
    if commandWasSuccessful(candidateCheck) {
        return candidate
    }
    return ""
}

fun resolveLlvmTool(tool: String) r: String {
    let pathResult: CommandResult = runCommand("command -v " + tool + " 2>/dev/null")
    if commandWasSuccessful(pathResult) {
        let resolvedPath = pathResult.output.trim()
        if resolvedPath != "" {
            return resolvedPath
        }
    }

    let seenLlvmBinResult: CommandResult = runCommand("printf '%s' \"$SEEN_LLVM_BIN\"")
    if commandWasSuccessful(seenLlvmBinResult) {
        let seenLlvmBin = seenLlvmBinResult.output.trim()
        let resolvedSeenTool = resolveLlvmToolFromDir(seenLlvmBin, tool)
        if resolvedSeenTool != "" {
            return resolvedSeenTool
        }
    }

    let llvmBinResult: CommandResult = runCommand("printf '%s' \"$LLVM_BIN\"")
    if commandWasSuccessful(llvmBinResult) {
        let llvmBin = llvmBinResult.output.trim()
        let resolvedLlvmTool = resolveLlvmToolFromDir(llvmBin, tool)
        if resolvedLlvmTool != "" {
            return resolvedLlvmTool
        }
    }

    let homebrewArmTool = resolveLlvmToolFromDir("/opt/homebrew/opt/llvm/bin", tool)
    if homebrewArmTool != "" {
        return homebrewArmTool
    }
    let homebrewIntelTool = resolveLlvmToolFromDir("/usr/local/opt/llvm/bin", tool)
    if homebrewIntelTool != "" {
        return homebrewIntelTool
    }
    return ""
}

fun compileCommandWithProfileAndCache(inputFile: String, outputFile: String, profile: String, useCache: Bool) r: Int {
    return compileCommandWithAllOptions(inputFile, outputFile, profile, false, useCache, "en", "", "auto", false, "", "", "", "", "")
}

fun compileCommandWithOptions(inputFile: String, outputFile: String, profile: String, panicOnOverflow: Bool, useCache: Bool) r: Int {
    return compileCommandWithAllOptions(inputFile, outputFile, profile, panicOnOverflow, useCache, "en", "", "auto", false, "", "", "", "", "")
}

// Release mode flag: enables cross-module LTO for multi-module builds
var g_releaseMode: Bool = false
// Emit LLVM IR flag: saves .ll files alongside output for debugging
var g_emitLlvm: Bool = false
// Fast mode flag: lightweight optimization for bootstrap verification (Int, not Bool -- Stage1 limitation)
var g_fastMode = 0
// Generated test-main mode leaves module objects for external test runners and skips final link.
var g_generatedTestMainMode = 0
// O2 mode flag: moderate optimization, faster than O3 for bootstrap stages (Int, not Bool -- Stage1 limitation)
var g_O2Mode = 0
// CLI flags for safety checks (Int, not Bool -- Stage1 limitation)
var g_panicOnOverflowCli = 0
var g_boundsCheckCli = 0
var g_warnUnusedResultCli = 0
// Emit GLSL flag for debugging shader generation
var g_emitGlsl = 0
// Safety control CLI flags (Int, not Bool -- Stage1 limitation)
var g_nullSafetyCli = 0
var g_uninitCheckCli = 0
var g_stackCheckCli = 0
var g_sanitizerModeCli = 0
// Feature flags CLI
var g_enabledFeaturesCli: String = ""
// Compilation database output
var g_emitCompileDb = 0
// Emit per-module object files that are safe to link into shared libraries.
var g_picMode = 0
// Optional TSV manifest: object path<TAB>Seen module path.
var g_objectManifestPath: String = ""
// Disable fork-parallel IR generation (use sequential in-process generation)
var g_noFork = 0
///
HeartOn validation passes this legacy project-prefix hint together with
--no-fork. Keep bootstrap builds serial, but allow a bounded worker pool for
large project graphs that explicitly opt into this path.
///
var g_projectPrefixLimit = 0
var g_largeProjectWorkerLimit = 16
var g_largeProjectOptWorkerLimit = 24
///
ThinLTO cache path (/tmp/seen_thinlto_cache) and IR cache path (/tmp/seen_ir_cache)
are inlined as string literals at each use site. Module-level String variables
generate invalid IR (`store %SeenString 0`) in the production compiler, so we
cannot store these as `var g_thinltoCachePath = "/tmp/..."` at module scope.
///

///
Core compilation pipeline: the single function that implements the entire
compile subcommand. Orchestrates a two-pass architecture:

  Pass 1: Parse all modules, register declarations into a shared registry.
          This builds the cross-module symbol table needed for type resolution.

  Pass 2: For each module, check caches (source-level, then IR-level).
          Uncached modules are compiled via fork() for parallelism -- each
          child inherits a CoW copy of the Pass 1 registry. Children write
          .ll files to /tmp and exit; the parent waits for all to complete.

  Pass 2b: Run LLVM opt + ThinLTO-bc in parallel via a generated shell script.
           Each module: opt -O3 -> Polly (best-effort) -> opt --thinlto-bc -> .o

  Pass 3: Link all .o files with clang -flto=thin using LLD (Linux) or ld64
          (macOS). The ThinLTO cache at /tmp/seen_thinlto_cache persists
          across builds for fast incremental links.

Returns 0 on success, 1 on any compilation or linking failure.
///
fun compileCommandWithAllOptions(inputFile: String, outputFile: String, profile: String, panicOnOverflow: Bool, useCache: Bool, language: String, targetCpu: String, simdPolicy: String, simdReport: Bool, sanitizePolicy: String, pgoMode: String, pgoPath: String, mlLogPath: String, crossTarget: String) r: Int {
    ///
    Canonicalize the entry path so symlinked workspaces behave the same as
    the real source tree during module discovery.
    ///
    let resolvedInput = resolveRealInputPath(inputFile)
    if not ensureProjectPackageDependenciesForInput(resolvedInput, true) {
        return 1
    }
    println("Stage1 compiling (Two-Pass Memory Optimized)")
    let isDeterministicProfile = profile == "deterministic"
    if isDeterministicProfile {
        println("  Profile: deterministic")
    }
    if panicOnOverflow {
        println("  Panic on overflow: enabled")
    }

    if g_releaseMode {
        println("  Release mode: cross-module LTO enabled, inline-threshold=2000")
    }
    if g_emitLlvm {
        println("  Emitting LLVM IR alongside output")
    }
    if g_fastMode == 1 {
        println("  Fast mode: lightweight optimization for bootstrap")
    }
    if g_picMode == 1 {
        println("  PIC object emission: enabled")
    }
    if g_O2Mode == 1 {
        println("  O2 mode: moderate optimization for bootstrap stages")
    }

    // Create generator - registries will persist across both passes
    let generator = LLVMIRGenerator.new()
    generator.setPanicOnOverflow(panicOnOverflow)
    // Wire P0 deferred CLI flags to codegen module-level state
    if g_panicOnOverflowCli == 1 {
        generator.setPanicOnOverflow(true)
    }
    if g_boundsCheckCli == 1 {
        generator.setBoundsCheckEnabled(1)
    }
    if g_warnUnusedResultCli == 1 {
        generator.setWarnUnusedResult(1)
    }
    // Safety control flags
    if g_nullSafetyCli == 1 {
        generator.setNullSafetyEnabled(1)
    }
    if g_uninitCheckCli == 1 {
        generator.setUninitCheckEnabled(1)
    }
    if g_stackCheckCli == 1 {
        generator.setStackCheckEnabled(1)
    }
    // Feature flags
    if g_enabledFeaturesCli != "" {
        generator.setEnabledFeatures(g_enabledFeaturesCli)
    }

    let normalizedCrossTarget = normalizeCrossTargetName(crossTarget)
    var effectiveTarget = normalizedCrossTarget
    if effectiveTarget == "" {
        effectiveTarget = detectHostTargetName()
    }
    setComptimeTargetName(effectiveTarget)
    let cacheSignature = buildCacheSignature(profile, language, targetCpu, simdPolicy, sanitizePolicy, pgoMode, effectiveTarget, panicOnOverflow)
    let targetClangArgs = buildTargetClangArgs(effectiveTarget)
    let targetClangDriver = buildTargetClangDriver(effectiveTarget)
    let targetRuntimeFlags = buildTargetRuntimeCompileFlags(effectiveTarget)
    let llvmOptTool = resolveLlvmTool("opt")
    let llvmLlcTool = resolveLlvmTool("llc")
    let llvmLinkTool = resolveLlvmTool("llvm-link")

    if normalizedCrossTarget == "android-arm64" and targetClangArgs == "" {
        println("  Error: Android cross-compilation requires ANDROID_NDK_HOME or ANDROID_NDK_ROOT with a valid LLVM sysroot")
        return 1
    }
    if normalizedCrossTarget != "android-arm64" and llvmOptTool == "" {
        println("  Error: LLVM tool not found: opt")
        println("  Hint: install LLVM or set SEEN_LLVM_BIN to your LLVM bin directory")
        return 1
    }
    if g_fastMode == 1 and normalizedCrossTarget != "android-arm64" and llvmLlcTool == "" {
        println("  Error: LLVM tool not found: llc")
        println("  Hint: install LLVM or set SEEN_LLVM_BIN to your LLVM bin directory")
        return 1
    }
    if normalizedCrossTarget == "linux-arm64" and detectHostTargetName() != "linux-arm64" and targetClangArgs == "" {
        println("  Error: Linux ARM64 cross-compilation requires SEEN_LINUX_ARM64_SYSROOT or an installed aarch64 sysroot such as /usr/aarch64-linux-gnu")
        return 1
    }

    // Cross-compilation: override target triple and data layout
    if normalizedCrossTarget != "" {
        if normalizedCrossTarget == "ios-sim-arm64" {
            overrideTargetTriple("arm64-apple-ios17.0-simulator", "e-m:o-i64:64-i128:128-n32:64-S128")
            println("  Cross-compiling for iOS Simulator ARM64")
        } else {
            if normalizedCrossTarget == "ios-arm64" {
            overrideTargetTriple("arm64-apple-ios17.0", "e-m:o-i64:64-i128:128-n32:64-S128")
            println("  Cross-compiling for iOS ARM64")
        } else {
            if normalizedCrossTarget == "macos-arm64" {
                overrideTargetTriple("arm64-apple-macosx14.0", "e-m:o-i64:64-i128:128-n32:64-S128")
                println("  Cross-compiling for macOS ARM64")
            } else {
                if normalizedCrossTarget == "macos-x86_64" {
                    overrideTargetTriple("x86_64-apple-macosx14.0", "e-m:o-p270:32:32-p271:32:32-p272:64:64-i64:64-i128:128-f80:128-n8:16:32:64-S128")
                    println("  Cross-compiling for macOS x86_64")
                } else {
                    if normalizedCrossTarget == "linux-x86_64" {
                        overrideTargetTriple("x86_64-unknown-linux-gnu", "e-m:e-p270:32:32-p271:32:32-p272:64:64-i64:64-f80:128-n8:16:32:64-S128")
                        println("  Cross-compiling for Linux x86_64")
                    } else {
                        if normalizedCrossTarget == "linux-arm64" {
                            overrideTargetTriple("aarch64-unknown-linux-gnu", "e-m:e-i8:8:32-i16:16:32-i64:64-i128:128-n32:64-S128")
                            println("  Cross-compiling for Linux ARM64")
                        } else {
                            if normalizedCrossTarget == "windows-x86_64" {
                                overrideTargetTriple("x86_64-w64-windows-gnu", "e-m:w-p270:32:32-p271:32:32-p272:64:64-i64:64-f80:128-n8:16:32:64-S128")
                                println("  Cross-compiling for Windows x86_64")
                            } else {
                                if normalizedCrossTarget == "android-arm64" {
                                    let androidTriple = "aarch64-linux-android" + getAndroidApiLevel()
                                    overrideTargetTriple(androidTriple, "e-m:e-i8:8:32-i16:16:32-i64:64-i128:128-n32:64-S128")
                                    println("  Cross-compiling for Android ARM64")
                                } else {
                                    println("  Warning: Unknown cross-target '" + crossTarget + "', using host platform")
                                }
                            }
                        }
                    }
                }
            }
        }
        }
    }

    // Split mlLogPath which may contain "|decisionLogPath" encoded by CLI
    var actualMlLogPath = mlLogPath
    var mlDecisionLogPath = ""
    var splitIdx = 0
    while splitIdx < mlLogPath.length() {
        if mlLogPath.substring(splitIdx, splitIdx + 1) == "|" {
            actualMlLogPath = mlLogPath.substring(0, splitIdx)
            mlDecisionLogPath = mlLogPath.substring(splitIdx + 1, mlLogPath.length())
            splitIdx = mlLogPath.length()
        }
        splitIdx = splitIdx + 1
    }

    ///
    Set type header path for ABI compatibility with Rust bootstrap compiler
    Also encode ML decision log path via "|ml:" delimiter (bootstrap-safe channel)
    ///
    var headerArg = "seen_types.ll"
    if mlDecisionLogPath.length() > 0 {
        headerArg = headerArg + "|ml:" + mlDecisionLogPath
    }
    generator.setTypeHeaderPath(headerArg)

    ///
    ============================================================
    : Dependency management -- parse Seen.toml if present
    ============================================================
    Reads [native.dependencies] (and legacy system=true entries inside
    [dependencies]) for native library link flags, [features] for
    compile-time feature flags, and [assets] for shader files to compile
    with glslc before linking.
    ///
    var tomlExtraLinkFlags = ""
    var tomlAssetShaders = ""
    let tomlPath = findNearestSeenTomlForInput(resolvedInput)
    let tomlContent = loadFileContent(tomlPath)
    if tomlContent != "" {
        let projectRoot = getSourceDir(tomlPath)
        println("  Reading Seen.toml...")
        var tomlSection = ""
        var tomlLineStart = 0
        var tomlPos = 0
        while tomlPos <= tomlContent.length() {
            var tomlAtEnd = 0
            if tomlPos == tomlContent.length() {
                tomlAtEnd = 1
            }
            var tomlIsNewline = 0
            if tomlAtEnd == 0 {
                let tomlByte = tomlContent.byteAt(tomlPos)
                if tomlByte == 10 {
                    tomlIsNewline = 1
                }
            }
            if tomlIsNewline == 1 or tomlAtEnd == 1 {
                let tomlLine = tomlContent.substring(tomlLineStart, tomlPos)
                let tomlLineTrimmed = tomlLine.trim()
                // Section headers: [dependencies], [native.dependencies], [features], [assets]
                if tomlLineTrimmed.startsWith("[") and tomlLineTrimmed.endsWith("]") {
                    tomlSection = tomlLineTrimmed.substring(1, tomlLineTrimmed.length() - 1)
                } else {
                    if tomlLineTrimmed != "" and not tomlLineTrimmed.startsWith("#") {
                        // Parse key = value
                        var tomlEqPos = tomlLineTrimmed.indexOf("=", 0)
                        if tomlEqPos > 0 {
                            let tomlKey = tomlLineTrimmed.substring(0, tomlEqPos).trim()
                            let tomlVal = tomlLineTrimmed.substring(tomlEqPos + 1, tomlLineTrimmed.length()).trim()
                            // [native.dependencies] (and legacy [dependencies] system=true) → native link flags
                            if tomlSection == "native.dependencies" or tomlSection == "dependencies" {
                                let tomlDepPath = extractTomlInlineQuotedField(tomlVal, "path")
                                let isLegacySystemDep = tomlSection == "dependencies" and (tomlVal.contains("system = true") or tomlVal.contains("system=true"))
                                let isNativeDepSection = tomlSection == "native.dependencies"
                                if isLegacySystemDep or isNativeDepSection {
                                    tomlExtraLinkFlags = tomlExtraLinkFlags + " -l" + tomlKey
                                    if tomlDepPath != "" {
                                        let resolvedDepPath = resolveProjectPath(projectRoot, tomlDepPath)
                                        tomlExtraLinkFlags = tomlExtraLinkFlags + buildLocalLibrarySearchFlags(resolvedDepPath, effectiveTarget, normalizedCrossTarget)
                                        println("    dep: " + tomlKey + " (system path: " + resolvedDepPath + ")")
                                    } else {
                                        println("    dep: " + tomlKey + " (system)")
                                    }
                                }
                            }
                            // [features] section: feature flags
                            if tomlSection == "features" {
                                g_enabledFeaturesCli = g_enabledFeaturesCli + tomlKey + "|"
                                println("    feature: " + tomlKey)
                            }
                            // [assets] section: shader compilation
                            if tomlSection == "assets" {
                                if tomlKey == "shaders" or tomlVal.contains(".glsl") or tomlVal.contains(".vert") or tomlVal.contains(".frag") or tomlVal.contains(".comp") {
                                    // Strip quotes from value
                                    var shaderPath = tomlVal
                                    if shaderPath.startsWith("\"") {
                                        shaderPath = shaderPath.substring(1, shaderPath.length())
                                    }
                                    if shaderPath.endsWith("\"") {
                                        shaderPath = shaderPath.substring(0, shaderPath.length() - 1)
                                    }
                                    let resolvedShaderPath = resolveProjectPath(projectRoot, shaderPath)
                                    tomlAssetShaders = tomlAssetShaders + resolvedShaderPath + "|"
                                    println("    asset shader: " + resolvedShaderPath)
                                }
                            }
                        }
                    }
                }
                tomlLineStart = tomlPos + 1
            }
            tomlPos = tomlPos + 1
        }
        // Apply features from TOML
        if g_enabledFeaturesCli != "" {
            generator.setEnabledFeatures(g_enabledFeaturesCli)
        }
    }

    // : Compile asset shaders (invoke glslc for each .glsl/.vert/.frag/.comp)
    if tomlAssetShaders != "" {
        var shaderSearchPos = 0
        var shaderPipePos = tomlAssetShaders.indexOf("|", shaderSearchPos)
        while shaderPipePos >= 0 {
            let shaderFile = tomlAssetShaders.substring(shaderSearchPos, shaderPipePos)
            if shaderFile != "" {
                let spvOut = shaderFile + ".spv"
                let shaderCmd = "glslc " + shaderFile + " -o " + spvOut
                println("  Compiling shader: " + shaderFile + " -> " + spvOut)
                let shaderResult: CommandResult = runCommand(shaderCmd)
                if not commandWasSuccessful(shaderResult) {
                    println("  Warning: shader compilation failed for " + shaderFile)
                }
            }
            shaderSearchPos = shaderPipePos + 1
            shaderPipePos = tomlAssetShaders.indexOf("|", shaderSearchPos)
        }
    }

    if tryUseGeneratedTestObjectSetCacheForInput(resolvedInput, cacheSignature, normalizedCrossTarget) {
        return 0
    }

    ///
    ============================================================
    Circular dependency detection
    ============================================================
    Build import graph and run DFS cycle detection before committing to
    compilation. Circular imports would cause the module collector to loop
    and the IR generator to emit incomplete forward references. Catching
    this early gives a clear diagnostic instead of a cryptic linker error.
    ///
    println("  [Pass 0] Discovering module graph...")
    let modulePaths = collectModulePaths(resolvedInput, false)
    println("    Found " + modulePaths.length().toString() + " modules")
    let boundedLargeProjectWorkers = effectiveLargeProjectWorkerLimit(
        modulePaths.length(), resolvedInput.contains("main_compiler.seen"))
    var boundedLargeProjectOptWorkers = 0
    if boundedLargeProjectWorkers > 0 {
        boundedLargeProjectOptWorkers = g_largeProjectOptWorkerLimit
    }
    if boundedLargeProjectWorkers > 0 {
        println("  Large project worker pool: IR " +
            boundedLargeProjectWorkers.toString() + " jobs, opt " +
            boundedLargeProjectOptWorkers.toString() + " jobs")
    }
    if tryUseCompleteGeneratedTestObjectCache(modulePaths, cacheSignature, normalizedCrossTarget) {
        storeGeneratedTestObjectSetCache(resolvedInput, modulePaths, cacheSignature, normalizedCrossTarget)
        return 0
    }
    if shouldRunWholeProjectPreflight(modulePaths) {
        let sealedValidation = validateSealedModules(modulePaths, language)
        if not sealedValidation.success {
            printFrontendDiagnostics(sealedValidation)
            return 1
        }
        var depGraph = Array<String>()   // pipe-delimited adjacency: "from|to1|to2|..."
        var depIdx = 0
        while depIdx < modulePaths.length() {
            let depPath = modulePaths[depIdx]
            let depSourceDir = getSourceDir(depPath)
            let depFe = parseModule(depPath, language)
            var edges = depPath
            if depFe.success {
                var depItemIdx = 0
                while depItemIdx < depFe.program.items.length() {
                    let depItem = depFe.program.items[depItemIdx]
                    if depItem.itemType == "Import" {
                        let depTarget = resolveAstImportItemPath(depItem, depSourceDir)
                        if depTarget != "" {
                            edges = edges + "|" + depTarget
                        }
                    }
                    depItemIdx = depItemIdx + 1
                }
                edges = appendSourceTextImportEdges(edges, depPath)
            }
            depGraph.push(edges)
            depIdx = depIdx + 1
        }
        // DFS cycle check: color 0=white, 1=gray, 2=black, 3=queued
        var depColors = Array<Int>()
        var depCycleFound = 0
        var depCyclePath = ""
        depIdx = 0
        while depIdx < modulePaths.length() {
            depColors.push(0)
            depIdx = depIdx + 1
        }
        ///
        Simple O(V+E) DFS; sufficient for small and medium module graphs.
        Use manual stack via Array<Int> + stackTop counter (no .pop() in runtime)
        ///
        var dfsStack = Array<Int>()
        var dfsStackTop = 0
        depIdx = 0
        while depIdx < modulePaths.length() {
            if depColors[depIdx] == 0 {
                depColors[depIdx] = 3
                dfsStack.push(depIdx)
                dfsStackTop = dfsStackTop + 1
                while dfsStackTop > 0 {
                    let dfsNode = dfsStack[dfsStackTop - 1]
                    if depColors[dfsNode] == 0 or depColors[dfsNode] == 3 {
                        depColors[dfsNode] = 1  // gray = in-progress
                        // Push neighbors
                        let dfsEdges = depGraph[dfsNode]
                        // Parse edges (pipe-delimited, first is self)
                        var dfsPos = 0
                        var dfsFirst = true
                        var dfsSegStart = 0
                        while dfsPos <= dfsEdges.length() {
                            var dfsIsSep = false
                            if dfsPos == dfsEdges.length() { dfsIsSep = true }
                            if not dfsIsSep {
                                if dfsEdges.substring(dfsPos, dfsPos + 1) == "|" { dfsIsSep = true }
                            }
                            if dfsIsSep {
                                if not dfsFirst {
                                    let dfsTarget = dfsEdges.substring(dfsSegStart, dfsPos)
                                    // Find target index
                                    var dfsTargetIdx = 0
                                    while dfsTargetIdx < modulePaths.length() {
                                        if modulePaths[dfsTargetIdx] == dfsTarget {
                                            if depColors[dfsTargetIdx] == 1 {
                                                depCycleFound = 1
                                                depCyclePath = modulePaths[dfsNode] + " -> " + dfsTarget
                                            }
                                            if depColors[dfsTargetIdx] == 0 {
                                                depColors[dfsTargetIdx] = 3
                                                dfsStack.push(dfsTargetIdx)
                                                dfsStackTop = dfsStackTop + 1
                                            }
                                            dfsTargetIdx = modulePaths.length()
                                        }
                                        dfsTargetIdx = dfsTargetIdx + 1
                                    }
                                }
                                dfsFirst = false
                                dfsSegStart = dfsPos + 1
                            }
                            dfsPos = dfsPos + 1
                        }
                    } else {
                        depColors[dfsNode] = 2  // black = done
                        dfsStackTop = dfsStackTop - 1
                    }
                }
            }
            depIdx = depIdx + 1
        }
        if depCycleFound == 1 {
            println("  WARNING: Circular module dependency detected: " + depCyclePath)
        }
    } else if modulePaths.length() > 48 {
        println("  [Pass 0] Large module graph: deferring whole-project validation to streaming passes")
    } else {
        println("  [Pass 0] Compiler-internal module graph: deferring whole-project validation to streaming passes")
    }

    ///
    ============================================================
    PASS 1: Collect module paths and register all declarations
    ============================================================
    Why a separate declaration pass? The IR generator uses a three-pass approach
    (signatures -> types -> implementations). Pass 1 here feeds all module ASTs
    into registerDeclarations() so every function signature, class layout, and
    enum variant is known before any IR is generated. Without this, cross-module
    references (e.g., calling a function defined in a different module) would
    produce "undefined value" errors during IR generation.
    Each AST is released after registration to bound memory usage.
    ///
    println("  [Pass 1] Scanning declarations...")

    var passIdx = 0
    while passIdx < modulePaths.length() {
        let path = modulePaths[passIdx]
        if g_generatedTestMainMode == 0 {
            println("    Scanning: " + path)
        }
        var frontend = parseModuleDeclarations(path, language)
        if isDeterministicProfile {
            frontend = parseModule(path, language)
        }
        if frontend.success {
            generator.registerDeclarations(frontend.program)

            if isDeterministicProfile {
                let deterResult = checkDeterminismWithProfile(frontend.program, true)
                if deterResult.hasErrors() {
                    println("  Determinism check failed for: " + path)
                    printDeterminismErrors(deterResult)
                    return 1
                }
            }
        } else {
            printFrontendDiagnostics(frontend)
            println("    Error: Failed to parse " + path)
            return 1
        }
        // AST goes out of scope here - memory released
        passIdx = passIdx + 1
    }
    println("  [Pass 1] Complete - declarations registered")

    // Optimization pipeline status
    if g_generatedTestMainMode == 0 {
        println("  Optimization pipeline:")
        println("    E-graph rewrite rules: 55 (22 integer, 13 self-comparison, 12 float, 8 FMA)")
        println("    Superoptimizer patterns: 10 (strength reduction in codegen)")
        println("    ML heuristics: inline/unroll/vectorize thresholds from config")
        var pipelineTargetCpu = targetCpu
        if pipelineTargetCpu == "" {
            pipelineTargetCpu = "native"
        }
        if simdPolicy == "none" {
            pipelineTargetCpu = "x86-64"
        }
        println("    Architecture: target-cpu=" + pipelineTargetCpu)
        println("    Memory: LLVM SROA/mem2reg + pool allocator runtime")
        println("    Backend: opt -O3 -> llc -O3 -> clang -O3 -flto")
    }

    ///
    ============================================================
    CACHE: Compute global hash for incremental compilation
    ============================================================
    The source-level cache (.seen_cache/) uses a global registryHash to detect
    when ANY module's declarations change. When the hash changes, all cached .o
    files are invalidated because cross-module type resolution may have changed.
    Cache entries are namespaced by the effective compilation signature so cross-
    target and cross-profile builds never reuse incompatible object files.
    The IR cache (/tmp/seen_ir_cache/) uses per-module keys (signature + registryHash + path)
    for finer granularity -- a body-only change in module A does not invalidate
    module B's IR cache since declarations are unchanged.
    ///
    var registryHash = ""
    var cacheValid = false
    if useCache {
        var globalData = ""
        var gi = 0
        while gi < modulePaths.length() {
            let gpath = modulePaths[gi]
            let gsrc = readText(gpath)
            let gsrcHash = hashString(gsrc)
            globalData = globalData + gpath + ":" + gsrcHash + "\n"
            gi = gi + 1
        }
        registryHash = hashString(cacheSignature + "\n" + globalData)
        ensureCacheDir()
        let cachedRegHash = loadFileContent(".seen_cache/registry.hash")
        if cachedRegHash == registryHash {
            cacheValid = true
        } else {
            // Global state changed -- invalidate all cached .o files
            clearCache()
            ensureCacheDir()
            writeText(".seen_cache/registry.hash", registryHash)
        }
    }

    ///
    ============================================================
    PASS 2: Stream compile each module (one AST at a time)
    ============================================================
    Clean stale per-module LLVM temp files so later invocations cannot
    accidentally reuse or inspect IR/object artifacts from previous builds.
    ///
    let cleanCmd = "rm -f /tmp/seen_module_*.ll /tmp/seen_module_*.o /tmp/seen_module_*.opt.ll /tmp/seen_module_*.polly.ll /tmp/seen_module_*.opt.status /tmp/seen_module_*.opt.log /tmp/seen_parallel_opt.sh"
    __ExecuteProgram(cleanCmd)

    if g_generatedTestMainMode == 0 {
        println("  [Pass 2] Compiling modules...")
    }
    var objectFiles = Array<String>()
    var objectSourcePaths = Array<String>()
    var llFiles = Array<String>()
    var expectedLinkObjects = modulePaths.length()
    var moduleIndex = 0
    var cachedCount = 0
    var uncachedIdxStrs = Array<String>()
    var uncachedSrcPaths = Array<String>()
    var uncachedIrKeys = Array<String>()

    ///
    Fork-parallel IR generation: each uncached module gets its own child process.
    Why fork instead of threads? Fork gives each child a copy-on-write snapshot of
    the parent's entire Pass 1 registry (all declaration tables, type info, struct
    layouts) without any serialization or shared-memory coordination. The child
    writes a .ll file to /tmp and exits. The parent waits for all children, then
    collects the .ll files for the optimization pass.

    When --no-fork is set, modules compile serially in-process and Pass 2b
    runs opt/object emission serially too, which lowers bootstrap memory use.
    Generated test mains are short-lived validation compiles; letting them use
    the parallel path keeps HeartOn's strict test-run timeout attainable while
    the outer memory guard still bounds the process tree.
    ///
    var pass2IrRunsParallel = g_noFork == 0
    if boundedLargeProjectWorkers > 0 {
        pass2IrRunsParallel = true
    }
    if g_generatedTestMainMode == 1 and normalizedCrossTarget != "android-arm64" {
        pass2IrRunsParallel = true
    }
    var forkPids = Array<Int>()
    var forkModuleIdxStrs = Array<String>()
    var forkIrKeys = Array<String>()
    var forkSrcPaths = Array<String>()
    var forkWaitCursor = 0
    var forkFailed = 0

    while moduleIndex < modulePaths.length() {
        let path = modulePaths[moduleIndex]
        var generatedTestObjectCacheKey = ""
        if g_generatedTestMainMode == 1 and normalizedCrossTarget != "android-arm64" {
            generatedTestObjectCacheKey = generatedTestObjectCacheKeyForModule(path, cacheSignature)
            if tryCopyGeneratedTestObjectFromCache(generatedTestObjectCacheKey, moduleIndex) {
                let cachedTestObj = "/tmp/seen_module_" + moduleIndex.toString() + ".o"
                objectFiles.push(cachedTestObj)
                objectSourcePaths.push(path)
                moduleIndex = moduleIndex + 1
                continue
            }
        }

        // Check source-level cache first (fastest: just file comparison)
        if useCache and cacheValid {
            let pathHash = hashString(cacheSignature + ":" + path)
            let sourceContent = readText(path)
            let sourceHash = hashString(sourceContent)
            let cachedHashFile = ".seen_cache/" + pathHash + ".hash"
            let cachedObjFile = ".seen_cache/" + pathHash + ".o"
            let storedHash = loadFileContent(cachedHashFile)
            if storedHash == sourceHash and exists(cachedObjFile) {
                println("    [" + moduleIndex.toString() + "] Cached: " + path)
                objectFiles.push(cachedObjFile)
                objectSourcePaths.push(path)
                cachedCount = cachedCount + 1
                moduleIndex = moduleIndex + 1
                continue
            }
        }

        ///
        IR content-addressed cache: deterministic codegen means identical source +
        identical declarations always produce identical optimized .o files. This cache
        persists across bootstrap stages (stage2 can reuse stage1's cached objects),
        which is critical for keeping bootstrap verification fast.
        Key = hash("v3:" + cacheSignature + ":" + registryHash + ":" + path).
        The "v3" prefix forces a one-time cache miss after broadening the cache key.
        one-time cache miss when the pipeline changes (e.g., llvm-as -> opt --thinlto-bc).
        ///
        var irCacheKey = ""
        var irCacheHit = 0
        if useCache and registryHash != "" {
            irCacheKey = hashString("v3:" + cacheSignature + ":" + registryHash + ":" + path)
            ensureIrCacheDir()
            let irCacheFile = "/tmp/seen_ir_cache/" + irCacheKey + ".o"
            let checkIrCache: CommandResult = runCommand("test -f " + irCacheFile)
            if commandWasSuccessful(checkIrCache) {
                irCacheHit = 1
            }
        }
        if irCacheHit == 1 {
            let irCacheFile = "/tmp/seen_ir_cache/" + irCacheKey + ".o"
            let irCacheObj = "/tmp/seen_module_" + moduleIndex.toString() + ".o"
            let irCopy: CommandResult = runCommand("cp " + irCacheFile + " " + irCacheObj)
            objectFiles.push(irCacheObj)
            objectSourcePaths.push(path)
            println("    [" + moduleIndex.toString() + "] IR cache hit: " + path)
            // Promote to source-level cache to speed up next build within same stage
            if useCache {
                ensureCacheDir()
                let srcPathHash = hashString(cacheSignature + ":" + path)
                let srcContent = readText(path)
                let cpSrcObj: CommandResult = runCommand("cp " + irCacheObj + " .seen_cache/" + srcPathHash + ".o")
                writeText(".seen_cache/" + srcPathHash + ".hash", hashString(srcContent))
            }
            moduleIndex = moduleIndex + 1
            continue
        }

        if not pass2IrRunsParallel {
            // Serial: generate IR in-process (no fork)
            println("    [" + moduleIndex.toString() + "] Generating IR (serial): " + path)
            let llFile = "/tmp/seen_module_" + moduleIndex.toString() + ".ll"
            let moduleStartTime = getTraceTimeSeconds()
            println("    [" + moduleIndex.toString() + "] Parse start")
            let parseStartTime = getTraceTimeSeconds()
            let frontend = parseModule(path, language)
            let parseEndTime = getTraceTimeSeconds()
            if not frontend.success {
                println("[irgen] Parse failed: " + path)
                return 1
            }
            println("    [" + moduleIndex.toString() + "] Parse done in " + (parseEndTime - parseStartTime).toString() + "s")
            println("    [" + moduleIndex.toString() + "] Codegen start")
            let codegenStartTime = getTraceTimeSeconds()
            let llvmIR = generator.generateSingle(frontend.program, moduleIndex)
            let codegenEndTime = getTraceTimeSeconds()
            println("    [" + moduleIndex.toString() + "] Codegen done in " + (codegenEndTime - codegenStartTime).toString() + "s")
            if g_emitLlvm {
                let emitDst = outputFile + ".module" + moduleIndex.toString() + ".ll"
                let emitCp: CommandResult = runCommand("cp " + llFile + " " + emitDst)
            }
            if not writeText(llFile, llvmIR) {
                println("[irgen] Failed to write IR: " + llFile)
                return 1
            }
            let moduleEndTime = getTraceTimeSeconds()
            println("    [" + moduleIndex.toString() + "] Module IR ready in " + (moduleEndTime - moduleStartTime).toString() + "s")
            llFiles.push(llFile)
            uncachedIdxStrs.push(moduleIndex.toString())
            uncachedSrcPaths.push(path)
            uncachedIrKeys.push(irCacheKey)
        } else {
            ///
            Fork a child to generate IR for this module in parallel.
            Child gets a copy-on-write snapshot of the parent's registry from Pass 1.
            ///
            if g_generatedTestMainMode == 0 {
                println("    [" + moduleIndex.toString() + "] Forking IR gen: " + path)
            }
            let pid = processFork()
            if pid < 0 {
                println("    Error: fork() failed for module " + moduleIndex.toString())
                return 1
            } else {
                if pid == 0 {
                    // === CHILD: generate IR, write .ll file, then exit ===
                    let llFile = "/tmp/seen_module_" + moduleIndex.toString() + ".ll"
                    let statusFile = "/tmp/seen_child_status_" + moduleIndex.toString() + ".txt"
                    if g_generatedTestMainMode == 0 {
                        writeText(statusFile, "parse_start\n" + path)
                    }
                    let frontend = parseModule(path, language)
                    if not frontend.success {
                        if g_generatedTestMainMode == 0 {
                            writeText(statusFile, "parse_failed\n" + path)
                        }
                        println("[irgen child] Parse failed: " + path)
                        processExit(1)
                    }
                    if g_generatedTestMainMode == 0 {
                        writeText(statusFile, "parse_done\n" + path)
                        writeText(statusFile, "codegen_start\n" + path)
                    }
                    let llvmIR = generator.generateSingle(frontend.program, moduleIndex)
                    if g_generatedTestMainMode == 0 {
                        writeText(statusFile, "codegen_done\n" + path)
                    }
                    // --emit-llvm: save IR alongside output for debugging
                    if g_emitLlvm {
                        let emitDst = outputFile + ".module" + moduleIndex.toString() + ".ll"
                        let emitCp: CommandResult = runCommand("cp " + llFile + " " + emitDst)
                    }
                    if not writeText(llFile, llvmIR) {
                        if g_generatedTestMainMode == 0 {
                            writeText(statusFile, "write_failed\n" + llFile)
                        }
                        println("[irgen child] Failed to write IR: " + llFile)
                        processExit(1)
                    }
                    if g_generatedTestMainMode == 1 and normalizedCrossTarget != "android-arm64" {
                        let objFile = "/tmp/seen_module_" + moduleIndex.toString() + ".o"
                        let childObjCmd = llvmLlcTool + " -filetype=obj -O0 -relocation-model=pic " + llFile + " -o " + objFile
                        let childObjResult: CommandResult = runCommand(childObjCmd)
                        if not commandWasSuccessful(childObjResult) {
                            if g_generatedTestMainMode == 0 {
                                writeText(statusFile, "object_failed\n" + objFile)
                            }
                            println("    Error: object emission failed for module " + moduleIndex.toString())
                            processExit(1)
                        }
                        storeGeneratedTestObjectInCache(generatedTestObjectCacheKey, objFile)
                    }
                    if g_generatedTestMainMode == 0 {
                        writeText(statusFile, "wrote_ir\n" + llFile)
                    }
                    processExit(0)
                } else {
                    // === PARENT: record child PID for later waitpid ===
                    forkPids.push(pid)
                    forkModuleIdxStrs.push(moduleIndex.toString())
                    forkIrKeys.push(irCacheKey)
                    forkSrcPaths.push(path)
                    if boundedLargeProjectWorkers > 0 {
                        var activeChildren = forkPids.length() - forkWaitCursor
                        while activeChildren >= boundedLargeProjectWorkers {

                            let throttledEc = waitPid(forkPids[forkWaitCursor])
                            let throttledIdx = forkModuleIdxStrs[
                                forkWaitCursor]
                            let throttledStatusFile =
                                "/tmp/seen_child_status_" + throttledIdx +
                                ".txt"
                            if throttledEc != 0 {
                                if g_generatedTestMainMode == 0 {
                                    writeText(throttledStatusFile,
                                        "exit_failed\n" +
                                        throttledEc.toString())
                                }
                                println("    Error: IR gen failed (exit " +
                                    throttledEc.toString() + ") for module " +
                                    throttledIdx)
                                forkFailed = 1
                            } else {
                                if g_generatedTestMainMode == 0 {
                                    writeText(throttledStatusFile,
                                        "exit_ok\n" + throttledIdx)
                                    println("    [" + throttledIdx +
                                        "] Child exit ok")
                                }
                            }
                            forkWaitCursor = forkWaitCursor + 1
                            if forkFailed == 1 {
                                return 1
                            }
                            activeChildren = forkPids.length() - forkWaitCursor
                        }
                    }
                }
            }
        }

        moduleIndex = moduleIndex + 1
    }

    // Wait for all forked children to complete
    var waitIdx = forkWaitCursor
    while waitIdx < forkPids.length() {
        let ec = waitPid(forkPids[waitIdx])
        let statusFile = "/tmp/seen_child_status_" + forkModuleIdxStrs[waitIdx] + ".txt"
        if ec != 0 {
            if g_generatedTestMainMode == 0 {
                writeText(statusFile, "exit_failed\n" + ec.toString())
            }
            println("    Error: IR gen failed (exit " + ec.toString() + ") for module " + forkModuleIdxStrs[waitIdx])
            forkFailed = 1
        } else {
            if g_generatedTestMainMode == 0 {
                writeText(statusFile, "exit_ok\n" + forkModuleIdxStrs[waitIdx])
                println("    [" + forkModuleIdxStrs[waitIdx] + "] Child exit ok")
            }
        }
        waitIdx = waitIdx + 1
    }
    if forkFailed == 1 {
        return 1
    }

    // Register all forked modules for Pass 2B parallel optimization
    var forkReg = 0
    while forkReg < forkModuleIdxStrs.length() {
        let midxStr = forkModuleIdxStrs[forkReg]
        let llFile = "/tmp/seen_module_" + midxStr + ".ll"
        if g_generatedTestMainMode == 1 and normalizedCrossTarget != "android-arm64" {
            let objFile = "/tmp/seen_module_" + midxStr + ".o"
            let checkObj: CommandResult = runCommand("test -f " + objFile)
            if not commandWasSuccessful(checkObj) {
                println("    Error: generated test main object missing for module " + midxStr)
                return 1
            }
            objectFiles.push(objFile)
            objectSourcePaths.push(forkSrcPaths[forkReg])
        } else {
            llFiles.push(llFile)
            uncachedIdxStrs.push(midxStr)
            uncachedSrcPaths.push(forkSrcPaths[forkReg])
            uncachedIrKeys.push(forkIrKeys[forkReg])
        }
        forkReg = forkReg + 1
    }

    ///
    ============================================================
    PASS 2B: Run opt + object emission for all uncached modules
    ============================================================
    Why a generated shell script? LLVM opt is an external process, and we need
    to run N instances with either backgrounded jobs (default) or serially when
    --no-fork requests the lower-memory bootstrap path. Generating a shell script
    is simpler and more portable than managing N fork+exec pairs from Seen code.
    Each module goes through:
      1. opt -O3 (main optimization) -- hard-fail the module on any error
      2. Polly polyhedral optimization (best-effort, skipped in --fast mode)
      3. object emission (ThinLTO bitcode normally, native llc objects in fast mode)
    ///
    if uncachedIdxStrs.length() > 0 {
        var pass2bRunsParallel = g_noFork == 0
        if boundedLargeProjectOptWorkers > 0 {
            pass2bRunsParallel = true
        }
        if g_generatedTestMainMode == 1 and normalizedCrossTarget != "android-arm64" {
            pass2bRunsParallel = true
        }
        var optExecutionMode = "parallel"
        if boundedLargeProjectOptWorkers > 0 {
            optExecutionMode = "bounded"
        }
        if not pass2bRunsParallel {
            optExecutionMode = "serial"
        }
        println("  [Pass 2b] Optimizing " + uncachedIdxStrs.length().toString() + " modules (" + optExecutionMode + ")...")

        // Build opt passes and threshold based on mode
        var optPasses = ""
        var optThreshold = ""
        var optInternalize = ""
        var pgoPasses = ""
        var pgoOptFlags = ""
        if pgoMode == "use" {
            pgoPasses = "pgo-instr-use,"
            pgoOptFlags = " -pgo-test-profile-file=" + pgoPath
        }
        if boundedLargeProjectOptWorkers > 0 {
            optPasses = pgoPasses + "default<O1>"
            optThreshold = "250"
        } else if g_fastMode == 1 {
            optPasses = pgoPasses + "default<O1>"
            optThreshold = "250"
        } else {
            if g_O2Mode == 1 {
                optPasses = "function(sroa,instcombine<no-verify-fixpoint>,simplifycfg)," + pgoPasses + "default<O2>"
                optThreshold = "500"
            } else {
                if modulePaths.length() == 1 {
                    optPasses = "function(sroa,instcombine<no-verify-fixpoint>,simplifycfg)," + pgoPasses + "internalize,default<O3>,function(loop-unroll-and-jam)"
                    optThreshold = "1500"
                    optInternalize = " -internalize-public-api-list=main"
                } else {
                    var inlineThreshold = "1000"
                    if g_releaseMode {
                        inlineThreshold = "2000"
                    }
                    optPasses = "function(sroa,instcombine<no-verify-fixpoint>,simplifycfg)," + pgoPasses + "default<O3>,function(loop-interchange,loop-unroll-and-jam)"
                    optThreshold = inlineThreshold
                }
            }
        }

        // Write parallel optimization shell script
        var script = "#!/bin/sh\n"
        var pi = 0
        while pi < uncachedIdxStrs.length() {
            let midx = uncachedIdxStrs[pi]
            let llFile = "/tmp/seen_module_" + midx + ".ll"
            let optFile = "/tmp/seen_module_" + midx + ".opt.ll"
            let objFile = "/tmp/seen_module_" + midx + ".o"

            var moduleOptCmd = llvmOptTool + " -passes='" + optPasses + "'" + optInternalize + " -inline-threshold=" + optThreshold + " -S " + llFile + " -o " + optFile + pgoOptFlags
            var androidClangOptLevel = "-O3"
            if g_fastMode == 1 {
                androidClangOptLevel = "-O1"
            } else {
                if g_O2Mode == 1 {
                    androidClangOptLevel = "-O2"
                }
            }
            if normalizedCrossTarget == "android-arm64" {
                moduleOptCmd = targetClangDriver + " " + androidClangOptLevel + " -S -emit-llvm -Wno-unused-command-line-argument -x ir " + targetClangArgs + " " + llFile + " -o " + optFile
            }

            if g_generatedTestMainMode == 1 and normalizedCrossTarget != "android-arm64" {
                moduleOptCmd = "cp " + llFile + " " + optFile
            } else if actualMlLogPath != "" {
                moduleOptCmd = moduleOptCmd + " -pass-remarks-output=/tmp/seen_ml_remarks_" + midx + ".yaml -pass-remarks-format=yaml"
            }

            let statusFile = "/tmp/seen_module_" + midx + ".opt.status"
            let logFile = "/tmp/seen_module_" + midx + ".opt.log"
            ///
            Each module writes a status file and log so the parent can stop the
            build on the first optimization/object-emission failure instead of
            silently falling back to raw IR and continuing toward link.
            Normal mode keeps ThinLTO summaries for LLD's cache. Fast mode
            emits native objects directly so generated test binaries avoid
            ThinLTO link overhead.
            ///
            var pollyStep = ""
            if g_fastMode == 0 and normalizedCrossTarget != "android-arm64" and
                boundedLargeProjectOptWorkers == 0 {

                let pollyFile = "/tmp/seen_module_" + midx + ".polly.ll"
                pollyStep = "    (" + llvmOptTool + " -passes='polly-canonicalize,polly' -S " + optFile + " -o " + pollyFile + " >>" + logFile + " 2>&1 && mv " + pollyFile + " " + optFile + ") || true\n"
            }
            var moduleObjCmd = llvmOptTool + " --thinlto-bc " + optFile + " -o " + objFile
            if g_picMode == 1 and normalizedCrossTarget != "android-arm64" {
                var picLlcOptLevel = "-O3"
                if g_fastMode == 1 {
                    picLlcOptLevel = "-O1"
                } else {
                    if g_O2Mode == 1 {
                        picLlcOptLevel = "-O2"
                    }
                }
                moduleObjCmd = llvmLlcTool + " -filetype=obj " +
                    picLlcOptLevel + " -relocation-model=pic " + optFile +
                    " -o " + objFile
            }
            if g_fastMode == 1 and normalizedCrossTarget != "android-arm64" {
                moduleObjCmd = llvmLlcTool + " -filetype=obj -O1 -relocation-model=pic " + optFile + " -o " + objFile
            }
            if g_generatedTestMainMode == 1 and normalizedCrossTarget != "android-arm64" {
                moduleObjCmd = llvmLlcTool + " -filetype=obj -O0 -relocation-model=pic " + optFile + " -o " + objFile
            }
            if normalizedCrossTarget == "android-arm64" {
                var modulePicFlag = ""
                if g_picMode == 1 {
                    modulePicFlag = " -fPIC"
                }
                moduleObjCmd = targetClangDriver + " " + androidClangOptLevel + " -flto=thin -ffunction-sections -fdata-sections" + modulePicFlag + " -Wno-unused-command-line-argument -c -x ir " + targetClangArgs + " " + optFile + " -o " + objFile
            }
            if pass2bRunsParallel and boundedLargeProjectOptWorkers > 0 {
                script = script + "while [ \"$(jobs -p | wc -l | tr -d ' ')\" -ge " + boundedLargeProjectOptWorkers.toString() + " ]; do sleep 0.05; done\n"
            }
            script = script + "(\n"
            script = script + "  rm -f " + objFile + " " + optFile + " " + statusFile + " " + logFile + "\n"
            script = script + "  if " + moduleOptCmd + " >" + logFile + " 2>&1; then\n"
            if pollyStep != "" {
                script = script + pollyStep
            }
            script = script + "    if " + moduleObjCmd + " >>" + logFile + " 2>&1; then\n"
            script = script + "      printf 'ok' > " + statusFile + "\n"
            script = script + "    else\n"
            script = script + "      printf 'object' > " + statusFile + "\n"
            script = script + "    fi\n"
            script = script + "  else\n"
            script = script + "    printf 'opt' > " + statusFile + "\n"
            script = script + "  fi\n"
            if pass2bRunsParallel {
                script = script + ") &\n"
            } else {
                script = script + ")\n"
            }

            pi = pi + 1
        }
        if pass2bRunsParallel {
            script = script + "wait\n"
        }

        if not writeText("/tmp/seen_parallel_opt.sh", script) {
            println("    Error: Failed to write parallel optimization script")
            return 1
        }
        let chmodResult: CommandResult = runCommand("chmod +x /tmp/seen_parallel_opt.sh")
        if not commandWasSuccessful(chmodResult) {
            println("    Error: Failed to make parallel optimization script executable")
            return 1
        }
        let parallelResult: CommandResult = runCommand("/tmp/seen_parallel_opt.sh")

        ///
        Verify all modules reported successful optimization/object emission
        before collecting any objects for the final link.
        ///
        var vi = 0
        while vi < uncachedIdxStrs.length() {
            let midx = uncachedIdxStrs[vi]
            let statusFile = "/tmp/seen_module_" + midx + ".opt.status"
            let statusText = loadFileContent(statusFile)
            if statusText != "ok" {
                if statusText == "opt" {
                    println("    Error: optimization failed for module " + midx)
                } else {
                    if statusText == "object" {
                        println("    Error: object emission failed for module " + midx)
                    } else {
                        println("    Error: module optimization did not complete for module " + midx)
                    }
                }
                let logFile = "/tmp/seen_module_" + midx + ".opt.log"
                let logTail: CommandResult = runCommand("tail -n 40 " + logFile)
                if commandWasSuccessful(logTail) {
                    println(logTail.output)
                }
                return 1
            }
            let objFile = "/tmp/seen_module_" + midx + ".o"
            let checkObj: CommandResult = runCommand("test -f " + objFile)
            if not commandWasSuccessful(checkObj) {
                println("    Error: module " + midx + " reported success but did not produce an object file")
                let logFile = "/tmp/seen_module_" + midx + ".opt.log"
                let logTail: CommandResult = runCommand("tail -n 40 " + logFile)
                if commandWasSuccessful(logTail) {
                    println(logTail.output)
                }
                return 1
            }
            vi = vi + 1
        }
        if not commandWasSuccessful(parallelResult) {
            println("    Error: parallel optimization script reported failure")
            return 1
        }

        // Collect object files, emit debug IR, collect ML data, and write cache
        var ci = 0
        while ci < uncachedIdxStrs.length() {
            let midx = uncachedIdxStrs[ci]
            let objFile = "/tmp/seen_module_" + midx + ".o"
            objectFiles.push(objFile)
            objectSourcePaths.push(uncachedSrcPaths[ci])

            // --emit-llvm: save optimized IR alongside output
            if g_emitLlvm {
                let optFile = "/tmp/seen_module_" + midx + ".opt.ll"
                let emitOptDst = outputFile + ".module" + midx + ".opt.ll"
                let emitOptCp: CommandResult = runCommand("cp " + optFile + " " + emitOptDst)
                println("    Emitted optimized IR: " + emitOptDst)
            }

            // Collect ML training data if --ml-log was specified
            if actualMlLogPath != "" {
                let mlRemarksFile = "/tmp/seen_ml_remarks_" + midx + ".yaml"
                collectMLTrainingData(mlRemarksFile, actualMlLogPath)
            }

            // Cache the .o file for future builds (source-level cache)
            if useCache {
                ensureCacheDir()
                let sourcePath = uncachedSrcPaths[ci]
                let pathHash = hashString(cacheSignature + ":" + sourcePath)
                let cpCacheResult: CommandResult = runCommand("cp " + objFile + " .seen_cache/" + pathHash + ".o")
                writeText(".seen_cache/" + pathHash + ".hash", hashString(readText(sourcePath)))
            }

            // IR cache: store post-opt .o for cross-stage reuse
            let irKey = uncachedIrKeys[ci]
            if irKey != "" {
                ensureIrCacheDir()
                let irCacheDest = "/tmp/seen_ir_cache/" + irKey + ".o"
                let irCacheCopy: CommandResult = runCommand("cp " + objFile + " " + irCacheDest)
            }

            ci = ci + 1
        }
        println("  [Pass 2b] Optimization complete")
    }

    if g_generatedTestMainMode == 0 {
        if cachedCount > 0 {
            println("  [Pass 2] Complete (" + cachedCount.toString() + "/" + modulePaths.length().toString() + " cached)")
        } else {
            println("  [Pass 2] Complete")
        }
    }

    ///
    Detect host platform before any native object emission so release builds
    can avoid inheriting unsupported ISA features from the build host.
    ///
    let unameS: CommandResult = runCommand("uname -s")
    var hostOS = "Linux"
    if commandWasSuccessful(unameS) {
        if unameS.output.contains("Darwin") {
            hostOS = "Darwin"
        }
    }
    let unameM: CommandResult = runCommand("uname -m")
    var hostArch = "x86_64"
    if commandWasSuccessful(unameM) {
        if unameM.output.contains("arm64") {
            hostArch = "arm64"
        }
        if unameM.output.contains("aarch64") {
            hostArch = "arm64"
        }
    }

    ///
    Build CPU flags from --target-cpu / --simd. Developer builds still
    default to native; release scripts pass --target-cpu explicitly.
    ///
    var clangMarch = "-march=native"
    var llvmLlcCpu = "native"
    if hostArch == "arm64" {
        if targetCpu == "x86-64-v3" or targetCpu == "x86-64-v4" or targetCpu == "x86-64" {
            clangMarch = "-march=native"
        } else {
            if targetCpu != "" and targetCpu != "native" {
                clangMarch = "-mcpu=" + targetCpu
                llvmLlcCpu = targetCpu
            }
        }
        if simdPolicy == "none" {
            clangMarch = "-mcpu=generic"
            llvmLlcCpu = "generic"
        }
    } else {
        if targetCpu == "x86-64" {
            clangMarch = "-march=x86-64"
            llvmLlcCpu = "x86-64"
        } else {
            if targetCpu == "x86-64-v3" {
                clangMarch = "-march=x86-64-v3"
                llvmLlcCpu = "x86-64-v3"
            } else {
                if targetCpu == "x86-64-v4" {
                    clangMarch = "-march=x86-64-v4"
                    llvmLlcCpu = "x86-64-v4"
                } else {
                    if targetCpu != "" {
                        if targetCpu != "native" {
                            clangMarch = "-march=" + targetCpu
                            llvmLlcCpu = targetCpu
                        }
                    }
                }
            }
        }
        if simdPolicy == "none" {
            clangMarch = "-march=x86-64"
            llvmLlcCpu = "x86-64"
        }
    }
    if normalizedCrossTarget != "" {
        if effectiveTarget == "linux-x86_64" or effectiveTarget == "macos-x86_64" or effectiveTarget == "windows-x86_64" {
            clangMarch = "-march=x86-64"
            llvmLlcCpu = "x86-64"
        } else {
            clangMarch = ""
        }
    }

    ///
    ============================================================
    RELEASE MODE: Cross-module LTO merge (when --release and multi-module)
    ============================================================
    Why a separate release path? The normal pipeline uses ThinLTO (per-module
    bitcode + link-time cross-module inlining). --release instead merges ALL
    modules into a single LLVM IR file via llvm-link, then runs internalize +
    O3 on the whole program. This enables aggressive whole-program optimization
    (dead code elimination, cross-module inlining with threshold=2000) at the
    cost of higher memory usage and slower compilation. The merged object is
    compiled via llc rather than ThinLTO.
    ///
    if g_releaseMode and modulePaths.length() > 1 and normalizedCrossTarget == "" and
        g_objectManifestPath == "" {

        if llFiles.length() != modulePaths.length() {
            println("  [2.5] Skipping merged release path: only " + llFiles.length().toString() + "/" + modulePaths.length().toString() + " modules have raw IR available")
        } else {
            if llvmLinkTool == "" or llvmLlcTool == "" {
                println("  [2.5] Skipping merged release path: missing llvm-link or llc")
            } else {
                println("  [2.5] Release mode: cross-module LTO merge (" + llFiles.length().toString() + " modules)...")
                var llLinkCmd = llvmLinkTool + " -S "
                var lli = 0
                while lli < llFiles.length() {
                    llLinkCmd = llLinkCmd + llFiles[lli] + " "
                    lli = lli + 1
                }
                let mergedLl = "/tmp/seen_merged_release.ll"
                llLinkCmd = llLinkCmd + "-o " + mergedLl
                let llLinkResult: CommandResult = runCommand(llLinkCmd)
                if commandWasSuccessful(llLinkResult) {
                    // Try Polly pre-pass for polyhedral loop optimization (best-effort)
                    let pollyOut = "/tmp/seen_merged_polly.ll"
                    let pollyCmd = llvmOptTool + " -passes='polly-canonicalize,polly' -S " + mergedLl + " -o " + pollyOut + " 2>/dev/null"
                    let pollyResult: CommandResult = runCommand(pollyCmd)
                    var mergedInput = mergedLl
                    if commandWasSuccessful(pollyResult) {
                        mergedInput = pollyOut
                        println("    Polly: polyhedral loop optimization applied")
                    }
                    // Run opt with internalize on merged module (enables cross-module inlining)
                    let mergedOpt = "/tmp/seen_merged_release.opt.ll"
                    let mergedOptCmd = llvmOptTool + " -passes='function(sroa,instcombine<no-verify-fixpoint>,simplifycfg),internalize,default<O3>,function(loop-unroll-and-jam)' -internalize-public-api-list=main -inline-threshold=2000 -S " + mergedInput + " -o " + mergedOpt
                    let mergedOptResult: CommandResult = runCommand(mergedOptCmd)
                    if commandWasSuccessful(mergedOptResult) {
                        // Compile merged optimized IR to single object file
                        let mergedObj = "/tmp/seen_merged_release.o"
                        let mergedLlcCmd = llvmLlcTool + " -filetype=obj -O3 -relocation-model=pic -enable-misched -enable-post-misched -enable-shrink-wrap -fp-contract=fast -mcpu=" + llvmLlcCpu + " " + mergedOpt + " -o " + mergedObj
                        let mergedLlcResult: CommandResult = runCommand(mergedLlcCmd)
                        if commandWasSuccessful(mergedLlcResult) {
                            // Replace all per-module object files with single merged object
                            objectFiles = Array<String>()
                            objectFiles.push(mergedObj)
                            expectedLinkObjects = 1
                            println("    Cross-module LTO: merged " + llFiles.length().toString() + " modules into 1")
                        } else {
                            println("    Warning: LLC on merged module failed, using per-module objects")
                        }
                    } else {
                        println("    Warning: opt on merged module failed, using per-module objects")
                    }
                    // --emit-llvm: save merged IR for debugging
                    if g_emitLlvm {
                        let emitMerge: CommandResult = runCommand("cp " + mergedOpt + " " + outputFile + ".merged.opt.ll")
                        println("    Emitted merged IR: " + outputFile + ".merged.opt.ll")
                    }
                } else {
                    println("    Warning: llvm-link failed, using per-module objects")
                    println(llLinkResult.output)
                }
            }
        }
    }

    ///
    ============================================================
    LINKING: Combine all object files
    ============================================================
    Why ThinLTO (not full LTO)? Full LTO loads all bitcode into one module,
    requiring O(total IR) memory. ThinLTO reads only summaries, then performs
    cross-module inlining on a per-function basis. For the 50-module compiler,
    full LTO would require 5+ GB RAM; ThinLTO stays under 1 GB while still
    enabling cross-module inlining. The ThinLTO cache at /tmp/seen_thinlto_cache
    means unchanged modules skip link-time optimization entirely on rebuilds.
    ///
    if objectFiles.length() != expectedLinkObjects {
        println("    Error: refusing to link partial module set (" + objectFiles.length().toString() + "/" + expectedLinkObjects.toString() + " link objects)")
        return 1
    }
    if g_objectManifestPath != "" {
        if not writeObjectManifest(g_objectManifestPath, objectFiles,
            objectSourcePaths) {

            println("    Error: failed to write object manifest: " +
                g_objectManifestPath)
            return 1
        }
        println("  Wrote object manifest: " + g_objectManifestPath)
    }
    if g_generatedTestMainMode == 1 {
        storeGeneratedTestObjectSetCache(resolvedInput, modulePaths, cacheSignature, normalizedCrossTarget)
        println("  [3] Skipping final link for generated test main; module objects are ready")
        return 0
    }
    println("  [3] Linking " + objectFiles.length().toString() + " object files...")

    ///
    Pre-compile the C runtime to a ThinLTO-compatible .o file. This is done once
    and reused across builds (checked via timestamp: .o newer than .c).
    Why ThinLTO for the runtime? Using -flto=thin here matches the linker's ThinLTO
    mode, enabling cross-module inlining of hot runtime functions (e.g., seen_str_concat,
    seen_arr_push) into user code at link time.
    When sanitizer is enabled, the runtime must be recompiled with sanitizer flags.
    ///
    let compRoot = getCompilerRoot()
    var rtPrefix = "seen_runtime"
    if compRoot != "" {
        rtPrefix = compRoot + "/seen_runtime"
    }
    var picCompileFlag = ""
    if g_picMode == 1 {
        picCompileFlag = " -fPIC"
    }
    var runtimeObj = rtPrefix + "/seen_runtime.o"
    if g_picMode == 1 {
        runtimeObj = rtPrefix + "/seen_runtime_pic.o"
    }
    let runtimeSrc = rtPrefix + "/seen_runtime.c"
    var teeRuntimeObj = rtPrefix + "/seen_tee_common.o"
    if g_picMode == 1 {
        teeRuntimeObj = rtPrefix + "/seen_tee_common_pic.o"
    }
    let teeRuntimeSrc = rtPrefix + "/seen_tee_common.c"
    let teeSgxRuntimeSrc = rtPrefix + "/seen_tee_sgx.c"
    let teeSevRuntimeSrc = rtPrefix + "/seen_tee_sev.c"
    let teeRuntimeExists: CommandResult = runCommand("test -f " + teeRuntimeSrc)
    let hasTeeRuntime = commandWasSuccessful(teeRuntimeExists)
    let teeSgxRuntimeExists: CommandResult = runCommand("test -f " + teeSgxRuntimeSrc)
    let hasTeeSgxRuntime = commandWasSuccessful(teeSgxRuntimeExists)
    let teeSevRuntimeExists: CommandResult = runCommand("test -f " + teeSevRuntimeSrc)
    let hasTeeSevRuntime = commandWasSuccessful(teeSevRuntimeExists)
    var sanitizerClangFlags = ""
    if sanitizePolicy != "" {
        sanitizerClangFlags = " -fsanitize=" + sanitizePolicy + " -fno-omit-frame-pointer -g"
        println("  Sanitizer: " + sanitizePolicy)
        g_sanitizerModeCli = 1
    }
    var pgoClangFlags = ""
    if pgoMode == "generate" {
        pgoClangFlags = " -fprofile-generate"
        println("  PGO: generate (instrumented build)")
    }
    if pgoMode == "use" {
        // Auto-merge .profraw files to .profdata if needed
        if pgoPath.endsWith(".profraw") {
            let profdataPath = "/tmp/seen_pgo.profdata"
            let mergeCmd = "llvm-profdata merge " + pgoPath + " -o " + profdataPath
            println("  PGO: merging profile data...")
            let mergeResult: CommandResult = runCommand(mergeCmd)
            if commandWasSuccessful(mergeResult) {
                pgoPath = profdataPath
            } else {
                println("    Warning: llvm-profdata merge failed, using raw profile")
            }
        }
        pgoClangFlags = " -fprofile-use=" + pgoPath
        println("  PGO: use profile from " + pgoPath)
    }

    let needsTeeHardwareRuntime = sourcesNeedTeeHardwareRuntime(modulePaths)
    var teeRuntimeCompileFlags = ""
    var teeRuntimeLinkFlags = ""
    let hostTargetForTee = detectHostTargetName()
    let teeCanUseHostHardware = needsTeeHardwareRuntime and effectiveTarget == hostTargetForTee and (hostTargetForTee == "linux-x86_64" or hostTargetForTee == "linux-arm64")
    if teeCanUseHostHardware and hasTeeSevRuntime {
        if pkgConfigExists("openssl") {
            teeRuntimeCompileFlags = teeRuntimeCompileFlags + " -DSEEN_TEE_ENABLE_SEV"
            let opensslCflags = pkgConfigOutput("--cflags", "openssl")
            if opensslCflags != "" {
                teeRuntimeCompileFlags = teeRuntimeCompileFlags + " " + opensslCflags
            }
            let opensslLibs = pkgConfigOutput("--libs", "openssl")
            if opensslLibs != "" {
                teeRuntimeLinkFlags = teeRuntimeLinkFlags + " " + opensslLibs
            }
        } else {
            println("    Warning: OpenSSL pkg-config metadata not found; building TEE runtime without SEV backend")
        }
    }
    if sanitizePolicy == "" {
        let checkRtResult: CommandResult =
            runCommand("test " + runtimeObj + " -nt " + runtimeSrc)
        if not commandWasSuccessful(checkRtResult) {
            println("  [3a] Pre-compiling runtime...")
            let rtCompile: CommandResult =
                runCommand("clang -O3 -flto=thin " + clangMarch +
                    " -ffunction-sections -fdata-sections -pthread" +
                    picCompileFlag + " -c -I " + rtPrefix + " " +
                    runtimeSrc + " -o " + runtimeObj)
            if not commandWasSuccessful(rtCompile) {
                println("    Warning: Runtime pre-compilation failed, will compile inline")
            }
        }
        if hasTeeRuntime {
            let checkTeeRtResult: CommandResult = runCommand("test " + teeRuntimeObj + " -nt " + teeRuntimeSrc)
            if not commandWasSuccessful(checkTeeRtResult) {
                let teeRtCompile: CommandResult =
                    runCommand("clang -O3 -flto=thin " + clangMarch +
                        " -ffunction-sections -fdata-sections -pthread" +
                        picCompileFlag + " -c -I " + rtPrefix + " " +
                        teeRuntimeSrc + " -o " + teeRuntimeObj)
                if not commandWasSuccessful(teeRtCompile) {
                    println("    Warning: TEE runtime pre-compilation failed, will compile inline")
                }
            }
        }
    } else {
        // With sanitizer, recompile runtime with sanitizer flags
        println("  [3a] Compiling runtime with sanitizer...")
        var sanitizedRuntimeObj = "/tmp/seen_runtime_sanitized.o"
        if g_picMode == 1 {
            sanitizedRuntimeObj = "/tmp/seen_runtime_sanitized_pic.o"
        }
        let rtCompile: CommandResult =
            runCommand("clang -O3 " + clangMarch +
                " -ffunction-sections -fdata-sections -pthread" +
                sanitizerClangFlags + picCompileFlag + " -c -I " + rtPrefix +
                " " + runtimeSrc + " -o " + sanitizedRuntimeObj)
        if not commandWasSuccessful(rtCompile) {
            println("    Warning: Sanitized runtime compilation failed")
        }
        if hasTeeRuntime {
            var sanitizedTeeRuntimeObj = "/tmp/seen_tee_common_sanitized.o"
            if g_picMode == 1 {
                sanitizedTeeRuntimeObj = "/tmp/seen_tee_common_sanitized_pic.o"
            }
            let teeRtCompile: CommandResult =
                runCommand("clang -O3 " + clangMarch +
                    " -ffunction-sections -fdata-sections -pthread" +
                    sanitizerClangFlags + picCompileFlag + " -c -I " +
                    rtPrefix + " " + teeRuntimeSrc + " -o " +
                    sanitizedTeeRuntimeObj)
            if not commandWasSuccessful(teeRtCompile) {
                println("    Warning: Sanitized TEE runtime compilation failed")
            }
        }
    }

    // Check if pre-compiled runtime exists
    var runtimeArg = ""
    var teeRuntimeSourceArg = ""
    if hasTeeRuntime {
        teeRuntimeSourceArg = " " + teeRuntimeSrc
    }
    if hasTeeSgxRuntime {
        teeRuntimeSourceArg = teeRuntimeSourceArg + " " + teeSgxRuntimeSrc
    }
    if hasTeeSevRuntime {
        teeRuntimeSourceArg = teeRuntimeSourceArg + " " + teeSevRuntimeSrc
    }
    var teeInlineArg = ""
    if teeRuntimeSourceArg != "" {
        teeInlineArg = " -I " + rtPrefix + picCompileFlag
        if teeRuntimeCompileFlags != "" {
            teeInlineArg = teeInlineArg + teeRuntimeCompileFlags
        }
        if sanitizePolicy != "" {
            teeInlineArg = teeInlineArg + sanitizerClangFlags
        }
        teeInlineArg = teeInlineArg + teeRuntimeSourceArg
    }
    if sanitizePolicy != "" {
        // Use sanitized runtime object
        var sanitizedRuntimeObj2 = "/tmp/seen_runtime_sanitized.o"
        if g_picMode == 1 {
            sanitizedRuntimeObj2 = "/tmp/seen_runtime_sanitized_pic.o"
        }
        let useSanitizedRt: CommandResult =
            runCommand("test -f " + sanitizedRuntimeObj2)
        if commandWasSuccessful(useSanitizedRt) {
            runtimeArg = sanitizedRuntimeObj2 + teeInlineArg
        } else {
            runtimeArg = "-I " + rtPrefix + sanitizerClangFlags +
                picCompileFlag + teeRuntimeCompileFlags + " " + runtimeSrc +
                teeRuntimeSourceArg
        }
    } else {
        let usePrecompiledRt: CommandResult = runCommand("test -f " + runtimeObj)
        if commandWasSuccessful(usePrecompiledRt) {
            runtimeArg = runtimeObj + teeInlineArg
        } else {
            runtimeArg = "-I " + rtPrefix + picCompileFlag +
                teeRuntimeCompileFlags + " " + runtimeSrc +
                teeRuntimeSourceArg
        }
    }

    if normalizedCrossTarget != "" {
        println("  [3a-target] Compiling runtime for " + effectiveTarget + "...")
        if targetClangArgs != "" {
            let rtTargetOut = "/tmp/seen_runtime_" + effectiveTarget + ".o"
            let rtTargetCmd: CommandResult = runCommand(targetClangDriver + " -O3 -flto=thin -ffunction-sections -fdata-sections" + targetRuntimeFlags + " -c " + targetClangArgs + " -I " + rtPrefix + " " + rtPrefix + "/seen_runtime.c -o " + rtTargetOut)
            if commandWasSuccessful(rtTargetCmd) {
                runtimeArg = rtTargetOut + teeInlineArg
            } else {
                println("    Error: target runtime compilation failed for " + effectiveTarget)
                println(rtTargetCmd.output)
                return 1
            }
        } else {
            println("    Error: target clang args unavailable for " + effectiveTarget)
            return 1
        }
    }

    ///
    Ensure ThinLTO cache directory exists for persistent cross-build link cache.
    This cache is shared across all Seen compilations on the machine, keyed by
    bitcode content hash. It persists across bootstrap stages and compiler rebuilds.
    ///
    let thinltoMkdir: CommandResult = runCommand("mkdir -p /tmp/seen_thinlto_cache")
    var linkCmd = ""
    if normalizedCrossTarget != "" {
        if effectiveTarget == "ios-arm64" or effectiveTarget == "ios-sim-arm64" {
            linkCmd = targetClangDriver + " " + targetClangArgs + " -O3 -flto=thin -Wl,-dead_strip -Wno-unused-command-line-argument "
        } else {
            if effectiveTarget == "macos-arm64" or effectiveTarget == "macos-x86_64" {
                linkCmd = targetClangDriver + " " + targetClangArgs + " -O3 -flto=thin -Wl,-cache_path_lto,/tmp/seen_thinlto_cache -Wl,-dead_strip -Wno-unused-command-line-argument "
                if clangMarch != "" {
                    linkCmd = linkCmd + clangMarch + " "
                }
            } else {
                if effectiveTarget == "windows-x86_64" {
                    linkCmd = targetClangDriver + " " + targetClangArgs + " -O2 -flto=thin -fuse-ld=lld -Wno-unused-command-line-argument "
                } else {
                    if effectiveTarget == "android-arm64" {
                        linkCmd = targetClangDriver + " " + targetClangArgs + " -O2 -flto=thin -shared -Wl,--gc-sections -Wno-unused-command-line-argument "
                    } else {
                        linkCmd = targetClangDriver + " " + targetClangArgs + " -O3 -flto=thin -fuse-ld=lld -Wl,--thinlto-cache-dir=/tmp/seen_thinlto_cache -Wl,--gc-sections -Wno-unused-command-line-argument "
                        if clangMarch != "" {
                            linkCmd = linkCmd + clangMarch + " "
                        }
                    }
                }
            }
        }
    } else if hostOS == "Darwin" {
        // macOS link command: no -fuse-ld=lld, use Apple ld64 flags
        if g_fastMode == 1 {
            linkCmd = "clang -O1 " + clangMarch + " -Wl,-dead_strip -Wno-unused-command-line-argument "
        } else {
            if g_O2Mode == 1 {
                linkCmd = "clang -O2 -flto=thin -Wl,-cache_path_lto,/tmp/seen_thinlto_cache " + clangMarch + " -Wl,-dead_strip -Wno-unused-command-line-argument "
            } else {
                linkCmd = "clang -O3 -flto=thin -Wl,-cache_path_lto,/tmp/seen_thinlto_cache " + clangMarch + " -Wl,-dead_strip -ffp-contract=fast -Wno-unused-command-line-argument "
            }
        }
    } else {
        // Linux link command (original)
        if g_fastMode == 1 {
            linkCmd = "clang -O1 -fuse-ld=lld " + clangMarch + " -Wl,--gc-sections -Wno-unused-command-line-argument "
        } else {
            if g_O2Mode == 1 {
                linkCmd = "clang -O2 -flto=thin -fuse-ld=lld -Wl,--thinlto-cache-dir=/tmp/seen_thinlto_cache " + clangMarch + " -Wl,--gc-sections -Wno-unused-command-line-argument "
            } else {
                linkCmd = "clang -O3 -flto=thin -fuse-ld=lld -Wl,--thinlto-cache-dir=/tmp/seen_thinlto_cache " + clangMarch + " -Wl,--gc-sections -ffp-contract=fast -Wno-unused-command-line-argument -mllvm -inline-threshold=1500 "
            }
        }
    }
    if g_releaseMode and llFiles.length() > 1 and normalizedCrossTarget != "" {
        println("  [2.5] Skipping merged llc release path for cross-target build: " + effectiveTarget)
    }
    // Append sanitizer and PGO flags to link command
    if sanitizerClangFlags != "" {
        linkCmd = linkCmd + sanitizerClangFlags + " "
    }
    if pgoClangFlags != "" {
        linkCmd = linkCmd + pgoClangFlags + " "
    }
    var oi = 0
    while oi < objectFiles.length() {
        linkCmd = linkCmd + objectFiles[oi] + " "
        oi = oi + 1
    }
    // Pre-compile region allocator if not already built
    var regionObj = rtPrefix + "/seen_region.o"
    if g_picMode == 1 {
        regionObj = rtPrefix + "/seen_region_pic.o"
    }
    let checkRegionResult: CommandResult = runCommand("test " + regionObj + " -nt " + rtPrefix + "/seen_region.c")
    if not commandWasSuccessful(checkRegionResult) {
        let regionSrcCheck: CommandResult = runCommand("test -f " + rtPrefix + "/seen_region.c")
        if commandWasSuccessful(regionSrcCheck) {
            let hostRegionCmd = "clang -O3 -flto=thin " + clangMarch +
                " -ffunction-sections -fdata-sections" + picCompileFlag +
                " -c -I " + rtPrefix + " " + rtPrefix +
                "/seen_region.c -o " + regionObj
            let rtRegion: CommandResult = runCommand(hostRegionCmd)
        }
    }
    // Add region allocator object if it exists
    var regionArg = ""
    if normalizedCrossTarget != "" {
        if targetSupportsRegionRuntime(effectiveTarget) {
            let targetRegionOut = "/tmp/seen_region_" + effectiveTarget + ".o"
            let regionSrcCheck2: CommandResult = runCommand("test -f " + rtPrefix + "/seen_region.c")
            if commandWasSuccessful(regionSrcCheck2) and targetClangArgs != "" {
                let targetRegionCmd = targetClangDriver + " -O3 -flto=thin -ffunction-sections -fdata-sections" + targetRuntimeFlags + " -c " + targetClangArgs + " -I " + rtPrefix + " " + rtPrefix + "/seen_region.c -o " + targetRegionOut
                let targetRegionResult: CommandResult = runCommand(targetRegionCmd)
                if commandWasSuccessful(targetRegionResult) {
                    regionArg = " " + targetRegionOut
                } else {
                    println("    Warning: target region runtime compilation failed for " + effectiveTarget)
                    println(targetRegionResult.output)
                }
            }
        } else {
            println("    Skipping region runtime for " + effectiveTarget + " (no supported target-specific implementation yet)")
        }
    } else {
        let useRegionObj: CommandResult = runCommand("test -f " + regionObj)
        if commandWasSuccessful(useRegionObj) {
            regionArg = " " + regionObj
        }
    }
    // Pre-compile GPU runtime if not already built
    var gpuArg = ""
    let needsGpuRuntime = sourcesNeedGpuRuntime(modulePaths)
    if needsGpuRuntime {
        var hostGpuObj = rtPrefix + "/seen_gpu.o"
        if g_picMode == 1 {
            hostGpuObj = rtPrefix + "/seen_gpu_pic.o"
        }
        let checkGpuResult: CommandResult = runCommand("test " + hostGpuObj + " -nt " + rtPrefix + "/seen_gpu.c")
        if not commandWasSuccessful(checkGpuResult) {
            let gpuSrcCheck: CommandResult = runCommand("test -f " + rtPrefix + "/seen_gpu.c")
            if commandWasSuccessful(gpuSrcCheck) {
                // Check if vulkan headers are available before trying to compile
                let vulkanCheck: CommandResult = runCommand("pkg-config --exists vulkan 2>/dev/null")
                if commandWasSuccessful(vulkanCheck) {
                    let rtGpu: CommandResult =
                        runCommand("clang -O3 -flto=thin " + clangMarch +
                            " -ffunction-sections -fdata-sections" +
                            picCompileFlag + " -c -I " + rtPrefix + " " +
                            rtPrefix + "/seen_gpu.c -o " + hostGpuObj +
                            " $(pkg-config --cflags vulkan) 2>&1")
                } else {
                    // Try without pkg-config (headers might be in standard paths)
                    let rtGpu2: CommandResult =
                        runCommand("clang -O3 -flto=thin " + clangMarch +
                            " -ffunction-sections -fdata-sections" +
                            picCompileFlag + " -c -I " + rtPrefix + " " +
                            rtPrefix + "/seen_gpu.c -o " + hostGpuObj +
                            " 2>&1")
                }
            }
        }
        if normalizedCrossTarget == "" {
            let useGpuObj: CommandResult = runCommand("test -f " + hostGpuObj)
            if commandWasSuccessful(useGpuObj) {
                gpuArg = " " + hostGpuObj
            }
        } else {
            if targetSupportsGpuRuntime(effectiveTarget) and targetClangArgs != "" {
                let targetGpuOut = "/tmp/seen_gpu_" + effectiveTarget + ".o"
                var targetGpuCmd = targetClangDriver + " -O3 -flto=thin -ffunction-sections -fdata-sections" + targetRuntimeFlags + " -c " + targetClangArgs + " -I " + rtPrefix + " " + rtPrefix + "/seen_gpu.c -o " + targetGpuOut
                if effectiveTarget == "linux-x86_64" or effectiveTarget == "linux-arm64" or effectiveTarget == "macos-x86_64" or effectiveTarget == "macos-arm64" {
                    let hostVulkanCflags = getHostVulkanCflags()
                    if hostVulkanCflags != "" {
                        targetGpuCmd = targetGpuCmd + " " + hostVulkanCflags
                    }
                }
                let targetGpuResult: CommandResult = runCommand(targetGpuCmd)
                if commandWasSuccessful(targetGpuResult) {
                    gpuArg = " " + targetGpuOut
                } else {
                    println("    Warning: target GPU runtime compilation failed for " + effectiveTarget)
                    println(targetGpuResult.output)
                }
            }
        }
    }
    var hasGpuRuntime = false
    if gpuArg != "" {
        hasGpuRuntime = true
    }
    var hotReloadArg = ""
    let needsHotReloadRuntime = sourcesNeedHotReloadRuntime(modulePaths)
    if needsHotReloadRuntime {
        if effectiveTarget == "windows-x86_64" {
            println("    Error: hotreload runtime is not implemented for Windows targets yet")
            return 1
        }
        let hotReloadSrc = rtPrefix + "/seen_hotreload.c"
        let hotReloadSrcCheck: CommandResult =
            runCommand("test -f " + hotReloadSrc)
        if not commandWasSuccessful(hotReloadSrcCheck) {
            println("    Error: missing hotreload runtime source: " + hotReloadSrc)
            return 1
        }
        if normalizedCrossTarget != "" {
            let targetHotReloadOut = "/tmp/seen_hotreload_" +
                effectiveTarget + ".o"
            let targetHotReloadCmd = targetClangDriver +
                " -O3 -flto=thin -ffunction-sections -fdata-sections" +
                targetRuntimeFlags + " -c " + targetClangArgs + " -I " +
                rtPrefix + " " + hotReloadSrc + " -o " +
                targetHotReloadOut
            let targetHotReloadResult: CommandResult =
                runCommand(targetHotReloadCmd)
            if commandWasSuccessful(targetHotReloadResult) {
                hotReloadArg = " " + targetHotReloadOut
            } else {
                println("    Error: hotreload runtime compilation failed for " +
                    effectiveTarget)
                println(targetHotReloadResult.output)
                return 1
            }
        } else {
            var hotReloadObj = rtPrefix + "/seen_hotreload.o"
            if g_picMode == 1 {
                hotReloadObj = rtPrefix + "/seen_hotreload_pic.o"
            }
            let checkHotReloadResult: CommandResult =
                runCommand("test " + hotReloadObj + " -nt " +
                    hotReloadSrc)
            if not commandWasSuccessful(checkHotReloadResult) {
                let hotReloadCmd = "clang -O3 -flto=thin " + clangMarch +
                    " -ffunction-sections -fdata-sections" +
                    picCompileFlag + " -c -I " + rtPrefix + " " +
                    hotReloadSrc + " -o " + hotReloadObj
                let hotReloadResult: CommandResult =
                    runCommand(hotReloadCmd)
                if not commandWasSuccessful(hotReloadResult) {
                    println("    Error: hotreload runtime compilation failed")
                    println(hotReloadResult.output)
                    return 1
                }
            }
            let useHotReloadObj: CommandResult =
                runCommand("test -f " + hotReloadObj)
            if commandWasSuccessful(useHotReloadObj) {
                hotReloadArg = " " + hotReloadObj
            }
        }
    }
    var platformShimArg = ""
    var platformShimLinkFlags = ""
    let needsLinuxVulkanShim = sourcesNeedLinuxPlatformVulkanShim(modulePaths)
    let needsLinuxAlsaShim = sourcesNeedLinuxPlatformAlsaShim(modulePaths)
    let needsLinuxPipewireShim = sourcesNeedLinuxPlatformPipewireShim(modulePaths)
    let needsLinuxEvdevShim = sourcesNeedLinuxPlatformEvdevShim(modulePaths)
    if needsLinuxVulkanShim or needsLinuxAlsaShim or needsLinuxPipewireShim or needsLinuxEvdevShim {
        let hostTarget = detectHostTargetName()
        let hostIsLinux = hostTarget == "linux-x86_64" or hostTarget == "linux-arm64"
        if not hostIsLinux or effectiveTarget != hostTarget {
            println("    Error: Linux platform shim modules currently require targeting the host Linux toolchain")
            return 1
        }
        var platformShimFlags = ""
        if needsLinuxVulkanShim {
            if not pkgConfigExists("vulkan") {
                println("    Error: missing pkg-config package 'vulkan' required by platform.linux.vulkan/graphics.renderer")
                return 1
            }
            platformShimFlags = platformShimFlags + " -DSEEN_USE_VULKAN"
            let vulkanCflags = pkgConfigOutput("--cflags", "vulkan")
            if vulkanCflags != "" {
                platformShimFlags = platformShimFlags + " " + vulkanCflags
            }
            let vulkanLibs = pkgConfigOutput("--libs", "vulkan")
            if vulkanLibs != "" {
                platformShimLinkFlags = platformShimLinkFlags + " " + vulkanLibs
            }
        }
        if needsLinuxAlsaShim {
            if not pkgConfigExists("alsa") {
                println("    Error: missing pkg-config package 'alsa' required by platform.linux.alsa")
                return 1
            }
            platformShimFlags = platformShimFlags + " -DSEEN_USE_ALSA"
            let alsaCflags = pkgConfigOutput("--cflags", "alsa")
            if alsaCflags != "" {
                platformShimFlags = platformShimFlags + " " + alsaCflags
            }
            let alsaLibs = pkgConfigOutput("--libs", "alsa")
            if alsaLibs != "" {
                platformShimLinkFlags = platformShimLinkFlags + " " + alsaLibs
            }
        }
        if needsLinuxPipewireShim {
            if not pkgConfigExists("libpipewire-0.3") {
                println("    Error: missing pkg-config package 'libpipewire-0.3' required by platform.linux.pipewire")
                return 1
            }
            platformShimFlags = platformShimFlags + " -DSEEN_USE_PIPEWIRE"
            let pipewireCflags = pkgConfigOutput("--cflags", "libpipewire-0.3")
            if pipewireCflags != "" {
                platformShimFlags = platformShimFlags + " " + pipewireCflags
            }
            let pipewireLibs = pkgConfigOutput("--libs", "libpipewire-0.3")
            if pipewireLibs != "" {
                platformShimLinkFlags = platformShimLinkFlags + " " + pipewireLibs
            }
        }
        if needsLinuxEvdevShim {
            if not pkgConfigExists("libevdev") {
                println("    Error: missing pkg-config package 'libevdev' required by platform.linux.evdev")
                return 1
            }
            platformShimFlags = platformShimFlags + " -DSEEN_USE_EVDEV"
            let evdevCflags = pkgConfigOutput("--cflags", "libevdev")
            if evdevCflags != "" {
                platformShimFlags = platformShimFlags + " " + evdevCflags
            }
            let evdevLibs = pkgConfigOutput("--libs", "libevdev")
            if evdevLibs != "" {
                platformShimLinkFlags = platformShimLinkFlags + " " + evdevLibs
            }
        }
        var platformShimSrc = "seen_std/src/platform/linux/shim/seen_platform_shim.c"
        if compRoot != "" {
            platformShimSrc = compRoot + "/seen_std/src/platform/linux/shim/seen_platform_shim.c"
        }
        let shimSourceCheck: CommandResult = runCommand("test -f " + platformShimSrc)
        if not commandWasSuccessful(shimSourceCheck) {
            println("    Error: missing Linux platform shim source: " + platformShimSrc)
            return 1
        }
        var platformShimOut = "/tmp/seen_platform_shim_" + effectiveTarget + ".o"
        if sanitizePolicy != "" {
            platformShimOut = "/tmp/seen_platform_shim_" + effectiveTarget + "_" + sanitizePolicy + ".o"
        }
        var platformShimCmd = "clang -O3 -flto=thin " + clangMarch + " -ffunction-sections -fdata-sections -fPIC" + sanitizerClangFlags + " -c" + platformShimFlags + " " + platformShimSrc + " -o " + platformShimOut
        if normalizedCrossTarget != "" and targetClangArgs != "" {
            platformShimCmd = targetClangDriver + " -O3 -flto=thin -ffunction-sections -fdata-sections -fPIC" + targetRuntimeFlags + sanitizerClangFlags + " -c " + targetClangArgs + platformShimFlags + " " + platformShimSrc + " -o " + platformShimOut
        }
        let platformShimResult: CommandResult = runCommand(platformShimCmd)
        if not commandWasSuccessful(platformShimResult) {
            println("    Error: Linux platform shim compilation failed")
            println(platformShimResult.output)
            return 1
        }
        platformShimArg = " " + platformShimOut
    }
    var linkLibs = buildTargetLinkLibraries(effectiveTarget, hasGpuRuntime)
    if needsHotReloadRuntime {
        if effectiveTarget == "linux-x86_64" or
            effectiveTarget == "linux-arm64" or
            effectiveTarget == "android-arm64" {

            if not linkLibs.contains("-ldl") {
                linkLibs = linkLibs + " -ldl"
            }
        }
    }
    if normalizedCrossTarget == "" {
        if sourcesNeedRawVulkanLink(modulePaths) and not linkLibs.contains("vulkan") {
            linkLibs = appendHostPkgOrFallbackLinkFlag(linkLibs, "vulkan",
                "-lvulkan")
            if not linkLibs.contains("-ldl") {
                linkLibs = linkLibs + " -ldl"
            }
        }
        if sourcesNeedSdl3Link(modulePaths) and not linkLibs.contains("SDL3") {
            linkLibs = appendHostPkgOrFallbackLinkFlag(linkLibs, "sdl3",
                "-lSDL3")
        }
    }
    linkCmd = linkCmd + runtimeArg + regionArg + gpuArg + hotReloadArg +
        platformShimArg + " -o " + outputFile + linkLibs +
        teeRuntimeLinkFlags + platformShimLinkFlags + tomlExtraLinkFlags +
        " 2>&1"

    let linkResult: CommandResult = runCommand(linkCmd)
    if commandWasSuccessful(linkResult) {
        let outputCheck: CommandResult = runCommand("test -f " + outputFile)
        if not commandWasSuccessful(outputCheck) {
            println("Link command reported success but output file was not created: " + outputFile)
            println("Link command: " + linkCmd)
            if linkResult.output != "" {
                println(linkResult.output)
            }
            return 1
        }
        // : Emit compilation database if requested
        if g_emitCompileDb == 1 {
            var cdbContent = "[\n"
            var cdbIdx = 0
            while cdbIdx < objectFiles.length() {
                let cdbObjFile = objectFiles[cdbIdx]
                if cdbIdx > 0 {
                    cdbContent = cdbContent + ",\n"
                }
                let lb = "{"
                let rb = "}"
                cdbContent = cdbContent + "  " + lb + "\n"
                cdbContent = cdbContent + "    \"directory\": \".\",\n"
                cdbContent = cdbContent + "    \"file\": \"" + cdbObjFile + "\",\n"
                cdbContent = cdbContent + "    \"command\": \"seen build " + cdbObjFile + "\"\n"
                cdbContent = cdbContent + "  " + rb
                cdbIdx = cdbIdx + 1
            }
            cdbContent = cdbContent + "\n]\n"
            writeText("compile_commands.json", cdbContent)
            println("  Wrote compile_commands.json (" + objectFiles.length().toString() + " entries)")
        }
        println("Build succeeded -> " + outputFile)
        return 0
    }

    println("Linking failed")
    println(linkResult.output)
    return 1
}

fun checkCommand(inputFile: String) r: Int {
    return checkCommandWithProfile(inputFile, "default", "en")
}

///
Type-check a source file without generating code. Runs the full frontend
pipeline (lex -> parse -> typecheck) and optionally the determinism checker.
Returns 0 if all checks pass, 1 on any error.
///
fun checkCommandWithProfile(inputFile: String, profile: String, language: String) r: Int {
    let resolvedInput = resolveRealInputPath(inputFile)
    if not ensureProjectPackageDependenciesForInput(resolvedInput, true) {
        return 1
    }
    let sourceCode = readText(resolvedInput)
    if sourceCode == "" {
        println("[ERROR] Failed to read source: " + resolvedInput)
        return 1
    }

    let frontend = run_frontend(sourceCode, resolvedInput, language)
    validateBasics(frontend, resolvedInput)
    if not frontend.success {
        printFrontendDiagnostics(frontend)
        return 1
    }

    let checkModulePaths = collectModulePaths(resolvedInput, true)
    let checkSealedValidation = validateSealedModules(checkModulePaths, language)
    if not checkSealedValidation.success {
        printFrontendDiagnostics(checkSealedValidation)
        return 1
    }

    if profile == "deterministic" {
        let deterResult = checkDeterminismWithProfile(frontend.program, true)
        if deterResult.hasErrors() {
            println("[ERROR] Determinism check failed")
            printDeterminismErrors(deterResult)
            return 1
        }
    }

    println("[OK] Check passed")
    return 0
}

fun printFrontendDiagnostics(frontend: FrontendResult) r: Void {
    var diagnostics = frontend.getDiagnostics()
    var index = 0
    while index < diagnostics.length() {
        var diag = diagnostics[index]

        var baseMsg = parseDiagBaseMessage(diag.message)
        var code = parseDiagCode(diag.message)
        var suggestion = parseDiagSuggestion(diag.message)
        var note = parseDiagNote(diag.message)
        var endCol = parseDiagEndColumn(diag.message)

        var label = ""
        if diag.severity == "error" {
            label = colorRed("error")
        } else {
            label = colorYellow("warning")
        }

        var header = label
        if code != "" {
            header = header + "[" + colorBoldWhite(code) + "]"
        }
        header = header + ": " + colorBoldWhite(baseMsg)
        println(header)

        var lineStr = diag.line.toString()
        var colStr = diag.column.toString()
        println("  " + colorCyan("-->") + " " + diag.file + ":" + lineStr + ":" + colStr)

        if diag.line > 0 {
            var sourceLine = getSourceLine(diag.file, diag.line)
            if sourceLine != "" {
                var gutterWidth = lineStr.length()

                println(makeSpaces(gutterWidth + 1) + colorBlue("|"))

                println(colorBlue(" " + lineStr + " ") + colorBlue("|") + " " + sourceLine)

                var caretPad = diag.column - 1
                if caretPad < 0 { caretPad = 0 }
                var caretLen = 1
                if endCol > diag.column {
                    caretLen = endCol - diag.column
                }
                var caret = makeSpaces(caretPad) + colorRed(makeCarets(caretLen))
                println(makeSpaces(gutterWidth + 1) + colorBlue("|") + " " + caret)

                if suggestion != "" {
                    println(makeSpaces(gutterWidth + 1) + colorBlue("|"))
                    println(makeSpaces(gutterWidth + 1) + colorCyan("= " + suggestion))
                }
                if note != "" {
                    println(makeSpaces(gutterWidth + 1) + colorBlue("|"))
                    println(makeSpaces(gutterWidth + 1) + colorCyan("= " + note))
                }
            }
        } else {
            if suggestion != "" {
                println("  " + colorCyan("= " + suggestion))
            }
            if note != "" {
                println("  " + colorCyan("= " + note))
            }
        }

        println("")
        index = index + 1
    }

    var errorCount = 0
    index = 0
    while index < diagnostics.length() {
        var d = diagnostics[index]
        if d.severity == "error" {
            errorCount = errorCount + 1
        }
        index = index + 1
    }
    if errorCount > 0 {
        println(colorRed("error") + ": aborting due to " + errorCount.toString() + " error(s)")
    }
    return
}

// Basic post-parse validation (missing main, etc.)
fun validateBasics(frontend: FrontendResult, inputFile: String) r: Void {
    var program = frontend.program
    var hasMain = 0
    var i = 0
    while i < program.items.length() {
        var item = program.items[i]
        if mainCompilerItemDeclaresMain(item) {
            hasMain = 1
        }
        i = i + 1
    }
    if hasMain == 0 {
        var mainMsg = encodeDiagMessage("missing `main` function", "E003", "help: add 'fun main() r: Void { }' as entry point", "", 0)
        frontend.addDiagnostic(FrontendDiagnostic.new(
            inputFile, 1, 1, "error", mainMsg
        ))
        frontend.setSuccess(false)
    }
    return
}

fun defaultOutput(sourceFile: String) r: String {
    if sourceFile.endsWith(".seen") {
        return sourceFile.substring(0, sourceFile.length() - 5)
    }
    return sourceFile + "_out"
}

// Ensure JIT runtime object (non-LTO ELF) exists for lli --extra-object
fun ensureJitRuntime() r: String {
    let jitRoot = getCompilerRoot()
    var jitRtDir = "seen_runtime"
    if jitRoot != "" {
        jitRtDir = jitRoot + "/seen_runtime"
    }
    let jitObj = jitRtDir + "/seen_runtime_jit.o"
    let checkResult: CommandResult = runCommand("test " + jitObj + " -nt " + jitRtDir + "/seen_runtime.c")
    if commandWasSuccessful(checkResult) {
        return jitObj
    }
    println("  [jit] Pre-compiling runtime for JIT...")
    let cmd: CommandResult = runCommand("clang -O2 -march=native -ffunction-sections -fdata-sections -pthread -c -I " + jitRtDir + " " + jitRtDir + "/seen_runtime.c -o " + jitObj)
    if not commandWasSuccessful(cmd) {
        return ""
    }
    return jitObj
}

///
JIT execution path: generates LLVM IR for all modules, merges them with
llvm-link into a single .ll, then executes via lli's ORC JIT engine.
Uses a non-LTO runtime object (seen_runtime_jit.o) since lli cannot
consume ThinLTO bitcode. Falls back to AOT compilation if lli is not
available or if JIT runtime build fails.
///
fun jitRunCommand(inputFile: String, verbose: Bool, language: String) r: Int {
    let jitInput = resolveRealInputPath(inputFile)
    if verbose {
        println("[jit] Compiling " + inputFile + "...")
    }

    // Check lli is available
    let lliCheck: CommandResult = runCommand("which lli")
    if not commandWasSuccessful(lliCheck) {
        println("[jit] lli not found, falling back to AOT")
        return aotRunCommand(inputFile, verbose, language)
    }

    // Build non-LTO runtime for lli
    let jitRt = ensureJitRuntime()
    if jitRt == "" {
        println("[jit] JIT runtime build failed, falling back to AOT")
        return aotRunCommand(inputFile, verbose, language)
    }

    // Create generator
    let generator = LLVMIRGenerator.new()

    // Pass 1: Collect module paths and register declarations
    if verbose {
        println("  [Pass 1] Scanning declarations...")
    }
    let modulePaths = collectModulePaths(jitInput, not verbose)
    if verbose {
        println("    Found " + modulePaths.length().toString() + " modules")
    }
    let jitSealedValidation = validateSealedModules(modulePaths, language)
    if not jitSealedValidation.success {
        printFrontendDiagnostics(jitSealedValidation)
        return 1
    }

    var passIdx = 0
    while passIdx < modulePaths.length() {
        let path = modulePaths[passIdx]
        let frontend = parseModuleDeclarations(path, language)
        if frontend.success {
            generator.registerDeclarations(frontend.program)
        } else {
            printFrontendDiagnostics(frontend)
            return 1
        }
        passIdx = passIdx + 1
    }
    if verbose {
        println("  [Pass 1] Complete")
    }

    // Pass 2: Generate IR for each module (no opt/llc -- just .ll files)
    if verbose {
        println("  [Pass 2] Generating IR...")
    }
    var llFiles = Array<String>()
    var moduleIndex = 0
    while moduleIndex < modulePaths.length() {
        let path = modulePaths[moduleIndex]
        let frontend = parseModule(path, language)
        if not frontend.success {
            printFrontendDiagnostics(frontend)
            println("    Error: Failed to parse " + path)
            return 1
        }
        let llvmIR = generator.generateSingle(frontend.program, moduleIndex)
        let llFile = "/tmp/seen_jit_module_" + moduleIndex.toString() + ".ll"
        if not writeText(llFile, llvmIR) {
            println("    Error: Failed to write IR: " + llFile)
            return 1
        }
        llFiles.push(llFile)
        generator.reset()
        moduleIndex = moduleIndex + 1
    }
    if verbose {
        println("  [Pass 2] Complete")
    }

    // Merge all .ll files with llvm-link
    var mergedFile = "/tmp/seen_jit_merged.ll"
    if llFiles.length() == 1 {
        // Single module -- use directly (no cp needed)
        mergedFile = llFiles[0]
    } else {
        var linkCmd = "llvm-link -S "
        var li = 0
        while li < llFiles.length() {
            linkCmd = linkCmd + llFiles[li] + " "
            li = li + 1
        }
        linkCmd = linkCmd + "-o " + mergedFile
        let linkResult: CommandResult = runCommand(linkCmd)
        if not commandWasSuccessful(linkResult) {
            println("[jit] llvm-link failed, falling back to AOT")
            println(linkResult.output)
            return aotRunCommand(inputFile, verbose)
        }
    }

    // Execute with lli
    if verbose {
        println("[jit] Executing...")
    }
    let execCmd = "lli --jit-kind=orc --extra-object=" + jitRt + " " + mergedFile
    // Program output flows directly to terminal via runProgram (posix_spawn).
    let exitCode: Int = runProgram(execCmd)
    if exitCode != 0 {
        println("[jit] JIT execution failed (exit code " + exitCode.toString() + ")")
        return exitCode
    }
    return 0
}

///
AOT execution path: compiles the source to a temporary binary at
/tmp/seen_run_script using the full compile pipeline, then executes it.
This is the fallback when JIT is unavailable and the explicit path for --aot.
///
fun aotRunCommand(inputFile: String, verbose: Bool, language: String) r: Int {
    if verbose {
        println("[run] Compiling " + inputFile + "...")
    }

    // Compile to temp file
    let tempOutput = "/tmp/seen_run_script"
    let compileResult = compileCommandWithLanguage(inputFile, tempOutput, language)
    if compileResult != 0 {
        println("[run] Compilation failed")
        return compileResult
    }

    // Execute the compiled binary
    if verbose {
        println("[run] Executing...")
    }
    let exitCode: Int = runProgram(tempOutput)
    if exitCode != 0 {
        println("[run] Execution failed (exit code " + exitCode.toString() + ")")
        return exitCode
    }
    return 0
}

// Dispatch run command: JIT by default, AOT with --aot flag
fun runScriptCommand(inputFile: String, useAot: Bool, verbose: Bool, language: String) r: Int {
    if useAot {
        return aotRunCommand(inputFile, verbose, language)
    }
    return jitRunCommand(inputFile, verbose, language)
}

fun printUsage() r: Void {
    println("Usage: seen compile <input.seen> [output] [--profile deterministic] [--no-cache]")
    println("       seen check <input.seen> [--profile deterministic]")
    println("       seen run <input.seen> [--aot] [--verbose] [--language <lang>]")
    println("       seen bundle <executable> <AppName> [--icon=<icon.icns>] [--version=<1.0>]")
    println("       seen sign <path> [--identity=<identity>]")
    println("       seen notarize <path> --apple-id=<email> --team-id=<id> --password=<pwd>")
    println("       seen lipo <x86_64_binary> <arm64_binary> [--output=<universal>]")
    println("       seen lipo --from-source <source.seen> [--output=<universal>]")
    println("       seen ipa <executable> <AppName> [--bundle-id=...] [--version=...] [--provisioning-profile=...]")
    println("       seen translate <file> --from <lang> --to <lang> [-o <output>]")
    println("       seen import-c <header.h>")
    println("       seen pkg <fetch|pack|publish> ...")
    println("       seen lsp")
    println("")
    println("Options:")
    println("  --profile deterministic  Reject HashMap/HashSet without @nondeterministic")
    println("  --no-cache               Disable incremental compilation caching")
    println("  --aot                    Use AOT compilation for 'run' (default: JIT via lli)")
    println("  --verbose                Show compiler diagnostics during 'run'")
    println("  --target-cpu=<cpu>       Target CPU (native, x86-64, x86-64-v3, x86-64-v4)")
    println("  --simd=<policy>          SIMD policy (auto, none, sse4.2, avx2, avx512)")
    println("  --simd-report            Show LLVM vectorization report (brief)")
    println("  --simd-report=full       Show detailed per-loop vectorization report")
    println("  --backend=<name>         Backend selection (llvm only in this binary)")
    println("  --backend <name>         Same as above")
    println("  --deterministic          Deterministic mode (scalar SIMD, no HashMap)")
    println("  --sanitize=<policy>      Sanitizer (address, undefined, thread, memory)")
    println("  --pgo-generate           Generate PGO instrumentation profile")
    println("  --pgo-use=<path>         Use PGO profile for optimization")
    println("  --ml-log=<path>          Collect ML training data from optimization remarks")
    println("  --ml-decision-log=<path> Write optimization decision log (JSONL format)")
    println("  --target=<platform>      Cross-compile target")
    println("  --target <platform>      Same as above")
    println("                           linux-x86_64, linux-arm64, windows-x86_64,")
    println("                           macos-x86_64, macos-arm64, ios-arm64,")
    println("                           ios-sim-arm64, android-arm64")
    println("  --pic                    Emit PIC module/runtime objects for shared libraries")
    println("  --object-manifest <path> Write object-to-module TSV manifest")
    println("  --fast                   Lightweight optimization (for bootstrap verification)")
    println("  --no-fork                Disable parallel IR/opt bootstrap steps (sequential)")
    println("  --projectprefix <n>      Large-project validation prefix hint")
    println("")
    println("PGO Workflow:")
    println("  1. seen compile prog.seen prog --pgo-generate")
    println("  2. ./prog                    # run with representative input")
    println("  3. llvm-profdata merge -o default.profdata default_*.profraw")
    println("  4. seen compile prog.seen prog --pgo-use=default.profdata")
    return
}

///
Extract value after = in a flag like "--target-cpu=native"
Uses .substring() method instead of free function to avoid stage1 codegen issue
///
fun extractFlagValue(flag: String, prefixLen: Int) r: String {
    return flag.substring(prefixLen, flag.length())
}

// Parse --profile flag from arguments starting at given index
fun parseProfile(argv: Array<String>, startIndex: Int) r: String {
    var i = startIndex
    while i < argv.length() {
        if argv[i] == "--profile" {
            if i + 1 < argv.length() {
                return argv[i + 1]
            }
        }
        i = i + 1
    }
    return "default"
}

// Check if --language or -l flag is present in argv starting at startIndex.
fun hasLanguageFlag(argv: Array<String>, startIndex: Int) r: Bool {
    var i = startIndex
    while i < argv.length() {
        if argv[i] == "--language" or argv[i] == "-l" {
            return true
        }
        i = i + 1
    }
    return false
}

// Extract language from Seen.toml [project] section. Returns "" if not found.
fun extractTomlProjectLanguage(content: String) r: String {
    var inProject = 0
    var lineStart = 0
    var pos = 0
    while pos <= content.length() {
        var atEnd = 0
        if pos == content.length() {
            atEnd = 1
        }
        var isNewline = 0
        if atEnd == 0 {
            let b = content.byteAt(pos)
            if b == 10 {
                isNewline = 1
            }
        }
        if isNewline == 1 or atEnd == 1 {
            let line = content.substring(lineStart, pos).trim()
            if line.startsWith("[") {
                if line.endsWith("]") {
                    let section = line.substring(1, line.length() - 1)
                    if section == "project" {
                        inProject = 1
                    } else {
                        inProject = 0
                    }
                }
            } else {
                if inProject == 1 {
                    if line != "" {
                        if not line.startsWith("#") {
                            var eqPos = line.indexOf("=", 0)
                            if eqPos > 0 {
                                let key = line.substring(0, eqPos).trim()
                                if key == "language" {
                                    var langVal = line.substring(eqPos + 1, line.length()).trim()
                                    if langVal.startsWith("\"") {
                                        langVal = langVal.substring(1, langVal.length())
                                    }
                                    if langVal.endsWith("\"") {
                                        langVal = langVal.substring(0, langVal.length() - 1)
                                    }
                                    return langVal
                                }
                            }
                        }
                    }
                }
            }
            lineStart = pos + 1
        }
        pos = pos + 1
    }
    return ""
}

fun parseLanguage(argv: Array<String>, startIndex: Int) r: String {
    var i = startIndex
    while i < argv.length() {
        if argv[i] == "--language" or argv[i] == "-l" {
            if i + 1 < argv.length() {
                return argv[i + 1]
            }
        }
        i = i + 1
    }
    return "en"
}

///
CLI entry point. Dispatches to subcommands: compile, check, run, lsp,
bundle, sign, notarize, lipo, ipa, translate, import-c. The compile subcommand does its own
extensive flag parsing here before delegating to compileCommandWithFullTargeting.
///
fun main() r: Int {
    let argv = args()
    if argv.length() < 2 {
        printUsage()
        return 1
    }

    let command = argv[1]
    if command == "compile" {
        if argv.length() < 3 {
            printUsage()
            return 1
        }
        // Parse flags and positional args from argv[2:]
        var useCache = true
        var profile = "default"
        var language = "en"
        var languageFromCli = 0
        var targetCpu = ""
        var simdPolicy = "auto"
        var simdReport = false
        var deterministic = false
        var backend = "llvm"
        var sanitizePolicy = ""
        var pgoMode = ""
        var pgoPath = ""
        var mlLogPath = ""
        var mlDecisionLogPath = ""
        var crossTarget = ""
        var positionalArgs = Array<String>()
        var argIdx = 2
        while argIdx < argv.length() {
            if argv[argIdx] == "--no-cache" {
                useCache = false
            } else {
                if argv[argIdx] == "--profile" {
                    if argIdx + 1 < argv.length() {
                        argIdx = argIdx + 1
                        profile = argv[argIdx]
                    }
                } else {
                    if argv[argIdx] == "--language" or argv[argIdx] == "-l" {
                        if argIdx + 1 < argv.length() {
                            argIdx = argIdx + 1
                            language = argv[argIdx]
                            languageFromCli = 1
                        }
                    } else if argv[argIdx] == "--simd-report" {
                        simdReport = true
                    } else {
                        if startsWith(argv[argIdx], "--simd-report=") {
                            simdReport = true
                        } else {
                            if argv[argIdx] == "--deterministic" {
                                deterministic = true
                                simdPolicy = "none"
                            } else {
                                if startsWith(argv[argIdx], "--target-cpu=") {
                                    targetCpu = extractFlagValue(argv[argIdx], 13)
                                } else {
                                    if startsWith(argv[argIdx], "--simd=") {
                                        simdPolicy = extractFlagValue(argv[argIdx], 7)
                                    } else {
                                        if argv[argIdx] == "--backend" {
                                            if argIdx + 1 < argv.length() {
                                                argIdx = argIdx + 1
                                                backend = argv[argIdx]
                                            }
                                        } else if startsWith(argv[argIdx], "--backend=") {
                                            backend = extractFlagValue(argv[argIdx], 10)
                                        } else {
                                            if startsWith(argv[argIdx], "--sanitize=") {
                                                sanitizePolicy = extractFlagValue(argv[argIdx], 11)
                                            } else {
                                                if argv[argIdx] == "--pgo-generate" {
                                                    pgoMode = "generate"
                                                } else {
                                                    if startsWith(argv[argIdx], "--pgo-use=") {
                                                        pgoMode = "use"
                                                        pgoPath = extractFlagValue(argv[argIdx], 10)
                                                    } else {
                                                        if startsWith(argv[argIdx], "--ml-log=") {
                                                            mlLogPath = extractFlagValue(argv[argIdx], 9)
                                                        } else {
                                                            if startsWith(argv[argIdx], "--ml-decision-log=") {
                                                                mlDecisionLogPath = extractFlagValue(argv[argIdx], 18)
                                                            } else {
                                                                if argv[argIdx] == "--release" {
                                                                    g_releaseMode = true
                                                                } else {
                                                                    if argv[argIdx] == "--emit-llvm" {
                                                                        g_emitLlvm = true
                                                                    } else {
                                                                        if argv[argIdx] == "--fast" {
                                                                            g_fastMode = 1
                                                                        } else {
                                                                            if argv[argIdx] == "--O2" {
                                                                                g_O2Mode = 1
                                                                            } else {
                                                                                if startsWith(argv[argIdx], "--target=") {
                                                                                    crossTarget = extractFlagValue(argv[argIdx], 9)
                                                                                } else if argv[argIdx] == "--target" or argv[argIdx] == "-t" {
                                                                                    if argIdx + 1 < argv.length() {
                                                                                        crossTarget = argv[argIdx + 1]
                                                                                        argIdx = argIdx + 1
                                                                                    }
                                                                                } else if argv[argIdx] == "--bounds-check" {
                                                                                    g_boundsCheckCli = 1
                                                                                } else if argv[argIdx] == "--panic-on-overflow" {
                                                                                    g_panicOnOverflowCli = 1
                                                                                } else if argv[argIdx] == "--warn-unused-result" {
                                                                                    g_warnUnusedResultCli = 1
                                                                                } else if argv[argIdx] == "--emit-glsl" {
                                                                                    g_emitGlsl = 1
                                                                                } else if argv[argIdx] == "--null-safety" {
                                                                                    g_nullSafetyCli = 1
                                                                                } else if argv[argIdx] == "--warn-uninit" {
                                                                                    g_uninitCheckCli = 1
                                                                                } else if argv[argIdx] == "--stack-check" {
                                                                                    g_stackCheckCli = 1
                                                                                } else if argv[argIdx] == "--emit-compile-db" {
                                                                                    g_emitCompileDb = 1
                                                                                } else if argv[argIdx] == "--pic" {
                                                                                    g_picMode = 1
                                                                                } else if argv[argIdx] == "--object-manifest" {
                                                                                    if argIdx + 1 < argv.length() {
                                                                                        argIdx = argIdx + 1
                                                                                        g_objectManifestPath = argv[argIdx]
                                                                                    }
                                                                                } else if startsWith(argv[argIdx], "--object-manifest=") {
                                                                                    g_objectManifestPath = extractFlagValue(argv[argIdx], 18)
                                                                                } else if argv[argIdx] == "--no-fork" {
                                                                                    g_noFork = 1
                                                                                } else if argv[argIdx] == "--projectprefix" {
                                                                                    if argIdx + 1 < argv.length() {
                                                                                        argIdx = argIdx + 1
                                                                                        g_projectPrefixLimit = argv[argIdx].toInt()
                                                                                    }
                                                                                } else if startsWith(argv[argIdx], "--projectprefix=") {
                                                                                    g_projectPrefixLimit = extractFlagValue(argv[argIdx], 16).toInt()
                                                                                } else if startsWith(argv[argIdx], "--feature=") {
                                                                                    let featureVal = extractFlagValue(argv[argIdx], 10)
                                                                                    g_enabledFeaturesCli = g_enabledFeaturesCli + featureVal + "|"
                                                                                } else {
                                                                                    positionalArgs.push(argv[argIdx])
                                                                                }
                                                                            }
                                                                        }
                                                                    }
                                                                }
                                                            }
                                                        }
                                                    }
                                                }
                                            }
                                        }
                                    }
                                }
                            }
                        }
                    }
                }
            }
            argIdx = argIdx + 1
        }
        if positionalArgs.length() < 1 {
            printUsage()
            return 1
        }
        // Check backend selection
        if backend != "llvm" {
            println("Error: Backend '" + backend + "' is not implemented in this binary. Supported backend: llvm.")
            return 1
        }
        let inputFile = positionalArgs[0]
        var outputFile = defaultOutput(inputFile)
        if positionalArgs.length() > 1 {
            outputFile = positionalArgs[1]
        }
        if inputFile.contains(".test_main.") {
            g_generatedTestMainMode = 1
            if g_fastMode == 0 {
                g_fastMode = 1
            }
        }
        // Read language from Seen.toml [project] if CLI didn't explicitly set it
        if languageFromCli == 0 {
            let tc = readNearestSeenTomlForInput(inputFile)
            if tc != "" {
                let tl = extractTomlProjectLanguage(tc)
                if tl != "" {
                    language = tl
                }
            }
        }
        // Encode mlDecisionLogPath into mlLogPath using | delimiter for bootstrap compat
        var combinedMlPath = mlLogPath
        if mlDecisionLogPath != "" {
            combinedMlPath = mlLogPath + "|" + mlDecisionLogPath
        }
        let compResult = compileCommandWithFullTargeting(inputFile, outputFile, profile, useCache, language, targetCpu, simdPolicy, simdReport, sanitizePolicy, pgoMode, pgoPath, combinedMlPath, crossTarget)
        return compResult
    }

    if command == "check" {
        if argv.length() < 3 {
            printUsage()
            return 1
        }
        let profile = parseProfile(argv, 3)
        var language = parseLanguage(argv, 3)
        // Read language from Seen.toml [project] if CLI didn't explicitly set --language
        if not hasLanguageFlag(argv, 3) {
            let tc = readNearestSeenTomlForInput(argv[2])
            if tc != "" {
                let tl = extractTomlProjectLanguage(tc)
                if tl != "" {
                    language = tl
                }
            }
        }
        return checkCommandWithProfile(argv[2], profile, language)
    }

    if command == "run" {
        if argv.length() < 3 {
            printUsage()
            return 1
        }
        // Parse --aot, --verbose, and --language flags
        var useAot = false
        var verbose = false
        var runInputFile = ""
        var runLanguage = "en"
        var ri = 2
        while ri < argv.length() {
            if argv[ri] == "--aot" {
                useAot = true
            } else if argv[ri] == "--verbose" {
                verbose = true
            } else if argv[ri] == "--language" or argv[ri] == "-l" {
                if ri + 1 < argv.length() {
                    ri = ri + 1
                    runLanguage = argv[ri]
                }
            } else {
                if runInputFile == "" {
                    runInputFile = argv[ri]
                }
            }
            ri = ri + 1
        }
        if runInputFile == "" {
            printUsage()
            return 1
        }
        // Read language from Seen.toml [project] if CLI didn't explicitly set --language
        if not hasLanguageFlag(argv, 2) {
            let tc = readNearestSeenTomlForInput(runInputFile)
            if tc != "" {
                let tl = extractTomlProjectLanguage(tc)
                if tl != "" {
                    runLanguage = tl
                }
            }
        }
        return runScriptCommand(runInputFile, useAot, verbose, runLanguage)
    }

    // LSP command - start language server
    if command == "lsp" {
        return runLspServer()
    }

    // macOS App Bundle command
    if command == "bundle" {
        if argv.length() < 4 {
            println("Usage: seen bundle <executable> <AppName> [--icon=<icon.icns>] [--version=<1.0>]")
            return 1
        }
        return bundleCommand(argv)
    }

    // macOS code signing command
    if command == "sign" {
        if argv.length() < 3 {
            println("Usage: seen sign <path> [--identity=<identity>]")
            return 1
        }
        return signCommand(argv)
    }

    // macOS notarization command
    if command == "notarize" {
        if argv.length() < 3 {
            println("Usage: seen notarize <path.zip|path.app> --apple-id=<email> --team-id=<id> --password=<app-specific-password>")
            return 1
        }
        return notarizeCommand(argv)
    }

    // Universal binary (lipo) command
    if command == "lipo" {
        if argv.length() < 3 {
            println("Usage: seen lipo <x86_64_binary> <arm64_binary> [--output=<universal>]")
            println("       seen lipo --from-source <source.seen> [--output=<universal>]")
            return 1
        }
        return lipoCommand(argv)
    }

    // iOS IPA builder command
    if command == "ipa" {
        if argv.length() < 4 {
            println("Usage: seen ipa <executable> <AppName> [--bundle-id=...] [--version=...] [--provisioning-profile=<path>]")
            return 1
        }
        return ipaCommand(argv)
    }

    if command == "translate" {
        return translateCommand(argv)
    }

    if command == "import-c" {
        return importCCommand(argv)
    }

    if command == "pkg" {
        return pkgCommand(argv)
    }

    println("Unknown command: " + command)
    printUsage()
    return 1
}

///
============================================================================
macOS App Bundle / Code Signing / Notarization Commands
============================================================================
///

///
Create a macOS .app bundle from a compiled executable. Generates the standard
Contents/MacOS + Contents/Resources directory structure and writes Info.plist.
///
fun bundleCommand(argv: Array<String>) r: Int {
    let executable = argv[2]
    let appName = argv[3]
    var iconPath = ""
    var version = "1.0"
    var bundleId = "com.seen." + appName

    // Parse optional flags
    var i = 4
    while i < argv.length() {
        if startsWith(argv[i], "--icon=") {
            iconPath = extractFlagValue(argv[i], 7)
        }
        if startsWith(argv[i], "--version=") {
            version = extractFlagValue(argv[i], 10)
        }
        if startsWith(argv[i], "--bundle-id=") {
            bundleId = extractFlagValue(argv[i], 12)
        }
        i = i + 1
    }

    let appDir = appName + ".app"
    let contentsDir = appDir + "/Contents"
    let macosDir = contentsDir + "/MacOS"
    let resourcesDir = contentsDir + "/Resources"

    // Create directory structure
    let mkdirResult: CommandResult = runCommand("mkdir -p " + macosDir + " " + resourcesDir)
    if not commandWasSuccessful(mkdirResult) {
        println("Error: Failed to create app bundle directory structure")
        return 1
    }

    // Copy executable
    let cpResult: CommandResult = runCommand("cp " + executable + " " + macosDir + "/" + appName)
    if not commandWasSuccessful(cpResult) {
        println("Error: Failed to copy executable into bundle")
        return 1
    }
    let chmodResult: CommandResult = runCommand("chmod +x " + macosDir + "/" + appName)

    // Copy icon if provided
    if iconPath != "" {
        let iconResult: CommandResult = runCommand("cp " + iconPath + " " + resourcesDir + "/AppIcon.icns")
    }

    // Generate Info.plist with incremental appends to avoid one deep concat tree.
    var plist: String = ""
    plist = plist + "<?xml version=\"1.0\" encoding=\"UTF-8\"?>\n"
    plist = plist + "<!DOCTYPE plist PUBLIC \"-//Apple//DTD PLIST 1.0//EN\" \"http://www.apple.com/DTDs/PropertyList-1.0.dtd\">\n"
    plist = plist + "<plist version=\"1.0\">\n"
    plist = plist + "<dict>\n"
    plist = plist + "  <key>CFBundleExecutable</key>\n"
    plist = plist + "  <string>" + appName + "</string>\n"
    plist = plist + "  <key>CFBundleIdentifier</key>\n"
    plist = plist + "  <string>" + bundleId + "</string>\n"
    plist = plist + "  <key>CFBundleName</key>\n"
    plist = plist + "  <string>" + appName + "</string>\n"
    plist = plist + "  <key>CFBundleVersion</key>\n"
    plist = plist + "  <string>" + version + "</string>\n"
    plist = plist + "  <key>CFBundleShortVersionString</key>\n"
    plist = plist + "  <string>" + version + "</string>\n"
    plist = plist + "  <key>CFBundlePackageType</key>\n"
    plist = plist + "  <string>APPL</string>\n"
    plist = plist + "  <key>CFBundleIconFile</key>\n"
    plist = plist + "  <string>AppIcon</string>\n"
    plist = plist + "  <key>LSMinimumSystemVersion</key>\n"
    plist = plist + "  <string>13.0</string>\n"
    plist = plist + "  <key>NSHighResolutionCapable</key>\n"
    plist = plist + "  <true/>\n"
    plist = plist + "</dict>\n"
    plist = plist + "</plist>"
    writeText(contentsDir + "/Info.plist", plist)

    println("App bundle created: " + appDir)
    return 0
}

fun signCommand(argv: Array<String>) r: Int {
    let path = argv[2]
    var identity = "-"  // Ad-hoc signing by default
    var i = 3
    while i < argv.length() {
        if startsWith(argv[i], "--identity=") {
            identity = extractFlagValue(argv[i], 11)
        }
        i = i + 1
    }

    let signCmd = "codesign --force --deep --sign \"" + identity + "\" " + path
    println("Signing: " + path + " (identity: " + identity + ")")
    let result: CommandResult = runCommand(signCmd)
    if commandWasSuccessful(result) {
        println("Signed successfully")
        return 0
    }
    println("Signing failed: " + result.output)
    return 1
}

fun notarizeCommand(argv: Array<String>) r: Int {
    let path = argv[2]
    var appleId = ""
    var teamId = ""
    var password = ""
    var i = 3
    while i < argv.length() {
        if startsWith(argv[i], "--apple-id=") {
            appleId = extractFlagValue(argv[i], 11)
        }
        if startsWith(argv[i], "--team-id=") {
            teamId = extractFlagValue(argv[i], 10)
        }
        if startsWith(argv[i], "--password=") {
            password = extractFlagValue(argv[i], 11)
        }
        i = i + 1
    }

    if appleId == "" or teamId == "" or password == "" {
        println("Error: --apple-id, --team-id, and --password are all required")
        return 1
    }

    let notarizeCmd = "xcrun notarytool submit " + path +
        " --apple-id " + appleId +
        " --team-id " + teamId +
        " --password " + password +
        " --wait"
    println("Submitting for notarization: " + path)
    let result: CommandResult = runCommand(notarizeCmd)
    if commandWasSuccessful(result) {
        println("Notarization succeeded")
        // Staple the ticket
        let stapleCmd = "xcrun stapler staple " + path
        let stapleResult: CommandResult = runCommand(stapleCmd)
        if commandWasSuccessful(stapleResult) {
            println("Ticket stapled successfully")
        }
        return 0
    }
    println("Notarization failed: " + result.output)
    return 1
}

///
============================================================================
Universal Binary (lipo) Command
============================================================================
///

///
Create a macOS universal binary (fat binary) containing both x86_64 and arm64
slices. Two modes: (A) merge two pre-built binaries, or (B) --from-source
compiles the same source for both architectures and merges the results.
///
fun lipoCommand(argv: Array<String>) r: Int {
    var outputPath = ""
    var fromSource = false
    var sourceFile = ""

    // Check for --from-source mode
    if argv[2] == "--from-source" {
        fromSource = true
        if argv.length() < 4 {
            println("Usage: seen lipo --from-source <source.seen> [--output=<universal>]")
            return 1
        }
        sourceFile = argv[3]
        // Parse remaining flags
        var i = 4
        while i < argv.length() {
            if startsWith(argv[i], "--output=") {
                outputPath = extractFlagValue(argv[i], 9)
            }
            i = i + 1
        }
        // Default output name: strip .seen extension
        if outputPath == "" {
            if sourceFile.endsWith(".seen") {
                outputPath = sourceFile.substring(0, sourceFile.length() - 5)
            } else {
                outputPath = sourceFile + ".universal"
            }
        }
    } else {
        // Mode A: merge two pre-built binaries
        let x86Binary = argv[2]
        let armBinary = argv[3]
        // Parse remaining flags
        var i = 4
        while i < argv.length() {
            if startsWith(argv[i], "--output=") {
                outputPath = extractFlagValue(argv[i], 9)
            }
            i = i + 1
        }
        if outputPath == "" {
            outputPath = x86Binary + ".universal"
        }

        println("Creating universal binary: " + outputPath)
        println("  x86_64: " + x86Binary)
        println("  arm64:  " + armBinary)

        let lipoCmd = "lipo -create " + x86Binary + " " + armBinary + " -output " + outputPath
        let result: CommandResult = runCommand(lipoCmd)
        if not commandWasSuccessful(result) {
            println("Error: lipo failed: " + result.output)
            return 1
        }

        // Verify the result
        let infoCmd = "lipo -info " + outputPath
        let infoResult: CommandResult = runCommand(infoCmd)
        if commandWasSuccessful(infoResult) {
            println("Universal binary created: " + infoResult.output)
        }
        return 0
    }

    // --from-source mode: compile for both architectures, then merge
    let selfPath = argv[0]
    let hash = hashString(sourceFile)
    let tmpX86 = "/tmp/seen_lipo_x86_" + hash
    let tmpArm = "/tmp/seen_lipo_arm_" + hash

    println("Building universal binary from source: " + sourceFile)

    // Compile for x86_64
    println("  Compiling for x86_64...")
    let x86Cmd = selfPath + " compile " + sourceFile + " " + tmpX86 + " --target=macos-x86_64"
    let x86Result: CommandResult = runCommand(x86Cmd)
    if not commandWasSuccessful(x86Result) {
        println("Error: x86_64 compilation failed: " + x86Result.output)
        return 1
    }

    // Compile for arm64
    println("  Compiling for arm64...")
    let armCmd = selfPath + " compile " + sourceFile + " " + tmpArm + " --target=macos-arm64"
    let armResult: CommandResult = runCommand(armCmd)
    if not commandWasSuccessful(armResult) {
        // Clean up x86 temp file
        let cleanResult: CommandResult = runCommand("rm -f " + tmpX86)
        println("Error: arm64 compilation failed: " + armResult.output)
        return 1
    }

    // Merge with lipo
    println("  Merging architectures...")
    let lipoCmd = "lipo -create " + tmpX86 + " " + tmpArm + " -output " + outputPath
    let lipoResult: CommandResult = runCommand(lipoCmd)
    if not commandWasSuccessful(lipoResult) {
        let cleanResult: CommandResult = runCommand("rm -f " + tmpX86 + " " + tmpArm)
        println("Error: lipo failed: " + lipoResult.output)
        return 1
    }

    // Clean up temp files
    let cleanResult: CommandResult = runCommand("rm -f " + tmpX86 + " " + tmpArm)

    // Verify the result
    let infoCmd = "lipo -info " + outputPath
    let infoResult: CommandResult = runCommand(infoCmd)
    if commandWasSuccessful(infoResult) {
        println("Universal binary created: " + infoResult.output)
    }
    return 0
}

///
============================================================================
iOS IPA Builder Command
============================================================================
///

///
Build an iOS .ipa archive from a pre-built arm64 executable or from source.
Creates the Payload/AppName.app directory structure, generates Info.plist,
embeds provisioning profile, code-signs, and packages into a .zip renamed .ipa.
///
fun ipaCommand(argv: Array<String>) r: Int {
    var fromSource = false
    var sourceFile = ""
    var executable = ""
    var appName = ""
    var bundleId = ""
    var version = "1.0"
    var minIos = "17.0"
    var iconPath = ""
    var provisioningProfile = ""
    var identity = "-"
    var entitlements = ""

    // Check for --from-source mode
    if argv[2] == "--from-source" {
        fromSource = true
        if argv.length() < 4 {
            println("Usage: seen ipa --from-source <source.seen> <AppName> [options...]")
            return 1
        }
        sourceFile = argv[3]
        if argv.length() < 5 {
            println("Usage: seen ipa --from-source <source.seen> <AppName> [options...]")
            return 1
        }
        appName = argv[4]
        // Parse flags starting at index 5
        var i = 5
        while i < argv.length() {
            if startsWith(argv[i], "--bundle-id=") {
                bundleId = extractFlagValue(argv[i], 12)
            }
            if startsWith(argv[i], "--version=") {
                version = extractFlagValue(argv[i], 10)
            }
            if startsWith(argv[i], "--min-ios=") {
                minIos = extractFlagValue(argv[i], 10)
            }
            if startsWith(argv[i], "--icon=") {
                iconPath = extractFlagValue(argv[i], 7)
            }
            if startsWith(argv[i], "--provisioning-profile=") {
                provisioningProfile = extractFlagValue(argv[i], 23)
            }
            if startsWith(argv[i], "--identity=") {
                identity = extractFlagValue(argv[i], 11)
            }
            if startsWith(argv[i], "--entitlements=") {
                entitlements = extractFlagValue(argv[i], 15)
            }
            i = i + 1
        }
    } else {
        executable = argv[2]
        appName = argv[3]
        // Parse flags starting at index 4
        var i = 4
        while i < argv.length() {
            if startsWith(argv[i], "--bundle-id=") {
                bundleId = extractFlagValue(argv[i], 12)
            }
            if startsWith(argv[i], "--version=") {
                version = extractFlagValue(argv[i], 10)
            }
            if startsWith(argv[i], "--min-ios=") {
                minIos = extractFlagValue(argv[i], 10)
            }
            if startsWith(argv[i], "--icon=") {
                iconPath = extractFlagValue(argv[i], 7)
            }
            if startsWith(argv[i], "--provisioning-profile=") {
                provisioningProfile = extractFlagValue(argv[i], 23)
            }
            if startsWith(argv[i], "--identity=") {
                identity = extractFlagValue(argv[i], 11)
            }
            if startsWith(argv[i], "--entitlements=") {
                entitlements = extractFlagValue(argv[i], 15)
            }
            i = i + 1
        }
    }

    if bundleId == "" {
        bundleId = "com.seen." + appName
    }

    // Step 1: If --from-source, compile for ios-arm64
    if fromSource {
        let selfPath = argv[0]
        let hash = hashString(sourceFile)
        let tmpOut = "/tmp/seen_ipa_bin_" + hash
        println("Compiling " + sourceFile + " for ios-arm64...")
        let compileCmd = selfPath + " compile " + sourceFile + " " + tmpOut + " --target=ios-arm64"
        let compileResult: CommandResult = runCommand(compileCmd)
        if not commandWasSuccessful(compileResult) {
            println("Error: iOS compilation failed: " + compileResult.output)
            return 1
        }
        executable = tmpOut
    }

    // Step 2: Create Payload directory structure in /tmp
    let hash = hashString(appName + version)
    let buildDir = "/tmp/seen_ipa_" + hash
    let payloadDir = buildDir + "/Payload"
    let appDir = payloadDir + "/" + appName + ".app"

    println("Building IPA: " + appName + ".ipa")
    println("  Bundle ID: " + bundleId)
    println("  Version: " + version)
    println("  Min iOS: " + minIos)

    let mkdirResult: CommandResult = runCommand("mkdir -p " + appDir)
    if not commandWasSuccessful(mkdirResult) {
        println("Error: Failed to create app directory structure")
        return 1
    }

    // Step 3: Copy executable into app bundle
    let cpResult: CommandResult = runCommand("cp " + executable + " " + appDir + "/" + appName)
    if not commandWasSuccessful(cpResult) {
        println("Error: Failed to copy executable into app bundle")
        let cleanResult: CommandResult = runCommand("rm -rf " + buildDir)
        return 1
    }
    let chmodResult: CommandResult = runCommand("chmod +x " + appDir + "/" + appName)

    // Step 4: Generate iOS Info.plist with incremental appends.
    var plist: String = ""
    plist = plist + "<?xml version=\"1.0\" encoding=\"UTF-8\"?>\n"
    plist = plist + "<!DOCTYPE plist PUBLIC \"-//Apple//DTD PLIST 1.0//EN\" \"http://www.apple.com/DTDs/PropertyList-1.0.dtd\">\n"
    plist = plist + "<plist version=\"1.0\">\n"
    plist = plist + "<dict>\n"
    plist = plist + "  <key>CFBundleExecutable</key>\n"
    plist = plist + "  <string>" + appName + "</string>\n"
    plist = plist + "  <key>CFBundleIdentifier</key>\n"
    plist = plist + "  <string>" + bundleId + "</string>\n"
    plist = plist + "  <key>CFBundleName</key>\n"
    plist = plist + "  <string>" + appName + "</string>\n"
    plist = plist + "  <key>CFBundleVersion</key>\n"
    plist = plist + "  <string>" + version + "</string>\n"
    plist = plist + "  <key>CFBundleShortVersionString</key>\n"
    plist = plist + "  <string>" + version + "</string>\n"
    plist = plist + "  <key>CFBundlePackageType</key>\n"
    plist = plist + "  <string>APPL</string>\n"
    plist = plist + "  <key>MinimumOSVersion</key>\n"
    plist = plist + "  <string>" + minIos + "</string>\n"
    plist = plist + "  <key>DTPlatformName</key>\n"
    plist = plist + "  <string>iphoneos</string>\n"
    plist = plist + "  <key>UIDeviceFamily</key>\n"
    plist = plist + "  <array>\n"
    plist = plist + "    <integer>1</integer>\n"
    plist = plist + "    <integer>2</integer>\n"
    plist = plist + "  </array>\n"
    plist = plist + "  <key>UILaunchStoryboardName</key>\n"
    plist = plist + "  <string></string>\n"
    plist = plist + "  <key>UIRequiredDeviceCapabilities</key>\n"
    plist = plist + "  <array>\n"
    plist = plist + "    <string>arm64</string>\n"
    plist = plist + "  </array>\n"
    plist = plist + "  <key>CFBundleSupportedPlatforms</key>\n"
    plist = plist + "  <array>\n"
    plist = plist + "    <string>iPhoneOS</string>\n"
    plist = plist + "  </array>\n"
    plist = plist + "</dict>\n"
    plist = plist + "</plist>"
    writeText(appDir + "/Info.plist", plist)

    // Step 5: Embed provisioning profile if provided
    if provisioningProfile != "" {
        let provResult: CommandResult = runCommand("cp " + provisioningProfile + " " + appDir + "/embedded.mobileprovision")
        if not commandWasSuccessful(provResult) {
            println("Warning: Failed to embed provisioning profile")
        }
    }

    // Step 6: Copy icon if provided
    if iconPath != "" {
        let iconResult: CommandResult = runCommand("cp " + iconPath + " " + appDir + "/AppIcon.png")
    }

    // Step 7: Code sign
    var signCmd = "codesign --force --deep --sign \"" + identity + "\" "
    if entitlements != "" {
        signCmd = signCmd + "--entitlements " + entitlements + " "
    }
    signCmd = signCmd + appDir
    println("  Signing with identity: " + identity)
    let signResult: CommandResult = runCommand(signCmd)
    if not commandWasSuccessful(signResult) {
        println("Warning: Code signing failed: " + signResult.output)
        println("  IPA will be unsigned (may not install on devices)")
    }

    // Step 8: Package as .ipa
    let ipaName = appName + ".ipa"
    let zipCmd = "cd " + buildDir + " && zip -r -q " + ipaName + " Payload/"
    let zipResult: CommandResult = runCommand(zipCmd)
    if not commandWasSuccessful(zipResult) {
        println("Error: Failed to create IPA archive")
        let cleanResult: CommandResult = runCommand("rm -rf " + buildDir)
        return 1
    }

    // Step 9: Move .ipa to current directory and clean up
    let mvResult: CommandResult = runCommand("mv " + buildDir + "/" + ipaName + " ./" + ipaName)
    if not commandWasSuccessful(mvResult) {
        println("Error: Failed to move IPA to current directory")
        let cleanResult: CommandResult = runCommand("rm -rf " + buildDir)
        return 1
    }
    let cleanResult: CommandResult = runCommand("rm -rf " + buildDir)

    // Clean up temp executable from --from-source
    if fromSource {
        let cleanSrcResult: CommandResult = runCommand("rm -f " + executable)
    }

    println("IPA created: " + ipaName)
    return 0
}

///
============================================================================
Translate Command
============================================================================
///

// Check if a language code is supported. Returns 1 for valid, 0 for invalid.
fun isValidTranslateLanguage(lang: String) r: Int {
    if lang == "en" { return 1 }
    if lang == "ar" { return 1 }
    if lang == "es" { return 1 }
    if lang == "ru" { return 1 }
    if lang == "zh" { return 1 }
    if lang == "ja" { return 1 }
    if lang == "fr" { return 1 }
    return 0
}

// Usage: seen translate <file> --from <lang> --to <lang> [-o <output>]
fun translateCommand(argv: Array<String>) r: Int {
    if argv.length() < 3 {
        println("Error: translate command requires a source file")
        println("Usage: seen translate <file> --from <lang> --to <lang> [-o <output>]")
        return 1
    }

    let sourceFile = argv[2]
    var fromLang = "en"
    var toLang = ""
    var outputFile = ""

    var i = 3
    while i < argv.length() {
        if argv[i] == "--from" {
            if i + 1 < argv.length() {
                i = i + 1
                fromLang = argv[i]
            } else {
                println("Error: --from requires a language code")
                return 1
            }
        } else {
            if argv[i] == "--to" {
                if i + 1 < argv.length() {
                    i = i + 1
                    toLang = argv[i]
                } else {
                    println("Error: --to requires a language code")
                    return 1
                }
            } else {
                if argv[i] == "-o" or argv[i] == "--output" {
                    if i + 1 < argv.length() {
                        i = i + 1
                        outputFile = argv[i]
                    } else {
                        println("Error: -o requires an output file path")
                        return 1
                    }
                } else {
                    println("Warning: Unknown option '" + argv[i] + "'")
                }
            }
        }
        i = i + 1
    }

    if toLang == "" {
        println("Error: --to <lang> is required")
        println("Usage: seen translate <file> --from <lang> --to <lang> [-o <output>]")
        return 1
    }

    if isValidTranslateLanguage(fromLang) == 0 {
        println("Error: Unsupported language '" + fromLang + "'")
        println("Supported languages: en, ar, es, ru, zh, ja, fr")
        return 1
    }
    if isValidTranslateLanguage(toLang) == 0 {
        println("Error: Unsupported language '" + toLang + "'")
        println("Supported languages: en, ar, es, ru, zh, ja, fr")
        return 1
    }

    let sourceCode = readText(sourceFile)
    if sourceCode.length() == 0 {
        println("Error: Could not read file '" + sourceFile + "'")
        return 1
    }

    let translated = translateSource(sourceCode, fromLang, toLang)

    if outputFile != "" {
        writeText(outputFile, translated)
        println("Translated " + sourceFile + " (" + fromLang + " -> " + toLang + ") -> " + outputFile)
        return 0
    }
    // Print to stdout
    printRaw(translated)
    return 0
}

// Usage: seen import-c <header.h>
fun importCCommand(argv: Array<String>) r: Int {
    if argv.length() < 3 {
        println("Error: import-c command requires a header file path")
        println("Usage: seen import-c <header.h>")
        return 1
    }

    let headerFile = argv[2]
    println("Generating Seen bindings for: " + headerFile)

    let gen = CImportGenerator.new(headerFile)
    let result: CImportResult = gen.parseHeader()

    if not result.isSuccessful() {
        var ei = 0
        while ei < result.errorCount() {
            println("Error: " + result.errorAt(ei))
            ei = ei + 1
        }
        return 1
    }

    var wi = 0
    while wi < result.warningCount() {
        println("Warning: " + result.warningAt(wi))
        wi = wi + 1
    }

    let declarations = gen.generateExternDeclarations()
    println(declarations)
    println("// " + result.typedefCount().toString() + " typedef aliases imported")
    println("// " + result.functionCount().toString() + " functions imported")
    println("// " + result.constantCount().toString() + " enum constants imported")
    return 0
}
