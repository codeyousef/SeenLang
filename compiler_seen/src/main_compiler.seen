fun sourcesNeedLinuxPlatformPipewireShim(modulePaths: Array<String>) r: Bool {
    var mi = 0
    while mi < modulePaths.length() {
        if modulePaths[mi].endsWith("/seen_std/src/platform/linux/pipewire.seen") {
            return true
        }
        mi = mi + 1
    }
    return false
}

fun sourcesNeedLinuxPlatformEvdevShim(modulePaths: Array<String>) r: Bool {
    var mi = 0
    while mi < modulePaths.length() {
        if modulePaths[mi].endsWith("/seen_std/src/platform/linux/evdev.seen") {
            return true
        }
