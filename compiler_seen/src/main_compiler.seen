    g_validationModulePaths = Array<String>()
    g_validationFrontends = Array<FrontendResult>()
}

///
DJB2 hash of a string, returned as 8-char hex
Uses byteAt() to avoid per-char string allocation
///
fun hashString(data: String) r: String {
    var hash = 5381
    var index = 0
    while index < data.length() {
        let code: Int = data.byteAt(index)
        var step = hash * 33
        step = step + code
        hash = step % 2147483647
        index = index + 1
    }
    let hexChars = "0123456789abcdef"
    var remaining = if hash < 0 { 0 - hash } else { hash }
    var result = ""
    var digits = 0
    while digits < 8 {
        let nibble = remaining % 16
        let digit = hexChars.substring(nibble, nibble + 1)
        result = digit + result
        remaining = remaining / 16
        digits = digits + 1
    }
    return result
}

fun mainCompilerStringsEqualBytes(left: String, right: String) r: Bool {
    if left.length() != right.length() {
        return false
    }
    var index = 0
    while index < left.length() {
        if left.byteAt(index) != right.byteAt(index) {
            return false
        }
        index = index + 1
    }
    return true
}

fun mainCompilerIsMainFunctionName(name: String) r: Bool {
    return mainCompilerStringsEqualBytes(name, "main")
}

fun mainCompilerItemFunctionNameEquals(item: ItemNode, functionName: String) r: Bool {
    return mainCompilerStringsEqualBytes(item.function.name, functionName)
}

fun mainCompilerItemDeclaresMain(item: ItemNode) r: Bool {
    if mainCompilerIsMainFunctionName(item.name) {
        return true
    }
    return mainCompilerIsMainFunctionName(item.function.name)
}

fun buildCacheSignature(profile: String, language: String, targetCpu: String, simdPolicy: String,
    sanitizePolicy: String, pgoMode: String, effectiveTarget: String, panicOnOverflow: Bool) r: String {
    var signature = "cache-v3"
    signature = signature + "|profile=" + profile
    signature = signature + "|language=" + language
    signature = signature + "|targetCpu=" + targetCpu
    signature = signature + "|simd=" + simdPolicy
    signature = signature + "|sanitize=" + sanitizePolicy
    signature = signature + "|pgo=" + pgoMode
    signature = signature + "|target=" + effectiveTarget
    if panicOnOverflow {
        signature = signature + "|panic=1"
    } else {
        signature = signature + "|panic=0"
    }
    if g_releaseMode {
        signature = signature + "|release=1"
    } else {
        signature = signature + "|release=0"
    }
    if g_fastMode == 1 {
        signature = signature + "|fast=1"
    } else {
        signature = signature + "|fast=0"
    }
    if g_picMode == 1 {
        signature = signature + "|pic=1"
    } else {
        signature = signature + "|pic=0"
    }
    if g_boundsCheckCli == 1 {
        signature = signature + "|bounds=1"
    } else {
        signature = signature + "|bounds=0"
    }
    if effectiveTarget == "android-arm64" {
        signature = signature + "|moduleobj=target-clang"
    } else {
        if g_generatedTestMainMode == 1 {
            signature = signature + "|moduleobj=host-llc-testmain-childobj-v5"
        } else {
            if g_fastMode == 1 {
                signature = signature + "|moduleobj=host-llc-fast-v1"
            } else {
                signature = signature + "|moduleobj=host-opt"
            }
        }
    }
    return signature
}

// Read file contents, returning "" if file doesn't exist
fun loadFileContent(path: String) r: String {
    if not exists(path) {
        return ""
    }
    return readText(path)
}

// ANSI escape code builder
fun ansiCode(code: String) r: String {
    var esc = String.fromCharCode(27)
    return esc + "[" + code + "m"
}
fun colorRed(text: String) r: String { return ansiCode("1;31") + text + ansiCode("0") }
fun colorYellow(text: String) r: String { return ansiCode("1;33") + text + ansiCode("0") }
fun colorCyan(text: String) r: String { return ansiCode("0;36") + text + ansiCode("0") }
fun colorBlue(text: String) r: String { return ansiCode("0;34") + text + ansiCode("0") }
fun colorBoldWhite(text: String) r: String { return ansiCode("1;37") + text + ansiCode("0") }

// Read a specific line from a file (1-indexed)
fun getSourceLine(filePath: String, lineNumber: Int) r: String {
    var source = readText(filePath)
    if source == "" { return "" }
    var lines = source.split("\n")
    if lineNumber < 1 { return "" }
    if lineNumber > lines.length() { return "" }
    return lines[lineNumber - 1]
}

// Create a string of N spaces
fun makeSpaces(count: Int) r: String {
    var result = ""
    var i = 0
    while i < count {
        result = result + " "
        i = i + 1
    }
    return result
}

// Create a string of N carets (^)
fun makeCarets(count: Int) r: String {
    var result = ""
    var i = 0
    while i < count {
        result = result + "^"
        i = i + 1
    }
    return result
}

// Ensure .seen_cache/ directory exists
fun ensureCacheDir() r: Void {
    if not exists(".seen_cache") {
        let result: CommandResult = runCommand("mkdir -p .seen_cache")
    }
}

// Ensure IR cache directory exists
fun ensureIrCacheDir() r: Void {
    let result: CommandResult = runCommand("mkdir -p /tmp/seen_ir_cache")
}

// Clear all cached files
fun clearCache() r: Void {
    let result: CommandResult = runCommand("rm -rf .seen_cache/*")
}

fun getTraceTimeSeconds() r: Int {
    let result: CommandResult = runCommand("date +%s")
    if commandWasSuccessful(result) {
        let out = result.output.trim()
        if out.length() > 0 {
            return out.toInt()
        }
    }
    return 0
}

// Helper to parse a module and return its program
fun parseModule(path: String, lang: String) r: FrontendResult {
    if not exists(path) {
        let frontend = FrontendResult.new()
        let message = encodeDiagMessage(
            "could not read module `" + path + "`",
            "E005",
            "",
            "note: imported and Seen.toml-declared modules must exist on disk",
            0
        )
        frontend.addDiagnostic(FrontendDiagnostic.new(path, 1, 1, "error", message))
        return frontend
    }
    let source = readText(path)
    return run_frontend(source, path, lang)
}

fun parseModuleDeclarations(path: String, lang: String) r: FrontendResult {
    if not exists(path) {
        let frontend = FrontendResult.new()
        let message = encodeDiagMessage(
            "could not read module `" + path + "`",
            "E005",
            "",
            "note: imported and Seen.toml-declared modules must exist on disk",
            0
        )
        frontend.addDiagnostic(FrontendDiagnostic.new(path, 1, 1, "error", message))
        return frontend
    }
    let source = readText(path)
    return run_frontend_declarations(source, path, lang)
}

fun stripTomlQuotedValue(value: String) r: String {
    var result = value.trim()
    if result.startsWith("\"") {
        result = result.substring(1, result.length())
    }
    if result.endsWith("\"") {
        result = result.substring(0, result.length() - 1)
    }
    return result
}

class PackageDependency {
    var name: String
    var source: String
    var version: String
    var path: String
    var registry: String

    static fun new() r: PackageDependency {
        return PackageDependency{
            name: "",
            source: "",
            version: "",
            path: "",
            registry: "default"
        }
    }
}

class PackageRelease {
    var version: String
    var archive: String
    var sha256: String

    static fun new() r: PackageRelease {
        return PackageRelease{
            version: "",
            archive: "",
            sha256: ""
        }
    }
}

fun currentWorkingDir() r: String {
    let pwdResult = runCommand("pwd")
    if commandWasSuccessful(pwdResult) {
        return pwdResult.output.trim()
    }
    return ""
}

fun directoryExists(path: String) r: Bool {
    if path == "" {
        return false
    }
    let result = runCommand("test -d " + shellQuote(path))
    return commandWasSuccessful(result)
}

fun ensureDirectory(path: String) r: Bool {
    if path == "" {
        return false
    }
    let result = runCommand("mkdir -p " + shellQuote(path))
    return commandWasSuccessful(result)
}

fun removePathIfExists(path: String) r: Void {
    if path == "" {
        return
    }
    let _ = runCommand("rm -rf " + shellQuote(path))
    return
}

fun isHttpRegistryLocation(location: String) r: Bool {
    return location.startsWith("http://") or location.startsWith("https://")
}

fun defaultRegistryLocation() r: String {
    return "https://seen.yousef.codes/packages"
}

fun extractTomlProjectVersion(content: String) r: String {
    var inProject = 0
    var lineStart = 0
    var pos = 0
    while pos <= content.length() {
        var atEnd = 0
        if pos == content.length() {
            atEnd = 1
        }
        var isNewline = 0
        if atEnd == 0 {
            let b = content.byteAt(pos)
            if b == 10 {
                isNewline = 1
            }
        }
        if isNewline == 1 or atEnd == 1 {
            let line = content.substring(lineStart, pos).trim()
            if line.startsWith("[") {
                if line.endsWith("]") {
                    let section = line.substring(1, line.length() - 1)
                    if section == "project" {
                        inProject = 1
                    } else {
                        inProject = 0
                    }
                }
            } else {
                if inProject == 1 {
                    if line != "" and not line.startsWith("#") {
                        let eqPos = line.indexOf("=", 0)
                        if eqPos > 0 {
                            let key = stripTomlQuotedValue(line.substring(0, eqPos).trim())
                            if key == "version" {
                                let value = line.substring(eqPos + 1, line.length()).trim()
                                return stripTomlQuotedValue(value)
                            }
                        }
                    }
                }
            }
            lineStart = pos + 1
        }
        pos = pos + 1
    }
    return ""
}

fun extractTomlRegistryLocation(content: String, registryName: String) r: String {
    var inRegistries = 0
    var lineStart = 0
    var pos = 0
    while pos <= content.length() {
        var atEnd = 0
        if pos == content.length() {
            atEnd = 1
        }
        var isNewline = 0
        if atEnd == 0 {
            let b = content.byteAt(pos)
            if b == 10 {
                isNewline = 1
            }
        }
        if isNewline == 1 or atEnd == 1 {
            let line = content.substring(lineStart, pos).trim()
            if line.startsWith("[") {
                if line.endsWith("]") {
                    let section = line.substring(1, line.length() - 1)
                    if section == "registries" {
                        inRegistries = 1
                    } else {
                        inRegistries = 0
                    }
                }
            } else {
                if inRegistries == 1 and line != "" and not line.startsWith("#") {
                    let eqPos = line.indexOf("=", 0)
                    if eqPos > 0 {
                        let key = stripTomlQuotedValue(line.substring(0, eqPos).trim())
                        if key == registryName {
                            return stripTomlQuotedValue(line.substring(eqPos + 1, line.length()).trim())
                        }
                    }
                }
            }
            lineStart = pos + 1
        }
        pos = pos + 1
    }
    return ""
}

fun registryLocationForProject(projectRoot: String, content: String, registryName: String) r: String {
    var location = extractTomlRegistryLocation(content, registryName)
    if location == "" and registryName == "default" {
        location = defaultRegistryLocation()
    }
    if location == "" {
        return ""
    }
    if isHttpRegistryLocation(location) {
        return location
    }
    return resolveProjectPath(projectRoot, location)
}

fun parsePackageDependencyEntry(depName: String, depValue: String) r: PackageDependency {
    let dep = PackageDependency.new()
    dep.name = stripTomlQuotedValue(depName)
    let trimmedValue = depValue.trim()
    if trimmedValue == "" {
        return dep
    }
    if trimmedValue.contains("system = true") or trimmedValue.contains("system=true") {
        dep.source = ""
        return dep
    }
    if trimmedValue.startsWith("{") {
        let depPath = extractTomlInlineQuotedField(trimmedValue, "path")
        let depVersion = extractTomlInlineQuotedField(trimmedValue, "version")
        let depRegistry = extractTomlInlineQuotedField(trimmedValue, "registry")
        if depRegistry != "" {
            dep.registry = depRegistry
        }
        if depPath != "" {
            dep.source = "path"
            dep.path = depPath
            return dep
        }
        if depVersion != "" {
            dep.source = "registry"
            dep.version = depVersion
            return dep
        }
        return dep
    }

    let simpleValue = stripTomlQuotedValue(trimmedValue)
    if simpleValue.startsWith(".") or simpleValue.startsWith("/") {
        dep.source = "path"
        dep.path = simpleValue
        return dep
    }
    if simpleValue.contains("/") and not isHttpRegistryLocation(simpleValue) and not simpleValue.contains("@") {
        dep.source = "path"
        dep.path = simpleValue
        return dep
    }
    dep.source = "registry"
    dep.version = simpleValue
    return dep
}

fun extractTomlPackageDependencies(content: String) r: Array<PackageDependency> {
    let deps = Array<PackageDependency>()
    var inDependencies = 0
    var lineStart = 0
    var pos = 0
    while pos <= content.length() {
        var atEnd = 0
        if pos == content.length() {
            atEnd = 1
        }
        var isNewline = 0
        if atEnd == 0 {
            let b = content.byteAt(pos)
            if b == 10 {
                isNewline = 1
            }
        }
        if isNewline == 1 or atEnd == 1 {
            let line = content.substring(lineStart, pos).trim()
            if line.startsWith("[") {
                if line.endsWith("]") {
                    let section = line.substring(1, line.length() - 1)
                    if section == "dependencies" {
                        inDependencies = 1
                    } else {
                        inDependencies = 0
                    }
                }
            } else {
                if inDependencies == 1 and line != "" and not line.startsWith("#") {
                    let eqPos = line.indexOf("=", 0)
                    if eqPos > 0 {
                        let depName = line.substring(0, eqPos).trim()
                        let depValue = line.substring(eqPos + 1, line.length()).trim()
                        let dep = parsePackageDependencyEntry(depName, depValue)
                        if dep.source != "" {
                            deps.push(dep)
                        }
                    }
                }
            }
            lineStart = pos + 1
        }
        pos = pos + 1
    }
    return deps
}

fun countRegistryPackageDependencies(deps: Array<PackageDependency>) r: Int {
    var count = 0
    var idx = 0
    while idx < deps.length() {
        if deps[idx].source == "registry" {
            count = count + 1
        }
        idx = idx + 1
    }
    return count
}

fun packageInstallRoot(projectRoot: String, depName: String, version: String) r: String {
    return projectRoot + "/.seen/packages/" + depName + "/" + version
}

fun resolveProjectManifestPath(target: String) r: String {
    var resolvedTarget = target
    if resolvedTarget == "" {
        resolvedTarget = currentWorkingDir()
    }
    resolvedTarget = resolveRealInputPath(resolvedTarget)
    if resolvedTarget.endsWith("/Seen.toml") and loadFileContent(resolvedTarget) != "" {
        return resolvedTarget
    }
    if loadFileContent(resolvedTarget + "/Seen.toml") != "" {
        return resolvedTarget + "/Seen.toml"
    }
    if loadFileContent(resolvedTarget) != "" {
        return findNearestSeenTomlForInput(resolvedTarget)
    }
    return findNearestSeenTomlFromDir(resolvedTarget)
}

fun readRegistryIndexContent(registryLocation: String, depName: String) r: String {
    if registryLocation == "" or depName == "" {
        return ""
    }
    if isHttpRegistryLocation(registryLocation) {
        let fetchCmd = "curl -fsSL " + shellQuote(registryLocation + "/index/" + depName + ".toml")
        let result = runCommand(fetchCmd)
        if commandWasSuccessful(result) {
            return result.output
        }
        return ""
    }
    return loadFileContent(registryLocation + "/index/" + depName + ".toml")
}

fun extractRegistryRelease(indexContent: String, requestedVersion: String) r: PackageRelease {
    let release = PackageRelease.new()
    var inRelease = 0
    var currentVersion = ""
    var currentArchive = ""
    var currentSha = ""
    var lineStart = 0
    var pos = 0
    while pos <= indexContent.length() {
        var atEnd = 0
        if pos == indexContent.length() {
            atEnd = 1
        }
        var isNewline = 0
        if atEnd == 0 {
            let b = indexContent.byteAt(pos)
            if b == 10 {
                isNewline = 1
            }
        }
        if isNewline == 1 or atEnd == 1 {
            let line = indexContent.substring(lineStart, pos).trim()
            if line.startsWith("[[") {
                if inRelease == 1 and currentVersion == requestedVersion {
                    release.version = currentVersion
                    release.archive = currentArchive
                    release.sha256 = currentSha
                    return release
                }
                currentVersion = ""
                currentArchive = ""
                currentSha = ""
                if line == "[[releases]]" {
                    inRelease = 1
                } else {
                    inRelease = 0
                }
            } else {
                if inRelease == 1 and line != "" and not line.startsWith("#") {
                    let eqPos = line.indexOf("=", 0)
                    if eqPos > 0 {
                        let key = stripTomlQuotedValue(line.substring(0, eqPos).trim())
                        let value = stripTomlQuotedValue(line.substring(eqPos + 1, line.length()).trim())
                        if key == "version" {
                            currentVersion = value
                        }
                        if key == "archive" {
                            currentArchive = value
                        }
                        if key == "sha256" {
                            currentSha = value
                        }
                    }
                }
            }
            lineStart = pos + 1
        }
        pos = pos + 1
    }
    if inRelease == 1 and currentVersion == requestedVersion {
        release.version = currentVersion
        release.archive = currentArchive
        release.sha256 = currentSha
    }
    return release
}

fun computeFileSha256(path: String) r: String {
    let script = "if command -v sha256sum >/dev/null 2>&1; then sha256sum " + shellQuote(path) + " | cut -d' ' -f1; else shasum -a 256 " + shellQuote(path) + " | cut -d' ' -f1; fi"
    let result = runCommand("sh -c " + shellQuote(script))
    if commandWasSuccessful(result) {
        return result.output.trim()
    }
    return ""
}

fun ensureRegistryPackageInstalled(projectRoot: String, projectTomlContent: String, dep: PackageDependency, quiet: Bool) r: String {
    if dep.version == "" {
        println("Error: dependency `" + dep.name + "` is missing a version")
        return ""
    }
    if dep.version.contains("^") or dep.version.contains("~") or dep.version.contains("*") {
        println("Error: dependency `" + dep.name + "` uses unsupported version requirement `" + dep.version + "`; use an exact version for now")
        return ""
    }

    let installRoot = packageInstallRoot(projectRoot, dep.name, dep.version)
    if loadFileContent(installRoot + "/Seen.toml") != "" {
        return installRoot
    }

    let registryLocation = registryLocationForProject(projectRoot, projectTomlContent, dep.registry)
    if registryLocation == "" {
        println("Error: unknown registry `" + dep.registry + "` for dependency `" + dep.name + "`")
        return ""
    }

    let indexContent = readRegistryIndexContent(registryLocation, dep.name)
    if indexContent == "" {
        println("Error: could not read package index for `" + dep.name + "` from " + registryLocation)
        return ""
    }

    let release = extractRegistryRelease(indexContent, dep.version)
    if release.version == "" or release.archive == "" {
        println("Error: package `" + dep.name + "` version `" + dep.version + "` was not found in " + registryLocation)
        return ""
    }

    let tempDir = projectRoot + "/.seen/tmp"
    if not ensureDirectory(tempDir) {
        println("Error: could not create package temp directory")
        return ""
    }
    let archiveTemp = tempDir + "/" + dep.name + "-" + dep.version + ".seenpkg.tgz"
    removePathIfExists(archiveTemp)

    var fetchOk = false
    if isHttpRegistryLocation(registryLocation) {
        let fetchCmd = "curl -fsSL " + shellQuote(registryLocation + "/" + release.archive) + " -o " + shellQuote(archiveTemp)
        let fetchResult = runCommand(fetchCmd)
        fetchOk = commandWasSuccessful(fetchResult)
    } else {
        let sourceArchive = registryLocation + "/" + release.archive
        let copyResult = runCommand("cp " + shellQuote(sourceArchive) + " " + shellQuote(archiveTemp))
        fetchOk = commandWasSuccessful(copyResult)
    }
    if not fetchOk {
        println("Error: failed to download package archive for `" + dep.name + "` " + dep.version)
        return ""
    }

    if release.sha256 != "" {
        let actualSha = computeFileSha256(archiveTemp)
        if actualSha == "" or actualSha != release.sha256 {
            println("Error: checksum mismatch for package `" + dep.name + "` " + dep.version)
            removePathIfExists(archiveTemp)
            return ""
        }
    }

    removePathIfExists(installRoot)
    if not ensureDirectory(installRoot) {
        println("Error: could not create install directory for `" + dep.name + "`")
        removePathIfExists(archiveTemp)
        return ""
    }
    let extractResult = runCommand("tar -xzf " + shellQuote(archiveTemp) + " -C " + shellQuote(installRoot))
    removePathIfExists(archiveTemp)
    if not commandWasSuccessful(extractResult) {
        println("Error: failed to extract package archive for `" + dep.name + "` " + dep.version)
        removePathIfExists(installRoot)
        return ""
    }
    if not quiet {
        println("  package: fetched " + dep.name + " " + dep.version + " from " + registryLocation)
    }
    return installRoot
}

fun writePackageLockfile(projectRoot: String, deps: Array<PackageDependency>, projectTomlContent: String) r: Void {
    if countRegistryPackageDependencies(deps) == 0 {
        return
    }
    var lockContent = "version = 1\n"
    var idx = 0
    while idx < deps.length() {
        let dep = deps[idx]
        if dep.source == "registry" {
            let installRoot = packageInstallRoot(projectRoot, dep.name, dep.version)
            let relativeInstallRoot = ".seen/packages/" + dep.name + "/" + dep.version
            let pkgToml = loadFileContent(installRoot + "/Seen.toml")
            var actualVersion = dep.version
            if pkgToml != "" {
                let parsedVersion = extractTomlProjectVersion(pkgToml)
                if parsedVersion != "" {
                    actualVersion = parsedVersion
                }
            }
            var archiveSha = ""
            let registryLocation = registryLocationForProject(projectRoot, projectTomlContent, dep.registry)
            let indexContent = readRegistryIndexContent(registryLocation, dep.name)
            if indexContent != "" {
                let release = extractRegistryRelease(indexContent, dep.version)
                archiveSha = release.sha256
            }
            lockContent = lockContent + "\n[[packages]]\n"
            lockContent = lockContent + "name = \"" + dep.name + "\"\n"
            lockContent = lockContent + "version = \"" + actualVersion + "\"\n"
            lockContent = lockContent + "source = \"registry\"\n"
            lockContent = lockContent + "registry = \"" + dep.registry + "\"\n"
            lockContent = lockContent + "path = \"" + relativeInstallRoot + "\"\n"
            if archiveSha != "" {
                lockContent = lockContent + "sha256 = \"" + archiveSha + "\"\n"
            }
        }
        idx = idx + 1
    }
    writeText(projectRoot + "/Seen.lock", lockContent)
}

fun ensureProjectPackageDependenciesForManifest(manifestPath: String, quiet: Bool) r: Bool {
    let tomlContent = loadFileContent(manifestPath)
    if tomlContent == "" {
        return true
    }
    let deps = extractTomlPackageDependencies(tomlContent)
    if deps.length() == 0 {
        return true
    }

    let projectRoot = getSourceDir(manifestPath)
    if countRegistryPackageDependencies(deps) > 0 {
        if not ensureDirectory(projectRoot + "/.seen/packages") {
            println("Error: could not create package cache directory in " + projectRoot)
            return false
        }
    }

    var idx = 0
    while idx < deps.length() {
        let dep = deps[idx]
        if dep.source == "path" {
            let resolvedPath = resolveProjectPath(projectRoot, dep.path)
            if loadFileContent(resolvedPath + "/Seen.toml") == "" {
                println("Error: dependency `" + dep.name + "` path `" + resolvedPath + "` does not contain a Seen.toml package manifest")
                return false
            }
        } else if dep.source == "registry" {
            let installedRoot = ensureRegistryPackageInstalled(projectRoot, tomlContent, dep, quiet)
            if installedRoot == "" {
                return false
            }
        }
        idx = idx + 1
    }

    writePackageLockfile(projectRoot, deps, tomlContent)
    return true
}

fun ensureProjectPackageDependenciesForInput(inputFile: String, quiet: Bool) r: Bool {
    let manifestPath = findNearestSeenTomlForInput(inputFile)
    if manifestPath == "" {
        return true
    }
    return ensureProjectPackageDependenciesForManifest(manifestPath, quiet)
}

fun resolvePackageDependencyProjectRoot(sourceDir: String, depName: String) r: String {
    let tomlPath = findNearestSeenTomlFromDir(sourceDir)
    let tomlContent = loadFileContent(tomlPath)
    if tomlContent == "" {
        return ""
    }
    let deps = extractTomlPackageDependencies(tomlContent)
    let projectRoot = getSourceDir(tomlPath)
    var idx = 0
    while idx < deps.length() {
        let dep = deps[idx]
        if dep.name == depName {
            if dep.source == "path" {
                let resolvedPath = resolveProjectPath(projectRoot, dep.path)
                if loadFileContent(resolvedPath + "/Seen.toml") != "" {
                    return resolvedPath
                }
                return ""
            }
            if dep.source == "registry" {
                return ensureRegistryPackageInstalled(projectRoot, tomlContent, dep, true)
            }
        }
        idx = idx + 1
    }
    return ""
}

fun resolvePackageImportPath(importPath: Array<String>, sourceDir: String) r: String {
    if importPath.length() == 0 {
        return ""
    }
    let packageRoot = resolvePackageDependencyProjectRoot(sourceDir, importPath[0])
    if packageRoot == "" {
        return ""
    }
    var packageBase = packageRoot + "/src"
    var idx = 1
    if importPath.length() > 1 {
        if importPath[1] == "src" {
            idx = 2
        }
    }
    while idx < importPath.length() {
        packageBase = packageBase + "/" + importPath[idx]
        idx = idx + 1
    }
    let modPath = packageBase + "/mod.seen"
    let directPath = packageBase + ".seen"
    if loadFileContent(modPath) != "" {
        return modPath
    }
    if loadFileContent(directPath) != "" {
        return directPath
    }
    return directPath
}

fun createPackageArchive(manifestPath: String, outputPath: String) r: Bool {
    let projectRoot = getSourceDir(manifestPath)
    let outputDir = getSourceDir(outputPath)
    if outputDir != "" and not ensureDirectory(outputDir) {
        return false
    }
    let tempArchive = "/tmp/" + hashString(projectRoot + "|" + outputPath) + ".seenpkg.tgz"
    removePathIfExists(tempArchive)
    let packCmd = "cd " + shellQuote(projectRoot) + " && tar -czf " + shellQuote(tempArchive) + " --exclude=.git --exclude=.seen --exclude=.seen_cache --exclude=target ."
    let result = runCommand(packCmd)
    if not commandWasSuccessful(result) {
        removePathIfExists(tempArchive)
        return false
    }
    let moveResult = runCommand("mv " + shellQuote(tempArchive) + " " + shellQuote(outputPath))
    if not commandWasSuccessful(moveResult) {
        removePathIfExists(tempArchive)
        return false
    }
    return true
}

fun packageArchiveFileName(projectName: String, version: String) r: String {
    return projectName + "-" + version + ".seenpkg.tgz"
}

fun printPkgUsage() r: Void {
    println("Usage: seen pkg fetch [project-dir-or-manifest]")
    println("       seen pkg pack [project-dir-or-manifest] [output]")
    println("       seen pkg publish <registry-dir> [project-dir-or-manifest]")
    println("")
    println("Registry packages currently use exact versions and source archives.")
    println("Published registry roots are static directories with index/*.toml and archives/*.")
    return
}

fun pkgCommand(argv: Array<String>) r: Int {
    if argv.length() < 3 {
        printPkgUsage()
        return 1
    }
    let subcommand = argv[2]

    if subcommand == "fetch" {
        var manifestPath = resolveProjectManifestPath("")
        if argv.length() >= 4 {
            manifestPath = resolveProjectManifestPath(argv[3])
        }
        if manifestPath == "" {
            println("Error: could not find Seen.toml for pkg fetch")
            return 1
        }
        if ensureProjectPackageDependenciesForManifest(manifestPath, false) {
            println("Package dependencies are ready")
            return 0
        }
        return 1
    }

    if subcommand == "pack" {
        var manifestPath = resolveProjectManifestPath("")
        var outputPath = ""
        if argv.length() >= 4 {
            manifestPath = resolveProjectManifestPath(argv[3])
        }
        if manifestPath == "" {
            println("Error: could not find Seen.toml for pkg pack")
            return 1
        }
        let tomlContent = loadFileContent(manifestPath)
        let projectName = extractTomlProjectName(tomlContent)
        let version = extractTomlProjectVersion(tomlContent)
        if projectName == "" or version == "" {
            println("Error: package project must define [project].name and [project].version")
            return 1
        }
        if argv.length() >= 5 {
            outputPath = resolveProjectPath(currentWorkingDir(), argv[4])
        } else {
            outputPath = getSourceDir(manifestPath) + "/" + packageArchiveFileName(projectName, version)
        }
        if not createPackageArchive(manifestPath, outputPath) {
            println("Error: failed to create package archive")
            return 1
        }
        println("Package archive created: " + outputPath)
        return 0
    }

    if subcommand == "publish" {
        if argv.length() < 4 {
            println("Error: pkg publish requires a registry directory")
            printPkgUsage()
            return 1
        }
        let registryRoot = resolveProjectPath(currentWorkingDir(), argv[3])
        if isHttpRegistryLocation(registryRoot) {
            println("Error: pkg publish currently supports local registry directories only")
            return 1
        }
        var manifestPath = resolveProjectManifestPath("")
        if argv.length() >= 5 {
            manifestPath = resolveProjectManifestPath(argv[4])
        }
        if manifestPath == "" {
            println("Error: could not find Seen.toml for pkg publish")
            return 1
        }
        let tomlContent = loadFileContent(manifestPath)
        let projectName = extractTomlProjectName(tomlContent)
        let version = extractTomlProjectVersion(tomlContent)
        if projectName == "" or version == "" {
            println("Error: package project must define [project].name and [project].version")
            return 1
        }
        let indexDir = registryRoot + "/index"
        let archiveDir = registryRoot + "/archives/" + projectName
        if not ensureDirectory(indexDir) or not ensureDirectory(archiveDir) {
            println("Error: failed to create registry directories under " + registryRoot)
            return 1
        }
        let indexPath = indexDir + "/" + projectName + ".toml"
        let existingIndex = loadFileContent(indexPath)
        if existingIndex != "" {
            let existingRelease = extractRegistryRelease(existingIndex, version)
            if existingRelease.version != "" {
                println("Error: package `" + projectName + "` version `" + version + "` is already published")
                return 1
            }
        }

        let archiveName = packageArchiveFileName(projectName, version)
        let archivePath = archiveDir + "/" + archiveName
        if not createPackageArchive(manifestPath, archivePath) {
            println("Error: failed to create publish archive")
            return 1
        }
        let archiveSha = computeFileSha256(archivePath)
        if archiveSha == "" {
            println("Error: failed to compute archive sha256")
            return 1
        }

        var newIndex = existingIndex
        if newIndex == "" {
            newIndex = "version = 1\n"
        }
        if not newIndex.endsWith("\n") {
            newIndex = newIndex + "\n"
        }
        newIndex = newIndex + "\n[[releases]]\n"
        newIndex = newIndex + "version = \"" + version + "\"\n"
        newIndex = newIndex + "archive = \"archives/" + projectName + "/" + archiveName + "\"\n"
        newIndex = newIndex + "sha256 = \"" + archiveSha + "\"\n"
        writeText(indexPath, newIndex)
        println("Published " + projectName + " " + version + " to " + registryRoot)
        println("Index:   " + indexPath)
        println("Archive: " + archivePath)
        return 0
    }

    printPkgUsage()
    return 1
}

fun extractTomlInlineQuotedField(value: String, fieldName: String) r: String {
    var fieldPos = value.indexOf(fieldName + " =", 0)
    if fieldPos < 0 {
        fieldPos = value.indexOf(fieldName + "=", 0)
    }
    if fieldPos < 0 {
        return ""
    }
    var pos = fieldPos + fieldName.length()
    while pos < value.length() {
        if value.byteAt(pos) == 34 {
            let start = pos + 1
            var end = start
            while end < value.length() {
                if value.byteAt(end) == 34 {
                    return value.substring(start, end)
                }
                end = end + 1
            }
            return ""
        }
        pos = pos + 1
    }
    return ""
}

fun extractTomlProjectName(content: String) r: String {
    var inProject = 0
    var lineStart = 0
    var pos = 0
    while pos <= content.length() {
        var atEnd = 0
        if pos == content.length() {
            atEnd = 1
        }
        var isNewline = 0
        if atEnd == 0 {
            let b = content.byteAt(pos)
            if b == 10 {
                isNewline = 1
            }
        }
        if isNewline == 1 or atEnd == 1 {
            let line = content.substring(lineStart, pos).trim()
            if line.startsWith("[") {
                if line.endsWith("]") {
                    let section = line.substring(1, line.length() - 1)
                    if section == "project" {
                        inProject = 1
                    } else {
                        inProject = 0
                    }
                }
            } else {
                if inProject == 1 {
                    if line != "" and not line.startsWith("#") {
                        let eqPos = line.indexOf("=", 0)
                        if eqPos > 0 {
                            let key = line.substring(0, eqPos).trim()
                            if key == "name" {
                                let value = line.substring(eqPos + 1, line.length()).trim()
                                return stripTomlQuotedValue(value)
                            }
                        }
                    }
                }
            }
            lineStart = pos + 1
        }
        pos = pos + 1
    }
    return ""
}

fun extractTomlBuildEntry(content: String) r: String {
    var inBuild = 0
    var lineStart = 0
    var pos = 0
    while pos <= content.length() {
        var atEnd = 0
        if pos == content.length() {
            atEnd = 1
        }
        var isNewline = 0
        if atEnd == 0 {
            let b = content.byteAt(pos)
            if b == 10 {
                isNewline = 1
            }
        }
        if isNewline == 1 or atEnd == 1 {
            let line = content.substring(lineStart, pos).trim()
            if line.startsWith("[") {
                if line.endsWith("]") {
                    let section = line.substring(1, line.length() - 1)
                    if section == "build" {
                        inBuild = 1
                    } else {
                        inBuild = 0
                    }
                }
            } else {
                if inBuild == 1 {
                    if line != "" and not line.startsWith("#") {
                        let eqPos = line.indexOf("=", 0)
                        if eqPos > 0 {
                            let key = line.substring(0, eqPos).trim()
                            if key == "entry" {
                                let value = line.substring(eqPos + 1, line.length()).trim()
                                return stripTomlQuotedValue(value)
                            }
                        }
                    }
                }
            }
            lineStart = pos + 1
        }
        pos = pos + 1
    }
    return ""
}

fun isStdlibImportRoot(segment: String) r: Bool {
    if segment == "async" { return true }
    if segment == "audio" { return true }
    if segment == "collections" { return true }
    if segment == "core" { return true }
    if segment == "crypto" { return true }
    if segment == "env" { return true }
    if segment == "ffi" { return true }
    if segment == "framework" { return true }
    if segment == "fs" { return true }
    if segment == "graphics" { return true }
    if segment == "hash" { return true }
    if segment == "input" { return true }
    if segment == "io" { return true }
    if segment == "json" { return true }
    if segment == "math" { return true }
    if segment == "memory" { return true }
    if segment == "net" { return true }
    if segment == "platform" { return true }
    if segment == "process" { return true }
    if segment == "random" { return true }
    if segment == "scripting" { return true }
    if segment == "security" { return true }
    if segment == "simd" { return true }
    if segment == "str" { return true }
    if segment == "sync" { return true }
    if segment == "thread" { return true }
    if segment == "time" { return true }
    if segment == "uww" { return true }
    return false
}

fun isCompilerImportRoot(segment: String) r: Bool {
    if segment == "lexer" { return true }
    if segment == "parser" { return true }
    if segment == "typechecker" { return true }
    if segment == "macro" { return true }
    if segment == "bootstrap" { return true }
    if segment == "codegen" { return true }
    if segment == "lsp" { return true }
    if segment == "tools" { return true }
    if segment == "optimization" { return true }
    if segment == "trace" { return true }
    if segment == "ir" { return true }
    if segment == "types" { return true }
    if segment == "testing" { return true }
    if segment == "ffi" { return true }
    return false
}

fun firstModuleSegment(modulePath: String) r: String {
    var i = 0
    while i < modulePath.length() {
        if modulePath.byteAt(i) == 46 {
            return modulePath.substring(0, i)
        }
        i = i + 1
    }
    return modulePath
}

// Resolve module path to actual file path
fun resolveModulePath(modulePath: String) r: String {
    // Determine base path: stdlib modules go to seen_std/src/, compiler modules to compiler_seen/src/
    let root = getCompilerRoot()
    var basePath = "compiler_seen/src/"
    if isStdlibImportRoot(firstModuleSegment(modulePath)) {
        basePath = "seen_std/src/"
    }
    if root != "" {
        basePath = root + "/" + basePath
    }

    var filePath = basePath
    var i = 0
    while i < modulePath.length() {
        if modulePath.byteAt(i) == 46 {
            filePath = filePath + "/"
        } else {
            filePath = filePath + modulePath.substring(i, i + 1)
        }
        i = i + 1
    }
    return filePath + ".seen"
}

fun compilerSourceBasePath() r: String {
    var basePath = "compiler_seen/src/"
    let root = getCompilerRoot()
    if root != "" {
        basePath = root + "/compiler_seen/src/"
    }
    return basePath
}

fun isCompilerSourceDir(sourceDir: String) r: Bool {
    if sourceDir.startsWith("compiler_seen/") { return true }
    if sourceDir.contains("/compiler_seen/") { return true }
    return false
}

fun isStdlibSourceDir(sourceDir: String) r: Bool {
    if sourceDir.startsWith("seen_std/") { return true }
    if sourceDir.contains("/seen_std/") { return true }
    return false
}

fun tryCompilerShortImportPath(moduleName: String, sourceDir: String) r: String {
    if not isCompilerSourceDir(sourceDir) {
        return ""
    }
    let basePath = compilerSourceBasePath()
    let rootPath = basePath + moduleName + ".seen"
    if readText(rootPath) != "" {
        return rootPath
    }
    let bootstrapPath = basePath + "bootstrap/" + moduleName + ".seen"
    if readText(bootstrapPath) != "" {
        return bootstrapPath
    }
    let toolsPath = basePath + "tools/" + moduleName + ".seen"
    if readText(toolsPath) != "" {
        return toolsPath
    }
    let parserPath = basePath + "parser/" + moduleName + ".seen"
    if readText(parserPath) != "" {
        return parserPath
    }
    let lexerPath = basePath + "lexer/" + moduleName + ".seen"
    if readText(lexerPath) != "" {
        return lexerPath
    }
    let typecheckerPath = basePath + "typechecker/" + moduleName + ".seen"
    if readText(typecheckerPath) != "" {
        return typecheckerPath
    }
    let macroPath = basePath + "macro/" + moduleName + ".seen"
    if readText(macroPath) != "" {
        return macroPath
    }
    let codegenPath = basePath + "codegen/" + moduleName + ".seen"
    if readText(codegenPath) != "" {
        return codegenPath
    }
    let lspPath = basePath + "lsp/" + moduleName + ".seen"
    if readText(lspPath) != "" {
        return lspPath
    }
    let optimizationPath = basePath + "optimization/" + moduleName + ".seen"
    if readText(optimizationPath) != "" {
        return optimizationPath
    }
    return ""
}

fun tryStdlibShortImportPath(moduleName: String, sourceDir: String) r: String {
    if not isCompilerSourceDir(sourceDir) and not isStdlibSourceDir(sourceDir) {
        return ""
    }
    var basePath = "seen_std/src/"
    let root = getCompilerRoot()
    if root != "" {
        basePath = root + "/seen_std/src/"
    }
    let ioPath = basePath + "io/" + moduleName + ".seen"
    if readText(ioPath) != "" {
        return ioPath
    }
    let processPath = basePath + "process/" + moduleName + ".seen"
    if readText(processPath) != "" {
        return processPath
    }
    let envPath = basePath + "env/" + moduleName + ".seen"
    if readText(envPath) != "" {
        return envPath
    }
    let strPath = basePath + "str/" + moduleName + ".seen"
    if readText(strPath) != "" {
        return strPath
    }
    let corePath = basePath + "core/" + moduleName + ".seen"
    if readText(corePath) != "" {
        return corePath
    }
    return ""
}

// Extract last segment from a path (e.g., "foo/bar/baz" -> "baz")
fun getLastSegment(path: String) r: String {
    var lastSlash = 0 - 1
    var i = 0
    while i < path.length() {
        if path.byteAt(i) == 47 {
            lastSlash = i
        }
        i = i + 1
    }
    if lastSlash < 0 {
        return path
    }
    return path.substring(lastSlash + 1, path.length())
}

///
Compute compiler installation root from the binary's absolute path.
Uses /proc/self/exe (Linux) to get the real path regardless of how the
binary was invoked (PATH lookup, symlink, relative path, etc.).
Binary is at <root>/compiler_seen/target/seen, so root = 3 levels up.
Falls back to args()[0] if /proc/self/exe is unavailable (e.g. macOS).
///
fun getCompilerRoot() r: String {
    // Try /proc/$PPID/exe — $PPID is the compiler process (parent of the shell spawned by runCommand)
    let exeResult = runCommand("readlink -f /proc/$PPID/exe")
    if commandWasSuccessful(exeResult) {
        var exePath = exeResult.output
        // Trim trailing newline
        if exePath.length() > 0 {
            if exePath.byteAt(exePath.length() - 1) == 10 {
                exePath = exePath.substring(0, exePath.length() - 1)
            }
        }
        // Binary is at <root>/compiler_seen/target/seen — strip 3 levels
        let binDir = getSourceDir(exePath)
        if binDir != "" {
            let targetDir = getSourceDir(binDir)
            if targetDir != "" {
                let compilerDir = getSourceDir(targetDir)
                if compilerDir != "" {
                    // Validate: the computed root must contain seen_runtime/
                    let validateResult: CommandResult = runCommand("test -d " + compilerDir + "/seen_runtime")
                    if commandWasSuccessful(validateResult) {
                        return compilerDir
                    }
                }
            }
        }
    }
    // Fallback: try args()[0] (macOS, or non-standard setups)
    let allArgs = args()
    if allArgs.length() == 0 { return "" }
    let binPath = allArgs[0]
    let binDir2 = getSourceDir(binPath)
    if binDir2 == "" { return "" }
    let targetDir2 = getSourceDir(binDir2)
    if targetDir2 == "" { return "" }
    let root2 = getSourceDir(targetDir2)
    // Validate the fallback root too
    let validateResult2: CommandResult = runCommand("test -d " + root2 + "/seen_runtime")
    if commandWasSuccessful(validateResult2) {
        return root2
    }
    return ""
}

///
Resolve an import path (e.g., ["codegen", "llvm_ir_gen"]) to a filesystem path.
Stdlib imports (str, io, env, process, etc.) resolve under seen_std/src/.
Compiler imports resolve relative to sourceDir, with deduplication: if the first
path segment matches the last directory segment, it is skipped to avoid paths
like "lexer/lexer/token.seen". Tries module-style (foo/mod.seen) before direct
(foo.seen).
///
fun tryExistingRelativeImportPath(importPath: Array<String>, sourceDir: String) r: String {
    var filePath = sourceDir
    if filePath != "" and not filePath.endsWith("/") {
        filePath = filePath + "/"
    }

    var startIdx = 0
    if importPath.length() > 1 {
        let lastDirSegment = getLastSegment(sourceDir)
        var shouldTrySkip = 0
        if lastDirSegment == importPath[0] {
            shouldTrySkip = 1
        } else {
            let tomlPath = findNearestSeenTomlFromDir(sourceDir)
            let tomlContent = loadFileContent(tomlPath)
            if tomlContent != "" {
                let projectName = extractTomlProjectName(tomlContent)
                if projectName == importPath[0] {
                    shouldTrySkip = 1
                }
            }
        }
        if shouldTrySkip == 1 {
            var testSkip = filePath
            var ti = 1
            while ti < importPath.length() {
                if ti > 1 { testSkip = testSkip + "/" }
                testSkip = testSkip + importPath[ti]
                ti = ti + 1
            }
            if readText(testSkip + ".seen") != "" {
                startIdx = 1
            } else {
                if readText(testSkip + "/mod.seen") != "" {
                    startIdx = 1
                }
            }
        }
    }

    var i = startIdx
    while i < importPath.length() {
        if i > startIdx {
            filePath = filePath + "/"
        }
        filePath = filePath + importPath[i]
        i = i + 1
    }

    let modPath = filePath + "/mod.seen"
    if readText(modPath) != "" {
        return modPath
    }
    let directPath = filePath + ".seen"
    if readText(directPath) != "" {
        return directPath
    }
    return ""
}

fun resolveImportPath(importPath: Array<String>, sourceDir: String) r: String {
    // Convert import path segments to file path

    // Check for compiler-root and stdlib imports first.
    if importPath.length() > 0 {
        let firstSegment = importPath[0]
        if isCompilerImportRoot(firstSegment) {
            var compilerBase = "compiler_seen/src/"
            let compRoot = getCompilerRoot()
            if compRoot != "" {
                compilerBase = compRoot + "/compiler_seen/src/"
            }
            var ci = 0
            while ci < importPath.length() {
                if ci > 0 {
                    compilerBase = compilerBase + "/"
                }
                compilerBase = compilerBase + importPath[ci]
                ci = ci + 1
            }
            let compilerModPath = compilerBase + "/mod.seen"
            let compilerDirectPath = compilerBase + ".seen"
            let compilerModContent = readText(compilerModPath)
            if compilerModContent != "" {
                return compilerModPath
            }
            let compilerDirectContent = readText(compilerDirectPath)
            if compilerDirectContent != "" {
                return compilerDirectPath
            }
        }

        let packageImportPath = resolvePackageImportPath(importPath, sourceDir)
        if packageImportPath != "" {
            return packageImportPath
        }
        let localImportPath = tryExistingRelativeImportPath(importPath, sourceDir)
        if localImportPath != "" {
            return localImportPath
        }

        if isStdlibImportRoot(firstSegment) {
            // This is a stdlib import — resolve from compiler root
            var stdlibBase = "seen_std/src/"
            let compRoot = getCompilerRoot()
            if compRoot != "" {
                stdlibBase = compRoot + "/seen_std/src/"
            }
            var i = 0
            while i < importPath.length() {
                if i > 0 {
                    stdlibBase = stdlibBase + "/"
                }
                stdlibBase = stdlibBase + importPath[i]
                i = i + 1
            }
            let stdlibModPath = stdlibBase + "/mod.seen"
            let stdlibDirectPath = stdlibBase + ".seen"
            let stdlibModContent = readText(stdlibModPath)
            if stdlibModContent != "" {
                return stdlibModPath
            }
            let stdlibDirectContent = readText(stdlibDirectPath)
            if stdlibDirectContent != "" {
                return stdlibDirectPath
            }
        }
    }

    ///
    Handle module-style imports: if first segment matches last segment of sourceDir,
    skip it to avoid duplication (e.g., in lexer/, "lexer.interfaces" -> "interfaces.seen")
    ///
    var filePath = sourceDir
    if filePath != "" and not filePath.endsWith("/") {
        filePath = filePath + "/"
    }

    ///
    Check if first import segment duplicates the source layout or the project
    package prefix. Only skip if the resulting file actually exists.
    ///
    var startIdx = 0
    if importPath.length() > 1 {
        let lastDirSegment = getLastSegment(sourceDir)
        var shouldTrySkip = 0
        if lastDirSegment == importPath[0] {
            shouldTrySkip = 1
        } else {
            let tomlPath = findNearestSeenTomlFromDir(sourceDir)
            let tomlContent = loadFileContent(tomlPath)
            if tomlContent != "" {
                let projectName = extractTomlProjectName(tomlContent)
                if projectName == importPath[0] {
                    shouldTrySkip = 1
                }
            }
        }
        if shouldTrySkip == 1 {
            // Build path with first segment skipped to check existence
            var testSkip = filePath
            var ti = 1
            while ti < importPath.length() {
                if ti > 1 { testSkip = testSkip + "/" }
                testSkip = testSkip + importPath[ti]
                ti = ti + 1
            }
            // Only skip if skipped path exists (.seen or mod.seen)
            let skipDirect = readText(testSkip + ".seen")
            if skipDirect != "" {
                startIdx = 1
            } else {
                let skipMod = readText(testSkip + "/mod.seen")
                if skipMod != "" {
                    startIdx = 1
                }
            }
        }
    }

    var i = startIdx
    while i < importPath.length() {
        if i > startIdx {
            filePath = filePath + "/"
        }
        filePath = filePath + importPath[i]
        i = i + 1
    }

    // Try module file first (foo/mod.seen), then direct file (foo.seen)
    let modPath = filePath + "/mod.seen"
    let directPath = filePath + ".seen"

    // Check if module file exists by trying to read it
    let modContent = readText(modPath)
    if modContent != "" {
        return modPath
    }
    let directContent = readText(directPath)
    if directContent != "" {
        return directPath
    }
    if importPath.length() > 0 {
        let shortImportName = importPath[importPath.length() - 1]
        let compilerShortPath = tryCompilerShortImportPath(shortImportName, sourceDir)
        if compilerShortPath != "" {
            return compilerShortPath
        }
        let stdlibShortPath = tryStdlibShortImportPath(shortImportName, sourceDir)
        if stdlibShortPath != "" {
            return stdlibShortPath
        }
    }
    return directPath
}

// Get directory part of file path. Uses byteAt() (47 = '/')
fun getSourceDir(filePath: String) r: String {
    var lastSlash = 0 - 1
    var i = 0
    while i < filePath.length() {
        if filePath.byteAt(i) == 47 {
            lastSlash = i
        }
        i = i + 1
    }
    if lastSlash < 0 {
        return ""
    }
    return filePath.substring(0, lastSlash)
}

fun isAbsolutePath(path: String) r: Bool {
    if path.length() == 0 {
        return false
    }
    return path.byteAt(0) == 47
}

fun resolveRealInputPath(path: String) r: String {
    if path == "" {
        return ""
    }
    var resolved = path
    if not isAbsolutePath(resolved) {
        let pwdResult = runCommand("pwd")
        if commandWasSuccessful(pwdResult) {
            var cwd = pwdResult.output
            if cwd.length() > 0 {
                if cwd.byteAt(cwd.length() - 1) == 10 {
                    cwd = cwd.substring(0, cwd.length() - 1)
                }
            }
            resolved = cwd + "/" + resolved
        }
    }
    let realpathResult = runCommand("readlink -f \"" + resolved + "\"")
    if commandWasSuccessful(realpathResult) {
        var realpath = realpathResult.output
        if realpath.length() > 0 {
            if realpath.byteAt(realpath.length() - 1) == 10 {
                realpath = realpath.substring(0, realpath.length() - 1)
            }
        }
        if realpath != "" {
            return realpath
        }
    }
    return resolved
}

fun findNearestSeenTomlFromDir(initialDir: String) r: String {
    var searchDir = initialDir
    var searching = 1
    while searching == 1 {
        var candidate = "Seen.toml"
        if searchDir == "/" {
            candidate = "/Seen.toml"
        } else {
            if searchDir != "" {
                candidate = searchDir + "/Seen.toml"
            }
        }
        if loadFileContent(candidate) != "" {
            return candidate
        }
        if searchDir == "" or searchDir == "/" {
            searching = 0
        } else {
            let parentDir = getSourceDir(searchDir)
            if parentDir == searchDir {
                searching = 0
            } else {
                if parentDir == "" {
                    if isAbsolutePath(searchDir) {
                        searchDir = "/"
                    } else {
                        searchDir = ""
                    }
                } else {
                    searchDir = parentDir
                }
            }
        }
    }
    return ""
}

fun findNearestSeenTomlForInput(inputFile: String) r: String {
    return findNearestSeenTomlFromDir(getSourceDir(inputFile))
}

fun readNearestSeenTomlForInput(inputFile: String) r: String {
    let tomlPath = findNearestSeenTomlForInput(inputFile)
    if tomlPath == "" {
        return ""
    }
    return readText(tomlPath)
}

fun resolveProjectPath(projectRoot: String, path: String) r: String {
    if path == "" {
        return ""
    }
    if isAbsolutePath(path) {
        return path
    }
    if projectRoot == "" {
        return path
    }
    if projectRoot == "/" {
        return "/" + path
    }
    return projectRoot + "/" + path
}

fun buildLocalLibrarySearchFlags(resolvedPath: String, effectiveTarget: String, normalizedCrossTarget: String) r: String {
    if resolvedPath == "" {
        return ""
    }
    var flags = " -L" + resolvedPath
    if normalizedCrossTarget == "" {
        if effectiveTarget == "linux-x86_64" or effectiveTarget == "linux-arm64" or effectiveTarget == "macos-x86_64" or effectiveTarget == "macos-arm64" {
            flags = flags + " -Wl,-rpath," + resolvedPath
        }
    }
    return flags
}

fun inputBelongsToProject(projectRoot: String, inputFile: String, projectModules: Array<String>, buildEntry: String) r: Bool {
    if buildEntry != "" {
        let resolvedBuildEntry = resolveProjectPath(projectRoot, buildEntry)
        if resolvedBuildEntry == inputFile {
            return true
        }
    }
    var projectModuleIdx = 0
    while projectModuleIdx < projectModules.length() {
        let projectModulePath = resolveProjectPath(projectRoot, projectModules[projectModuleIdx])
        if projectModulePath == inputFile {
            return true
        }
        projectModuleIdx = projectModuleIdx + 1
    }
    return false
}

// Check if a path is in the array (handles absolute vs relative paths)
fun containsPath(paths: Array<String>, path: String) r: Bool {
    var i = 0
    while i < paths.length() {
        let existing = paths[i]
        // Direct match
        if existing == path {
            return true
        }
        // Handle absolute vs relative: check if one ends with the other
        if existing.endsWith(path) or path.endsWith(existing) {
            return true
        }
        i = i + 1
    }
    return false
}

fun pushUniquePath(paths: Array<String>, processedPaths: Array<String>, path: String) r: Void {
    if path != "" {
        let normalizedPath = resolveRealInputPath(path)
        if not containsPath(processedPaths, normalizedPath) {
            paths.push(normalizedPath)
            processedPaths.push(normalizedPath)
        }
    }
    return
}

fun stripSeenExtension(fileName: String) r: String {
    if fileName.endsWith(".seen") {
        return fileName.substring(0, fileName.length() - 5)
    }
    return fileName
}

fun pathRelativeToProjectRoot(path: String, projectRoot: String) r: String {
    if path == "" or projectRoot == "" {
        return path
    }
    let rootPrefix = projectRoot + "/"
    if path.startsWith(rootPrefix) {
        return path.substring(rootPrefix.length(), path.length())
    }
    return path
}

fun cachedManifestProjectModules(tomlPath: String, tomlContent: String)
    r: Array<String> {

    if g_manifestCompanionCacheTomlPath != tomlPath {
        g_manifestCompanionCacheTomlPath = tomlPath
        g_manifestCompanionCacheProjectRoot = getSourceDir(tomlPath)
        g_manifestCompanionCacheModules = extractTomlProjectModules(tomlContent)
    }
    return g_manifestCompanionCacheModules
}

fun appendManifestCompanionModulesForPath(paths: Array<String>,
    processedPaths: Array<String>, currentPath: String) r: Void {

    let normalizedCurrent = resolveRealInputPath(currentPath)
    let sourceDir = getSourceDir(normalizedCurrent)
    if sourceDir == "" {
        return
    }

    let fileName = getLastSegment(normalizedCurrent)
    let stem = stripSeenExtension(fileName)
    if stem == "" {
        return
    }

    let tomlPath = findNearestSeenTomlFromDir(sourceDir)
    let tomlContent = loadFileContent(tomlPath)
    if tomlContent == "" {
        return
    }

    let projectRoot = getSourceDir(tomlPath)
    let projectRootReal = resolveRealInputPath(projectRoot)
    let projectModules = cachedManifestProjectModules(tomlPath, tomlContent)
    let companionPrefix = stem + "_"
    let currentRel = pathRelativeToProjectRoot(normalizedCurrent,
        projectRootReal)
    var currentModuleIndex = 0 - 1
    var moduleIdx = 0
    while moduleIdx < projectModules.length() {
        if projectModules[moduleIdx] == currentRel {
            currentModuleIndex = moduleIdx
        }
        moduleIdx = moduleIdx + 1
    }

    moduleIdx = 0
    while moduleIdx < projectModules.length() {
        let moduleRel = projectModules[moduleIdx]
        if moduleRel != currentRel {
            let candidateDir = resolveProjectPath(projectRootReal,
                getSourceDir(moduleRel))
            if candidateDir == sourceDir {
                let candidateFile = getLastSegment(moduleRel)
                var shouldAddCandidate = false
                if candidateFile.startsWith(companionPrefix) and
                    candidateFile.endsWith(".seen") {
                    shouldAddCandidate = true
                }
                if currentModuleIndex >= 0 and moduleIdx < currentModuleIndex {
                    if candidateFile == "behavior.seen" or
                        candidateFile.endsWith("_constants.seen") or
                        candidateFile.endsWith("_conversion_support.seen") or
                        candidateFile.endsWith("_enum.seen") or
                        candidateFile.endsWith("_type.seen") or
                        candidateFile.endsWith("_hash_map.seen") {
                        shouldAddCandidate = true
                    }
                }
                if shouldAddCandidate {
                    let candidatePath = resolveProjectPath(projectRootReal,
                        moduleRel)
                    pushUniquePath(paths, processedPaths, candidatePath)
                }
            }
        }
        moduleIdx = moduleIdx + 1
    }
    return
}

fun isCompilerRuntimeBackedStdlibPath(importFilePath: String) r: Bool {
    return importFilePath == "seen_std/src/str/string.seen" or importFilePath == "seen_std/src/core/option.seen" or importFilePath == "seen_std/src/core/result.seen" or importFilePath == "seen_std/src/collections/map.seen" or importFilePath.endsWith("/seen_std/src/str/string.seen") or importFilePath.endsWith("/seen_std/src/core/option.seen") or importFilePath.endsWith("/seen_std/src/core/result.seen") or importFilePath.endsWith("/seen_std/src/collections/map.seen")
}

fun shouldQueueDiscoveredImport(inputFile: String, currentPath: String, isBootstrap: Bool, importFilePath: String) r: Bool {
    let skipCompilerStdlib = not isBootstrap and currentPath != inputFile and inputFile.contains("/compiler_seen/") and isCompilerRuntimeBackedStdlibPath(importFilePath)
    var shouldQueueImport = not skipCompilerStdlib
    if isBootstrap {
        shouldQueueImport = shouldQueueImport and exists(importFilePath)
    }
    return shouldQueueImport
}

fun appendCompilerInternalSupportModules(paths: Array<String>, processedPaths: Array<String>) r: Void {
    let modules = Array<String>()
    modules.push("lexer.token")
    modules.push("lexer.token_type")
    modules.push("lexer.interfaces")
    modules.push("lexer.keyword_manager")
    modules.push("lexer.lexer")
    modules.push("trace")
    modules.push("io.file")
    modules.push("process.process")
    modules.push("env.env")

    var mi = 0
    while mi < modules.length() {
        pushUniquePath(paths, processedPaths, resolveModulePath(modules[mi]))
        mi = mi + 1
    }
    return
}

fun extractQuotedTomlStrings(line: String) r: Array<String> {
    let values = Array<String>()
    var pos = 0
    while pos < line.length() {
        if line.byteAt(pos) == 34 {
            let start = pos + 1
            var end = start
            while end < line.length() {
                if line.byteAt(end) == 34 {
                    values.push(line.substring(start, end))
                    pos = end + 1
                    break
                }
                end = end + 1
            }
            if end >= line.length() {
                pos = line.length()
            }
        } else {
            pos = pos + 1
        }
    }
    return values
}

fun extractTomlProjectModules(content: String) r: Array<String> {
    let modules = Array<String>()
    var inProject = 0
    var collectingModules = 0
    var lineStart = 0
    var pos = 0
    while pos <= content.length() {
        var atEnd = 0
        if pos == content.length() {
            atEnd = 1
        }
        var isNewline = 0
        if atEnd == 0 {
            let b = content.byteAt(pos)
            if b == 10 {
                isNewline = 1
            }
        }
        if isNewline == 1 or atEnd == 1 {
            let line = content.substring(lineStart, pos).trim()
            if line.startsWith("[") {
                if line.endsWith("]") {
                    let section = line.substring(1, line.length() - 1)
                    if section == "project" {
                        inProject = 1
                    } else {
                        inProject = 0
                    }
                    collectingModules = 0
                }
            } else {
                if inProject == 1 {
                    if line != "" and not line.startsWith("#") {
                        if collectingModules == 1 {
                            let lineModules = extractQuotedTomlStrings(line)
                            var lineModuleIdx = 0
                            while lineModuleIdx < lineModules.length() {
                                let modulePath = lineModules[lineModuleIdx]
                                if not containsPath(modules, modulePath) {
                                    modules.push(modulePath)
                                }
                                lineModuleIdx = lineModuleIdx + 1
                            }
                            if line.contains("]") {
                                collectingModules = 0
                            }
                        } else {
                            let eqPos = line.indexOf("=", 0)
                            if eqPos > 0 {
                                let key = line.substring(0, eqPos).trim()
                                let value = line.substring(eqPos + 1, line.length()).trim()
                                if key == "modules" {
                                    let valueModules = extractQuotedTomlStrings(value)
                                    var valueModuleIdx = 0
                                    while valueModuleIdx < valueModules.length() {
                                        let modulePath = valueModules[valueModuleIdx]
                                        if not containsPath(modules, modulePath) {
                                            modules.push(modulePath)
                                        }
                                        valueModuleIdx = valueModuleIdx + 1
                                    }
                                    if value.contains("[") and not value.contains("]") {
                                        collectingModules = 1
                                    }
                                }
                            }
                        }
                    }
                }
            }
            lineStart = pos + 1
        }
        pos = pos + 1
    }
    return modules
}

fun shouldResolveAstImportPath(importPath: Array<String>) r: Bool {
    if importPath.length() == 0 {
        return false
    }
    let firstSegment = importPath[0]
    if firstSegment == "" {
        return false
    }
    if firstSegment == "." {
        return false
    }
    if firstSegment == ":" {
        return false
    }
    return true
}

fun resolveAstImportItemPath(importItem: ItemNode, sourceDir: String) r: String {
    if importItem.itemType != "Import" {
        return ""
    }
    if not shouldResolveAstImportPath(importItem.importPath) {
        return ""
    }
    return resolveImportPath(importItem.importPath, sourceDir)
}

fun discoverImportsFromModule(paths: Array<String>, processedPaths: Array<String>, inputFile: String, currentPath: String, isBootstrap: Bool) r: Void {
    discoverImportsFromSourceText(paths, processedPaths, inputFile, currentPath, isBootstrap)
    return
}

fun moduleDeclaresMain(path: String) r: Bool {
    let frontend = parseModule(path, "en")
    if not frontend.success {
        return false
    }
    var itemIdx = 0
    while itemIdx < frontend.program.items.length() {
        let item = frontend.program.items[itemIdx]
        if mainCompilerItemDeclaresMain(item) {
            return true
        }
        itemIdx = itemIdx + 1
    }
    return false
}

fun parseImportTextSegments(importText: String) r: Array<String> {
    let segments = Array<String>()
    var currentSegment = ""
    var idx = 0
    while idx < importText.length() {
        let b = importText.byteAt(idx)
        var isNameChar = false
        if b >= 48 and b <= 57 { isNameChar = true }
        if b >= 65 and b <= 90 { isNameChar = true }
        if b >= 97 and b <= 122 { isNameChar = true }
        if b == 95 { isNameChar = true }

        if isNameChar {
            currentSegment = currentSegment + importText.substring(idx, idx + 1)
        } else {
            if currentSegment != "" {
                segments.push(currentSegment)
                currentSegment = ""
            }
            if b != 46 and b != 58 {
                return segments
            }
        }
        idx = idx + 1
    }
    if currentSegment != "" {
        segments.push(currentSegment)
    }
    return segments
}

fun normalizeSourceImportText(importText: String) r: String {
    var text = importText.trim()
    let commentStart = text.indexOf("//", 0)
    if commentStart >= 0 {
        text = text.substring(0, commentStart).trim()
    }
    if text.endsWith(";") {
        text = text.substring(0, text.length() - 1).trim()
    }
    return text
}

fun sourceImportBodyFromLine(line: String) r: String {
    let trimmed = line.trim()
    if trimmed.startsWith("pub import ") {
        return normalizeSourceImportText(trimmed.substring(11, trimmed.length()))
    }
    if trimmed.startsWith("pub use ") {
        return normalizeSourceImportText(trimmed.substring(8, trimmed.length()))
    }
    if trimmed.startsWith("import ") {
        return normalizeSourceImportText(trimmed.substring(7, trimmed.length()))
    }
    if trimmed.startsWith("use ") {
        return normalizeSourceImportText(trimmed.substring(4, trimmed.length()))
    }
    return ""
}

fun sourceTextImportPath(importText: String, sourceDir: String) r: String {
    let importSegments = parseImportTextSegments(importText)
    if importSegments.length() == 0 {
        return ""
    }
    return resolveImportPath(importSegments, sourceDir)
}

fun resolveSourceTextImportedSymbolName(importText: String, symbolName: String) r: String {
    let text = normalizeSourceImportText(importText)
    if text == "" or symbolName == "" {
        return ""
    }

    let braceStart = text.indexOf("{", 0)
    if braceStart >= 0 {
        var braceEnd = text.indexOf("}", braceStart + 1)
        if braceEnd < 0 {
            braceEnd = text.length()
        }
        let symbolsText = text.substring(braceStart + 1, braceEnd)
        var symbolStart = 0
        var pos = 0
        while pos <= symbolsText.length() {
            var atEnd = 0
            if pos == symbolsText.length() {
                atEnd = 1
            }
            var isComma = 0
            if atEnd == 0 {
                if symbolsText.byteAt(pos) == 44 {
                    isComma = 1
                }
            }
            if atEnd == 1 or isComma == 1 {
                let part = symbolsText.substring(symbolStart, pos).trim()
                if part != "" {
                    let aliasPos = part.indexOf(" as ", 0)
                    if aliasPos >= 0 {
                        let sourceName = part.substring(0, aliasPos).trim()
                        let aliasName = part.substring(aliasPos + 4, part.length()).trim()
                        if aliasName == symbolName {
                            return sourceName
                        }
                    } else {
                        if part == symbolName {
                            return part
                        }
                    }
                }
                symbolStart = pos + 1
            }
            pos = pos + 1
        }
        return ""
    }

    let aliasPos = text.indexOf(" as ", 0)
    if aliasPos >= 0 {
        let pathText = text.substring(0, aliasPos).trim()
        let aliasName = text.substring(aliasPos + 4, text.length()).trim()
        if aliasName == symbolName {
            let segments = parseImportTextSegments(pathText)
            if segments.length() > 0 {
                return segments[segments.length() - 1]
            }
        }
        return ""
    }

    return symbolName
}

fun appendSourceTextImportEdges(edges: String, modulePath: String) r: String {
    var result = edges
    let content = readText(modulePath)
    if content == "" {
        return result
    }
    let sourceDir = getSourceDir(modulePath)
    var lineStart = 0
    var pos = 0
    while pos <= content.length() {
        var atEnd = 0
        if pos == content.length() {
            atEnd = 1
        }
        var isNewline = 0
        if atEnd == 0 {
            if content.byteAt(pos) == 10 {
                isNewline = 1
            }
        }
        if isNewline == 1 or atEnd == 1 {
            let importText = sourceImportBodyFromLine(content.substring(lineStart, pos))
            if importText != "" {
                let importPath = sourceTextImportPath(importText, sourceDir)
                if importPath != "" {
                    if not result.contains("|" + importPath) {
                        result = result + "|" + importPath
                    }
                }
            }
            lineStart = pos + 1
        }
        pos = pos + 1
    }
    return result
}

fun queueImportTextPath(paths: Array<String>, processedPaths: Array<String>, inputFile: String, currentPath: String, sourceDir: String, isBootstrap: Bool, importText: String) r: Void {
    let importFilePath = sourceTextImportPath(importText, sourceDir)
    if shouldQueueDiscoveredImport(inputFile, currentPath, isBootstrap, importFilePath) {
        pushUniquePath(paths, processedPaths, importFilePath)
    }
    return
}

fun sourceTextUsesRuntimeMemory(content: String) r: Bool {
    if content.contains("seen_mem_") {
        return true
    }
    return false
}

fun resolveImplicitRuntimeMemoryImportPath(sourceDir: String) r: String {
    let tomlPath = findNearestSeenTomlFromDir(sourceDir)
    if tomlPath != "" {
        let projectRoot = getSourceDir(tomlPath)
        let projectRuntimePath = projectRoot + "/seen_runtime/src/memory.seen"
        if loadFileContent(projectRuntimePath) != "" {
            return projectRuntimePath
        }
    }

    let compilerRoot = getCompilerRoot()
    if compilerRoot != "" {
        let compilerRuntimePath = compilerRoot + "/seen_runtime/src/memory.seen"
        if loadFileContent(compilerRuntimePath) != "" {
            return compilerRuntimePath
        }
    }

    if loadFileContent("seen_runtime/src/memory.seen") != "" {
        return "seen_runtime/src/memory.seen"
    }
    return ""
}

fun queueImplicitRuntimeMemoryImport(paths: Array<String>, processedPaths: Array<String>, inputFile: String, currentPath: String, sourceDir: String, isBootstrap: Bool, content: String) r: Void {
    if not sourceTextUsesRuntimeMemory(content) {
        return
    }
    if isCompilerSourceDir(sourceDir) {
        return
    }
    if currentPath.endsWith("/seen_runtime/src/memory.seen") or currentPath == "seen_runtime/src/memory.seen" {
        return
    }
    let importFilePath = resolveImplicitRuntimeMemoryImportPath(sourceDir)
    if shouldQueueDiscoveredImport(inputFile, currentPath, isBootstrap, importFilePath) {
        pushUniquePath(paths, processedPaths, importFilePath)
    }
    return
}

fun ensureGeneratedTestObjectCacheDir() r: Void {
    let result: CommandResult = runCommand("mkdir -p /tmp/seen_testmain_obj_cache")
    return
}

fun generatedTestStableModuleIdentity(normalizedPath: String) r: String {
    let projectRootMarker = "/project_root/"
    let projectRootIdx = normalizedPath.indexOf(projectRootMarker, 0)
    if projectRootIdx >= 0 {
        return normalizedPath.substring(projectRootIdx + projectRootMarker.length(), normalizedPath.length())
    }

    let markers = Array<String>()
    markers.push("/compiler_seen/")
    markers.push("/seen_std/")
    markers.push("/seen_runtime/")
    markers.push("/hearton/")
    markers.push("/hearthshire/")
    markers.push("/native/")
    markers.push("/seen_audio/")
    markers.push("/seen_console/")
    markers.push("/seen_ecs/")
    markers.push("/seen_hot_reload/")
    markers.push("/seen_input/")
    markers.push("/seen_math/")
    markers.push("/seen_render/")
    markers.push("/seen_vk/")
    markers.push("/seen_voxel/")
    markers.push("/seen_window/")

    var markerIdx = 0
    while markerIdx < markers.length() {
        let marker = markers[markerIdx]
        let pathIdx = normalizedPath.indexOf(marker, 0)
        if pathIdx >= 0 {
            return normalizedPath.substring(pathIdx + 1, normalizedPath.length())
        }
        markerIdx = markerIdx + 1
    }

    return normalizedPath
}

fun generatedTestObjectCacheKeyForModule(modulePath: String, cacheSignature: String) r: String {
    let normalizedPath = resolveRealInputPath(modulePath)
    if normalizedPath == "" {
        return ""
    }
    let content = readText(normalizedPath)
    if content == "" {
        return ""
    }
    let contentHash = hashString(content)
    let stableIdentity = generatedTestStableModuleIdentity(normalizedPath)
    return hashString("testmain-object-source-v2|" + cacheSignature + "|" + stableIdentity + "|" + contentHash)
}

fun generatedTestObjectCachePath(cacheKey: String) r: String {
    if cacheKey == "" {
        return ""
    }
    return "/tmp/seen_testmain_obj_cache/" + cacheKey + ".o"
}

fun generatedTestObjectSetCacheKeyForInput(inputFile: String, cacheSignature: String) r: String {
    let normalizedPath = resolveRealInputPath(inputFile)
    if normalizedPath == "" {
        return ""
    }
    let content = readText(normalizedPath)
    if content == "" {
        return ""
    }
    let stableIdentity = generatedTestStableModuleIdentity(normalizedPath)
    let contentHash = hashString(content)
    return hashString("testmain-object-set-v1|" + cacheSignature + "|" + stableIdentity + "|" + contentHash)
}

fun generatedTestObjectSetCachePath(setKey: String) r: String {
    if setKey == "" {
        return ""
    }
    return "/tmp/seen_testmain_obj_cache/" + setKey + ".objects"
}

fun tryCopyGeneratedTestObjectFromCache(cacheKey: String, moduleIndex: Int) r: Bool {
    let cacheFile = generatedTestObjectCachePath(cacheKey)
    if cacheFile == "" {
        return false
    }
    if not exists(cacheFile) {
        return false
    }
    let objFile = "/tmp/seen_module_" + moduleIndex.toString() + ".o"
    let copyResult: CommandResult = runCommand("cp " + shellQuote(cacheFile) + " " + shellQuote(objFile))
    return commandWasSuccessful(copyResult)
}

fun generatedTestObjectCacheHasKey(cacheKey: String) r: Bool {
    let cacheFile = generatedTestObjectCachePath(cacheKey)
    if cacheFile == "" {
        return false
    }
    let checkResult: CommandResult = runCommand("test -f " + shellQuote(cacheFile))
    return commandWasSuccessful(checkResult)
}

fun tryUseGeneratedTestObjectSetCacheForInput(inputFile: String, cacheSignature: String, normalizedCrossTarget: String) r: Bool {
    if g_generatedTestMainMode == 0 {
        return false
    }
    if normalizedCrossTarget == "android-arm64" {
        return false
    }

    let setKey = generatedTestObjectSetCacheKeyForInput(inputFile, cacheSignature)
    let setPath = generatedTestObjectSetCachePath(setKey)
    if setPath == "" {
        return false
    }
    let setContent = loadFileContent(setPath)
    if setContent == "" {
        return false
    }

    let cacheKeys = Array<String>()
    var lineStart = 0
    var pos = 0
    while pos <= setContent.length() {
        var atEnd = 0
        if pos == setContent.length() {
            atEnd = 1
        }
        var isNewline = 0
        if atEnd == 0 {
            if setContent.byteAt(pos) == 10 {
                isNewline = 1
            }
        }
        if isNewline == 1 or atEnd == 1 {
            let cacheKey = setContent.substring(lineStart, pos).trim()
            if cacheKey != "" {
                if not generatedTestObjectCacheHasKey(cacheKey) {
                    return false
                }
                cacheKeys.push(cacheKey)
            }
            lineStart = pos + 1
        }
        pos = pos + 1
    }

    if cacheKeys.length() == 0 {
        return false
    }

    let cleanCmd = "rm -f /tmp/seen_module_*.ll /tmp/seen_module_*.o /tmp/seen_module_*.opt.ll /tmp/seen_module_*.polly.ll /tmp/seen_module_*.opt.status /tmp/seen_module_*.opt.log /tmp/seen_parallel_opt.sh"
    let cleanResult: CommandResult = runCommand(cleanCmd)

    var copyIdx = 0
    while copyIdx < cacheKeys.length() {
        if not tryCopyGeneratedTestObjectFromCache(cacheKeys[copyIdx], copyIdx) {
            return false
        }
        copyIdx = copyIdx + 1
    }

    println("  [Pass 0] Reusing generated test object set")
    println("    Found " + cacheKeys.length().toString() + " modules")
    println("  [3] Skipping final link for generated test main; module objects are ready")
    return true
}

fun tryUseCompleteGeneratedTestObjectCache(modulePaths: Array<String>, cacheSignature: String, normalizedCrossTarget: String) r: Bool {
    if g_generatedTestMainMode == 0 {
        return false
    }
    if normalizedCrossTarget == "android-arm64" {
        return false
    }
    if modulePaths.length() == 0 {
        return false
    }

    let cacheKeys = Array<String>()
    var checkIdx = 0
    while checkIdx < modulePaths.length() {
        let cacheKey = generatedTestObjectCacheKeyForModule(modulePaths[checkIdx], cacheSignature)
        if not generatedTestObjectCacheHasKey(cacheKey) {
            return false
        }
        cacheKeys.push(cacheKey)
        checkIdx = checkIdx + 1
    }

    var copyIdx = 0
    while copyIdx < cacheKeys.length() {
        if not tryCopyGeneratedTestObjectFromCache(cacheKeys[copyIdx], copyIdx) {
            return false
        }
        copyIdx = copyIdx + 1
    }

    println("  [3] Skipping final link for generated test main; module objects are ready")
    return true
}

fun storeGeneratedTestObjectInCache(cacheKey: String, objFile: String) r: Void {
    let cacheFile = generatedTestObjectCachePath(cacheKey)
    if cacheFile == "" {
        return
    }
    if exists(cacheFile) {
        return
    }
    ensureGeneratedTestObjectCacheDir()
    let copyResult: CommandResult = runCommand("cp " + shellQuote(objFile) + " " + shellQuote(cacheFile))
    return
}

fun storeGeneratedTestObjectSetCache(inputFile: String, modulePaths: Array<String>, cacheSignature: String, normalizedCrossTarget: String) r: Void {
    if g_generatedTestMainMode == 0 {
        return
    }
    if normalizedCrossTarget == "android-arm64" {
        return
    }
    if modulePaths.length() == 0 {
        return
    }

    let setKey = generatedTestObjectSetCacheKeyForInput(inputFile, cacheSignature)
    let setPath = generatedTestObjectSetCachePath(setKey)
    if setPath == "" {
        return
    }
    if exists(setPath) {
        return
    }

    var setContent = ""
    var moduleIdx = 0
    while moduleIdx < modulePaths.length() {
        let cacheKey = generatedTestObjectCacheKeyForModule(modulePaths[moduleIdx], cacheSignature)
        if cacheKey == "" {
            return
        }
        if not generatedTestObjectCacheHasKey(cacheKey) {
            return
        }
        setContent = setContent + cacheKey + "\n"
        moduleIdx = moduleIdx + 1
    }

    ensureGeneratedTestObjectCacheDir()
    let wrote = writeText(setPath, setContent)
    return
}

fun discoverImportsFromSourceText(paths: Array<String>, processedPaths: Array<String>, inputFile: String, currentPath: String, isBootstrap: Bool) r: Void {
    let content = readText(currentPath)
    if content == "" {
        return
    }
    let sourceDir = getSourceDir(currentPath)
    var lineStart = 0
    var pos = 0
    while pos <= content.length() {
        var atEnd = 0
        if pos == content.length() {
            atEnd = 1
        }
        var isNewline = 0
        if atEnd == 0 {
            if content.byteAt(pos) == 10 {
                isNewline = 1
            }
        }
        if isNewline == 1 or atEnd == 1 {
            let importText = sourceImportBodyFromLine(content.substring(lineStart, pos))
            if importText != "" {
                queueImportTextPath(paths, processedPaths, inputFile, currentPath, sourceDir, isBootstrap, importText)
            }
            lineStart = pos + 1
        }
        pos = pos + 1
    }
    queueImplicitRuntimeMemoryImport(paths, processedPaths, inputFile, currentPath, sourceDir, isBootstrap, content)
    return
}

fun moduleGraphContainsCompilerSources(modulePaths: Array<String>) r: Bool {
    var idx = 0
    while idx < modulePaths.length() {
        let modulePath = modulePaths[idx]
        if modulePath.startsWith("compiler_seen/src/") or modulePath.contains("/compiler_seen/src/") {
            return true
        }
        idx = idx + 1
    }
    return false
}

fun shouldRunWholeProjectPreflight(modulePaths: Array<String>) r: Bool {
    if g_generatedTestMainMode == 1 {
        return false
    }
    if modulePaths.length() > 24 {
        return false
    }
    if moduleGraphContainsCompilerSources(modulePaths) {
        return false
    }
    return true
}

fun effectiveLargeProjectWorkerLimit(moduleCount: Int, isBootstrap: Bool) r: Int {
    if isBootstrap {
        return 0
    }
    if g_noFork == 0 {
        return 0
    }
    if g_projectPrefixLimit <= 0 {
        return 0
    }
    if moduleCount < 256 {
        return 0
    }
    return g_largeProjectWorkerLimit
}

///
Collect all module paths needed for compilation (without storing ASTs).
For regular compilations this walks imports recursively so standalone builds
include transitive dependencies. For bootstrap compilation we keep the older
behavior of parsing only the main file, then appending the curated compiler
module list below. Returns paths in discovery order with duplicates removed.
The AST from import discovery is released before returning to bound memory.
///
fun collectModulePaths(inputFile: String, quiet: Bool) r: Array<String> {
    var paths = Array<String>()
    var processedPaths = Array<String>()

    let isBootstrap = inputFile.contains("main_compiler.seen")

    pushUniquePath(paths, processedPaths, inputFile)

    if not isBootstrap {
        let tomlPath = findNearestSeenTomlForInput(inputFile)
        let tomlContent = loadFileContent(tomlPath)
        if tomlContent != "" {
            let projectRoot = getSourceDir(tomlPath)
            let projectModules = extractTomlProjectModules(tomlContent)
            let buildEntry = extractTomlBuildEntry(tomlContent)
            let inputIsProjectMember = inputBelongsToProject(projectRoot, inputFile, projectModules, buildEntry)
            if inputIsProjectMember {
                if not quiet and projectModules.length() > 0 {
                    println("    Adding " + projectModules.length().toString() + " modules from Seen.toml...")
                }
                var projectModuleIdx = 0
                while projectModuleIdx < projectModules.length() {
                    let projectModulePath = resolveProjectPath(projectRoot, projectModules[projectModuleIdx])
                    pushUniquePath(paths, processedPaths, projectModulePath)
                    projectModuleIdx = projectModuleIdx + 1
                }
            }
            if buildEntry != "" {
                let inputDeclaresMain = moduleDeclaresMain(inputFile)
                let rootStandaloneMain = inputDeclaresMain and getSourceDir(inputFile) == projectRoot and not inputIsProjectMember
                let resolvedBuildEntry = resolveProjectPath(projectRoot, buildEntry)
                ///
                Keep root-level scratch entrypoints standalone even when a project build
                entry exists; nested project files still inherit build-entry imports.
                ///
                if not rootStandaloneMain {
                    if not inputDeclaresMain {
                        if not quiet {
                            println("    Adding Seen.toml build entry: " + buildEntry)
                        }
                        pushUniquePath(paths, processedPaths, resolvedBuildEntry)
                    }
                    if not quiet {
                        println("    Seeding imports from Seen.toml build entry: " + buildEntry)
                    }
                    discoverImportsFromModule(paths, processedPaths, inputFile, resolvedBuildEntry, isBootstrap)
                }
            }
        }
    }

    ///
    Parse imports into a worklist. Non-bootstrap builds recurse through the
    full import graph; bootstrap still uses the curated module list below.
    ///
    if not quiet {
        println("    Discovering imports from main file...")
    }
    var discoverIdx = 0
    while discoverIdx < paths.length() {
        if isBootstrap and discoverIdx > 0 {
            break
        }

        let currentPath = paths[discoverIdx]
        appendManifestCompanionModulesForPath(paths, processedPaths,
            currentPath)
        discoverImportsFromModule(paths, processedPaths, inputFile, currentPath, isBootstrap)
        discoverIdx = discoverIdx + 1
    }

    if not isBootstrap and moduleGraphContainsCompilerSources(paths) {
        appendCompilerInternalSupportModules(paths, processedPaths)
    }

    // Add bootstrap modules if compiling the compiler
    if isBootstrap {
        if not quiet {
            println("    Bootstrap mode: adding compiler modules...")
        }
        let modules = Array<String>()
        ///
        Keep direct stdlib dependencies explicit for bootstrap binaries run
        outside compiler_seen/target, where root-based import discovery is fragile.
        ///
        modules.push("io.file")
        modules.push("process.process")
        modules.push("env.env")
        modules.push("lexer.token")
        modules.push("lexer.token_type")
        modules.push("lexer.interfaces")
        modules.push("lexer.keyword_manager")
        modules.push("lexer.lexer")
        modules.push("trace")
        // lexer.real_lexer removed: 2-line re-export shim, no compiler module imports it
        modules.push("parser.real_parser")
        modules.push("typechecker.interfaces")
        modules.push("typechecker.typechecker")
        modules.push("typechecker.determinism")
        // Macro modules must come before bootstrap.frontend (which imports them)
        modules.push("macro.ast_node")
        modules.push("macro.registry")
        modules.push("macro.interpreter")
        modules.push("macro.expander")
        modules.push("bootstrap.frontend")
        modules.push("codegen.ir_optimization")
        modules.push("codegen.ir_egraph_rules")
        modules.push("codegen.ir_egraph_emit")
        modules.push("codegen.ir_inline_heuristics")
        modules.push("codegen.ir_enum_lookup")
