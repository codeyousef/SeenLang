// Factory functions
// Removed: keyword manager factory is not used in self-host path
fun createKeywordManager() -> KeywordManager {
    return KeywordManager.new()
}

fun createLexer(source: String, language: String) -> SeenLexer {
    let km = KeywordManager.new()
    return SeenLexer.new(source, 1, km)
}

fun createParser(tokens: Array<Token>) -> SeenParser {
    return SeenParser.new(tokens)
}

