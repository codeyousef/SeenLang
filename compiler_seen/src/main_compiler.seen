        while mi < modules.length() {
            let modPath = resolveModulePath(modules[mi])
            if not containsPath(processedPaths, modPath) {
                paths.push(modPath)
                processedPaths.push(modPath)
            }
            mi = mi + 1
        }
    }

    return paths
}

fun importProvidesSymbol(importItem: ItemNode, symbolName: String) r: Bool {
    return resolveImportedSymbolName(importItem, symbolName) != ""
}

fun stripCallGenericArguments(callName: String) r: String {
    let genericStart = callName.indexOf("<", 0)
    if genericStart > 0 {
        return callName.substring(0, genericStart)
    }
    return callName
}

fun resolveImportedSymbolName(importItem: ItemNode, symbolName: String) r: String {
    if importItem.itemType != "Import" {
        return ""
    }

    if importItem.importSymbols.length() == 0 {
        return symbolName
    }

    var i = 0
    while i < importItem.importSymbols.length() {
        let symbol = importItem.importSymbols[i]
        if symbol.alias == symbolName {
            return symbol.name
        }
        if symbol.alias == "" and symbol.name == symbolName {
            return symbol.name
        }
        i = i + 1
    }

    return ""
}

fun findProgramClass(program: ProgramNode, className: String) r: ClassNode {
    var i = 0
    while i < program.items.length() {
        let item = program.items[i]
        if item.itemType == "Class" {
            if item.classNode.name == className {
                return item.classNode
            }
        }
        i = i + 1
    }
    return ClassNode.new()
}

fun findParsedModuleClass(modulePaths: Array<String>, frontends: Array<FrontendResult>, targetPath: String, className: String) r: ClassNode {
    let normalizedTargetPath = resolveRealInputPath(targetPath)
    var i = 0
    while i < modulePaths.length() {
        if modulePaths[i] == normalizedTargetPath {
            return findProgramClass(frontends[i].program, className)
        }
        i = i + 1
    }
    if exists(normalizedTargetPath) {
        let frontend = parseModule(normalizedTargetPath, "en")
        if frontend.success {
            return findProgramClass(frontend.program, className)
        }
    }
    return ClassNode.new()
}

fun findSourceTextImportedClassInModules(modulePath: String,
    modulePaths: Array<String>, frontends: Array<FrontendResult>,
    className: String) r: ClassNode {

    let content = readText(modulePath)
    if content == "" {
        return ClassNode.new()
    }

    let sourceDir = getSourceDir(modulePath)
    var lineStart = 0
    var pos = 0
    while pos <= content.length() {
        var atEnd = 0
        if pos == content.length() {
            atEnd = 1
        }
        var isNewline = 0
        if atEnd == 0 {
            if content.byteAt(pos) == 10 {
                isNewline = 1
            }
        }
        if isNewline == 1 or atEnd == 1 {
            let importText = sourceImportBodyFromLine(content.substring(lineStart, pos))
            if importText != "" {
                let importedSymbolName = resolveSourceTextImportedSymbolName(importText, className)
                if importedSymbolName != "" {
                    let importedPath = sourceTextImportPath(importText, sourceDir)
                    if importedPath != "" {
                        let importedClass = findParsedModuleClass(modulePaths,
                            frontends, importedPath, importedSymbolName)
                        if importedClass.name != "" {
                            return importedClass
                        }
                    }
                }
            }
            lineStart = pos + 1
        }
        pos = pos + 1
    }

    return ClassNode.new()
}

fun capabilityDecoratorNameMatches(name: String) r: Bool {
    return name == "using" or name == "effect"
}

fun moduleFunctionHasCapabilityToken(func: FunctionNode, token: String) r: Bool {
    var di = 0
    while di < func.decorators.length() {
        let decorator = func.decorators[di]
        if capabilityDecoratorNameMatches(decorator.name) {
            var ai = 0
            while ai < decorator.arguments.length() {
                let arg = decorator.arguments[ai]
                if arg == token or arg == "AllToken" {
                    return true
                }
                ai = ai + 1
            }
        }
        di = di + 1
    }
    return false
}

fun moduleCollectFunctionCapabilities(func: FunctionNode) r: Array<String> {
    let caps = Array<String>()
    var di = 0
    while di < func.decorators.length() {
        let decorator = func.decorators[di]
        if capabilityDecoratorNameMatches(decorator.name) {
            var ai = 0
            while ai < decorator.arguments.length() {
                caps.push(decorator.arguments[ai])
                ai = ai + 1
            }
        }
        di = di + 1
    }
    return caps
}

fun findProgramFunction(program: ProgramNode, functionName: String) r: FunctionNode {
    var i = 0
    while i < program.items.length() {
        let item = program.items[i]
        if mainCompilerItemFunctionNameEquals(item, functionName) {
            return item.function
        }
        i = i + 1
    }
    return FunctionNode.new()
}

fun findParsedModuleFunction(modulePaths: Array<String>, frontends: Array<FrontendResult>, targetPath: String, functionName: String) r: FunctionNode {
    let normalizedTargetPath = resolveRealInputPath(targetPath)
    var i = 0
    while i < modulePaths.length() {
        if modulePaths[i] == normalizedTargetPath {
            return findProgramFunction(frontends[i].program, functionName)
        }
        i = i + 1
    }
    if exists(normalizedTargetPath) {
        let frontend = parseModule(normalizedTargetPath, "en")
        if frontend.success {
            return findProgramFunction(frontend.program, functionName)
        }
    }
    return FunctionNode.new()
}

fun findSourceTextImportedFunctionInModules(modulePath: String,
    modulePaths: Array<String>, frontends: Array<FrontendResult>,
    functionName: String) r: FunctionNode {

    let content = readText(modulePath)
    if content == "" {
        return FunctionNode.new()
    }

    let sourceDir = getSourceDir(modulePath)
    var lineStart = 0
    var pos = 0
    while pos <= content.length() {
        var atEnd = 0
        if pos == content.length() {
            atEnd = 1
        }
        var isNewline = 0
        if atEnd == 0 {
            if content.byteAt(pos) == 10 {
                isNewline = 1
            }
        }
        if isNewline == 1 or atEnd == 1 {
            let importText = sourceImportBodyFromLine(content.substring(lineStart, pos))
            if importText != "" {
                let importedSymbolName = resolveSourceTextImportedSymbolName(importText, functionName)
                if importedSymbolName != "" {
                    let importedPath = sourceTextImportPath(importText, sourceDir)
                    if importedPath != "" {
                        let importedFunc = findParsedModuleFunction(modulePaths,
                            frontends, importedPath, importedSymbolName)
                        if importedFunc.name != "" {
                            return importedFunc
                        }
                    }
                }
            }
            lineStart = pos + 1
        }
        pos = pos + 1
    }

    return FunctionNode.new()
}

fun findFunctionImportedByAnyModuleInModules(modulePaths: Array<String>,
    frontends: Array<FrontendResult>, functionName: String) r: FunctionNode {

    var moduleIdx = 0
    while moduleIdx < modulePaths.length() {
        let importingPath = modulePaths[moduleIdx]
        let importingDir = getSourceDir(importingPath)
        let importingProgram = frontends[moduleIdx].program
        var itemIdx = 0
        while itemIdx < importingProgram.items.length() {
            let item = importingProgram.items[itemIdx]
            let importedSymbolName = resolveImportedSymbolName(item,
                functionName)
            if importedSymbolName != "" {
                let importedPath = resolveAstImportItemPath(item,
                    importingDir)
                if importedPath != "" {
                    let importedFunc = findParsedModuleFunction(modulePaths,
                        frontends, importedPath, importedSymbolName)
                    if importedFunc.name != "" {
                        return importedFunc
                    }
                }
            }
            itemIdx = itemIdx + 1
        }
        let sourceTextFunc = findSourceTextImportedFunctionInModules(importingPath,
            modulePaths, frontends, functionName)
        if sourceTextFunc.name != "" {
            return sourceTextFunc
        }
        moduleIdx = moduleIdx + 1
    }
    return FunctionNode.new()
}

fun findFunctionInAnyParsedModule(modulePaths: Array<String>,
    frontends: Array<FrontendResult>, functionName: String) r: FunctionNode {

    var moduleIdx = 0
    while moduleIdx < modulePaths.length() {
        let func = findProgramFunction(frontends[moduleIdx].program,
            functionName)
        if func.name != "" {
            return func
        }
        moduleIdx = moduleIdx + 1
    }
    return FunctionNode.new()
}

fun findImportedFunctionInModules(modulePath: String, moduleProgram: ProgramNode, modulePaths: Array<String>, frontends: Array<FrontendResult>, functionName: String) r: FunctionNode {
    let sourceDir = getSourceDir(modulePath)
    var i = 0
    while i < moduleProgram.items.length() {
        let item = moduleProgram.items[i]
        let importedSymbolName = resolveImportedSymbolName(item, functionName)
        if importedSymbolName != "" {
            let importedPath = resolveAstImportItemPath(item, sourceDir)
            if importedPath != "" {
                let importedFunc = findParsedModuleFunction(modulePaths, frontends, importedPath, importedSymbolName)
                if importedFunc.name != "" {
                    return importedFunc
                }
            }
        }
        i = i + 1
    }
    return findSourceTextImportedFunctionInModules(modulePath, modulePaths,
        frontends, functionName)
}

fun addImportedCapabilityViolation(result: FrontendResult, modulePath: String, line: Int, functionName: String, calledFunction: String, requiredToken: String) r: Void {
    var message = "Calling imported function that requires capability token"
    if functionName != "" {
        message = message + " in function '" + functionName + "'"
    }
    if calledFunction != "" {
        message = message + " when calling '" + calledFunction + "'"
    }
    if requiredToken != "" {
        message = message + " (requires @using(" + requiredToken + "))"
    }

    var suggestion = ""
    if requiredToken != "" and functionName != "" {
        suggestion = "Add effect(" + requiredToken + ") or @using(" + requiredToken + ") to '" + functionName + "'."
    }

    let encoded = encodeDiagMessage(message, "E005", suggestion, "", 0)
    result.addDiagnostic(FrontendDiagnostic.new(modulePath, line, 0, "error", encoded))
}

fun checkImportedCapabilityCalledFunction(result: FrontendResult, modulePath: String, moduleProgram: ProgramNode, modulePaths: Array<String>, frontends: Array<FrontendResult>, callerFunc: FunctionNode, callerName: String, calledName: String, funcLine: Int) r: Void {
    let importedFunc = findImportedFunctionInModules(modulePath, moduleProgram, modulePaths, frontends, calledName)
    if importedFunc.name == "" {
        return
    }

    let importedCaps = moduleCollectFunctionCapabilities(importedFunc)
    var i = 0
    while i < importedCaps.length() {
        let cap = importedCaps[i]
        if not moduleFunctionHasCapabilityToken(callerFunc, cap) {
            addImportedCapabilityViolation(result, modulePath, funcLine, callerName, calledName, cap)
        }
        i = i + 1
    }
}

fun checkImportedCapabilityExpression(result: FrontendResult, modulePath: String, moduleProgram: ProgramNode, modulePaths: Array<String>, frontends: Array<FrontendResult>, func: FunctionNode, funcName: String, expr: ParserExpressionNode, funcLine: Int) r: Void {
    if expr.kind == "None" or expr.kind == "" {
        return
    }

    if expr.kind == "Call" {
        checkImportedCapabilityCalledFunction(result, modulePath, moduleProgram, modulePaths, frontends, func, funcName, expr.callee, funcLine)

        var argIdx = 0
        while argIdx < expr.arguments.length() {
            checkImportedCapabilityExpression(result, modulePath, moduleProgram, modulePaths, frontends, func, funcName, expr.arguments[argIdx], funcLine)
            argIdx = argIdx + 1
        }
    }

    if expr.kind == "MethodCall" or expr.kind == "MemberAccess" {
        var methodArgIdx = 0
        while methodArgIdx < expr.arguments.length() {
            checkImportedCapabilityExpression(result, modulePath, moduleProgram, modulePaths, frontends, func, funcName, expr.arguments[methodArgIdx], funcLine)
            methodArgIdx = methodArgIdx + 1
        }
    }

    if expr.kind == "Binary" {
        var operandIdx = 0
        while operandIdx < expr.operands.length() {
            checkImportedCapabilityExpression(result, modulePath, moduleProgram, modulePaths, frontends, func, funcName, expr.operands[operandIdx], funcLine)
            operandIdx = operandIdx + 1
        }
    }
}

fun checkImportedCapabilityStatement(result: FrontendResult, modulePath: String, moduleProgram: ProgramNode, modulePaths: Array<String>, frontends: Array<FrontendResult>, func: FunctionNode, funcName: String, stmt: StatementNode, funcLine: Int) r: Void {
    if stmt.kind == "Expression" or stmt.kind == "Return" {
        checkImportedCapabilityExpression(result, modulePath, moduleProgram, modulePaths, frontends, func, funcName, stmt.expression, funcLine)
        checkImportedCapabilityExpression(result, modulePath, moduleProgram, modulePaths, frontends, func, funcName, stmt.returnValue, funcLine)
    }

    if stmt.kind == "Let" or stmt.kind == "Var" {
        checkImportedCapabilityExpression(result, modulePath, moduleProgram, modulePaths, frontends, func, funcName, stmt.initializer, funcLine)
    }

    if stmt.kind == "If" {
        checkImportedCapabilityExpression(result, modulePath, moduleProgram, modulePaths, frontends, func, funcName, stmt.condition, funcLine)
        checkImportedCapabilityBlock(result, modulePath, moduleProgram, modulePaths, frontends, func, funcName, stmt.thenBranch, funcLine)
        checkImportedCapabilityBlock(result, modulePath, moduleProgram, modulePaths, frontends, func, funcName, stmt.elseBranch, funcLine)
    }

    if stmt.kind == "While" {
        checkImportedCapabilityExpression(result, modulePath, moduleProgram, modulePaths, frontends, func, funcName, stmt.loopCondition, funcLine)
        checkImportedCapabilityBlock(result, modulePath, moduleProgram, modulePaths, frontends, func, funcName, stmt.loopBody, funcLine)
    }
}

fun checkImportedCapabilityBlock(result: FrontendResult, modulePath: String, moduleProgram: ProgramNode, modulePaths: Array<String>, frontends: Array<FrontendResult>, func: FunctionNode, funcName: String, block: BlockNode, funcLine: Int) r: Void {
    var i = 0
    while i < block.statements.length() {
        checkImportedCapabilityStatement(result, modulePath, moduleProgram, modulePaths, frontends, func, funcName, block.statements[i], funcLine)
        i = i + 1
    }
}

fun findReferencedClassInModules(modulePath: String, moduleProgram: ProgramNode, modulePaths: Array<String>, frontends: Array<FrontendResult>, className: String) r: ClassNode {
    let localClass = findProgramClass(moduleProgram, className)
    if localClass.name != "" {
        return localClass
    }

    let sourceDir = getSourceDir(modulePath)
    var i = 0
    while i < moduleProgram.items.length() {
        let item = moduleProgram.items[i]
        let importedSymbolName = resolveImportedSymbolName(item, className)
        if importedSymbolName != "" {
            let importedPath = resolveAstImportItemPath(item, sourceDir)
            if importedPath != "" {
                let importedClass = findParsedModuleClass(modulePaths, frontends, importedPath, importedSymbolName)
                if importedClass.name != "" {
                    return importedClass
                }
            }
        }
        i = i + 1
    }

    let sourceTextClass = findSourceTextImportedClassInModules(modulePath,
        modulePaths, frontends, className)
    if sourceTextClass.name != "" {
        return sourceTextClass
    }

    return findClassImportedByAnyModuleInModules(modulePaths, frontends,
        className)
}

fun findClassImportedByAnyModuleInModules(modulePaths: Array<String>,
    frontends: Array<FrontendResult>, className: String) r: ClassNode {

    var moduleIdx = 0
    while moduleIdx < modulePaths.length() {
        let importingPath = modulePaths[moduleIdx]
        let importingDir = getSourceDir(importingPath)
        let importingProgram = frontends[moduleIdx].program
        var itemIdx = 0
        while itemIdx < importingProgram.items.length() {
            let item = importingProgram.items[itemIdx]
            let importedSymbolName = resolveImportedSymbolName(item, className)
            if importedSymbolName != "" {
                let importedPath = resolveAstImportItemPath(item,
                    importingDir)
                if importedPath != "" {
                    let importedClass = findParsedModuleClass(modulePaths,
                        frontends, importedPath, importedSymbolName)
                    if importedClass.name != "" {
                        return importedClass
                    }
                }
            }
            itemIdx = itemIdx + 1
        }
        let sourceTextClass = findSourceTextImportedClassInModules(importingPath,
            modulePaths, frontends, className)
        if sourceTextClass.name != "" {
            return sourceTextClass
        }
        moduleIdx = moduleIdx + 1
    }
    return ClassNode.new()
}

fun isIdentifierStartChar(ch: String) r: Bool {
    if ch == "_" { return true }
    if ch >= "a" and ch <= "z" { return true }
    if ch >= "A" and ch <= "Z" { return true }
    return false
}

fun isIdentifierPartChar(ch: String) r: Bool {
    if isIdentifierStartChar(ch) { return true }
    if ch >= "0" and ch <= "9" { return true }
    return false
}

fun findUndecoratedReferencedClassInModules(modulePath: String, moduleProgram: ProgramNode, modulePaths: Array<String>, frontends: Array<FrontendResult>, ownerClassName: String, typeName: String, requiredDecorator: String) r: String {
    var pos = 0
    while pos < typeName.length() {
        let ch = typeName.substring(pos, pos + 1)
        if isIdentifierStartChar(ch) {
            let start = pos
            pos = pos + 1
            while pos < typeName.length() {
                let inner = typeName.substring(pos, pos + 1)
                if not isIdentifierPartChar(inner) {
                    break
                }
                pos = pos + 1
            }

            let token = typeName.substring(start, pos)
            if token != ownerClassName {
                let referenced = findReferencedClassInModules(modulePath, moduleProgram, modulePaths, frontends, token)
                if referenced.name != "" {
                    if not referenced.hasDecorator(requiredDecorator) and not referenced.hasDecorator("type_alias") {
                        return token
                    }
                }
            }
        } else {
            pos = pos + 1
        }
    }

    return ""
}

fun programDefinesSealedClass(program: ProgramNode, className: String) r: Bool {
    var i = 0
    while i < program.items.length() {
        let item = program.items[i]
        if item.itemType == "Class" {
            if item.classNode.name == className and item.classNode.hasDecorator("sealed") {
                return true
            }
        }
        i = i + 1
    }
    return false
}

fun parsedModuleHasSealedClass(modulePaths: Array<String>, frontends: Array<FrontendResult>, targetPath: String, className: String) r: Bool {
    var i = 0
    while i < modulePaths.length() {
        if modulePaths[i] == targetPath {
            return programDefinesSealedClass(frontends[i].program, className)
        }
        i = i + 1
    }
    return false
}

fun findSourceTextImportedSealedParentModule(modulePath: String,
    modulePaths: Array<String>, frontends: Array<FrontendResult>,
    parentName: String) r: String {

    let content = readText(modulePath)
    if content == "" {
        return ""
    }

    let sourceDir = getSourceDir(modulePath)
    var lineStart = 0
    var pos = 0
    while pos <= content.length() {
        var atEnd = 0
        if pos == content.length() {
            atEnd = 1
        }
        var isNewline = 0
        if atEnd == 0 {
            if content.byteAt(pos) == 10 {
                isNewline = 1
            }
        }
        if isNewline == 1 or atEnd == 1 {
            let importText = sourceImportBodyFromLine(content.substring(lineStart, pos))
            if importText != "" {
                let importedSymbolName = resolveSourceTextImportedSymbolName(importText, parentName)
                if importedSymbolName != "" {
                    let importedPath = sourceTextImportPath(importText, sourceDir)
                    if importedPath != "" {
                        if parsedModuleHasSealedClass(modulePaths, frontends,
                            importedPath, importedSymbolName) {
                            return importedPath
                        }
                    }
                }
            }
            lineStart = pos + 1
        }
        pos = pos + 1
    }

    return ""
}

fun findImportedSealedParentModule(modulePath: String, moduleProgram: ProgramNode, modulePaths: Array<String>, frontends: Array<FrontendResult>, parentName: String) r: String {
    if programDefinesSealedClass(moduleProgram, parentName) {
        return ""
    }

    let sourceDir = getSourceDir(modulePath)
    var i = 0
    while i < moduleProgram.items.length() {
        let item = moduleProgram.items[i]
        let importedSymbolName = resolveImportedSymbolName(item, parentName)
        if importedSymbolName != "" {
            let importedPath = resolveAstImportItemPath(item, sourceDir)
            if importedPath != "" {
                if parsedModuleHasSealedClass(modulePaths, frontends, importedPath, importedSymbolName) {
                    return importedPath
                }
            }
        }
        i = i + 1
    }

    return findSourceTextImportedSealedParentModule(modulePath, modulePaths,
        frontends, parentName)
}

fun findProgramEnum(program: ProgramNode, enumName: String) r: EnumNode {
    var i = 0
    while i < program.items.length() {
        let item = program.items[i]
        if item.itemType == "Enum" {
            if item.enumNode.name == enumName {
                return item.enumNode
            }
        }
        i = i + 1
    }
    return EnumNode.new()
}

fun findParsedModuleEnum(modulePaths: Array<String>, frontends: Array<FrontendResult>, targetPath: String, enumName: String) r: EnumNode {
    let normalizedTargetPath = resolveRealInputPath(targetPath)
    var i = 0
    while i < modulePaths.length() {
        if modulePaths[i] == normalizedTargetPath {
            return findProgramEnum(frontends[i].program, enumName)
        }
        i = i + 1
    }
    if exists(normalizedTargetPath) {
        let frontend = parseModule(normalizedTargetPath, "en")
        if frontend.success {
            return findProgramEnum(frontend.program, enumName)
        }
    }
    return EnumNode.new()
}

fun findSourceTextImportedEnumInModules(modulePath: String,
    modulePaths: Array<String>, frontends: Array<FrontendResult>,
    enumName: String) r: EnumNode {

    let content = readText(modulePath)
    if content == "" {
        return EnumNode.new()
    }

    let sourceDir = getSourceDir(modulePath)
    var lineStart = 0
    var pos = 0
    while pos <= content.length() {
        var atEnd = 0
        if pos == content.length() {
            atEnd = 1
        }
        var isNewline = 0
        if atEnd == 0 {
            if content.byteAt(pos) == 10 {
                isNewline = 1
            }
        }
        if isNewline == 1 or atEnd == 1 {
            let importText = sourceImportBodyFromLine(content.substring(lineStart, pos))
            if importText != "" {
                let importedSymbolName = resolveSourceTextImportedSymbolName(importText, enumName)
                if importedSymbolName != "" {
                    let importedPath = sourceTextImportPath(importText, sourceDir)
                    if importedPath != "" {
                        let importedEnum = findParsedModuleEnum(modulePaths,
                            frontends, importedPath, importedSymbolName)
                        if importedEnum.name != "" {
                            return importedEnum
                        }
                    }
                }
            }
            lineStart = pos + 1
        }
        pos = pos + 1
    }

    return EnumNode.new()
}

fun findReferencedEnumInModules(modulePath: String, moduleProgram: ProgramNode, modulePaths: Array<String>, frontends: Array<FrontendResult>, enumName: String) r: EnumNode {
    let localEnum = findProgramEnum(moduleProgram, enumName)
    if localEnum.name != "" {
        return localEnum
    }

    let sourceDir = getSourceDir(modulePath)
    var i = 0
    while i < moduleProgram.items.length() {
        let item = moduleProgram.items[i]
        let importedSymbolName = resolveImportedSymbolName(item, enumName)
        if importedSymbolName != "" {
            let importedPath = resolveAstImportItemPath(item, sourceDir)
            if importedPath != "" {
                let importedEnum = findParsedModuleEnum(modulePaths, frontends, importedPath, importedSymbolName)
                if importedEnum.name != "" {
                    return importedEnum
                }
            }
        }
        i = i + 1
    }

    let sourceTextEnum = findSourceTextImportedEnumInModules(modulePath,
        modulePaths, frontends, enumName)
    if sourceTextEnum.name != "" {
        return sourceTextEnum
    }

    return findEnumImportedByAnyModuleInModules(modulePaths, frontends,
        enumName)
}

fun findEnumImportedByAnyModuleInModules(modulePaths: Array<String>,
    frontends: Array<FrontendResult>, enumName: String) r: EnumNode {

    var moduleIdx = 0
    while moduleIdx < modulePaths.length() {
        let importingPath = modulePaths[moduleIdx]
        let importingDir = getSourceDir(importingPath)
        let importingProgram = frontends[moduleIdx].program
        var itemIdx = 0
        while itemIdx < importingProgram.items.length() {
            let item = importingProgram.items[itemIdx]
            let importedSymbolName = resolveImportedSymbolName(item, enumName)
            if importedSymbolName != "" {
                let importedPath = resolveAstImportItemPath(item,
                    importingDir)
                if importedPath != "" {
                    let importedEnum = findParsedModuleEnum(modulePaths,
                        frontends, importedPath, importedSymbolName)
                    if importedEnum.name != "" {
                        return importedEnum
                    }
                }
            }
            itemIdx = itemIdx + 1
        }
        let sourceTextEnum = findSourceTextImportedEnumInModules(importingPath,
            modulePaths, frontends, enumName)
        if sourceTextEnum.name != "" {
            return sourceTextEnum
        }
        moduleIdx = moduleIdx + 1
    }
    return EnumNode.new()
}

fun enumHasVariant(enumNode: EnumNode, variantName: String) r: Bool {
    var i = 0
    while i < enumNode.variants.length() {
        if enumNode.variants[i] == variantName {
            return true
        }
        i = i + 1
    }
    return false
}

fun copyStringArray(values: Array<String>) r: Array<String> {
    let copied = Array<String>()
    var i = 0
    while i < values.length() {
        copied.push(values[i])
        i = i + 1
    }
    return copied
}

fun lookupBoundType(boundNames: Array<String>, boundTypes: Array<String>, name: String) r: String {
    var i = boundNames.length() - 1
    while i >= 0 {
        if boundNames[i] == name {
            return boundTypes[i]
        }
        i = i - 1
    }
    return ""
}

fun addBoundType(boundNames: Array<String>, boundTypes: Array<String>, name: String, typeName: String) r: Void {
    if name == "" {
        return
    }
    if typeName == "" or typeName == "Unknown" {
        return
    }
    boundNames.push(name)
    boundTypes.push(typeName)
}

fun getExpressionVariableName(expr: ParserExpressionNode) r: String {
    if expr.variableName != "" {
        return expr.variableName
    }
    return expr.literalValue
}

fun findClassFieldType(classNode: ClassNode, fieldName: String) r: String {
    var i = 0
    while i < classNode.fields.length() {
        let field = classNode.fields[i]
        if field.name == fieldName {
            return field.paramType.typeName
        }
        i = i + 1
    }
    return ""
}

fun findReferencedClassFieldTypeInModules(modulePath: String, moduleProgram: ProgramNode, modulePaths: Array<String>, frontends: Array<FrontendResult>, className: String, fieldName: String) r: String {
    let referencedClass = findReferencedClassInModules(modulePath, moduleProgram, modulePaths, frontends, className)
    if referencedClass.name == "" {
        return ""
    }
    return findClassFieldType(referencedClass, fieldName)
}

fun findClassMethodReturnType(classNode: ClassNode, methodName: String) r: String {
    var i = 0
    while i < classNode.methods.length() {
        let method = classNode.methods[i]
        if method.name == methodName {
            return method.returnType.typeName
        }
        i = i + 1
    }
    return ""
}

fun findReferencedClassMethodReturnTypeInModules(modulePath: String, moduleProgram: ProgramNode, modulePaths: Array<String>, frontends: Array<FrontendResult>, className: String, methodName: String) r: String {
    let referencedClass = findReferencedClassInModules(modulePath, moduleProgram, modulePaths, frontends, className)
    if referencedClass.name == "" {
        return ""
    }
    return findClassMethodReturnType(referencedClass, methodName)
}

fun findReferencedFunctionInModules(modulePath: String, moduleProgram: ProgramNode, modulePaths: Array<String>, frontends: Array<FrontendResult>, functionName: String) r: FunctionNode {
    let localFunc = findProgramFunction(moduleProgram, functionName)
    if localFunc.name != "" {
        return localFunc
    }
    let directlyImported = findImportedFunctionInModules(modulePath,
        moduleProgram, modulePaths, frontends, functionName)
    if directlyImported.name != "" {
        return directlyImported
    }
    let moduleVisible = findFunctionInAnyParsedModule(modulePaths, frontends,
        functionName)
    if moduleVisible.name != "" {
        return moduleVisible
    }
    return findFunctionImportedByAnyModuleInModules(modulePaths, frontends,
        functionName)
}

fun inferExpressionTypeNameInModules(modulePath: String, moduleProgram: ProgramNode, modulePaths: Array<String>, frontends: Array<FrontendResult>, expr: ParserExpressionNode, boundNames: Array<String>, boundTypes: Array<String>, ownerClassName: String) r: String {
    if expr.kind == "None" or expr.kind == "" {
        return ""
    }

    if expr.kind == "Literal" {
        return expr.literalType
    }

    if expr.kind == "StructLiteral" {
        return expr.literalType
    }

    if expr.kind == "VarExpr" {
        let varName = getExpressionVariableName(expr)
        let boundType = lookupBoundType(boundNames, boundTypes, varName)
        if boundType != "" {
            return boundType
        }
        if ownerClassName != "" {
            let fieldType = findReferencedClassFieldTypeInModules(modulePath, moduleProgram, modulePaths, frontends, ownerClassName, varName)
            if fieldType != "" {
                return fieldType
            }
        }
        return ""
    }

    if expr.kind == "Call" {
        let referencedFunc = findReferencedFunctionInModules(modulePath, moduleProgram, modulePaths, frontends, expr.callee)
        if referencedFunc.name != "" {
            return referencedFunc.returnType.typeName
        }
        return ""
    }

    if expr.kind == "MemberAccess" or expr.kind == "MethodCall" {
        var receiverType = ""
        if expr.literalValue != "" {
            let receiverName = expr.literalValue
            if receiverName == "this" and ownerClassName != "" {
                receiverType = ownerClassName
            }
            if receiverType == "" {
                receiverType = lookupBoundType(boundNames, boundTypes, receiverName)
            }
            if receiverType == "" and ownerClassName != "" {
                receiverType = findReferencedClassFieldTypeInModules(modulePath, moduleProgram, modulePaths, frontends, ownerClassName, receiverName)
            }
            if receiverType == "" {
                let receiverEnum = findReferencedEnumInModules(modulePath, moduleProgram, modulePaths, frontends, receiverName)
                if receiverEnum.name != "" and enumHasVariant(receiverEnum, expr.variableName) {
                    return receiverName
                }
            }
        }
        if receiverType == "" and expr.operands.length() > 0 {
            receiverType = inferExpressionTypeNameInModules(modulePath, moduleProgram, modulePaths, frontends, expr.operands[0], boundNames, boundTypes, ownerClassName)
        }
        if receiverType != "" {
            let receiverEnum = findReferencedEnumInModules(modulePath, moduleProgram, modulePaths, frontends, receiverType)
            if receiverEnum.name != "" and enumHasVariant(receiverEnum, expr.variableName) {
                return receiverType
            }
            if expr.kind == "MethodCall" {
                let methodReturnType = findReferencedClassMethodReturnTypeInModules(modulePath, moduleProgram, modulePaths, frontends, receiverType, expr.callee)
                if methodReturnType != "" {
                    return methodReturnType
                }
            }
            let fieldType = findReferencedClassFieldTypeInModules(modulePath, moduleProgram, modulePaths, frontends, receiverType, expr.variableName)
            if fieldType != "" {
                return fieldType
            }
        }
        return ""
    }

    return ""
}

fun inferStatementBindingTypeInModules(modulePath: String, moduleProgram: ProgramNode, modulePaths: Array<String>, frontends: Array<FrontendResult>, stmt: StatementNode, boundNames: Array<String>, boundTypes: Array<String>, ownerClassName: String) r: String {
    if stmt.variableType.typeName != "" and stmt.variableType.typeName != "Unknown" {
        return stmt.variableType.typeName
    }
    return inferExpressionTypeNameInModules(modulePath, moduleProgram, modulePaths, frontends, stmt.initializer, boundNames, boundTypes, ownerClassName)
}

fun whenArmHasGuard(arm: ParserExpressionNode) r: Bool {
    return arm.operands.length() > 2
}

fun whenExpressionHasCatchAll(expr: ParserExpressionNode) r: Bool {
    var i = 0
    while i < expr.arguments.length() {
        let arm = expr.arguments[i]
        if not whenArmHasGuard(arm) and arm.operands.length() > 0 {
            let pattern = arm.operands[0]
            if pattern.variableName == "Wildcard" or pattern.variableName == "Variable" {
                return true
            }
        }
        i = i + 1
    }
    return false
}

fun whenExpressionCoversEnumVariant(expr: ParserExpressionNode, variantName: String) r: Bool {
    var i = 0
    while i < expr.arguments.length() {
        let arm = expr.arguments[i]
        if not whenArmHasGuard(arm) and arm.operands.length() > 0 {
            let pattern = arm.operands[0]
            if pattern.variableName == "Is" and pattern.literalValue == variantName {
                return true
            }
        }
        i = i + 1
    }
    return false
}

fun collectMissingEnumVariants(expr: ParserExpressionNode, enumNode: EnumNode) r: Array<String> {
    let missing = Array<String>()
    if whenExpressionHasCatchAll(expr) {
        return missing
    }

    var i = 0
    while i < enumNode.variants.length() {
        let variant = enumNode.variants[i]
        if not whenExpressionCoversEnumVariant(expr, variant) {
            missing.push(variant)
        }
        i = i + 1
    }
    return missing
}

fun joinStringArray(values: Array<String>) r: String {
    var result = ""
    var i = 0
    while i < values.length() {
        if i > 0 {
            result = result + ", "
        }
        result = result + values[i]
        i = i + 1
    }
    return result
}

fun addNonExhaustiveEnumDiagnostic(result: FrontendResult, modulePath: String, line: Int, enumName: String, missingVariants: Array<String>) r: Void {
    let missingText = joinStringArray(missingVariants)
    let message = "non-exhaustive match on enum `" + enumName + "`"
    var suggestion = "Add an else arm."
    if missingText != "" {
        suggestion = "Add arms for " + missingText + " or add an else arm."
    }
    let note = "missing cases: " + missingText
    let encoded = encodeDiagMessage(message, "E008", suggestion, note, 0)
    result.addDiagnostic(FrontendDiagnostic.new(modulePath, line, 0, "error", encoded))
}

fun checkEnumExhaustivenessExpression(result: FrontendResult, modulePath: String, moduleProgram: ProgramNode, modulePaths: Array<String>, frontends: Array<FrontendResult>, expr: ParserExpressionNode, boundNames: Array<String>, boundTypes: Array<String>, ownerClassName: String, funcLine: Int) r: Void {
    if expr.kind == "None" or expr.kind == "" {
        return
    }

    if expr.kind == "WhenExpression" and expr.operands.length() > 0 {
        let subjectType = inferExpressionTypeNameInModules(modulePath, moduleProgram, modulePaths, frontends, expr.operands[0], boundNames, boundTypes, ownerClassName)
        if subjectType != "" {
            let subjectEnum = findReferencedEnumInModules(modulePath, moduleProgram, modulePaths, frontends, subjectType)
            if subjectEnum.name != "" {
                let missingVariants = collectMissingEnumVariants(expr, subjectEnum)
                if missingVariants.length() > 0 {
                    addNonExhaustiveEnumDiagnostic(result, modulePath, funcLine, subjectEnum.name, missingVariants)
                }
            }
        }
    }

    var operandIdx = 0
    while operandIdx < expr.operands.length() {
        checkEnumExhaustivenessExpression(result, modulePath, moduleProgram, modulePaths, frontends, expr.operands[operandIdx], boundNames, boundTypes, ownerClassName, funcLine)
        operandIdx = operandIdx + 1
    }

    var argIdx = 0
    while argIdx < expr.arguments.length() {
        checkEnumExhaustivenessExpression(result, modulePath, moduleProgram, modulePaths, frontends, expr.arguments[argIdx], boundNames, boundTypes, ownerClassName, funcLine)
        argIdx = argIdx + 1
    }
}

fun checkEnumExhaustivenessStatement(result: FrontendResult, modulePath: String, moduleProgram: ProgramNode, modulePaths: Array<String>, frontends: Array<FrontendResult>, stmt: StatementNode, boundNames: Array<String>, boundTypes: Array<String>, ownerClassName: String, funcLine: Int) r: Void {
    if stmt.kind == "Let" or stmt.kind == "Var" {
        checkEnumExhaustivenessExpression(result, modulePath, moduleProgram, modulePaths, frontends, stmt.initializer, boundNames, boundTypes, ownerClassName, funcLine)
        let boundType = inferStatementBindingTypeInModules(modulePath, moduleProgram, modulePaths, frontends, stmt, boundNames, boundTypes, ownerClassName)
        addBoundType(boundNames, boundTypes, stmt.variableName, boundType)
        return
    }

    checkEnumExhaustivenessExpression(result, modulePath, moduleProgram, modulePaths, frontends, stmt.expression, boundNames, boundTypes, ownerClassName, funcLine)
    checkEnumExhaustivenessExpression(result, modulePath, moduleProgram, modulePaths, frontends, stmt.returnValue, boundNames, boundTypes, ownerClassName, funcLine)
    checkEnumExhaustivenessExpression(result, modulePath, moduleProgram, modulePaths, frontends, stmt.condition, boundNames, boundTypes, ownerClassName, funcLine)
    checkEnumExhaustivenessExpression(result, modulePath, moduleProgram, modulePaths, frontends, stmt.loopCondition, boundNames, boundTypes, ownerClassName, funcLine)
    checkEnumExhaustivenessExpression(result, modulePath, moduleProgram, modulePaths, frontends, stmt.initializer, boundNames, boundTypes, ownerClassName, funcLine)

    checkEnumExhaustivenessBlock(result, modulePath, moduleProgram, modulePaths, frontends, stmt.thenBranch, boundNames, boundTypes, ownerClassName, funcLine)
    checkEnumExhaustivenessBlock(result, modulePath, moduleProgram, modulePaths, frontends, stmt.elseBranch, boundNames, boundTypes, ownerClassName, funcLine)
    checkEnumExhaustivenessBlock(result, modulePath, moduleProgram, modulePaths, frontends, stmt.loopBody, boundNames, boundTypes, ownerClassName, funcLine)
}

fun checkEnumExhaustivenessBlock(result: FrontendResult, modulePath: String, moduleProgram: ProgramNode, modulePaths: Array<String>, frontends: Array<FrontendResult>, block: BlockNode, boundNames: Array<String>, boundTypes: Array<String>, ownerClassName: String, funcLine: Int) r: Void {
    let localNames = copyStringArray(boundNames)
    let localTypes = copyStringArray(boundTypes)
    var i = 0
    while i < block.statements.length() {
        checkEnumExhaustivenessStatement(result, modulePath, moduleProgram, modulePaths, frontends, block.statements[i], localNames, localTypes, ownerClassName, funcLine)
        i = i + 1
    }
}

fun checkEnumExhaustivenessInFunction(result: FrontendResult, modulePath: String, moduleProgram: ProgramNode, modulePaths: Array<String>, frontends: Array<FrontendResult>, func: FunctionNode, ownerClassName: String) r: Void {
    let boundNames = Array<String>()
    let boundTypes = Array<String>()
    if ownerClassName != "" {
        addBoundType(boundNames, boundTypes, "this", ownerClassName)
    }

    var paramIdx = 0
    while paramIdx < func.params.length() {
        let param = func.params[paramIdx]
        addBoundType(boundNames, boundTypes, param.name, param.paramType.typeName)
        paramIdx = paramIdx + 1
    }

    checkEnumExhaustivenessBlock(result, modulePath, moduleProgram, modulePaths, frontends, func.body, boundNames, boundTypes, ownerClassName, func.line)
}

fun isKnownCompilerBuiltinCallName(callName: String) r: Bool {
    if callName == "sizeof" or callName == "alignof" or callName == "offsetof" {
        return true
    }
    if callName == "includeStr" or callName == "includeBytes" {
        return true
    }
    if callName.startsWith("transmute<") {
        return true
    }
    if callName == "barrier" or callName == "stackAlloc" or
        callName.startsWith("stackAlloc<") or callName == "constructAt" {
        return true
    }
    if callName == "debug_assert" or callName == "abort" or
        callName == "__default" or
        callName.startsWith("__default<") {
        return true
    }
    if callName == "str_to_cstr" or callName == "cstr_to_str" or
        callName == "split" or callName == "async_yield" {
        return true
    }
    if callName.startsWith("simd_") or callName.startsWith("Simd") {
        return true
    }
    if isPtrBuiltinCallImpl(callName) == 1 {
        return true
    }
    if isOptionRuntimeCallPlanImpl(callName) {
        return true
    }
    if isPrintRuntimeCallPlanImpl(callName) {
        return true
    }
    if runtimeIoCallActionImpl(callName, 1) != 0 {
        return true
    }
    if isPanicRuntimeCallPlanImpl(callName) {
        return true
    }
    if isMathRuntimeCallPlanImpl(callName) {
        return true
    }
    if isArrayConstructorNameImpl(callName) {
        return true
    }
    if isSmallVecConstructorNameImpl(callName) {
        return true
    }
    if isCollectionConstructorNameImpl(callName) {
        return true
    }
    return false
}

fun moduleSetHasEnumVariant(variantName: String) r: Bool {
    var moduleIdx = 0
    while moduleIdx < g_validationFrontends.length() {
        let program = g_validationFrontends[moduleIdx].program
        var itemIdx = 0
        while itemIdx < program.items.length() {
            let item = program.items[itemIdx]
            if item.itemType == "Enum" {
                if enumHasVariant(item.enumNode, variantName) {
                    return true
                }
            }
            itemIdx = itemIdx + 1
        }
        moduleIdx = moduleIdx + 1
    }
    return false
}

fun isResolvableFreeFunctionCall(modulePath: String,
    moduleProgram: ProgramNode, callName: String,
    boundNames: Array<String>, boundTypes: Array<String>,
    ownerClassName: String) r: Bool {

    if callName == "" {
        return true
    }
    let resolvedCallName = stripCallGenericArguments(callName)
    if isKnownCompilerBuiltinCallName(resolvedCallName) {
        return true
    }
    if lookupBoundType(boundNames, boundTypes, resolvedCallName) != "" {
        return true
    }
    let referencedFunc = findReferencedFunctionInModules(modulePath,
        moduleProgram, g_validationModulePaths, g_validationFrontends,
        resolvedCallName)
    if referencedFunc.name != "" {
        return true
    }
    let referencedClass = findReferencedClassInModules(modulePath,
        moduleProgram, g_validationModulePaths, g_validationFrontends,
        resolvedCallName)
    if referencedClass.name != "" {
        return true
    }
    if moduleSetHasEnumVariant(resolvedCallName) {
        return true
    }
    if ownerClassName != "" {
        let methodRet = findReferencedClassMethodReturnTypeInModules(modulePath,
            moduleProgram, g_validationModulePaths, g_validationFrontends,
            ownerClassName, resolvedCallName)
        if methodRet != "" {
            return true
        }
    }
    return false
}

fun addUnresolvedFreeCallDiagnostic(result: FrontendResult,
    modulePath: String, line: Int, callName: String) r: Void {

    let message = encodeDiagMessage(
        "unresolved function `" + callName + "`",
        "E009",
        "Define `" + callName + "` or import it before calling it.",
        "",
        0
    )
    result.addDiagnostic(FrontendDiagnostic.new(modulePath, line, 0, "error",
        message))
}

fun sourceTextImportMentionsResolvableSymbol(modulePath: String,
    symbolName: String) r: Bool {

    let content = readText(modulePath)
    if content == "" {
        return false
    }

    let sourceDir = getSourceDir(modulePath)
    var lineStart = 0
    var pos = 0
    while pos <= content.length() {
        var atEnd = 0
        if pos == content.length() {
            atEnd = 1
        }
        var isNewline = 0
        if atEnd == 0 {
            if content.byteAt(pos) == 10 {
                isNewline = 1
            }
        }
        if isNewline == 1 or atEnd == 1 {
            let importText = sourceImportBodyFromLine(content.substring(lineStart, pos))
            if importText != "" {
                let importedSymbolName = resolveSourceTextImportedSymbolName(importText, symbolName)
                if importedSymbolName != "" {
                    let importedPath = sourceTextImportPath(importText, sourceDir)
                    if importedPath != "" and exists(importedPath) {
                        return true
                    }
                }
            }
            lineStart = pos + 1
        }
        pos = pos + 1
    }

    return false
}

fun checkUnresolvedFreeCallExpression(result: FrontendResult,
    modulePath: String, moduleProgram: ProgramNode, expr: ParserExpressionNode,
    boundNames: Array<String>, boundTypes: Array<String>,
    ownerClassName: String, funcLine: Int) r: Void {

    if expr.kind == "None" or expr.kind == "" {
        return
    }

    if expr.kind == "Call" {
        if not isResolvableFreeFunctionCall(modulePath, moduleProgram,
            expr.callee, boundNames, boundTypes, ownerClassName) {
            if not sourceTextImportMentionsResolvableSymbol(modulePath,
                stripCallGenericArguments(expr.callee)) {
                addUnresolvedFreeCallDiagnostic(result, modulePath, funcLine,
                    expr.callee)
            }
        }
    }

    var operandIdx = 0
    while operandIdx < expr.operands.length() {
        checkUnresolvedFreeCallExpression(result, modulePath, moduleProgram,
            expr.operands[operandIdx], boundNames, boundTypes, ownerClassName,
            funcLine)
        operandIdx = operandIdx + 1
    }

    var argIdx = 0
    while argIdx < expr.arguments.length() {
        checkUnresolvedFreeCallExpression(result, modulePath, moduleProgram,
            expr.arguments[argIdx], boundNames, boundTypes, ownerClassName,
            funcLine)
        argIdx = argIdx + 1
    }
}

fun checkUnresolvedFreeCallStatement(result: FrontendResult,
    modulePath: String, moduleProgram: ProgramNode, stmt: StatementNode,
    boundNames: Array<String>, boundTypes: Array<String>,
    ownerClassName: String, funcLine: Int) r: Void {

    if stmt.kind == "Let" or stmt.kind == "Var" {
        checkUnresolvedFreeCallExpression(result, modulePath, moduleProgram,
            stmt.initializer, boundNames, boundTypes, ownerClassName, funcLine)
        let boundType = inferStatementBindingTypeInModules(modulePath,
            moduleProgram, g_validationModulePaths, g_validationFrontends,
            stmt, boundNames, boundTypes, ownerClassName)
        addBoundType(boundNames, boundTypes, stmt.variableName, boundType)
        return
    }

    if stmt.kind == "Expression" and stmt.expression.kind == "Call" {
        // Direct call statements can still lower to late external declarations.
        return
    }

    checkUnresolvedFreeCallExpression(result, modulePath, moduleProgram,
        stmt.expression, boundNames, boundTypes, ownerClassName, funcLine)
    checkUnresolvedFreeCallExpression(result, modulePath, moduleProgram,
        stmt.returnValue, boundNames, boundTypes, ownerClassName, funcLine)
    checkUnresolvedFreeCallExpression(result, modulePath, moduleProgram,
        stmt.condition, boundNames, boundTypes, ownerClassName, funcLine)
    checkUnresolvedFreeCallExpression(result, modulePath, moduleProgram,
        stmt.loopCondition, boundNames, boundTypes, ownerClassName, funcLine)
    checkUnresolvedFreeCallExpression(result, modulePath, moduleProgram,
        stmt.initializer, boundNames, boundTypes, ownerClassName, funcLine)

    checkUnresolvedFreeCallBlock(result, modulePath, moduleProgram,
        stmt.thenBranch, boundNames, boundTypes, ownerClassName, funcLine)
    checkUnresolvedFreeCallBlock(result, modulePath, moduleProgram,
        stmt.elseBranch, boundNames, boundTypes, ownerClassName, funcLine)
    checkUnresolvedFreeCallBlock(result, modulePath, moduleProgram,
        stmt.loopBody, boundNames, boundTypes, ownerClassName, funcLine)
}

fun checkUnresolvedFreeCallBlock(result: FrontendResult,
    modulePath: String, moduleProgram: ProgramNode, block: BlockNode,
    boundNames: Array<String>, boundTypes: Array<String>,
    ownerClassName: String, funcLine: Int) r: Void {

    let localNames = copyStringArray(boundNames)
    let localTypes = copyStringArray(boundTypes)
    var i = 0
    while i < block.statements.length() {
        checkUnresolvedFreeCallStatement(result, modulePath, moduleProgram,
            block.statements[i], localNames, localTypes, ownerClassName,
            funcLine)
        i = i + 1
    }
}

fun checkUnresolvedFreeCallsInFunction(result: FrontendResult,
    modulePath: String, moduleProgram: ProgramNode, func: FunctionNode,
    ownerClassName: String) r: Void {

    let boundNames = Array<String>()
    let boundTypes = Array<String>()
    if ownerClassName != "" {
        addBoundType(boundNames, boundTypes, "this", ownerClassName)
    }

    var paramIdx = 0
    while paramIdx < func.params.length() {
        let param = func.params[paramIdx]
        addBoundType(boundNames, boundTypes, param.name, param.paramType.typeName)
        paramIdx = paramIdx + 1
    }

    checkUnresolvedFreeCallBlock(result, modulePath, moduleProgram, func.body,
        boundNames, boundTypes, ownerClassName, func.line)
}

fun validateSealedModules(modulePaths: Array<String>, language: String) r: FrontendResult {
    clearValidationModuleCache()
    let result = FrontendResult.new()
    let frontends = Array<FrontendResult>()

    var i = 0
    while i < modulePaths.length() {
        let frontend = parseModule(modulePaths[i], language)
        if not frontend.success {
            clearValidationModuleCache()
            return frontend
        }
        frontends.push(frontend)
        i = i + 1
    }

    g_validationModulePaths = modulePaths
    g_validationFrontends = frontends

    i = 0
    while i < modulePaths.length() {
        let modulePath = modulePaths[i]
        let program = frontends[i].program

        var itemIdx = 0
        while itemIdx < program.items.length() {
            let item = program.items[itemIdx]
            if item.itemType == "Class" {
                let cls = item.classNode
                if cls.parentName != "" {
                    let sealedModule = findImportedSealedParentModule(modulePath, program, modulePaths, frontends, cls.parentName)
                    if sealedModule != "" {
                        let message = encodeDiagMessage(
                            "sealed class `" + cls.parentName + "` cannot be extended outside `" + sealedModule + "`",
                            "E007",
                            "Move `" + cls.name + "` into `" + sealedModule + "` or remove `sealed` from `" + cls.parentName + "`.",
                            "",
                            0
                        )
                        result.addDiagnostic(FrontendDiagnostic.new(modulePath, 0, 0, "error", message))
                    }
                }
                if cls.hasDecorator("send") {
                    var sendFieldIdx = 0
                    while sendFieldIdx < cls.fields.length() {
                        let field = cls.fields[sendFieldIdx]
                        let badType = findUndecoratedReferencedClassInModules(modulePath, program, modulePaths, frontends, cls.name, field.paramType.typeName, "send")
                        if badType != "" {
                            let message = encodeDiagMessage(
                                "@send class '" + cls.name + "' cannot contain field '" + field.name + "' of type '" + badType + "' without @send",
                                "E006",
                                "Mark '" + badType + "' with @send or change field '" + field.name + "' to a compatible type.",
                                "",
                                0
                            )
                            result.addDiagnostic(FrontendDiagnostic.new(modulePath, 0, 0, "error", message))
                        }
                        sendFieldIdx = sendFieldIdx + 1
                    }
                }
                if cls.hasDecorator("sync") {
                    var syncFieldIdx = 0
                    while syncFieldIdx < cls.fields.length() {
                        let field = cls.fields[syncFieldIdx]
                        let badType = findUndecoratedReferencedClassInModules(modulePath, program, modulePaths, frontends, cls.name, field.paramType.typeName, "sync")
                        if badType != "" {
                            let message = encodeDiagMessage(
                                "@sync class '" + cls.name + "' cannot contain field '" + field.name + "' of type '" + badType + "' without @sync",
                                "E006",
                                "Mark '" + badType + "' with @sync or change field '" + field.name + "' to a compatible type.",
                                "",
                                0
                            )
                            result.addDiagnostic(FrontendDiagnostic.new(modulePath, 0, 0, "error", message))
                        }
                        syncFieldIdx = syncFieldIdx + 1
                    }
                }

                var methodIdx = 0
                while methodIdx < cls.methods.length() {
                    let method = cls.methods[methodIdx]
                    let methodName = cls.name + "." + method.name
                    checkImportedCapabilityBlock(result, modulePath, program, modulePaths, frontends, method, methodName, method.body, method.line)
                    checkEnumExhaustivenessInFunction(result, modulePath, program, modulePaths, frontends, method, cls.name)
                    checkUnresolvedFreeCallsInFunction(result, modulePath,
                        program, method, cls.name)
                    methodIdx = methodIdx + 1
                }
            }

            if item.itemType == "Function" {
                let func = item.function
                checkImportedCapabilityBlock(result, modulePath, program, modulePaths, frontends, func, func.name, func.body, func.line)
                checkEnumExhaustivenessInFunction(result, modulePath, program, modulePaths, frontends, func, "")
                checkUnresolvedFreeCallsInFunction(result, modulePath, program,
                    func, "")
            }
            itemIdx = itemIdx + 1
        }

        i = i + 1
    }

    if not result.hasErrors() {
        result.success = true
    }
    clearValidationModuleCache()
    return result
}

///
Collect ML training data from LLVM optimization remarks YAML file.
Parses the YAML line-by-line extracting Pass/Name/Function fields from
each remark block (delimited by "---" or "..."), and appends tab-separated
records to outputPath. Used with --ml-log to build training datasets for
the ML-guided optimization heuristics.
///
fun collectMLTrainingData(remarksFile: String, outputPath: String) r: Void {
    let content = readText(remarksFile)
    if content.length() == 0 {
        return
    }
    ///
    Parse YAML remarks line-by-line, extracting Pass/Name/Function/Args fields
    LLVM remarks YAML format: key-value lines like "Pass: loop-vectorize"
    ///
    var mlData = ""
    var lineStart = 0
    var i = 0
    var curPass = ""
    var curName = ""
    var curFunc = ""
    while i <= content.length() {
        var isNewline = false
        if i == content.length() { isNewline = true }
        if not isNewline {
            if content.substring(i, i + 1) == "\n" { isNewline = true }
        }
        if isNewline {
            if i > lineStart {
                let line = content.substring(lineStart, i)
                // Check for "Pass:" prefix (with optional leading spaces/dashes)
                if contains(line, "Pass:") {
                    // Extract value after "Pass:"
                    var pIdx = 0
                    var pFound = false
                    while pIdx < line.length() - 5 {
                        if line.substring(pIdx, pIdx + 5) == "Pass:" {
                            curPass = line.substring(pIdx + 5, line.length())
                            // Trim leading space
                            if curPass.length() > 0 {
                                if curPass.substring(0, 1) == " " {
                                    curPass = curPass.substring(1, curPass.length())
                                }
                            }
                            pFound = true
                        }
                        pIdx = pIdx + 1
                    }
                }
                if contains(line, "Name:") {
                    var nIdx = 0
                    while nIdx < line.length() - 5 {
                        if line.substring(nIdx, nIdx + 5) == "Name:" {
                            curName = line.substring(nIdx + 5, line.length())
                            if curName.length() > 0 {
                                if curName.substring(0, 1) == " " {
                                    curName = curName.substring(1, curName.length())
                                }
                            }
                        }
                        nIdx = nIdx + 1
                    }
                }
                if contains(line, "Function:") {
                    var fIdx = 0
                    while fIdx < line.length() - 9 {
                        if line.substring(fIdx, fIdx + 9) == "Function:" {
                            curFunc = line.substring(fIdx + 9, line.length())
                            if curFunc.length() > 0 {
                                if curFunc.substring(0, 1) == " " {
                                    curFunc = curFunc.substring(1, curFunc.length())
                                }
                            }
                        }
                        fIdx = fIdx + 1
                    }
                }
                // End of a remark block (starts with "---" or "...")
                if line.startsWith("---") or line.startsWith("...") {
                    if curPass != "" and curName != "" {
                        mlData = mlData + curPass + "\t" + curName + "\t" + curFunc + "\n"
                    }
                    curPass = ""
                    curName = ""
                    curFunc = ""
                }
            }
            lineStart = i + 1
        }
        i = i + 1
    }
    // Flush last remark if file doesn't end with ---
    if curPass != "" and curName != "" {
        mlData = mlData + curPass + "\t" + curName + "\t" + curFunc + "\n"
    }
    if mlData.length() > 0 {
        let existing = readText(outputPath)
        writeText(outputPath, existing + mlData)
    }
}

///
Format LLVM vectorization remarks into a structured report
Uses contains() which is available in stage1 from C runtime
///
fun formatSimdReport(output: String) r: String {
    // Count vectorized and missed loops by scanning for known substrings
    var vectorizedCount = 0
    var missedCount = 0
    // Count occurrences by checking for multiple markers
    if contains(output, "vectorized loop") {
        vectorizedCount = 1
        // Rough heuristic: check for multiple remark lines
        if contains(output, "vectorized loop (vectorization width: 8)") {
            vectorizedCount = vectorizedCount + 1
        }
    }
    if contains(output, "loop not vectorized") {
        missedCount = 1
    }
    if vectorizedCount == 0 {
        if missedCount == 0 {
            return ""
        }
    }
    var result = "=== SIMD Vectorization Report ===\n"
    result = result + "Vectorized loops: " + vectorizedCount.toString() + "\n"
    result = result + "Missed loops:     " + missedCount.toString() + "\n"
    result = result + "=================================\n"
    result = result + "\nRaw remarks:\n" + output
    return result
}

///
Convenience entry points for compilation. All delegate to compileCommandWithAllOptions
which contains the full pipeline. These exist because the bootstrap compiler cannot
handle default parameter values, so each call site uses the variant with the fewest
parameters it needs.
///
fun compileCommand(inputFile: String, outputFile: String) r: Int {
    return compileCommandWithOptions(inputFile, outputFile, "default", false, true)
}

fun compileCommandWithLanguage(inputFile: String, outputFile: String, language: String) r: Int {
    return compileCommandWithAllOptions(inputFile, outputFile, "default", false, true, language, "", "auto", false, "", "", "", "", "")
}

fun compileCommandWithProfile(inputFile: String, outputFile: String, profile: String) r: Int {
    return compileCommandWithOptions(inputFile, outputFile, profile, false, true)
}

fun compileCommandWithTargeting(inputFile: String, outputFile: String, profile: String, useCache: Bool, targetCpu: String, simdPolicy: String, simdReport: Bool) r: Int {
    return compileCommandWithAllOptions(inputFile, outputFile, profile, false, useCache, "en", targetCpu, simdPolicy, simdReport, "", "", "", "", "")
}

fun compileCommandWithFullTargeting(inputFile: String, outputFile: String, profile: String, useCache: Bool, language: String, targetCpu: String, simdPolicy: String, simdReport: Bool, sanitizePolicy: String, pgoMode: String, pgoPath: String, mlLogPath: String, crossTarget: String) r: Int {
    return compileCommandWithAllOptions(inputFile, outputFile, profile, false, useCache, language, targetCpu, simdPolicy, simdReport, sanitizePolicy, pgoMode, pgoPath, mlLogPath, crossTarget)
}

fun targetIsIosSimulatorName(target: String) r: Bool {
    if target == "" {
        return false
    }
    if target == "ios-sim-arm64" or target == "arm64-apple-ios-simulator" or target == "aarch64-apple-ios-simulator" or target == "arm64-apple-ios17.0-simulator" or target == "aarch64-apple-ios17.0-simulator" {
        return true
    }
    if (target.startsWith("arm64-apple-ios") or target.startsWith("aarch64-apple-ios")) and target.contains("simulator") {
        return true
    }
    return false
}

fun targetIsIosDeviceName(target: String) r: Bool {
    if target == "" {
        return false
    }
    if target == "ios-arm64" or target == "arm64-apple-ios" or target == "aarch64-apple-ios" or target == "arm64-apple-ios17.0" or target == "aarch64-apple-ios17.0" {
        return true
    }
    if (target.startsWith("arm64-apple-ios") or target.startsWith("aarch64-apple-ios")) and not target.contains("simulator") {
        return true
    }
    return false
}

fun targetIsIosFamily(target: String) r: Bool {
    return targetIsIosDeviceName(target) or targetIsIosSimulatorName(target)
}

fun normalizeCrossTargetName(target: String) r: String {
    if target == "" {
        return ""
    }
    if targetIsIosSimulatorName(target) {
        return "ios-sim-arm64"
    }
    if targetIsIosDeviceName(target) {
        return "ios-arm64"
    }
    if target == "macos-arm64" or target == "arm64-apple-darwin" or target == "aarch64-apple-darwin" {
        return "macos-arm64"
    }
    if target == "macos-x86_64" or target == "x86_64-apple-darwin" {
        return "macos-x86_64"
    }
    if target == "linux-x86_64" or target == "x86_64-linux-gnu" or target == "x86_64-unknown-linux-gnu" {
        return "linux-x86_64"
    }
    if target == "linux-arm64" or target == "aarch64-linux-gnu" or target == "aarch64-unknown-linux-gnu" {
        return "linux-arm64"
    }
    if target == "windows-x86_64" or target == "windows-gnu-x86_64" or target == "x86_64-pc-windows-msvc" or target == "x86_64-w64-windows-gnu" {
        return "windows-x86_64"
    }
    if target == "android-arm64" or target == "aarch64-linux-android" or target == "aarch64-linux-android24" {
        return "android-arm64"
    }
    return target
}

fun detectHostTargetName() r: String {
    let unameS: CommandResult = runCommand("uname -s")
    let unameM: CommandResult = runCommand("uname -m")
    var os = "linux"
    var arch = "x86_64"
    if commandWasSuccessful(unameS) {
        if unameS.output.contains("Darwin") {
            os = "darwin"
        }
    }
    if commandWasSuccessful(unameM) {
        if unameM.output.contains("arm64") or unameM.output.contains("aarch64") {
            arch = "arm64"
        }
    }
    if os == "darwin" {
        if arch == "arm64" {
            return "macos-arm64"
        }
        return "macos-x86_64"
    }
    if arch == "arm64" {
        return "linux-arm64"
    }
    return "linux-x86_64"
}

fun getAndroidApiLevel() r: String {
    let apiResult: CommandResult = runCommand("printf '%s' \"$ANDROID_API_LEVEL\"")
    if commandWasSuccessful(apiResult) {
        let apiLevel = apiResult.output.trim()
        if apiLevel != "" {
            return apiLevel
        }
    }
    return "24"
}

fun getAndroidNdkRoot() r: String {
    let ndkHomeResult: CommandResult = runCommand("printf '%s' \"$ANDROID_NDK_HOME\"")
    if commandWasSuccessful(ndkHomeResult) {
        let ndkHome = ndkHomeResult.output.trim()
        if ndkHome != "" {
            let validateHome: CommandResult = runCommand("test -d " + ndkHome)
            if commandWasSuccessful(validateHome) {
                return ndkHome
            }
        }
    }
    let ndkRootResult: CommandResult = runCommand("printf '%s' \"$ANDROID_NDK_ROOT\"")
    if commandWasSuccessful(ndkRootResult) {
        let ndkRoot = ndkRootResult.output.trim()
        if ndkRoot != "" {
            let validateRoot: CommandResult = runCommand("test -d " + ndkRoot)
            if commandWasSuccessful(validateRoot) {
                return ndkRoot
            }
        }
    }
    return ""
}

fun getAndroidNdkHostTag() r: String {
    let unameS: CommandResult = runCommand("uname -s")
    let unameM: CommandResult = runCommand("uname -m")
    var hostOs = "linux"
    var hostArch = "x86_64"
    if commandWasSuccessful(unameS) {
        if unameS.output.contains("Darwin") {
            hostOs = "darwin"
        }
    }
    if commandWasSuccessful(unameM) {
        if unameM.output.contains("arm64") or unameM.output.contains("aarch64") {
            hostArch = "arm64"
        }
    }
    return hostOs + "-" + hostArch
}

fun getAndroidSysroot() r: String {
    let ndkRoot = getAndroidNdkRoot()
    if ndkRoot == "" {
        return ""
    }
    let hostTag = getAndroidNdkHostTag()
    let sysroot = ndkRoot + "/toolchains/llvm/prebuilt/" + hostTag + "/sysroot"
    let validateSysroot: CommandResult = runCommand("test -d " + sysroot)
    if commandWasSuccessful(validateSysroot) {
        return sysroot
    }
    return ""
}

fun getLinuxArm64Sysroot() r: String {
    let sysrootEnvResult: CommandResult = runCommand("printf '%s' \"$SEEN_LINUX_ARM64_SYSROOT\"")
    if commandWasSuccessful(sysrootEnvResult) {
        let sysrootEnv = sysrootEnvResult.output.trim()
        if sysrootEnv != "" {
            let validateEnv: CommandResult = runCommand("test -d " + sysrootEnv)
            if commandWasSuccessful(validateEnv) {
                return sysrootEnv
            }
        }
    }
    let usrSysrootCheck: CommandResult = runCommand("test -d /usr/aarch64-linux-gnu")
    if commandWasSuccessful(usrSysrootCheck) {
        return "/usr/aarch64-linux-gnu"
    }
    let usrLocalSysrootCheck: CommandResult = runCommand("test -d /usr/local/aarch64-linux-gnu")
    if commandWasSuccessful(usrLocalSysrootCheck) {
        return "/usr/local/aarch64-linux-gnu"
    }
    let optSysrootCheck: CommandResult = runCommand("test -d /opt/aarch64-linux-gnu")
    if commandWasSuccessful(optSysrootCheck) {
        return "/opt/aarch64-linux-gnu"
    }
    return ""
}

fun getLinuxArm64GccToolchain(sysroot: String) r: String {
    let toolchainEnvResult: CommandResult = runCommand("printf '%s' \"$SEEN_LINUX_ARM64_GCC_TOOLCHAIN\"")
    if commandWasSuccessful(toolchainEnvResult) {
        let toolchainEnv = toolchainEnvResult.output.trim()
        if toolchainEnv != "" {
            let validateEnv: CommandResult = runCommand("test -d " + toolchainEnv)
            if commandWasSuccessful(validateEnv) {
                return toolchainEnv
            }
        }
    }
    if sysroot != "" {
        let parentDirResult: CommandResult = runCommand("dirname " + sysroot)
        if commandWasSuccessful(parentDirResult) {
            let parentDir = parentDirResult.output.trim()
            if parentDir != "" {
                let gccDirCheck: CommandResult = runCommand("test -d " + parentDir + "/lib/gcc/aarch64-linux-gnu")
                if commandWasSuccessful(gccDirCheck) {
                    return parentDir
                }
            }
        }
    }
    let gccPathResult: CommandResult = runCommand("command -v aarch64-linux-gnu-gcc 2>/dev/null")
    if commandWasSuccessful(gccPathResult) {
        let gccPath = gccPathResult.output.trim()
        if gccPath != "" {
            let gccBinDirResult: CommandResult = runCommand("dirname " + gccPath)
            if commandWasSuccessful(gccBinDirResult) {
                let gccBinDir = gccBinDirResult.output.trim()
                if gccBinDir != "" {
                    let toolchainRootResult: CommandResult = runCommand("dirname " + gccBinDir)
                    if commandWasSuccessful(toolchainRootResult) {
                        let toolchainRoot = toolchainRootResult.output.trim()
                        if toolchainRoot != "" {
                            return toolchainRoot
                        }
                    }
                }
            }
        }
    }
    return ""
}

fun sourcesNeedGpuRuntime(modulePaths: Array<String>) r: Bool {
    var mi = 0
    while mi < modulePaths.length() {
        let sourceText = readText(modulePaths[mi])
        if sourceText.contains("@compute") or sourceText.contains("@vertex") or sourceText.contains("@fragment") {
            return true
        }
        if sourceText.contains("Buffer<") or sourceText.contains("Uniform<") or sourceText.contains("Image<") {
            return true
        }
        mi = mi + 1
    }
    return false
}

fun sourcesNeedHotReloadRuntime(modulePaths: Array<String>) r: Bool {
    var mi = 0
    while mi < modulePaths.length() {
        let modulePath = modulePaths[mi]
        if modulePath.endsWith("/seen_std/src/framework/hotreload.seen") or
            modulePath.endsWith("seen_std/src/framework/hotreload.seen") {

            return true
        }
        let sourceText = readText(modulePath)
        if sourceText.contains("__seen_hotreload_") {
            return true
        }
        mi = mi + 1
    }
    return false
}

fun targetNeedsPthreadCompileFlag(target: String) r: Bool {
    if target == "windows-x86_64" {
        return false
    }
    return true
}

fun targetNeedsPicCompileFlag(target: String) r: Bool {
    if target == "windows-x86_64" {
        return false
    }
    if g_picMode == 1 {
        return true
    }
    if target == "android-arm64" {
        return true
    }
    return false
}

fun buildTargetRuntimeCompileFlags(target: String) r: String {
    var flags = ""
    if targetNeedsPthreadCompileFlag(target) {
        flags = flags + " -pthread"
    }
    if targetNeedsPicCompileFlag(target) {
        flags = flags + " -fPIC"
    }
    if target == "windows-x86_64" {
        flags = flags + " -D_WIN32_WINNT=0x0601"
    }
    if target == "android-arm64" {
        flags = flags + " -D__ANDROID_API__=" + getAndroidApiLevel()
    }
    return flags
}

fun targetSupportsRegionRuntime(target: String) r: Bool {
    if target == "linux-x86_64" or target == "linux-arm64" or target == "android-arm64" {
        return true
    }
    return false
}

fun targetSupportsGpuRuntime(target: String) r: Bool {
    if targetIsIosFamily(target) or target == "windows-x86_64" {
        return false
    }
    return true
}

fun getHostVulkanCflags() r: String {
    let vulkanCheck: CommandResult = runCommand("pkg-config --exists vulkan 2>/dev/null")
    if commandWasSuccessful(vulkanCheck) {
        let cflagsResult: CommandResult = runCommand("pkg-config --cflags vulkan 2>/dev/null")
        if commandWasSuccessful(cflagsResult) {
            return cflagsResult.output.trim()
        }
    }
    return ""
}

fun pkgConfigExists(pkg: String) r: Bool {
    let pkgResult: CommandResult = runCommand("pkg-config --exists " + pkg + " 2>/dev/null")
    return commandWasSuccessful(pkgResult)
}

fun pkgConfigOutput(flag: String, pkg: String) r: String {
    let pkgResult: CommandResult = runCommand("pkg-config " + flag + " " + pkg + " 2>/dev/null")
    if commandWasSuccessful(pkgResult) {
        return pkgResult.output.trim()
    }
    return ""
}

fun sourcesNeedLinuxPlatformVulkanShim(modulePaths: Array<String>) r: Bool {
    var mi = 0
    while mi < modulePaths.length() {
        let modulePath = modulePaths[mi]
        if modulePath.endsWith("/seen_std/src/platform/linux/vulkan.seen") or modulePath.endsWith("/seen_std/src/graphics/renderer.seen") {
            return true
        }
        mi = mi + 1
    }
    return false
}

