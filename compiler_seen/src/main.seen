///
Wrapper to avoid symbol collision with the runtime's built-in println.
Uses println() directly rather than writing to /dev/stdout to avoid
file descriptor quirks in the runtime.
///
fun printLn(text: String) r: Void {
    println(text)
    return
}

extern fun __FileExists(path: String) r: Bool
extern fun __OpenFile(path: String, mode: String) r: Int
extern fun __VerifyStringABI(testString: String) r: Int
extern fun __WriteFile(fd: Int, content: String) r: Int
extern fun __CloseFile(fd: Int) r: Int

fun myWriteText(path: String, content: String) r: Bool {
    let abi = __VerifyStringABI(content)
    if abi == 0 {
        printLn("String ABI mismatch or corruption detected in myWriteText!")
        return false
    }
    let fd = __OpenFile(path, "w")
    if fd < 0 {
        printLn("Failed to open file: " + path)
        return false
    }
    let written = __WriteFile(fd, content)
    let _ = __CloseFile(fd)
    return written >= 0
}

///
Aggregated compiler settings from CLI flag parsing.
Constructed by parseCompilerOptions() from positional args and flags,
then consumed by buildCommandWithOptions() to select backend and target.
///
class CompilerOptions {
    var sourceFile: String
    var outputFile: String
    var target: Target
    var targetSpecified: Bool
    var debugMode: Bool
    var optimizationLevel: Int
    var profile: String  // "default" or "deterministic"
    var backend: String  // "llvm" or "c"
    var language: String  // Source language: "en", "ar", "es", "ru", "zh", "ja"

    fun new() r: CompilerOptions {
        sourceFile = ""
        outputFile = ""
        target = Target.Linux_x86_64  // Default native target
        targetSpecified = false
        debugMode = false
        optimizationLevel = 2
        profile = "default"
        backend = "llvm"
        language = "en"  // Default to English
    }

    fun isDeterministic() r: Bool {
        return profile == "deterministic"
    }
}

fun main() r: Int {
    let args = GetCommandLineArgs()
    if args.size() < 2 {
        printUsage()
        return 1
    }

    var exit: Int = 0
    let command = args[1]
    if command == "build" {
        let options = parseCompilerOptions(args, 2)
        if options.sourceFile == "" {
            printLn("Error: build command requires a source file")
            return 1
        }
        if options.outputFile == "" {
            options.outputFile = getDefaultOutput(options.sourceFile, options.target)
        }
        // Read language from Seen.toml [project] if CLI didn't explicitly set --language
        if not hasLanguageFlag(args, 2) {
            let tc = readNearestSeenTomlForInput(options.sourceFile)
            if tc != "" {
                let tl = extractTomlLanguage(tc)
                if tl != "" {
                    options.language = tl
                }
            }
        }
        exit = buildCommandWithOptions(options)
    } else if command == "check" {
        let sourceFile = requireArg(args, 2, "Error: check command requires a source file")
        // Parse language from remaining args, then check Seen.toml
        var language = parseLanguageFlag(args, 3)
        if not hasLanguageFlag(args, 3) {
            let tc = readNearestSeenTomlForInput(sourceFile)
            if tc != "" {
                let tl = extractTomlLanguage(tc)
                if tl != "" {
                    language = tl
                }
            }
        }
        exit = checkCommand(sourceFile, language)

    } else if command == "run" {
        let sourceFile = requireArg(args, 2, "Error: run command requires a source file")
        // Parse language from remaining args, then check Seen.toml
        var language = parseLanguageFlag(args, 3)
        if not hasLanguageFlag(args, 3) {
            let tc = readNearestSeenTomlForInput(sourceFile)
            if tc != "" {
                let tl = extractTomlLanguage(tc)
                if tl != "" {
                    language = tl
                }
            }
        }
        exit = runCommand_seen(sourceFile, language)
    } else if command == "init" {
        let projectName = requireArg(args, 2, "Error: init command requires a project name")
        exit = initCommand(projectName)
    } else if command == "format" or command == "fmt" {
        let sourceFile = requireArg(args, 2, "Error: format command requires a source file")
        exit = formatCommand(sourceFile)
    } else if command == "clean" {
        exit = cleanCommand()
    } else if command == "test" {
        exit = testCommand()
    } else if command == "lsp" {
        exit = lspCommand()
    } else if command == "translate" {
        exit = translateCommand(args)
    } else if command == "import-c" {
        let headerFile = requireArg(args, 2, "Error: import-c command requires a header file path")
        exit = importCCommand(headerFile)
    } else if command == "pkg" {
        exit = StagePkgCommand(GetRawCommandLineArgs())
    } else if command == "--version" or command == "-v" {
        printLn("Seen 0.6.0 (100% self-hosted)")
        printLn("Language: Seen")
        printLn("Targets: native, wasm, uww, c, llvm-ir")
        exit = 0
    } else if command == "--help" or command == "-h" {
        printUsage()
        exit = 0
    } else {
        printLn("Error: Unknown command '" + command + "'")
        printUsage()
        exit = 1
    }

    return exit
}

// Parse compiler options from command line arguments
fun parseCompilerOptions(args: List<String>, startIndex: Int) r: CompilerOptions {
    let options = CompilerOptions.new()
    var i = startIndex

    while i < args.size() {
        let arg = args[i]

        if arg == "--target" or arg == "-t" {
            // Next argument is the target
            if i + 1 < args.size() {
                let targetStr = args[i + 1]
                options.target = parseTarget(targetStr)
                if options.target == Target.Unsupported {
                    printLn("Warning: Unknown target '" + targetStr + "', using default")
                    options.target = Target.Linux_x86_64
                } else {
                    options.targetSpecified = true
                }
                i = i + 2
            } else {
                printLn("Error: --target requires an argument")
                i = i + 1
            }
        } else if arg == "-o" or arg == "--output" {
            // Next argument is the output file
            if i + 1 < args.size() {
                options.outputFile = args[i + 1]
                i = i + 2
            } else {
                printLn("Error: -o requires an argument")
                i = i + 1
            }
        } else if arg == "--debug" or arg == "-g" {
            options.debugMode = true
            i = i + 1
        } else if arg == "-O0" {
            options.optimizationLevel = 0
            i = i + 1
        } else if arg == "-O1" {
            options.optimizationLevel = 1
            i = i + 1
        } else if arg == "-O2" {
            options.optimizationLevel = 2
            i = i + 1
        } else if arg == "-O3" {
            options.optimizationLevel = 3
            i = i + 1
        } else if arg == "--release" {
            options.optimizationLevel = 3
            i = i + 1
        } else if arg == "--backend" {
            if i + 1 < args.size() {
                options.backend = args[i + 1]
                i = i + 2
            } else {
                printLn("Error: --backend requires an argument (llvm or c)")
                i = i + 1
            }
        } else if arg == "--backend=c" {
            options.backend = "c"
            i = i + 1
        } else if arg == "--backend=llvm" {
            options.backend = "llvm"
            i = i + 1
        } else if arg == "--profile" {
            // Next argument is the profile name
            if i + 1 < args.size() {
                let profileStr = args[i + 1]
                if profileStr == "deterministic" or profileStr == "default" {
                    options.profile = profileStr
                } else {
                    printLn("Warning: Unknown profile '" + profileStr + "', using default")
                    options.profile = "default"
                }
                i = i + 2
            } else {
                printLn("Error: --profile requires an argument")
                i = i + 1
            }
        } else if arg == "--language" or arg == "-l" {
            // Next argument is the language code
            if i + 1 < args.size() {
                options.language = args[i + 1]
                i = i + 2
            } else {
                printLn("Error: --language requires an argument")
                i = i + 1
            }
        } else if arg.startsWith("-") {
            printLn("Warning: Unknown option '" + arg + "'")
            i = i + 1
        } else {
            // Positional argument - source file
            if options.sourceFile == "" {
                options.sourceFile = arg
            } else if options.outputFile == "" {
                options.outputFile = arg
            }
            i = i + 1
        }
    }

    return options
}

// Get default output filename based on target
fun getDefaultOutput(sourceFile: String, target: Target) r: String {
    let baseName = if sourceFile.endsWith(".seen") {
        sourceFile.substring(0, sourceFile.length() - 5)
    } else {
        sourceFile
    }

    return match target {
        Target.WASM -> baseName + ".wasm"
        Target.UWW -> baseName + ".wasm"
        Target.C -> baseName + ".c"
        Target.LLVM_IR -> baseName + ".ll"
        Target.Windows_x86_64 -> baseName + ".exe"
        Target.Android_ARM64 -> "lib" + baseName + ".so"
        _ -> baseName  // Native executable
    }
}

