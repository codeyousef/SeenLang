// ir_binary_expr.seen — Shared binary expression IR emitters
// Extracted from llvm_ir_gen.seen to reduce expression-lowering sprawl.

import str.string.{StringBuilder}
import codegen.ir_optimization.{getNextRegFn}

// emitPointerArithmeticBinaryImpl — lower pointer +/- integer and pointer - pointer.
// Returns "" when the caller should fall through.
fun emitPointerArithmeticBinaryImpl(output: StringBuilder, regBox: Array<Int>,
    operator: String, leftType: String, rightType: String, leftReg: String, rightReg: String) r: String {

    if not leftType.startsWith("*") {
        return ""
    }
    if operator != "+" and operator != "-" {
        return ""
    }

    var offsetReg = rightReg
    if operator == "-" and not rightType.startsWith("*") {
        offsetReg = getNextRegFn(regBox)
        output.append("  " + offsetReg + " = sub i64 0, " + rightReg + "\n")
    }
    if rightType.startsWith("*") {
        let diffReg = getNextRegFn(regBox)
        output.append("  " + diffReg + " = sub i64 " + leftReg + ", " + rightReg + " ; ptr - ptr\n")
        return diffReg
    }

    let resultReg = getNextRegFn(regBox)
    output.append("  " + resultReg + " = call i64 @seen_ptr_add(i64 " + leftReg + ", i64 " + offsetReg + ", i64 1) ; ptr arithmetic\n")
    return resultReg
}

fun simdComparisonPredicateImpl(operator: String, isFloat: Int) r: String {
    if isFloat == 1 {
        if operator == "==" { return "oeq" }
        if operator == "!=" { return "one" }
        if operator == "<" { return "olt" }
        if operator == ">" { return "ogt" }
        if operator == "<=" { return "ole" }
        if operator == ">=" { return "oge" }
        return ""
    }
    if operator == "==" { return "eq" }
    if operator == "!=" { return "ne" }
    if operator == "<" { return "slt" }
    if operator == ">" { return "sgt" }
    if operator == "<=" { return "sle" }
    if operator == ">=" { return "sge" }
    return ""
}

// emitSimdBinaryExprImpl — lower SIMD arithmetic and comparison operations.
// Returns "" when the caller should fall through.
fun emitSimdBinaryExprImpl(output: StringBuilder, regBox: Array<Int>,
    operator: String, leftType: String, simdLlvmType: String, leftReg: String, rightReg: String) r: String {

    if not leftType.startsWith("f32") and not leftType.startsWith("f64") and
        not leftType.startsWith("i32") {
        return ""
    }

    let resultReg = getNextRegFn(regBox)
    var isFloat = 0
    if leftType.startsWith("f32") or leftType.startsWith("f64") { isFloat = 1 }

    if operator == "+" {
        if isFloat == 1 {
            output.append("  " + resultReg + " = fadd " + simdLlvmType + " " + leftReg + ", " + rightReg + "\n")
        } else {
            output.append("  " + resultReg + " = add " + simdLlvmType + " " + leftReg + ", " + rightReg + "\n")
        }
        return resultReg
    }
    if operator == "-" {
        if isFloat == 1 {
            output.append("  " + resultReg + " = fsub " + simdLlvmType + " " + leftReg + ", " + rightReg + "\n")
        } else {
            output.append("  " + resultReg + " = sub " + simdLlvmType + " " + leftReg + ", " + rightReg + "\n")
        }
        return resultReg
    }
    if operator == "*" {
        if isFloat == 1 {
            output.append("  " + resultReg + " = fmul " + simdLlvmType + " " + leftReg + ", " + rightReg + "\n")
        } else {
            output.append("  " + resultReg + " = mul " + simdLlvmType + " " + leftReg + ", " + rightReg + "\n")
        }
        return resultReg
    }
    if operator == "/" {
        if isFloat == 1 {
            output.append("  " + resultReg + " = fdiv " + simdLlvmType + " " + leftReg + ", " + rightReg + "\n")
        } else {
            output.append("  " + resultReg + " = sdiv " + simdLlvmType + " " + leftReg + ", " + rightReg + "\n")
        }
        return resultReg
    }

    let predicate = simdComparisonPredicateImpl(operator, isFloat)
    if predicate != "" {
        if isFloat == 1 {
            output.append("  " + resultReg + " = fcmp " + predicate + " " + simdLlvmType + " " + leftReg + ", " + rightReg + "\n")
        } else {
            output.append("  " + resultReg + " = icmp " + predicate + " " + simdLlvmType + " " + leftReg + ", " + rightReg + "\n")
        }
        return resultReg
    }

    return ""
}

fun binaryOperatorMethodSuffixImpl(operator: String) r: String {
    if operator == "+" { return "operator_add" }
    if operator == "-" { return "operator_sub" }
    if operator == "*" { return "operator_mul" }
    if operator == "/" { return "operator_div" }
    if operator == "%" { return "operator_mod" }
    if operator == "==" { return "operator_eq" }
    if operator == "!=" { return "operator_neq" }
    if operator == "<" { return "operator_lt" }
    if operator == ">" { return "operator_gt" }
    if operator == "<=" { return "operator_lte" }
    if operator == ">=" { return "operator_gte" }
    return ""
}

// emitOverloadedBinaryCallImpl — lower user-defined operator overload calls.
fun emitOverloadedBinaryCallImpl(output: StringBuilder, regBox: Array<Int>,
    quotedFuncName: String, retLlvmType: String, leftReg: String, rightReg: String) r: String {

    let thisPtrReg = getNextRegFn(regBox)
    output.append("  " + thisPtrReg + " = inttoptr i64 " + leftReg + " to ptr\n")
    let argPtrReg = getNextRegFn(regBox)
    output.append("  " + argPtrReg + " = inttoptr i64 " + rightReg + " to ptr\n")
    let resultReg = getNextRegFn(regBox)
    output.append("  " + resultReg + " = call " + retLlvmType + " @" + quotedFuncName + "(ptr " + thisPtrReg + ", ptr " + argPtrReg + ")\n")
    return resultReg
}
