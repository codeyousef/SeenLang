        if fieldName == "attributes" { g_resolvedFieldIndex = 3; g_resolvedFieldTypeCode = 0 }
        if fieldName == "removedAttrs" { g_resolvedFieldIndex = 4; g_resolvedFieldTypeCode = 0 }
