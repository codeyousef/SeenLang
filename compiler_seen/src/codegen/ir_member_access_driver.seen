// ir_member_access_driver.seen - acyclic member/field access lowering leaves.

import str.string.{StringBuilder}
import parser.real_parser.{ParserExpressionNode}
import codegen.ir_codegen_feature_state.{getFeatureReprCClassNamesImpl, getFeatureUnionTypesImpl, getFeatureTypeAliasNamesImpl, getFeatureTypeAliasTargetsImpl, getFeatureTypeAliasCountImpl, getFeatureEnumTypeNamesImpl, getFeatureRegBoxImpl, getFeatureBitfieldKeysImpl, getFeatureBitfieldWidthsImpl, getFeatureBitfieldCountImpl}
import codegen.ir_codegen_global_state.{getBoundedActiveVarCountWithGlobalStateImpl, getGlobalStructNamesImpl, getGlobalStructLayoutsImpl, getGlobalStructFieldNamesImpl, getGlobalStructFieldTypesImpl, getGlobalStructMethodNamesImpl, getGlobalStructMethodRetTypesImpl}
import codegen.ir_codegen_module_state.{findModuleConstantWithModuleStateImpl, getModuleConstantTypeWithModuleStateImpl, getModuleConstSeenTypeWithModuleStateImpl, moduleConstantInvariantLoadSuffixWithModuleStateImpl}
import codegen.ir_codegen_type_state.{mapTypeState}
import codegen.ir_field_layout.{generateFieldAccessImpl, generateFieldAccessPtrImpl}
import codegen.ir_field_lookup_state.{getFieldInfoState, getFieldTypeState, getSeenFieldTypeState}
import codegen.ir_enum_ctor_gen.{isEnumVariantStateImpl, lookupEnumParentStateImpl, lookupEnumFieldCountStateImpl, lookupEnumVariantTagStateImpl}
import codegen.ir_local_type_leaf_driver.{findVarTypeState}
import codegen.ir_lowering_context.{CodegenLoweringContext, lowerExpression, inferLoweredExpressionType, lowerCallExpression, prepareLoweredCallArgumentsWithDefaults, lowerEnumConstructor, resetLoweringGenerator, resetLoweringSharedModuleScratch, syncLoweringState, writeBackLoweringState, lowerProgramClasses, lowerProgramTopLevelFunctions, lowerPlainLargeClass, lowerClassNode, lowerFunctionNode, lowerClassMethodFromList, setLowerCurrentClassParentName, resetLoweringLocalCodegenState, collectLoweringVariableDeclarations, clearLoweringActiveBindings, lowerBlock, lowerStatement, isLoweringBlockTerminated, beginLoweringNestedScratch, restoreLoweringNestedScratch, currentLoweringFunctionOptions}
import codegen.ir_member_access.{emitSimdSwizzleMemberAccessImpl, inferSimdSwizzleMemberTypeImpl}
import codegen.ir_member_access_gen.{emitPreparedBracketPathMemberAccessImpl, emitPreparedChainedReceiverMemberAccessImpl, emitPreparedExpressionReceiverMemberAccessImpl, emitPreparedImplicitThisReceiverMemberAccessImpl, emitPreparedModuleConstReceiverMemberAccessImpl, emitPreparedVariableReceiverMemberAccessImpl}
import codegen.ir_member_access_plan.{planMemberAccessRouteImpl}
import codegen.ir_method_receiver.{quoteIdentIfNeededImpl, resolveMethodFieldPathTypeImpl}
import codegen.ir_path_expr.{splitBracketPathImpl, splitFirstPathDotImpl, splitChainedPathImpl, buildChainedPathExprImpl, resolveChainedPathSuffixTypeImpl}
import codegen.ir_seen_token_types.{getSeenTokenTypeValueImpl}
import codegen.ir_string_collect.{parseArrayElementTypeImpl}
