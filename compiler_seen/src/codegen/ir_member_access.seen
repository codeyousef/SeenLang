// ir_member_access.seen — Shared member-access helpers
// Extracted from llvm_ir_gen.seen expression lowering.

import str.string.{StringBuilder}
import codegen.ir_optimization.{getNextRegFn}
import codegen.ir_type_info.{getSeenFieldTypeImpl}
import codegen.ir_type_mapping.{swizzleLaneIndexImpl, simdLaneCountImpl, isSwizzlePatternImpl}
import codegen.ir_method_receiver.{getSemanticFieldTypeImpl}

// emitSimdSwizzleMemberAccessImpl — emit vec.x / vec.xy / vec.xzyw swizzles.
// Returns "" when the caller should fall through.
fun emitSimdSwizzleMemberAccessImpl(output: StringBuilder, regBox: Array<Int>,
    fieldName: String, vectorLlvmType: String, vectorPtrReg: String) r: String {

    let vecReg = getNextRegFn(regBox)
    output.append("  " + vecReg + " = load " + vectorLlvmType + ", ptr " + vectorPtrReg + "\n")
    if fieldName.length() == 1 {
        let laneIdx = swizzleLaneIndexImpl(fieldName)
        let extReg = getNextRegFn(regBox)
        output.append("  " + extReg + " = extractelement " + vectorLlvmType + " " + vecReg + ", i32 " + laneIdx.toString() + "\n")
        return extReg
    }

    var swizzleMask = "<"
    var idx = 0
    while idx < fieldName.length() {
        if idx > 0 { swizzleMask = swizzleMask + ", " }
        let swizzleChar = fieldName.substring(idx, idx + 1)
        let swizzleIdx = swizzleLaneIndexImpl(swizzleChar)
        swizzleMask = swizzleMask + "i32 " + swizzleIdx.toString()
        idx = idx + 1
    }
    swizzleMask = swizzleMask + ">"

    let resReg = getNextRegFn(regBox)
    output.append("  " + resReg + " = shufflevector " + vectorLlvmType + " " + vecReg + ", " + vectorLlvmType + " undef, <" + fieldName.length().toString() + " x i32> " + swizzleMask + "\n")
    return resReg
}

fun inferSimdSwizzleMemberTypeImpl(vectorSeenType: String, fieldName: String) r: String {
    if vectorSeenType == "" {
        return ""
    }
    let swzLanes = simdLaneCountImpl(vectorSeenType)
    if isSwizzlePatternImpl(fieldName, swzLanes) != 1 {
        return ""
    }
    if fieldName.length() == 1 {
        if vectorSeenType.startsWith("f32") or vectorSeenType.startsWith("f64") {
            return "Float"
        }
        return "Int"
    }
    return vectorSeenType
}

fun inferMemberFieldTypeImpl(receiverType: String, fieldName: String,
    structNames: Array<String>, structFieldNames: Array<String>,
    structFieldTypes: Array<String>) r: String {

    if receiverType == "" {
        return ""
    }
    let semanticFieldType = getSemanticFieldTypeImpl(receiverType, fieldName,
        structNames, structFieldNames, structFieldTypes)
    if semanticFieldType != "" {
        return semanticFieldType
    }
    return getSeenFieldTypeImpl(receiverType, fieldName, structNames,
        structFieldNames, structFieldTypes)
}

fun inferJsonValueMemberAccessTypeImpl(fieldName: String,
    operandReceiverType: String, literalValue: String, currentClassName: String,
    literalValueType: String, structNames: Array<String>,
    structFieldNames: Array<String>, structFieldTypes: Array<String>) r: String {

    if fieldName != "kind" and fieldName != "boolValue" and
        fieldName != "numberValue" and fieldName != "stringValue" and
        fieldName != "arrayValue" and fieldName != "objectKeys" and
        fieldName != "objectValues" {
        return ""
    }
    if operandReceiverType == "JsonValue" {
        return getSeenFieldTypeImpl("JsonValue", fieldName, structNames,
            structFieldNames, structFieldTypes)
    }
    if literalValue == "this" and currentClassName == "JsonValue" {
        return getSeenFieldTypeImpl("JsonValue", fieldName, structNames,
            structFieldNames, structFieldTypes)
    }
    if literalValue != "" and literalValue != "this" and
        literalValueType == "JsonValue" {
        return getSeenFieldTypeImpl("JsonValue", fieldName, structNames,
            structFieldNames, structFieldTypes)
    }
    return ""
}

fun inferLiteralReceiverMemberAccessTypeImpl(receiverName: String,
    fieldName: String, chainedPathType: String, directVarType: String,
    thisType: String, structNames: Array<String>,
    structFieldNames: Array<String>, structFieldTypes: Array<String>) r: String {

    if receiverName == "" or receiverName == "this" {
        return ""
    }
    if receiverName.contains(".") {
        let chainedFieldType = inferMemberFieldTypeImpl(chainedPathType,
            fieldName, structNames, structFieldNames, structFieldTypes)
        if chainedFieldType != "" {
            return chainedFieldType
        }
    }
    let directFieldType = inferMemberFieldTypeImpl(directVarType, fieldName,
        structNames, structFieldNames, structFieldTypes)
    if directFieldType != "" {
        return directFieldType
    }
    let receiverFieldType = getSemanticFieldTypeImpl(thisType, receiverName,
        structNames, structFieldNames, structFieldTypes)
    return inferMemberFieldTypeImpl(receiverFieldType, fieldName, structNames,
        structFieldNames, structFieldTypes)
}

fun inferDirectMemberAccessTypeImpl(fieldName: String, literalValue: String,
    currentClassName: String, operandReceiverType: String,
    literalReceiverFieldType: String, structNames: Array<String>,
    structFieldNames: Array<String>, structFieldTypes: Array<String>) r: String {

    if literalValue == "this" and currentClassName != "" {
        let implicitThisFieldType = inferMemberFieldTypeImpl(currentClassName,
            fieldName, structNames, structFieldNames, structFieldTypes)
        if implicitThisFieldType != "" {
            return implicitThisFieldType
        }
    }
    let receiverFieldType = inferMemberFieldTypeImpl(operandReceiverType,
        fieldName, structNames, structFieldNames, structFieldTypes)
    if receiverFieldType != "" {
        return receiverFieldType
    }
    return literalReceiverFieldType
}

fun extractLastMemberFieldSegmentImpl(fieldName: String) r: String {
    var lastDot = -1
    var idx = 0
    while idx < fieldName.length() {
        if fieldName.byteAt(idx) == 46 {
            lastDot = idx
        }
        idx = idx + 1
    }
    if lastDot < 0 {
        return fieldName
    }
    return fieldName.substring(lastDot + 1, fieldName.length())
}

fun emitMemberArrayElementPtrImpl(output: StringBuilder, regBox: Array<Int>,
    arrayReg: String, indexValue: String) r: String {

    let elementPtrReg = getNextRegFn(regBox)
    output.append("  " + elementPtrReg + " = call ptr @seen_arr_get_element_ptr(ptr " + arrayReg + ", i64 " + indexValue + ")\n")
    return elementPtrReg
}

fun emitFieldAccessPtrImpl(output: StringBuilder, regBox: Array<Int>,
    ptrReg: String, structLayout: String, fieldIndex: Int) r: String {

    let fieldPtrReg = getNextRegFn(regBox)
    output.append("  " + fieldPtrReg + " = getelementptr inbounds " + structLayout + ", ptr " + ptrReg + ", i32 0, i32 " + fieldIndex.toString() + "\n")
    return fieldPtrReg
}

fun emitFieldAccessLoadImpl(output: StringBuilder, regBox: Array<Int>,
    fieldType: String, fieldPtrReg: String) r: String {

    let resultReg = getNextRegFn(regBox)
    output.append("  " + resultReg + " = load " + fieldType + ", ptr " + fieldPtrReg + "\n")
    return resultReg
}

fun emitBitfieldMaskLoadImpl(output: StringBuilder, regBox: Array<Int>,
    valueReg: String, bitfieldWidth: Int) r: String {

    var bitfieldMask = 1
    var shiftIdx = 0
    while shiftIdx < bitfieldWidth {
        bitfieldMask = bitfieldMask * 2
        shiftIdx = shiftIdx + 1
    }
    bitfieldMask = bitfieldMask - 1

    let maskedReg = getNextRegFn(regBox)
    output.append("  " + maskedReg + " = and i64 " + valueReg + ", " + bitfieldMask.toString() + " ; bitfield(" + bitfieldWidth.toString() + ")\n")
    return maskedReg
}

// prepareExpressionMemberReceiverImpl — normalize an expression-result receiver
// into the register form expected by generateFieldAccess.
fun prepareExpressionMemberReceiverImpl(output: StringBuilder, regBox: Array<Int>,
    receiverReg: String, receiverType: String, reprCClassNames: String,
    isClassReceiver: Int, isDataReceiver: Int) r: String {

    if reprCClassNames != "" {
        if reprCClassNames.contains(receiverType + "|") {
            return receiverReg
        }
    }
    if isDataReceiver == 1 {
        let tmpReg = getNextRegFn(regBox)
        output.append("  " + tmpReg + " = alloca %" + receiverType + "\n")
        output.append("  store %" + receiverType + " " + receiverReg + ", ptr " + tmpReg + "\n")
        return tmpReg
    }
    if isClassReceiver == 1 {
        let ptrReg = getNextRegFn(regBox)
        output.append("  " + ptrReg + " = inttoptr i64 " + receiverReg + " to ptr\n")
        return ptrReg
    }
    return receiverReg
}

// prepareVariableMemberReceiverImpl — load a local variable into the register
// form expected by generateFieldAccess.
fun prepareVariableMemberReceiverImpl(output: StringBuilder, regBox: Array<Int>,
    varReg: String, varType: String, reprCClassNames: String,
    isClassReceiver: Int, isDataReceiver: Int) r: String {

    if reprCClassNames != "" {
        if reprCClassNames.contains(varType + "|") {
            let loadReg = getNextRegFn(regBox)
            output.append("  " + loadReg + " = load %" + varType + ", ptr " + varReg + "\n")
            return loadReg
        }
    }
    if isClassReceiver == 1 {
        let loadReg = getNextRegFn(regBox)
        output.append("  " + loadReg + " = load i64, ptr " + varReg + "\n")
        let ptrReg = getNextRegFn(regBox)
        output.append("  " + ptrReg + " = inttoptr i64 " + loadReg + " to ptr\n")
        return ptrReg
    }
    if isDataReceiver == 1 {
        return varReg
    }
    let ptrReg = getNextRegFn(regBox)
    output.append("  " + ptrReg + " = load ptr, ptr " + varReg + "\n")
    return ptrReg
}

// prepareModuleConstMemberReceiverImpl — load a module constant into the
// register form expected by generateFieldAccess.
fun prepareModuleConstMemberReceiverImpl(output: StringBuilder, regBox: Array<Int>,
    quotedGlobalName: String, constType: String, constSeenType: String, invariantSuffix: String,
    isClassReceiver: Int, isDataReceiver: Int) r: String {

    if constSeenType != "" and isClassReceiver == 1 {
        let loadReg = getNextRegFn(regBox)
        output.append("  " + loadReg + " = load i64, ptr " + quotedGlobalName + invariantSuffix + "\n")
        let ptrReg = getNextRegFn(regBox)
        output.append("  " + ptrReg + " = inttoptr i64 " + loadReg + " to ptr\n")
        return ptrReg
    }
    if constSeenType != "" and isDataReceiver == 1 {
        return quotedGlobalName
    }
    if constType == "ptr" {
        let ptrReg = getNextRegFn(regBox)
        output.append("  " + ptrReg + " = load ptr, ptr " + quotedGlobalName + invariantSuffix + "\n")
        return ptrReg
    }
    return ""
}
