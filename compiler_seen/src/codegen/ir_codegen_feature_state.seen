fun prepareFunctionPreBodyWithFeatureStateImpl(state: CodegenState,
    fn: FunctionNode, implFuncName: String,
    resolvedFunctionReturnType: String) r: Void {

    resetLocalCodegenStateImpl(state)
    state.currentFunctionReturnType = resolvedFunctionReturnType
    state.currentClassName = ""
    resetFunctionLoweringOptions(state.functionOptions)
    state.indent = 0

    let activeVarCountBox = Array<Int>()
    activeVarCountBox.push(state.activeVarCount)
    let comptimeNamesBox = Array<String>()
    comptimeNamesBox.push(g_comptimeParamFuncNames)
    let comptimeCountBox = Array<Int>()
    comptimeCountBox.push(g_comptimeParamCount)
    let funcDefaultsBox = Array<String>()
    funcDefaultsBox.push(g_funcDefaultsArr)
    let dynParamFuncsBox = Array<String>()
    dynParamFuncsBox.push(g_dynParamFuncs)
    let funcParamCountBox = Array<String>()
    funcParamCountBox.push(g_funcParamCountArr)

    preRegisterFunctionParametersImpl(fn, implFuncName, state.varNames,
        state.varRegs, state.varTypes, activeVarCountBox, comptimeNamesBox,
        comptimeCountBox, funcDefaultsBox, dynParamFuncsBox,
        funcParamCountBox)

    state.activeVarCount = activeVarCountBox[0]
    g_comptimeParamFuncNames = comptimeNamesBox[0]
    g_comptimeParamCount = comptimeCountBox[0]
    g_funcDefaultsArr = funcDefaultsBox[0]
    g_dynParamFuncs = dynParamFuncsBox[0]
    g_funcParamCountArr = funcParamCountBox[0]
}

fun appendDynTraitNameWithFeatureStateImpl(className: String) r: Void {
    let dynTraitNamesBox = Array<String>()
    dynTraitNamesBox.push(g_dynTraitNames)
    appendDynTraitNameImpl(className, dynTraitNamesBox)
    g_dynTraitNames = dynTraitNamesBox[0]
}

fun registerTopLevelTypeAliasWithFeatureStateImpl(className: String,
    aliasTarget: String) r: Void {

    if g_typeAliasCount > 0 {
        g_typeAliasNames = g_typeAliasNames + "|" + className
        g_typeAliasTargets = g_typeAliasTargets + "|" + aliasTarget
    } else {
        g_typeAliasNames = className
        g_typeAliasTargets = aliasTarget
    }
    g_typeAliasCount = g_typeAliasCount + 1
}

fun appendDistinctTypeNameWithFeatureStateImpl(className: String) r: Void {
    g_distinctTypeNames = g_distinctTypeNames + className + "|"
}

fun prepareClassTypeDecoratorScanWithFeatureStateImpl(output: StringBuilder,
    classNode: ClassNode, structNames: Array<String>,
    structLayouts: Array<String>, structSizes: Array<Int>)
    r: ClassTypeDecoratorScanSnapshot {

    let decoratorSnapshot = prepareClassTypeDecoratorScanSnapshotImpl(
        output, classNode, g_reprCClassNames, g_cacheLineClasses,
        g_sendTypes, g_syncTypes, g_soaClassNames, g_soaClassCount,
        g_triviallyCopyableClasses, g_moveOnlyClasses, g_cResourceClasses,
        g_cResourceDestructors, g_reflectClassNames, g_reflectClassCount,
        g_binaryClassNames, g_binaryEndianness, g_binaryVersions,
        g_binaryClassCount, g_packetClassNames, g_packetClassIds,
        g_packetCount, g_gpuBufferClasses, g_gpuBufferLayouts, g_unionTypes,
        g_typeAliasNames, g_typeAliasTargets, g_typeAliasCount,
        g_enumTypeNames, structNames, structLayouts, structSizes)
    let decoratorState = decoratorSnapshot.decoratorState
    g_reprCClassNames = decoratorState.reprCClassNames
    g_cacheLineClasses = decoratorState.cacheLineClasses
    g_sendTypes = decoratorState.sendTypes
    g_syncTypes = decoratorState.syncTypes
    g_soaClassNames = decoratorState.soaClassNames
    g_soaClassCount = decoratorState.soaClassCount
    g_triviallyCopyableClasses = decoratorState.triviallyCopyableClasses
    g_moveOnlyClasses = decoratorState.moveOnlyClasses
    g_cResourceClasses = decoratorState.cResourceClasses
    g_cResourceDestructors = decoratorState.cResourceDestructors
    g_reflectClassNames = decoratorState.reflectClassNames
    g_reflectClassCount = decoratorState.reflectClassCount
    g_binaryClassNames = decoratorState.binaryClassNames
    g_binaryEndianness = decoratorState.binaryEndianness
    g_binaryVersions = decoratorState.binaryVersions
    g_binaryClassCount = decoratorState.binaryClassCount
    g_packetClassNames = decoratorState.packetClassNames
    g_packetClassIds = decoratorState.packetClassIds
    g_packetCount = decoratorState.packetCount
    g_gpuBufferClasses = decoratorState.gpuBufferClasses
    g_gpuBufferLayouts = decoratorState.gpuBufferLayouts
    g_unionTypes = decoratorState.unionTypes
    return decoratorSnapshot
}

fun prepareClassTypeAliasWithFeatureStateImpl(classNode: ClassNode)
    r: ClassTypeAliasStateSnapshot {

    let typeAliasState = prepareClassTypeAliasStateSnapshotImpl(classNode,
        g_typeAliasNames, g_typeAliasTargets, g_typeAliasCount)
    g_typeAliasNames = typeAliasState.typeAliasNames
    g_typeAliasTargets = typeAliasState.typeAliasTargets
    g_typeAliasCount = typeAliasState.typeAliasCount
    return typeAliasState
}

fun emitClassTypeFieldsWithFeatureStateImpl(output: StringBuilder,
    classNode: ClassNode, structNames: Array<String>) r: Void {

    emitClassTypeFieldsImpl(output, classNode, g_reprCClassNames,
        structNames, g_typeAliasNames, g_typeAliasTargets,
        g_typeAliasCount, g_enumTypeNames)
}

fun prepareStructLayoutRegistrationWithFeatureStateImpl(classNode: ClassNode,
    structNames: Array<String>, structLayouts: Array<String>,
    structFieldNames: Array<String>, structFieldTypes: Array<String>,
    structSizes: Array<Int>) r: StructLayoutRegistrationSnapshot {

    let layoutSnapshot = prepareStructLayoutRegistrationSnapshotImpl(
        classNode, g_constGenericNames, g_constGenericValues,
        g_typeAliasNames, g_typeAliasTargets, g_typeAliasCount,
        g_inheritanceChildNames, g_inheritanceParentNames,
        g_inheritanceCount, g_bitfieldKeys, g_bitfieldWidths,
        g_bitfieldOffsets, g_bitfieldCount, structNames, structLayouts,
        structFieldNames, structFieldTypes, structSizes, g_enumTypeNames)
    g_constGenericNames = layoutSnapshot.constGenericNames
    g_constGenericValues = layoutSnapshot.constGenericValues
    g_typeAliasNames = layoutSnapshot.typeAliasNames
    g_typeAliasTargets = layoutSnapshot.typeAliasTargets
    g_typeAliasCount = layoutSnapshot.typeAliasCount
    g_inheritanceChildNames = layoutSnapshot.inheritanceChildNames
    g_inheritanceParentNames = layoutSnapshot.inheritanceParentNames
    g_inheritanceCount = layoutSnapshot.inheritanceCount
    g_bitfieldKeys = layoutSnapshot.bitfieldKeys
    g_bitfieldWidths = layoutSnapshot.bitfieldWidths
    g_bitfieldOffsets = layoutSnapshot.bitfieldOffsets
    g_bitfieldCount = layoutSnapshot.bitfieldCount
    return layoutSnapshot
}

fun registerComptimeVarWithFeatureStateImpl(name: String, value: Int)
    r: Void {

    let comptimeNamesBox = Array<String>()
    comptimeNamesBox.push(g_comptimeNames)
    let comptimeValuesBox = Array<String>()
    comptimeValuesBox.push(g_comptimeValues)
    let comptimeCountBox = Array<Int>()
    comptimeCountBox.push(g_comptimeCount)
    registerComptimeVarStateImpl(name, value, comptimeNamesBox,
        comptimeValuesBox, comptimeCountBox)
    g_comptimeNames = comptimeNamesBox[0]
    g_comptimeValues = comptimeValuesBox[0]
    g_comptimeCount = comptimeCountBox[0]
}

fun updateComptimeVarWithFeatureStateImpl(name: String, value: Int) r: Void {
    let comptimeValuesBox = Array<String>()
    comptimeValuesBox.push(g_comptimeValues)
    updateComptimeVarStateImpl(name, value, g_comptimeNames,
        comptimeValuesBox, g_comptimeCount)
    g_comptimeValues = comptimeValuesBox[0]
}

fun registerComptimeStrVarWithFeatureStateImpl(name: String,
