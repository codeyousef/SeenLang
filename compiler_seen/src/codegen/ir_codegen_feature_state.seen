fun resetFeatureBootstrapStateImpl() r: Void {
    g_deferExprs = Array<ParserExpressionNode>()
    g_errdeferExprs = Array<ParserExpressionNode>()
    g_regBox = Array<Int>()
    g_blockBox = Array<Int>()
    g_floatParamFuncNames = Array<String>()
    g_floatParamParamIdxs = Array<Int>()
}

fun resetFeatureModuleScratchStateImpl() r: Void {
    g_regBox = Array<Int>()
    g_regBox.push(1)
    g_blockBox = Array<Int>()
    g_blockBox.push(0)
    g_deferExprs = Array<ParserExpressionNode>()
    g_errdeferExprs = Array<ParserExpressionNode>()
    g_initFuncNames = ""
    g_initFuncCount = 0
}

