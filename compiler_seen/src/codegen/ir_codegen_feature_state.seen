fun populateFeatureDeclarationPassStateImpl(
    declState: DeclarationPassState) r: Void {

    declState.asyncFuncNames = g_asyncFuncNames
    declState.asyncFuncRetTypes = g_asyncFuncRetTypes
    declState.asyncFuncCount = g_asyncFuncCount
    declState.enumTypeNames = g_enumTypeNames
    declState.enumVariantNames = g_enumVariantNames
    declState.enumVariantTags = g_enumVariantTags
    declState.enumVariantFieldTypes = g_enumVariantFieldTypes
    declState.enumVariantFieldCounts = g_enumVariantFieldCounts
    declState.enumVariantParent = g_enumVariantParent
    declState.enumTypeCount = g_enumTypeCount
    declState.enumVariantCount = g_enumVariantCount
}

fun applyFeatureDeclarationPassStateImpl(
    declState: DeclarationPassState) r: Void {

    g_asyncFuncNames = declState.asyncFuncNames
    g_asyncFuncRetTypes = declState.asyncFuncRetTypes
    g_asyncFuncCount = declState.asyncFuncCount
    g_enumTypeNames = declState.enumTypeNames
    g_enumVariantNames = declState.enumVariantNames
    g_enumVariantTags = declState.enumVariantTags
    g_enumVariantFieldTypes = declState.enumVariantFieldTypes
    g_enumVariantFieldCounts = declState.enumVariantFieldCounts
    g_enumVariantParent = declState.enumVariantParent
    g_enumTypeCount = declState.enumTypeCount
    g_enumVariantCount = declState.enumVariantCount
}
