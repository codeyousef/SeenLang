fun getFeatureBitfieldKeysImpl() r: String {
    return g_bitfieldKeys
}

fun getFeatureBitfieldWidthsImpl() r: String {
    return g_bitfieldWidths
}

fun getFeatureBitfieldCountImpl() r: Int {
    if g_bitfieldCount < 0 {
        return 0
    }
    if g_bitfieldCount > 4096 {
        return 0
    }
    return g_bitfieldCount
}

fun isFeatureBitfieldMetadataUsableImpl() r: Bool {
    let keyLen = g_bitfieldKeys.length()
    let widthLen = g_bitfieldWidths.length()
    if keyLen <= 0 or widthLen <= 0 {
        return false
    }
    if keyLen > 65536 or widthLen > 65536 {
        return false
    }
    return true
}

fun findFeatureBitfieldWidthImpl(bitfieldKey: String) r: Int {
    if bitfieldKey == "" or getFeatureBitfieldCountImpl() <= 0 {
        return 0
    }
    if not isFeatureBitfieldMetadataUsableImpl() {
        return 0
    }
    return findBitfieldWidthImpl(bitfieldKey, g_bitfieldKeys,
        g_bitfieldWidths)
}

