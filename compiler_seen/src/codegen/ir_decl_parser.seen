// ir_decl_parser.seen — Parser and typechecker runtime declarations

import str.string.{StringBuilder}
import codegen.ir_declarations.{isFuncDefinedInModule}
import codegen.ir_decl_typechecker.{emitTypecheckerDeclsImpl}

fun emitParserDecls(output: StringBuilder, definedFuncs: Array<String>) r: Void {
    // Frontend functions (from imported modules - conditionally declared)
    // run_frontend returns FrontendResult (class type stored as i64)
    if not isFuncDefinedInModule("run_frontend", definedFuncs) {
        output.append("declare i64 @run_frontend(%SeenString, %SeenString, %SeenString) nounwind\n")
    }
    if not isFuncDefinedInModule("run_frontend_declarations", definedFuncs) {
        output.append("declare i64 @run_frontend_declarations(%SeenString, %SeenString, %SeenString) nounwind\n")
    }
    // getDiagnostics returns Array pointer (not a class type itself, stays as ptr)
    if not isFuncDefinedInModule("FrontendResult_getDiagnostics", definedFuncs) {
        output.append("declare ptr @FrontendResult_getDiagnostics(ptr) nounwind\n")
    }
    // LLVMIRGenerator_new returns LLVMIRGenerator (class type stored as i64)
    if not isFuncDefinedInModule("LLVMIRGenerator_new", definedFuncs) {
        output.append("declare i64 @LLVMIRGenerator_new() nounwind\n")
    }
    if not isFuncDefinedInModule("LLVMIRGenerator_generate", definedFuncs) {
        // ProgramNode is a class type (stored as i64)
        output.append("declare %SeenString @LLVMIRGenerator_generate(ptr, i64) nounwind\n")
    }
    if not isFuncDefinedInModule("LLVMIRGenerator_generateMultiple", definedFuncs) {
        output.append("declare %SeenString @LLVMIRGenerator_generateMultiple(ptr, ptr) nounwind\n")
    }
    if not isFuncDefinedInModule("LLVMIRGenerator_generateSingle", definedFuncs) {
        // ProgramNode is a class type (stored as i64), i64 is for optional module index
        output.append("declare %SeenString @LLVMIRGenerator_generateSingle(ptr, i64, i64) nounwind\n")
    }
    if not isFuncDefinedInModule("LLVMIRGenerator_registerDeclarations", definedFuncs) {
        // ProgramNode is a class type (stored as i64)
        output.append("declare void @LLVMIRGenerator_registerDeclarations(ptr, i64) nounwind\n")
    }
    if not isFuncDefinedInModule("LLVMIRGenerator_reset", definedFuncs) {
        output.append("declare void @LLVMIRGenerator_reset(ptr) nounwind\n")
    }
    if not isFuncDefinedInModule("LLVMIRGenerator_setTypeHeaderPath", definedFuncs) {
        output.append("declare void @LLVMIRGenerator_setTypeHeaderPath(ptr, %SeenString) nounwind\n")
    }
    if not isFuncDefinedInModule("LLVMIRGenerator_setPanicOnOverflow", definedFuncs) {
        output.append("declare void @LLVMIRGenerator_setPanicOnOverflow(ptr, i1) nounwind\n")
    }
    // setter methods for safety flags
    if not isFuncDefinedInModule("LLVMIRGenerator_setBoundsCheckEnabled", definedFuncs) {
        output.append("declare void @LLVMIRGenerator_setBoundsCheckEnabled(ptr, i64) nounwind\n")
    }
    if not isFuncDefinedInModule("LLVMIRGenerator_setWarnUnusedResult", definedFuncs) {
        output.append("declare void @LLVMIRGenerator_setWarnUnusedResult(ptr, i64) nounwind\n")
    }

    // Other class constructors (conditionally declared, return class types as i64)
    if not isFuncDefinedInModule("ProgramNode_new", definedFuncs) {
        output.append("declare i64 @ProgramNode_new() nounwind\n")
    }
    // These constructors return class types (stored as i64)
    if not isFuncDefinedInModule("TypeChecker_new", definedFuncs) {
        output.append("declare i64 @TypeChecker_new() nounwind\n")
    }
    if not isFuncDefinedInModule("RealParser_new", definedFuncs) {
        output.append("declare i64 @RealParser_new(ptr) nounwind\n")
    }
    if not isFuncDefinedInModule("SeenLexer_new", definedFuncs) {
        output.append("declare i64 @SeenLexer_new(%SeenString, i64, %SeenString) nounwind\n")
    }
    // These return class types (stored as i64)
    if not isFuncDefinedInModule("TypeChecker_check", definedFuncs) {
        // ProgramNode is a class type (stored as i64)
        output.append("declare i64 @TypeChecker_check(ptr, i64) nounwind\n")
    }
    // Determinism checker functions (from typechecker.determinism module)
    if not isFuncDefinedInModule("DeterminismChecker_new", definedFuncs) {
        output.append("declare ptr @DeterminismChecker_new() nounwind\n")
    }
    if not isFuncDefinedInModule("DeterminismChecker_check", definedFuncs) {
        output.append("declare ptr @DeterminismChecker_check(ptr, i64) nounwind\n")
    }
    if not isFuncDefinedInModule("DeterminismChecker_setDeterministicProfile", definedFuncs) {
        output.append("declare void @DeterminismChecker_setDeterministicProfile(ptr, i1) nounwind\n")
    }
    if not isFuncDefinedInModule("DeterminismChecker_setUWWMode", definedFuncs) {
        output.append("declare void @DeterminismChecker_setUWWMode(ptr, i1) nounwind\n")
    }
    if not isFuncDefinedInModule("DeterminismCheckResult_new", definedFuncs) {
        output.append("declare ptr @DeterminismCheckResult_new() nounwind\n")
    }
    if not isFuncDefinedInModule("DeterminismCheckResult_hasErrors", definedFuncs) {
        output.append("declare i1 @DeterminismCheckResult_hasErrors(ptr) nounwind readonly\n")
    }
    if not isFuncDefinedInModule("DeterminismCheckResult_addError", definedFuncs) {
        output.append("declare void @DeterminismCheckResult_addError(ptr, ptr) nounwind\n")
    }
    if not isFuncDefinedInModule("DeterminismCheckResult_addWarning", definedFuncs) {
        output.append("declare void @DeterminismCheckResult_addWarning(ptr, %SeenString) nounwind\n")
    }
    if not isFuncDefinedInModule("DeterminismError_new", definedFuncs) {
        output.append("declare ptr @DeterminismError_new(%SeenString, %SeenString, %SeenString) nounwind\n")
    }
    if not isFuncDefinedInModule("DeterminismError_toString", definedFuncs) {
        output.append("declare %SeenString @DeterminismError_toString(ptr) nounwind\n")
    }
    if not isFuncDefinedInModule("checkDeterminism", definedFuncs) {
        output.append("declare ptr @checkDeterminism(i64, i1) nounwind\n")
    }
    if not isFuncDefinedInModule("checkDeterminismWithProfile", definedFuncs) {
        output.append("declare ptr @checkDeterminismWithProfile(i64, i1) nounwind\n")
    }
    if not isFuncDefinedInModule("printDeterminismErrors", definedFuncs) {
        output.append("declare void @printDeterminismErrors(ptr) nounwind\n")
    }
    // LSP server functions (from lsp.server module)
    if not isFuncDefinedInModule("runLspServer", definedFuncs) {
        output.append("declare i64 @runLspServer() nounwind\n")
    }
    if not isFuncDefinedInModule("RealParser_parse", definedFuncs) {
        output.append("declare i64 @RealParser_parse(ptr) nounwind\n")
    }
    // RealParser utility methods (may be in different module)
    // These return Token which is a class type, so return i64
    if not isFuncDefinedInModule("RealParser_advance", definedFuncs) {
        output.append("declare i64 @RealParser_advance(ptr) nounwind\n")
    }
    if not isFuncDefinedInModule("RealParser_peek", definedFuncs) {
        output.append("declare i64 @RealParser_peek(ptr) nounwind\n")
    }
    if not isFuncDefinedInModule("RealParser_previous", definedFuncs) {
        output.append("declare i64 @RealParser_previous(ptr) nounwind\n")
    }
    if not isFuncDefinedInModule("RealParser_isAtEnd", definedFuncs) {
        output.append("declare i1 @RealParser_isAtEnd(ptr) nounwind\n")
    }
    if not isFuncDefinedInModule("RealParser_consume", definedFuncs) {
        output.append("declare i64 @RealParser_consume(ptr, i64, %SeenString) nounwind\n")
    }
    if not isFuncDefinedInModule("RealParser_matchTokenStr", definedFuncs) {
        output.append("declare i1 @RealParser_matchTokenStr(ptr, i64) nounwind\n")
    }
    if not isFuncDefinedInModule("RealParser_checkToken", definedFuncs) {
        output.append("declare i1 @RealParser_checkToken(ptr, i64) nounwind\n")
    }
    // RealParser parse methods that may be in different modules
    if not isFuncDefinedInModule("RealParser_parseExpressionStatementField", definedFuncs) {
        output.append("declare i64 @RealParser_parseExpressionStatementField(ptr) nounwind\n")
    }
    if not isFuncDefinedInModule("RealParser_parseIfStatementInto", definedFuncs) {
        output.append("declare void @RealParser_parseIfStatementInto(ptr, ptr) nounwind\n")
    }
    if not isFuncDefinedInModule("RealParser_parseExpressionInto", definedFuncs) {
        output.append("declare void @RealParser_parseExpressionInto(ptr, ptr) nounwind\n")
    }
    if not isFuncDefinedInModule("RealParser_makeImportSymbol", definedFuncs) {
        output.append("declare ptr @RealParser_makeImportSymbol(ptr, %SeenString, %SeenString) nounwind\n")
    }
    if not isFuncDefinedInModule("RealParser_inferVisibility", definedFuncs) {
        output.append("declare %SeenString @RealParser_inferVisibility(ptr, %SeenString) nounwind\n")
    }
    if not isFuncDefinedInModule("RealParser_peekTokenType", definedFuncs) {
        output.append("declare i64 @RealParser_peekTokenType(ptr) nounwind\n")
    }
    if not isFuncDefinedInModule("RealParser_peekTokenTypeStr", definedFuncs) {
        output.append("declare %SeenString @RealParser_peekTokenTypeStr(ptr) nounwind\n")
    }
    // RealParser parse statement field methods (return void as i64)
    if not isFuncDefinedInModule("RealParser_parseWhileStatementField", definedFuncs) {
        output.append("declare i64 @RealParser_parseWhileStatementField(ptr) nounwind\n")
    }
    if not isFuncDefinedInModule("RealParser_parseLetStatementField", definedFuncs) {
        output.append("declare i64 @RealParser_parseLetStatementField(ptr) nounwind\n")
    }
    if not isFuncDefinedInModule("RealParser_parseVarStatementField", definedFuncs) {
        output.append("declare i64 @RealParser_parseVarStatementField(ptr) nounwind\n")
    }
    if not isFuncDefinedInModule("RealParser_parseReturnStatementField", definedFuncs) {
        output.append("declare i64 @RealParser_parseReturnStatementField(ptr) nounwind\n")
    }
    if not isFuncDefinedInModule("RealParser_parseIfStatementField", definedFuncs) {
        output.append("declare i64 @RealParser_parseIfStatementField(ptr) nounwind\n")
    }
    // RealParser parse Into methods (return void as i64)
    if not isFuncDefinedInModule("RealParser_parseStatementInto", definedFuncs) {
        output.append("declare i64 @RealParser_parseStatementInto(ptr) nounwind\n")
    }
    if not isFuncDefinedInModule("RealParser_parseLetStatementInto", definedFuncs) {
        output.append("declare i64 @RealParser_parseLetStatementInto(ptr, ptr) nounwind\n")
    }
    if not isFuncDefinedInModule("RealParser_parseVarStatementInto", definedFuncs) {
        output.append("declare i64 @RealParser_parseVarStatementInto(ptr, ptr) nounwind\n")
    }
    if not isFuncDefinedInModule("RealParser_parseReturnStatementInto", definedFuncs) {
        output.append("declare i64 @RealParser_parseReturnStatementInto(ptr, ptr) nounwind\n")
    }
    if not isFuncDefinedInModule("RealParser_parseWhileStatementInto", definedFuncs) {
        output.append("declare i64 @RealParser_parseWhileStatementInto(ptr, ptr) nounwind\n")
    }
    if not isFuncDefinedInModule("RealParser_parseExpressionStatementInto", definedFuncs) {
        output.append("declare i64 @RealParser_parseExpressionStatementInto(ptr, ptr) nounwind\n")
    }
    if not isFuncDefinedInModule("RealParser_parseFunctionItemInto", definedFuncs) {
        output.append("declare i64 @RealParser_parseFunctionItemInto(ptr) nounwind\n")
    }
    if not isFuncDefinedInModule("RealParser_parseClassItemInto", definedFuncs) {
        output.append("declare i64 @RealParser_parseClassItemInto(ptr) nounwind\n")
    }
    if not isFuncDefinedInModule("RealParser_parseEnumItemInto", definedFuncs) {
        output.append("declare i64 @RealParser_parseEnumItemInto(ptr) nounwind\n")
    }
    if not isFuncDefinedInModule("RealParser_parseImportItemInto", definedFuncs) {
        output.append("declare i64 @RealParser_parseImportItemInto(ptr) nounwind\n")
    }
    if not isFuncDefinedInModule("RealParser_parseDeclarationsOnly", definedFuncs) {
        output.append("declare i64 @RealParser_parseDeclarationsOnly(ptr) nounwind\n")
    }
    // RealParser parse methods returning class types (all AST nodes stored as i64)
    if not isFuncDefinedInModule("RealParser_parseFunctionItem", definedFuncs) {
        output.append("declare i64 @RealParser_parseFunctionItem(ptr) nounwind\n")
    }
    if not isFuncDefinedInModule("RealParser_parseClassItem", definedFuncs) {
        output.append("declare i64 @RealParser_parseClassItem(ptr) nounwind\n")
    }
    if not isFuncDefinedInModule("RealParser_parseEnumItem", definedFuncs) {
        output.append("declare i64 @RealParser_parseEnumItem(ptr) nounwind\n")
    }
    if not isFuncDefinedInModule("RealParser_parseImportItem", definedFuncs) {
        output.append("declare i64 @RealParser_parseImportItem(ptr) nounwind\n")
    }
    if not isFuncDefinedInModule("RealParser_parseBlock", definedFuncs) {
        output.append("declare i64 @RealParser_parseBlock(ptr) nounwind\n")
    }
    if not isFuncDefinedInModule("RealParser_parseStatement", definedFuncs) {
        output.append("declare i64 @RealParser_parseStatement(ptr) nounwind\n")
    }
    if not isFuncDefinedInModule("RealParser_parseLetStatement", definedFuncs) {
        output.append("declare i64 @RealParser_parseLetStatement(ptr) nounwind\n")
    }
    if not isFuncDefinedInModule("RealParser_parseVarStatement", definedFuncs) {
        output.append("declare i64 @RealParser_parseVarStatement(ptr) nounwind\n")
    }
    if not isFuncDefinedInModule("RealParser_parseReturnStatement", definedFuncs) {
        output.append("declare i64 @RealParser_parseReturnStatement(ptr) nounwind\n")
    }
    if not isFuncDefinedInModule("RealParser_parseIfStatement", definedFuncs) {
        output.append("declare i64 @RealParser_parseIfStatement(ptr) nounwind\n")
    }
    if not isFuncDefinedInModule("RealParser_parseWhileStatement", definedFuncs) {
        output.append("declare i64 @RealParser_parseWhileStatement(ptr) nounwind\n")
    }
    if not isFuncDefinedInModule("RealParser_parseExpressionStatement", definedFuncs) {
        output.append("declare i64 @RealParser_parseExpressionStatement(ptr) nounwind\n")
    }
    if not isFuncDefinedInModule("RealParser_parseExpression", definedFuncs) {
        output.append("declare i64 @RealParser_parseExpression(ptr) nounwind\n")
    }
    if not isFuncDefinedInModule("RealParser_parseAssignment", definedFuncs) {
        output.append("declare i64 @RealParser_parseAssignment(ptr) nounwind\n")
    }
    if not isFuncDefinedInModule("RealParser_parseOr", definedFuncs) {
        output.append("declare i64 @RealParser_parseOr(ptr) nounwind\n")
    }
    if not isFuncDefinedInModule("RealParser_parseAnd", definedFuncs) {
        output.append("declare i64 @RealParser_parseAnd(ptr) nounwind\n")
    }
    if not isFuncDefinedInModule("RealParser_parseEquality", definedFuncs) {
        output.append("declare i64 @RealParser_parseEquality(ptr) nounwind\n")
    }
    if not isFuncDefinedInModule("RealParser_parseComparison", definedFuncs) {
        output.append("declare i64 @RealParser_parseComparison(ptr) nounwind\n")
    }
    if not isFuncDefinedInModule("RealParser_parseTerm", definedFuncs) {
        output.append("declare i64 @RealParser_parseTerm(ptr) nounwind\n")
    }
    if not isFuncDefinedInModule("RealParser_parseFactor", definedFuncs) {
        output.append("declare i64 @RealParser_parseFactor(ptr) nounwind\n")
    }
    if not isFuncDefinedInModule("RealParser_parseUnary", definedFuncs) {
        output.append("declare i64 @RealParser_parseUnary(ptr) nounwind\n")
    }
    if not isFuncDefinedInModule("RealParser_parseCall", definedFuncs) {
        output.append("declare i64 @RealParser_parseCall(ptr) nounwind\n")
    }
    if not isFuncDefinedInModule("RealParser_parsePrimary", definedFuncs) {
        output.append("declare i64 @RealParser_parsePrimary(ptr) nounwind\n")
    }
    if not isFuncDefinedInModule("RealParser_parseParam", definedFuncs) {
        output.append("declare i64 @RealParser_parseParam(ptr) nounwind\n")
    }
    if not isFuncDefinedInModule("RealParser_parseTypeNode", definedFuncs) {
        output.append("declare %TypeNode @RealParser_parseTypeNode(ptr) nounwind\n")
    }
    if not isFuncDefinedInModule("RealParser_parseOptionalTypeAnnotation", definedFuncs) {
        output.append("declare %TypeNode @RealParser_parseOptionalTypeAnnotation(ptr) nounwind\n")
    }
    if not isFuncDefinedInModule("RealParser_parseOptionalReturnType", definedFuncs) {
        output.append("declare %TypeNode @RealParser_parseOptionalReturnType(ptr) nounwind\n")
    }
    if not isFuncDefinedInModule("RealParser_parseImportPath", definedFuncs) {
        output.append("declare %ImportPathInfo @RealParser_parseImportPath(ptr) nounwind\n")
    }
    if not isFuncDefinedInModule("RealParser_parseImportSymbols", definedFuncs) {
        output.append("declare ptr @RealParser_parseImportSymbols(ptr, i64) nounwind\n")
    }
    if not isFuncDefinedInModule("RealParser_parseParameterList", definedFuncs) {
        output.append("declare i64 @RealParser_parseParameterList(ptr, ptr) nounwind\n")
    }
    if not isFuncDefinedInModule("RealParser_parseParameterListField", definedFuncs) {
        output.append("declare i64 @RealParser_parseParameterListField(ptr) nounwind\n")
    }
    if not isFuncDefinedInModule("RealParser_parseExpressionIntoField", definedFuncs) {
        output.append("declare i64 @RealParser_parseExpressionIntoField(ptr, ptr) nounwind\n")
    }
    // ByIdx methods
    if not isFuncDefinedInModule("RealParser_parseLetStatementByIdx", definedFuncs) {
        output.append("declare i64 @RealParser_parseLetStatementByIdx(ptr, i64) nounwind\n")
    }
    if not isFuncDefinedInModule("RealParser_parseVarStatementByIdx", definedFuncs) {
        output.append("declare i64 @RealParser_parseVarStatementByIdx(ptr, i64) nounwind\n")
    }
    if not isFuncDefinedInModule("RealParser_parseReturnStatementByIdx", definedFuncs) {
        output.append("declare i64 @RealParser_parseReturnStatementByIdx(ptr, i64) nounwind\n")
    }
    if not isFuncDefinedInModule("RealParser_parseIfStatementByIdx", definedFuncs) {
        output.append("declare i64 @RealParser_parseIfStatementByIdx(ptr, i64) nounwind\n")
    }
    if not isFuncDefinedInModule("RealParser_parseWhileStatementByIdx", definedFuncs) {
        output.append("declare i64 @RealParser_parseWhileStatementByIdx(ptr, i64) nounwind\n")
    }
    if not isFuncDefinedInModule("RealParser_parseExpressionStatementByIdx", definedFuncs) {
        output.append("declare i64 @RealParser_parseExpressionStatementByIdx(ptr, i64) nounwind\n")
    }
    // Other RealParser utility methods
    if not isFuncDefinedInModule("RealParser_skipExpression", definedFuncs) {
        output.append("declare i64 @RealParser_skipExpression(ptr) nounwind\n")
    }
    if not isFuncDefinedInModule("RealParser_toArray", definedFuncs) {
        output.append("declare ptr @RealParser_toArray(ptr) nounwind\n")
    }
    if not isFuncDefinedInModule("RealParser_joinSegments", definedFuncs) {
        output.append("declare %SeenString @RealParser_joinSegments(ptr, ptr, %SeenString) nounwind\n")
    }
    if not isFuncDefinedInModule("SeenLexer_tokenize", definedFuncs) {
        output.append("declare ptr @SeenLexer_tokenize(ptr) nounwind\n")
    }
}

// Emit typechecker, token, AST, and type-related declarations
fun emitTypecheckerDecls(output: StringBuilder, runtimeDeclsLoaded: Bool, definedFuncs: Array<String>) r: Void {
    emitTypecheckerDeclsImpl(output, runtimeDeclsLoaded, definedFuncs)
}
