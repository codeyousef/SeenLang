    }
    // TypeNode stays as data type (inline struct, returned by value)
    if not isFuncDefinedInModule("TypeNode_new", definedFuncs) {
        output.append("declare %TypeNode @TypeNode_new() nounwind\n")
    }

    // TypeError, Location, Type, and Result methods - also included in runtime header
    // Note: TypeError method declarations (getMessage, getLocation, etc.) are NOT emitted here.
    // The g_xmDeclareNames mechanism auto-generates them for modules that call them.
    // Emitting them here would cause duplicate declarations (redefinition errors).
    if not runtimeDeclsLoaded {
        // Location/Type field accessors
        output.append("declare i64 @Location_line(ptr) nounwind\n")
        output.append("declare i64 @Location_column(ptr) nounwind\n")
        output.append("declare %SeenString @Type_name(ptr) nounwind\n")

        // Result methods
        output.append("declare i1 @Result_isOkay(ptr) nounwind\n")
        output.append("declare i1 @Result_isErr(ptr) nounwind\n")
        output.append("declare ptr @Result_unwrap(ptr) nounwind\n")
        output.append("declare %SeenString @Result_unwrapErr(ptr) nounwind\n")
        // Ok and Err return Result which is a class type (stored as i64)
        output.append("declare i64 @Err(%SeenString) nounwind\n")
        output.append("declare i64 @Ok(i64) nounwind\n")
    }

    // FsFile methods (conditionally declared, return FsFileResult/Result class types as i64)
    if not isFuncDefinedInModule("FsFile_open", definedFuncs) {
        output.append("declare i64 @FsFile_open(%SeenString) nounwind\n")
    }
    if not isFuncDefinedInModule("FsFile_create", definedFuncs) {
