    if not isFuncDefinedInModule("Environment_lookupClass", definedFuncs) {
        output.append("declare i64 @Environment_lookupClass(ptr, %SeenString) nounwind\n")
    }
    // Type-related functions (Type is class type stored as i64)
    if not isFuncDefinedInModule("Type_new", definedFuncs) {
        output.append("declare i64 @Type_new(%SeenString, i1) nounwind\n")
    }
    if not isFuncDefinedInModule("typeInt", definedFuncs) {
        output.append("declare i64 @typeInt() nounwind\n")
    }
    if not isFuncDefinedInModule("typeFloat", definedFuncs) {
