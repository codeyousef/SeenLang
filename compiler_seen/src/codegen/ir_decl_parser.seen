    }
    if not isFuncDefinedInModule("FsFile_writeContent", definedFuncs) {
        output.append("declare i64 @FsFile_writeContent(ptr, %SeenString) nounwind\n")
    }
    if not isFuncDefinedInModule("FsFile_closeFile", definedFuncs) {
        output.append("declare i64 @FsFile_closeFile(ptr) nounwind\n")
    }
    // FsFileResult_unwrap returns FsFile (class type as i64)
    if not isFuncDefinedInModule("FsFileResult_unwrap", definedFuncs) {
        output.append("declare i64 @FsFileResult_unwrap(ptr) nounwind\n")
    }
    if not isFuncDefinedInModule("FsFileResult_unwrapErr", definedFuncs) {
        output.append("declare %SeenString @FsFileResult_unwrapErr(ptr) nounwind\n")
    }
