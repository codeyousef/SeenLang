    // KeywordManager class methods (KeywordManager is class type stored as i64)
    if not isFuncDefinedInModule("KeywordManager_new", definedFuncs) {
        output.append("declare i64 @KeywordManager_new(%SeenString) nounwind\n")
    }
    if not isFuncDefinedInModule("KeywordManager_getKeywordCount", definedFuncs) {
