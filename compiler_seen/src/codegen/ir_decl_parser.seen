    // Typechecker class constructors (class types stored as i64)
    if not isFuncDefinedInModule("ClassType", definedFuncs) {
        output.append("declare i64 @ClassType() nounwind\n")
    }
    if not isFuncDefinedInModule("FunctionType", definedFuncs) {
