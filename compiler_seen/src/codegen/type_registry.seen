// =============================================================================
// TypeRegistry - Struct/Function Type Registry
// =============================================================================
//
// Owns the parallel arrays that track struct layouts, field names/types,
// method signatures, and function return types. Array-backed operations live in
// focused helper modules so this file stays as the state container and method
// compatibility facade.
// =============================================================================

import codegen.ir_seen_field_type_lookup.{getSeenFieldTypeImpl}
import codegen.type_registry_core.{findStructReg, ensureStructEntryReg, registerStructMethodReg, registerKnownDataTypesReg, getFunctionReturnTypeReg, isClassTypeReg, isDataTypeReg, getTypeSizeReg, getDataTypeSizeReg, getFieldInfoReg}
import codegen.ir_type_header_registry.{updateStructLayoutFromHeaderReg, updateStructFieldsFromHeaderReg, updateStructSizeFromHeaderReg, getFieldTypeFromListsReg, reorderFieldTypesReg}

class TypeRegistry {
    var structNames: Array<String>
    var structLayouts: Array<String>
    var structFieldNames: Array<String>
    var structFieldTypes: Array<String>
    var structLlvmFieldTypes: Array<String>
    var structSizes: Array<Int>
    var structMethodNames: Array<String>
    var structMethodRetTypes: Array<String>
    var funcNames: Array<String>
    var funcRetTypes: Array<String>
    var classMethodBaseNames: Array<String>
    var typeHeaderPath: String

    static fun new() r: TypeRegistry {
        return TypeRegistry{
            structNames: Array<String>(),
            structLayouts: Array<String>(),
            structFieldNames: Array<String>(),
            structFieldTypes: Array<String>(),
            structLlvmFieldTypes: Array<String>(),
            structSizes: Array<Int>(),
            structMethodNames: Array<String>(),
            structMethodRetTypes: Array<String>(),
            funcNames: Array<String>(),
            funcRetTypes: Array<String>(),
            classMethodBaseNames: Array<String>(),
            typeHeaderPath: ""
        }
    }

    fun findStruct(name: String) r: Int {
        return findStructReg(name, structNames)
    }

    fun ensureStructEntry(name: String) r: Int {
        return ensureStructEntryReg(name, structNames, structLayouts,
            structFieldNames, structFieldTypes, structLlvmFieldTypes,
            structSizes, structMethodNames, structMethodRetTypes)
    }

    fun registerStructMethod(className: String, methodName: String,
        retType: String) r: Void {

        registerStructMethodReg(className, methodName, retType, structNames,
            structMethodNames, structMethodRetTypes, funcNames, funcRetTypes)
    }

    fun registerKnownDataTypes() r: Void {
        registerKnownDataTypesReg(structNames, structLayouts, structFieldNames,
            structFieldTypes, structLlvmFieldTypes, structSizes,
            structMethodNames, structMethodRetTypes)
    }

    fun getFunctionReturnType(name: String) r: String {
        return getFunctionReturnTypeReg(name, funcNames, funcRetTypes)
    }

    fun isClassType(seenType: String) r: Bool {
        return isClassTypeReg(seenType, structNames)
    }

    fun isDataType(seenType: String) r: Bool {
        return isDataTypeReg(seenType)
    }

    fun getTypeSize(typeName: String) r: Int {
        return getTypeSizeReg(typeName, structNames, structSizes)
    }

    fun getDataTypeSize(seenType: String) r: Int {
        return getDataTypeSizeReg(seenType, structNames, structSizes)
    }

    fun getFieldInfo(structName: String, fieldName: String) r: Int {
        return getFieldInfoReg(structName, fieldName, structNames,
            structFieldNames)
    }

    fun updateStructLayoutFromHeader(structName: String,
        structLayout: String) r: Void {

        updateStructLayoutFromHeaderReg(structName, structLayout, structNames,
            structLayouts, structFieldNames, structFieldTypes,
            structLlvmFieldTypes, structSizes, structMethodNames,
            structMethodRetTypes)
    }

    fun updateStructFieldsFromHeader(structName: String,
        fieldsStr: String) r: Void {

        updateStructFieldsFromHeaderReg(structName, fieldsStr, structNames,
            structLayouts, structFieldNames, structFieldTypes,
            structLlvmFieldTypes, structSizes, structMethodNames,
            structMethodRetTypes)
    }

    fun updateStructSizeFromHeader(structName: String,
        sizeStr: String) r: Void {

        updateStructSizeFromHeaderReg(structName, sizeStr, structNames,
            structLayouts, structFieldNames, structFieldTypes,
            structLlvmFieldTypes, structSizes, structMethodNames,
            structMethodRetTypes)
    }

    fun getFieldTypeFromLists(fieldNamesStr: String, fieldTypesStr: String,
        fieldName: String) r: String {

        return getFieldTypeFromListsReg(fieldNamesStr, fieldTypesStr,
            fieldName)
    }

    fun reorderFieldTypes(existingNames: String, existingTypes: String,
        newNames: String) r: String {

        return reorderFieldTypesReg(existingNames, existingTypes, newNames)
    }

    fun getSeenFieldType(structName: String, fieldName: String) r: String {
        return getSeenFieldTypeImpl(structName, fieldName, structNames,
            structFieldNames, structFieldTypes)
    }
}
