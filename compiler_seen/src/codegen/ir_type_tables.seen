    }
    if callee == "FunctionType" {
        return "FunctionType"
    }
    if callee == "ClassType" {
        return "ClassType"
    }
    if callee == "InterfaceType" {
        return "InterfaceType"
    }
    if callee == "Location" {
        return "Location"
    }
    if callee == "Type" {
        return "Type"
    }
    if callee == "Environment" {
