// Core runtime declarations for LLVM IR generation
// Extracted from ir_declarations.seen to reduce file size

import str.string.{StringBuilder}
import codegen.ir_declarations.{isFuncDefinedInModule}
import codegen.ir_decl_runtime_lsp_json.{emitLspJsonRuntimeDecls}

fun emitCoreRuntimeDecls(output: StringBuilder, runtimeDeclsLoaded: Bool, definedFuncs: Array<String>) r: Void {
    // If runtime declarations were loaded from header file, skip core declarations
    // They are already included in the header, only emit compiler-specific ones below
    if runtimeDeclsLoaded {
        output.append("; Core runtime declarations loaded from type header file\n")
    } else {
        // Emit core runtime declarations (fallback when no header file)
        output.append("; Runtime function declarations\n")
        output.append("declare void @seen_runtime_init(i32, ptr) nounwind\n")
        output.append("declare void @println(%SeenString) nounwind\n")
        output.append("declare void @print(%SeenString) nounwind\n")
        output.append("declare %SeenString @seen_cstr_to_str(ptr) nounwind readonly\n")
        output.append("declare noalias ptr @seen_str_to_cstr(%SeenString) nounwind\n")
        output.append("declare i64 @seen_length(%SeenString) nounwind willreturn memory(argmem: read)\n")
        output.append("declare %SeenString @seen_substring(%SeenString, i64, i64) nounwind\n")
        // String functions that may be defined in str.string module
        if not isFuncDefinedInModule("startsWith", definedFuncs) {
            output.append("declare i1 @startsWith(%SeenString, %SeenString) nounwind readonly\n")
        }
        if not isFuncDefinedInModule("endsWith", definedFuncs) {
            output.append("declare i1 @endsWith(%SeenString, %SeenString) nounwind readonly\n")
        }
        if not isFuncDefinedInModule("contains", definedFuncs) {
            output.append("declare i1 @contains(%SeenString, %SeenString) nounwind readonly\n")
        }
        if not isFuncDefinedInModule("trim", definedFuncs) {
            output.append("declare %SeenString @trim(%SeenString) nounwind\n")
        }
        output.append("declare %SeenString @seen_str_concat_ss(%SeenString, %SeenString) nounwind\n")
        output.append("declare %SeenString @seen_int_to_string(i64) nounwind readonly\n")
        output.append("declare %SeenString @seen_float_to_string(double) nounwind readonly\n")
        output.append("declare %SeenString @seen_char_to_str(i64) nounwind readonly\n")
        output.append("declare %SeenString @String_fromCharCode(i64) nounwind readonly\n")
        output.append("declare %SeenString @seen_bool_to_string(i1) nounwind readonly\n")
        output.append("declare i64 @seen_char_at(%SeenString, i64) nounwind readonly\n")
        output.append("declare i64 @seen_byte_at(%SeenString, i64) nounwind readonly\n")
        // String.byteAt() method generated by old stage1_frozen (falls through to generic dispatch)
        output.append("declare i64 @String_byteAt(%SeenString, i64) nounwind readonly\n")
        output.append("declare i64 @seen_string_length_codepoints(%SeenString) nounwind readonly\n")

        // StringBuilder functions
        output.append("declare noalias dereferenceable(32) ptr @StringBuilder_new() nounwind willreturn\n")
        output.append("declare noalias dereferenceable(32) ptr @StringBuilder_new_with_capacity(i64) nounwind willreturn\n")
        output.append("declare i64 @StringBuilder_append(ptr nonnull, %SeenString) nounwind willreturn\n")
        output.append("declare i64 @StringBuilder_appendChar(ptr nonnull, i64) nounwind willreturn\n")
        output.append("declare %SeenString @StringBuilder_toString(ptr nonnull) nounwind willreturn\n")
        output.append("declare void @StringBuilder_clear_impl(ptr nonnull) nounwind willreturn\n")
        output.append("declare i64 @StringBuilder_length(ptr nonnull) nounwind willreturn memory(argmem: read)\n")
        output.append("declare i64 @StringBuilder_appendFloat(ptr nonnull, double) nounwind willreturn\n")
        output.append("declare i64 @StringBuilder_appendInt(ptr nonnull, i64) nounwind willreturn\n")
        output.append("declare i64 @Char_toInt(i64) nounwind readonly\n")
        output.append("declare i64 @Int_unwrap(i64) nounwind readonly\n")
        output.append("declare i1 @Bool_unwrap(i64) nounwind readonly\n")
        output.append("declare ptr @Optional_unwrap(ptr) nounwind\n")
        // Option<T> class method declarations - guarded for standalone stdlib compilation
        if not isFuncDefinedInModule("Option_isSome", definedFuncs) {
            output.append("declare i1 @Option_isSome(ptr) nounwind readonly\n")
        }
        if not isFuncDefinedInModule("Option_isNone", definedFuncs) {
            output.append("declare i1 @Option_isNone(ptr) nounwind readonly\n")
        }
        if not isFuncDefinedInModule("Option_IsSome", definedFuncs) {
            output.append("declare i1 @Option_IsSome(ptr) nounwind readonly\n")
        }
        if not isFuncDefinedInModule("Option_IsNone", definedFuncs) {
            output.append("declare i1 @Option_IsNone(ptr) nounwind readonly\n")
        }
        // Option<T>.unwrap() - for primitive inner types, we need specific unwrap functions
        // The generic version returns ptr (matching C runtime semantics)
        output.append("declare i1 @Option_unwrap_bool(ptr) nounwind\n")
        output.append("declare i64 @Option_unwrap_int(ptr) nounwind\n")
        output.append("declare %SeenString @Option_unwrap_string(ptr) nounwind\n")
        output.append("declare double @Option_unwrap_float(ptr) nounwind\n")
        output.append("declare i64 @Option_unwrap_boxed(ptr) nounwind\n")
        // Option_unwrap/Unwrap: return i64 to match cross-module declare from registerDeclarations
        // (mapType("T") = "i64", so the cross-module declare emits i64; must agree here)
        // Guard with isFuncDefinedInModule — cross-module declare system pre-pushes these names
        // to definedFuncs, so this prevents duplicate declarations when option.seen is imported.
        if not isFuncDefinedInModule("Option_unwrap", definedFuncs) {
            output.append("declare i64 @Option_unwrap(ptr) nounwind\n")
        }
        if not isFuncDefinedInModule("Option_Unwrap", definedFuncs) {
            output.append("declare i64 @Option_Unwrap(ptr) nounwind\n")
        }
        if not isFuncDefinedInModule("Result_isOkay", definedFuncs) {
            output.append("declare i1 @Result_isOkay(ptr) nounwind\n")
        }
        if not isFuncDefinedInModule("Result_unwrapErr", definedFuncs) {
            output.append("declare %SeenString @Result_unwrapErr(ptr) nounwind\n")
        }
        output.append("declare i64 @SeenTokenType_unwrap(i64) nounwind readonly\n")
        emitLspJsonRuntimeDecls(output, definedFuncs)
        // Some and None return Optional which is a class type (stored as i64)
        // Guarded for standalone stdlib compilation
        if not isFuncDefinedInModule("Some", definedFuncs) {
            output.append("declare i64 @Some(ptr) nounwind\n")
        }
        if not isFuncDefinedInModule("None", definedFuncs) {
            output.append("declare i64 @None() nounwind\n")
        }
        output.append("declare i1 @seen_str_eq_ss(%SeenString, %SeenString) nounwind readonly\n")
        output.append("declare i1 @seen_str_ne_ss(%SeenString, %SeenString) nounwind readonly\n")

        // Array functions - pass SeenArray by value (matches C ABI: SeenArray a, not ptr)
        // Array creation functions - return ptr to heap-allocated SeenArray
        output.append("declare noalias dereferenceable(32) ptr @seen_arr_new_str_ptr() nounwind willreturn memory(inaccessiblemem: readwrite)\n")
        output.append("declare noalias dereferenceable(32) ptr @seen_arr_new_ptr_ptr() nounwind willreturn memory(inaccessiblemem: readwrite)\n")
        output.append("declare noalias dereferenceable(32) ptr @seen_arr_new_with_size_ptr(i64) nounwind willreturn memory(inaccessiblemem: readwrite)\n")
        output.append("declare i64 @seen_arr_length(%SeenArray) nounwind willreturn memory(argmem: read)\n")
        output.append("declare i64 @seen_arr_length_ptr(ptr nonnull) nounwind willreturn memory(argmem: read)\n")
        output.append("declare i64 @seen_arr_data_ptr(ptr nonnull) nounwind willreturn memory(argmem: read)\n")
        output.append("declare %SeenString @seen_arr_get_str(%SeenArray, i64) nounwind willreturn memory(argmem: read)\n")
        output.append("declare %SeenString @seen_arr_get_str_ptr(ptr nonnull, i64) nounwind willreturn memory(argmem: read)\n")
        output.append("declare ptr @seen_arr_get_diag(%SeenArray, i64) nounwind willreturn memory(argmem: read)\n")
        output.append("declare ptr @seen_arr_get_diag_ptr(ptr nonnull, i64) nounwind willreturn memory(argmem: read)\n")
        output.append("declare ptr @seen_arr_get_ptr(%SeenArray, i64) nounwind willreturn memory(argmem: read)\n")
        output.append("declare ptr @seen_arr_get_ptr_ptr(ptr nonnull, i64) nounwind willreturn memory(argmem: read)\n")
        output.append("declare ptr @seen_arr_get_element(%SeenArray, i64) nounwind willreturn memory(argmem: read)\n")
        output.append("declare ptr @seen_arr_get_element_ptr(ptr nonnull, i64) nounwind willreturn memory(argmem: read)\n")
        output.append("declare i64 @Array_push(ptr nonnull, ptr) nounwind willreturn memory(argmem: readwrite, inaccessiblemem: readwrite)\n")
        output.append("declare void @Array_set(ptr nonnull, i64, ptr) nounwind willreturn memory(argmem: readwrite)\n")
        output.append("declare void @seen_arr_set_i64(ptr nonnull, i64, i64) nounwind willreturn memory(argmem: readwrite)\n")
        output.append("declare void @seen_arr_set_double(ptr nonnull, i64, double) nounwind willreturn memory(argmem: readwrite)\n")
        output.append("declare void @seen_arr_set_str(ptr nonnull, i64, %SeenString) nounwind willreturn memory(argmem: readwrite)\n")
        output.append("declare void @seen_arr_push_str(ptr nonnull, %SeenString) nounwind willreturn memory(argmem: readwrite, inaccessiblemem: readwrite)\n")
        output.append("declare void @seen_arr_push_i64(ptr nonnull, i64) nounwind willreturn memory(argmem: readwrite, inaccessiblemem: readwrite)\n")
        output.append("declare void @seen_arr_push_f64(ptr nonnull, double) nounwind willreturn memory(argmem: readwrite, inaccessiblemem: readwrite)\n")
        output.append("declare noalias dereferenceable(32) ptr @seen_arr_new_filled_i64(i64, i64) nounwind willreturn memory(inaccessiblemem: readwrite)\n")
        output.append("declare noalias dereferenceable(32) ptr @seen_arr_new_filled_double(i64, double) nounwind willreturn memory(inaccessiblemem: readwrite)\n")
        output.append("declare void @seen_arr_push_ptr(ptr nonnull, ptr) nounwind willreturn memory(argmem: readwrite, inaccessiblemem: readwrite)\n")
        output.append("declare i64 @seen_arr_get_i64(ptr nonnull, i64) nounwind willreturn memory(argmem: read)\n")  // For @derive(Deserialize)
        output.append("declare i64 @seen_arr_pop_i64(ptr nonnull) nounwind willreturn memory(argmem: readwrite)\n")
        output.append("declare double @seen_arr_pop_f64(ptr nonnull) nounwind willreturn memory(argmem: readwrite)\n")
        output.append("declare %SeenString @seen_arr_pop_str(ptr nonnull) nounwind willreturn memory(argmem: readwrite)\n")
        output.append("declare void @seen_arr_clear(ptr nonnull) nounwind willreturn memory(argmem: readwrite)\n")

        // C runtime primitive functions (extern fun __*) for stdlib
        // File I/O primitives
        output.append("declare i64 @__OpenFile(%SeenString, %SeenString) nounwind\n")
        output.append("declare %SeenString @__ReadFile(i64) nounwind\n")
        output.append("declare ptr @__ReadFileBytes(i64, i64) nounwind\n")
        output.append("declare ptr @__ReadFileBytesPath(%SeenString) nounwind\n")
        output.append("declare i64 @__WriteFile(i64, %SeenString) nounwind\n")
        output.append("declare i64 @__WriteFileBytes(i64, ptr) nounwind\n")
        output.append("declare i64 @__CloseFile(i64) nounwind\n")
        output.append("declare i64 @__FileSize(i64) nounwind\n")
        output.append("declare %SeenString @__FileError(i64) nounwind\n")
        output.append("declare i1 @__FileExists(%SeenString) nounwind\n")
        output.append("declare i1 @__DeleteFile(%SeenString) nounwind\n")
        output.append("declare i1 @__CreateDirectory(%SeenString) nounwind\n")
        // Process primitives
        output.append("declare i64 @__ExecuteProgram(%SeenString) nounwind\n")
        output.append("declare ptr @__ExecuteCommand(%SeenString) nounwind\n")
        // Environment primitives
        output.append("declare ptr @__GetCommandLineArgs() nounwind\n")
        output.append("declare i1 @__HasEnv(%SeenString) nounwind\n")
        output.append("declare %SeenString @__GetEnv(%SeenString) nounwind\n")
        output.append("declare i1 @__SetEnv(%SeenString, %SeenString) nounwind\n")
        output.append("declare i1 @__RemoveEnv(%SeenString) nounwind\n")
        // Fork/wait/exit/getpid (process.process module)
        output.append("declare i64 @__seen_fork() nounwind\n")
        output.append("declare i64 @__seen_waitpid(i64, i64) nounwind\n")
        output.append("declare void @__seen_exit(i64) nounwind\n")
        output.append("declare i64 @__seen_getpid() nounwind\n")
        output.append("declare void @__panic(i64, ptr) noreturn nounwind\n")
        // Mutex (sync.mutex module)
        output.append("declare i64 @__MutexCreate() nounwind\n")
        output.append("declare void @__MutexDestroy(i64) nounwind\n")
        output.append("declare void @__MutexLock(i64) nounwind\n")
        output.append("declare void @__MutexUnlock(i64) nounwind\n")
        output.append("declare i64 @__MutexTryLock(i64) nounwind\n")
        // Atomics (sync.atomic module)
        output.append("declare i64 @__AtomicAlloc(i64) nounwind\n")
        output.append("declare i64 @__AtomicLoad(i64) nounwind\n")
        output.append("declare void @__AtomicStore(i64, i64) nounwind\n")
        output.append("declare i64 @__AtomicAdd(i64, i64) nounwind\n")
        output.append("declare i64 @__AtomicSub(i64, i64) nounwind\n")
        output.append("declare i64 @__AtomicCompareExchange(i64, i64, i64) nounwind\n")
        output.append("declare i64 @__AtomicLoadRelaxed(i64) nounwind\n")
        output.append("declare i64 @__AtomicLoadAcquire(i64) nounwind\n")
        output.append("declare void @__AtomicStoreRelease(i64, i64) nounwind\n")
        output.append("declare i64 @__AtomicLoadBool(i64) nounwind\n")
        output.append("declare void @__AtomicStoreBool(i64, i64) nounwind\n")
        output.append("declare i64 @__AtomicCompareExchangeBool(i64, i64, i64) nounwind\n")
        // Channel (sync.channel module)
        output.append("declare i64 @__ChannelCreate() nounwind\n")
        output.append("declare i64 @__ChannelSend(i64, i64) nounwind\n")
        output.append("declare i64 @__ChannelReceive(i64) nounwind\n")
        output.append("declare void @__ChannelClose(i64) nounwind\n")
        // Thread utilities (thread.mod module)
        output.append("declare void @__ThreadSleep(i64) nounwind\n")
        output.append("declare void @__ThreadYield() nounwind\n")
        output.append("declare i64 @__ThreadCurrent() nounwind\n")
        output.append("declare i64 @__RawThreadCreate(i64, i64) nounwind\n")
        output.append("declare i64 @__RawThreadJoin(i64) nounwind\n")
        // Async promise extraction (async.runtime module)
        output.append("declare i64 @__seen_promise_load_i64(ptr) nounwind readonly\n")
        output.append("declare double @__seen_promise_load_f64(ptr) nounwind readonly\n")
        // Print primitives
        output.append("declare void @__Print(%SeenString) nounwind\n")
        output.append("declare void @__PrintInt(i64) nounwind\n")
        output.append("declare void @__PrintFloat(double) nounwind\n")
        output.append("declare double @__IntToFloat(i64) nounwind readnone\n")
        output.append("declare i64 @__FloatToInt(double) nounwind readnone\n")
        output.append("declare void @__PrintRaw(%SeenString) nounwind\n")
        output.append("declare void @__FlushStdout() nounwind\n")
        output.append("declare double @__GetTime() nounwind\n")
        output.append("declare double @__Sqrt(double) nounwind readonly\n")
        output.append("declare double @llvm.sqrt.f64(double) nounwind readnone\n")
        output.append("declare double @__Sin(double) nounwind readonly\n")
        output.append("declare double @llvm.sin.f64(double) nounwind readnone\n")
        output.append("declare double @__Cos(double) nounwind readonly\n")
        output.append("declare double @llvm.cos.f64(double) nounwind readnone\n")
        output.append("declare double @__Exp(double) nounwind readonly\n")
        output.append("declare double @llvm.exp.f64(double) nounwind readnone\n")
        output.append("declare double @__Log(double) nounwind readonly\n")
        output.append("declare double @llvm.log.f64(double) nounwind readnone\n")
        output.append("declare double @__Log10(double) nounwind readonly\n")
        output.append("declare double @llvm.log10.f64(double) nounwind readnone\n")
        output.append("declare double @__Fabs(double) nounwind readonly\n")
        output.append("declare double @llvm.fabs.f64(double) nounwind readnone\n")
        output.append("declare double @__Pow(double, double) nounwind readonly\n")
        output.append("declare double @llvm.pow.f64(double, double) nounwind readnone\n")
        output.append("declare double @llvm.fmuladd.f64(double, double, double) nounwind readnone\n")
        output.append("declare double @llvm.floor.f64(double) nounwind readnone\n")
        output.append("declare double @llvm.ceil.f64(double) nounwind readnone\n")
        output.append("declare double @llvm.round.f64(double) nounwind readnone\n")
        output.append("declare double @llvm.minnum.f64(double, double) nounwind readnone\n")
        output.append("declare double @llvm.maxnum.f64(double, double) nounwind readnone\n")
        output.append("declare double @__Asin(double) nounwind readonly\n")
        output.append("declare double @__Acos(double) nounwind readonly\n")
        output.append("declare double @__Atan(double) nounwind readonly\n")
        output.append("declare double @__Atan2(double, double) nounwind readonly\n")
        output.append("declare double @__Sinh(double) nounwind readonly\n")
        output.append("declare double @__Cosh(double) nounwind readonly\n")
        output.append("declare double @__Tanh(double) nounwind readonly\n")
        output.append("declare double @__Tan(double) nounwind readonly\n")
        output.append("declare %SeenString @__FloatToString(double) nounwind\n")
        // Stdin primitives
        output.append("declare %SeenString @__ReadStdinLine() nounwind\n")
        output.append("declare %SeenString @__ReadStdinBytes(i64) nounwind\n")

        // Map functions (generic key-value store) - guarded to allow standalone stdlib compilation
        if not isFuncDefinedInModule("Map_new", definedFuncs) {
            output.append("declare i64 @Map_new() nounwind\n")
        }
        if not isFuncDefinedInModule("Map_set", definedFuncs) {
            output.append("declare i64 @Map_set(i64, %SeenString, i64) nounwind\n")
        }
        if not isFuncDefinedInModule("Map_put", definedFuncs) {
            output.append("declare i64 @Map_put(i64, %SeenString, i64) nounwind\n")
        }
        if not isFuncDefinedInModule("Map_get", definedFuncs) {
            output.append("declare i64 @Map_get(i64, %SeenString) nounwind readonly\n")
        }
        if not isFuncDefinedInModule("Map_size", definedFuncs) {
            output.append("declare i64 @Map_size(i64) nounwind readonly\n")
        }
        if not isFuncDefinedInModule("Map_containsKey", definedFuncs) {
            output.append("declare i1 @Map_containsKey(i64, %SeenString) nounwind readonly\n")
        }
        if not isFuncDefinedInModule("Map_containsValue", definedFuncs) {
            output.append("declare i1 @Map_containsValue(i64, i64) nounwind readonly\n")
        }
        if not isFuncDefinedInModule("Map_keys", definedFuncs) {
            output.append("declare %SeenArray @Map_keys(i64) nounwind\n")
        }
        if not isFuncDefinedInModule("Map_values", definedFuncs) {
            output.append("declare %SeenArray @Map_values(i64) nounwind\n")
        }

        // Vec<T> runtime helpers
        if not isFuncDefinedInModule("Vec_new", definedFuncs) {
            output.append("declare noalias ptr @Vec_new() nounwind\n")
        }
        if not isFuncDefinedInModule("Vec_push", definedFuncs) {
            output.append("declare void @Vec_push(ptr, i64) nounwind\n")
        }
        if not isFuncDefinedInModule("Vec_get", definedFuncs) {
            output.append("declare i64 @Vec_get(ptr, i64) nounwind readonly\n")
        }
        if not isFuncDefinedInModule("Vec_set", definedFuncs) {
            output.append("declare void @Vec_set(ptr, i64, i64) nounwind\n")
        }
        if not isFuncDefinedInModule("Vec_pop", definedFuncs) {
            output.append("declare i64 @Vec_pop(ptr) nounwind\n")
        }
        if not isFuncDefinedInModule("Vec_clear", definedFuncs) {
            output.append("declare void @Vec_clear(ptr) nounwind\n")
        }
        if not isFuncDefinedInModule("Vec_len", definedFuncs) {
            output.append("declare i64 @Vec_len(ptr) nounwind readonly\n")
        }
        if not isFuncDefinedInModule("Vec_capacity", definedFuncs) {
            output.append("declare i64 @Vec_capacity(ptr) nounwind readonly\n")
        }
        if not isFuncDefinedInModule("Vec_ensureCapacity", definedFuncs) {
            output.append("declare void @Vec_ensureCapacity(ptr, i64) nounwind\n")
        }
        // Vec<Int> utility methods
        if not isFuncDefinedInModule("Vec_contains", definedFuncs) {
            output.append("declare i64 @Vec_contains(ptr, i64) nounwind readonly\n")
        }
        if not isFuncDefinedInModule("Vec_indexOf", definedFuncs) {
            output.append("declare i64 @Vec_indexOf(ptr, i64) nounwind readonly\n")
        }
        if not isFuncDefinedInModule("Vec_reverse", definedFuncs) {
            output.append("declare void @Vec_reverse(ptr) nounwind\n")
        }
        if not isFuncDefinedInModule("Vec_remove", definedFuncs) {
            output.append("declare i64 @Vec_remove(ptr, i64) nounwind\n")
        }
        if not isFuncDefinedInModule("Vec_insert", definedFuncs) {
            output.append("declare void @Vec_insert(ptr, i64, i64) nounwind\n")
        }
        if not isFuncDefinedInModule("Vec_first", definedFuncs) {
            output.append("declare i64 @Vec_first(ptr) nounwind readonly\n")
        }
        if not isFuncDefinedInModule("Vec_last", definedFuncs) {
            output.append("declare i64 @Vec_last(ptr) nounwind readonly\n")
        }
        if not isFuncDefinedInModule("Vec_sort", definedFuncs) {
            output.append("declare void @Vec_sort(ptr) nounwind\n")
        }

        // BTreeMap<K,V> runtime helpers
        if not isFuncDefinedInModule("BTreeMap_new", definedFuncs) {
            output.append("declare noalias dereferenceable(64) ptr @BTreeMap_new() nounwind\n")
        }
        if not isFuncDefinedInModule("BTreeMap_insert", definedFuncs) {
            output.append("declare i1 @BTreeMap_insert(ptr, i64, i64) nounwind\n")
        }
        if not isFuncDefinedInModule("BTreeMap_get", definedFuncs) {
            output.append("declare i64 @BTreeMap_get(ptr, i64) nounwind readonly\n")
        }
        if not isFuncDefinedInModule("BTreeMap_containsKey", definedFuncs) {
            output.append("declare i1 @BTreeMap_containsKey(ptr, i64) nounwind readonly\n")
        }
        if not isFuncDefinedInModule("BTreeMap_keys", definedFuncs) {
            output.append("declare ptr @BTreeMap_keys(ptr) nounwind\n")
        }
        if not isFuncDefinedInModule("BTreeMap_remove", definedFuncs) {
            output.append("declare i64 @BTreeMap_remove(ptr, i64) nounwind\n")
        }
        if not isFuncDefinedInModule("BTreeMap_values", definedFuncs) {
            output.append("declare ptr @BTreeMap_values(ptr) nounwind\n")
        }
        if not isFuncDefinedInModule("BTreeMap_clear", definedFuncs) {
            output.append("declare void @BTreeMap_clear(ptr) nounwind\n")
        }

        // Vec<String> runtime helpers (String elements)
        if not isFuncDefinedInModule("Vec_new_str", definedFuncs) {
            output.append("declare noalias dereferenceable(32) ptr @Vec_new_str() nounwind\n")
        }
        if not isFuncDefinedInModule("Vec_push_str", definedFuncs) {
            output.append("declare void @Vec_push_str(ptr, %SeenString) nounwind\n")
        }
        if not isFuncDefinedInModule("Vec_get_str", definedFuncs) {
            output.append("declare %SeenString @Vec_get_str(ptr, i64) nounwind readonly\n")
        }
        if not isFuncDefinedInModule("Vec_len_str", definedFuncs) {
            output.append("declare i64 @Vec_len_str(ptr) nounwind readonly\n")
        }
        if not isFuncDefinedInModule("Vec_capacity_str", definedFuncs) {
            output.append("declare i64 @Vec_capacity_str(ptr) nounwind readonly\n")
        }
        if not isFuncDefinedInModule("Vec_ensureCapacity_str", definedFuncs) {
            output.append("declare void @Vec_ensureCapacity_str(ptr, i64) nounwind\n")
        }
        if not isFuncDefinedInModule("Vec_set_str", definedFuncs) {
            output.append("declare void @Vec_set_str(ptr, i64, %SeenString) nounwind\n")
        }
