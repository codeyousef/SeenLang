fun getKnownFieldIndexPrimaryImpl(structName: String, fieldName: String) r: Int {
    let primaryFieldIdx = getKnownFieldIndexPrimaryTableImpl(structName,
        fieldName)
    if primaryFieldIdx >= 0 { return primaryFieldIdx }
    let lspFieldIdx = getKnownLspFieldIndexImpl(structName, fieldName)
    if lspFieldIdx >= 0 { return lspFieldIdx }
    return -1
}

fun getKnownLspFieldIndexImpl(structName: String, fieldName: String) r: Int {
    return getKnownLspFieldIndexTableImpl(structName, fieldName)
}

fun getKnownLspSeenFieldTypeImpl(structName: String, fieldName: String) r: String {
    return getKnownLspSeenFieldTypeTableImpl(structName, fieldName)
}

fun getKnownFieldIndexFallbackImpl(structName: String, fieldName: String) r: Int {
    return getKnownFieldIndexFallbackTableImpl(structName, fieldName)
}

fun getLLVMIRGeneratorFieldIndexImpl(fieldName: String) r: Int {
    return getLLVMIRGeneratorFieldIndexTableImpl(fieldName)
}

fun getLLVMIRGeneratorFieldLlvmTypeImpl(fieldName: String) r: String {
    return getLLVMIRGeneratorFieldLlvmTypeTableImpl(fieldName)
}

fun getLLVMIRGeneratorStructLayoutImpl() r: String {
    return getLLVMIRGeneratorStructLayoutTableImpl()
}

// Character to ASCII code string conversion
fun charToCodeStr(val: String) r: String {
    return charToCodeStrImpl(val)
}

