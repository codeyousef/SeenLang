// Type information utilities extracted from llvm_ir_gen.seen
// Pure lookup functions with no class state dependencies.

// Note: comptime/SIMD/type-mapping functions moved to ir_type_mapping.seen
// String utilities and collection functions moved to ir_string_collect.seen

// Out-parameters for resolveKnownStructFieldImpl
var g_resolvedFieldIndex = 0
// Field type encoded as int to avoid module-level String var codegen bug:
// 0=i64, 1=i1, 2=ptr, 3=%SeenString, 4=%TypeNode, 5=%SeenArray, 6=%Range, 7=%LspPosition
var g_resolvedFieldTypeCode = 0

fun decodeFieldTypeCode(code: Int) r: String {
    if code == 0 { return "i64" }
    if code == 1 { return "i1" }
    if code == 2 { return "ptr" }
    if code == 3 { return "%SeenString" }
    if code == 4 { return "%TypeNode" }
    if code == 5 { return "%SeenArray" }
    if code == 6 { return "%Range" }
    if code == 7 { return "%LspPosition" }
    return "i64"
}

// Local struct name lookup (replaces class findStruct method)
fun findStructIdx(structNames: Array<String>, name: String) r: Int {
    var i = structNames.length() - 1
    while i >= 0 {
        if structNames[i] == name { return i }
        i = i - 1
    }
    return -1
}

// Character to ASCII code string conversion
fun charToCodeStr(val: String) r: String {
    if val.length() == 0 { return "0" }
    if val == " " { return "32" }
    if val == "\t" { return "9" }
    if val == "\n" { return "10" }
    if val == "\r" { return "13" }
    if val == "0" { return "48" }
    if val == "1" { return "49" }
    if val == "2" { return "50" }
    if val == "3" { return "51" }
    if val == "4" { return "52" }
    if val == "5" { return "53" }
    if val == "6" { return "54" }
    if val == "7" { return "55" }
    if val == "8" { return "56" }
    if val == "9" { return "57" }
    if val == "a" { return "97" }
    if val == "b" { return "98" }
    if val == "c" { return "99" }
    if val == "d" { return "100" }
    if val == "e" { return "101" }
    if val == "f" { return "102" }
    if val == "g" { return "103" }
    if val == "h" { return "104" }
    if val == "i" { return "105" }
    if val == "j" { return "106" }
    if val == "k" { return "107" }
    if val == "l" { return "108" }
    if val == "m" { return "109" }
    if val == "n" { return "110" }
    if val == "o" { return "111" }
    if val == "p" { return "112" }
    if val == "q" { return "113" }
    if val == "r" { return "114" }
    if val == "s" { return "115" }
    if val == "t" { return "116" }
    if val == "u" { return "117" }
    if val == "v" { return "118" }
    if val == "w" { return "119" }
    if val == "x" { return "120" }
    if val == "y" { return "121" }
    if val == "z" { return "122" }
    if val == "A" { return "65" }
    if val == "B" { return "66" }
    if val == "C" { return "67" }
    if val == "D" { return "68" }
    if val == "E" { return "69" }
    if val == "F" { return "70" }
    if val == "G" { return "71" }
    if val == "H" { return "72" }
    if val == "I" { return "73" }
    if val == "J" { return "74" }
    if val == "K" { return "75" }
    if val == "L" { return "76" }
    if val == "M" { return "77" }
    if val == "N" { return "78" }
    if val == "O" { return "79" }
    if val == "P" { return "80" }
    if val == "Q" { return "81" }
    if val == "R" { return "82" }
    if val == "S" { return "83" }
    if val == "T" { return "84" }
    if val == "U" { return "85" }
    if val == "V" { return "86" }
    if val == "W" { return "87" }
    if val == "X" { return "88" }
    if val == "Y" { return "89" }
    if val == "Z" { return "90" }
    if val == "'" { return "39" }
    if val == "\"" { return "34" }
    if val == "\\" { return "92" }
    if val == "/" { return "47" }
    if val == "." { return "46" }
    if val == "," { return "44" }
    if val == ":" { return "58" }
    if val == ";" { return "59" }
    if val == "!" { return "33" }
    if val == "?" { return "63" }
    if val == "@" { return "64" }
    if val == "#" { return "35" }
    if val == "$" { return "36" }
    if val == "%" { return "37" }
    if val == "^" { return "94" }
    if val == "&" { return "38" }
    if val == "*" { return "42" }
    if val == "(" { return "40" }
    if val == ")" { return "41" }
    if val == "[" { return "91" }
    if val == "]" { return "93" }
    if val == "{" { return "123" }
    if val == "}" { return "125" }
    if val == "<" { return "60" }
    if val == ">" { return "62" }
    if val == "=" { return "61" }
    if val == "+" { return "43" }
    if val == "-" { return "45" }
    if val == "_" { return "95" }
    if val == "|" { return "124" }
    // Tilde char code 126 — avoid "~" string literal (miscompiled by bootstrap)
    if val.length() == 1 {
        if val.charAt(0).toInt() == 126 { return "126" }
    }
    if val == "`" { return "96" }
    return "0"
}

// Get Seen-level type for a struct field (hardcoded + dynamic registry lookup)
fun getSeenFieldTypeImpl(structName: String, fieldName: String, structNames: Array<String>, structFieldNames: Array<String>, structFieldTypes: Array<String>) r: String {
    if structName == "LLVMIRGenerator" {
        if fieldName == "output" { return "StringBuilder" }
        if fieldName == "stringConstants" { return "Array<String>" }
        if fieldName == "nextReg" { return "Int" }
        if fieldName == "nextBlock" { return "Int" }
        if fieldName == "varNames" { return "Array<String>" }
        if fieldName == "varRegs" { return "Array<String>" }
        if fieldName == "varTypes" { return "Array<String>" }
        if fieldName == "indent" { return "Int" }
        if fieldName == "structNames" { return "Array<String>" }
        if fieldName == "structLayouts" { return "Array<String>" }
        if fieldName == "structFieldNames" { return "Array<String>" }
        if fieldName == "structFieldTypes" { return "Array<String>" }
        if fieldName == "structLlvmFieldTypes" { return "Array<String>" }
        if fieldName == "structSizes" { return "Array<Int>" }
        if fieldName == "structMethodNames" { return "Array<String>" }
        if fieldName == "structMethodRetTypes" { return "Array<String>" }
        if fieldName == "funcNames" { return "Array<String>" }
        if fieldName == "funcRetTypes" { return "Array<String>" }
        if fieldName == "currentFunctionReturnType" { return "String" }
        if fieldName == "currentClassName" { return "String" }
        if fieldName == "blockTerminated" { return "Bool" }
        if fieldName == "currentLoopCondLabel" { return "String" }
        if fieldName == "currentLoopEndLabel" { return "String" }
        if fieldName == "preAllocatedVars" { return "Array<String>" }
        if fieldName == "preAllocatedTypes" { return "Array<String>" }
        if fieldName == "stringConstantPrefix" { return "String" }
        if fieldName == "generatedFunctions" { return "Array<String>" }
        if fieldName == "generatedClasses" { return "Array<String>" }
        if fieldName == "typesLoadedFromHeader" { return "Bool" }
        if fieldName == "runtimeDeclsLoaded" { return "Bool" }
        if fieldName == "typeHeaderPath" { return "String" }
        if fieldName == "pendingArrayLiteralType" { return "String" }
        if fieldName == "classMethodBaseNames" { return "Array<String>" }
        if fieldName == "moduleConstantNames" { return "Array<String>" }
        if fieldName == "moduleConstantValues" { return "Array<String>" }
        if fieldName == "moduleConstantTypes" { return "Array<String>" }
    }
    let idx = findStructIdx(structNames, structName)
    if idx < 0 {
        // Fallback for well-known types not in registry
        if structName == "FrontendResult" {
            if fieldName == "success" { return "Bool" }
            if fieldName == "diagnostics" { return "Array<FrontendDiagnostic>" }
            if fieldName == "program" { return "ProgramNode" }
        }
        if structName == "ProgramNode" {
            if fieldName == "items" { return "Array<ItemNode>" }
        }
        if structName == "ItemNode" {
            if fieldName == "itemType" { return "String" }
            if fieldName == "function" { return "FunctionNode" }
            if fieldName == "classNode" { return "ClassNode" }
            if fieldName == "importPath" { return "Array<String>" }
        }
        if structName == "FrontendDiagnostic" {
            if fieldName == "severity" { return "String" }
            if fieldName == "file" { return "String" }
            if fieldName == "line" { return "Int" }
            if fieldName == "column" { return "Int" }
            if fieldName == "message" { return "String" }
        }
        if structName == "CommandResult" {
            if fieldName == "success" { return "Bool" }
            if fieldName == "output" { return "String" }
        }
        if structName == "TypeInferenceResult" {
            if fieldName == "success" { return "Bool" }
            if fieldName == "type" { return "Type" }
            if fieldName == "errors" { return "Array<TypeError>" }
            if fieldName == "warnings" { return "Array<String>" }
            if fieldName == "environment" { return "Environment" }
        }
        if structName == "MacroExpansionResult" {
            if fieldName == "success" { return "Bool" }
            if fieldName == "errors" { return "Array<String>" }
            if fieldName == "program" { return "ProgramNode" }
        }
        if structName == "FsFileResult" {
            if fieldName == "isOk" { return "Bool" }
            if fieldName == "file" { return "FsFile" }
            if fieldName == "error" { return "String" }
        }
        if structName == "FsFile" {
            if fieldName == "fd" { return "Int" }
            if fieldName == "path" { return "String" }
        }
        if structName == "FunctionNode" {
            if fieldName == "name" { return "String" }
            if fieldName == "params" { return "Array<ParamNode>" }
            if fieldName == "returnType" { return "TypeNode" }
            if fieldName == "body" { return "BlockNode" }
            if fieldName == "isAsync" { return "Bool" }
            if fieldName == "isInline" { return "Bool" }
            if fieldName == "isStatic" { return "Bool" }
            if fieldName == "isExtern" { return "Bool" }
            if fieldName == "isDeterministic" { return "Bool" }
            if fieldName == "isNondeterministic" { return "Bool" }
            if fieldName == "decorators" { return "Array<AnnotationNode>" }
            if fieldName == "line" { return "Int" }
            if fieldName == "column" { return "Int" }
        }
        if structName == "ClassNode" {
            if fieldName == "name" { return "String" }
            if fieldName == "fields" { return "Array<ParamNode>" }
            if fieldName == "methods" { return "Array<FunctionNode>" }
            if fieldName == "decorators" { return "Array<AnnotationNode>" }
            if fieldName == "isNondeterministic" { return "Bool" }
        }
        if structName == "TypeNode" {
            if fieldName == "typeName" { return "String" }
        }
        if structName == "ParamNode" {
            if fieldName == "name" { return "String" }
            if fieldName == "paramType" { return "TypeNode" }
        }
        if structName == "FieldNode" {
            if fieldName == "name" { return "String" }
            if fieldName == "paramType" { return "TypeNode" }
        }
        if structName == "BlockNode" {
            if fieldName == "statements" { return "Array<StatementNode>" }
        }
        if structName == "ImportPathInfo" {
            if fieldName == "text" { return "String" }
            if fieldName == "segments" { return "Array<String>" }
        }
        if structName == "AnnotationNode" {
            if fieldName == "name" { return "String" }
            if fieldName == "arguments" { return "Array<String>" }
        }
        if structName == "StatementNode" {
            if fieldName == "kind" { return "String" }
            if fieldName == "variableName" { return "String" }
            if fieldName == "variableType" { return "TypeNode" }
            if fieldName == "initializer" { return "ParserExpressionNode" }
            if fieldName == "returnValue" { return "ParserExpressionNode" }
            if fieldName == "condition" { return "ParserExpressionNode" }
            if fieldName == "thenBody" { return "BlockNode" }
            if fieldName == "elseBody" { return "BlockNode" }
            if fieldName == "loopBody" { return "BlockNode" }
        }
        if structName == "ParserExpressionNode" {
            if fieldName == "kind" { return "String" }
            if fieldName == "variableName" { return "String" }
            if fieldName == "callee" { return "String" }
            if fieldName == "operator" { return "String" }
            if fieldName == "literalValue" { return "String" }
            if fieldName == "literalType" { return "String" }
            if fieldName == "operands" { return "Array<ParserExpressionNode>" }
            if fieldName == "arguments" { return "Array<ParserExpressionNode>" }
        }
        if structName == "Type" {
            if fieldName == "name" { return "String" }
            if fieldName == "isNullable" { return "Bool" }
        }
        if structName == "FunctionType" {
            if fieldName == "parameters" { return "Array<Type>" }
            if fieldName == "returnType" { return "Type" }
            if fieldName == "isAsync" { return "Bool" }
        }
        if structName == "ClassType" {
            if fieldName == "name" { return "String" }
        }
        if structName == "InterfaceType" {
            if fieldName == "name" { return "String" }
        }
        if structName == "Location" or structName == "SourceLocation" {
            if fieldName == "line" { return "Int" }
            if fieldName == "column" { return "Int" }
            if fieldName == "file" { return "String" }
        }
        if structName == "TypeError" {
            if fieldName == "message" { return "String" }
            if fieldName == "location" { return "SourceLocation" }
            if fieldName == "expected" { return "Type" }
            if fieldName == "actual" { return "Type" }
            if fieldName == "context" { return "String" }
        }
        if structName == "Environment" {
            if fieldName == "parent" { return "Environment" }
        }
        // Macro system classes
        if structName == "ComptimeValue" {
            if fieldName == "kind" { return "String" }
            if fieldName == "intValue" { return "Int" }
            if fieldName == "stringValue" { return "String" }
            if fieldName == "boolValue" { return "Bool" }
            if fieldName == "astValue" { return "AstNode" }
            if fieldName == "arrayValue" { return "Array<ComptimeValue>" }
            if fieldName == "errorMessage" { return "String" }
        }
        if structName == "ComptimeVariable" {
            if fieldName == "name" { return "String" }
