// Out-parameters for resolveKnownStructFieldImpl
var g_resolvedFieldIndex = 0
// Field type encoded as int to avoid module-level String var codegen bug:
// 0=i64, 1=i1, 2=ptr, 3=%SeenString, 4=%TypeNode, 5=%SeenArray, 6=%Range, 7=%LspPosition
var g_resolvedFieldTypeCode = 0
var g_typeInfoFindStructCacheNames: Array<String> = Array<String>()
var g_typeInfoFindStructCacheIdxs: Array<Int> = Array<Int>()
var g_typeInfoFindStructCacheLens: Array<Int> = Array<Int>()
var g_seenFieldTypeCacheKeys: Array<String> = Array<String>()
var g_seenFieldTypeCacheLens: Array<Int> = Array<Int>()
var g_seenFieldTypeCacheValues: Array<String> = Array<String>()
var g_methodReturnCacheKeys: Array<String> = Array<String>()
var g_methodReturnCacheTypes: Array<String> = Array<String>()
var g_methodReturnCacheStructLens: Array<Int> = Array<Int>()
var g_methodReturnCacheStructIdxs: Array<Int> = Array<Int>()
var g_methodReturnCacheMethodNames: Array<String> = Array<String>()
var g_methodReturnCacheMethodRetTypes: Array<String> = Array<String>()

fun decodeFieldTypeCode(code: Int) r: String {
    if code == 0 { return "i64" }
    if code == 1 { return "i1" }
    if code == 2 { return "ptr" }
    if code == 3 { return "%SeenString" }
    if code == 4 { return "%TypeNode" }
    if code == 5 { return "%SeenArray" }
    if code == 6 { return "%Range" }
    if code == 7 { return "%LspPosition" }
    return "i64"
}

// Local struct name lookup (replaces class findStruct method)
fun findStructIdx(structNames: Array<String>, name: String) r: Int {
    var i = structNames.length() - 1
    while i >= 0 {
        if structNames[i] == name {
            return i
        }
        i = i - 1
    }
    return -1
}

