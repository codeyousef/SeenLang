///
SIMD Vectorization Report Parser
Parses LLVM opt -pass-remarks output and formats a vectorization report
///

import str.string.{StringBuilder}

// A single vectorization remark from LLVM opt
class VectorizationRemark {
    let location: String    // file:line:col
    let loopName: String    // loop identifier
    let width: Int          // vectorization width (0 if not vectorized)
    let reason: String      // reason for failure (empty if vectorized)
    let vectorized: Bool    // whether the loop was vectorized

    fun new(location: String, loopName: String, width: Int, reason: String, vectorized: Bool) r: VectorizationRemark {
        return VectorizationRemark{
            location: location,
            loopName: loopName,
            width: width,
            reason: reason,
            vectorized: vectorized
        }
    }
}

// Parse vectorization remarks from LLVM opt stderr output
class SIMDReportParser {
    let remarks: Array<VectorizationRemark>
    let vectorizedCount: Int
    let missedCount: Int

    fun new() r: SIMDReportParser {
        return SIMDReportParser{
            remarks: Array<VectorizationRemark>(),
            vectorizedCount: 0,
            missedCount: 0
        }
    }

    ///
    Parse LLVM opt output lines for vectorization remarks
    Lines matching "remark:" are vectorization passes
    ///
    fun parseOutput(output: String) r: SIMDReportParser {
        var result = SIMDReportParser.new()
        let lines = output.split("\n")
        var i = 0
        while i < lines.length() {
            let line = lines[i]
            if contains(line, "remark:") {
                if contains(line, "vectorized loop") {
                    // Successfully vectorized
                    var width = 0
                    if contains(line, "width 2") {
                        width = 2
                    }
                    if contains(line, "width 4") {
                        width = 4
                    }
                    if contains(line, "width 8") {
                        width = 8
                    }
                    if contains(line, "width 16") {
                        width = 16
                    }
                    let remark = VectorizationRemark.new(line, "", width, "", true)
                    result.remarks.push(remark)
                    result.vectorizedCount = result.vectorizedCount + 1
                } else {
                    if contains(line, "loop not vectorized") {
                        // Failed to vectorize
                        let remark = VectorizationRemark.new(line, "", 0, "not vectorized", false)
                        result.remarks.push(remark)
                        result.missedCount = result.missedCount + 1
                    }
                }
            }
            i = i + 1
        }
        return result
    }

    // Format the report for stderr output
    fun formatReport(parser: SIMDReportParser) r: String {
        var sb = StringBuilder.new()
        sb.append("=== SIMD Vectorization Report ===\n")
        sb.append("Vectorized loops: " + parser.vectorizedCount.toString() + "\n")
        sb.append("Missed loops:     " + parser.missedCount.toString() + "\n")
        sb.append("\n")

        var i = 0
        while i < parser.remarks.length() {
            let remark = parser.remarks[i]
            if remark.vectorized {
                sb.append("[VECTORIZED] width=" + remark.width.toString() + "  " + remark.location + "\n")
            } else {
                sb.append("[MISSED]     " + remark.reason + "  " + remark.location + "\n")
            }
            i = i + 1
        }
        sb.append("=================================\n")
        return sb.toString()
    }
}
