    let sz = numFields * 8
    output.append("  %mem = call ptr @malloc(i64 " + sz.toString() + ")\n")
    var fi = 0
    while fi < numFields {
        let fis = fi.toString()
        output.append("  %src_" + fis + " = getelementptr inbounds i64, ptr %this, i64 " + fis + "\n")
        output.append("  %val_" + fis + " = load i64, ptr %src_" + fis + "\n")
        output.append("  %dst_" + fis + " = getelementptr inbounds i64, ptr %mem, i64 " + fis + "\n")
        output.append("  store i64 %val_" + fis + ", ptr %dst_" + fis + "\n")
        fi = fi + 1
    }
    output.append("  %ret = ptrtoint ptr %mem to i64\n")
    output.append("  ret i64 %ret\n")
    output.append("}\n\n")
    registerStructMethodImpl(className, "clone", className, structNames, structMethodNames, structMethodRetTypes, funcNames, funcRetTypes)
}

fun generateDeriveHashImpl(output: StringBuilder, classNode: ClassNode, structNames: Array<String>, structMethodNames: Array<String>, structMethodRetTypes: Array<String>, funcNames: Array<String>, funcRetTypes: Array<String>) r: Void {
    let className = classNode.name
    output.append("; @derive(Hash) generated method\n")
    output.append("define i64 @" + className + "_hash(ptr %this) #0 {\n")
    output.append("entry:\n")
    output.append("  %h0 = add i64 0, 14695981039346656037\n")
    var fi = 0
    while fi < classNode.fields.length() {
        let fis = fi.toString()
        let prev = "h" + fi.toString()
        let next = "h" + (fi + 1).toString()
        output.append("  %fp_" + fis + " = getelementptr inbounds i64, ptr %this, i64 " + fis + "\n")
        output.append("  %fv_" + fis + " = load i64, ptr %fp_" + fis + "\n")
        output.append("  %fh_" + fis + " = call i64 @seen_hash_int(i64 %fv_" + fis + ")\n")
        output.append("  %" + next + " = call i64 @seen_hash_combine(i64 %" + prev + ", i64 %fh_" + fis + ")\n")
        fi = fi + 1
    }
    let finalH = "h" + fi.toString()
    output.append("  ret i64 %" + finalH + "\n")
    output.append("}\n\n")
    registerStructMethodImpl(className, "hash", "Int", structNames, structMethodNames, structMethodRetTypes, funcNames, funcRetTypes)
}

fun generateDeriveEqImpl(output: StringBuilder, classNode: ClassNode, structNames: Array<String>, structMethodNames: Array<String>, structMethodRetTypes: Array<String>, funcNames: Array<String>, funcRetTypes: Array<String>) r: Void {
    let className = classNode.name
    output.append("; @derive(Eq) generated method\n")
    output.append("define i1 @" + className + "_eq(ptr %this, ptr %other) #0 {\n")
    output.append("entry:\n")
    var fi = 0
    while fi < classNode.fields.length() {
        let fis = fi.toString()
        output.append("  %a_" + fis + " = getelementptr inbounds i64, ptr %this, i64 " + fis + "\n")
        output.append("  %av_" + fis + " = load i64, ptr %a_" + fis + "\n")
        output.append("  %b_" + fis + " = getelementptr inbounds i64, ptr %other, i64 " + fis + "\n")
        output.append("  %bv_" + fis + " = load i64, ptr %b_" + fis + "\n")
        output.append("  %cmp_" + fis + " = icmp eq i64 %av_" + fis + ", %bv_" + fis + "\n")
        output.append("  br i1 %cmp_" + fis + ", label %eq_next_" + fis + ", label %eq_fail\n")
        output.append("eq_next_" + fis + ":\n")
        fi = fi + 1
    }
    output.append("  ret i1 true\n")
    output.append("eq_fail:\n")
    output.append("  ret i1 false\n")
    output.append("}\n\n")
    registerStructMethodImpl(className, "eq", "Bool", structNames, structMethodNames, structMethodRetTypes, funcNames, funcRetTypes)
}

fun generateDeriveDebugImpl(output: StringBuilder, classNode: ClassNode, structNames: Array<String>, structMethodNames: Array<String>, structMethodRetTypes: Array<String>, funcNames: Array<String>, funcRetTypes: Array<String>, stringConstants: Array<String>, stringConstantPrefix: String) r: Void {
    let className = classNode.name
    output.append("; @derive(Debug) generated method\n")
    output.append("define %SeenString @" + className + "_debug(ptr %this) #0 {\n")
    output.append("entry:\n")
    output.append("  %sb = call ptr @StringBuilder_new()\n")
    var headerStr = className + " { "
    let headerIdx = addStringConstantImpl(stringConstants, headerStr)
    output.append("  %hdr = call %SeenString @seen_cstr_to_str(ptr @.str." + stringConstantPrefix + headerIdx.toString() + ")\n")
    output.append("  call i64 @StringBuilder_append(ptr %sb, %SeenString %hdr)\n")
    var fi = 0
    while fi < classNode.fields.length() {
        let fis = fi.toString()
        let field = classNode.fields[fi]
        if fi > 0 {
            let sepIdx = addStringConstantImpl(stringConstants, ", ")
            output.append("  %sep_" + fis + " = call %SeenString @seen_cstr_to_str(ptr @.str." + stringConstantPrefix + sepIdx.toString() + ")\n")
            output.append("  call i64 @StringBuilder_append(ptr %sb, %SeenString %sep_" + fis + ")\n")
        }
        let fnStr = field.name + ": "
        let fnIdx = addStringConstantImpl(stringConstants, fnStr)
        output.append("  %fn_" + fis + " = call %SeenString @seen_cstr_to_str(ptr @.str." + stringConstantPrefix + fnIdx.toString() + ")\n")
        output.append("  call i64 @StringBuilder_append(ptr %sb, %SeenString %fn_" + fis + ")\n")
        output.append("  %fp_" + fis + " = getelementptr inbounds i64, ptr %this, i64 " + fis + "\n")
        output.append("  %fv_" + fis + " = load i64, ptr %fp_" + fis + "\n")
        output.append("  %fs_" + fis + " = call %SeenString @seen_int_to_string(i64 %fv_" + fis + ")\n")
        output.append("  call i64 @StringBuilder_append(ptr %sb, %SeenString %fs_" + fis + ")\n")
        fi = fi + 1
    }
    let endIdx = addStringConstantImpl(stringConstants, " }")
    output.append("  %end = call %SeenString @seen_cstr_to_str(ptr @.str." + stringConstantPrefix + endIdx.toString() + ")\n")
    output.append("  call i64 @StringBuilder_append(ptr %sb, %SeenString %end)\n")
    output.append("  %result = call %SeenString @StringBuilder_toString(ptr %sb)\n")
    output.append("  ret %SeenString %result\n")
    output.append("}\n\n")
    registerStructMethodImpl(className, "debug", "String", structNames, structMethodNames, structMethodRetTypes, funcNames, funcRetTypes)
}

fun generateReflectImpl(output: StringBuilder, classNode: ClassNode, structNames: Array<String>, structMethodNames: Array<String>, structMethodRetTypes: Array<String>, funcNames: Array<String>, funcRetTypes: Array<String>, stringConstants: Array<String>, stringConstantPrefix: String) r: Void {
    let className = classNode.name
    let numFields = classNode.fields.length()
    output.append("; @reflect RTTI for " + className + "\n")
    let tnIdx = addStringConstantImpl(stringConstants, className)
    output.append("define %SeenString @" + className + "_getTypeName(ptr %this) #0 {\n")
    output.append("entry:\n")
    output.append("  %name = call %SeenString @seen_cstr_to_str(ptr @.str." + stringConstantPrefix + tnIdx.toString() + ")\n")
    output.append("  ret %SeenString %name\n")
    output.append("}\n\n")
    registerStructMethodImpl(className, "getTypeName", "String", structNames, structMethodNames, structMethodRetTypes, funcNames, funcRetTypes)
    output.append("define i64 @" + className + "_getFieldCount(ptr %this) #0 {\n")
    output.append("entry:\n")
    output.append("  ret i64 " + numFields.toString() + "\n")
    output.append("}\n\n")
    registerStructMethodImpl(className, "getFieldCount", "Int", structNames, structMethodNames, structMethodRetTypes, funcNames, funcRetTypes)
    output.append("define ptr @" + className + "_getFieldNames(ptr %this) #0 {\n")
    output.append("entry:\n")
    output.append("  %arr = call ptr @seen_arr_new_ptr_ptr()\n")
    var fi = 0
    while fi < numFields {
        let fis = fi.toString()
        let field = classNode.fields[fi]
        let fnIdx = addStringConstantImpl(stringConstants, field.name)
        output.append("  %fn_" + fis + " = call %SeenString @seen_cstr_to_str(ptr @.str." + stringConstantPrefix + fnIdx.toString() + ")\n")
        output.append("  call void @seen_arr_push_str(ptr %arr, %SeenString %fn_" + fis + ")\n")
        fi = fi + 1
    }
    output.append("  ret ptr %arr\n")
    output.append("}\n\n")
    registerStructMethodImpl(className, "getFieldNames", "Array<String>", structNames, structMethodNames, structMethodRetTypes, funcNames, funcRetTypes)
    output.append("define i64 @" + className + "_getFieldValue(ptr %this, i64 %idx) #0 {\n")
    output.append("entry:\n")
    output.append("  %ptr = getelementptr inbounds i64, ptr %this, i64 %idx\n")
    output.append("  %val = load i64, ptr %ptr\n")
    output.append("  ret i64 %val\n")
    output.append("}\n\n")
    registerStructMethodImpl(className, "getFieldValue", "Int", structNames, structMethodNames, structMethodRetTypes, funcNames, funcRetTypes)
    output.append("define void @" + className + "_setFieldValue(ptr %this, i64 %idx, i64 %val) #0 {\n")
    output.append("entry:\n")
    output.append("  %ptr = getelementptr inbounds i64, ptr %this, i64 %idx\n")
    output.append("  store i64 %val, ptr %ptr\n")
    output.append("  ret void\n")
    output.append("}\n\n")
    registerStructMethodImpl(className, "setFieldValue", "Void", structNames, structMethodNames, structMethodRetTypes, funcNames, funcRetTypes)
}

fun generateBinarySerializerImpl(output: StringBuilder, classNode: ClassNode, structNames: Array<String>, structMethodNames: Array<String>, structMethodRetTypes: Array<String>, funcNames: Array<String>, funcRetTypes: Array<String>, binaryClassNames: String, binaryVersions: String, binaryEndianness: String, binaryClassCount: Int) r: Void {
    let className = classNode.name
    output.append("; @binary serialize for " + className + "\n")
    output.append("define i64 @" + className + "_serialize(ptr %this) #0 {\n")
    output.append("entry:\n")
    output.append("  %buf = call i64 @seen_binary_buffer_new(i64 256)\n")
    var hasVersion = 0
    var versionStr = "1"
    var bci = 0
    while bci < binaryClassCount {
        var bcName = pipeGet(binaryClassNames, bci)
        if bcName == className {
            versionStr = pipeGet(binaryVersions, bci)
            hasVersion = 1
        }
        bci = bci + 1
    }
    if hasVersion == 1 {
        let versionVal = parseIntManual(versionStr)
        output.append("  call void @seen_binary_write_i32(i64 %buf, i32 " + versionVal.toString() + ")\n")
    }
    var useBE = 0
    bci = 0
    while bci < binaryClassCount {
        var bcName2 = pipeGet(binaryClassNames, bci)
        if bcName2 == className {
            var endian = pipeGet(binaryEndianness, bci)
            if endian == "big" or endian == "be" {
                useBE = 1
            }
        }
        bci = bci + 1
    }
    var fi = 0
    while fi < classNode.fields.length() {
        let fis = fi.toString()
        let field = classNode.fields[fi]
        let fType = field.paramType.typeName
        output.append("  %fp_" + fis + " = getelementptr inbounds i64, ptr %this, i64 " + fis + "\n")
        if fType == "String" {
            output.append("  %fv_" + fis + " = load %SeenString, ptr %fp_" + fis + "\n")
            output.append("  call void @seen_binary_write_str(i64 %buf, %SeenString %fv_" + fis + ")\n")
        } else {
            output.append("  %fv_" + fis + " = load i64, ptr %fp_" + fis + "\n")
            if fType == "Float" {
                output.append("  %ff_" + fis + " = bitcast i64 %fv_" + fis + " to double\n")
                if useBE == 1 {
                    output.append("  call void @seen_binary_write_f64_be(i64 %buf, double %ff_" + fis + ")\n")
                } else {
                    output.append("  call void @seen_binary_write_f64(i64 %buf, double %ff_" + fis + ")\n")
                }
            } else {
                if useBE == 1 {
                    output.append("  call void @seen_binary_write_i64_be(i64 %buf, i64 %fv_" + fis + ")\n")
                } else {
                    output.append("  call void @seen_binary_write_i64(i64 %buf, i64 %fv_" + fis + ")\n")
                }
            }
        }
        fi = fi + 1
    }
    output.append("  ret i64 %buf\n")
    output.append("}\n\n")
    registerStructMethodImpl(className, "serialize", "Int", structNames, structMethodNames, structMethodRetTypes, funcNames, funcRetTypes)
}

fun generateBinaryDeserializerImpl(output: StringBuilder, classNode: ClassNode, structNames: Array<String>, structMethodNames: Array<String>, structMethodRetTypes: Array<String>, funcNames: Array<String>, funcRetTypes: Array<String>, binaryClassNames: String, binaryVersions: String, binaryEndianness: String, binaryClassCount: Int) r: Void {
    let className = classNode.name
    let numFields = classNode.fields.length()
    let sz = numFields * 8
    output.append("; @binary deserialize for " + className + "\n")
    output.append("define i64 @" + className + "_deserialize(i64 %buf) #0 {\n")
    output.append("entry:\n")
    output.append("  %mem = call ptr @malloc(i64 " + sz.toString() + ")\n")
    var dataOffset = 0
    var bci = 0
    while bci < binaryClassCount {
        var bcName = pipeGet(binaryClassNames, bci)
        if bcName == className {
            dataOffset = 4
        }
        bci = bci + 1
    }
    var useBE = 0
    bci = 0
    while bci < binaryClassCount {
        var bcName2 = pipeGet(binaryClassNames, bci)
        if bcName2 == className {
            var endian = pipeGet(binaryEndianness, bci)
            if endian == "big" or endian == "be" {
                useBE = 1
            }
        }
        bci = bci + 1
    }
    var fi = 0
    var byteOff = dataOffset
    while fi < numFields {
        let fis = fi.toString()
        let field = classNode.fields[fi]
        let fType = field.paramType.typeName
        if fType == "String" {
            output.append("  %rv_" + fis + " = call %SeenString @seen_binary_read_str(i64 %buf, i64 " + byteOff.toString() + ")\n")
            output.append("  %dp_" + fis + " = getelementptr inbounds i64, ptr %mem, i64 " + fis + "\n")
            output.append("  store %SeenString %rv_" + fis + ", ptr %dp_" + fis + "\n")
            byteOff = byteOff + 12
        } else {
            if fType == "Float" {
                if useBE == 1 {
                    output.append("  %rv_" + fis + " = call double @seen_binary_read_f64_be(i64 %buf, i64 " + byteOff.toString() + ")\n")
                } else {
                    output.append("  %rv_" + fis + " = call double @seen_binary_read_f64(i64 %buf, i64 " + byteOff.toString() + ")\n")
                }
                output.append("  %ri_" + fis + " = bitcast double %rv_" + fis + " to i64\n")
                output.append("  %dp_" + fis + " = getelementptr inbounds i64, ptr %mem, i64 " + fis + "\n")
                output.append("  store i64 %ri_" + fis + ", ptr %dp_" + fis + "\n")
            } else {
                if useBE == 1 {
                    output.append("  %rv_" + fis + " = call i64 @seen_binary_read_i64_be(i64 %buf, i64 " + byteOff.toString() + ")\n")
                } else {
                    output.append("  %rv_" + fis + " = call i64 @seen_binary_read_i64(i64 %buf, i64 " + byteOff.toString() + ")\n")
                }
                output.append("  %dp_" + fis + " = getelementptr inbounds i64, ptr %mem, i64 " + fis + "\n")
                output.append("  store i64 %rv_" + fis + ", ptr %dp_" + fis + "\n")
            }
            byteOff = byteOff + 8
        }
        fi = fi + 1
    }
    output.append("  %deser_ret = ptrtoint ptr %mem to i64\n")
    output.append("  ret i64 %deser_ret\n")
    output.append("}\n\n")
    registerStructMethodImpl(className, "deserialize", className, structNames, structMethodNames, structMethodRetTypes, funcNames, funcRetTypes)
}

fun generateJsonSerializeImpl(output: StringBuilder, classNode: ClassNode, structNames: Array<String>, structMethodNames: Array<String>, structMethodRetTypes: Array<String>, funcNames: Array<String>, funcRetTypes: Array<String>, stringConstants: Array<String>, stringConstantPrefix: String) r: Void {
    let className = classNode.name
    output.append("; @derive(Json) serialize for " + className + "\n")
    output.append("define %SeenString @" + className + "_toJson(ptr %this) #0 {\n")
    output.append("entry:\n")
    output.append("  %jb = call i64 @seen_json_start_object(i64 0)\n")
    var fi = 0
    while fi < classNode.fields.length() {
        let fis = fi.toString()
        let field = classNode.fields[fi]
        let fType = field.paramType.typeName
        let keyIdx = addStringConstantImpl(stringConstants, field.name)
        output.append("  %key_" + fis + " = call %SeenString @seen_cstr_to_str(ptr @.str." + stringConstantPrefix + keyIdx.toString() + ")\n")
        output.append("  %fp_" + fis + " = getelementptr inbounds i64, ptr %this, i64 " + fis + "\n")
        if fType == "String" {
            output.append("  %fv_" + fis + " = load %SeenString, ptr %fp_" + fis + "\n")
            output.append("  call void @seen_json_key_str(i64 %jb, %SeenString %key_" + fis + ", %SeenString %fv_" + fis + ")\n")
        } else {
            if fType == "Float" {
                output.append("  %fi_" + fis + " = load i64, ptr %fp_" + fis + "\n")
                output.append("  %ff_" + fis + " = bitcast i64 %fi_" + fis + " to double\n")
                output.append("  call void @seen_json_key_float(i64 %jb, %SeenString %key_" + fis + ", double %ff_" + fis + ")\n")
            } else {
                if fType == "Bool" {
                    output.append("  %fv_" + fis + " = load i64, ptr %fp_" + fis + "\n")
                    output.append("  call void @seen_json_key_bool(i64 %jb, %SeenString %key_" + fis + ", i64 %fv_" + fis + ")\n")
                } else {
                    output.append("  %fv_" + fis + " = load i64, ptr %fp_" + fis + "\n")
                    output.append("  call void @seen_json_key_int(i64 %jb, %SeenString %key_" + fis + ", i64 %fv_" + fis + ")\n")
                }
            }
        }
        fi = fi + 1
    }
    output.append("  %result = call %SeenString @seen_json_end_object(i64 %jb)\n")
    output.append("  ret %SeenString %result\n")
    output.append("}\n\n")
    registerStructMethodImpl(className, "toJson", "String", structNames, structMethodNames, structMethodRetTypes, funcNames, funcRetTypes)
}

fun generateJsonDeserializeImpl(output: StringBuilder, classNode: ClassNode, structNames: Array<String>, structMethodNames: Array<String>, structMethodRetTypes: Array<String>, funcNames: Array<String>, funcRetTypes: Array<String>) r: Void {
    let className = classNode.name
