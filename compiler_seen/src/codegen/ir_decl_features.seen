fun generatePacketReaderImpl(output: StringBuilder, classNode: ClassNode, packetIdStr: String, structNames: Array<String>, structMethodNames: Array<String>, structMethodRetTypes: Array<String>, funcNames: Array<String>, funcRetTypes: Array<String>) r: Void {
    let className = classNode.name
    let numFields = classNode.fields.length()
    let sz = numFields * 8
    output.append("; @packet reader for " + className + "\n")
    output.append("define i64 @" + className + "_readPacket(i64 %buf) #0 {\n")
    output.append("entry:\n")
    output.append("  %hdr = call i64 @seen_packet_read_header(i64 %buf, i64 0)\n")
    output.append("  %mem = call ptr @malloc(i64 " + sz.toString() + ")\n")
    var fi = 0
    var byteOff = 8
    while fi < numFields {
        let fis = fi.toString()
        output.append("  %rv_" + fis + " = call i64 @seen_binary_read_i64(i64 %buf, i64 " + byteOff.toString() + ")\n")
        output.append("  %dp_" + fis + " = getelementptr inbounds i64, ptr %mem, i64 " + fis + "\n")
        output.append("  store i64 %rv_" + fis + ", ptr %dp_" + fis + "\n")
        fi = fi + 1
        byteOff = byteOff + 8
    }
    output.append("  %pkt_ret = ptrtoint ptr %mem to i64\n")
    output.append("  ret i64 %pkt_ret\n")
    output.append("}\n\n")
    registerStructMethodImpl(className, "readPacket", className, structNames, structMethodNames, structMethodRetTypes, funcNames, funcRetTypes)
}
