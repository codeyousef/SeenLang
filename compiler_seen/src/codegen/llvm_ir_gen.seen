// Override host target triple and data layout for cross-compilation
fun overrideTargetTriple(triple: String, layout: String) r: Void {
    overrideTargetTripleImpl(triple, layout)
}

fun getCurrentFunctionOptions() r: FunctionLoweringOptions {
    return getSharedCodegenState().functionOptions
}

///
The main code generator class. One instance is created in main_compiler.seen
and reused across modules (reset() clears per-module state between modules,
but struct/function registries persist for cross-module type resolution).

Key field groups:
  Output buffer:       output (StringBuilder), stringConstants (Array<String>)
  Register state:      nextReg, nextBlock (SSA counter; boxed in getFeatureRegBoxImpl()/getFeatureBlockBoxImpl()
                       for mutation by extracted free functions)
  Variable tracking:   varNames/varRegs/varTypes (parallel arrays, scoped by push,
                       never popped — findVar searches backwards for shadowing)
  Struct registry:     getGlobalStructNamesImpl()/getGlobalStructLayoutsImpl()/getGlobalStructFieldNamesImpl()/getGlobalStructFieldTypesImpl()/
                       getGlobalStructSizesImpl()/getGlobalStructMethodNamesImpl()/getGlobalStructMethodRetTypesImpl()
  Function registry:   funcNames/funcRetTypes (return type lookup for call codegen)
  Per-function state:  currentFunctionReturnType, currentClassName, blockTerminated,
                       currentLoopCondLabel/EndLabel, preAllocatedVars/Types
  Dedup tracking:      generatedFunctions/generatedClasses (DO NOT remove reset()
                       of these — causes "undefined reference" linker errors)
///
class LLVMIRGenerator {
    var output: StringBuilder
    var stringConstants: Array<String>
    var nextReg: Int
    var nextBlock: Int
    // Using parallel arrays as workaround for Map.get() bug
    var varNames: Array<String>
    var varRegs: Array<String>
    var varTypes: Array<String>
    var indent: Int
    static fun new() r: LLVMIRGenerator {
        initBootstrapFragileGlobalArrays()
        let gen = LLVMIRGenerator{
            output: StringBuilder.new(),
            stringConstants: Array<String>(),
            nextReg: 1,
            nextBlock: 0,
            varNames: Array<String>(),
            varRegs: Array<String>(),
            varTypes: Array<String>(),
            indent: 0
        }
        gen.reset()
        return gen
    }

    // Set the path to the type header file (generated by --emit-type-header)
    fun setTypeHeaderPath(path: String) r: Void {
        // Check for encoded ML decision log path: "header_path|ml:log_path"
        var pipeIdx = 0
        var foundPipe = false
        while pipeIdx < path.length() {
            if path.charAt(pipeIdx) == '|' {
                foundPipe = true
                setGlobalTypeHeaderPathImpl(path.substring(0, pipeIdx))
                let rest = path.substring(pipeIdx + 1, path.length())
                if rest.length() > 3 {
                    if rest.substring(0, 3) == "ml:" {
                        setupMLLogging(rest.substring(3, rest.length()))
                    }
                }
                break
            }
            pipeIdx = pipeIdx + 1
        }
        if not foundPipe {
            setGlobalTypeHeaderPathImpl(path)
        }
    }

    // Set the panic on overflow flag (uses module-level var for bootstrap compat)
    fun setPanicOnOverflow(enabled: Bool) r: Void {
        setPanicOnOverflowStateImpl(enabled)
    }

    // Set bounds checking flag
    fun setBoundsCheckEnabled(enabled: Int) r: Void {
        setBoundsCheckEnabledStateImpl(enabled)
    }

    // Set unused Result warning flag
    fun setWarnUnusedResult(enabled: Int) r: Void {
        setWarnUnusedResultStateImpl(enabled)
    }

    // Safety control setters
    fun setNullSafetyEnabled(enabled: Int) r: Void {
        setNullSafetyEnabledStateImpl(enabled)
    }
    fun setUninitCheckEnabled(enabled: Int) r: Void {
        setUninitCheckEnabledStateImpl(enabled)
    }
    fun setStackCheckEnabled(enabled: Int) r: Void {
        setStackCheckEnabledStateImpl(enabled)
    }
    fun setSanitizerMode(mode: String) r: Void {
        setSanitizerModeStateImpl(mode)
    }
    // : Set enabled feature flags (pipe-delimited)
    fun setEnabledFeatures(features: String) r: Void {
        setEnabledFeaturesStateImpl(features)
    }

    ///
    Reset generator state for per-module compilation (keeps struct/func registries)
    Reset all per-module state for generating a new module's IR.
    Clears output buffer, variable tracking, string constants, dedup lists,
    optimization counters, and module constants. Keeps struct/function
    registries intact (needed for cross-module type resolution).
    WARNING: DO NOT remove the reset of generatedFunctions/generatedClasses —
    they track deduplication within a module and removing them causes
    "undefined reference" linker errors from missing definitions.
    ///
    fun reset() r: Void {
        let resetState = resetLLVMIRGeneratorModuleStateImpl(
            getCurrentFunctionOptions())
        this.output = resetState.output
        this.stringConstants = resetState.stringConstants
        this.varNames = resetState.varNames
        this.varRegs = resetState.varRegs
        this.varTypes = resetState.varTypes
        nextReg = resetState.nextReg
        nextBlock = resetState.nextBlock
        this.indent = resetState.indent
    }

    fun beginNestedScratchState(returnType: String)
        r: NestedScratchStateSnapshot {
        syncState()
        let state = getSharedCodegenState()
        let savedState = snapshotNestedScratchStateImpl(state)
        beginNestedScratchStateImpl(state, returnType)
        writeBackState()
        return savedState
    }

    fun restoreNestedScratchState(savedState: NestedScratchStateSnapshot)
        r: Void {
        syncState()
        let state = getSharedCodegenState()
        restoreNestedScratchStateImpl(state, savedState)
        writeBackState()
    }

    fun resetLocalCodegenState() r: Void {
        syncState()
        let state = getSharedCodegenState()
        resetLocalCodegenStateImpl(state)
        writeBackState()
    }

    fun clearActiveBindings() r: Void {
        syncState()
        let state = getSharedCodegenState()
        clearActiveBindingsImpl(state)
        writeBackState()
    }

    fun isBlockTerminated() r: Bool {
        return getBlockTerminatedWithGlobalStateImpl()
    }

    fun setBlockTerminated(value: Bool) r: Void {
        setBlockTerminatedWithGlobalStateImpl(value)
    }

    fun syncState() r: Void {
        let state = getSharedCodegenState()
        // Legacy layout field only. FunctionLoweringOptions is the source of truth.
        this.indent = 0
        syncCodegenStateFromGlobalStateImpl(state, this.output,
            this.stringConstants, getFeatureRegBoxImpl(),
            getFeatureBlockBoxImpl(), this.varNames, this.varRegs,
            this.varTypes, getCurrentFunctionOptions())
    }

    fun writeBackState() r: Void {
        let state = getSharedCodegenState()
        let snapshot = captureCodegenStateBridgeSnapshotImpl(state)
        this.output = snapshot.output
        this.stringConstants = snapshot.stringConstants
        this.varNames = snapshot.varNames
        this.varRegs = snapshot.varRegs
        this.varTypes = snapshot.varTypes
        applyGlobalCodegenStateBridgeSnapshotImpl(snapshot)
        this.indent = 0
    }

    ///
    Pass 1 entry point: scan a ProgramNode and register all declarations
    without generating any IR. This populates:
      - Struct layouts (getGlobalStructFieldNamesImpl()/Types/Layouts via registerStructLayout)
      - Function signatures (funcNames/funcRetTypes via registerFunction)
      - Async function registry (g_asyncFuncNames/RetTypes)
      - Enum variant registry (g_enumVariantNames/Tags/FieldTypes)
      - Cross-module declare strings (g_xmDeclareNames/Strs for `declare` stubs)
    Called once per module by main_compiler.seen before any generateSingle().
    The registries built here form the declarationsHash component of the
    content-addressed IR cache key.
    ///
    fun registerDeclarations(program: ProgramNode) r: Void {
        beginDeclarationRegistrationWithGlobalState(program)

        let declState = captureDeclarationPassState()
        let declItemContext = createDeclarationItemContextFromOwnerState(
            declState)
        let preparedItems = collectPreparedDeclarationItems(program)
        finishDeclarationRegistrationPassImpl(program, preparedItems,
            declItemContext, declState)
        applyDeclarationPassState(declState)
    }

    fun collectClassMethodDeclarationReturnTypes(classNode: ClassNode)
        r: Array<String> {

        let methodRetTypeNames = Array<String>()
        var methodIdx = 0
        while methodIdx < classNode.methods.length() {
            methodRetTypeNames.push(resolveMethodReturnTypeFromList(
                classNode.name, classNode.methods, methodIdx))
            methodIdx = methodIdx + 1
        }
        return methodRetTypeNames
    }

    fun prepareDeclarationItemForRegistration(item: ItemNode)
        r: PreparedDeclarationItem {

        var classMethodRetTypeNames = Array<String>()
        var funcRetTypeName = ""
        if item.itemType == "Class" {
            classMethodRetTypeNames =
                collectClassMethodDeclarationReturnTypes(item.classNode)
        }
        if item.itemType == "Function" {
            funcRetTypeName = resolveFunctionReturnType(item.function)
        }
        return prepareDeclarationItemForRegistrationImpl(item,
            classMethodRetTypeNames, funcRetTypeName)
    }

    fun collectPreparedDeclarationItems(program: ProgramNode)
        r: Array<PreparedDeclarationItem> {

        let preparedItems = Array<PreparedDeclarationItem>()
        var itemIdx = 0
        while itemIdx < program.items.length() {
            let item = program.items[itemIdx]
            if item.itemType == "Class" or item.itemType == "Data" {
                registerStructLayoutState(item.classNode)
            }
            preparedItems.push(prepareDeclarationItemForRegistration(item))
            itemIdx = itemIdx + 1
        }
        return preparedItems
    }

    ///
    Helper to find variable type (checks both this.varTypes and preAllocatedTypes)
    Searches backwards for speed.
    ///
    fun findVarType(name: String) r: String {
        return findVarTypeState(this.varNames, this.varTypes, name)
    }

    ///
    Helper to find module constant by name. Searches backwards.
    Falls back to cross-module constant registry if not found in current module.
    ///
    fun findModuleConstant(name: String) r: Int {
        return findModuleConstantWithModuleStateImpl(name)
    }

    ///
    Pre-scan a function's block to collect all variable declarations.
    ///
    fun collectVariableDeclarations(block: BlockNode) r: Void {
        collectVariableDeclarationsState(block, this.varNames, this.varTypes,
            this.stringConstants)
    }

    ///
    Infer a declaration initializer type with an extra fast path for
    static method calls like Counter.new() and Foo.fromJson(...).
    ///
    fun inferDeclarationInitializerType(expr: ParserExpressionNode) r: String {
        return inferDeclarationInitializerTypeState(expr, this.varNames,
            this.varTypes, this.stringConstants)
    }

    // Helper to collect variables from a single statement - separate method to avoid merging
    fun collectStmtVars(stmt: StatementNode) r: Void {
        collectStmtVarsState(stmt, this.varNames, this.varTypes,
            this.stringConstants)
    }

    ///
    Resolve the type of a chained path like "item.function.returnType"
    Returns the type of the final field in the chain
    ///
    fun resolveChainedPathType(path: String) r: String {
        return resolveChainedPathTypeState(path, this.varNames, this.varTypes,
            this.stringConstants)
    }

    // Single-module entry point: wraps generateMultiple with one program.
    fun generate(program: ProgramNode) r: String {
        // Single module compilation
        let programs = Array<ProgramNode>()
        programs.push(program)
        return generateMultiple(programs)
    }

    fun resetSharedModuleGenerationScratchState() r: Void {
        let scratchState = resetSharedModuleGenerationScratchStateImpl()
        this.output = scratchState.output
        this.stringConstants = scratchState.stringConstants
        g_closureCount = scratchState.closureCount
        g_closureDefs = scratchState.closureDefs
        g_pforCount = scratchState.pforCount
        g_comptimeNames = scratchState.comptimeNames
        g_comptimeValues = scratchState.comptimeValues
        g_comptimeCount = scratchState.comptimeCount
        g_intrinsicFuncNames = scratchState.intrinsicFuncNames
        g_intrinsicLlvmNames = scratchState.intrinsicLlvmNames
        g_intrinsicCount = scratchState.intrinsicCount
        g_sendTypes = scratchState.sendTypes
        g_syncTypes = scratchState.syncTypes
    }

    fun emitProgramClassTypes(program: ProgramNode) r: Void {
        emitProgramClassTypesState(this.output, program)
    }

    fun generateProgramClasses(program: ProgramNode) r: Void {
        var i = 0
        while shouldVisitProgramFlowIndexImpl(i, program.items.length()) {
            let item = program.items[i]
            if shouldGenerateProgramClassItemImpl(item.itemType) {
                if canUseLargePlainClassPathImpl(item.classNode.parentName, item.classNode.decorators, item.classNode.methods) {
                    generatePlainLargeClass(item.classNode.name, item.classNode.parentName, item.classNode.methods)
                } else {
                    generateClass(item.classNode)
                }
            }
            i = i + 1
        }
    }

    fun emitProgramTopLevelFunctions(program: ProgramNode, moduleIndex: Int,
        traceModule: Bool) r: Void {

        var i = 0
        while shouldVisitProgramFlowIndexImpl(i, program.items.length()) {
            let item = program.items[i]
            var plannedFnName = ""
            if item.itemType == "Function" {
                plannedFnName = item.function.name
            }
            let fnPlan = planProgramTopLevelFunctionStartImpl(item.itemType,
                traceModule, shouldSkipStandaloneTopLevelFunctionImpl(
                plannedFnName))
            if fnPlan.shouldHandleFunction {
                let fnName = item.function.name
                if fnPlan.shouldSkipStandalone {
                    i = i + 1
                    continue
                }
                let handledSpecial = tryHandleSpecialTopLevelFunctionImpl(
                    item.function, this.output, getGlobalFuncNamesImpl(),
                    getGlobalFuncRetTypesImpl())
                let afterSpecialPlan =
                    planProgramTopLevelFunctionAfterSpecialImpl(traceModule,
                        fnPlan.shouldTrySpecialHandler, handledSpecial)
                if not afterSpecialPlan.shouldGenerateFunction {
                    i = i + 1
                    continue
                }
                generateFunction(item.function)
            }
            i = i + 1
        }
    }

    ///
    Multi-module monolithic entry point: generates a single .ll file
    containing IR for ALL programs. Used by the `--release` path and
    single-file compilation. Follows the three-pass architecture:
      1. Collect string constants from all programs
      2. Emit prologue, struct types, globals, string constants, runtime decls
      3. Generate class methods (BEFORE top-level functions — see ordering
         note below), then top-level functions, then closures
    Class methods are generated before top-level functions so that
    registerStructMethod() calls from @derive/@reflect/@binary/@packet
    decorators complete before generateFunction(main) tries to resolve
    method return types.
    ///
    fun generateMultiple(programs: Array<ProgramNode>) r: String {
        resetSharedModuleGenerationScratchState()
        setStringConstantPrefixWithGlobalStateImpl("")  // No prefix for multi-module

        collectProgramsStringConstantsState(programs, this.stringConstants)

        // Emit module header
        emitPrologue()

        emitProgramsClassTypesState(this.output, programs)

        emitProgramsGlobalVariablesState(this.output, programs)

        // Emit string constants
        emitStringConstantsImpl(this.output, this.stringConstants)
        let stringConstCountBeforeGen = this.stringConstants.length()

        // Emit runtime declarations
        let definedFuncs = Array<String>()
        emitRuntimeDeclarations(definedFuncs)

        // Sync class fields → CodegenState before code generation begins.
        syncState()

        ///
        WHY class methods BEFORE top-level functions:
        @derive/@reflect/@binary/@packet decorators on classes call
        registerStructMethod() during generateClass(), which populates
        getGlobalStructMethodNamesImpl()/getGlobalStructMethodRetTypesImpl(). If generateFunction(main)
        runs first, it calls inferExpressionType on method calls like
        obj.serialize(), but the method return type isn't registered yet,
        causing type inference to fail and generate incorrect IR.
        ///
        var classPi = 0
        while shouldVisitProgramFlowIndexImpl(classPi, programs.length()) {
            generateProgramClasses(programs[classPi])
            classPi = classPi + 1
        }

        // Emit functions (top-level) from all programs
        var fnPi = 0
        while shouldVisitProgramFlowIndexImpl(fnPi, programs.length()) {
            emitProgramTopLevelFunctions(programs[fnPi], 0, false)
            fnPi = fnPi + 1
        }

        // Emit vtable constants for trait implementations
        emitTraitVtableConstantsWithFeatureStateImpl(this.output)

        emitAdditionalGeneratedStringConstantsImpl(this.output, this.stringConstants,
            getStringConstantPrefixWithGlobalStateImpl(),
            stringConstCountBeforeGen)
        emitGeneratedClosuresWithFeatureStateImpl(this.output)

        emitOptimizationStatisticsSummaryImpl(this.output, 0, false,
            g_branchesEliminated, g_deadStatementsEliminated,
            g_constantsFolded, g_cseHits, g_loopsOptimized,
            g_deadStoresEliminated, g_reductionChainsDetected)

        // Emit @llvm.global_ctors for @init functions
        emitGlobalConstructorsWithFeatureStateImpl(this.output)

        // Emit TBAA metadata at end of module
        emitTBAAMetadata()
        emitLoopMetadata()

        // Write ML decision log and print stats (single-module path)
        writeMLDecisionLog()

        return this.output.toString()
    }

    ///
    Per-module entry point: generates one .ll file for a single source
    module, identified by moduleIndex. This is the hot path used by the
    ThinLTO build pipeline and fork-parallel IR generation.

    Resets all per-module state (reset()), then:
      1. Collects string constants and call counts for ML inline decisions
      2. Emits prologue with module-specific string constant prefix (M0., M1., ...)
      3. Emits struct types, globals, cross-module declares, runtime decls
      4. Generates class methods BEFORE top-level functions (same ordering
         rationale as generateMultiple — registerStructMethod must run first)
      5. Emits closures, optimization stats, @init constructors, TBAA metadata

    The struct/function registries are NOT reset — they persist from Pass 1
    (registerDeclarations) and are shared across all modules.
    ///
    fun generateSingle(program: ProgramNode, moduleIndex: Int) r: String {
        ///
        Reset ALL per-module codegen state (generatedFunctions, generatedClasses,
        nextReg, nextBlock, currentFunctionReturnType, loop labels, opt counters, etc.)
        ///
        reset()
        // Module-specific state not covered by reset()
        resetSharedModuleGenerationScratchState()
        // Set module prefix for string constants (e.g., "M0.", "M1.", etc.)
        setStringConstantPrefixWithGlobalStateImpl(
            "M" + moduleIndex.toString() + ".")

        // Load ML heuristic weights (once per compilation)
        loadMLWeights()

        ///
        Collect string constants for THIS module only
        Also piggybacks call counting for ML inline decisions + self-call detection
        ///
        callCountClear()
        selfCallClear()
        collectStringConstants(program)

        // Emit module header
        emitPrologue()

        // Emit class struct type definitions for THIS module
        emitProgramClassTypes(program)

        ///
        NOTE: vtable constants are emitted AFTER function generation (see below)
        because g_traitImplRegistry is populated during generateFunction's impl detection.
        ///

        // Emit global variable declarations for THIS module
        emitProgramGlobalVariablesState(this.output, program)

        // Emit external declarations for cross-module constants not defined in this module
        emitCrossModuleConstantDeclaresWithModuleStateImpl(this.output)

        // Emit string constants with module prefix
        emitStringConstantsWithPrefixImpl(this.output, this.stringConstants,
            moduleIndex)
        ///
        Track how many string constants exist before class/function generation
        (derive/reflect/json codegen may add new constants that need separate emission)
        ///
        var stringConstCountBeforeGen = this.stringConstants.length()

        // Collect function names defined in this module (to skip their declarations)
        let definedFuncs = collectProgramDefinedSymbolsImpl(program)

	        ///
	        Cross-module user declarations are emitted lazily after codegen.
	        Large projects can register thousands of functions; eagerly copying
	        every declare into every module turns Pass 2 into O(modules * decls)
	        string growth. Call emission records the actually referenced symbols.
	        ///

        // Emit runtime declarations (skip functions defined in this module)
        emitRuntimeDeclarations(definedFuncs)

        ///
        Sync class fields → CodegenState before code generation begins.
        Free functions in satellite modules use state.* for shared access.
        ///
        syncState()

        ///
        WHY class methods BEFORE top-level functions: see generateMultiple.
        registerStructMethod() must populate method return types before
        generateFunction(main) calls inferExpressionType on method calls.
        ///
        generateProgramClasses(program)

        // Emit functions (top-level) for THIS module
        emitProgramTopLevelFunctions(program, moduleIndex, false)

        emitLateUserDeclaresWithModuleStateImpl(this.output, definedFuncs)

        ///
        Emit vtable constants for trait implementations found in this module
        Must be AFTER generateFunction so g_traitImplRegistry is populated
        ///
        emitTraitVtableConstantsWithFeatureStateImpl(this.output)

        emitAdditionalGeneratedStringConstantsImpl(this.output, this.stringConstants,
            getStringConstantPrefixWithGlobalStateImpl(),
            stringConstCountBeforeGen)

        emitGeneratedClosuresWithFeatureStateImpl(this.output)

        emitUnusedTopLevelFunctionWarningsImpl(this.output, program)

        emitOptimizationStatisticsSummaryImpl(this.output, moduleIndex, false,
            g_branchesEliminated, g_deadStatementsEliminated,
            g_constantsFolded, g_cseHits, g_loopsOptimized,
            g_deadStoresEliminated, g_reductionChainsDetected)

        // Clear per-module CSE cache (expressions don't carry across modules)
        cseClear()

        // Flush ML decision log if enabled (appends per-module decisions)
        writeMLDecisionLog()

        // Emit @llvm.global_ctors for @init functions (multi-module path)
        emitGlobalConstructorsWithFeatureStateImpl(this.output)

        // Emit TBAA metadata at end of module
        emitTBAAMetadata()
        emitLoopMetadata()

        return this.output.toString()
    }

    ///
    Emit the LLVM IR module header: target datalayout, target triple,
    and the %SeenString / %SeenArray struct type definitions that are
    used by all generated code.
    ///
    fun emitPrologue() r: Void {
        emitModulePrologueWithGlobalStateImpl(this.output)
    }

    fun emitTBAAMetadata() r: Void {
        emitTBAAMetadataWithFeatureStateImpl(this.output)
    }

    fun emitLoopMetadata() r: Void {
        emitLoopMetadataWithMetricsStateImpl(this.output, getCurrentFunctionOptions())
    }

    fun emitClassType(classNode: ClassNode) r: Void {
        emitClassTypeState(this.output, classNode)
    }

    fun emitTraitDefaultMethod(className: String, traitMethod: FunctionNode, traitRetTypeName: String) r: Void {
        let defaultFuncName = className + "_" + traitMethod.name + "_default"
        this.output.append("; trait default method: " + defaultFuncName + "\n")
        let savedNestedState = beginNestedScratchState(traitRetTypeName)
        cseClear()
        var defaultParamStr = ""
        var paramIdx = 0
        while paramIdx < traitMethod.params.length() {
            if paramIdx > 0 {
                defaultParamStr = defaultParamStr + ", "
            }
            let defaultParam = traitMethod.params[paramIdx]
            let defaultParamType = mapTypeState(normalizeDeclaredTypeNodeImpl(defaultParam.paramType))
            let defaultParamReg = "%" + quoteIdentIfNeededImpl(defaultParam.name)
            defaultParamStr = defaultParamStr + defaultParamType + " " + defaultParamReg
            setActiveVarCountWithGlobalStateImpl(storeActiveVariableBindingImpl(this.varNames, this.varRegs,
                this.varTypes, getBoundedActiveVarCountWithGlobalStateImpl(this.varNames), defaultParam.name, defaultParamReg,
                normalizeDeclaredTypeNodeImpl(defaultParam.paramType)))
            paramIdx = paramIdx + 1
        }
        let defaultRetType = mapTypeState(traitRetTypeName)
        this.output.append("define " + defaultRetType + " @" + quoteIdentIfNeededImpl(defaultFuncName) + "(" + defaultParamStr + ") {\n")
        this.output.append("entry:\n")
        generateBlock(traitMethod.body)
        if not isBlockTerminated() {
            if defaultRetType == "void" {
                this.output.append("  ret void\n")
            } else {
                this.output.append("  ret " + defaultRetType + " zeroinitializer\n")
            }
        }
        this.output.append("}\n\n")
        restoreNestedScratchState(savedNestedState)
        registerFunctionStateImpl(defaultFuncName, traitRetTypeName,
            getGlobalFuncNamesImpl(), getGlobalFuncRetTypesImpl())
    }

    fun tryGenerateTraitClass(classNode: ClassNode) r: Bool {
        if not isTraitClassNodeImpl(classNode) {
            return false
        }

        let className = classNode.name
        this.output.append("; trait " + className + " (method signatures + default impls)\n")
        var traitMethodIdx = 0
        while traitMethodIdx < classNode.methods.length() {
            let traitMethod = classNode.methods[traitMethodIdx]
            let traitFuncName = className + "_" + traitMethod.name
            let traitRetTypeName = resolveMethodReturnType(className, traitMethod)
            registerFunctionStateImpl(traitFuncName, traitRetTypeName,
                getGlobalFuncNamesImpl(), getGlobalFuncRetTypesImpl())
            registerStructMethodReg(className, traitMethod.name,
                traitRetTypeName, getGlobalStructNamesImpl(), getGlobalStructMethodNamesImpl(),
                getGlobalStructMethodRetTypesImpl(), getGlobalFuncNamesImpl(),
                getGlobalFuncRetTypesImpl())
            if traitMethod.body.statements.length() > 0 {
                emitTraitDefaultMethod(className, traitMethod, traitRetTypeName)
            }
            traitMethodIdx = traitMethodIdx + 1
        }

        emitTraitVtableTypeState(this.output, classNode)
        return true
    }

    fun tryHandleTypeAliasClass(classNode: ClassNode) r: Bool {
        return tryHandleTypeAliasClassState(this.output, classNode)
    }

    fun generateRegularClassMethods(classNode: ClassNode, isStringBuilder: Bool) r: Void {
        var methodIdx = 0
        while methodIdx < classNode.methods.length() {
            let method = classNode.methods[methodIdx]
            let methodName = method.name
            if shouldSkipSourceClassMethodImpl(methodName, isStringBuilder) {
                methodIdx = methodIdx + 1
                continue
            }
            generateClassMethodFromList(classNode.name, classNode.parentName,
                classNode.methods, methodIdx)
            methodIdx = methodIdx + 1
        }
    }

    fun generatePlainLargeClass(className: String, parentName: String, methods: Array<FunctionNode>) r: Void {
        if className == "" {
            return
        }

        let isStringBuilder = className == "StringBuilder"

        var methodIdx = 0
        while methodIdx < methods.length() {
            let method = methods[methodIdx]
            let methodName = method.name
            if shouldSkipSourceClassMethodImpl(methodName, isStringBuilder) {
                methodIdx = methodIdx + 1
                continue
            }
            generateClassMethodFromList(className, parentName, methods, methodIdx)
            methodIdx = methodIdx + 1
        }

        g_currentClassParentName = ""
    }

    ///
    Generate IR for all methods of a class, plus derived implementations
    (@derive, @reflect, @binary, @packet decorators). Skips @trait
    definitions (which only generate default method implementations).
    Handles the `new` constructor specially: emits malloc + memset zero-init
    followed by field initialization. For classes with Array<T> fields,
    post-constructor code emits seen_arr_new_* calls using byte-offset
    i8 GEP to initialize array headers (fixes null-ptr-after-constructor bug).
    NOTE: Uses memset zero-init instead of per-field GEP to avoid the
    cross-module GEP bug where %ClassName from module Y is not available in
    module X.
    ///
    fun generateClass(classNode: ClassNode) r: Void {
        // Skip classes with parsing issues
        let className = classNode.name
        if className == "" {
            // Empty class name means parsing issue - skip to avoid bad code
            return
        }

        if tryGenerateTraitClass(classNode) {
            return
        }

        if tryHandleTypeAliasClass(classNode) {
            return
        }

        ///
        For StringBuilder, the runtime-backed methods should not be emitted from
        the source class because call sites already dispatch to the C runtime ABI.
        ///
        let isStringBuilder = className == "StringBuilder"

        let decoratorSnapshot =
            prepareGeneratedClassDecoratorSnapshotImpl(classNode)
        generateRegularClassMethods(classNode, isStringBuilder)

        // Generate @hot_reload synthesized methods if class has the decorator
        if decoratorSnapshot.isHotReload == 1 {
            generateHotReloadMethodsImpl(this.output, classNode)
        }

        emitGeneratedClassDecoratorMethodsImpl(this.output, classNode,
            decoratorSnapshot.decoratorFlags, decoratorSnapshot.packetId,
            getGlobalStructNamesImpl(), getGlobalStructSizesImpl(),
            getGlobalStructMethodNamesImpl(), getGlobalStructMethodRetTypesImpl(), getGlobalFuncNamesImpl(),
            getGlobalFuncRetTypesImpl(),
            this.stringConstants, getStringConstantPrefixWithGlobalStateImpl(),
            g_binaryClassNames,
            g_binaryVersions, g_binaryEndianness, g_binaryClassCount)
        emitInheritedClassMethodThunksImpl(this.output, getFeatureRegBoxImpl(), classNode,
            getGlobalStructNamesImpl(), getGlobalStructMethodNamesImpl(), getGlobalStructMethodRetTypesImpl(),
            g_reprCClassNames, g_typeAliasNames, g_typeAliasTargets,
            g_typeAliasCount, g_enumTypeNames)

        g_currentClassParentName = ""
    }

    ///
    Generate IR for a single class method. The method name is mangled as
    ClassName_methodName. Non-static methods receive an implicit `ptr %this`
    first parameter pointing to the heap-allocated struct.

    Option class methods (isSome, isNone) are inlined against the direct-value
    option object layout used by runtime unwrap helpers.
    rather than delegated to the C runtime.

    CRITICAL: cseClear() is called at method entry to prevent the cross-method
    CSE bug. Without it, a CSE key like "%4*%7->%8" cached from method A
    could match the same register numbers in method B (since each method
    resets nextReg to 1), producing self-referential IR that causes LLVM
    verification failures.
    ///
    fun resetClassMethodGenerationState(className: String, parentName: String, methods: Array<FunctionNode>, methodIdx: Int) r: Void {
        resetLocalCodegenState()
        setCurrentFunctionReturnTypeWithGlobalStateImpl(
            resolveMethodReturnTypeFromList(className, methods, methodIdx))
        setGlobalCurrentClassNameImpl(className)
        g_currentClassParentName = parentName
        resetFunctionLoweringOptionsStateImpl(getCurrentFunctionOptions())
        resetFunctionEmissionForFunctionImpl(
            getCurrentFunctionEmissionStateImpl())
        cseClear()
    }

    fun prepareClassMethodVariableCollection(className: String, methods: Array<FunctionNode>, methodIdx: Int,
        normalizedMethodParamTypes: Array<String>) r: Void {

        let method = methods[methodIdx]
        if not method.isStatic {
            setActiveVarCountWithGlobalStateImpl(storeActiveVariableBindingImpl(this.varNames, this.varRegs,
                this.varTypes, getBoundedActiveVarCountWithGlobalStateImpl(this.varNames), "this", "", className))
        }
        var paramIdx = 0
        while paramIdx < method.params.length() {
            let param = method.params[paramIdx]
            setActiveVarCountWithGlobalStateImpl(storeActiveVariableBindingImpl(this.varNames, this.varRegs,
                this.varTypes, getBoundedActiveVarCountWithGlobalStateImpl(this.varNames), param.name, "",
                normalizedMethodParamTypes[paramIdx]))
            paramIdx = paramIdx + 1
        }
        collectVariableDeclarations(method.body)
        clearActiveBindings()
    }

    fun generateClassMethodFromList(className: String, parentName: String, methods: Array<FunctionNode>, methodIdx: Int) r: Void {
        let method = methods[methodIdx]
        let methodName = method.name
        if tryEmitOptionClassMethodShimImpl(this.output, className, methodName) == 1 {
            return
        }

        resetClassMethodGenerationState(className, parentName, methods, methodIdx)

        let normalizedMethodParamTypes = Array<String>()
        let mappedMethodParamTypes = Array<String>()
        let quotedMethodArgNames = Array<String>()
        collectClassMethodParameterInfoImpl(methods, methodIdx,
            normalizedMethodParamTypes, mappedMethodParamTypes,
            quotedMethodArgNames)
        prepareClassMethodVariableCollection(className, methods, methodIdx, normalizedMethodParamTypes)

        let returnType = mapTypeState(
            getCurrentFunctionReturnTypeWithGlobalStateImpl())
        let isStatic = method.isStatic or methodName == "new"
        let explicitReceiverName = emitClassMethodSignatureStateImpl(this.output,
            methods, methodIdx, className, methodName, isStatic, returnType,
            mappedMethodParamTypes, quotedMethodArgNames,
            getMetricsSelfCallFuncsImpl(), getMetricsSelfCallNamesImpl(),
            getMetricsSelfCallCountImpl())
        setActiveVarCountWithGlobalStateImpl(emitClassMethodReceiverBindingStateImpl(this.output,
            getFeatureRegBoxImpl(), this.varNames, this.varRegs, this.varTypes, getBoundedActiveVarCountWithGlobalStateImpl(this.varNames), className,
            isStatic, explicitReceiverName))
        setActiveVarCountWithGlobalStateImpl(emitClassMethodParameterBindingsStateImpl(this.output,
            getFeatureRegBoxImpl(), this.varNames, this.varRegs, this.varTypes, getBoundedActiveVarCountWithGlobalStateImpl(this.varNames), methods,
            methodIdx, explicitReceiverName, normalizedMethodParamTypes,
            quotedMethodArgNames))
        let classMethodPreAllocatedTypes = getPreAllocatedTypesWithGlobalStateImpl()
        let classMethodPreAllocatedLlvmTypes = Array<String>()
        var classMethodPreAllocatedIdx = 0
        while classMethodPreAllocatedIdx < classMethodPreAllocatedTypes.length() {
            classMethodPreAllocatedLlvmTypes.push(mapTypeState(
                classMethodPreAllocatedTypes[classMethodPreAllocatedIdx]))
            classMethodPreAllocatedIdx = classMethodPreAllocatedIdx + 1
        }
        setPreAllocatedRegsWithGlobalStateImpl(emitPreAllocatedAllocasImpl(
            this.output, getFeatureRegBoxImpl(),
            classMethodPreAllocatedLlvmTypes))
        setActiveVarCountWithGlobalStateImpl(emitClassMethodConstructorSetupStateImpl(this.output,
            getFeatureRegBoxImpl(), this.varNames, this.varRegs, this.varTypes, getBoundedActiveVarCountWithGlobalStateImpl(this.varNames), className,
            methodName, method.isStatic, methods, methodIdx,
            getGlobalStructNamesImpl(), getGlobalStructSizesImpl(), getGlobalStructLayoutsImpl(), getGlobalStructFieldNamesImpl(),
            getGlobalStructFieldTypesImpl()))

        generateBlock(method.body)
        setBlockTerminated(tryEmitClassMethodConstructorReturnStateImpl(this.output,
            getFeatureRegBoxImpl(), this.varNames, this.varRegs, getBoundedActiveVarCountWithGlobalStateImpl(this.varNames), methodName,
            isBlockTerminated()))
        emitClassMethodDefaultReturnStateImpl(this.output, returnType,
            isBlockTerminated())
        this.output.append("}\n\n")
    }

    ///
    Delegates to free functions in ir_decl_runtime/parser/features.seen
    Emit `declare` statements for all runtime C functions (seen_runtime.c)
    and standard library functions that might be called from user code.
    Skips functions that are defined in this module (definedFuncs) to
    avoid "invalid redefinition" LLVM errors. Delegates to specialized
    emitters in ir_decl_runtime, ir_decl_parser, ir_decl_features.
    ///
    fun emitRuntimeDeclarations(definedFuncs: Array<String>) r: Void {
        emitRuntimeDeclarationsWithGlobalStateImpl(this.output, definedFuncs)
    }

    ///
    Generate IR for a top-level (free) function. Handles decorators:
      @cfg — conditional compilation (skip if predicate doesn't match)
      @intrinsic — emit thin wrapper calling an LLVM intrinsic
      @inline/@noinline — LLVM inlining hints (alwaysinline/noinline)
      @compute — GPU shader (skip IR, handled by GLSL codegen)
      @async — LLVM coroutine-based async function
      @profile — instrumentation profiling (call enter/exit hooks)
      @vectorize/@no_vectorize/@unroll/@prefetch — loop optimization hints

    Extern functions (body has no statements, name starts with "__") are
    skipped — they must have explicit `declare` in ir_declarations.seen.

    Function bodies are wrapped in: entry block -> alloca hoisting ->
    parameter stores -> body generation -> implicit void return.
    ML-guided inlining decisions are logged when g_mlLogEnabled is set.
    ///
    fun prepareFunctionPreBodyAndTryEmitMain(fn: FunctionNode,
        implFuncName: String, resolvedFunctionReturnType: String,
        returnTypeBox: Array<String>) r: Bool {

        g_currentClassParentName = ""
        let functionEmission = getCurrentFunctionEmissionStateImpl()
        resetFunctionEmissionForFunctionImpl(functionEmission)
        resetFunctionHighPressureImpl(getCurrentFunctionOptions())
        syncState()
        prepareFunctionPreBodyWithFeatureStateImpl(getSharedCodegenState(),
            fn, implFuncName, resolvedFunctionReturnType)
        writeBackState()

        // Clear CSE cache at function boundaries
        cseClear()

        // Collect all variable declarations for hoisting allocas to entry block
        collectVariableDeclarations(fn.body)

        // Clear pre-registered parameters (will be re-added with proper registers)
        clearActiveBindings()

        returnTypeBox[0] = mapTypeState(resolvedFunctionReturnType)

        if not isMainFunctionNameImpl(implFuncName) {
            return false
        }
        functionEmission.isMainFunc = 1
        let mainReturnType = emitMainFunctionEntryWithGlobalStateImpl(
            this.output, getFeatureRegBoxImpl(), returnTypeBox[0])
        generateBlock(fn.body)
        emitMainFunctionExitImpl(this.output, isBlockTerminated(),
            mainReturnType)
        functionEmission.isMainFunc = 0
        return true
    }

    fun generateFunction(fn: FunctionNode) r: Void {
        if shouldSkipFunctionByCfgStateImpl(this.output, fn, g_enabledFeatures) {
            return
        }

        emitFunctionDecoratorMetadataCommentsStateImpl(this.output, fn,
            g_traitImplCount)

        if tryHandleFunctionIntrinsicDriverGlobalStateImpl(this.output,
            getFeatureRegBoxImpl(), fn, getGlobalStructNamesImpl(), g_typeAliasNames, g_typeAliasTargets,
            g_typeAliasCount, g_enumTypeNames) {

            return
        }

        if prepareFunctionDecoratorPreflightGlobalStateImpl(this.output,
            getFeatureRegBoxImpl(), fn) {

            return
        }

        if shouldSkipSpecialFunctionBodyStateImpl(this.output, fn) {
            return
        }

        if tryHandleExternFunctionGenerationWithGlobalStateImpl(this.output,
            fn) {
            return
        }

        let functionIdentity = prepareFunctionGenerationIdentityWithGlobalStateImpl(
            fn, resolveFunctionReturnType(fn))
        let identityFlow = planFunctionIdentityFlowImpl(
            functionIdentity.alreadyGenerated,
            functionIdentity.skipRuntimeBuiltinStub)
        if identityFlow.shouldEmitRuntimeSkipNote {
            this.output.append("; skipped user stub for runtime builtin: " +
                functionIdentity.implFuncName + "\n")
        }
        if identityFlow.shouldReturn {
            return
        }

        let returnTypeBox = Array<String>()
        returnTypeBox.push("")
        if prepareFunctionPreBodyAndTryEmitMain(fn,
            functionIdentity.implFuncName,
            functionIdentity.resolvedFunctionReturnType, returnTypeBox) {
            return
        }
        let fnName = functionIdentity.implFuncName
        let returnType = returnTypeBox[0]

        // Build function attributes
        var funcAttrs = prepareFunctionAttributeGlobalStateImpl(this.output,
            fn)

        // ML-guided inline decision
        let preludeAnalysis = prepareFunctionPreludeAnalysisWithMetricsStateImpl(
            this.output, fn, fnName, funcAttrs)
        funcAttrs = preludeAnalysis.funcAttrs
        applyFunctionPreludeMlLogsImpl(preludeAnalysis, fnName)

        let functionEmission = getCurrentFunctionEmissionStateImpl()
        // ML register pressure estimation (9.7): count unique variables
        let highPressurePlan = planFunctionHighPressureImpl(
            preludeAnalysis.highPressure)
        if highPressurePlan.shouldMarkEmission {
            markFunctionEmissionHighPressureImpl(functionEmission)
        }
        if highPressurePlan.shouldMarkLowering {
            markFunctionHighPressureImpl(getCurrentFunctionOptions())
        }

        // Clear CSE cache at function boundary (safe to re-enable within function scope)
        cseClear()

        syncState()
        let state = getSharedCodegenState()
        let entrySetup = emitFunctionEntrySetupSnapshotImpl(state, fn, fnName,
            returnType, funcAttrs)
        writeBackState()
        let entryExitFlow = planFunctionEntryExitFlowImpl()
        if entryExitFlow.shouldApplyEntrySetup {
            applyFunctionEntrySetupToEmissionImpl(functionEmission, entrySetup)
        }
        if entryExitFlow.shouldApplyUnusedParamLogs {
            applyFunctionUnusedParamMlLogsImpl(entrySetup.unusedParams, fnName)
        }

        // Generate function body
        generateBlock(fn.body)

        syncState()
        let exitState = emitFunctionExitResetSnapshotImpl(state, fn,
            returnType)
        writeBackState()
        if entryExitFlow.shouldApplyExitState {
            applyFunctionExitStateToEmissionImpl(functionEmission, exitState)
        }
    }

    ///
    Generate IR for a block of statements. Manages the defer stack depth
    (saves on entry, emits deferred expressions in LIFO order on exit).
    Performs dead store elimination: scans for "var x = literal; x = expr"
    patterns where x is not read between the two stores, and skips the
    first literal initialization.
    ///
    fun generateBlock(block: BlockNode) r: Void {
        // Save defer stack depth for this block scope
        let blockScope = captureFunctionBodyBlockScopeImpl(g_deferCount,
            g_deadStoreSkipVars, getBoundedActiveVarCountWithGlobalStateImpl(this.varNames))

        ///
        Dead store elimination (9.10b): scan for var x = literal; x = expr2 with no read of x
        Only skip literal initializers (Int, Float, Bool, String) to preserve side effects
        ///
        let deadStoreScan = scanFunctionBodyDeadStorePatternsSnapshotImpl(
            this.output, block, g_deadStoresEliminated, g_deadStoreSkipVars)
        g_deadStoresEliminated = deadStoreScan.deadStoresEliminated
        g_deadStoreSkipVars = deadStoreScan.deadStoreSkipVars

        var i = 0
        while i < block.statements.length() {
            if isBlockTerminated() {
                let deadCodeNotice =
                    emitFunctionBodyTrailingDeadCodeNoticeSnapshotImpl(this.output,
                        block, i, g_deadStatementsEliminated)
                g_deadStatementsEliminated =
                    deadCodeNotice.deadStatementsEliminated
                break
            }
            generateStatement(block.statements[i])
            i = i + 1
        }

        var deferCleanupIdx = beginFunctionBodyBlockDeferredCleanupImpl(this.output,
            blockScope.savedDeferCount, g_deferCount, isBlockTerminated())
        while deferCleanupIdx >= blockScope.savedDeferCount {
            generateExpression(g_deferExprs[deferCleanupIdx])
            deferCleanupIdx = deferCleanupIdx - 1
        }

        // Restore defer stack to saved depth
        g_deferCount = blockScope.savedDeferCount
        // Restore dead store skip list (scoped to this block)
        g_deadStoreSkipVars = blockScope.savedDeadStoreSkipVars
        setActiveVarCountWithGlobalStateImpl(blockScope.savedActiveVarCount)
    }

    fun warnUnusedResultCall(expr: ParserExpressionNode) r: Void {
        emitUnusedResultCallWarningImpl(this.output, expr, g_warnUnusedResult,
            g_tryCatchLabel, getGlobalFuncNamesImpl(), getGlobalFuncRetTypesImpl())
    }

    fun generateExpressionStatement(stmt: StatementNode) r: Void {
        let exprStmtAction = planFunctionBodyExpressionStatementImpl(
            stmt.expression)
        if exprStmtAction == 1 {
            generateAssignmentExpr(stmt.expression)
            return
        }
        if exprStmtAction == 2 {
            generateMemberAssignment(stmt.expression)
            return
        }
        if exprStmtAction == 3 {
            generateIndexAssignment(stmt.expression)
            return
        }
        warnUnusedResultCall(stmt.expression)
        generateExpression(stmt.expression)
    }

    fun emitContinueStatement() r: Void {
        if emitContinueStatementImpl(this.output,
            getCurrentLoopCondLabelWithGlobalStateImpl()) == 1 {
            setBlockTerminated(true)
        }
    }

    fun emitBreakStatement() r: Void {
        if emitBreakStatementImpl(this.output,
            getCurrentLoopEndLabelWithGlobalStateImpl()) == 1 {
            setBlockTerminated(true)
        }
    }

    fun generateTryCatchStatement(stmt: StatementNode) r: Void {
        let tryCatchContext = beginTryCatchStatementSnapshotImpl(this.output,
            getFeatureBlockBoxImpl(), g_tryCatchLabel, g_tryCatchEndLabel)
        g_tryCatchLabel = tryCatchContext.currentTryCatchLabel
        g_tryCatchEndLabel = tryCatchContext.currentTryCatchEndLabel
        if stmt.thenBranch.statements.length() > 0 {
            generateBlock(stmt.thenBranch)
        }
        setBlockTerminated(finalizeTryCatchArmImpl(this.output,
            isBlockTerminated(), tryCatchContext.tryEndLabel))

        emitTryCatchCatchHeaderImpl(this.output, tryCatchContext.tryCatchLabel)
        let savedCatchVarCount = getBoundedActiveVarCountWithGlobalStateImpl(this.varNames)
        setActiveVarCountWithGlobalStateImpl(bindFunctionBodyCatchVariableImpl(this.output, getFeatureRegBoxImpl(),
            this.varNames, this.varRegs, this.varTypes, getBoundedActiveVarCountWithGlobalStateImpl(this.varNames), stmt.variableName))
        if stmt.elseBranch.statements.length() > 0 {
            generateBlock(stmt.elseBranch)
        }
        setActiveVarCountWithGlobalStateImpl(savedCatchVarCount)
        setBlockTerminated(finalizeTryCatchArmImpl(this.output,
            isBlockTerminated(), tryCatchContext.tryEndLabel))
        emitTryCatchFooterImpl(this.output, tryCatchContext.tryEndLabel)

        g_tryCatchLabel = tryCatchContext.savedTryCatchLabel
        g_tryCatchEndLabel = tryCatchContext.savedTryCatchEndLabel
    }

    ///
    Top-level statement dispatch. Routes each statement kind to its
    specialized generator: Let/Var, Return, If, IfLet, While, ForIn,
    Match, Expression (which may be Assignment, MemberAssignment,
    IndexAssignment, or a general expression), Defer, Errdefer,
    TryCatch, UnsafeBlock, Region, ComptimeIf/Block, ParallelFor.
    Uses fixed action ids from ir_stmt_dispatch_plan to keep routing stable.
    ///
    fun generateStatement(stmt: StatementNode) r: Void {
        let dispatchAction = planStatementDispatchImpl(stmt.kind)
        if dispatchAction == 1 { generateLetStatement(stmt) }
        if dispatchAction == 2 { generateReturnStatement(stmt) }
        if dispatchAction == 3 { generateExpressionStatement(stmt) }
        if dispatchAction == 4 { generateIfStatement(stmt) }
        if dispatchAction == 5 { generateIfLetStatement(stmt) }
        if dispatchAction == 6 { generateWhileStatement(stmt) }
        if dispatchAction == 7 { generateAssignment(stmt) }
        if dispatchAction == 8 { generateForInStatement(stmt) }
        if dispatchAction == 9 { generateRegionStatement(stmt) }
        if dispatchAction == 10 { emitContinueStatement() }
        if dispatchAction == 11 { emitBreakStatement() }
        if dispatchAction == 12 { generateDeferredStatement(stmt, false) }
        if dispatchAction == 13 { generateDeferredStatement(stmt, true) }
        if dispatchAction == 14 and stmt.thenBranch.statements.length() > 0 {
            generateBlock(stmt.thenBranch)
        }
        if dispatchAction == 15 {
            let insideUnsafeBox = Array<Int>()
            insideUnsafeBox.push(g_insideUnsafe)
            enterUnsafeStatementImpl(this.output, insideUnsafeBox)
            g_insideUnsafe = insideUnsafeBox[0]
            if stmt.thenBranch.statements.length() > 0 {
                generateBlock(stmt.thenBranch)
            }
            insideUnsafeBox[0] = g_insideUnsafe
            exitUnsafeStatementImpl(this.output, insideUnsafeBox)
            g_insideUnsafe = insideUnsafeBox[0]
        }
        if dispatchAction == 16 { generateTryCatchStatement(stmt) }
        if dispatchAction == 17 { generateParallelForStatement(stmt) }
        if dispatchAction == 18 { generateComptimeBlock(stmt) }
        if dispatchAction == 19 { generateComptimeAssert(stmt) }
        if dispatchAction == 20 { generateComptimeIf(stmt) }
    }

    fun generateRegionStatement(stmt: StatementNode) r: Void {
        // region [strategy] [name] { body }
        let strategy = normalizeDeclaredTypeNodeImpl(stmt.variableType)
        let regionName = stmt.variableName
        let regionSlot = emitRegionStatementPreambleImpl(this.output, getFeatureRegBoxImpl(),
            strategy, regionName)
        // Generate body
        generateBlock(stmt.thenBranch)
        // Pop and destroy region
        emitRegionStatementCleanupImpl(this.output, getFeatureRegBoxImpl(), regionSlot)
    }

    // parallel_for i in start..end { body } → extract closure, call seen_parallel_for
    fun generateParallelForStatement(stmt: StatementNode) r: Void {
        // The expression should be a range: start..end (parsed as Binary with operator "..")
        let rangeExpr = stmt.expression
        var startReg = ""
        var endReg = ""
        if classifyParallelForRangeExprImpl(rangeExpr) == 1 {
            startReg = generateExpression(rangeExpr.operands[0])
            endReg = generateExpression(rangeExpr.operands[1])
        } else {
            // Fallback: treat expression as end, start = 0
            startReg = "0"
            endReg = generateExpression(rangeExpr)
        }

        // Generate the loop body as an anonymous function
        let pforIdx = g_pforCount
        g_pforCount = g_pforCount + 1
        let bodyFuncName = buildParallelForBodyFunctionNameImpl(pforIdx)
        let pforReturnType = getCurrentFunctionReturnTypeWithGlobalStateImpl()

        let savedNestedState = beginNestedScratchState(pforReturnType)

        emitParallelForBodyHeaderImpl(this.output, bodyFuncName)
        // Bind loop variable to %0
        setActiveVarCountWithGlobalStateImpl(storeActiveVariableBindingImpl(this.varNames, this.varRegs,
            this.varTypes, getBoundedActiveVarCountWithGlobalStateImpl(this.varNames), stmt.variableName, "%0", "Int"))
        // Generate body block
        generateBlock(stmt.loopBody)

        // Store generated body function in closures list
        let bodyFuncIR = finalizeParallelForBodyImpl(this.output,
            isBlockTerminated())
        g_closureDefs = g_closureDefs + bodyFuncIR

        restoreNestedScratchState(savedNestedState)
        emitParallelForCallImpl(this.output, stmt.variableName, startReg, endReg,
            bodyFuncName)
    }

    // comptime { block } — evaluate let bindings at compile time, store in comptime registry
    fun generateComptimeBlock(stmt: StatementNode) r: Void {
        this.output.append("  ; comptime block\n")
        processComptimeStatements(stmt.thenBranch)
    }

    // Process comptime block statements, supporting Let/Var, Assignment, While
    fun processComptimeStatements(block: BlockNode) r: Void {
        var ctIdx = 0
        while ctIdx < block.statements.length() {
            let ctStmt = block.statements[ctIdx]
            let ctAction = classifyComptimeStatementKindImpl(ctStmt.kind)
            if shouldProcessComptimeLetImpl(ctAction) {
                // Try integer evaluation first
                let ctVal = evaluateConstExprState(ctStmt.initializer)
                if shouldRegisterComptimeIntValueImpl(ctVal) {
                    registerComptimeVarState(ctStmt.variableName, ctVal)
                    emitComptimeIntNoteImpl(this.output, "let ",
                        ctStmt.variableName, ctVal)
                } else {
                    // Try string evaluation
                    let ctStrVal = evaluateConstExprStrState(ctStmt.initializer)
                    if shouldRegisterComptimeStringValueImpl(ctStrVal) {
                        registerComptimeStrVarState(ctStmt.variableName, ctStrVal)
                        emitComptimeStringNoteImpl(this.output, "let ",
                            ctStmt.variableName, ctStrVal)
                    }
                }
            }
            // comptime Assignment — update existing comptime variable
            if shouldProcessComptimeAssignmentImpl(ctAction,
                ctStmt.expression.kind) {

                let ctAssignName = resolveComptimeAssignmentTargetImpl(
                    ctStmt.expression)
                if ctAssignName != "" {
                    let ctNewVal = evaluateConstExprState(ctStmt.expression.operands[0])
                    if shouldApplyComptimeAssignmentUpdateImpl(ctAssignName,
                        ctNewVal) {
                        updateComptimeVarState(ctAssignName, ctNewVal)
                        emitComptimeIntNoteImpl(this.output, "",
                            ctAssignName, ctNewVal)
                    }
                }
            }
            // comptime While — unroll loop at compile time
            if shouldProcessComptimeWhileImpl(ctAction) {
                var ctWhileIter = 0
                while ctWhileIter < 1000 {
                    let ctWhileCond = evaluateConstExprState(ctStmt.expression)
                    if not shouldContinueComptimeWhileImpl(ctWhileCond) { break }
                    // Process body: comptime statements update vars, runtime statements get emitted
                    processComptimeStatements(ctStmt.thenBranch)
                    ctWhileIter = ctWhileIter + 1
                }
                emitComptimeWhileUnrolledNoteImpl(this.output, ctWhileIter)
            }
            // Other statement kinds: emit as runtime code (code generation use case)
            if shouldEmitRuntimeComptimeStatementImpl(ctAction) {
                generateStatement(ctStmt)
            }
            ctIdx = ctIdx + 1
        }
    }

    // comptime assert(cond, "msg") — compile-time assertion
    fun generateComptimeAssert(stmt: StatementNode) r: Void {
        let condVal = evaluateConstExprState(stmt.expression)
        let assertAction = classifyComptimeAssertResultImpl(condVal)
        if assertAction == 1 {
            // Assertion failed
            let msg = resolveComptimeAssertMessageImpl(stmt.condition)
            emitComptimeAssertFailureNoteImpl(this.output, msg)
            // Emit compile error via runtime abort
            let msgReg = getNextRegFn(getFeatureRegBoxImpl())
            emitComptimeAssertAbortImpl(this.output, msgReg)
        } else {
            emitComptimeAssertPassedNoteImpl(this.output)
        }
    }

    // comptime if (cond) { then } else { else } - dead code elimination
    fun generateComptimeIf(stmt: StatementNode) r: Void {
        let condVal = evaluateConstExprState(stmt.expression)
        let branchAction = classifyComptimeIfBranchImpl(condVal,
            stmt.elseBranch.statements.length())
        if shouldGenerateComptimeIfThenImpl(branchAction) {
            // Condition is true - generate then branch only
            emitComptimeIfBranchNoteImpl(this.output, branchAction)
            generateBlock(stmt.thenBranch)
        } else {
            // Condition is false - generate else branch only (if present)
            if shouldGenerateComptimeIfElseImpl(branchAction) {
                emitComptimeIfBranchNoteImpl(this.output, branchAction)
                generateBlock(stmt.elseBranch)
            } else {
                emitComptimeIfBranchNoteImpl(this.output, branchAction)
            }
        }
    }

    fun coerceValueForLlvmTarget(targetLlvmType: String,
        sourceSeenType: String, valueReg: String) r: String {

        var sourceLlvmType = ""
        if sourceSeenType != "" and sourceSeenType != "Unknown" {
            sourceLlvmType = mapTypeState(sourceSeenType)
        }
        return coerceValueForLlvmTargetImpl(this.output, getFeatureRegBoxImpl(),
            targetLlvmType, sourceSeenType, sourceLlvmType, valueReg)
    }

    fun emitLetStatementInitializer(stmt: StatementNode, reg: String, varType: String, llvmType: String) r: Void {
        if stmt.initializer.kind == "None" {
            return
        }
        if shouldSkipDeadLiteralInitializerImpl(g_deadStoreSkipVars, stmt) {
            emitDeadLiteralInitializerSkipNoteImpl(this.output, stmt.variableName)
            return
        }
        let savedPendingType = getPendingArrayLiteralTypeWithGlobalStateImpl()
        if shouldSeedDeclarationPendingArrayLiteralTypeImpl(
            stmt.initializer.kind, varType) != 0 {
            setPendingArrayLiteralTypeWithGlobalStateImpl(varType)
        }
        let valueReg = generateExpression(stmt.initializer)
        setPendingArrayLiteralTypeWithGlobalStateImpl(savedPendingType)
        let initializerType = inferExpressionType(stmt.initializer)
        let storedValueReg = coerceValueForLlvmTarget(llvmType,
            initializerType, valueReg)
        emitDeclarationInitializerStoreImpl(this.output, llvmType, storedValueReg,
            reg)
    }

    fun generateLetStatement(stmt: StatementNode) r: Void {
        let declaredType = normalizeDeclaredTypeNodeImpl(stmt.variableType)
        var initializerType = ""
        if shouldInferDeclarationInitializerTypeImpl(declaredType,
            stmt.initializer.kind) != 0 {
            initializerType = inferDeclarationInitializerType(stmt.initializer)
        }
        let letPlan = prepareLetStatementPlanWithGlobalStateImpl(stmt,
            declaredType, initializerType)
        let varType = letPlan.varType
        let llvmType = mapTypeState(varType)
        let preAllocatedReg = resolveLetPreAllocatedRegWithGlobalStateImpl(
            letPlan.preIdx)
        var preAllocatedLlvmType = ""
        if preAllocatedReg != "" {
            preAllocatedLlvmType = mapTypeState(letPlan.preAllocatedType)
        }
        let reg = resolveLetStatementAllocaImpl(this.output, getFeatureRegBoxImpl(),
            preAllocatedReg, preAllocatedLlvmType, llvmType)
        setActiveVarCountWithGlobalStateImpl(storeActiveVariableBindingImpl(this.varNames, this.varRegs,
            this.varTypes, getBoundedActiveVarCountWithGlobalStateImpl(this.varNames), stmt.variableName, reg, varType))
        emitLetStatementInitializer(stmt, reg, varType, llvmType)
    }

    fun emitPendingReturnDefers() r: Void {
        var deferIdx = beginFunctionBodyReturnDeferCleanupImpl(this.output,
            g_deferCount)
        while deferIdx >= 0 {
            generateExpression(g_deferExprs[deferIdx])
            deferIdx = deferIdx - 1
        }
    }

    fun prepareErrdeferReturnStatement(stmt: StatementNode) r: Void {
        if g_errdeferCount == 0 {
            return
        }
        if stmt.returnValue.kind == "None" {
            var voidErrdeferIdx = beginFunctionBodyVoidErrdeferCleanupImpl(
                this.output, g_errdeferCount)
            while voidErrdeferIdx >= 0 {
                generateExpression(g_errdeferExprs[voidErrdeferIdx])
                voidErrdeferIdx = voidErrdeferIdx - 1
            }
            return
        }

        let returnValueReg = generateExpression(stmt.returnValue)
        let errdeferPlan = beginFunctionBodyValueErrdeferCleanupImpl(this.output,
            getFeatureRegBoxImpl(), getFeatureBlockBoxImpl(), returnValueReg, g_errdeferCount)
        var errdeferIdx = errdeferPlan.cleanupStartIndex
        while errdeferIdx >= 0 {
            generateExpression(g_errdeferExprs[errdeferIdx])
            errdeferIdx = errdeferIdx - 1
        }
        finishFunctionBodyValueErrdeferCleanupImpl(this.output,
            errdeferPlan.okLabel)
        g_errdeferTempAlloca = errdeferPlan.tempAllocaReg
    }

    fun tryEmitAsyncReturnStatement(stmt: StatementNode) r: Bool {
        if not isCurrentFunctionAsyncLoweringImpl(getCurrentFunctionOptions()) {
            return false
        }
        let functionEmission = getCurrentFunctionEmissionStateImpl()
        if stmt.returnValue.kind != "None" {
            let savedPendingType = getPendingArrayLiteralTypeWithGlobalStateImpl()
            let currentReturnType = getCurrentFunctionReturnTypeWithGlobalStateImpl()
            let asyncReturnPlan = prepareAsyncReturnValuePlanImpl(
                stmt.returnValue.kind, currentReturnType,
                savedPendingType)
            setPendingArrayLiteralTypeWithGlobalStateImpl(
                asyncReturnPlan.pendingArrayLiteralType)
            if asyncReturnPlan.shouldMarkTailCall == 1 {
                markTailCallPositionImpl(getCurrentFunctionOptions())
            }
            let valueReg = generateExpression(stmt.returnValue)
            setPendingArrayLiteralTypeWithGlobalStateImpl(savedPendingType)
            let promiseType = mapTypeState(currentReturnType)
            emitAsyncReturnValueBranchImpl(this.output, promiseType, valueReg,
                functionEmission.asyncPromise, functionEmission.asyncFinalLabel)
            setBlockTerminated(true)
            return true
        }
        emitAsyncReturnVoidBranchImpl(this.output, functionEmission.asyncFinalLabel)
        setBlockTerminated(true)
        return true
    }

    fun resolveReturnStatementValueReg(stmt: StatementNode) r: String {
        if g_errdeferTempAlloca != "" {
            let loadReg = getNextRegFn(getFeatureRegBoxImpl())
            emitErrdeferTempReturnLoadImpl(this.output, loadReg,
                g_errdeferTempAlloca)
            g_errdeferTempAlloca = ""
            return loadReg
        }

        let savedPendingType = getPendingArrayLiteralTypeWithGlobalStateImpl()
        let currentReturnType = getCurrentFunctionReturnTypeWithGlobalStateImpl()
        if shouldSeedReturnPendingArrayLiteralTypeImpl(stmt.returnValue.kind,
            currentReturnType) == 1 {
            setPendingArrayLiteralTypeWithGlobalStateImpl(currentReturnType)
        }
        let valueReg = generateExpression(stmt.returnValue)
        setPendingArrayLiteralTypeWithGlobalStateImpl(savedPendingType)
        return valueReg
    }

    ///
    Generate IR for a return statement. Emits pending defer expressions
    in LIFO order before the return. For async functions, stores the return
    value into the coroutine promise and branches to the async cleanup label.
    Handles type coercion (int-to-float, class-to-ptr, data-type-to-ptr).
    Sets blockTerminated=true to prevent unreachable instructions after ret.
    ///
    fun generateReturnStatement(stmt: StatementNode) r: Void {
        emitPendingReturnDefers()
        prepareErrdeferReturnStatement(stmt)
        var profileStringIndex = -1
        let functionEmission = getCurrentFunctionEmissionStateImpl()
        if functionEmission.profiledFlag {
            profileStringIndex = getStringConstantIndexImpl(this.stringConstants,
                functionEmission.profiledName)
        }
        emitReturnRegionAndProfileCleanupImpl(this.output, getFeatureRegBoxImpl(),
            currentFunctionRegionSizeBytesImpl(getCurrentFunctionOptions()),
            functionEmission.profiledFlag, profileStringIndex)

        if tryEmitAsyncReturnStatement(stmt) {
            return
        }

        if stmt.returnValue.kind == "None" {
            let emptyReturnType = mapTypeState(
                getCurrentFunctionReturnTypeWithGlobalStateImpl())
            emitDefaultEmptyReturnStatementImpl(this.output, emptyReturnType,
                functionEmission.isMainFunc)
            setBlockTerminated(true)
            return
        }

        if shouldMarkReturnTailCallImpl(stmt.returnValue.kind) == 1 {
            markTailCallPositionImpl(getCurrentFunctionOptions())
        }
        let currentReturnType = getCurrentFunctionReturnTypeWithGlobalStateImpl()
        let charValue = resolveCharLiteralReturnValueImpl(
            currentReturnType, stmt.returnValue.kind,
            stmt.returnValue.literalType, stmt.returnValue.literalValue)
        if charValue != "" {
            emitCharLiteralReturnImpl(this.output, charValue)
            setBlockTerminated(true)
            return
        }

        let llvmType = mapTypeState(currentReturnType)
        let rawValueReg = resolveReturnStatementValueReg(stmt)
        let inferredReturnExprType = inferExpressionType(stmt.returnValue)
        let returnExprType = normalizeIfConditionTypeImpl(stmt.returnValue,
            inferredReturnExprType)
        let returnExprLlvmType = mapTypeState(returnExprType)
        emitFinalReturnStatementValueImpl(this.output, getFeatureRegBoxImpl(),
            isDataTypeState(currentReturnType), stmt.returnValue.kind,
            returnExprType, returnExprLlvmType, llvmType, rawValueReg)
        setBlockTerminated(true)
    }

    fun tryEmitConstantIfStatement(stmt: StatementNode) r: Bool {
        let constantIfAction = planFunctionBodyConstantIfImpl(stmt.condition)
        if constantIfAction == 0 {
            return false
        }
        if constantIfAction == 1 {
            g_branchesEliminated = g_branchesEliminated + 1
            mlLogDecision("branch-elim", "folded", "if-true")
            emitFunctionBodyConstantIfNoteImpl(this.output, constantIfAction)
            generateBlock(stmt.thenBranch)
            return true
        }
        if constantIfAction == 2 {
            g_branchesEliminated = g_branchesEliminated + 1
            mlLogDecision("branch-elim", "folded", "if-false")
            emitFunctionBodyConstantIfNoteImpl(this.output, constantIfAction)
            if stmt.elseBranch.statements.length() > 0 {
                generateBlock(stmt.elseBranch)
            }
            return true
        }
        return false
    }

    fun tryEmitPairedAssignmentSelectIfStatement(stmt: StatementNode) r: Bool {
        let selectPlan = planPairedAssignmentSelectIfImpl(stmt)
        if not selectPlan.isValid {
            return false
        }

        let varIdx = findActiveVariableIndexImpl(this.varNames, getBoundedActiveVarCountWithGlobalStateImpl(this.varNames),
            selectPlan.assignName)
        if varIdx < 0 {
            return false
        }

        let varType = this.varTypes[varIdx]
        let llvmType = mapTypeState(varType)
        if llvmType != "i64" and llvmType != "double" {
            return false
        }
        let thenType = mapTypeState(inferExpressionType(selectPlan.thenRhs))
        let elseType = mapTypeState(inferExpressionType(selectPlan.elseRhs))
        if thenType != llvmType or elseType != llvmType {
            return false
        }

        let condReg = generateExpression(stmt.condition)
        let thenReg = generateExpression(selectPlan.thenRhs)
        let elseReg = generateExpression(selectPlan.elseRhs)
        emitFunctionBodyPairedSelectStoreImpl(this.output, getFeatureRegBoxImpl(), condReg,
            llvmType, thenReg, elseReg, this.varRegs[varIdx])
        g_branchesEliminated = g_branchesEliminated + 1
        mlLogDecision("select", "if-else", selectPlan.assignName)
        return true
    }

    fun tryEmitSingleArmSelectIfStatement(stmt: StatementNode) r: Bool {
        let selectPlan = planSingleArmSelectIfImpl(stmt)
        if not selectPlan.isValid {
            return false
        }

        let varIdx = findActiveVariableIndexImpl(this.varNames, getBoundedActiveVarCountWithGlobalStateImpl(this.varNames),
            selectPlan.assignName)
        if varIdx < 0 {
            return false
        }

        let varType = this.varTypes[varIdx]
        let llvmType = mapTypeState(varType)
        if llvmType != "i64" and llvmType != "double" {
            return false
        }
        let rhsType = mapTypeState(inferExpressionType(selectPlan.rhsExpr))
        if rhsType != llvmType {
            return false
        }

        let condReg = generateExpression(stmt.condition)
        let newValueReg = generateExpression(selectPlan.rhsExpr)
        emitFunctionBodySingleArmSelectStoreImpl(this.output, getFeatureRegBoxImpl(), condReg,
            llvmType, newValueReg, this.varRegs[varIdx])
        g_branchesEliminated = g_branchesEliminated + 1
        mlLogDecision("select", "max-min", selectPlan.assignName)
        return true
    }

    fun tryEmitSelectOptimizedIfStatement(stmt: StatementNode) r: Bool {
        if tryEmitPairedAssignmentSelectIfStatement(stmt) {
            return true
        }
        return tryEmitSingleArmSelectIfStatement(stmt)
    }

    fun finalizeConditionalEndBlock(endLabel: String, thenTerminated: Bool, elseTerminated: Bool) r: Void {
        cseClear()
        setBlockTerminated(finalizeConditionalEndBlockImpl(this.output,
            endLabel, thenTerminated, elseTerminated))
    }

    ///
    Generate IR for an if/else statement. Performs branch elimination at
    compile time for constant conditions (BoolLiteral true/false).
    Emits conditional branch (br i1 %cond, label %then, label %else),
    generates then/else blocks, and emits a merge block if neither branch
    terminates (both have a path to the merge point).
    ///
    fun generateIfStatement(stmt: StatementNode) r: Void {
        if tryEmitConstantIfStatement(stmt) {
            return
        }
        if tryEmitSelectOptimizedIfStatement(stmt) {
            return
        }

        let condReg = generateExpression(stmt.condition)
        let condType = normalizeIfConditionTypeImpl(stmt.condition,
            inferExpressionType(stmt.condition))
        let condBool = emitConditionToI1Impl(this.output, getFeatureRegBoxImpl(), condReg, condType)
        let branchLabels = emitFunctionBodyIfBranchingImpl(this.output, getFeatureBlockBoxImpl(),
            condBool,
            computeIfBranchWeightMetadataForStatementImpl(stmt))
        let elseLabel = branchLabels.elseLabel
        let endLabel = branchLabels.endLabel

        cseClear()
        setBlockTerminated(false)
        generateBlock(stmt.thenBranch)
        let thenTerminated = isBlockTerminated()
        if not thenTerminated {
            this.output.append("  br label %" + endLabel + "\n")
        }

        // Else block
        this.output.append(elseLabel + ":\n")
        cseClear()  // CSE cache invalid across basic block boundaries
        setBlockTerminated(false)
        if stmt.elseBranch.statements.length() > 0 {
            generateBlock(stmt.elseBranch)
        }
        let elseTerminated = isBlockTerminated()
        if not elseTerminated {
            this.output.append("  br label %" + endLabel + "\n")
        }

        finalizeConditionalEndBlock(endLabel, thenTerminated, elseTerminated)
    }

    ///
    if let name = expr { ... } else { ... }
    Evaluate expr, if non-null bind name to value and run then-block
    ///
    fun generateIfLetStatement(stmt: StatementNode) r: Void {
        let exprReg = generateExpression(stmt.condition)
        let cmpReg = emitConditionToI1Impl(this.output, getFeatureRegBoxImpl(), exprReg, "Int")
        let branchLabels = emitFunctionBodyIfBranchingImpl(this.output, getFeatureBlockBoxImpl(),
            cmpReg, "")
        let elseLabel = branchLabels.elseLabel
        let endLabel = branchLabels.endLabel

        cseClear()
        setBlockTerminated(false)
        let savedIfLetVarCount = getBoundedActiveVarCountWithGlobalStateImpl(this.varNames)
        setActiveVarCountWithGlobalStateImpl(emitIfLetBindingStateImpl(this.output, getFeatureRegBoxImpl(),
            this.varNames, this.varRegs, this.varTypes, getBoundedActiveVarCountWithGlobalStateImpl(this.varNames), stmt.variableName,
            exprReg))
        generateBlock(stmt.thenBranch)
        setActiveVarCountWithGlobalStateImpl(savedIfLetVarCount)
        let thenTerminated = isBlockTerminated()
        if not thenTerminated {
            this.output.append("  br label %" + endLabel + "\n")
        }

        // Else block
        this.output.append(elseLabel + ":\n")
        cseClear()
        setBlockTerminated(false)
        if stmt.elseBranch.statements.length() > 0 {
            generateBlock(stmt.elseBranch)
        }
        let elseTerminated = isBlockTerminated()
        if not elseTerminated {
            this.output.append("  br label %" + endLabel + "\n")
        }

        finalizeConditionalEndBlock(endLabel, thenTerminated, elseTerminated)
    }

    fun emitLiteralBoundWhileHints(stmt: StatementNode, loopMetaId: Int, loopBoundLiteral: Int) r: Void {
        let tileSize = computeLoopTileSizeImpl(loopBoundLiteral, g_mlUnrollThreshold)
        if tileSize > 0 {
            this.output.append("  ; loop tiling: bound=" + loopBoundLiteral.toString() + " → unroll.count=" + tileSize.toString() + "\n")
            g_loopsOptimized = g_loopsOptimized + 1
            appendLoopTileHint(loopMetaId, tileSize)
            mlLogDecision("loop-tile", "unroll", "bound:" + loopBoundLiteral.toString() + ",tile:" + tileSize.toString())
        }
        if loopBoundLiteral < g_mlVectorizeThreshold and loopBoundLiteral > 0 {
            this.output.append("  ; ML: loop bound " + loopBoundLiteral.toString() + " < vectorize threshold " + g_mlVectorizeThreshold.toString() + " → skip vectorize\n")
            appendLoopTileHint(loopMetaId, -1)
            mlLogDecision("ml-vec", "skip", "bound:" + loopBoundLiteral.toString() + "<threshold:" + g_mlVectorizeThreshold.toString())
        }
        if loopBoundLiteral > 0 and loopBoundLiteral <= 32 and not detectNestedLoopImpl(stmt.loopBody) and stmt.loopBody.statements.length() <= 8 {
            appendLoopTileHint(loopMetaId, -2)
            this.output.append("  ; small loop (bound=" + loopBoundLiteral.toString() + ", " + stmt.loopBody.statements.length().toString() + " stmts) → full unroll hint\n")
        }
    }

    fun emitWhileLoopInvariantAnnotations(stmt: StatementNode, loopMetaId: Int) r: Void {
        var licmIdx = 0
        while licmIdx < stmt.loopBody.statements.length() {
            let licmStmt = stmt.loopBody.statements[licmIdx]
            if licmStmt.kind == "Let" or licmStmt.kind == "Var" {
                if licmStmt.expression.kind == "Variable" or licmStmt.expression.kind == "VarExpr" {
                    var licmVarName = licmStmt.expression.literalValue
                    if licmVarName == "" { licmVarName = licmStmt.expression.variableName }
                    let mcIdx = findModuleConstant(licmVarName)
                    if mcIdx >= 0 {
                        var licmImmutable = true
                        if isModuleConstMutableWithModuleStateImpl(mcIdx) {
                            licmImmutable = false
                        }
                        if licmImmutable {
                            this.output.append("  ; LICM: " + licmVarName + " is immutable module constant (!invariant.load applied)\n")
                            mlLogDecision("licm", "applied", licmVarName)
                        } else {
                            this.output.append("  ; LICM candidate: " + licmVarName + " is mutable (var), skipped\n")
                            mlLogDecision("licm", "skipped-mutable", licmVarName)
                        }
                        g_loopsOptimized = g_loopsOptimized + 1
                    }
                }
            }
            licmIdx = licmIdx + 1
        }

        if detectNestedLoopImpl(stmt.loopBody) {
            this.output.append("  ; nested loop detected - interchange candidate\n")
            g_loopsOptimized = g_loopsOptimized + 1
            mlLogDecision("loop-interchange", "candidate", "nested-loop")
            appendNestedLoopMetadataId(loopMetaId)
        }
    }

    fun emitGcdPatternWhileHint(stmt: StatementNode, loopMetaId: Int) r: Void {
        if detectGcdPatternImpl(stmt.loopCondition, stmt.loopBody) {
            appendLoopTileHint(loopMetaId, 8)
            this.output.append("  ; GCD-pattern loop → unroll.count=8\n")
        }
    }

    fun emitWhileConditionBranch(condReg: String, breakFlagVar: String, bodyLabel: String, endLabel: String) r: Void {
        var breakFlagPtrReg = ""
        if breakFlagVar != "" {
            let bfVarIdx = findActiveVariableIndexImpl(this.varNames, getBoundedActiveVarCountWithGlobalStateImpl(this.varNames), breakFlagVar)
            if bfVarIdx >= 0 {
                breakFlagPtrReg = this.varRegs[bfVarIdx]
            }
        }
        emitWhileConditionBranchImpl(this.output, getFeatureRegBoxImpl(), condReg,
            breakFlagPtrReg, bodyLabel, endLabel)
    }

    fun tryEmitMemcpyOptimizedWhileLoop(stmt: StatementNode, condLabel: String, bodyLabel: String, endLabel: String, savedCondLabel: String, savedEndLabel: String) r: Bool {
        let memcpyPlan = planMemcpyOptimizedWhileLoopImpl(stmt)
        if not memcpyPlan.isValid {
            return false
        }
        let mcBoundReg = generateExpression(memcpyPlan.boundExpr)

        let lhsArrayType = findVarType(memcpyPlan.lhsArrayName)
        var rhsArrayType = ""
        if memcpyPlan.kind == 1 {
            rhsArrayType = findVarType(memcpyPlan.rhsArrayName)
        }
        var lhsArrayReg = ""
        let lhsArrayIdx = findActiveVariableIndexImpl(this.varNames,
            getBoundedActiveVarCountWithGlobalStateImpl(this.varNames), memcpyPlan.lhsArrayName)
        if lhsArrayIdx >= 0 {
            lhsArrayReg = this.varRegs[lhsArrayIdx]
        }
        var rhsArrayReg = ""
        if memcpyPlan.kind == 1 {
            let rhsArrayIdx = findActiveVariableIndexImpl(this.varNames,
                getBoundedActiveVarCountWithGlobalStateImpl(this.varNames), memcpyPlan.rhsArrayName)
            if rhsArrayIdx >= 0 {
                rhsArrayReg = this.varRegs[rhsArrayIdx]
            }
        }
        var incrementVarReg = ""
        let incrementVarIdx = findActiveVariableIndexImpl(this.varNames,
            getBoundedActiveVarCountWithGlobalStateImpl(this.varNames), memcpyPlan.incrementVarName)
        if incrementVarIdx >= 0 {
            incrementVarReg = this.varRegs[incrementVarIdx]
        }

        let memcpyEmitResult = emitFunctionBodyMemcpyOptimizedLoopImpl(
            this.output, getFeatureRegBoxImpl(), memcpyPlan.kind, memcpyPlan.lhsArrayName,
            memcpyPlan.rhsArrayName, memcpyPlan.incrementVarName, mcBoundReg,
            lhsArrayType, rhsArrayType, lhsArrayReg, rhsArrayReg,
            incrementVarReg)
        if not memcpyEmitResult.didEmit {
            return false
        }
        if memcpyEmitResult.mlCategory != "" {
            mlLogDecision(memcpyEmitResult.mlCategory,
                memcpyEmitResult.mlAction, memcpyEmitResult.mlDetail)
        }
        g_loopsOptimized = g_loopsOptimized +
            memcpyEmitResult.loopsOptimizedDelta
        emitMemcpyLoopExitBlocksImpl(this.output, condLabel, bodyLabel, endLabel)
        let restoredLoopContext = restoreFunctionBodyLoopContextImpl(
            getCurrentLoopCondLabelWithGlobalStateImpl(),
            getCurrentLoopEndLabelWithGlobalStateImpl(), savedCondLabel,
            savedEndLabel)
        setCurrentLoopCondLabelWithGlobalStateImpl(
            restoredLoopContext.currentCondLabel)
        setCurrentLoopEndLabelWithGlobalStateImpl(
            restoredLoopContext.currentEndLabel)
        return true
    }

    fun emitWhileLoopAnalyses(stmt: StatementNode, loopMetaId: Int,
        breakFlagBox: Array<String>, savedInductionVarBox: Array<String>) r: Void {
        let loopBoundLiteral = detectLoopBoundImpl(stmt.loopCondition)
        if loopBoundLiteral >= 0 {
            emitLiteralBoundWhileHints(stmt, loopMetaId, loopBoundLiteral)
        }
        emitWhileLoopInvariantAnnotations(stmt, loopMetaId)
        emitGcdPatternWhileHint(stmt, loopMetaId)

        let reductionVar = detectReductionPatternImpl(stmt.loopBody)
        if reductionVar != "" {
            let reductionType = "sum"
            this.output.append("  ; reduction chain detected: " + reductionType + " on " + reductionVar + " → 2x vectorize width\n")
            g_reductionChainsDetected = g_reductionChainsDetected + 1
            appendReductionLoopMetadataId(loopMetaId)
            mlLogDecision("reduction", reductionType, reductionVar)
        }

        savedInductionVarBox.push(g_inductionVarName)
        let inductionVarName = detectInductionVarImpl(stmt.loopBody)
        if inductionVarName != "" {
            this.output.append("  ; induction variable: " + inductionVarName + " → nsw\n")
            g_inductionVarName = inductionVarName
        }

        let breakFlagVar = detectBreakOnFlagImpl(stmt.loopBody)
        breakFlagBox.push(breakFlagVar)
        if breakFlagVar != "" {
            this.output.append("  ; break-on-flag: " + breakFlagVar + " → early loop exit\n")
            mlLogDecision("break-flag", "early-exit", breakFlagVar)
        }
    }

    fun emitWhileLoopBody(stmt: StatementNode, condLabel: String, bodyLabel: String,
        endLabel: String, breakFlagVar: String, loopMetaIdStr: String) r: Void {
        this.output.append("  br label %" + condLabel + "\n")

        this.output.append(condLabel + ":\n")
        cseClear()
        let condReg = generateExpression(stmt.loopCondition)
        emitWhileConditionBranch(condReg, breakFlagVar, bodyLabel, endLabel)

        this.output.append(bodyLabel + ":\n")
        cseClear()
        setBlockTerminated(false)
        generateBlock(stmt.loopBody)
        let bodyTerminated = isBlockTerminated()
        if not bodyTerminated {
            this.output.append("  br label %" + condLabel + ", !llvm.loop !" + loopMetaIdStr + "\n")
        }
    }

    fun emitRangeForInLoop(stmt: StatementNode, loopVarName: String, loopVarType: String, loopVarReg: String,
        forInIterable: ParserExpressionNode, condLabel: String, bodyLabel: String,
        endLabel: String, loopMetaIdStr: String) r: Void {
        let startReg = generateExpression(forInIterable.operands[0])
        let endReg = generateExpression(forInIterable.operands[1])
        let idxReg = resolveFunctionBodyForInIndexAllocaWithGlobalStateImpl(
            this.output, getFeatureRegBoxImpl(), "__forin_idx_" + loopVarName)
        setActiveVarCountWithGlobalStateImpl(storeActiveVariableBindingImpl(this.varNames, this.varRegs,
            this.varTypes, getBoundedActiveVarCountWithGlobalStateImpl(this.varNames), loopVarName, loopVarReg, loopVarType))
        cseClear()
        emitIndexedForLoopHeaderImpl(this.output, getFeatureRegBoxImpl(), startReg, endReg, loopVarReg, idxReg, condLabel, bodyLabel, endLabel)
        cseClear()
        setBlockTerminated(false)
        generateBlock(stmt.loopBody)
        let bodyTerminated = isBlockTerminated()
        if not bodyTerminated {
            emitForInIncrementImpl(this.output, getFeatureRegBoxImpl(), idxReg, condLabel, loopMetaIdStr)
        }
    }

    fun tryEmitIteratorProtocolForInLoop(stmt: StatementNode, loopVarName: String, loopVarType: String,
        loopVarReg: String, forInIterable: ParserExpressionNode, iterableType: String,
        condLabel: String, bodyLabel: String, endLabel: String) r: Bool {
        let iterLookupName = iteratorProtocolFunctionNameImpl(iterableType)
        let iterFuncRet = getFunctionReturnTypeStateImpl(iterLookupName,
            getGlobalFuncNamesImpl(), getGlobalFuncRetTypesImpl())
        let iterPlan = planIteratorProtocolForInLoopImpl(iterableType,
            iterFuncRet)
        if not iterPlan.isValid {
            return false
        }

        let iterableReg = generateExpression(forInIterable)
        let iterThisReg = getNextRegFn(getFeatureRegBoxImpl())
        this.output.append("  " + iterThisReg + " = inttoptr i64 " + iterableReg + " to ptr\n")
        let iterObjReg = getNextRegFn(getFeatureRegBoxImpl())
        let iterRetLlvm = mapTypeState(iterPlan.iterReturnType)
        this.output.append("  " + iterObjReg + " = call " + iterRetLlvm + " @" + quoteIdentIfNeededImpl(iterPlan.iterFuncName) + "(ptr " + iterThisReg + ")\n")
        let iterStoreReg = getNextRegFn(getFeatureRegBoxImpl())
        this.output.append("  " + iterStoreReg + " = alloca i64, align 8\n")
        this.output.append("  store i64 " + iterObjReg + ", ptr " + iterStoreReg + "\n")
        setActiveVarCountWithGlobalStateImpl(storeActiveVariableBindingImpl(this.varNames, this.varRegs,
            this.varTypes, getBoundedActiveVarCountWithGlobalStateImpl(this.varNames), loopVarName, loopVarReg, loopVarType))

        this.output.append("  br label %" + condLabel + "\n")
        this.output.append(condLabel + ":\n")
        cseClear()
        let iterLoadReg = getNextRegFn(getFeatureRegBoxImpl())
        this.output.append("  " + iterLoadReg + " = load i64, ptr " + iterStoreReg + "\n")
        let iterPtrReg = getNextRegFn(getFeatureRegBoxImpl())
        this.output.append("  " + iterPtrReg + " = inttoptr i64 " + iterLoadReg + " to ptr\n")
        let hasNextReg = getNextRegFn(getFeatureRegBoxImpl())
        this.output.append("  " + hasNextReg + " = call i1 @" + quoteIdentIfNeededImpl(iterPlan.hasNextFuncName) + "(ptr " + iterPtrReg + ")\n")
        this.output.append("  br i1 " + hasNextReg + ", label %" + bodyLabel + ", label %" + endLabel + "\n")

        this.output.append(bodyLabel + ":\n")
        cseClear()
        setBlockTerminated(false)
        let nextRetType = getFunctionReturnTypeStateImpl(
            iterPlan.nextFuncName, getGlobalFuncNamesImpl(),
            getGlobalFuncRetTypesImpl())
        var nextRetLlvm = "i64"
        if nextRetType != "" {
            nextRetLlvm = mapTypeState(nextRetType)
        }
        let nextReg = getNextRegFn(getFeatureRegBoxImpl())
        this.output.append("  " + nextReg + " = call " + nextRetLlvm + " @" + quoteIdentIfNeededImpl(iterPlan.nextFuncName) + "(ptr " + iterPtrReg + ")\n")
        if loopVarReg != "" {
            this.output.append("  store " + nextRetLlvm + " " + nextReg + ", ptr " + loopVarReg + "\n")
        }
        generateBlock(stmt.loopBody)
        let bodyTerminated = isBlockTerminated()
        if not bodyTerminated {
            this.output.append("  br label %" + condLabel + "\n")
        }
        return true
    }

    fun emitStringForInElement(arrReg: String, loadIdx: String, loopVarReg: String) r: Void {
        emitStringForInElementImpl(this.output, getFeatureRegBoxImpl(), arrReg, loadIdx,
            loopVarReg)
    }

    fun emitArrayLikeForInLoop(stmt: StatementNode, loopVarName: String, loopVarType: String, loopVarReg: String,
        forInIterable: ParserExpressionNode, condLabel: String, bodyLabel: String,
        endLabel: String, loopMetaIdStr: String) r: Void {
        let arrReg = generateExpression(forInIterable)
        let iterType = inferExpressionType(forInIterable)
        var elementType = "Int"
        if iterType.startsWith("Array<") {
            elementType = iterType.substring(6, iterType.length() - 1)
        }

        var isStringIterable = 0
        if iterType == "String" {
            isStringIterable = 1
            elementType = "Char"
        }
        var lenReg = ""
        if isStringIterable == 1 {
            lenReg = getNextRegFn(getFeatureRegBoxImpl())
            var arrStrReg = arrReg
            if arrReg == "0" {
                arrStrReg = "zeroinitializer"
            }
            this.output.append("  " + lenReg + " = call i64 @seen_length(%SeenString " + arrStrReg + ")\n")
        } else {
            lenReg = emitSeenArrayLengthLoadImpl(this.output, getFeatureRegBoxImpl(), arrReg,
                ", !tbaa !108, !range !188")
        }

        let idxReg = resolveFunctionBodyForInIndexAllocaWithGlobalStateImpl(
            this.output, getFeatureRegBoxImpl(), "__forin_idx_" + loopVarName)
        setActiveVarCountWithGlobalStateImpl(storeActiveVariableBindingImpl(this.varNames, this.varRegs,
            this.varTypes, getBoundedActiveVarCountWithGlobalStateImpl(this.varNames), loopVarName, loopVarReg, loopVarType))
        cseClear()
        let loadIdx = emitIndexedForLoopHeaderImpl(this.output, getFeatureRegBoxImpl(), "0", lenReg, "", idxReg, condLabel, bodyLabel, endLabel)
        cseClear()
        setBlockTerminated(false)

        if isStringIterable == 1 {
            emitStringForInElement(arrReg, loadIdx, loopVarReg)
        } else {
            var isString = 0
            var isFloat = 0
            if elementType == "String" { isString = 1 }
            if elementType == "Float" { isFloat = 1 }
            emitForInElementFetchImpl(this.output, getFeatureRegBoxImpl(), arrReg, loadIdx, loopVarReg, elementType, isString, isFloat)
            emitForInPrefetchImpl(this.output, getFeatureRegBoxImpl(), getFeatureBlockBoxImpl(), arrReg, loadIdx, lenReg, elementType)
        }

        generateBlock(stmt.loopBody)
        let bodyTerminated = isBlockTerminated()
        if not bodyTerminated {
            emitForInIncrementImpl(this.output, getFeatureRegBoxImpl(), idxReg, condLabel, loopMetaIdStr)
        }
    }

    fun finalizeForInLoop(endLabel: String, savedForInVarCount: Int, savedCondLabel: String, savedEndLabel: String) r: Void {
        emitFunctionBodyLoopEndLabelImpl(this.output, endLabel)
        cseClear()
        setBlockTerminated(false)
        setActiveVarCountWithGlobalStateImpl(savedForInVarCount)
        let restoredLoopContext = restoreFunctionBodyLoopContextImpl(
            getCurrentLoopCondLabelWithGlobalStateImpl(),
            getCurrentLoopEndLabelWithGlobalStateImpl(), savedCondLabel,
            savedEndLabel)
        setCurrentLoopCondLabelWithGlobalStateImpl(
            restoredLoopContext.currentCondLabel)
        setCurrentLoopEndLabelWithGlobalStateImpl(
            restoredLoopContext.currentEndLabel)
    }

    ///
    Generate IR for a while loop. Emits cond/body/end blocks with
    back-edge from body to cond. Attaches LLVM loop metadata for:
      - !llvm.loop.vectorize.enable/width (from @vectorize decorator)
      - !llvm.loop.unroll.count (from @unroll decorator or tile hints)
      - !llvm.loop.distribute.enable (for nested loops)
    Performs pattern detection for memcpy/memmove idioms and replaces
    them with llvm.memcpy/memmove intrinsics.
    Saves/restores outer loop context (currentLoopCondLabel/EndLabel)
    for nested loop support. Break jumps to endLabel, continue to condLabel.
    ///
    fun generateWhileStatement(stmt: StatementNode) r: Void {
        let loopContext = beginFunctionBodyLoopContextImpl(getFeatureBlockBoxImpl(),
            getCurrentLoopCondLabelWithGlobalStateImpl(),
            getCurrentLoopEndLabelWithGlobalStateImpl())
        setCurrentLoopCondLabelWithGlobalStateImpl(loopContext.currentCondLabel)
        setCurrentLoopEndLabelWithGlobalStateImpl(loopContext.currentEndLabel)

        if tryEmitMemcpyOptimizedWhileLoop(stmt, loopContext.condLabel,
            loopContext.bodyLabel, loopContext.endLabel,
            loopContext.savedCondLabel, loopContext.savedEndLabel) {
            return
        }

        let breakFlagBox = Array<String>()
        let savedInductionVarBox = Array<String>()
        emitWhileLoopAnalyses(stmt, loopContext.loopMetaId, breakFlagBox,
            savedInductionVarBox)
        emitWhileLoopBody(stmt, loopContext.condLabel, loopContext.bodyLabel,
            loopContext.endLabel, breakFlagBox[0], loopContext.loopMetaIdStr)
        emitFunctionBodyLoopEndLabelImpl(this.output, loopContext.endLabel)
        cseClear()
        setBlockTerminated(false)

        g_inductionVarName = savedInductionVarBox[0]
        let restoredLoopContext = restoreFunctionBodyLoopContextImpl(
            getCurrentLoopCondLabelWithGlobalStateImpl(),
            getCurrentLoopEndLabelWithGlobalStateImpl(),
            loopContext.savedCondLabel, loopContext.savedEndLabel)
        setCurrentLoopCondLabelWithGlobalStateImpl(
            restoredLoopContext.currentCondLabel)
        setCurrentLoopEndLabelWithGlobalStateImpl(
            restoredLoopContext.currentEndLabel)
    }

    ///
    Generate IR for a for-in loop over a range or array.
    Range loops (for i in 0..n) emit a simple counter-based loop.
    Array loops (for item in arr) emit index-based iteration with
    element load per iteration. Attaches the same loop metadata as
    generateWhileStatement for vectorization/unrolling hints.
    ///
    fun generateForInStatement(stmt: StatementNode) r: Void {
        let loopContext = beginFunctionBodyLoopContextImpl(getFeatureBlockBoxImpl(),
            getCurrentLoopCondLabelWithGlobalStateImpl(),
            getCurrentLoopEndLabelWithGlobalStateImpl())
        setCurrentLoopCondLabelWithGlobalStateImpl(loopContext.currentCondLabel)
        setCurrentLoopEndLabelWithGlobalStateImpl(loopContext.currentEndLabel)
        let savedForInVarCount = getBoundedActiveVarCountWithGlobalStateImpl(this.varNames)

        let loopVarName = stmt.variableName
        var resolvedLoopVarType = findVarType(loopVarName)
        if resolvedLoopVarType == "" {
            resolvedLoopVarType = "Int"
        }
        let loopVarStorage = resolveFunctionBodyForInLoopVariableStorageWithGlobalStateImpl(
            this.output, getFeatureRegBoxImpl(), loopVarName, resolvedLoopVarType,
            mapTypeState(resolvedLoopVarType))
        let loopVarType = loopVarStorage.seenType
        let loopVarReg = loopVarStorage.storageReg
        let forInIterable = stmt.expression
        if isRangeForInIterableImpl(forInIterable.kind) {
            emitRangeForInLoop(stmt, loopVarName, loopVarType, loopVarReg, forInIterable,
                loopContext.condLabel, loopContext.bodyLabel,
                loopContext.endLabel, loopContext.loopMetaIdStr)
        } else {
            let iterableType = inferExpressionType(forInIterable)
            if not tryEmitIteratorProtocolForInLoop(stmt, loopVarName, loopVarType, loopVarReg,
                forInIterable, iterableType, loopContext.condLabel,
                loopContext.bodyLabel, loopContext.endLabel) {
                emitArrayLikeForInLoop(stmt, loopVarName, loopVarType, loopVarReg, forInIterable,
                    loopContext.condLabel, loopContext.bodyLabel,
                    loopContext.endLabel, loopContext.loopMetaIdStr)
            }
        }
        finalizeForInLoop(loopContext.endLabel, savedForInVarCount,
            loopContext.savedCondLabel, loopContext.savedEndLabel)
    }

    fun generateAssignmentValuePreservingPendingType(valueExpr: ParserExpressionNode) r: String {
        let savedPendingType = getPendingArrayLiteralTypeWithGlobalStateImpl()
        let valueReg = generateExpression(valueExpr)
        setPendingArrayLiteralTypeWithGlobalStateImpl(savedPendingType)
        return valueReg
    }

    fun generateAssignmentValueForSeenType(valueExpr: ParserExpressionNode, targetSeenType: String) r: String {
        let savedPendingType = getPendingArrayLiteralTypeWithGlobalStateImpl()
        if targetSeenType != "" and valueExpr.kind == "ArrayLiteral" {
            if targetSeenType.startsWith("Array") or targetSeenType.startsWith("List") {
                setPendingArrayLiteralTypeWithGlobalStateImpl(targetSeenType)
            }
        }
        let valueReg = generateExpression(valueExpr)
        setPendingArrayLiteralTypeWithGlobalStateImpl(savedPendingType)
        return valueReg
    }

    fun tryGenerateModuleConstantAssignment(varName: String, valueExpr: ParserExpressionNode) r: Int {
        let constIdx = findModuleConstant(varName)
        if constIdx < 0 {
            return 0
        }
        let constType = getModuleConstantTypeWithModuleStateImpl(constIdx)
        let valueReg = generateAssignmentValuePreservingPendingType(valueExpr)
        let valueSeenType = inferExpressionType(valueExpr)
        let storedValueReg = coerceValueForLlvmTarget(constType,
            valueSeenType, valueReg)
        emitStoreValueToPtrImpl(this.output, constType, storedValueReg,
            "@" + varName)
        return 1
    }

    fun tryGenerateImplicitThisFieldAssignment(varName: String, valueExpr: ParserExpressionNode) r: Int {
        let thisIdx = findActiveVariableIndexImpl(this.varNames, getBoundedActiveVarCountWithGlobalStateImpl(this.varNames), "this")
        if thisIdx < 0 {
            return 0
        }

        let thisType = this.varTypes[thisIdx]
        let structIdx = findStructReg(thisType, getGlobalStructNamesImpl())
        if structIdx < 0 {
            return 0
        }

        let fieldIdx = getFieldInfoState(thisType, varName)
        if fieldIdx < 0 {
            return 0
        }

        let fieldSeenType = getSeenFieldTypeState(thisType, varName)
        let valueReg = generateAssignmentValueForSeenType(valueExpr, fieldSeenType)
        let fieldType = getFieldTypeState(thisType, varName)
        let valueSeenType = inferExpressionType(valueExpr)
        let storedValueReg = coerceValueForLlvmTarget(fieldType,
            valueSeenType, valueReg)
        emitImplicitThisFieldStoreImpl(this.output, getFeatureRegBoxImpl(),
            this.varRegs[thisIdx], getGlobalStructLayoutsImpl()[structIdx], fieldIdx, fieldType,
            storedValueReg)
        return 1
    }

    fun tryGenerateFallbackAssignmentTarget(varName: String, valueExpr: ParserExpressionNode) r: Int {
        if tryGenerateModuleConstantAssignment(varName, valueExpr) == 1 {
            return 1
        }
        return tryGenerateImplicitThisFieldAssignment(varName, valueExpr)
    }

    fun emitDistinctAssignmentTypeWarning(varType: String, valueExpr: ParserExpressionNode) r: Void {
        if g_distinctTypeNames == "" or not g_distinctTypeNames.contains(varType + "|") {
            return
        }
        let rhsType = inferExpressionType(valueExpr)
        if rhsType != "" and rhsType != varType {
            emitDistinctTypeMismatchWarningImpl(this.output, rhsType, varType)
        }
    }

    fun emitLocalVariableAssignment(idx: Int, valueExpr: ParserExpressionNode) r: String {
        let varType = this.varTypes[idx]
        let valueReg = generateAssignmentValueForSeenType(valueExpr, varType)
        let llvmType = mapTypeState(varType)
        let valueSeenType = inferExpressionType(valueExpr)
        let storedValueReg = coerceValueForLlvmTarget(llvmType,
            valueSeenType, valueReg)
        emitStoreValueToPtrImpl(this.output, llvmType, storedValueReg, this.varRegs[idx])
        return varType
    }

    fun applyMoveAssignmentSemantics(valueExpr: ParserExpressionNode) r: Void {
        if g_moveOnlyClasses == "" {
            return
        }
        if valueExpr.kind != "Variable" and valueExpr.kind != "VarExpr" {
            return
        }

        let rhsVarName = getExprVariableNameImpl(valueExpr.variableName, valueExpr.literalValue)
        if rhsVarName == "" {
            return
        }

        let rhsIdx = findActiveVariableIndexImpl(this.varNames, getBoundedActiveVarCountWithGlobalStateImpl(this.varNames), rhsVarName)
        if rhsIdx < 0 {
            return
        }

        let rhsType = this.varTypes[rhsIdx]
        if not g_moveOnlyClasses.contains(rhsType + "|") {
            return
        }

        emitMoveSourceNullifyImpl(this.output, this.varRegs[rhsIdx])
        recordMovedVariableImpl(getCurrentFunctionEmissionStateImpl(),
            rhsVarName)
    }

    fun emitTriviallyCopyableAssignmentNote(varType: String) r: Void {
        if g_triviallyCopyableClasses != "" and g_triviallyCopyableClasses.contains(varType + "|") {
            emitTriviallyCopyableAssignmentNoteImpl(this.output, varType)
        }
    }

    // Handle assignment expression (from parser)
    fun generateAssignmentExpr(expr: ParserExpressionNode) r: Void {
        let varName = expr.variableName
        let idx = findActiveVariableIndexImpl(this.varNames, getBoundedActiveVarCountWithGlobalStateImpl(this.varNames), varName)

        if idx < 0 {
            tryGenerateFallbackAssignmentTarget(varName, expr.operands[0])
            return
        }

        emitLocalVariableAssignment(idx, expr.operands[0])
    }

    ///
    Generate IR for a variable assignment statement (x = expr).
    Finds the variable's alloca register via findVar and emits a store.
    Handles compound assignments (+=, -=, *=, /=, %=, &=, |=, ^=, <<=, >>=)
    by loading the current value, performing the operation, and storing back.
    ///
    fun generateAssignment(stmt: StatementNode) r: Void {
        let varName = stmt.variableName
        let idx = findActiveVariableIndexImpl(this.varNames, getBoundedActiveVarCountWithGlobalStateImpl(this.varNames), varName)

        if idx < 0 {
            tryGenerateFallbackAssignmentTarget(varName, stmt.initializer)
            return
        }

        let varType = this.varTypes[idx]
        emitDistinctAssignmentTypeWarning(varType, stmt.initializer)
        emitLocalVariableAssignment(idx, stmt.initializer)
        applyMoveAssignmentSemantics(stmt.initializer)
        emitTriviallyCopyableAssignmentNote(varType)
    }

    fun generateMemberAssignment(expr: ParserExpressionNode) r: Void {
        let memberAccess = expr.operands[0]
        let value = expr.operands[1]
        let receiverName = memberAccess.literalValue
        let fieldName = memberAccess.variableName

        let valueReg = generateExpression(value)
        let valueSeenType = inferExpressionType(value)

        if memberAccess.operands.length() > 0 and memberAccess.literalValue == "" {
            let receiverExpr = memberAccess.operands[0]
            let receiverReg = generateExpression(receiverExpr)
            let receiverType = inferExpressionType(receiverExpr)
            if emitValueReceiverMemberAssignmentImpl(this.output, getFeatureRegBoxImpl(),
                receiverReg, receiverType, fieldName, valueReg, value.kind,
                valueSeenType, getGlobalStructNamesImpl(), getGlobalStructLayoutsImpl(), getGlobalStructFieldNamesImpl(),
                getGlobalStructFieldTypesImpl(), getGlobalStructLlvmFieldTypesImpl(), g_reprCClassNames,
                g_typeAliasNames, g_typeAliasTargets, g_typeAliasCount,
                g_enumTypeNames, g_unionTypes, getFeatureBitfieldCountImpl(),
                getFeatureBitfieldKeysImpl(), getFeatureBitfieldWidthsImpl()) == 1 {
                return
            }
            return
        }

        if receiverName.contains(".") {
            let receiverExpr = buildChainedPathExprImpl(receiverName)
            if receiverExpr.kind != "" {
                let receiverReg = generateExpression(receiverExpr)
                let receiverType = inferExpressionType(receiverExpr)
                if emitValueReceiverMemberAssignmentImpl(this.output, getFeatureRegBoxImpl(),
                    receiverReg, receiverType, fieldName, valueReg,
                    value.kind, valueSeenType, getGlobalStructNamesImpl(), getGlobalStructLayoutsImpl(),
                    getGlobalStructFieldNamesImpl(), getGlobalStructFieldTypesImpl(),
                    getGlobalStructLlvmFieldTypesImpl(), g_reprCClassNames,
                    g_typeAliasNames, g_typeAliasTargets, g_typeAliasCount,
                    g_enumTypeNames, g_unionTypes, getFeatureBitfieldCountImpl(),
                    getFeatureBitfieldKeysImpl(), getFeatureBitfieldWidthsImpl()) == 1 {
                    return
                }
            }
        }

        if emitVariableReceiverMemberAssignmentImpl(this.output, getFeatureRegBoxImpl(),
            receiverName, fieldName, valueReg, value.kind, valueSeenType,
            this.varNames,
            getBoundedActiveVarCountWithGlobalStateImpl(this.varNames), this.varRegs, this.varTypes, getGlobalStructNamesImpl(), getGlobalStructLayoutsImpl(),
            getGlobalStructFieldNamesImpl(), getGlobalStructFieldTypesImpl(), getGlobalStructLlvmFieldTypesImpl(),
            g_reprCClassNames, g_typeAliasNames, g_typeAliasTargets,
            g_typeAliasCount, g_enumTypeNames, g_unionTypes,
            getFeatureBitfieldCountImpl(), getFeatureBitfieldKeysImpl(), getFeatureBitfieldWidthsImpl()) == 1 {
            return
        }
        emitImplicitThisMemberAssignmentImpl(this.output, getFeatureRegBoxImpl(), receiverName,
            fieldName, valueReg, value.kind, valueSeenType, this.varNames,
            getBoundedActiveVarCountWithGlobalStateImpl(this.varNames),
            this.varRegs, this.varTypes, getGlobalStructNamesImpl(), getGlobalStructLayoutsImpl(), getGlobalStructFieldNamesImpl(),
            getGlobalStructFieldTypesImpl(), getGlobalStructLlvmFieldTypesImpl(), g_reprCClassNames,
            g_typeAliasNames, g_typeAliasTargets, g_typeAliasCount,
            g_enumTypeNames, g_unionTypes, getFeatureBitfieldCountImpl(), getFeatureBitfieldKeysImpl(),
            getFeatureBitfieldWidthsImpl())
    }

    ///
    Generate index assignment: a[i] = value
    Generate IR for an index assignment (arr[idx] = expr). Dispatches to
    runtime helpers based on element type: seen_arr_set_str, seen_arr_set,
    or type-specific variants. Also handles HashMap index assignment.
    ///
    fun generateIndexAssignment(expr: ParserExpressionNode) r: Void {
        let indexAccess = expr.operands[0]
        let value = expr.operands[1]
        let array = indexAccess.operands[0]
        let index = indexAccess.operands[1]

        let arrayReg = generateExpression(array)
        let indexReg = generateExpression(index)
        let valueReg = generateExpression(value)

        if g_boundsCheckEnabled == 1 {
            let labelSuffix = g_boundsCheckLabelCount.toString()
            g_boundsCheckLabelCount = g_boundsCheckLabelCount + 1
            emitPreparedIndexAssignmentBoundsCheckImpl(this.output, getFeatureRegBoxImpl(),
                arrayReg, indexReg,
                "bounds_fail_" + labelSuffix, "bounds_ok_" + labelSuffix)
            cseClear()
        }

        let arrayType = inferExpressionType(array)
        var elementType = "ptr"
        if arrayType.startsWith("Array<") {
            elementType = arrayType.substring(6, arrayType.length() - 1)
        }
        let llvmElementType = mapTypeState(elementType)

        var valueIsStructLiteral = 0
        if value.kind == "StructLiteral" {
            valueIsStructLiteral = 1
        }
        let valueSeenType = inferExpressionType(value)
        emitPreparedIndexAssignmentStoreImpl(this.output, getFeatureRegBoxImpl(), arrayReg,
            indexReg, valueReg, elementType, llvmElementType,
            valueIsStructLiteral, valueSeenType, getGlobalStructNamesImpl())
    }

    ///
    Main expression codegen dispatcher. Returns the SSA register (or
    immediate constant string) holding the expression's value.
    Dispatches on expr.kind to specialized generators: Literal, Variable,
    Binary, Call, MethodCall, Unary, Await, MemberAccess, IndexAccess,
    StructLiteral, ArrayLiteral, StringInterpolation, Elvis/NullCoalesce,
    SafeNavigation, WhenExpression, IfExpression, Cast, Closure, Lambda,
    EnumVariant constructors, Result ? operator, etc.
    ///
    fun tryGenerateConstructionExpression(expr: ParserExpressionNode) r: String {
        if expr.kind == "StructLiteral" {
            return generateStructLiteral(expr)
        }
        if expr.kind == "ArrayLiteral" {
            return generateArrayLiteral(expr)
        }
        if expr.kind == "StringInterpolation" {
            return generateStringInterpolation(expr)
        }
        return ""
    }

    fun tryGenerateConditionalValueExpression(expr: ParserExpressionNode) r: String {
        if expr.kind == "Elvis" or expr.kind == "NullCoalesce" {
            return generateElvis(expr)
        }
        if expr.kind == "SafeNavigation" {
            return generateSafeNavigation(expr)
        }
        if expr.kind == "WhenExpression" {
            return generateWhenExpression(expr)
        }
        if expr.kind == "IfExpression" {
            return generateIfExpression(expr)
        }
        return ""
    }

    fun emitCastSpecialExpression(expr: ParserExpressionNode) r: String {
        let cSrcReg = generateExpression(expr.operands[0])
        let cSrcType = inferExpressionType(expr.operands[0])
        let cTgtType = expr.literalValue
        return emitCastExprImpl(this.output, getFeatureRegBoxImpl(), cSrcReg, cSrcType, cTgtType)
    }

    fun emitIsExpressionTest(expr: ParserExpressionNode) r: String {
        let isSubjectReg = generateExpression(expr.operands[0])
        let isTypeName = expr.literalValue
        let isTagIdx = lookupEnumVariantTagStateImpl(isTypeName,
            g_enumVariantNames, g_enumVariantTags, g_enumVariantCount)
        if isTagIdx >= 0 {
            let isTagLoad = getNextRegFn(getFeatureRegBoxImpl())
            this.output.append("  " + isTagLoad + " = load i64, ptr " + isSubjectReg + "\n")
            let isCmpReg = getNextRegFn(getFeatureRegBoxImpl())
            this.output.append("  " + isCmpReg + " = icmp eq i64 " + isTagLoad + ", " + isTagIdx.toString() + "\n")
            return isCmpReg
        }
        let isSubjectType = inferExpressionType(expr.operands[0])
        if isSubjectType == isTypeName {
            return "1"
        }
        return "0"
    }

    fun emitTryPropagateExpression(expr: ParserExpressionNode) r: String {
        let tryInnerReg = generateExpression(expr.operands[0])
        let tryInnerType = inferExpressionType(expr.operands[0])
        if tryInnerType.startsWith("Result") {
            let tryIsOkReg = getNextRegFn(getFeatureRegBoxImpl())
            this.output.append("  " + tryIsOkReg + " = icmp ne i64 " + tryInnerReg + ", 0\n")

            let tryRegBox = getFeatureRegBoxImpl()
            let tryLabelSuffix = tryRegBox[0].toString()
            let tryOkLabel = "try.ok." + tryLabelSuffix
            let tryErrLabel = "try.err." + tryLabelSuffix

            this.output.append("  br i1 " + tryIsOkReg + ", label %" + tryOkLabel + ", label %" + tryErrLabel + "\n")

            this.output.append(tryErrLabel + ":\n")
            let tryRetType = mapTypeState(
                getCurrentFunctionReturnTypeWithGlobalStateImpl())
            if tryRetType == "void" {
                this.output.append("  ret void\n")
            } else {
                this.output.append("  ret " + tryRetType + " 0\n")
            }

            this.output.append(tryOkLabel + ":\n")
            return tryInnerReg
        }
        return tryInnerReg
    }

    fun tryGenerateSpecialExpression(expr: ParserExpressionNode) r: String {
        if expr.kind == "Await" {
            return generateAwaitExpression(expr)
        }
        if expr.kind == "Unary" {
            return generateUnary(expr)
        }
        if expr.kind == "Cast" {
            return emitCastSpecialExpression(expr)
        }
        if expr.kind == "IsExpression" {
            return emitIsExpressionTest(expr)
        }
        if expr.kind == "Closure" {
            return generateClosure(expr)
        }
        if expr.kind == "TryPropagate" {
            return emitTryPropagateExpression(expr)
        }
        return ""
    }

    fun generateExpression(expr: ParserExpressionNode) r: String {
        if expr.kind == "Literal" {
            return generateLiteral(expr)
        }
        if expr.kind == "Variable" or expr.kind == "VarExpr" {
            return generateVariable(expr)
        }
        if expr.kind == "Binary" {
            return generateBinary(expr)
        }
        if expr.kind == "Call" {
            return generateCall(expr)
        }
        if expr.kind == "MethodCall" {
            return generateMethodCall(expr)
        }
        if expr.kind == "MemberAccess" {
            return generateMemberAccess(expr)
        }
        if expr.kind == "IndexAccess" {
            return generateIndexAccess(expr)
        }
        let constructionReg = tryGenerateConstructionExpression(expr)
        if constructionReg != "" {
            return constructionReg
        }
        let conditionalReg = tryGenerateConditionalValueExpression(expr)
        if conditionalReg != "" {
            return conditionalReg
        }
        let specialReg = tryGenerateSpecialExpression(expr)
        if specialReg != "" {
            return specialReg
        }
        return "0"
    }

    fun collectStringConcatPieces(expr: ParserExpressionNode,
        pieces: Array<ParserExpressionNode>, pieceTypes: Array<String>,
        forceFlatten: Bool) r: Void {

        if expr.kind == "Binary" and expr.operator == "+" and
            expr.operands.length() >= 2 {

            var shouldFlatten = forceFlatten
            if not shouldFlatten {
                shouldFlatten = exprHasStringConcatMarkerImpl(expr)
            }
            if shouldFlatten {
                collectStringConcatPieces(expr.operands[0], pieces, pieceTypes,
                    false)
                collectStringConcatPieces(expr.operands[1], pieces, pieceTypes,
                    false)
                return
            }
        }
        pieces.push(expr)
        pieceTypes.push(inferExpressionType(expr))
    }

    fun generateFlattenedStringConcat(expr: ParserExpressionNode) r: String {
        var pieces = Array<ParserExpressionNode>()
        var pieceTypes = Array<String>()
        collectStringConcatPieces(expr, pieces, pieceTypes, true)
        if pieces.length() == 0 {
            return ""
        }

        var pieceIdx = 0
        var resultReg = ""
        while pieceIdx < pieces.length() {
            let pieceReg = generateExpression(pieces[pieceIdx])
            let pieceStrReg = coerceStringConcatPieceRegImpl(this.output,
                getFeatureRegBoxImpl(), pieceReg, pieceTypes[pieceIdx])
            if pieceIdx == 0 {
                resultReg = pieceStrReg
            } else {
                let concatReg = getNextRegFn(getFeatureRegBoxImpl())
                this.output.append("  " + concatReg +
                    " = call %SeenString @seen_str_concat_ss(%SeenString " +
                    resultReg + ", %SeenString " + pieceStrReg + ")\n")
                resultReg = concatReg
            }
            pieceIdx = pieceIdx + 1
        }
        return resultReg
    }

    ///
    Generate IR for an if-expression (if cond { a } else { b } used as a
    value). Emits then/else blocks and a phi node to merge the result.
    Supports multi-expression blocks separated by semicolons, where side
    effects execute before the final expression provides the block value.
    ///
    fun emitIfExpressionSideEffects(expr: ParserExpressionNode, startIdx: Int, stopOnSentinel: Bool) r: Int {
        var sideIdx = startIdx
        while sideIdx < expr.arguments.length() {
            let sideExpr = expr.arguments[sideIdx]
            if stopOnSentinel and sideExpr.kind == "Sentinel" {
                return sideIdx + 1
            }
            generateExpression(sideExpr)
            sideIdx = sideIdx + 1
        }
        return sideIdx
    }

    fun emitIfExpressionBranchValue(branchExpr: ParserExpressionNode, branchLabelPrefix: String, mergeLabel: String) r: String {
        let branchReg = generateExpression(branchExpr)
        let ifExprRegBox = getFeatureRegBoxImpl()
        return emitIfExpressionBranchValueImpl(this.output, branchReg,
            branchLabelPrefix, mergeLabel, ifExprRegBox[0].toString())
    }

    fun emitPhiMergeValue(llvmType: String, thenReg: String, thenLabel: String, elseReg: String, elseLabel: String) r: String {
        return emitPhiMergeValueImpl(this.output, getFeatureRegBoxImpl(), llvmType, thenReg,
            thenLabel, elseReg, elseLabel)
    }

    fun generateIfExpression(expr: ParserExpressionNode) r: String {
        ///
        if-as-expression: if cond { thenExpr } else { elseExpr }
        Generates SSA with phi node
        ///
        let condExpr = expr.operands[0]
        let thenExpr = expr.operands[1]
        let elseExpr = expr.operands[2]

        let condReg = generateExpression(condExpr)
        let condExprType = normalizeIfConditionTypeImpl(condExpr,
            inferExpressionType(condExpr))
        let condBool = emitConditionToI1Impl(this.output, getFeatureRegBoxImpl(), condReg,
            condExprType)

        let ifRegBox = getFeatureRegBoxImpl()
        let labelSuffix = ifRegBox[0].toString()
        let thenLabel = "if.expr.then." + labelSuffix
        let elseLabel = "if.expr.else." + labelSuffix
        let mergeLabel = "if.expr.merge." + labelSuffix

        this.output.append("  br i1 " + condBool + ", label %" + thenLabel + ", label %" + elseLabel + "\n")

        // Generate then-branch side-effect expressions (before the value expression)
        this.output.append(thenLabel + ":\n")
        var ifSideIdx = emitIfExpressionSideEffects(expr, 0, true)
        let thenInfo = splitPipe(emitIfExpressionBranchValue(thenExpr, "if.expr.then", mergeLabel))
        let thenReg = thenInfo[0]
        let thenPhiLabel = thenInfo[1]

        // Generate else-branch side-effect expressions
        this.output.append(elseLabel + ":\n")
        emitIfExpressionSideEffects(expr, ifSideIdx, false)
        let elseInfo = splitPipe(emitIfExpressionBranchValue(elseExpr, "if.expr.else", mergeLabel))
        let elseReg = elseInfo[0]
        let elsePhiLabel = elseInfo[1]

        // Merge with phi
        this.output.append(mergeLabel + ":\n")
        let resultType = inferExpressionType(thenExpr)
        let irType = mapTypeState(resultType)
        return emitPhiMergeValue(irType, thenReg, thenPhiLabel, elseReg, elsePhiLabel)
    }

    ///
    Generate IR for a closure expression (|x| expr or |x, y| { ... }).
    No-capture MVP: emits an anonymous `define` function, converts its
    function pointer to i64 via ptrtoint, and returns the i64 handle.
    Callers use inttoptr to convert back to a function pointer for indirect
    calls. Closure definitions are accumulated in g_closureDefs and emitted
    after all regular functions (to avoid forward-reference issues).
    ///
    fun generateClosure(expr: ParserExpressionNode) r: String {
        let closureId = g_closureCount
        g_closureCount = g_closureCount + 1
        let closureName = "__seen_closure_" + closureId.toString()

        // Build parameter list: all params are i64
        var paramList = ""
        var paramIdx = 0
        while paramIdx < expr.arguments.length() {
            if paramIdx > 0 { paramList = paramList + ", " }
            paramList = paramList + "i64 %__cp" + paramIdx.toString()
            paramIdx = paramIdx + 1
        }

        let clSavedState = beginNestedScratchState("Int")

        this.output.append("define i64 @" + quoteIdentIfNeededImpl(closureName) + "(" + paramList + ") {\n")
        this.output.append("entry:\n")

        // Bind params as local variables
        paramIdx = 0
        while paramIdx < expr.arguments.length() {
            let cpName = expr.arguments[paramIdx].literalValue
            let cpReg = "%__cp" + paramIdx.toString()
            let cpLocal = getNextRegFn(getFeatureRegBoxImpl())
            this.output.append("  " + cpLocal + " = alloca i64\n")
            this.output.append("  store i64 " + cpReg + ", ptr " + cpLocal + "\n")
            setActiveVarCountWithGlobalStateImpl(storeActiveVariableBindingImpl(this.varNames, this.varRegs,
                this.varTypes, getBoundedActiveVarCountWithGlobalStateImpl(this.varNames), cpName, cpLocal, "Int"))
            paramIdx = paramIdx + 1
        }

        // Generate body expression
        let clBodyReg = generateExpression(expr.operands[0])
        if not isBlockTerminated() {
            this.output.append("  ret i64 " + clBodyReg + "\n")
        }
        this.output.append("}\n\n")

        let closureDef = this.output.toString()
        g_closureDefs = g_closureDefs + closureDef

        restoreNestedScratchState(clSavedState)

        // Return function pointer as i64
        let clResultReg = getNextRegFn(getFeatureRegBoxImpl())
        this.output.append("  " + clResultReg + " = ptrtoint ptr @" + closureName + " to i64\n")
        return clResultReg
    }

    ///
    Generate IR for an array literal [a, b, c]. Creates the array via
    runtime helpers (seen_arr_new_str/int/float) to ensure element_size
    is set correctly, then pushes each element. The element type is
    resolved from pendingArrayLiteralType (set by the enclosing let/var
    statement) or inferred from the first element.
    ///
    fun resolveArrayLiteralElementSeenType(elemExpr: ParserExpressionNode, defaultType: String) r: String {
        if defaultType != "" {
            return defaultType
        }
        if elemExpr.kind == "StructLiteral" and elemExpr.literalType != "" {
            return elemExpr.literalType
        }
        return inferExpressionType(elemExpr)
    }

    fun resolveArrayLiteralElementType(expr: ParserExpressionNode) r: String {
        let activePendingArrayLiteralType =
            getPendingArrayLiteralTypeWithGlobalStateImpl()
        if activePendingArrayLiteralType != "" {
            let pendingElementType = extractArrayLiteralElementTypeImpl(
                activePendingArrayLiteralType)
            if pendingElementType != "" {
                return pendingElementType
            }
        }
        if expr.arguments.length() == 0 {
            return ""
        }
        return resolveArrayLiteralElementSeenType(expr.arguments[0], "")
    }

    fun emitArrayLiteralAllocation(elementType: String) r: String {
        let arrReg = getNextRegFn(getFeatureRegBoxImpl())
        if elementType == "String" {
            this.output.append("  " + arrReg + " = call ptr @seen_arr_new_str_ptr()\n")
        } else if isDataTypeState(elementType) {
            let elementSize = getDataTypeSizeState(elementType)
            this.output.append("  " + arrReg + " = call ptr @seen_arr_new_with_size_ptr(i64 " + elementSize.toString() + ")\n")
        } else {
            this.output.append("  " + arrReg + " = call ptr @seen_arr_new_ptr_ptr()\n")
        }
        return arrReg
    }

    fun generateArrayLiteralElementValue(elemExpr: ParserExpressionNode, elementType: String) r: String {
        let savedElemPending = getPendingArrayLiteralTypeWithGlobalStateImpl()
        setPendingArrayLiteralTypeWithGlobalStateImpl("")
        if elemExpr.kind == "ArrayLiteral" and (elementType.startsWith("Array") or elementType.startsWith("List")) {
            setPendingArrayLiteralTypeWithGlobalStateImpl(elementType)
        }
        let argReg = generateExpression(elemExpr)
        setPendingArrayLiteralTypeWithGlobalStateImpl(savedElemPending)
        return argReg
    }

    fun emitArrayLiteralElementPush(arrReg: String, argReg: String, argType: String, argIsStructLiteral: Bool) r: Void {
        if argType == "String" {
            this.output.append("  call void @seen_arr_push_str(ptr " + arrReg + ", %SeenString " + argReg + ")\n")
            return
        }
        if argType == "Int" {
            this.output.append("  call void @seen_arr_push_i64(ptr " + arrReg + ", i64 " + argReg + ")\n")
            return
        }

        var ptrArgReg = argReg
        if ptrArgReg == "0" {
            ptrArgReg = "null"
        }
        if isClassTypeState(argType) {
            let tmpClassReg = getNextRegFn(getFeatureRegBoxImpl())
            this.output.append("  " + tmpClassReg + " = alloca i64\n")
            this.output.append("  store i64 " + argReg + ", ptr " + tmpClassReg + "\n")
            ptrArgReg = tmpClassReg
        }
        if isDataTypeState(argType) and not argIsStructLiteral {
            let tmpDataReg = getNextRegFn(getFeatureRegBoxImpl())
            this.output.append("  " + tmpDataReg + " = alloca %" + argType + "\n")
            this.output.append("  store %" + argType + " " + argReg + ", ptr " + tmpDataReg + "\n")
            ptrArgReg = tmpDataReg
        }
        let pushReg = getNextRegFn(getFeatureRegBoxImpl())
        this.output.append("  " + pushReg + " = call i64 @Array_push(ptr " + arrReg + ", ptr " + ptrArgReg + ")\n")
    }

    fun generateArrayLiteral(expr: ParserExpressionNode) r: String {
        let savedPendingType = getPendingArrayLiteralTypeWithGlobalStateImpl()
        let elementType = resolveArrayLiteralElementType(expr)
        let arrReg = emitArrayLiteralAllocation(elementType)

        // Populate elements
        var elemIdx = 0
        while elemIdx < expr.arguments.length() {
            let elemExpr = expr.arguments[elemIdx]
            let argReg = generateArrayLiteralElementValue(elemExpr, elementType)
            let argType = resolveArrayLiteralElementSeenType(elemExpr, elementType)
            let argIsStructLiteral = elemExpr.kind == "StructLiteral"
            emitArrayLiteralElementPush(arrReg, argReg, argType, argIsStructLiteral)
            elemIdx = elemIdx + 1
        }

        setPendingArrayLiteralTypeWithGlobalStateImpl(savedPendingType)
        return arrReg
    }

    ///
    Generate IR for index access (arr[idx]). Dispatches to runtime helpers
    based on element type: seen_arr_get_str for String arrays, seen_arr_get
    for Int arrays (with bitcast i64->double for Float arrays). Supports
    bounds checking when g_boundsCheckEnabled is set. Also handles HashMap
    index access (hash_get_*) and String character access (seen_str_char_at).
    ///
    fun generateIndexAccess(expr: ParserExpressionNode) r: String {
        let idxBaseType = inferExpressionType(expr.operands[0])
        if shouldUsePointerIndexAccessImpl(idxBaseType) {
            let piaBaseReg = generateExpression(expr.operands[0])
            let piaIdxReg = generateExpression(expr.operands[1])
            return emitPreparedPointerIndexAccessImpl(this.output, getFeatureRegBoxImpl(), piaBaseReg,
                piaIdxReg)
        }

        if shouldTryOperatorIndexAccessImpl(idxBaseType) {
            let idxOpFunc = idxBaseType + "_operator_index"
            let idxOpRet = getFunctionReturnTypeWithGlobalStateImpl(idxOpFunc)
            if idxOpRet != "" {
                let idxBaseReg = generateExpression(expr.operands[0])
                let idxIdxReg = generateExpression(expr.operands[1])
                let idxRetLlvm = mapTypeState(idxOpRet)
                return emitPreparedOperatorIndexAccessCallImpl(this.output, getFeatureRegBoxImpl(),
                    idxBaseReg, idxIdxReg, idxRetLlvm,
                    quoteIdentIfNeededImpl(idxOpFunc))
            }
        }

        var arrayReg = generateExpression(expr.operands[0])
        let indexReg = generateExpression(expr.operands[1])

        ///
        Workaround: if arrayReg is 0 and the variable name is 'statements',
        try to find a BlockNode variable with that field
        ///
        if arrayReg == "0" and expr.operands[0].variableName == "statements" {
            // Look for any local variable of type BlockNode
            var blockIdx = 0
            while blockIdx < this.varTypes.length() {
                if this.varTypes[blockIdx] == "BlockNode" {
                    let blockVarReg = this.varRegs[blockIdx]
                    // Load the block pointer
                    let blockPtrReg = getNextRegFn(getFeatureRegBoxImpl())
                    this.output.append("  " + blockPtrReg + " = load ptr, ptr " + blockVarReg + "\n")
                    // Access the statements field
                    arrayReg = generateFieldAccess(blockPtrReg, "BlockNode", "statements")
                    blockIdx = this.varTypes.length()  // break
                }
                blockIdx = blockIdx + 1
            }
        }

        if shouldEmitIndexBoundsCheckImpl(g_boundsCheckEnabled) {
            var boundsCountBox = Array<Int>()
            boundsCountBox.push(g_boundsCheckLabelCount)
            emitPreparedIndexBoundsCheckImpl(this.output, getFeatureRegBoxImpl(), arrayReg, indexReg,
                boundsCountBox)
            g_boundsCheckLabelCount = boundsCountBox[0]
            cseClear()
        }

        let arrayType = inferExpressionType(expr.operands[0])
        let typedIndexPlan = planTypedIndexAccessImpl(arrayType)
        var isDataElement = 0
        if isDataTypeState(typedIndexPlan.elementType) {
            isDataElement = 1
        }
        var isClassElement = 0
        if isClassTypeState(typedIndexPlan.elementType) {
            isClassElement = 1
        }
        return emitPreparedIndexElementAccessImpl(this.output, getFeatureRegBoxImpl(),
            typedIndexPlan.action, arrayReg, indexReg,
            typedIndexPlan.elementType, isDataElement, isClassElement)
    }

    fun tryRebuildMemberAccessReceiver(expr: ParserExpressionNode,
        receiverName: String, fieldName: String,
        shouldTryRebuild: Bool) r: String {

        if not shouldTryRebuild {
            return ""
        }
        let rebuiltReceiverExpr = buildChainedPathExprImpl(receiverName)
        if rebuiltReceiverExpr.kind == "None" {
            return ""
        }
        let rebuiltExpr = ParserExpressionNode.new()
        rebuiltExpr.kind = "MemberAccess"
        rebuiltExpr.variableName = fieldName
        rebuiltExpr.operands.push(rebuiltReceiverExpr)
        return generateMemberAccess(rebuiltExpr)
    }

    fun tryGenerateEnumMemberAccess(receiverName: String, fieldName: String) r: String {
        if g_enumVariantCount > 0 and isEnumVariantStateImpl(fieldName,
            g_enumVariantNames, g_enumVariantCount) {
            let parentEnum = lookupEnumParentStateImpl(fieldName,
                g_enumVariantNames, g_enumVariantParent, g_enumVariantCount)
            if parentEnum == receiverName {
                let varFieldCount = lookupEnumFieldCountStateImpl(fieldName,
                    g_enumVariantNames, g_enumVariantFieldCounts,
                    g_enumVariantCount)
                if varFieldCount > 0 {
                    let enumExpr = ParserExpressionNode.new()
                    return generateEnumConstructor(fieldName, enumExpr)
                }
                return lookupEnumVariantTagStateImpl(fieldName,
                    g_enumVariantNames, g_enumVariantTags,
                    g_enumVariantCount).toString()
            }
        }
        if receiverName == "SeenTokenType" {
            return getSeenTokenTypeValueImpl(fieldName).toString()
        }
        return ""
    }

    fun tryGenerateSimdSwizzleMemberAccess(receiverName: String, fieldName: String) r: String {
        if receiverName == "" {
            return ""
        }
        let swzVarType = findVarType(receiverName)
        let swizzleType = inferSimdSwizzleMemberTypeImpl(swzVarType, fieldName)
        if swizzleType == "" {
            return ""
        }
        let swzIdx = findActiveVariableIndexImpl(this.varNames, getBoundedActiveVarCountWithGlobalStateImpl(this.varNames), receiverName)
        if swzIdx < 0 {
            return ""
        }
        return emitSimdSwizzleMemberAccessImpl(this.output, getFeatureRegBoxImpl(), fieldName, mapTypeState(swzVarType), this.varRegs[swzIdx])
    }

    fun tryGenerateExpressionReceiverMemberAccess(receiverExpr: ParserExpressionNode, fieldName: String) r: String {
        let receiverReg = generateExpression(receiverExpr)
        let receiverType = inferExpressionType(receiverExpr)
        return emitPreparedExpressionReceiverMemberAccessImpl(this.output, getFeatureRegBoxImpl(),
            receiverReg, receiverType, fieldName,
            getFieldTypeState(receiverType, fieldName), getGlobalStructNamesImpl(), getGlobalStructLayoutsImpl(),
            getGlobalStructFieldNamesImpl(), getGlobalStructFieldTypesImpl(), g_reprCClassNames,
            g_unionTypes, g_typeAliasNames, g_typeAliasTargets,
            g_typeAliasCount, g_enumTypeNames, getFeatureBitfieldCountImpl(),
            getFeatureBitfieldKeysImpl(), getFeatureBitfieldWidthsImpl())
    }

    fun tryGenerateVariableReceiverMemberAccess(receiverName: String, fieldName: String) r: String {
        let idx = findActiveVariableIndexImpl(this.varNames, getBoundedActiveVarCountWithGlobalStateImpl(this.varNames), receiverName)
        if idx < 0 {
            return ""
        }
        let varType = this.varTypes[idx]
        return emitPreparedVariableReceiverMemberAccessImpl(this.output, getFeatureRegBoxImpl(),
            this.varRegs[idx], varType, fieldName, getFieldTypeState(varType, fieldName),
            getGlobalStructNamesImpl(), getGlobalStructLayoutsImpl(), getGlobalStructFieldNamesImpl(), getGlobalStructFieldTypesImpl(),
            g_reprCClassNames, g_unionTypes, g_typeAliasNames,
            g_typeAliasTargets, g_typeAliasCount, g_enumTypeNames,
            getFeatureBitfieldCountImpl(), getFeatureBitfieldKeysImpl(), getFeatureBitfieldWidthsImpl())
    }

    fun tryGenerateModuleConstReceiverMemberAccess(receiverName: String, fieldName: String) r: String {
        let constIdx = findModuleConstant(receiverName)
        if constIdx < 0 {
            return ""
        }
        let constType = getModuleConstantTypeWithModuleStateImpl(constIdx)
        var constSeenType = getModuleConstSeenTypeWithModuleStateImpl(constIdx)
        if constSeenType == "" {
            constSeenType = findVarType(receiverName)
        }
        let invSuffix = moduleConstantInvariantLoadSuffixWithModuleStateImpl(
            constIdx)
        return emitPreparedModuleConstReceiverMemberAccessImpl(this.output, getFeatureRegBoxImpl(),
            "@" + quoteIdentIfNeededImpl(receiverName), constType, constSeenType,
            invSuffix, fieldName, getFieldTypeState(constSeenType, fieldName),
            getGlobalStructNamesImpl(), getGlobalStructLayoutsImpl(), getGlobalStructFieldNamesImpl(), getGlobalStructFieldTypesImpl(),
            g_reprCClassNames, g_unionTypes, g_typeAliasNames,
            g_typeAliasTargets, g_typeAliasCount, g_enumTypeNames,
            getFeatureBitfieldCountImpl(), getFeatureBitfieldKeysImpl(), getFeatureBitfieldWidthsImpl())
    }

    fun tryGenerateBracketPathMemberAccess(receiverName: String, fieldName: String) r: String {
        if not receiverName.contains("[") {
            return ""
        }
        let bracketParts = splitBracketPathImpl(receiverName)
        if bracketParts.length() < 2 {
            return ""
        }
        let pathBeforeBracket = bracketParts[0]
        let indexStr = bracketParts[1]
        if not pathBeforeBracket.contains(".") {
            return ""
        }

        let pathParts = splitFirstPathDotImpl(pathBeforeBracket)
        let baseVar = pathParts[0]
        let arrayField = pathParts[1]

        let baseIdx = findActiveVariableIndexImpl(this.varNames, getBoundedActiveVarCountWithGlobalStateImpl(this.varNames), baseVar)
        if baseIdx < 0 {
            return ""
        }

        let baseType = this.varTypes[baseIdx]
        let arrayType = getSeenFieldTypeState(baseType, arrayField)
        var elementType = parseArrayElementTypeImpl(arrayType)
        if elementType == "" and arrayType.startsWith("Array<") and arrayType.endsWith(">") {
            elementType = arrayType.substring(6, arrayType.length() - 1)
        }
        return emitPreparedBracketPathMemberAccessImpl(this.output, getFeatureRegBoxImpl(), receiverName,
            fieldName, baseVar, this.varRegs[baseIdx], baseType, arrayField,
            getFieldTypeState(baseType, arrayField), indexStr, elementType,
            getFieldTypeState(elementType, fieldName), getGlobalStructNamesImpl(), getGlobalStructLayoutsImpl(),
            getGlobalStructFieldNamesImpl(), getGlobalStructFieldTypesImpl(), g_reprCClassNames,
            g_unionTypes, g_typeAliasNames, g_typeAliasTargets,
            g_typeAliasCount, g_enumTypeNames, getFeatureBitfieldCountImpl(),
            getFeatureBitfieldKeysImpl(), getFeatureBitfieldWidthsImpl())
    }

    fun tryGenerateChainedReceiverMemberAccess(receiverName: String, fieldName: String) r: String {
        if not receiverName.contains(".") {
            return ""
        }
        let receiverParts = splitFirstPathDotImpl(receiverName)
        let baseVarName = receiverParts[0]
        let restPath = receiverParts[1]
        if restPath == "" {
            return ""
        }

        let baseIdx = findActiveVariableIndexImpl(this.varNames, getBoundedActiveVarCountWithGlobalStateImpl(this.varNames), baseVarName)
        if baseIdx < 0 {
            return ""
        }
        let baseType = this.varTypes[baseIdx]
        var intermediateType = resolveChainedPathSuffixTypeImpl(baseType, restPath,
            getGlobalStructNamesImpl(), getGlobalStructFieldNamesImpl(), getGlobalStructFieldTypesImpl(), getGlobalStructMethodNamesImpl(), getGlobalStructMethodRetTypesImpl())
        if intermediateType == "" {
            intermediateType = "ProgramNode"
        }
        return emitPreparedChainedReceiverMemberAccessImpl(this.output, getFeatureRegBoxImpl(),
            fieldName, this.varRegs[baseIdx], baseType, restPath, intermediateType,
            getFieldTypeState(intermediateType, fieldName), getGlobalStructNamesImpl(),
            getGlobalStructLayoutsImpl(), getGlobalStructFieldNamesImpl(), getGlobalStructFieldTypesImpl(),
            g_reprCClassNames, g_unionTypes, g_typeAliasNames,
            g_typeAliasTargets, g_typeAliasCount, g_enumTypeNames,
            getFeatureBitfieldCountImpl(), getFeatureBitfieldKeysImpl(), getFeatureBitfieldWidthsImpl())
    }

    fun tryGenerateImplicitThisReceiverMemberAccess(receiverName: String, fieldName: String) r: String {
        let thisIdx = findActiveVariableIndexImpl(this.varNames, getBoundedActiveVarCountWithGlobalStateImpl(this.varNames), "this")
        if thisIdx < 0 {
            return ""
        }
        let thisType = this.varTypes[thisIdx]
        var intermediateType = ""
        if receiverName.contains(".") {
            intermediateType = resolveMethodFieldPathTypeImpl(thisType,
                receiverName, getGlobalStructNamesImpl(), getGlobalStructFieldNamesImpl(), getGlobalStructFieldTypesImpl(),
                getGlobalStructMethodNamesImpl(), getGlobalStructMethodRetTypesImpl())
        } else {
            let fieldIdx = getFieldInfoState(thisType, receiverName)
            if fieldIdx < 0 {
                return ""
            }
            intermediateType = getSeenFieldTypeState(thisType, receiverName)
        }
        if intermediateType == "" {
            return ""
        }
        return emitPreparedImplicitThisReceiverMemberAccessImpl(this.output, getFeatureRegBoxImpl(),
            receiverName, fieldName, this.varRegs[thisIdx], thisType,
            intermediateType, getFieldTypeState(intermediateType, fieldName),
            getGlobalStructNamesImpl(), getGlobalStructLayoutsImpl(), getGlobalStructFieldNamesImpl(), getGlobalStructFieldTypesImpl(),
            g_reprCClassNames, g_unionTypes, g_typeAliasNames,
            g_typeAliasTargets, g_typeAliasCount, g_enumTypeNames,
            getFeatureBitfieldCountImpl(), getFeatureBitfieldKeysImpl(), getFeatureBitfieldWidthsImpl())
    }

    ///
    Generate IR for member access (expr.field). Handles:
      - Array/String .length() — inline load from SeenArray.len field
      - Enum variant field access — load from heap offset (tag + fieldIdx*8)
      - Class field access — inttoptr receiver i64->ptr, then GEP + load
      - Data type field access — direct GEP on pointer
      - Chained access (a.b.c) — recursive resolution via generateFieldAccess
    ///
    fun generateMemberAccess(expr: ParserExpressionNode) r: String {
        let receiverName = expr.literalValue
        let fieldName = expr.variableName
        var dottedBaseKnown = false
        if receiverName.contains(".") {
            let receiverSegments = splitChainedPathImpl(receiverName)
            if receiverSegments.length() > 0 and
                findVarType(receiverSegments[0]) != "" {
                dottedBaseKnown = true
            }
        }
        let memberRoute = planMemberAccessRouteImpl(expr.operands.length(),
            receiverName, dottedBaseKnown)

        if memberRoute.shouldTryRebuild {
            let rebuiltResult = tryRebuildMemberAccessReceiver(expr,
                receiverName, fieldName, memberRoute.shouldTryRebuild)
            if rebuiltResult != "" {
                return rebuiltResult
            }
        }

        if memberRoute.shouldTryEnum {
            let enumResult = tryGenerateEnumMemberAccess(receiverName,
                fieldName)
            if enumResult != "" {
                return enumResult
            }
        }

        if memberRoute.shouldTrySwizzle {
            let swizzleResult = tryGenerateSimdSwizzleMemberAccess(
                receiverName, fieldName)
            if swizzleResult != "" {
                return swizzleResult
            }
        }

        if memberRoute.shouldUseExpressionReceiver {
            return tryGenerateExpressionReceiverMemberAccess(expr.operands[0], fieldName)
        }

        if memberRoute.shouldTryVariableReceiver {
            let varResult = tryGenerateVariableReceiverMemberAccess(
                receiverName, fieldName)
            if varResult != "" {
                return varResult
            }
        }

        if memberRoute.shouldTryModuleConstantReceiver {
            let constResult = tryGenerateModuleConstReceiverMemberAccess(
                receiverName, fieldName)
            if constResult != "" {
                return constResult
            }
        }

        if memberRoute.shouldTryBracketPath {
            let bracketResult = tryGenerateBracketPathMemberAccess(
                receiverName, fieldName)
            if bracketResult != "" {
                return bracketResult
            }
        }

        if memberRoute.shouldTryChainedReceiver {
            let chainedResult = tryGenerateChainedReceiverMemberAccess(
                receiverName, fieldName)
            if chainedResult != "" {
                return chainedResult
            }
        }

        if memberRoute.shouldTryImplicitThisReceiver {
            let thisResult = tryGenerateImplicitThisReceiverMemberAccess(
                receiverName, fieldName)
            if thisResult != "" {
                return thisResult
            }
        }

        return "0"
    }

    ///
    Generate a struct field load via GEP (getelementptr). For simple fields,
    emits: getelementptr %StructType, ptr %ptrReg, i32 0, i32 <fieldIdx>
    followed by a load. For chained field access (e.g., "a.b.c"), recursively
    resolves each segment, converting class-type intermediates from i64 to
    ptr via inttoptr. For inline data types, uses generateFieldAccessPtr to
    get a pointer without loading (avoids copying the entire struct).
    WARNING: DO NOT use `!invariant.load` on array data pointers — array
    data changes on push/resize, so the invariant annotation would be
    incorrect and could cause LLVM to cache stale pointers.
    ///
    fun generateFieldAccess(ptrReg: String, structType: String, fieldName: String) r: String {
        return generateFieldAccessImpl(this.output, getFeatureRegBoxImpl(), ptrReg, structType,
            fieldName, getFieldTypeState(structType, fieldName), getGlobalStructNamesImpl(),
            getGlobalStructLayoutsImpl(), getGlobalStructFieldNamesImpl(), getGlobalStructFieldTypesImpl(),
            g_reprCClassNames, g_unionTypes, g_typeAliasNames,
            g_typeAliasTargets, g_typeAliasCount, g_enumTypeNames,
            getFeatureBitfieldCountImpl(), getFeatureBitfieldKeysImpl(), getFeatureBitfieldWidthsImpl())
    }

    ///
    Same as generateFieldAccess but returns the GEP pointer without loading
    Used for methods like push that need to modify the field in place
    ///
    fun generateFieldAccessPtr(ptrReg: String, structType: String, fieldName: String) r: String {
        return generateFieldAccessPtrImpl(this.output, getFeatureRegBoxImpl(), ptrReg,
            structType, fieldName, getGlobalStructNamesImpl(), getGlobalStructLayoutsImpl(),
            getGlobalStructFieldNamesImpl(), g_unionTypes)
    }

    ///
    Generate IR for a struct literal expression (StructName { field: val, ... }).
    Allocates the struct on the heap via malloc, memsets to zero, then stores
    each field at its GEP offset. Data types use value semantics and return
    the allocated pointer directly. Class values follow the current ABI and
    are represented as pointer-as-i64 in expression results.
    ///
    fun inferStructLiteralFieldTypeFromValueExpr(valueExpr: ParserExpressionNode, sizeOut: Array<Int>) r: String {
        if valueExpr.kind == "StructLiteral" and valueExpr.literalType != "" {
            sizeOut[0] = 24
            return "%" + quoteIdentIfNeededImpl(valueExpr.literalType)
        }
        var fieldType = inferStructFieldTypeFromExpr(valueExpr, sizeOut)
        if valueExpr.kind == "MethodCall" {
            let calleeType = inferExpressionType(valueExpr)
            if isDataTypeState(calleeType) {
                fieldType = "%" + quoteIdentIfNeededImpl(calleeType)
            }
        }
        return fieldType
    }

    fun buildInferredStructLiteralLayoutInfo(expr: ParserExpressionNode) r: String {
        let lb = "{"
        let rb = "}"
        var structSize = 0
        var layoutFields = ""
        var fieldI = 0
        while fieldI < expr.arguments.length() {
            if fieldI > 0 {
                layoutFields = layoutFields + ", "
            }
            var inferredFieldType = "i64"
            var fieldSize = 8
            let fieldExpr = expr.arguments[fieldI]
            if fieldExpr.operands.length() > 0 {
                let fieldSizeOut = Array<Int>()
                fieldSizeOut.push(8)
                inferredFieldType = inferStructLiteralFieldTypeFromValueExpr(fieldExpr.operands[0], fieldSizeOut)
                fieldSize = fieldSizeOut[0]
            }
            structSize = structSize + fieldSize
            layoutFields = layoutFields + inferredFieldType
            fieldI = fieldI + 1
        }
        let inferredLayout = lb + " " + layoutFields + " " + rb
        let alignedStructSize = computeStructSizeFromLayoutImpl(inferredLayout,
            getGlobalStructNamesImpl(), getGlobalStructLayoutsImpl(), getGlobalStructSizesImpl())
        if alignedStructSize > 0 {
            structSize = alignedStructSize
        }
        return structSize.toString() + "|" + inferredLayout
    }

    fun resolveStructLiteralLayoutInfo(expr: ParserExpressionNode, structName: String, structIdx: Int) r: String {
        if structIdx >= 0 {
            var structSize = getGlobalStructSizesImpl()[structIdx]
            if structSize < 8 {
                structSize = 8
            }
            return structSize.toString() + "|" + getGlobalStructLayoutsImpl()[structIdx]
        }
        let knownLitLayout = resolveKnownStructFieldImpl(structName, "")
        if knownLitLayout != "" {
            var knownStructSize = getLlvmTypeSizeImpl(knownLitLayout,
                getGlobalStructNamesImpl(), getGlobalStructLayoutsImpl(), getGlobalStructSizesImpl())
            if knownStructSize < 8 {
                knownStructSize = 8
            }
            return knownStructSize.toString() + "|" + knownLitLayout
        }
        let inferredInfo = splitPipe(buildInferredStructLiteralLayoutInfo(expr))
        var inferredSize = inferredInfo[0].toInt()
        if inferredSize < 8 {
            inferredSize = 8
        }
        let inferredLayout = inferredInfo[1]
        println("[WARN] Unknown struct type '" + structName + "' - using inferred layout: " + inferredLayout + " size=" + inferredSize.toString())
        return inferredSize.toString() + "|" + inferredLayout
    }

    fun allocateStructLiteralStorage(structSize: Int) r: String {
        let mallocReg = getNextRegFn(getFeatureRegBoxImpl())
        if structSize <= 80 {
            this.output.append("  " + mallocReg + " = call ptr @seen_pool_alloc(i64 " + structSize.toString() + ")\n")
        }
        if structSize > 80 {
            this.output.append("  " + mallocReg + " = call ptr @malloc(i64 " + structSize.toString() + ")\n")
        }
        this.output.append("  ; escape-analysis: heap-to-stack candidate (" + structSize.toString() + " bytes)\n")
        return mallocReg
    }

    fun resolveStructLiteralFieldValue(structName: String, structIdx: Int, fieldName: String, fieldExpr: ParserExpressionNode) r: String {
        if fieldExpr.operands.length() == 0 {
            return "0"
        }
        let savedPendingType = getPendingArrayLiteralTypeWithGlobalStateImpl()
        var fieldSeenType = ""
        if structIdx >= 0 {
            fieldSeenType = getSeenFieldTypeState(structName, fieldName)
        }
        if fieldExpr.operands[0].kind == "ArrayLiteral" and (fieldSeenType.startsWith("Array") or fieldSeenType.startsWith("List")) {
            setPendingArrayLiteralTypeWithGlobalStateImpl(fieldSeenType)
        }
        let valueReg = generateExpression(fieldExpr.operands[0])
        setPendingArrayLiteralTypeWithGlobalStateImpl(savedPendingType)
        return valueReg
    }

    fun resolveStructLiteralFieldInfo(structName: String, structIdx: Int, fieldName: String, fieldExpr: ParserExpressionNode, defaultGepIndex: Int) r: String {
        var gepIndex = defaultGepIndex
        var fieldType = "i64"
        if structIdx >= 0 {
            let regFieldIdx = getFieldInfoState(structName, fieldName)
            if regFieldIdx >= 0 {
                gepIndex = regFieldIdx
                fieldType = getFieldTypeState(structName, fieldName)
            }
            return fieldType + "|" + gepIndex.toString()
        }
        let knownFieldLayout = resolveKnownStructFieldImpl(structName, fieldName)
        if knownFieldLayout != "" and g_resolvedFieldIndex >= 0 {
            gepIndex = g_resolvedFieldIndex
            fieldType = decodeFieldTypeCode(g_resolvedFieldTypeCode)
            return fieldType + "|" + gepIndex.toString()
        }
        let fbGepBox = Array<Int>()
        fbGepBox.push(defaultGepIndex)
        let fbType = resolveStructLiteralFieldFallback(structName, fieldName, fbGepBox)
        if fbType != "" {
            gepIndex = fbGepBox[0]
            fieldType = fbType
            return fieldType + "|" + gepIndex.toString()
        }
        if fieldExpr.operands.length() > 0 {
            let fieldSizeOut = Array<Int>()
            fieldSizeOut.push(8)
            fieldType = inferStructLiteralFieldTypeFromValueExpr(fieldExpr.operands[0], fieldSizeOut)
        }
        return fieldType + "|" + gepIndex.toString()
    }

    fun generateStructLiteral(expr: ParserExpressionNode) r: String {
        let structName = expr.literalType
        let structIdx = findStructReg(structName, getGlobalStructNamesImpl())
        let layoutInfo = splitPipe(resolveStructLiteralLayoutInfo(expr, structName, structIdx))
        let structSize = layoutInfo[0].toInt()
        let structLayout = layoutInfo[1]
        let mallocReg = allocateStructLiteralStorage(structSize)

        var slFieldRegs = Array<String>()
        var slFieldTypes = Array<String>()
        var slGepIndices = Array<Int>()
        var fieldIdx = 0
        while fieldIdx < expr.arguments.length() {
            let fieldExpr = expr.arguments[fieldIdx]
            let fieldName = fieldExpr.variableName
            let fieldInfo = splitPipe(resolveStructLiteralFieldInfo(structName, structIdx, fieldName, fieldExpr, fieldIdx))
            let fieldType = fieldInfo[0]
            let gepIndex = fieldInfo[1].toInt()
            var fieldReg = resolveStructLiteralFieldValue(structName,
                structIdx, fieldName, fieldExpr)
            if fieldExpr.operands.length() > 0 {
                let fieldValueExpr = fieldExpr.operands[0]
                if fieldValueExpr.kind == "StructLiteral" and
                    fieldType.startsWith("%") {

                    let loadedFieldReg = getNextRegFn(getFeatureRegBoxImpl())
                    this.output.append("  " + loadedFieldReg + " = load " +
                        fieldType + ", ptr " + fieldReg + "\n")
                    fieldReg = loadedFieldReg
                } else {
                    let fieldValueSeenType = inferExpressionType(fieldValueExpr)
                    let rawFieldReg = fieldReg
                    fieldReg = coerceValueForLlvmTarget(fieldType,
                        fieldValueSeenType, fieldReg)
                    fieldReg = coerceMethodCallHandleAssignmentImpl(this.output,
                        getFeatureRegBoxImpl(), fieldType, fieldValueSeenType, rawFieldReg,
                        fieldValueExpr.kind, fieldReg, getGlobalStructNamesImpl())
                }
            }
            slFieldRegs.push(fieldReg)
            slFieldTypes.push(fieldType)
            slGepIndices.push(gepIndex)
            fieldIdx = fieldIdx + 1
        }

        emitStructFieldStoresImpl(this.output, getFeatureRegBoxImpl(), structLayout, mallocReg, slFieldRegs, slFieldTypes, slGepIndices)

        if isClassTypeState(structName) {
            let i64Reg = getNextRegFn(getFeatureRegBoxImpl())
            this.output.append("  " + i64Reg + " = ptrtoint ptr " + mallocReg + " to i64\n")
            return i64Reg
        }

        return mallocReg
    }

    ///
    Thin wrapper: delegates to generateLiteralFree in ir_literal_gen.seen,
    then updates stats counters that aren't accessible from satellite modules.
    ///
    fun generateLiteral(expr: ParserExpressionNode) r: String {
        syncState()
        let litState = getSharedCodegenState()
        let litResult = generateLiteralFree(litState, expr)
        writeBackState()
        // Update stats counter (module-level, not accessible from satellite)
        if expr.literalType == "String" {
            if expr.literalValue.length() <= 15 {
                g_stringsDeduped = g_stringsDeduped + 1
                mlLogDecision("sso", "inlined", "len:" + expr.literalValue.length().toString())
            }
        }
        return litResult
    }

    ///
    Generate IR for a variable reference. Looks up the variable in
    this.varNames[] (via findVar, searching backwards for shadowing), then
    emits a load from the alloca register. Falls back to module constants
    (@global_name), enum variant tags (i64 constants), and 'this' field
    access if the bare name matches a struct field on the current class.
    ///
    fun tryEmitMovedVariableRead(varName: String) r: Int {
        if isMovedVariableImpl(getCurrentFunctionEmissionStateImpl(),
            varName) == 1 {
            emitMovedVariableUseTrapImpl(this.output, varName)
            return 1
        }
        return 0
    }

    fun tryGenerateComptimeVariable(varName: String) r: String {
        if g_comptimeCount > 0 {
            let ctVal = lookupComptimeVarState(varName)
            if ctVal != -9999999 {
                return emitComptimeVariableLoadImpl(this.output, getFeatureRegBoxImpl(), ctVal)
            }
        }
        return ""
    }

    fun tryGenerateImplicitThisVariable(varName: String) r: String {
        let thisIdx = findActiveVariableIndexImpl(this.varNames, getBoundedActiveVarCountWithGlobalStateImpl(this.varNames), "this")
        if thisIdx < 0 {
            return ""
        }

        let thisReg = this.varRegs[thisIdx]
        let thisType = this.varTypes[thisIdx]
        if thisType == "LLVMIRGenerator" {
            let idxCheck = getLLVMIRGeneratorFieldIndexImpl(varName)
            if idxCheck >= 0 {
                let thisPtrReg = emitImplicitThisPointerLoadImpl(this.output, getFeatureRegBoxImpl(), thisReg)
                return generateFieldAccess(thisPtrReg, thisType, varName)
            }
        }

        let structIdx = findStructReg(thisType, getGlobalStructNamesImpl())
        if structIdx < 0 {
            return ""
        }

        let fieldIdx = getFieldInfoState(thisType, varName)
        if fieldIdx < 0 {
            return ""
        }

        let thisPtrReg = emitImplicitThisPointerLoadImpl(this.output, getFeatureRegBoxImpl(), thisReg)
        return generateFieldAccess(thisPtrReg, thisType, varName)
    }

    fun tryGenerateFallbackVariable(varName: String) r: String {
        let constIdx = findModuleConstant(varName)
        if constIdx >= 0 {
            let invSuffix = moduleConstantInvariantLoadSuffixWithModuleStateImpl(
                constIdx)
            let constType = getModuleConstantTypeWithModuleStateImpl(constIdx)
            let loadReg = emitModuleConstantLoadImpl(this.output, getFeatureRegBoxImpl(),
                "@" + varName, constType, invSuffix)
            let seenType = getModuleConstSeenTypeWithModuleStateImpl(constIdx)
            return narrowModuleConstantLoadIfNeededImpl(this.output, getFeatureRegBoxImpl(),
                constType, loadReg, seenType, mapTypeState(seenType))
        }

        let implicitThisReg = tryGenerateImplicitThisVariable(varName)
        if implicitThisReg != "" {
            return implicitThisReg
        }

        let fpRetType = getFunctionReturnTypeWithGlobalStateImpl(varName)
        if fpRetType != "" {
            return emitFunctionPointerInteropLoadImpl(this.output, getFeatureRegBoxImpl(),
                "@" + quoteIdentIfNeededImpl(varName))
        }
        return ""
    }

    fun generateVariable(expr: ParserExpressionNode) r: String {
        let varName = getExprVariableName(expr)
        if varName == "" {
            return "0"
        }

        if tryEmitMovedVariableRead(varName) == 1 {
            return "0"
        }

        let ctReg = tryGenerateComptimeVariable(varName)
        if ctReg != "" {
            return ctReg
        }

        let idx = findActiveVariableIndexImpl(this.varNames, getBoundedActiveVarCountWithGlobalStateImpl(this.varNames), varName)
        if idx < 0 {
            let fallbackReg = tryGenerateFallbackVariable(varName)
            if fallbackReg != "" {
                return fallbackReg
            }
            return "0"
        }

        return emitLocalVariableLoadImpl(this.output, getFeatureRegBoxImpl(),
            mapTypeState(this.varTypes[idx]), this.varRegs[idx])
    }

    fun inferMembershipElementType(rightExpr: ParserExpressionNode,
        rightType: String) r: String {

        let declaredElementType = inferDeclaredMembershipElementTypeImpl(
            rightType)
        if declaredElementType != "" {
            return declaredElementType
        }
        if shouldInferMembershipArrayLiteralElementImpl(rightExpr.kind,
            rightExpr.arguments.length()) {

            return inferExpressionType(rightExpr.arguments[0])
        }
        return ""
    }

    fun generateMembershipArrayReg(rightExpr: ParserExpressionNode,
        elementType: String) r: String {

        let savedPendingType = getPendingArrayLiteralTypeWithGlobalStateImpl()
        let pendingMembershipType = membershipPendingArrayLiteralTypeImpl(
            rightExpr.kind, elementType)
        if pendingMembershipType != "" {
            setPendingArrayLiteralTypeWithGlobalStateImpl(pendingMembershipType)
        }
        let rightReg = generateExpression(rightExpr)
        setPendingArrayLiteralTypeWithGlobalStateImpl(savedPendingType)
        return rightReg
    }

    fun generateMembershipExpression(leftExpr: ParserExpressionNode,
        rightExpr: ParserExpressionNode, leftType: String, rightType: String)
        r: String {

        let elementType = inferMembershipElementType(rightExpr, rightType)
        let needleWarning = membershipNeedleWarningImpl(elementType, leftType)
        if needleWarning != "" {
            this.output.append(needleWarning)
            return "false"
        }
        let unsupportedWarning = membershipUnsupportedSetWarningImpl(
            elementType, rightType)
        if unsupportedWarning != "" {
            this.output.append(unsupportedWarning)
            return "false"
        }
        let leftReg = generateExpression(leftExpr)
        let rightReg = generateMembershipArrayReg(rightExpr, elementType)
        return emitPreparedMembershipContainsImpl(this.output, getFeatureRegBoxImpl(),
            elementType, leftReg, rightReg)
    }

    ///
    Generate IR for a binary expression (+, -, *, /, %, ==, !=, <, >, etc.).
    Type-dispatches: SIMD vector arithmetic, float operations (fadd/fsub/...),
    string concatenation (seen_str_concat_ss), integer arithmetic, comparison
    operators, bitwise ops, and short-circuit &&/||.
    Includes constant folding for integer-literal operands via foldIntConstants.
    Supports overflow-checked arithmetic when g_panicOnOverflow is set
    (uses llvm.sadd.with.overflow intrinsics). Delegates to prepared helpers
    for the core LLVM instruction emission.
    ///
    fun generateBinary(expr: ParserExpressionNode) r: String {
        let leftExpr = expr.operands[0]
        let rightExpr = expr.operands[1]

        let leftType = inferExpressionType(leftExpr)
        let rightType = inferExpressionType(rightExpr)

        if expr.operator == "in" {
            return generateMembershipExpression(leftExpr, rightExpr,
                leftType, rightType)
        }

        if expr.operator == "+" and isStringConcatTypePairImpl(leftType, rightType) {
            let flattenedStringConcat = generateFlattenedStringConcat(expr)
            if flattenedStringConcat != "" {
                return flattenedStringConcat
            }
        }

        // --- Pointer arithmetic ---
        if shouldTryPointerArithmeticBinaryImpl(leftType, expr.operator) {
            let paLeftReg = generateExpression(leftExpr)
            let paRightReg = generateExpression(rightExpr)
            let paResult = emitPreparedPointerArithmeticBinaryImpl(this.output, getFeatureRegBoxImpl(),
                expr.operator, leftType, rightType, paLeftReg, paRightReg)
            if paResult != "" {
                return paResult
            }
        }

        // --- SIMD vector arithmetic ---
        let simdBinaryOp = isSimdBinaryOperatorImpl(expr.operator)
        if shouldTrySimdBinaryGateImpl(isSimdVectorTypeImpl(leftType),
            simdBinaryOp) {
            let simdLlvmType = mapTypeState(leftType)
            let simdLeftReg = generateExpression(leftExpr)
            let simdRightReg = generateExpression(rightExpr)
            let simdResult = emitPreparedSimdBinaryExprImpl(this.output, getFeatureRegBoxImpl(),
                expr.operator, leftType, simdLlvmType, simdLeftReg, simdRightReg)
            if simdResult != "" {
                return simdResult
            }
        }

        // --- E-graph peephole optimizations (consolidated via egraph lookup) ---
        let binaryLiteralFacts = planBinaryOperandLiteralFactsImpl(
            leftExpr.kind, leftExpr.literalType, leftExpr.literalValue,
            rightExpr.kind, rightExpr.literalType, rightExpr.literalValue)
        // Integer peephole rules
        if shouldUseIntPeepholeGateImpl(leftType, rightType) {
            let leftIsIntLit = binaryLiteralFacts.leftIsIntLiteral
            let rightIsIntLit = binaryLiteralFacts.rightIsIntLiteral
            let leftLitVal = binaryLiteralFacts.leftLiteralValue
            let rightLitVal = binaryLiteralFacts.rightLiteralValue

            // Self-comparison: both sides are the same variable (not a call)
            if binaryLiteralFacts.isSelfVariableComparison {
                let selfAction = egraphSelfComparison(expr.operator)
                let selfPlan = planBinaryFoldActionImpl(selfAction, true)
                if selfPlan.returnLeft {
                    return generateExpression(leftExpr)
                }
                let selfFoldReg = emitPreparedSelfComparisonConstResultImpl(this.output,
                    getFeatureRegBoxImpl(), selfAction, expr.operator)
                if selfFoldReg != "" {
                    g_constantsFolded = g_constantsFolded + 1
                    if selfPlan.shouldLogSelfComparison {
                        mlLogDecision("e-graph", "self-opt",
                            buildSelfComparisonLogValueImpl(
                            leftExpr.literalValue, expr.operator,
                            selfAction))
                    }
                    return selfFoldReg
                }
            }

            // E-graph lookup for literal-based rules — delegated to ir_optimization.seen
            let action = egraphLookup(expr.operator, leftLitVal, rightLitVal, leftIsIntLit, rightIsIntLit)
            let actionPlan = planBinaryFoldActionImpl(action, false)
            if actionPlan.returnLeft {
                return generateExpression(leftExpr)
            }
            if actionPlan.returnRight {
                return generateExpression(rightExpr)
            }
            if actionPlan.shouldEmitAction {
                if actionPlan.shouldCountFold {
                    g_constantsFolded = g_constantsFolded + 1
                    mlLogDecision("e-graph", "folded", expr.operator + "=" + action)
                }
                // For non-const actions, generate left operand (all remaining actions use leftReg)
                var egLeftReg = ""
                if actionPlan.shouldGenerateLeftReg {
                    egLeftReg = generateExpression(leftExpr)
                }
                let egResult = emitPreparedIntPeepholeBinaryActionImpl(this.output, getFeatureRegBoxImpl(), action, egLeftReg, expr.operator)
                if egResult != "" {
                    return egResult
                }
            }

            // Associative rewrite: (a OP CONST1) OP CONST2 → a OP (CONST1 OP CONST2)
            if shouldTryBinaryAssociativeIntFoldImpl(expr.operator, rightIsIntLit,
                leftExpr.kind, leftExpr.operator, leftExpr.operands.length()) {
                let innerRight = leftExpr.operands[1]
                if isBinaryIntLiteralOperandImpl(innerRight.kind,
                    innerRight.literalType) {
                    let combinedVal = foldIntConstants(
                        innerRight.literalValue, rightLitVal, expr.operator)
                    let origCost = exprCost(expr) + exprCost(leftExpr)
                    let rewriteCost = binaryAssociativeIntFoldRewriteCostImpl(
                        expr.operator, exprCost(leftExpr.operands[0]))
                    if shouldApplyBinaryAssociativeIntFoldImpl(combinedVal,
                        rewriteCost, origCost) {
                        g_constantsFolded = g_constantsFolded + 1
                        mlLogDecision("e-graph", "assoc-fold",
                            buildBinaryFoldLogValueImpl(
                            innerRight.literalValue, expr.operator,
                            rightLitVal, combinedVal))
                        let innerLeftReg =
                            generateExpression(leftExpr.operands[0])
                        let assocResultReg =
                            emitPreparedAssociativeIntFoldResultImpl(this.output,
                                getFeatureRegBoxImpl(), expr.operator, innerLeftReg,
                                combinedVal)
                        if assocResultReg != "" {
                            return assocResultReg
                        }
                    }
                }
            }
            // Comparison of two integer literals: fold at compile time
            var cmpResult = ""
            if leftIsIntLit and rightIsIntLit {
                cmpResult = foldIntComparison(leftLitVal, rightLitVal,
                    expr.operator)
            }
            let cmpFoldPlan = planBinaryLiteralComparisonFoldImpl(
                leftIsIntLit, rightIsIntLit, cmpResult)
            if cmpFoldPlan.shouldFold {
                g_constantsFolded = g_constantsFolded + 1
                if cmpFoldPlan.shouldCountBranch {
                    g_branchesEliminated = g_branchesEliminated + 1
                }
                mlLogDecision("const-fold", "cmp-folded",
                    buildBinaryFoldLogValueImpl(leftLitVal,
                    expr.operator, rightLitVal, cmpResult))
                return emitPreparedFoldedBoolLiteralBinaryResultImpl(this.output,
                    getFeatureRegBoxImpl(), cmpResult)
            }
            // Constant folding: both operands are IntLiteral → compute at compile time
            var folded = ""
            if leftIsIntLit and rightIsIntLit {
                folded = foldIntConstants(leftLitVal, rightLitVal,
                    expr.operator)
            }
            let literalConstFoldPlan = planBinaryLiteralConstantFoldImpl(
                leftIsIntLit, rightIsIntLit, folded)
            if literalConstFoldPlan.shouldFold {
                g_constantsFolded = g_constantsFolded + 1
                mlLogDecision("const-fold", "folded",
                    buildBinaryFoldLogValueImpl(leftLitVal,
                    expr.operator, rightLitVal, folded))
                return emitPreparedFoldedIntLiteralBinaryResultImpl(this.output,
                    getFeatureRegBoxImpl(), folded)
            }
        }
        // Float peephole optimizations — delegated to ir_optimization.seen
        if shouldUseFloatPeepholeGateImpl(leftType, rightType) {
            let fLeftIsLit = binaryLiteralFacts.leftIsFloatLiteral
            let fRightIsLit = binaryLiteralFacts.rightIsFloatLiteral
            let fLeftLitVal = binaryLiteralFacts.leftLiteralValue
            let fRightLitVal = binaryLiteralFacts.rightLiteralValue
            let fAction = egraphLookupFloat(expr.operator, fLeftLitVal, fRightLitVal, fLeftIsLit, fRightIsLit)
            let fActionPlan = planBinaryFloatPeepholeImpl(fAction)
            if fActionPlan.returnLeft {
                return generateExpression(leftExpr)
            }
            if fActionPlan.returnRight {
                return generateExpression(rightExpr)
            }
            if fActionPlan.shouldEmitAction {
                if fActionPlan.shouldCountFold {
                    g_constantsFolded = g_constantsFolded + 1
                }
                // Generate left/right operands as needed by the action
                var fgLeftReg = ""
                var fgRightReg = ""
                if fActionPlan.shouldGenerateRightReg {
                    fgRightReg = generateExpression(rightExpr)
                }
                if fActionPlan.shouldGenerateLeftReg {
                    fgLeftReg = generateExpression(leftExpr)
                }
                let fResult = emitPreparedFloatPeepholeBinaryActionImpl(this.output, getFeatureRegBoxImpl(), fAction, fgLeftReg, fgRightReg, expr.operator)
                if fResult != "" {
                    return fResult
                }
            }
        }
        ///
        FMA detection: a + (b * c) or (a * b) + c → llvm.fmuladd.f64
        NOTE: Int operands must be promoted to double via sitofp before use.
        ///
        let fmaSides = planBinaryFoldFmaImpl(expr.operator, leftType,
            rightType, leftExpr.kind, leftExpr.operator, rightExpr.kind,
            rightExpr.operator)
        if fmaSides.shouldTryCandidate {
            // Check if right operand is a float multiply
            if fmaSides.shouldTryRight {
                let rLeftType = inferExpressionType(rightExpr.operands[0])
                let rRightType = inferExpressionType(rightExpr.operands[1])
                if shouldUseFmaForOperandTypesImpl(rLeftType, rRightType) {
                    let fmaAReg = generateExpression(rightExpr.operands[0])
                    let fmaBReg = generateExpression(rightExpr.operands[1])
                    let fmaCReg = generateExpression(leftExpr)
                    return emitPreparedFmaTripleCallImpl(this.output, getFeatureRegBoxImpl(),
                        fmaAReg, rLeftType, fmaBReg, rRightType, fmaCReg,
                        leftType, "c + a*b")
                }
            }
            // Check if left operand is a float multiply
            if fmaSides.shouldTryLeft {
                let lLeftType = inferExpressionType(leftExpr.operands[0])
                let lRightType = inferExpressionType(leftExpr.operands[1])
                if shouldUseFmaForOperandTypesImpl(lLeftType, lRightType) {
                    let fmaAReg = generateExpression(leftExpr.operands[0])
                    let fmaBReg = generateExpression(leftExpr.operands[1])
                    let fmaCReg = generateExpression(rightExpr)
                    return emitPreparedFmaTripleCallImpl(this.output, getFeatureRegBoxImpl(),
                        fmaAReg, lLeftType, fmaBReg, lRightType, fmaCReg,
                        rightType, "a*b + c")
                }
            }
        }
        // --- End peephole optimizations ---

        // Short-circuit logical operators (must evaluate before eager left/right eval)
        let shortCircuitAction = shortCircuitBinaryActionImpl(expr.operator)
        if shortCircuitAction == 1 {
            return generateShortCircuitAnd(expr)
        }
        if shortCircuitAction == 2 {
            return generateShortCircuitOr(expr)
        }

        let leftReg = generateExpression(leftExpr)
        let rightReg = generateExpression(rightExpr)

        ///
        CSE within function scope: re-enabled for pure int/float binary ops.
        Cache is cleared at function entry and block boundaries (safe with dominance).
        ///
        let csePlan = planBinaryFoldCseImpl(leftType, rightType, expr.operator)
        if csePlan.shouldLookup {
            let cseCached = tryLookupPreparedBinaryCseImpl(leftReg,
                expr.operator, rightReg)
            if cseCached != "" {
                return cseCached
            }
        }

        ///
        Note: resultReg must be allocated AFTER any intermediate conversion registers
        to maintain SSA sequential numbering
        ///

        // --- Operator overloading dispatch ---
        let overloadedBinaryPlan = planOverloadedBinaryState(expr.operator,
            leftType, getGlobalFuncNamesImpl(), getGlobalFuncRetTypesImpl())
        if overloadedBinaryPlan.funcName != "" {
            return emitPreparedOverloadedBinaryCallImpl(this.output, getFeatureRegBoxImpl(),
                quoteIdentIfNeededImpl(overloadedBinaryPlan.funcName),
                overloadedBinaryPlan.retLlvmType, leftReg, rightReg)
        }
        // --- End operator overloading ---

        // Delegate to extracted binary op impl
        let coreBinaryResult = emitPreparedCoreBinaryOpState(this.output, getFeatureRegBoxImpl(),
            g_boundsCheckLabelCount, expr.operator, leftReg, rightReg,
            leftType, rightType, leftExpr.kind, leftExpr.literalValue,
            leftExpr.variableName, rightExpr.kind, rightExpr.literalValue,
            g_panicOnOverflow, g_inductionVarName)
        let resultReg = coreBinaryResult.resultReg
        g_boundsCheckLabelCount = coreBinaryResult.boundsCheckLabelCount
        if coreBinaryResult.shouldClearCse { cseClear() }

        // CSE recording for pure int/float binary ops (within function scope only)
        if csePlan.shouldRecord {
            recordPreparedBinaryCseImpl(leftReg, expr.operator, rightReg,
                resultReg)
        }

        return resultReg
    }

    // Helper: check if an expression produces i1 (bool) rather than i64
    fun generateShortCircuitAnd(expr: ParserExpressionNode) r: String {
        let leftExpr = expr.operands[0]
        let rightExpr = expr.operands[1]
        let leftType = inferExpressionType(leftExpr)
        let rightType = inferExpressionType(rightExpr)

        let labels = allocateShortCircuitBinaryLabelsImpl(getFeatureBlockBoxImpl())

        // Evaluate left side (may emit multiple blocks for nested and/or)
        let leftReg = generateExpression(leftExpr)

        // Bridge to known block for phi correctness
        emitShortCircuitCheckBridgeImpl(this.output, labels.checkLabel)
        cseClear()

        // Convert left to i1 if needed
        let leftBool = emitBoolCoercionImpl(this.output, getFeatureRegBoxImpl(), leftReg, leftType, leftExpr.operator)

        // If left is true, evaluate right; otherwise skip to merge with false
        emitShortCircuitAndDecisionImpl(this.output, leftBool,
            labels.rightLabel, labels.mergeLabel)

        // Right side block
        emitShortCircuitRightLabelImpl(this.output, labels.rightLabel)
        cseClear()
        let rightReg = generateExpression(rightExpr)

        // Bridge to known block after right evaluation
        emitShortCircuitDoneBridgeImpl(this.output, labels.doneLabel)
        cseClear()

        // Convert right to i1 if needed
        let rightBool = emitBoolCoercionImpl(this.output, getFeatureRegBoxImpl(), rightReg, rightType, rightExpr.operator)

        emitShortCircuitMergeJumpImpl(this.output, labels.mergeLabel)

        // Merge block with phi
        cseClear()
        return emitShortCircuitPhiImpl(this.output, getFeatureRegBoxImpl(), labels.mergeLabel,
            "false", labels.checkLabel, rightBool, labels.doneLabel)
    }

    ///
    Short-circuit OR: left ? true : right
    Uses bridge blocks so phi predecessors are always correct even with nested and/or
    Generate short-circuit evaluation for logical OR (||).
    If the left operand is true, skips evaluating the right operand.
    ///
    fun generateShortCircuitOr(expr: ParserExpressionNode) r: String {
        let leftExpr = expr.operands[0]
        let rightExpr = expr.operands[1]
        let leftType = inferExpressionType(leftExpr)
        let rightType = inferExpressionType(rightExpr)

        let labels = allocateShortCircuitBinaryLabelsImpl(getFeatureBlockBoxImpl())

        // Evaluate left side (may emit multiple blocks for nested and/or)
        let leftReg = generateExpression(leftExpr)

        // Bridge to known block for phi correctness
        emitShortCircuitCheckBridgeImpl(this.output, labels.checkLabel)
        cseClear()

        // Convert left to i1 if needed
        let leftBool = emitBoolCoercionImpl(this.output, getFeatureRegBoxImpl(), leftReg, leftType, leftExpr.operator)

        // If left is true, skip to merge with true; otherwise evaluate right
        emitShortCircuitOrDecisionImpl(this.output, leftBool,
            labels.rightLabel, labels.mergeLabel)

        // Right side block
        emitShortCircuitRightLabelImpl(this.output, labels.rightLabel)
        cseClear()
        let rightReg = generateExpression(rightExpr)

        // Bridge to known block after right evaluation
        emitShortCircuitDoneBridgeImpl(this.output, labels.doneLabel)
        cseClear()

        // Convert right to i1 if needed
        let rightBool = emitBoolCoercionImpl(this.output, getFeatureRegBoxImpl(), rightReg, rightType, rightExpr.operator)

        emitShortCircuitMergeJumpImpl(this.output, labels.mergeLabel)

        // Merge block with phi
        cseClear()
        return emitShortCircuitPhiImpl(this.output, getFeatureRegBoxImpl(), labels.mergeLabel,
            "true", labels.checkLabel, rightBool, labels.doneLabel)
    }

    fun tryGenerateMetaBuiltinCall(expr: ParserExpressionNode, funcName: String) r: String {
        let metaPlan = planMetaBuiltinCallImpl(funcName,
            expr.arguments.length())
        if metaPlan.action == 1 {
            if metaPlan.hasArg0 {
                // Try comptime evaluator first (handles bare type names like Int32)
                let ctSize = evaluateConstExprState(expr)
                if ctSize > 0 {
                    return ctSize.toString()
                }
                let sizeTypeName = inferExpressionType(expr.arguments[0])
                return resolveSizeofBuiltinValueImpl(mapTypeState(sizeTypeName),
                    getGlobalStructNamesImpl(), getGlobalStructLayoutsImpl(), getGlobalStructSizesImpl())
            }
            return "0"
        }

        if metaPlan.action == 2 {
            if metaPlan.hasArg0 {
                let alignTypeName = inferExpressionType(expr.arguments[0])
                return resolveAlignofBuiltinValueImpl(mapTypeState(alignTypeName),
                    getGlobalStructNamesImpl(), getGlobalStructLayoutsImpl(), getGlobalStructSizesImpl())
            }
            return "0"
        }

        if metaPlan.action == 3 {
            if metaPlan.hasArg0 and metaPlan.hasArg1 {
                let offTypeName = inferExpressionType(expr.arguments[0])
                let offFieldName = inferExpressionType(expr.arguments[1])
                return resolveOffsetofBuiltinValueImpl(offTypeName,
                    offFieldName, getGlobalStructNamesImpl(), getGlobalStructFieldNamesImpl(),
                    getGlobalStructFieldTypesImpl(), getGlobalStructLayoutsImpl(), getGlobalStructSizesImpl())
            }
            return "0"
        }

        if metaPlan.action == 4 {
            if g_insideUnsafe == 0 {
                this.output.append("  ; ERROR: transmute requires unsafe block\n")
                return "0"
            }
            if metaPlan.hasArg0 {
                let tmSrcReg = generateExpression(expr.arguments[0])
                let tmSrcType = inferExpressionType(expr.arguments[0])
                return emitTransmuteImpl(this.output, getFeatureRegBoxImpl(), tmSrcReg,
                    mapTypeState(tmSrcType), mapTypeState(metaPlan.targetTypeName))
            }
            return "0"
        }

        if metaPlan.action == 5 {
            if metaPlan.hasArg0 {
                let inclPath = expr.arguments[0].literalValue
                let inclInfo = loadEmbeddedStringConstantInfoImpl(
                    this.stringConstants, inclPath)
                if inclInfo.length() >= 3 {
                    return emitIncludeStrImpl(this.output, getFeatureRegBoxImpl(), inclInfo[0],
                        inclInfo[1], getStringConstantPrefixWithGlobalStateImpl(),
                        parseIntManual(inclInfo[2]))
                }
                this.output.append("  ; WARNING: includeStr file not found: " + inclPath + "\n")
            }
            let inclEmptyReg = getNextRegFn(getFeatureRegBoxImpl())
            this.output.append("  " + inclEmptyReg + " = insertvalue %SeenString undef, i64 0, 0\n")
            return inclEmptyReg
        }

        if metaPlan.action == 6 {
            if metaPlan.hasArg0 {
                let inclBPath = expr.arguments[0].literalValue
                let inclBInfo = loadEmbeddedStringConstantInfoImpl(
                    this.stringConstants, inclBPath)
                if inclBInfo.length() >= 3 {
                    return emitIncludeBytesImpl(this.output, getFeatureRegBoxImpl(),
                        inclBInfo[0], inclBInfo[1],
                        getStringConstantPrefixWithGlobalStateImpl(),
                        parseIntManual(inclBInfo[2]))
                }
            }
            return "0"
        }

        return ""
    }

    fun tryGenerateLowLevelBuiltinCall(expr: ParserExpressionNode, funcName: String) r: String {
        var lowIsVariantCall = false
        var lowVariantFieldCount = 0
        if g_enumVariantCount > 0 {
            lowIsVariantCall = isEnumVariantStateImpl(funcName,
                g_enumVariantNames, g_enumVariantCount)
            if lowIsVariantCall {
                lowVariantFieldCount = lookupEnumFieldCountStateImpl(funcName,
                    g_enumVariantNames, g_enumVariantFieldCounts,
                    g_enumVariantCount)
            }
        }
        let lowPlan = planLowLevelBuiltinCallImpl(funcName,
            expr.arguments.length(), isPtrBuiltinCallImpl(funcName),
            isSimdBuiltinCallImpl(funcName, isSimdVectorTypeImpl(funcName)),
            this.varNames, getBoundedActiveVarCountWithGlobalStateImpl(this.varNames), g_enumVariantCount, lowIsVariantCall,
            lowVariantFieldCount)
        let lowArgPlan = planLowLevelBuiltinArgumentReadsImpl(lowPlan.action,
            lowPlan.hasArg0, lowPlan.hasArg1, lowPlan.hasArg2)

        var lowArg0 = lowArgPlan.defaultArg0
        var lowArg1 = ""
        var lowArg2 = ""
        if lowArgPlan.shouldReadArg0 {
            lowArg0 = generateExpression(expr.arguments[0])
        }
        if lowArgPlan.shouldReadArg1 {
            lowArg1 = generateExpression(expr.arguments[1])
        }
        if lowArgPlan.shouldReadArg2 {
            lowArg2 = generateExpression(expr.arguments[2])
        }

        if lowPlan.action >= 1 and lowPlan.action <= 9 {
            var boundsCountBox = Array<Int>()
            boundsCountBox.push(g_boundsCheckLabelCount)
            let lowResult = emitPreparedLowLevelBuiltinActionImpl(this.output,
                getFeatureRegBoxImpl(), lowPlan.action, funcName, g_insideUnsafe,
                g_boundsCheckEnabled, lowArg0, lowArg1, lowArg2, "", "",
                Array<Int>(), Array<String>(), Array<String>(), Array<Int>(),
                "", Array<String>(), boundsCountBox)
            g_boundsCheckLabelCount = boundsCountBox[0]
            if shouldClearLowLevelDebugAssertCseImpl(lowPlan.action,
                g_boundsCheckEnabled,
                lowArg0) {
                cseClear()
            }
            return lowResult
        }

        if lowPlan.action == 10 {
            if lowArgPlan.shouldUseAsyncYieldState {
                var yieldCounterBox = Array<Int>()
                let functionEmission = getCurrentFunctionEmissionStateImpl()
                yieldCounterBox.push(functionEmission.yieldCounter)
                let yieldResult = emitPreparedLowLevelBuiltinActionImpl(this.output,
                    getFeatureRegBoxImpl(), lowPlan.action, funcName, g_insideUnsafe,
                    g_boundsCheckEnabled, lowArg0, lowArg1, lowArg2,
                    functionEmission.asyncCoroHdl,
                    functionEmission.asyncCleanupLabel, yieldCounterBox,
                    Array<String>(), Array<String>(), Array<Int>(), "",
                    Array<String>(), Array<Int>())
                functionEmission.yieldCounter = yieldCounterBox[0]
                return yieldResult
            }
            return "0"
        }

        if lowArgPlan.shouldPrepareSimdArgs {
            var simdArgs = Array<String>()
            var simdArgTypes = Array<String>()
            var simdConstIndices = Array<Int>()
            var simdPreArgIdx = 0
            while simdPreArgIdx < expr.arguments.length() {
                if shouldReadSimdShuffleConstArgImpl(funcName,
                    simdPreArgIdx) {
                    let shufConstIdx = evaluateConstExprState(expr.arguments[simdPreArgIdx])
                    simdConstIndices.push(shufConstIdx)
                } else {
                    let simdArgReg = generateExpression(expr.arguments[simdPreArgIdx])
                    simdArgs.push(simdArgReg)
                    let simdArgType = inferExpressionType(expr.arguments[simdPreArgIdx])
                    simdArgTypes.push(simdArgType)
                }
                simdPreArgIdx = simdPreArgIdx + 1
            }
            let simdResult = emitPreparedLowLevelBuiltinActionImpl(this.output,
                getFeatureRegBoxImpl(), lowPlan.action, funcName, g_insideUnsafe,
                g_boundsCheckEnabled, lowArg0, lowArg1, lowArg2, "", "",
                Array<Int>(), simdArgs, simdArgTypes, simdConstIndices, "",
                Array<String>(), Array<Int>())
            if simdResult != "" {
                return simdResult
            }
        }

        if lowArgPlan.shouldPrepareIndirectArgs {
            var icArgRegs = Array<String>()
            var icArgIdx = 0
            while icArgIdx < expr.arguments.length() {
                let icArgReg = generateExpression(expr.arguments[icArgIdx])
                icArgRegs.push(icArgReg)
                icArgIdx = icArgIdx + 1
            }
            return emitPreparedLowLevelBuiltinActionImpl(this.output, getFeatureRegBoxImpl(),
                lowPlan.action, funcName, g_insideUnsafe, g_boundsCheckEnabled,
                lowArg0, lowArg1, lowArg2, "", "", Array<Int>(),
                Array<String>(), Array<String>(), Array<Int>(),
                this.varRegs[lowPlan.indirectVarIndex], icArgRegs, Array<Int>())
        }

        if lowArgPlan.shouldGenerateEnumConstructor {
            return generateEnumConstructor(funcName, expr)
        }

        return ""
    }

    fun tryGenerateArrayConstructorCall(expr: ParserExpressionNode, funcName: String) r: String {
        var fillKind = ""
        var fillLiteralValue = ""
        if expr.arguments.length() > 1 {
            fillKind = expr.arguments[1].kind
            fillLiteralValue = expr.arguments[1].literalValue
        }
        let isArrayCtor = isArrayConstructorNameImpl(funcName)
        var elementType = ""
        if isArrayCtor {
            elementType = resolveArrayConstructorElementTypeImpl(funcName)
        }
        let arrayCtorPlan = planArrayConstructorCallImpl(
            isArrayCtor, expr.arguments.length(), elementType, fillKind,
            fillLiteralValue)
        if not arrayCtorPlan.isValid {
            return ""
        }

        if arrayCtorPlan.mode == 1 {
            let countReg = generateExpression(expr.arguments[0])
            let valueReg = generateExpression(expr.arguments[1])
            return emitArrayBulkInitImpl(this.output, getFeatureRegBoxImpl(), getFeatureBlockBoxImpl(), countReg, valueReg,
                arrayCtorPlan.elementType, arrayCtorPlan.isZeroFill,
                currentFunctionAlignToImpl(getCurrentFunctionOptions()))
        }

        if arrayCtorPlan.mode == 2 {
            let capReg = generateExpression(expr.arguments[0])
            let elemSz = resolveArrayConstructorElementSizeImpl(funcName,
                arrayCtorPlan.elementType, getGlobalStructNamesImpl(), getGlobalStructSizesImpl())
            return emitArrayPreallocImpl(this.output, getFeatureRegBoxImpl(), capReg, elemSz)
        }

        let elemSize = resolveArrayConstructorElementSizeImpl(funcName,
            arrayCtorPlan.elementType, getGlobalStructNamesImpl(), getGlobalStructSizesImpl())
        return emitArrayInlineImpl(this.output, getFeatureRegBoxImpl(), elemSize,
            currentFunctionAlignToImpl(getCurrentFunctionOptions()))
    }

    fun tryGenerateSmallVecConstructorCall(expr: ParserExpressionNode, funcName: String) r: String {
        if not shouldEmitSmallVecConstructorImpl(
            isSmallVecConstructorNameImpl(funcName)) {
            return ""
        }
        var svCapArgReg = ""
        if shouldReadFirstConstructorArgImpl(expr.arguments.length()) {
            svCapArgReg = generateExpression(expr.arguments[0])
        }
        return emitSmallVecConstructorImpl(this.output, getFeatureRegBoxImpl(), funcName, svCapArgReg)
    }

    fun tryGenerateCollectionConstructorCall(expr: ParserExpressionNode, funcName: String) r: String {
        if not shouldEmitCollectionConstructorImpl(
            isCollectionConstructorNameImpl(funcName)) {
            return ""
        }
        var colCapArg = ""
        if shouldReadFirstConstructorArgImpl(expr.arguments.length()) {
            colCapArg = generateExpression(expr.arguments[0])
        }
        return emitCollectionConstructorImpl(this.output, getFeatureRegBoxImpl(), funcName, colCapArg, expr.arguments.length())
    }

    fun tryGenerateReprCClassConstructorCall(expr: ParserExpressionNode, funcName: String, structIdx: Int) r: String {
        if not isReprCConstructorType(funcName) {
            return ""
        }
        if shouldEmitReprCZeroInitializerImpl(expr.arguments.length(),
            structIdx) {
            return "zeroinitializer"
        }

        var reprCArgRegs = Array<String>()
        var reprCFieldTypes = Array<String>()
        let fieldTypesStr = getGlobalStructFieldTypesImpl()[structIdx]
        let argCount = expr.arguments.length()
        var reprCArgIdx = 0
        var typePos = 0
        while reprCArgIdx < argCount {
            let reprCArgExpr = expr.arguments[reprCArgIdx]
            let reprCRawArgReg = generateExpression(reprCArgExpr)
            let reprCFieldPlan = planNextConstructorFieldTypeImpl(
                fieldTypesStr, typePos)
            let reprCFieldLlvmType = mapTypeState(reprCFieldPlan.fieldSeenType)
            let reprCArgSeenType = inferExpressionType(reprCArgExpr)
            reprCArgRegs.push(coerceValueForLlvmTarget(reprCFieldLlvmType,
                reprCArgSeenType, reprCRawArgReg))
            reprCFieldTypes.push(reprCFieldLlvmType)
            reprCArgIdx = reprCArgIdx + 1
            typePos = reprCFieldPlan.nextTypePos
        }
        return emitPreparedReprCConstructorImpl(this.output, getFeatureRegBoxImpl(), funcName,
            reprCArgRegs, reprCFieldTypes)
    }

    fun emitClassConstructorArgumentStores(expr: ParserExpressionNode, ptrReg: String, structIdx: Int) r: Void {
        if structIdx < 0 or expr.arguments.length() == 0 {
            return
        }

        let ctorFieldTypesStr = getGlobalStructFieldTypesImpl()[structIdx]
        var ctorByteOffset = 0
        var ctorTypePos = 0
        var ctorArgIdx = 0
        while ctorArgIdx < expr.arguments.length() and ctorTypePos < ctorFieldTypesStr.length() {
            let ctorTypePlan = planNextConstructorFieldTypeImpl(
                ctorFieldTypesStr, ctorTypePos)
            let ctorArgExpr = expr.arguments[ctorArgIdx]
            let ctorArgReg = generateExpression(ctorArgExpr)
            let ctorFieldPtrReg = getNextRegFn(getFeatureRegBoxImpl())
            let ctorFieldOffset = resolveClassConstructorFieldOffsetImpl(
                structIdx, ctorArgIdx, ctorByteOffset, getGlobalStructNamesImpl(),
                getGlobalStructLayoutsImpl(), getGlobalStructSizesImpl())
            let ctorFieldByteSize = getTypeSizeReg(
                ctorTypePlan.fieldSeenType, getGlobalStructNamesImpl(), getGlobalStructSizesImpl())
            let ctorStorePlan = planConstructorFieldStoreImpl(
                ctorTypePlan.fieldSeenType, ctorTypePlan.nextTypePos,
                ctorByteOffset, ctorFieldOffset, ctorFieldByteSize)
            let ctorIsDataField = isDataTypeState(ctorStorePlan.fieldSeenType)
            var ctorStoreLlvmType = mapTypeState(ctorStorePlan.fieldSeenType)
            var ctorMemcpySize = 0
            if ctorIsDataField {
                ctorStoreLlvmType = "%" + ctorStorePlan.fieldSeenType
                if ctorArgExpr.kind == "StructLiteral" {
                    ctorMemcpySize = getDataTypeSizeState(ctorStorePlan.fieldSeenType)
                }
            }
            var ctorStoreReg = ctorArgReg
            if not (ctorIsDataField and ctorArgExpr.kind == "StructLiteral") {
                let ctorArgSeenType = inferExpressionType(ctorArgExpr)
                ctorStoreReg = coerceValueForLlvmTarget(ctorStoreLlvmType,
                    ctorArgSeenType, ctorArgReg)
            }
            emitPreparedClassConstructorFieldStoreImpl(this.output, ctorFieldPtrReg,
                ptrReg, ctorStorePlan.fieldOffset, ctorStoreLlvmType,
                ctorStoreReg,
                ctorArgExpr.kind == "StructLiteral", ctorIsDataField,
                ctorMemcpySize)
            ctorByteOffset = ctorStorePlan.nextByteOffset
            ctorArgIdx = ctorArgIdx + 1
            ctorTypePos = ctorStorePlan.nextTypePos
        }
    }

    fun tryGenerateHeapClassConstructorCall(expr: ParserExpressionNode, funcName: String, structIdx: Int) r: String {
        if not shouldEmitHeapClassConstructorImpl(isClassTypeState(funcName)) {
            return ""
        }

        let ptrReg = emitClassHeapAllocationImpl(this.output, getFeatureRegBoxImpl(), structIdx,
            getGlobalStructNamesImpl(), getGlobalStructSizesImpl(), getGlobalStructLayoutsImpl())
        emitClassArrayFieldInitializersImpl(this.output, getFeatureRegBoxImpl(), ptrReg,
            structIdx, getGlobalStructNamesImpl(), getGlobalStructSizesImpl(), getGlobalStructLayoutsImpl(),
            getGlobalStructFieldNamesImpl(), getGlobalStructFieldTypesImpl())
        emitClassConstructorArgumentStores(expr, ptrReg, structIdx)
        let intReg = getNextRegFn(getFeatureRegBoxImpl())
        this.output.append("  " + intReg + " = ptrtoint ptr " + ptrReg + " to i64\n")
        return intReg
    }

    fun tryGenerateClassConstructorCall(expr: ParserExpressionNode, funcName: String) r: String {
        if not isClassTypeState(funcName) {
            return ""
        }

        let structIdx = findStructReg(funcName, getGlobalStructNamesImpl())
        let reprCResult = tryGenerateReprCClassConstructorCall(expr, funcName, structIdx)
        if reprCResult != "" {
            return reprCResult
        }
        return tryGenerateHeapClassConstructorCall(expr, funcName, structIdx)
    }

    fun tryGenerateConstructorLikeCall(expr: ParserExpressionNode, funcName: String) r: String {
        let arrayCtorResult = tryGenerateArrayConstructorCall(expr, funcName)
        if arrayCtorResult != "" {
            return arrayCtorResult
        }

        let smallVecCtorResult = tryGenerateSmallVecConstructorCall(expr, funcName)
        if smallVecCtorResult != "" {
            return smallVecCtorResult
        }

        let collectionCtorResult = tryGenerateCollectionConstructorCall(expr, funcName)
        if collectionCtorResult != "" {
            return collectionCtorResult
        }

        return tryGenerateClassConstructorCall(expr, funcName)
    }

    fun tryGenerateOptionRuntimeBuiltinCall(expr: ParserExpressionNode, funcName: String) r: String {
        if not isOptionRuntimeCallPlanImpl(funcName) {
            return ""
        }
        var argReg = "0"
        var argType = "Int"
        if shouldReadSomeRuntimeArgImpl(funcName, expr.arguments.length()) {
            argReg = generateExpression(expr.arguments[0])
            argType = inferExpressionType(expr.arguments[0])
        }
        var isClassArg = 0
        if isClassTypeState(argType) { isClassArg = 1 }
        return emitOptionRuntimeBuiltinCallImpl(this.output, getFeatureRegBoxImpl(), funcName,
            argReg, argType, isClassArg)
    }

    fun tryGenerateSuperRuntimeBuiltinCall(funcName: String) r: String {
        if isSuperRuntimeCallPlanImpl(funcName) {
            if g_currentClassParentName != "" {
                let thisIdx = findActiveVariableIndexImpl(this.varNames, getBoundedActiveVarCountWithGlobalStateImpl(this.varNames), "this")
                if thisIdx >= 0 {
                    return emitSuperRuntimeBuiltinCallImpl(this.output, getFeatureRegBoxImpl(),
                        quoteIdentIfNeededImpl(g_currentClassParentName + "_init"),
                        this.varRegs[thisIdx])
                }
            }
            return "0"
        }
        return ""
    }

    fun tryGenerateEmptyRuntimeBuiltinCall(expr: ParserExpressionNode, funcName: String) r: String {
        if isEmptyRuntimeCalleeImpl(funcName) {
            var i = 0
            while i < expr.arguments.length() {
                generateExpression(expr.arguments[i])
                i = i + 1
            }
            return "0"
        }
        return ""
    }

    fun tryGeneratePrintRuntimeBuiltinCall(expr: ParserExpressionNode, funcName: String) r: String {
        if not isPrintRuntimeCallPlanImpl(funcName) {
            return ""
        }
        if shouldReadPrintRuntimeArgImpl(funcName, expr.arguments.length()) {
            let argType = inferExpressionType(expr.arguments[0])
            let argReg = generateExpression(expr.arguments[0])
            return emitPrintLikeCallImpl(this.output, getFeatureRegBoxImpl(), funcName, argReg,
                argType)
        }
        return "0"
    }

    fun tryGenerateIoRuntimeBuiltinCall(expr: ParserExpressionNode, funcName: String) r: String {

        let ioAction = runtimeIoCallActionImpl(funcName, expr.arguments.length())
        if ioAction == 0 {
            return ""
        }

        if ioAction == 1 {
            let argReg = generateExpression(expr.arguments[0])
            return emitReadTextRuntimeCallImpl(this.output, getFeatureRegBoxImpl(), argReg)
        }

        if ioAction == 2 {
            let pathReg = generateExpression(expr.arguments[0])
            let contentReg = generateExpression(expr.arguments[1])
            return emitWriteTextRuntimeCallImpl(this.output, getFeatureRegBoxImpl(), pathReg, contentReg)
        }

        if ioAction == 3 {
            return emitArgsRuntimeCallImpl(this.output, getFeatureRegBoxImpl())
        }

        if ioAction == 5 {
            let pathReg = generateExpression(expr.arguments[0])
            return emitReadFileBytesPathRuntimeCallImpl(this.output, getFeatureRegBoxImpl(),
                pathReg)
        }
        return "0"
    }

    fun tryGeneratePanicRuntimeBuiltinCall(expr: ParserExpressionNode, funcName: String) r: String {
        if not isPanicRuntimeCallPlanImpl(funcName) {
            return ""
        }
        if shouldReadPanicRuntimeArgImpl(funcName, expr.arguments.length()) {
            let argReg = generateExpression(expr.arguments[0])
            return emitPanicRuntimeCallImpl(this.output, getFeatureRegBoxImpl(), argReg)
        }
        return "0"
    }

    fun tryGenerateRuntimeBuiltinCall(expr: ParserExpressionNode, funcName: String) r: String {
        let runtimePlan = planRuntimeBuiltinDispatchImpl(funcName,
            expr.arguments.length())
        if runtimePlan.shouldTryOption {
            let optionResult = tryGenerateOptionRuntimeBuiltinCall(expr,
                funcName)
            if optionResult != "" {
                return optionResult
            }
        }

        if runtimePlan.shouldTrySuper {
            let superResult = tryGenerateSuperRuntimeBuiltinCall(funcName)
            if superResult != "" {
                return superResult
            }
        }

        if runtimePlan.shouldTryEmpty {
            let emptyCallResult = tryGenerateEmptyRuntimeBuiltinCall(expr,
                funcName)
            if emptyCallResult != "" {
                return emptyCallResult
            }
        }

        if runtimePlan.shouldTryPrint {
            let printResult = tryGeneratePrintRuntimeBuiltinCall(expr,
                funcName)
            if printResult != "" {
                return printResult
            }
        }

        if runtimePlan.shouldTryIo {
            let ioResult = tryGenerateIoRuntimeBuiltinCall(expr, funcName)
            if ioResult != "" {
                return ioResult
            }
        }

        if runtimePlan.shouldTryPanic {
            return tryGeneratePanicRuntimeBuiltinCall(expr, funcName)
        }
        return ""
    }

    fun tryGenerateImplicitThisCall(expr: ParserExpressionNode, funcName: String) r: String {
        let thisIdx = findActiveVariableIndexImpl(this.varNames, getBoundedActiveVarCountWithGlobalStateImpl(this.varNames), "this")
        if thisIdx < 0 {
            return ""
        }

        let thisType = this.varTypes[thisIdx]
        let misplacedRetType = resolveRealParserMisplacedMethodReturnTypeImpl(funcName)
        let misplacedPlan = planImplicitThisCallImpl(thisIdx, thisType,
            misplacedRetType, "", false, expr.arguments.length())
        if misplacedPlan.shouldUseMisplacedRealParserMethod {
            let thisReg = this.varRegs[thisIdx]
            let methodFuncName = thisType + "_" + funcName
            prepareCallArgumentsWithDefaults(methodFuncName, expr.arguments,
                false, false, false, "")
            let argRegs = getDefaultFillArgRegsImpl()
            let argTypeStrs = getDefaultFillArgTypeStrsImpl()

            let mpTailCall = implicitThisTailCallFlagImpl(
                takeTailCallPositionImpl(getCurrentFunctionOptions()))
            return emitPreparedMisplacedParserImplicitThisCallImpl(this.output,
                getFeatureRegBoxImpl(), quoteIdentIfNeededImpl(methodFuncName),
                misplacedRetType, thisReg, argRegs, argTypeStrs, mpTailCall)
        }

        let methodRetType = getMethodReturnTypeState(thisType, funcName)
        if methodRetType == "" {
            return ""
        }
        let implicitThisPlan = planImplicitThisCallImpl(thisIdx, thisType,
            misplacedRetType, methodRetType,
            isStringBuilderRuntimeMethodImpl(funcName), expr.arguments.length())

        let thisReg = this.varRegs[thisIdx]
        let methodFuncName = thisType + "_" + funcName
        prepareCallArgumentsWithDefaults(methodFuncName, expr.arguments, false,
            true, false, "")
        let argRegs = getDefaultFillArgRegsImpl()
        let argTypeStrs = getDefaultFillArgTypeStrsImpl()

        if implicitThisPlan.shouldUseStringBuilderRuntimeMethod {
            var sbArg0 = ""
            if implicitThisPlan.hasArg0 {
                sbArg0 = argRegs[0]
            }
            return emitPreparedStringBuilderImplicitThisCallImpl(this.output,
                getFeatureRegBoxImpl(), funcName, thisReg, sbArg0)
        }

        if not implicitThisPlan.shouldUseNormalImplicitThisMethod {
            return ""
        }

        let llvmReturnType = mapTypeState(methodRetType)

        let selfTailCall = implicitThisTailCallFlagImpl(
            takeTailCallPositionImpl(getCurrentFunctionOptions()))
        return emitPreparedNormalImplicitThisCallImpl(this.output, getFeatureRegBoxImpl(),
            quoteIdentIfNeededImpl(methodFuncName), llvmReturnType, thisReg,
            argRegs, argTypeStrs, selfTailCall)
    }

    fun tryGenerateMathBuiltinCall(expr: ParserExpressionNode, funcName: String) r: String {
        let runtimePlan = planRuntimeBuiltinDispatchImpl(funcName,
            expr.arguments.length())
        if not runtimePlan.shouldTryMath {
            return ""
        }
        var mArg0 = ""
        var mArg1 = ""
        if runtimePlan.shouldReadMathArg0 {
            mArg0 = generateExpression(expr.arguments[0])
        }
        if runtimePlan.shouldReadMathArg1 {
            mArg1 = generateExpression(expr.arguments[1])
        }
        let mResult = emitMathBuiltinCallImpl(this.output, getFeatureRegBoxImpl(), funcName,
            mArg0, mArg1)
        if mResult != "" { return mResult }
        return ""
    }

    ///
    Generate IR for a function call expression. Handles a wide variety of
    call types in priority order:
      1. Comptime parameter specialization (evaluate compile-time args)
      2. Builtins: sizeof/alignof/offsetof (compile-time constants)
      3. Print/println (variadic, type-dispatched formatting)
      4. Type constructors: Array/Vec/HashMap/BTreeMap/LinkedList/Option/etc.
      5. Enum variant constructors (checked via isEnumVariant)
      6. Closure/indirect calls (this.varNames match before enum/array check)
      7. Class constructors (malloc + memset + field init)
      8. Async function calls (return coroutine handle ptr)
      9. Regular function calls with ABI-correct parameter passing
    Data types are passed as pointers (ptr) for ABI compatibility.
    Collection constructors (HashMap_new_str_int, etc.) dispatch to
    type-specialized runtime functions.
    ///
    fun generateCall(expr: ParserExpressionNode) r: String {
        var funcName = expr.callee

        applyComptimeParamSpecializationState(this.output,
            g_comptimeParamCount, g_comptimeParamFuncNames, funcName, expr)

        let metaBuiltinResult = tryGenerateMetaBuiltinCall(expr, funcName)
        if metaBuiltinResult != "" {
            return metaBuiltinResult
        }

        let lowLevelBuiltinResult = tryGenerateLowLevelBuiltinCall(expr, funcName)
        if lowLevelBuiltinResult != "" {
            return lowLevelBuiltinResult
        }

        let constructorResult = tryGenerateConstructorLikeCall(expr, funcName)
        if constructorResult != "" {
            return constructorResult
        }

        funcName = stripGenericCalleeNameImpl(funcName)

        let runtimeBuiltinResult = tryGenerateRuntimeBuiltinCall(expr, funcName)
        if runtimeBuiltinResult != "" {
            return runtimeBuiltinResult
        }

        let implicitThisResult = tryGenerateImplicitThisCall(expr, funcName)
        if implicitThisResult != "" {
            return implicitThisResult
        }

        let mathBuiltinResult = tryGenerateMathBuiltinCall(expr, funcName)
        if mathBuiltinResult != "" {
            return mathBuiltinResult
        }

        prepareCallArgumentsWithDefaults(funcName, expr.arguments, true, false,
            true, "fn call")
        var argRegs = getDefaultFillArgRegsImpl()
        var argTypeStrs = getDefaultFillArgTypeStrsImpl()

        promoteRegularCallFloatArgsIfNeededState(this.output, getFeatureRegBoxImpl(), funcName,
            argRegs, argTypeStrs, g_floatParamFuncNames,
            g_floatParamParamIdxs)

        let returnType = inferExpressionType(expr)
        let llvmReturnType = resolveRegularCallLlvmReturnTypeImpl(
            mapTypeState(returnType), isAsyncFunctionStateImpl(funcName,
            g_asyncFuncNames, g_asyncFuncCount))

        let lateState = captureLateUserDeclareState()
        if recordRegularLateDeclareIfNeededState(funcName, llvmReturnType,
            argTypeStrs, lateState) {

            applyLateUserDeclareState(lateState)
        }
        return emitPreparedRegularFunctionCallState(this.output, getFeatureRegBoxImpl(),
            funcName, llvmReturnType, argRegs, argTypeStrs,
            takeTailCallPositionImpl(getCurrentFunctionOptions()))
    }

    fun tryGenerateResolvedReceiverFastPathMethodCall(expr: ParserExpressionNode,
        methodName: String, receiverReg: String, receiverType: String) r: String {

        let fastPathPlan = planResolvedReceiverFastPathImpl(receiverReg,
            isOptionReceiverTypeImpl(receiverType),
            isSmallVecReceiverTypeImpl(receiverType),
            isCollectionReceiverTypeImpl(receiverType),
            isArrayReceiverTypeImpl(receiverType))

        var optDefaultRegS = "0"
        var svArgReg = ""
        var collArg0s = "0"
        var collArg1s = "0"
        var arrArg0 = ""
        var arrArg1 = ""
        var arrArg0Type = ""
        var arrArg1Type = ""

        if shouldReadOptionDefaultFastPathArgImpl(fastPathPlan.action,
            methodName, expr.arguments.length()) {
            optDefaultRegS = generateExpression(expr.arguments[0])
        }
        if shouldReadSmallVecFastPathArgImpl(fastPathPlan.action,
            methodName, expr.arguments.length()) {
            svArgReg = generateExpression(expr.arguments[0])
        }
        if fastPathPlan.action == 3 and
            shouldReadReceiverFastPathArgImpl(fastPathPlan.action,
            expr.arguments.length(), 0) {
            collArg0s = generateExpression(expr.arguments[0])
        }
        if fastPathPlan.action == 3 and
            shouldReadReceiverFastPathArgImpl(fastPathPlan.action,
            expr.arguments.length(), 1) {
            collArg1s = generateExpression(expr.arguments[1])
        }
        if fastPathPlan.action == 4 and
            shouldReadReceiverFastPathArgImpl(fastPathPlan.action,
            expr.arguments.length(), 0) {
            arrArg0 = generateExpression(expr.arguments[0])
            arrArg0Type = inferExpressionType(expr.arguments[0])
        }
        if fastPathPlan.action == 4 and
            shouldReadReceiverFastPathArgImpl(fastPathPlan.action,
            expr.arguments.length(), 1) {
            arrArg1 = generateExpression(expr.arguments[1])
            arrArg1Type = inferExpressionType(expr.arguments[1])
        }

        return emitResolvedReceiverFastPathActionImpl(this.output, getFeatureRegBoxImpl(),
            g_blockLabelBox, fastPathPlan.action, methodName, receiverReg,
            receiverType, optDefaultRegS, svArgReg, collArg0s, collArg1s,
            arrArg0, arrArg1, arrArg0Type, arrArg1Type)
    }

    fun tryGenerateStaticMethodCall(expr: ParserExpressionNode, methodName: String,
        receiverReg: String) r: String {

        if not shouldTryStaticMethodCallImpl(receiverReg, expr.literalValue) {
            return ""
        }

        let classNames = splitPipe(resolveStaticMethodClassNamesImpl(expr.literalValue))
        let potentialClassName = classNames[0]
        let fullClassName = classNames[1]
        if not isStaticMethodReceiverReferenceImpl(findActiveVariableIndexImpl(this.varNames, getBoundedActiveVarCountWithGlobalStateImpl(this.varNames), expr.literalValue),
            findActiveVariableIndexImpl(this.varNames, getBoundedActiveVarCountWithGlobalStateImpl(this.varNames), potentialClassName)) {
            return ""
        }

        let isUppercase = isPascalStaticReceiverNameImpl(potentialClassName)
        if shouldTryNoArgStaticFactoryImpl(isUppercase, methodName) {
            let staticFactoryResult: String = tryGenerateStaticFactoryMethodCallImpl(
                this.output, getFeatureRegBoxImpl(), methodName, potentialClassName,
                fullClassName, "", 0)
            if staticFactoryResult != "" {
                return staticFactoryResult
            }
        }
        if shouldTryArgStaticFactoryImpl(isUppercase,
            expr.arguments.length()) {
            if needsStaticFactoryArgumentImpl(methodName,
                potentialClassName) {
                let staticFactoryArg0 = generateExpression(expr.arguments[0])
                let staticFactoryResult: String = tryGenerateStaticFactoryMethodCallImpl(
                    this.output, getFeatureRegBoxImpl(), methodName, potentialClassName,
                    fullClassName, staticFactoryArg0,
                    expr.arguments.length())
                if staticFactoryResult != "" {
                    return staticFactoryResult
                }
            }
        }

        let staticClassName = resolveStaticCallClassNameImpl(
            expr.literalValue, potentialClassName, isUppercase)
        let funcName = staticMethodFunctionNameImpl(staticClassName,
            methodName)

        let enableFloatPromotion =
            shouldPromoteStaticMethodFloatArgsImpl(isUppercase)
        prepareCallArgumentsWithDefaults(funcName, expr.arguments, false,
            enableFloatPromotion, false, "")
        let argRegs = getDefaultFillArgRegsImpl()
        let argTypeStrs = getDefaultFillArgTypeStrsImpl()

        let registeredStaticReturnType =
            getMethodReturnTypeState(staticClassName, methodName)
        var inferredStaticReturnType = ""
        if registeredStaticReturnType == "" or
            registeredStaticReturnType == "Unknown" {

            inferredStaticReturnType = tryInferStaticMethodCallTypeState(expr,
                this.varNames, this.varTypes)
        }
        let staticLateState = captureLateUserDeclareState()
        let staticResult = emitPreparedStaticMethodDispatchState(
            this.output, getFeatureRegBoxImpl(), methodName, potentialClassName,
            staticClassName, funcName, registeredStaticReturnType,
            inferredStaticReturnType, argRegs, argTypeStrs, staticLateState)
        applyLateUserDeclareState(staticLateState)
        return staticResult
    }

    fun tryResolveArrayMutatorPointerFromLiteral(varName: String) r: String {
        if varName == "" {
            return ""
        }

        if isDottedArrayMutatorLiteralImpl(varName) {
            let fieldName = extractLastMemberFieldSegmentImpl(varName)
            let receiverName = varName.substring(0,
                varName.length() - fieldName.length() - 1)

            if shouldResolveChainedArrayMutatorReceiverImpl(receiverName) {
                let chainedArrayPtr = tryGenerateChainedReceiverMemberAccess(
                    receiverName, fieldName)
                if chainedArrayPtr != "" {
                    return chainedArrayPtr
                }
            } else {
                let varArrayPtr = tryGenerateVariableReceiverMemberAccess(
                    receiverName, fieldName)
                if varArrayPtr != "" {
                    return varArrayPtr
                }

                let constArrayPtr = tryGenerateModuleConstReceiverMemberAccess(
                    receiverName, fieldName)
                if constArrayPtr != "" {
                    return constArrayPtr
                }

                let implicitThisArrayPtr =
                    tryGenerateImplicitThisReceiverMemberAccess(receiverName,
                        fieldName)
                if implicitThisArrayPtr != "" {
                    return implicitThisArrayPtr
                }
            }
            return ""
        }

        let varIdx = findActiveVariableIndexImpl(this.varNames, getBoundedActiveVarCountWithGlobalStateImpl(this.varNames), varName)
        if shouldLoadLocalArrayMutatorPointerImpl(varIdx) {
            return emitLocalVariableLoadImpl(this.output, getFeatureRegBoxImpl(), "ptr",
                this.varRegs[varIdx])
        }

        let implicitThisArrayPtr = tryGenerateImplicitThisVariable(varName)
        if shouldUseImplicitThisArrayMutatorPointerImpl(
            implicitThisArrayPtr) {
            return implicitThisArrayPtr
        }

        let loadReg = getNextRegFn(getFeatureRegBoxImpl())
        this.output.append("  " + loadReg + " = load ptr, ptr @" + varName +
            "\n")
        return loadReg
    }

    fun tryGenerateArrayMutatorMethodCall(expr: ParserExpressionNode, methodName: String,
        receiverReg: String, receiverType: String) r: String {

        let receiverIsArray = isArrayReceiverTypeImpl(receiverType)
        let mutatorPlan = planArrayMutatorMethodImpl(methodName,
            receiverIsArray, expr.arguments.length())

        if mutatorPlan.action == 1 {
            let freeReceiverType = resolveArrayFreeReceiverTypeStateImpl(
                receiverType, expr.literalValue, this.varNames, this.varTypes,
                getBoundedActiveVarCountWithGlobalStateImpl(this.varNames))
            var freePtrReg = receiverReg
            if shouldResolveArrayFreeMutatorPointerStateImpl(
                freeReceiverType, freePtrReg, expr.literalValue, getGlobalStructNamesImpl()) {

                freePtrReg = tryResolveArrayMutatorPointerFromLiteral(
                    expr.literalValue)
            }
            return emitPreparedArrayFreeMutatorMethodStateImpl(this.output,
                getFeatureRegBoxImpl(), freeReceiverType, expr.literalValue,
                expr.variableName, freePtrReg, this.varNames, this.varRegs,
                getBoundedActiveVarCountWithGlobalStateImpl(this.varNames), getGlobalStructNamesImpl(), getGlobalStructSizesImpl())
        }

        if mutatorPlan.action == 2 {
            let argExpr = expr.arguments[0]
            let argReg = generateExpression(argExpr)
            let argType = inferExpressionType(argExpr)
            let argIsStructLiteral = argExpr.kind == "StructLiteral"
            let varName = expr.literalValue
            let arrayPtrReg = tryResolveArrayMutatorPointerFromLiteral(varName)
            let pushResult = emitPreparedArrayPushMutatorMethodStateImpl(
                this.output, getFeatureRegBoxImpl(), g_blockLabelBox, arrayPtrReg,
                receiverReg, receiverIsArray, argReg, argType,
                argIsStructLiteral, receiverType, getGlobalStructNamesImpl())
            if pushResult != "" {
                return pushResult
            }
        }

        if mutatorPlan.action == 3 {
            let arrayPtrReg =
                tryResolveArrayMutatorPointerFromLiteral(expr.literalValue)
            let popResult = emitPreparedArrayPopMutatorMethodStateImpl(
                this.output, getFeatureRegBoxImpl(), arrayPtrReg, receiverReg, receiverType)
            if popResult != "" {
                return popResult
            }
        }

        if mutatorPlan.action == 4 {
            let idxAReg = generateExpression(expr.arguments[0])
            let idxBReg = generateExpression(expr.arguments[1])
            let arrayPtrReg =
                tryResolveArrayMutatorPointerFromLiteral(expr.literalValue)
            let swapResult = emitPreparedArraySwapMutatorMethodStateImpl(
                this.output, getFeatureRegBoxImpl(), arrayPtrReg, receiverReg, idxAReg,
                idxBReg)
            if swapResult != "" {
                return swapResult
            }
        }

        return ""
    }

    fun resolveLiteralMethodReceiverType(literalValue: String) r: String {
        return resolveLiteralMethodReceiverTypeState(literalValue,
            this.varNames, this.varTypes, this.stringConstants)
    }

    fun prepareMethodCallArgRegsAndTypes(args: Array<ParserExpressionNode>,
        argRegs: Array<String>, argTypes: Array<String>) r: Void {

        var argIdx = 0
        while argIdx < args.length() {
            let argReg = generateExpression(args[argIdx])
            let argType = inferExpressionType(args[argIdx])
            argRegs.push(argReg)
            argTypes.push(mapTypeState(argType))
            argIdx = argIdx + 1
        }
    }

    ///
    Generate IR for a method call (receiver.method(args)). The largest and
    most complex dispatch in the codegen — handles:
      - SIMD horizontal reductions (reduce_add/min/max)
      - Option methods (isSome/isNone/unwrap — inlined as null checks)
      - Hot-reload synthesized methods (__seen_hot_get_size etc.)
      - Collection methods: Vec, HashMap, BTreeMap, LinkedList (dispatched
        to type-specialized runtime functions via dispatchCollectionMethodImpl)
      - String methods (length, contains, indexOf, split, trim, etc.)
      - StringBuilder methods (append, toString)
      - Array methods (push, get, set, length, pop, etc. with type dispatch
        for Int/String/Float/Bool/data-type element types)
      - SmallVec/JsonValue methods
      - Numeric methods (toString, toFloat, abs, etc.)
      - User-defined class methods (ClassName_methodName mangling)
      - Simple variable receivers (separate handling path when operands is
        empty but callee contains the receiver)
    NOTE: HashMap/BTreeMap methods must be handled in TWO locations — inside
    the "operands.length() > 0" path AND the "simple variable receivers"
    fallback section.
    ///
    fun generateMethodCall(expr: ParserExpressionNode) r: String {
        let methodName = expr.callee
        var receiverReg = ""
        var receiverType = "String"
        let receiverPhasePlan = planMethodReceiverInitialPhaseImpl(
            expr.operands.length(), expr.literalValue)
        let hasDottedReceiver = receiverPhasePlan.hasDottedReceiver

        if receiverPhasePlan.shouldTryDottedReceiver {

            let receiverSegments = splitChainedPathImpl(expr.literalValue)
            if receiverSegments.length() > 0 {
                let baseReceiverName = receiverSegments[0]
                let baseReceiverType = findVarType(baseReceiverName)
                let dottedBuildPlan = planDottedReceiverStageImpl(
                    expr.operands.length(), expr.literalValue,
                    receiverSegments.length(), baseReceiverType)
                if dottedBuildPlan.shouldBuildReceiverExpr {
                    let rebuiltReceiverExpr = buildChainedPathExprImpl(
                        expr.literalValue)
                    if rebuiltReceiverExpr.kind != "None" {
                        receiverReg = generateExpression(rebuiltReceiverExpr)
                        receiverType = inferExpressionType(rebuiltReceiverExpr)
                    }
                }
            }
        }

        if receiverPhasePlan.shouldUseExplicitReceiver {
            receiverReg = generateExpression(expr.operands[0])
            receiverType = inferExpressionType(expr.operands[0])

            let simdRedResult = emitSimdReductionImpl(this.output, getFeatureRegBoxImpl(),
                methodName, receiverReg, receiverType)
            if simdRedResult != "" {
                return simdRedResult
            }

            var dynArgRegs = Array<String>()
            var dynArgTypes = Array<String>()
            if shouldPrepareEarlyMethodFastPathArgsImpl(receiverType) {
                prepareMethodCallArgRegsAndTypes(expr.arguments, dynArgRegs,
                    dynArgTypes)
            }
            let explicitReceiverTypeBox = Array<String>()
            explicitReceiverTypeBox.push(receiverType)
            let explicitFastPath =
                tryGeneratePreparedExplicitReceiverFastPathImpl(this.output,
                    getFeatureRegBoxImpl(), g_blockLabelBox, methodName, receiverReg,
                    explicitReceiverTypeBox, getGlobalStructNamesImpl(), getGlobalStructMethodNamesImpl(),
                    getGlobalStructMethodRetTypesImpl(), dynArgRegs, dynArgTypes,
                    g_reprCClassNames)
            receiverType = explicitReceiverTypeBox[0]
            if explicitFastPath != "" {
                return explicitFastPath
            }
        }

        let postLookupPhase = planMethodReceiverPostLookupPhaseImpl(
            hasDottedReceiver, receiverReg, expr.literalValue)
        let dottedFallbackPlan = planDottedReceiverFallbackStageImpl(
            hasDottedReceiver, receiverReg)
        if postLookupPhase.shouldTryDottedFallback {

            let enumReceiverRegBox = Array<String>()
            enumReceiverRegBox.push("")
            let enumReceiverTypeBox = Array<String>()
            enumReceiverTypeBox.push(receiverType)
            if dottedFallbackPlan.shouldTryEnumLiteralFallback and
                tryResolveEnumLiteralMethodReceiverImpl(expr,
                enumReceiverRegBox, enumReceiverTypeBox) == 1 {
                receiverReg = enumReceiverRegBox[0]
                receiverType = enumReceiverTypeBox[0]
            } else {
                let implicitDottedReceiver =
                    tryResolveImplicitThisDottedMethodReceiverStateImpl(
                    this.output, getFeatureRegBoxImpl(), expr.literalValue, this.varNames,
                    this.varRegs, this.varTypes, getBoundedActiveVarCountWithGlobalStateImpl(this.varNames), getGlobalStructNamesImpl(),
                    getGlobalStructLayoutsImpl(), getGlobalStructFieldNamesImpl(), getGlobalStructFieldTypesImpl(),
                    getGlobalStructMethodNamesImpl(), getGlobalStructMethodRetTypesImpl(),
                    g_reprCClassNames, g_unionTypes, g_typeAliasNames,
                    g_typeAliasTargets, g_typeAliasCount, g_enumTypeNames,
                    getFeatureBitfieldCountImpl(), getFeatureBitfieldKeysImpl(), getFeatureBitfieldWidthsImpl())
                if implicitDottedReceiver.receiverReg != "" {
                    receiverReg = implicitDottedReceiver.receiverReg
                    receiverType = implicitDottedReceiver.receiverType
                }
            }
        } else {
            if postLookupPhase.shouldTrySimpleLiteral {
                let varName = expr.literalValue
                let idx = findActiveVariableIndexImpl(this.varNames, getBoundedActiveVarCountWithGlobalStateImpl(this.varNames), varName)
                var gvMcIdx = -1
                if idx < 0 {
                    gvMcIdx = findModuleConstant(varName)
                }
                let thisIdx = findActiveVariableIndexImpl(this.varNames,
                    getBoundedActiveVarCountWithGlobalStateImpl(this.varNames), "this")
                let simpleLiteralPlan =
                    planSimpleLiteralReceiverStageImpl(hasDottedReceiver,
                        expr.literalValue, idx, gvMcIdx, receiverReg,
                        thisIdx)
                if simpleLiteralPlan.shouldUseLocalLiteral {
                    let varReg = this.varRegs[idx]
                    let varType = this.varTypes[idx]
                    let llvmType = mapTypeState(varType)
                    let localReceiver = emitLocalMethodReceiverLoadImpl(
                        this.output, getFeatureRegBoxImpl(), llvmType, varReg, varType)
                    receiverReg = localReceiver.receiverReg
                    receiverType = localReceiver.receiverType

                    var svDynArgRegs = Array<String>()
                    var svDynArgTypes = Array<String>()
                    if shouldPrepareEarlyMethodFastPathArgsImpl(varType) {
                        prepareMethodCallArgRegsAndTypes(expr.arguments,
                            svDynArgRegs, svDynArgTypes)
                    }
                    let localVarFastPath =
                        tryGeneratePreparedLocalVariableReceiverFastPathImpl(
                            this.output, getFeatureRegBoxImpl(), methodName, receiverReg,
                            varType, getGlobalStructNamesImpl(), getGlobalStructMethodNamesImpl(),
                            getGlobalStructMethodRetTypesImpl(), svDynArgRegs,
                            svDynArgTypes)
                    if localVarFastPath != "" {
                        return localVarFastPath
                    }
                } else {
                    if simpleLiteralPlan.shouldUseModuleConstantLiteral {
                        let gvMcType =
                            getModuleConstantTypeWithModuleStateImpl(gvMcIdx)
                        let gvMcInvSuffix =
                            moduleConstantInvariantLoadSuffixWithModuleStateImpl(
                                gvMcIdx)
                        let moduleConstReceiver =
                            emitModuleConstantMethodReceiverLoadImpl(this.output,
                                getFeatureRegBoxImpl(), "@" + varName, gvMcType,
                                gvMcInvSuffix,
                                resolveLiteralMethodReceiverType(varName),
                                receiverReg, receiverType)
                        receiverReg = moduleConstReceiver.receiverReg
                        receiverType = moduleConstReceiver.receiverType
                    }
                    if receiverReg == "" {
                        if simpleLiteralPlan.shouldTryImplicitThisLiteral {
                            let implicitThisReceiver =
                                tryResolveImplicitThisLiteralMethodReceiverStateImpl(
                                this.output, getFeatureRegBoxImpl(), varName,
                                resolveLiteralMethodReceiverType(varName),
                                this.varNames, this.varRegs, this.varTypes,
                                getBoundedActiveVarCountWithGlobalStateImpl(this.varNames), getGlobalStructNamesImpl(), getGlobalStructLayoutsImpl(),
                                getGlobalStructFieldNamesImpl(), getGlobalStructFieldTypesImpl(),
                                g_reprCClassNames, g_unionTypes,
                                g_typeAliasNames, g_typeAliasTargets,
                                g_typeAliasCount, g_enumTypeNames,
                                getFeatureBitfieldCountImpl(), getFeatureBitfieldKeysImpl(),
                                getFeatureBitfieldWidthsImpl())
                            if implicitThisReceiver.receiverReg != "" {
                                receiverReg = implicitThisReceiver.receiverReg
                                receiverType = implicitThisReceiver.receiverType
                            }
                        }
                    }
                }
            }
        }

        let activeClassName = getGlobalCurrentClassNameImpl()
        let postResolutionPhase = planMethodReceiverPostResolutionPhaseImpl(
            receiverReg, activeClassName)
        if postResolutionPhase.shouldTryResolvedFastPath {
            let resolvedReceiverFastPath = tryGenerateResolvedReceiverFastPathMethodCall(expr, methodName, receiverReg, receiverType)
            if resolvedReceiverFastPath != "" {
                return resolvedReceiverFastPath
            }
        }

        ///
        Check if this is a static method call BEFORE setting receiver fallback
        Static method call: ClassName.method() where ClassName is not a variable
        Class names use PascalCase (start with uppercase letter)
        ///
        if postResolutionPhase.shouldTryStaticCall {
            let staticCallResult = tryGenerateStaticMethodCall(expr, methodName, receiverReg)
            if staticCallResult != "" {
                return staticCallResult
            }
        }

        let unresolvedStartPlan = planMethodUnresolvedReceiverStartImpl(
            receiverReg, activeClassName)
        if postResolutionPhase.shouldTryUnresolvedFallback and
            unresolvedStartPlan.shouldHandle {

            var implicitMethodRetType = ""
            if unresolvedStartPlan.shouldLookupImplicitReturn {
                implicitMethodRetType = getMethodReturnTypeState(activeClassName,
                    methodName)
            }
            let unresolvedFunctionRetType = getFunctionReturnTypeStateImpl(
                methodName, getGlobalFuncNamesImpl(), getGlobalFuncRetTypesImpl())
            let unresolvedFinalPlan = planMethodUnresolvedReceiverFinalImpl(
                receiverReg, activeClassName, implicitMethodRetType,
                unresolvedFunctionRetType,
                isStandaloneParserWorkaroundImpl(methodName))
            if unresolvedFinalPlan.shouldLowerAsCall {
                return generateCall(expr)
            }

            if unresolvedFinalPlan.shouldUseStandaloneParserWorkaround {
                prepareCallArgumentsWithDefaults(methodName, expr.arguments,
                    false, false, false, "")
                return emitStandaloneParserWorkaroundCallImpl(this.output,
                    getFeatureRegBoxImpl(), methodName,
                    getDefaultFillArgRegsImpl(),
                    getDefaultFillArgTypeStrsImpl())
            }

            if unresolvedFinalPlan.shouldWarnAndApplyDefault {
                let unresolvedDefault =
                    emitPreparedUnresolvedReceiverDefaultImpl(this.output,
                    getFeatureRegBoxImpl(), methodName, receiverReg, receiverType,
                    activeClassName, expr.literalValue,
                    expr.operands.length())
                if unresolvedDefault.resultReg != "" {
                    return unresolvedDefault.resultReg
                }
                receiverReg = unresolvedDefault.receiverReg
            }
        }

        // Generate arguments BEFORE allocating result register to keep numbers in order
        if postResolutionPhase.shouldTryArrayMutator {
            let arrayMutatorResult = tryGenerateArrayMutatorMethodCall(expr, methodName, receiverReg, receiverType)
            if arrayMutatorResult != "" {
                return arrayMutatorResult
            }
        }

        let lowerPlan = planMethodLowerCallImpl(receiverType, methodName,
            expr.arguments.length(), expr.operands.length(),
            isStringBuilderRuntimeMethodImpl(methodName),
            isNumericReceiverMethodImpl(methodName))

        if postResolutionPhase.shouldTryLowering {
            let noArgLower =
                tryEmitMethodLowerNoArgDriver(this.output,
                methodName, receiverReg, receiverType, lowerPlan)
            if noArgLower != "" {
                return noArgLower
            }
        }

        if postResolutionPhase.shouldTryLowering and
            lowerPlan.shouldTryStringBuilder {

            var sbArg0 = ""
            var isFloatFused = 0
            let sbArgAction = methodLowerStringBuilderArgActionForArgsImpl(
                receiverType, methodName, expr.arguments)
            if sbArgAction == 2 {
                let appendArgExpr = expr.arguments[0]
                sbArg0 = generateExpression(appendArgExpr.arguments[0])
                isFloatFused = 1
            }
            if sbArgAction == 1 {
                sbArg0 = generateExpression(expr.arguments[0])
            }
            let stringBuilderResult =
                emitPreparedStringBuilderMethodLowerImpl(this.output, getFeatureRegBoxImpl(),
                    methodName, receiverReg, receiverType, sbArg0,
                    isFloatFused)
            if stringBuilderResult != "" {
                return stringBuilderResult
            }
        }

        if postResolutionPhase.shouldTryLowering and
            lowerPlan.shouldTryPrimitiveConversion {

            let conversionResult = tryEmitMethodPrimitiveConversionDriver(
                this.output, methodName, receiverReg, receiverType,
                lowerPlan)
            if conversionResult != "" {
                return conversionResult
            }
        }

        if postResolutionPhase.shouldTryLowering and lowerPlan.shouldTryNumeric {
            var numArg0 = ""
            var numArg1 = ""
            if lowerPlan.hasArg0 {
                numArg0 = generateExpression(expr.arguments[0])
            }
            if lowerPlan.hasArg1 {
                numArg1 = generateExpression(expr.arguments[1])
            }
            let numericResult = emitPreparedNumericMethodLowerImpl(
                this.output, getFeatureRegBoxImpl(), methodName, receiverReg, receiverType,
                numArg0, numArg1)
            if numericResult != "" {
                return numericResult
            }
        }

        var strArg0 = ""
        var strArg1 = ""
        let strArgCount = expr.arguments.length()
        if postResolutionPhase.shouldTryLowering and lowerPlan.shouldTryStringLike {
            if lowerPlan.hasArg0 {
                strArg0 = generateExpression(expr.arguments[0])
            }
            if lowerPlan.hasArg1 {
                strArg1 = generateExpression(expr.arguments[1])
            }
            let stringLikeResult = emitPreparedStringLikeMethodLowerImpl(
                this.output, getFeatureRegBoxImpl(), methodName, receiverReg, receiverType, strArg0,
                strArg1, strArgCount, g_reprCClassNames, getGlobalStructNamesImpl())
            if stringLikeResult != "" {
                return stringLikeResult
            }
        }

        var tracedUnwrapSourceType = ""
        if postResolutionPhase.shouldTryLowering and
            lowerPlan.shouldTraceUnwrapToJsonSource {

            let receiverExpr = expr.operands[0]
            if shouldUseMethodLowerUnwrapTraceSourceImpl(receiverExpr.kind,
                receiverExpr.callee, receiverExpr.operands.length()) {
                tracedUnwrapSourceType = inferExpressionType(
                    receiverExpr.operands[0])
            }
        }
        let collectionGetWarning = tryEmitMethodUnresolvedCollectionGetWarningDriver(
            this.output, methodName, receiverType, expr.literalValue)
        if collectionGetWarning != "" {
            return collectionGetWarning
        }
        let instanceTypeName = resolveMethodCallInstanceTypeNameImpl(expr,
            methodName, receiverType, tracedUnwrapSourceType)
        let funcName = instanceTypeName + "_" + methodName

        var hotStateArg = ""
        if postResolutionPhase.shouldTryLowering and
            lowerPlan.shouldReadHotStateArg {

            hotStateArg = generateExpression(expr.arguments[0])
        }
        if postResolutionPhase.shouldTryLowering and lowerPlan.shouldTryHotReload {
            let hotReloadResult =
                tryEmitMethodHotReloadLoweringDriver(this.output, methodName,
                funcName, receiverReg, receiverType, hotStateArg)
            if hotReloadResult != "" {
                return hotReloadResult
            }
        }

        if isScalarFieldChainTerminalTypeImpl(receiverType) and
            shouldUseScalarReceiverFallbackImpl(methodName,
                isNumericReceiverMethodImpl(methodName)) {

            return emitPreparedScalarReceiverFallbackImpl(this.output,
                receiverType, methodName, expr.literalValue,
                inferExpressionType(expr))
        }

        let finalDispatchPlan = planMethodFinalDispatchImpl(
            postResolutionPhase.shouldTryFinalDispatch and
            lowerPlan.shouldTrySpecialized)
        if finalDispatchPlan.shouldPrepareArguments {
            prepareCallArgumentsWithDefaults(funcName, expr.arguments, false,
                true, false, "")
        }
        let argRegs = getDefaultFillArgRegsImpl()
        let argTypeStrs = getDefaultFillArgTypeStrsImpl()

        let registeredMethodReturnType = getMethodReturnTypeState(instanceTypeName,
            methodName)
        var inferredMethodReturnType = ""
        if registeredMethodReturnType == "" or
            registeredMethodReturnType == "Unknown" {

            inferredMethodReturnType = inferExpressionType(expr)
        }
        let methodLateState = captureLateUserDeclareState()
        let finalMethodResult = emitPreparedFinalMethodDispatchState(
            this.output, getFeatureRegBoxImpl(), methodName, instanceTypeName, funcName,
            receiverReg, receiverType, registeredMethodReturnType,
            inferredMethodReturnType, argRegs, argTypeStrs,
            finalDispatchPlan.shouldPrepareReceiverAbi,
            finalDispatchPlan.shouldTrySpecialized,
            finalDispatchPlan.shouldEmitUserMethod, methodLateState)
        applyLateUserDeclareState(methodLateState)
        return finalMethodResult
    }

    ///
    Generate IR for an await expression. Calls the async function to get
    a coroutine handle (ptr), then emits a poll loop: coro.done? -> yes:
    extract promise value, no: coro.resume and loop. Uses LLVM coroutine
    intrinsics (coro.done, coro.resume, coro.destroy) directly — C wrapper
    functions CRASH due to calling convention mismatch (fastcc vs ccc).
    ///
    fun generateAwaitExpression(expr: ParserExpressionNode) r: String {
        let futureExpr = expr.operands[0]
        let hdlReg = generateExpression(futureExpr)
        let resultLlvmType = resolveAwaitExpressionResultLlvmTypeState(
            futureExpr, g_asyncFuncNames, g_asyncFuncRetTypes, g_asyncFuncCount)
        emitAwaitPollLoopImpl(this.output, getFeatureRegBoxImpl(), g_blockLabelBox, hdlReg)
        return emitAwaitResultValueImpl(this.output, getFeatureRegBoxImpl(), hdlReg,
            resultLlvmType)
    }

    ///
    Generate IR for a unary expression: negation (-x), logical not (!x),
    bitwise not (~x), address-of (&x), dereference (*x).
    ///
    fun tryEmitOverloadedUnary(expr: ParserExpressionNode) r: String {
        if expr.operands.length() == 0 {
            return ""
        }
        let unaryOpType = inferExpressionType(expr.operands[0])
        let unaryPlan = planOverloadedUnaryState(expr.operator, unaryOpType,
            getGlobalFuncNamesImpl(), getGlobalFuncRetTypesImpl())
        if unaryPlan.funcName == "" {
            return ""
        }
        let unaryValReg = generateExpression(expr.operands[0])
        return emitOverloadedUnaryCallImpl(this.output, getFeatureRegBoxImpl(),
            quoteIdentIfNeededImpl(unaryPlan.funcName), unaryPlan.retLlvmType,
            unaryValReg)
    }

    fun emitUnaryNegation(expr: ParserExpressionNode) r: String {
        let operandReg = generateExpression(expr.operands[0])
        let operandType = inferExpressionType(expr.operands[0])
        return emitUnaryNegationImpl(this.output, getFeatureRegBoxImpl(), operandReg, operandType)
    }

    fun tryEmitNegatedComparison(innerExpr: ParserExpressionNode) r: String {
        if innerExpr.kind != "Binary" {
            return ""
        }
        let flippedOp = negatedComparisonPredicateImpl(innerExpr.operator)
        if flippedOp == "" {
            return ""
        }
        let innerLeftType = inferExpressionType(innerExpr.operands[0])
        let innerRightType = inferExpressionType(innerExpr.operands[1])
        if not shouldEmitNegatedComparisonForTypesImpl(innerLeftType,
            innerRightType) {

            return ""
        }
        let aReg = generateExpression(innerExpr.operands[0])
        let bReg = generateExpression(innerExpr.operands[1])
        return emitNegatedComparisonImpl(this.output, getFeatureRegBoxImpl(), flippedOp, aReg,
            bReg)
    }

    fun emitUnaryLogicalNot(expr: ParserExpressionNode) r: String {
        let innerExpr = expr.operands[0]
        let negatedCmpReg = tryEmitNegatedComparison(innerExpr)
        if negatedCmpReg != "" {
            return negatedCmpReg
        }
        let operandReg = generateExpression(innerExpr)
        let operandType = inferExpressionType(innerExpr)
        return emitUnaryLogicalNotImpl(this.output, getFeatureRegBoxImpl(), operandReg,
            operandType)
    }

    fun emitUnaryAddressOf(expr: ParserExpressionNode) r: String {
        if g_insideUnsafe == 0 {
            this.output.append("  ; WARNING: address-of (&) requires unsafe block\n")
        }
        let addrOperand = expr.operands[0]
        let addrType = inferExpressionType(addrOperand)
        if addrOperand.kind == "Variable" or addrOperand.kind == "VarExpr" {
            var addrVarName = addrOperand.variableName
            if addrVarName == "" { addrVarName = addrOperand.literalValue }
            let addrIdx = findActiveVariableIndexImpl(this.varNames, getBoundedActiveVarCountWithGlobalStateImpl(this.varNames), addrVarName)
            if addrIdx >= 0 {
                let addrVarReg = this.varRegs[addrIdx]
                if isClassTypeState(addrType) {
                    return emitUnaryAddressOfClassValueImpl(this.output, getFeatureRegBoxImpl(),
                        addrVarReg)
                }
                return emitUnaryAddressOfVariablePtrImpl(this.output, getFeatureRegBoxImpl(),
                    addrVarReg)
            }
        }
        return generateExpression(addrOperand)
    }

    fun emitUnaryDereference(expr: ParserExpressionNode) r: String {
        if g_insideUnsafe == 0 {
            this.output.append("  ; WARNING: pointer dereference (*) requires unsafe block\n")
        }
        let derefValReg = generateExpression(expr.operands[0])
        return emitUnaryDereferenceImpl(this.output, getFeatureRegBoxImpl(), derefValReg)
    }

    fun emitUnaryBitwiseNot(expr: ParserExpressionNode) r: String {
        let operandReg = generateExpression(expr.operands[0])
        return emitUnaryBitwiseNotImpl(this.output, getFeatureRegBoxImpl(), operandReg)
    }

    fun generateUnary(expr: ParserExpressionNode) r: String {
        let overloadedUnaryReg = tryEmitOverloadedUnary(expr)
        if overloadedUnaryReg != "" {
            return overloadedUnaryReg
        }

        if expr.operator == "-" {
            return emitUnaryNegation(expr)
        }
        if expr.operator == "not" or expr.operator == "!" {
            return emitUnaryLogicalNot(expr)
        }
        if expr.operator == "&" {
            return emitUnaryAddressOf(expr)
        }
        if expr.operator == "*" {
            return emitUnaryDereference(expr)
        }
        if isUnaryBitwiseNotOperatorImpl(expr.operator) {
            return emitUnaryBitwiseNot(expr)
        }
        let operandReg = generateExpression(expr.operands[0])
        let resultReg = getNextRegFn(getFeatureRegBoxImpl())
        return resultReg
    }

    fun prepareCallArguments(funcName: String, arguments: Array<ParserExpressionNode>,
        argRegs: Array<String>, argTypeStrs: Array<String>, enableDynBoxing: Bool,
        enableFloatPromotion: Bool, nullifyMovedSources: Bool, moveContext: String) r: Void {

        var argIdx = 0
        while argIdx < arguments.length() {
            let argExpr = arguments[argIdx]
            let argReg = generateExpression(argExpr)
            let argType = inferExpressionType(argExpr)
            let argLlvmType = mapTypeState(argType)
            appendPreparedCallArgImpl(this.output, getFeatureRegBoxImpl(), funcName, argReg, argType, argLlvmType, argIdx, argRegs, argTypeStrs, g_dynParamFuncs, enableDynBoxing, enableFloatPromotion, g_floatParamFuncNames, g_floatParamParamIdxs)

            if shouldNullifyMovedArgumentSourceImpl(nullifyMovedSources,
                g_moveOnlyClasses, argType) {

                let moveVarName = resolveMovedArgumentSourceNameImpl(
                    argExpr.kind, argExpr.variableName, argExpr.literalValue)
                if moveVarName != "" {
                    let moveVarIdx = findActiveVariableIndexImpl(this.varNames,
                        getBoundedActiveVarCountWithGlobalStateImpl(this.varNames), moveVarName)
                    if shouldRecordMovedArgumentSourceImpl(moveVarName,
                        moveVarIdx) {
                        let moveSrcReg = this.varRegs[moveVarIdx]
                        this.output.append("  store i64 0, ptr " + moveSrcReg + " ; @move: nullify source (" + moveContext + ")\n")
                        recordMovedVariableImpl(
                            getCurrentFunctionEmissionStateImpl(),
                            moveVarName)
                    }
                }
            }
            argIdx = argIdx + 1
        }
    }

    fun prepareCallArgumentsWithDefaults(funcName: String,
        arguments: Array<ParserExpressionNode>, enableDynBoxing: Bool,
        enableFloatPromotion: Bool, nullifyMovedSources: Bool,
        moveContext: String) r: Void {

        let preparedArgRegs = Array<String>()
        let preparedArgTypeStrs = Array<String>()
        prepareCallArguments(funcName, arguments, preparedArgRegs,
            preparedArgTypeStrs, enableDynBoxing, enableFloatPromotion,
            nullifyMovedSources, moveContext)
        fillDefaultParamsLocal(funcName, preparedArgRegs, preparedArgTypeStrs)
    }

    fun fillDefaultParamsLocal(funcName: String, argRegs: Array<String>, argTypeStrs: Array<String>) r: Void {
        setDefaultFillArgsImpl(argRegs, argTypeStrs)
        fillDefaultParamsImpl(this.output, getFeatureRegBoxImpl(), funcName,
            getDefaultFillArgRegsImpl(), getDefaultFillArgTypeStrsImpl(),
            g_funcParamCountArr, g_funcDefaultsArr,
            getStringConstantPrefixWithGlobalStateImpl(), this.stringConstants)
    }

    fun inferReturnExprType(className: String, expr: ParserExpressionNode) r: String {
        return inferReturnExprTypeState(className, expr, this.varNames,
            this.varTypes, this.stringConstants)
    }

    fun inferBlockReturnType(className: String, block: BlockNode) r: String {
        return inferBlockReturnTypeState(className, block, this.varNames,
            this.varTypes, this.stringConstants)
    }

    fun resolveMethodReturnType(className: String, method: FunctionNode) r: String {
        return resolveMethodReturnTypeState(className, method, this.varNames,
            this.varTypes, this.stringConstants)
    }

    fun resolveMethodReturnTypeFromList(className: String, methods: Array<FunctionNode>, methodIdx: Int) r: String {
        return resolveMethodReturnTypeFromListState(className, methods,
            methodIdx, this.varNames, this.varTypes, this.stringConstants)
    }

    fun resolveMethodReturnTypeByIndex(classNode: ClassNode, methodIdx: Int) r: String {
        return resolveMethodReturnTypeFromList(classNode.name, classNode.methods, methodIdx)
    }

    fun resolveFunctionReturnType(fn: FunctionNode) r: String {
        return resolveFunctionReturnTypeState(fn, this.varNames, this.varTypes,
            this.stringConstants)
    }

    fun inferExpressionType(expr: ParserExpressionNode) r: String {
        return inferExpressionTypeState(expr, this.varNames, this.varTypes,
            this.stringConstants)
    }

    ///
    Pre-scan all expressions in a program to collect string literal constants.
    These are emitted as LLVM global constants before any function bodies.
    Also piggybacks call counting for ML inline decisions and self-call
    detection (for the norecurse attribute). Delegates to
    collectStringConstantsImpl in ir_string_collect_scan.seen.
    ///
    fun collectStringConstants(program: ProgramNode) r: Void {
        collectProgramStringConstantsState(program, this.stringConstants)
    }

    fun generateStringInterpolation(expr: ParserExpressionNode) r: String {
        let numParts = expr.arguments.length()
        let numExprs = expr.operands.length()
        var partRegs = Array<String>()
        var exprRegs = Array<String>()
        var exprTypes = Array<String>()
        var i = 0
        while i < numParts {
            partRegs.push(generateLiteral(expr.arguments[i]))
            if i < numExprs {
                let interpExpr = expr.operands[i]
                exprTypes.push(inferExpressionType(interpExpr))
                exprRegs.push(generateExpression(interpExpr))
            }
            i = i + 1
        }
        return generateStringInterpolationFromPartsImpl(this.output, getFeatureRegBoxImpl(),
            partRegs, exprRegs, exprTypes)
    }

    ///
    Elvis operator: a ?: b — returns a if non-zero/non-null, otherwise b
    Generate IR for the elvis/null-coalesce operator (a ?? b).
    Evaluates 'a', checks if null (icmp eq ptr, null), and returns 'b'
    if null, otherwise 'a'. Uses a phi node to merge the two paths.
    ///
    fun generateElvis(expr: ParserExpressionNode) r: String {
        let leftReg = generateExpression(expr.operands[0])
        let leftType = inferExpressionType(expr.operands[0])
        let llvmType = mapTypeState(leftType)
        let cmpReg = emitNullishCheckComparisonImpl(this.output, getFeatureRegBoxImpl(), leftReg,
            llvmType)
        let branchLabels = splitPipe(emitNullishBranchingImpl(this.output,
            getFeatureBlockBoxImpl(), cmpReg))
        let thenLabel = branchLabels[0]
        let elseLabel = branchLabels[1]
        let endLabel = branchLabels[2]

        // Then: left is non-null, use left
        emitNullishBranchToEndImpl(this.output, endLabel)

        // Else: left is null, compute right
        enterNullishElseBranchImpl(this.output, elseLabel)
        let rightReg = generateExpression(expr.operands[1])
        emitNullishBranchToEndImpl(this.output, endLabel)

        // Merge with phi
        return finalizeNullishMergeImpl(this.output, getFeatureRegBoxImpl(), endLabel, llvmType,
            leftReg, thenLabel, rightReg, elseLabel)
    }

    ///
    Safe navigation: obj?.member — returns member if obj is non-null, else default
    Generate IR for the safe navigation operator (a?.b).
    Checks if 'a' is null — if so, short-circuits to null/0 without
    accessing the field. Otherwise, proceeds with normal field access.
    ///
    fun generateSafeNavigation(expr: ParserExpressionNode) r: String {
        let recvReg = generateExpression(expr.operands[0])
        let recvType = inferExpressionType(expr.operands[0])
        let cmpReg = emitNullishCheckComparisonImpl(this.output, getFeatureRegBoxImpl(), recvReg,
            mapTypeState(recvType))
        let branchLabels = splitPipe(emitNullishBranchingImpl(this.output,
            getFeatureBlockBoxImpl(), cmpReg))
        let thenLabel = branchLabels[0]
        let elseLabel = branchLabels[1]
        let endLabel = branchLabels[2]

        // Then: non-null, access member
        let memberExpr = buildSafeNavigationMemberExprImpl(expr.variableName,
            expr.operands[0])
        let memberReg = generateMemberAccess(memberExpr)
        let memberType = inferExpressionType(memberExpr)
        let memberLlvm = mapTypeState(memberType)
        emitNullishBranchToEndImpl(this.output, endLabel)

        // Else: null, use default
        enterNullishElseBranchImpl(this.output, elseLabel)
        let defaultVal = defaultValueForLlvmTypeImpl(memberLlvm)
        emitNullishBranchToEndImpl(this.output, endLabel)

        // Merge
        return finalizeNullishMergeImpl(this.output, getFeatureRegBoxImpl(), endLabel,
            memberLlvm, memberReg, thenLabel, defaultVal, elseLabel)
    }

    fun emitWhenArmGuard(arm: ParserExpressionNode, armBodyLabel: String, nextCheckLabel: String) r: Void {
        if not shouldEmitWhenArmGuardImpl(arm.operands.length()) {
            return
        }
        let guardReg = generateExpression(arm.operands[2])
        let guardType = inferExpressionType(arm.operands[2])
        emitWhenArmGuardImpl(this.output, getFeatureRegBoxImpl(), guardReg, guardType,
            armBodyLabel, nextCheckLabel)
        cseClear()
    }

    fun emitWhenPatternBindings(subjectReg: String, subjectLlvm: String, patternExpr: ParserExpressionNode) r: Void {
        emitWhenPatternBindingsState(this.output, getFeatureRegBoxImpl(), subjectReg, subjectLlvm,
            patternExpr, this.varNames, this.varRegs, getBoundedActiveVarCountWithGlobalStateImpl(this.varNames),
            g_enumVariantNames, g_enumVariantFieldTypes, g_enumVariantCount)
    }

    fun emitWhenArmResult(arm: ParserExpressionNode, resultAlloca: String) r: Void {
        let resultPlanSeed = planWhenArmResultImpl(arm.operands.length(),
            "", 0)
        if resultPlanSeed.resultAction == 0 {
            return
        }
        let armResult = arm.operands[1]
        let resultPlan = planWhenArmResultImpl(arm.operands.length(),
            armResult.kind, armResult.operands.length())
        if resultPlan.resultAction == 1 {
            let retType = mapTypeState(
                getCurrentFunctionReturnTypeWithGlobalStateImpl())
            if resultPlan.shouldReadReturnValue {
                let retValReg = generateExpression(armResult.operands[0])
                emitWhenArmReturnImpl(this.output, retType, retValReg, true)
            } else {
                emitWhenArmReturnImpl(this.output, retType, "", false)
            }
            setBlockTerminated(true)
            return
        }
        if not resultPlan.shouldGenerateValueExpression {
            return
        }
        let armResultReg = generateExpression(armResult)
        if shouldStoreWhenArmResultImpl(isBlockTerminated()) {
            let armResultType = inferExpressionType(armResult)
            let armStoreReg = normalizeWhenArmStoreValueImpl(this.output,
                getFeatureRegBoxImpl(), armResultReg, armResultType)
            emitWhenArmStoreImpl(this.output, resultAlloca, armStoreReg)
        }
    }

    fun generateWhenExpression(expr: ParserExpressionNode) r: String {
        // Subject expression (if present)
        let subjectPlan = planWhenSubjectImpl(expr.operands.length())
        var subjectReg = subjectPlan.defaultSubjectReg
        var subjectType = subjectPlan.defaultSubjectType
        if subjectPlan.shouldEvaluateSubject {
            subjectReg = generateExpression(expr.operands[0])
            subjectType = inferExpressionType(expr.operands[0])
        }
        let subjectLlvm = mapTypeState(subjectType)

        let endLabel = getNextBlockFn(getFeatureBlockBoxImpl())
        let resultAlloca = allocateWhenResultSlotImpl(this.output, getFeatureRegBoxImpl())

        // Generate each arm
        var armIdx = 0
        while armIdx < expr.arguments.length() {
            let arm = expr.arguments[armIdx]
            ///
            arm.variableName = pattern kind ("Is", "Literal", "Wildcard", "Variable")
            arm.literalValue = type/constructor name or literal value
            arm.operands[0] = Pattern expression
            arm.operands[1] = arm result expression
            ///
            let patternExpr = arm.operands[0]

            let armBodyLabel = getNextBlockFn(getFeatureBlockBoxImpl())
            let nextCheckLabel = getNextBlockFn(getFeatureBlockBoxImpl())

            emitWhenPatternBranchState(this.output, getFeatureRegBoxImpl(), this.stringConstants,
                subjectReg, subjectLlvm, patternExpr, armBodyLabel,
                nextCheckLabel, g_enumVariantNames, g_enumVariantTags,
                g_enumVariantCount)

            // Arm body
            this.output.append(armBodyLabel + ":\n")
            cseClear()

            emitWhenArmGuard(arm, armBodyLabel, nextCheckLabel)
            emitWhenPatternBindings(subjectReg, subjectLlvm, patternExpr)
            emitWhenArmResult(arm, resultAlloca)
            if shouldBranchWhenArmToEndImpl(isBlockTerminated()) {
                this.output.append("  br label %" + endLabel + "\n")
            }
            setBlockTerminated(false)

            // Next check
            this.output.append(nextCheckLabel + ":\n")
            cseClear()
            armIdx = armIdx + 1
        }

        // After all arms, branch to end (fallthrough if no match)
        if shouldEmitWhenFinalFallthroughImpl(expr.arguments.length()) {
            this.output.append("  br label %" + endLabel + "\n")
        }

        cseClear()
        let resultReg = finalizeWhenResultImpl(this.output, getFeatureRegBoxImpl(), endLabel,
            resultAlloca)
        return resultReg
    }

    fun emitEnumConstructorFieldStores(variantName: String, expr: ParserExpressionNode, objReg: String, fieldCount: Int) r: Void {
        let fieldRegs = Array<String>()
        var fi = 0
        while shouldCollectEnumConstructorFieldImpl(fi, fieldCount,
            expr.arguments.length()) {

            fieldRegs.push(generateExpression(expr.arguments[fi]))
            fi = fi + 1
        }
        emitEnumConstructorPreparedFieldStoresState(this.output, getFeatureRegBoxImpl(),
            variantName, objReg, fieldRegs, g_enumVariantNames,
            g_enumVariantFieldTypes, g_enumVariantCount)
    }

    fun generateEnumConstructor(variantName: String, expr: ParserExpressionNode) r: String {
        let enumCtorPlan = planEnumConstructorImpl(variantName,
            g_enumVariantNames, g_enumVariantTags, g_enumVariantFieldCounts,
            g_enumVariantCount)
        if enumCtorPlan.isSimple {
            return enumCtorPlan.tag.toString()
        }
        let objReg = allocateEnumConstructorObjectImpl(this.output, getFeatureRegBoxImpl(),
            enumCtorPlan.tag, enumCtorPlan.fieldCount)
        emitEnumConstructorFieldStores(variantName, expr, objReg,
            enumCtorPlan.fieldCount)
        return objReg
    }
}
