// LLVM IR Generator - Generates LLVM IR text from ProgramNode
// This replaces the C generator for Stage1 compilation

import parser.real_parser.{ProgramNode, ItemNode, FunctionNode, BlockNode, StatementNode, ParserExpressionNode, ParamNode, TypeNode}

class LLVMIRGenerator {
    var output: String
    var stringConstants: Array<String>
    var nextReg: Int
    var nextBlock: Int
    // Using parallel arrays as workaround for Map.get() bug
    var varNames: Array<String>
    var varRegs: Array<String>
    var varTypes: Array<String>
    var indent: Int

    static fun new() r: LLVMIRGenerator {
        return LLVMIRGenerator{
            output: "",
            stringConstants: Array<String>(),
            nextReg: 1,
            nextBlock: 0,
            varNames: Array<String>(),
            varRegs: Array<String>(),
            varTypes: Array<String>(),
            indent: 0
        }
    }

    // Helper to store variable
    fun storeVar(name: String, reg: String, varType: String) r: Void {
        varNames.push(name)
        varRegs.push(reg)
        varTypes.push(varType)
    }

    // Helper to find variable
    fun findVar(name: String) r: Int {
        let len = varNames.length()
        var i = 0
        while i < len {
            let current = varNames[i]
            if current == name {
                return i
            }
            i = i + 1
        }
        return -1
    }

    fun generate(program: ProgramNode) r: String {
        output = ""
        stringConstants = Array<String>()

        // First pass: collect string constants
        collectStringConstants(program)

        // Emit module header
        emitPrologue()

        // Emit string constants
        emitStringConstants()

        // Emit runtime declarations
        emitRuntimeDeclarations()

        // Emit functions
        var i = 0
        while i < program.items.length() {
            let item = program.items[i]
            if item.itemType == "Function" {
                generateFunction(item.function)
            }
            i = i + 1
        }

        return output
    }

    fun emitPrologue() r: Void {
        output = output + "; Generated by Seen Stage1 Compiler (LLVM backend)\n"
        output = output + "target datalayout = \"e-m:e-p270:32:32-p271:32:32-p272:64:64-i64:64-f80:128-n8:16:32:64-S128\"\n"
        output = output + "target triple = \"x86_64-unknown-linux-gnu\"\n\n"

        // SeenString type
        output = output + "%SeenString = type { i64, ptr }\n\n"
    }

    fun emitStringConstants() r: Void {
        var i = 0
        while i < stringConstants.length() {
            let str = stringConstants[i]
            let escaped = escapeString(str)
            let len = str.length() + 1  // +1 for null terminator
            output = output + "@.str." + i.toString() + " = private unnamed_addr constant [" + len.toString() + " x i8] c\"" + escaped + "\\00\"\n"
            i = i + 1
        }
        if stringConstants.length() > 0 {
            output = output + "\n"
        }
    }

    fun emitRuntimeDeclarations() r: Void {
        output = output + "; Runtime function declarations\n"
        output = output + "declare void @seen_runtime_init(i32, ptr)\n"
        output = output + "declare void @println(%SeenString)\n"
        output = output + "declare %SeenString @seen_cstr_to_str(ptr)\n"
        output = output + "declare i64 @seen_length(%SeenString)\n"
        output = output + "declare %SeenString @seen_substring(%SeenString, i64, i64)\n"
        output = output + "declare i1 @startsWith(%SeenString, %SeenString)\n"
        output = output + "declare i1 @endsWith(%SeenString, %SeenString)\n"
        output = output + "declare i1 @contains(%SeenString, %SeenString)\n"
        output = output + "declare %SeenString @trim(%SeenString)\n"
        output = output + "declare %SeenString @seen_str_concat_ss(%SeenString, %SeenString)\n"
        output = output + "declare %SeenString @seen_int_to_string(i64)\n"
        output = output + "declare %SeenString @readText(%SeenString)\n"
        output = output + "declare i1 @writeText(%SeenString, %SeenString)\n"
        output = output + "\n"
    }

    fun generateFunction(fn: FunctionNode) r: Void {
        // Reset per-function state
        nextReg = 1
        nextBlock = 0
        varNames = Array<String>()
        varRegs = Array<String>()
        varTypes = Array<String>()

        let returnType = mapType(fn.returnType.typeName)

        // Function signature
        output = output + "define " + returnType + " @" + fn.name + "("

        // Parameters
        var paramIdx = 0
        while paramIdx < fn.params.length() {
            if paramIdx > 0 {
                output = output + ", "
            }
            let param = fn.params[paramIdx]
            let paramType = mapType(param.paramType.typeName)
            output = output + paramType + " %" + param.name + ".arg"
            paramIdx = paramIdx + 1
        }

        output = output + ") {\n"
        output = output + "entry:\n"

        // Allocate space for parameters and store them
        paramIdx = 0
        while paramIdx < fn.params.length() {
            let param = fn.params[paramIdx]
            let paramType = mapType(param.paramType.typeName)
            let reg = getNextReg()
            output = output + "  " + reg + " = alloca " + paramType + "\n"
            output = output + "  store " + paramType + " %" + param.name + ".arg, ptr " + reg + "\n"
            storeVar(param.name, reg, param.paramType.typeName)
            paramIdx = paramIdx + 1
        }

        // For main function, call runtime init
        if fn.name == "main" {
            output = output + "  call void @seen_runtime_init(i32 0, ptr null)\n"
        }

        // Generate function body
        generateBlock(fn.body)

        // If no return was generated for void functions, add one
        if returnType == "void" {
            output = output + "  ret void\n"
        }

        output = output + "}\n\n"
    }

    fun generateBlock(block: BlockNode) r: Void {
        var i = 0
        while i < block.statements.length() {
            generateStatement(block.statements[i])
            i = i + 1
        }
    }

    fun generateStatement(stmt: StatementNode) r: Void {
        if stmt.kind == "Let" or stmt.kind == "Var" {
            generateLetStatement(stmt)
        } else if stmt.kind == "Return" {
            generateReturnStatement(stmt)
        } else if stmt.kind == "Expression" {
            generateExpression(stmt.expression)
        } else if stmt.kind == "If" {
            generateIfStatement(stmt)
        } else if stmt.kind == "While" {
            generateWhileStatement(stmt)
        } else if stmt.kind == "Assignment" {
            generateAssignment(stmt)
        }
    }

    fun generateLetStatement(stmt: StatementNode) r: Void {
        // Get variable type - prefer explicit type, fall back to inference
        var varType = stmt.variableType.typeName
        if varType == "" or varType == "Unknown" {
            // Infer type from initializer
            if stmt.initializer.kind != "None" {
                varType = inferExpressionType(stmt.initializer)
            }
        }
        let llvmType = mapType(varType)

        // Allocate space
        let reg = getNextReg()
        output = output + "  " + reg + " = alloca " + llvmType + "\n"

        // Store variable mapping
        storeVar(stmt.variableName, reg, varType)

        // Initialize if there's an initializer
        if stmt.initializer.kind != "None" {
            let valueReg = generateExpression(stmt.initializer)
            output = output + "  store " + llvmType + " " + valueReg + ", ptr " + reg + "\n"
        }
    }

    fun generateReturnStatement(stmt: StatementNode) r: Void {
        if stmt.returnValue.kind == "None" {
            output = output + "  ret void\n"
        } else {
            let valueReg = generateExpression(stmt.returnValue)
            // Determine return type from expression
            let retType = inferExpressionType(stmt.returnValue)
            let llvmType = mapType(retType)
            output = output + "  ret " + llvmType + " " + valueReg + "\n"
        }
    }

    fun generateIfStatement(stmt: StatementNode) r: Void {
        let condReg = generateExpression(stmt.condition)

        let thenLabel = getNextBlockLabel()
        let elseLabel = getNextBlockLabel()
        let endLabel = getNextBlockLabel()

        // Branch on condition
        output = output + "  br i1 " + condReg + ", label %" + thenLabel + ", label %" + elseLabel + "\n"

        // Then block
        output = output + thenLabel + ":\n"
        let thenHasTerminator = blockHasTerminator(stmt.thenBranch)
        generateBlock(stmt.thenBranch)
        if not thenHasTerminator {
            output = output + "  br label %" + endLabel + "\n"
        }

        // Else block
        output = output + elseLabel + ":\n"
        let elseHasTerminator = blockHasTerminator(stmt.elseBranch)
        if stmt.elseBranch.statements.length() > 0 {
            generateBlock(stmt.elseBranch)
        }
        if not elseHasTerminator {
            output = output + "  br label %" + endLabel + "\n"
        }

        // End block
        output = output + endLabel + ":\n"
    }

    fun blockHasTerminator(block: BlockNode) r: Bool {
        if block.statements.length() == 0 {
            return false
        }
        let lastStmt = block.statements[block.statements.length() - 1]
        return lastStmt.kind == "Return"
    }

    fun generateWhileStatement(stmt: StatementNode) r: Void {
        let condLabel = getNextBlockLabel()
        let bodyLabel = getNextBlockLabel()
        let endLabel = getNextBlockLabel()

        // Jump to condition check
        output = output + "  br label %" + condLabel + "\n"

        // Condition block
        output = output + condLabel + ":\n"
        let condReg = generateExpression(stmt.loopCondition)
        output = output + "  br i1 " + condReg + ", label %" + bodyLabel + ", label %" + endLabel + "\n"

        // Body block
        output = output + bodyLabel + ":\n"
        generateBlock(stmt.loopBody)
        output = output + "  br label %" + condLabel + "\n"

        // End block
        output = output + endLabel + ":\n"
    }

    fun generateAssignment(stmt: StatementNode) r: Void {
        let varName = stmt.variableName
        let idx = findVar(varName)
        if idx < 0 {
            return
        }

        let valueReg = generateExpression(stmt.initializer)
        let varReg = varRegs[idx]
        let varType = varTypes[idx]
        let llvmType = mapType(varType)
        output = output + "  store " + llvmType + " " + valueReg + ", ptr " + varReg + "\n"
    }

    fun generateExpression(expr: ParserExpressionNode) r: String {
        if expr.kind == "Literal" {
            return generateLiteral(expr)
        } else if expr.kind == "Variable" or expr.kind == "VarExpr" {
            return generateVariable(expr)
        } else if expr.kind == "Binary" {
            return generateBinary(expr)
        } else if expr.kind == "Call" {
            return generateCall(expr)
        } else if expr.kind == "MethodCall" {
            return generateMethodCall(expr)
        } else if expr.kind == "Unary" {
            return generateUnary(expr)
        }
        return "0"
    }

    fun generateLiteral(expr: ParserExpressionNode) r: String {
        if expr.literalType == "Int" or expr.literalType == "Integer" {
            return expr.literalValue
        } else if expr.literalType == "Bool" or expr.literalType == "Boolean" {
            if expr.literalValue == "true" {
                return "1"
            } else {
                return "0"
            }
        } else if expr.literalType == "String" {
            // Find string constant index
            var idx = 0
            var found = false
            while idx < stringConstants.length() {
                if stringConstants[idx] == expr.literalValue {
                    found = true
                    break
                }
                idx = idx + 1
            }

            // Convert to SeenString
            let ptrReg = getNextReg()
            let strLen = expr.literalValue.length() + 1
            output = output + "  " + ptrReg + " = getelementptr [" + strLen.toString() + " x i8], ptr @.str." + idx.toString() + ", i64 0, i64 0\n"

            let strReg = getNextReg()
            output = output + "  " + strReg + " = call %SeenString @seen_cstr_to_str(ptr " + ptrReg + ")\n"
            return strReg
        } else if expr.literalType == "Float" {
            return expr.literalValue
        }
        return "0"
    }

    fun generateVariable(expr: ParserExpressionNode) r: String {
        var varName = expr.variableName
        if varName == "" {
            // Try literalValue for method call receivers
            varName = expr.literalValue
        }
        if varName == "" {
            return "0"
        }

        let idx = findVar(varName)
        if idx < 0 {
            return "0"
        }

        let varReg = varRegs[idx]
        let varType = varTypes[idx]
        let llvmType = mapType(varType)
        let loadReg = getNextReg()
        output = output + "  " + loadReg + " = load " + llvmType + ", ptr " + varReg + "\n"
        return loadReg
    }

    fun generateBinary(expr: ParserExpressionNode) r: String {
        let leftExpr = expr.operands[0]
        let rightExpr = expr.operands[1]

        let leftType = inferExpressionType(leftExpr)
        let rightType = inferExpressionType(rightExpr)

        let leftReg = generateExpression(leftExpr)
        let rightReg = generateExpression(rightExpr)

        let resultReg = getNextReg()

        if expr.operator == "+" {
            if leftType == "String" or rightType == "String" {
                // String concatenation
                output = output + "  " + resultReg + " = call %SeenString @seen_str_concat_ss(%SeenString " + leftReg + ", %SeenString " + rightReg + ")\n"
            } else {
                output = output + "  " + resultReg + " = add i64 " + leftReg + ", " + rightReg + "\n"
            }
        } else if expr.operator == "-" {
            output = output + "  " + resultReg + " = sub i64 " + leftReg + ", " + rightReg + "\n"
        } else if expr.operator == "*" {
            output = output + "  " + resultReg + " = mul i64 " + leftReg + ", " + rightReg + "\n"
        } else if expr.operator == "/" {
            output = output + "  " + resultReg + " = sdiv i64 " + leftReg + ", " + rightReg + "\n"
        } else if expr.operator == "%" {
            output = output + "  " + resultReg + " = srem i64 " + leftReg + ", " + rightReg + "\n"
        } else if expr.operator == "==" {
            if leftType == "String" {
                // String comparison - use memcmp through runtime
                // For now, just compare pointers (TODO: proper string compare)
                output = output + "  " + resultReg + " = icmp eq i64 0, 0\n"  // placeholder
            } else {
                output = output + "  " + resultReg + " = icmp eq i64 " + leftReg + ", " + rightReg + "\n"
            }
        } else if expr.operator == "!=" {
            output = output + "  " + resultReg + " = icmp ne i64 " + leftReg + ", " + rightReg + "\n"
        } else if expr.operator == "<" {
            output = output + "  " + resultReg + " = icmp slt i64 " + leftReg + ", " + rightReg + "\n"
        } else if expr.operator == "<=" {
            output = output + "  " + resultReg + " = icmp sle i64 " + leftReg + ", " + rightReg + "\n"
        } else if expr.operator == ">" {
            output = output + "  " + resultReg + " = icmp sgt i64 " + leftReg + ", " + rightReg + "\n"
        } else if expr.operator == ">=" {
            output = output + "  " + resultReg + " = icmp sge i64 " + leftReg + ", " + rightReg + "\n"
        } else if expr.operator == "and" {
            output = output + "  " + resultReg + " = and i1 " + leftReg + ", " + rightReg + "\n"
        } else if expr.operator == "or" {
            output = output + "  " + resultReg + " = or i1 " + leftReg + ", " + rightReg + "\n"
        }

        return resultReg
    }

    fun generateCall(expr: ParserExpressionNode) r: String {
        let funcName = expr.callee

        // Special case: println
        if funcName == "println" {
            if expr.arguments.length() > 0 {
                let argReg = generateExpression(expr.arguments[0])
                output = output + "  call void @println(%SeenString " + argReg + ")\n"
            }
            return "0"
        }

        // Special case: readText
        if funcName == "readText" {
            if expr.arguments.length() > 0 {
                let argReg = generateExpression(expr.arguments[0])
                let resultReg = getNextReg()
                output = output + "  " + resultReg + " = call %SeenString @readText(%SeenString " + argReg + ")\n"
                return resultReg
            }
            return "0"
        }

        // Special case: writeText
        if funcName == "writeText" {
            if expr.arguments.length() >= 2 {
                let pathReg = generateExpression(expr.arguments[0])
                let contentReg = generateExpression(expr.arguments[1])
                let resultReg = getNextReg()
                output = output + "  " + resultReg + " = call i1 @writeText(%SeenString " + pathReg + ", %SeenString " + contentReg + ")\n"
                return resultReg
            }
            return "0"
        }

        // Generic function call - generate args first, then result reg
        var argRegs = Array<String>()
        var argTypeStrs = Array<String>()
        var argIdx = 0
        while argIdx < expr.arguments.length() {
            let argReg = generateExpression(expr.arguments[argIdx])
            let argType = inferExpressionType(expr.arguments[argIdx])
            argRegs.push(argReg)
            argTypeStrs.push(mapType(argType))
            argIdx = argIdx + 1
        }

        let resultReg = getNextReg()
        output = output + "  " + resultReg + " = call i64 @" + funcName + "("

        argIdx = 0
        while argIdx < argRegs.length() {
            if argIdx > 0 {
                output = output + ", "
            }
            output = output + argTypeStrs[argIdx] + " " + argRegs[argIdx]
            argIdx = argIdx + 1
        }

        output = output + ")\n"
        return resultReg
    }

    fun generateMethodCall(expr: ParserExpressionNode) r: String {
        let methodName = expr.callee

        // Get receiver
        var receiverReg = ""
        var receiverType = "String"  // Default assumption for method calls

        if expr.operands.length() > 0 {
            // Complex receiver (e.g., chained method call or expression)
            receiverReg = generateExpression(expr.operands[0])
            receiverType = inferExpressionType(expr.operands[0])
        } else if expr.literalValue != "" {
            // Simple variable receiver stored in literalValue
            let varName = expr.literalValue
            let idx = findVar(varName)
            if idx >= 0 {
                let varReg = varRegs[idx]
                let varType = varTypes[idx]
                let llvmType = mapType(varType)
                receiverReg = getNextReg()
                receiverType = varType
                output = output + "  " + receiverReg + " = load " + llvmType + ", ptr " + varReg + "\n"
            }
        }

        // Generate arguments BEFORE allocating result register to keep numbers in order
        if methodName == "length" {
            let resultReg = getNextReg()
            output = output + "  " + resultReg + " = call i64 @seen_length(%SeenString " + receiverReg + ")\n"
            return resultReg
        } else if methodName == "toString" {
            let resultReg = getNextReg()
            output = output + "  " + resultReg + " = call %SeenString @seen_int_to_string(i64 " + receiverReg + ")\n"
            return resultReg
        } else if methodName == "startsWith" {
            let argReg = generateExpression(expr.arguments[0])
            let resultReg = getNextReg()
            output = output + "  " + resultReg + " = call i1 @startsWith(%SeenString " + receiverReg + ", %SeenString " + argReg + ")\n"
            return resultReg
        } else if methodName == "endsWith" {
            let argReg = generateExpression(expr.arguments[0])
            let resultReg = getNextReg()
            output = output + "  " + resultReg + " = call i1 @endsWith(%SeenString " + receiverReg + ", %SeenString " + argReg + ")\n"
            return resultReg
        } else if methodName == "contains" {
            let argReg = generateExpression(expr.arguments[0])
            let resultReg = getNextReg()
            output = output + "  " + resultReg + " = call i1 @contains(%SeenString " + receiverReg + ", %SeenString " + argReg + ")\n"
            return resultReg
        } else if methodName == "trim" {
            let resultReg = getNextReg()
            output = output + "  " + resultReg + " = call %SeenString @trim(%SeenString " + receiverReg + ")\n"
            return resultReg
        } else if methodName == "substring" {
            let startReg = generateExpression(expr.arguments[0])
            let endReg = generateExpression(expr.arguments[1])
            let resultReg = getNextReg()
            output = output + "  " + resultReg + " = call %SeenString @seen_substring(%SeenString " + receiverReg + ", i64 " + startReg + ", i64 " + endReg + ")\n"
            return resultReg
        }

        // Generic method call - not supported yet
        return "0"
    }

    fun generateUnary(expr: ParserExpressionNode) r: String {
        let operandReg = generateExpression(expr.operands[0])
        let resultReg = getNextReg()

        if expr.operator == "-" {
            output = output + "  " + resultReg + " = sub i64 0, " + operandReg + "\n"
        } else if expr.operator == "not" or expr.operator == "!" {
            output = output + "  " + resultReg + " = xor i1 " + operandReg + ", 1\n"
        }

        return resultReg
    }

    // Helper functions

    fun getNextReg() r: String {
        let reg = "%" + nextReg.toString()
        nextReg = nextReg + 1
        return reg
    }

    fun getNextBlockLabel() r: String {
        let label = "bb" + nextBlock.toString()
        nextBlock = nextBlock + 1
        return label
    }

    fun mapType(seenType: String) r: String {
        if seenType == "Int" {
            return "i64"
        } else if seenType == "Bool" or seenType == "Boolean" {
            return "i1"
        } else if seenType == "String" {
            return "%SeenString"
        } else if seenType == "Float" {
            return "double"
        } else if seenType == "Void" or seenType == "" {
            return "void"
        }
        // Default to i64 for unknown types
        return "i64"
    }

    fun inferExpressionType(expr: ParserExpressionNode) r: String {
        if expr.kind == "Literal" {
            if expr.literalType == "Int" or expr.literalType == "Integer" {
                return "Int"
            } else if expr.literalType == "String" {
                return "String"
            } else if expr.literalType == "Bool" or expr.literalType == "Boolean" {
                return "Bool"
            } else if expr.literalType == "Float" {
                return "Float"
            }
        } else if expr.kind == "Variable" or expr.kind == "VarExpr" {
            let idx = findVar(expr.variableName)
            if idx >= 0 {
                return varTypes[idx]
            }
        } else if expr.kind == "Binary" {
            if expr.operator == "==" or expr.operator == "!=" or expr.operator == "<" or expr.operator == ">" or expr.operator == "<=" or expr.operator == ">=" or expr.operator == "and" or expr.operator == "or" {
                return "Bool"
            }
            if expr.operator == "+" {
                // Check if string concat
                if expr.operands.length() >= 2 {
                    let leftType = inferExpressionType(expr.operands[0])
                    if leftType == "String" {
                        return "String"
                    }
                }
            }
            return "Int"
        } else if expr.kind == "MethodCall" {
            if expr.callee == "length" or expr.callee == "size" {
                return "Int"
            } else if expr.callee == "toString" or expr.callee == "substring" or expr.callee == "trim" or expr.callee == "generate" {
                return "String"
            } else if expr.callee == "startsWith" or expr.callee == "endsWith" or expr.callee == "contains" or expr.callee == "success" {
                return "Bool"
            }
        } else if expr.kind == "Call" {
            if expr.callee == "readText" {
                return "String"
            } else if expr.callee == "writeText" {
                return "Bool"
            }
        }
        return "Int"
    }

    fun escapeString(str: String) r: String {
        var result = ""
        var i = 0
        while i < str.length() {
            let c = str.substring(i, i + 1)
            if c == "\\" {
                result = result + "\\\\"
            } else if c == "\"" {
                result = result + "\\\""
            } else if c == "\n" {
                result = result + "\\0A"
            } else if c == "\t" {
                result = result + "\\09"
            } else if c == "\r" {
                result = result + "\\0D"
            } else {
                result = result + c
            }
            i = i + 1
        }
        return result
    }

    fun collectStringConstants(program: ProgramNode) r: Void {
        var i = 0
        while i < program.items.length() {
            let item = program.items[i]
            if item.itemType == "Function" {
                collectStringConstantsFromBlock(item.function.body)
            }
            i = i + 1
        }
    }

    fun collectStringConstantsFromBlock(block: BlockNode) r: Void {
        var i = 0
        while i < block.statements.length() {
            collectStringConstantsFromStatement(block.statements[i])
            i = i + 1
        }
    }

    fun collectStringConstantsFromStatement(stmt: StatementNode) r: Void {
        if stmt.kind == "Let" or stmt.kind == "Var" {
            collectStringConstantsFromExpr(stmt.initializer)
        } else if stmt.kind == "Return" {
            collectStringConstantsFromExpr(stmt.returnValue)
        } else if stmt.kind == "Expression" {
            collectStringConstantsFromExpr(stmt.expression)
        } else if stmt.kind == "If" {
            collectStringConstantsFromExpr(stmt.condition)
            collectStringConstantsFromBlock(stmt.thenBranch)
            collectStringConstantsFromBlock(stmt.elseBranch)
        } else if stmt.kind == "While" {
            collectStringConstantsFromExpr(stmt.loopCondition)
            collectStringConstantsFromBlock(stmt.loopBody)
        } else if stmt.kind == "Assignment" {
            collectStringConstantsFromExpr(stmt.initializer)
        }
    }

    fun collectStringConstantsFromExpr(expr: ParserExpressionNode) r: Void {
        if expr.kind == "Literal" and expr.literalType == "String" {
            // Check if already in constants
            var found = false
            var i = 0
            while i < stringConstants.length() {
                if stringConstants[i] == expr.literalValue {
                    found = true
                    break
                }
                i = i + 1
            }
            if not found {
                stringConstants.push(expr.literalValue)
            }
        } else if expr.kind == "Binary" {
            var i = 0
            while i < expr.operands.length() {
                collectStringConstantsFromExpr(expr.operands[i])
                i = i + 1
            }
        } else if expr.kind == "Call" or expr.kind == "MethodCall" {
            var i = 0
            while i < expr.arguments.length() {
                collectStringConstantsFromExpr(expr.arguments[i])
                i = i + 1
            }
            // Also check operands for chained method calls
            i = 0
            while i < expr.operands.length() {
                collectStringConstantsFromExpr(expr.operands[i])
                i = i + 1
            }
        } else if expr.kind == "Unary" {
            if expr.operands.length() > 0 {
                collectStringConstantsFromExpr(expr.operands[0])
            }
        }
    }
}
