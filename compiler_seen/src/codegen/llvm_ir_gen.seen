            output.append("declare ptr @typeNever()\n")
        }
        if not isFuncDefinedInModule("typeUnknown", definedFuncs) {
            output.append("declare ptr @typeUnknown()\n")
        }
        // Typechecker class constructors (used as plain function calls)
        if not isFuncDefinedInModule("ClassType", definedFuncs) {
            output.append("declare ptr @ClassType()\n")
        }
        if not isFuncDefinedInModule("FunctionType", definedFuncs) {
            output.append("declare ptr @FunctionType()\n")
