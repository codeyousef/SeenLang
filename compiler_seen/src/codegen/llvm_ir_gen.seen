// @trivially_copyable classes
var g_triviallyCopyableClasses: String = ""

// @move non-copyable types
var g_moveOnlyClasses: String = ""

// @repr(C) value-type classes (C-compatible layout, stack-allocated)
var g_reprCClassNames: String = ""

// @c_resource lifetime bridging
var g_cResourceClasses: String = ""
var g_cResourceDestructors: String = ""

