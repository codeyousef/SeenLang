// Check if module constant at given index is mutable (from g_moduleConstMutable pipe-delimited string)
fun isModuleConstMutable(idx: Int) r: Bool {
    if g_moduleConstMutable == "" { return true }
    var entryIdx = 0
    var pos = 0
    var segStart = 0
    while pos <= g_moduleConstMutable.length() {
        var atEnd = false
        if pos == g_moduleConstMutable.length() { atEnd = true }
        if not atEnd {
            if g_moduleConstMutable.charAt(pos) == '|' { atEnd = true }
        }
        if atEnd {
            if entryIdx == idx {
                if pos > segStart {
                    let val = g_moduleConstMutable.substring(segStart, pos)
                    if val == "1" { return true }
                    return false
                }
                return true
            }
            entryIdx = entryIdx + 1
            segStart = pos + 1
        }
        pos = pos + 1
    }
    return true
}

// Get the Seen type of module constant at given index
fun getModuleConstSeenType(idx: Int) r: String {
    if g_moduleConstSeenTypes == "" { return "" }
    var entryIdx = 0
    var pos = 0
    var segStart = 0
    while pos <= g_moduleConstSeenTypes.length() {
        var atEnd = false
        if pos == g_moduleConstSeenTypes.length() { atEnd = true }
        if not atEnd {
            if g_moduleConstSeenTypes.charAt(pos) == '|' { atEnd = true }
        }
        if atEnd {
            if entryIdx == idx {
                return g_moduleConstSeenTypes.substring(segStart, pos)
            }
            entryIdx = entryIdx + 1
            segStart = pos + 1
        }
        pos = pos + 1
    }
    return ""
}

// Uses Array<String> for O(1) indexed access. Searches backwards (most recent first).
// CSE (Common Subexpression Elimination) cache lookup.
// Searches backwards through g_cseKeysArr so the most recent entry wins,
// which is critical for correctness when the same expression key appears
// at multiple scope levels (inner scope must shadow outer).
fun cseLookup(key: String) r: String {
    var i = g_cseKeysArr.length() - 1
    while i >= 0 {
        if g_cseKeysArr[i] == key {
            g_cseHits = g_cseHits + 1
            return g_cseValsArr[i]
        }
        i = i - 1
    }
    return ""
}

// O(1) amortized via Array.push().
fun cseRecord(key: String, value: String) r: Void {
    g_cseKeysArr.push(key)
    g_cseValsArr.push(value)
    g_cseCount = g_cseCount + 1
}

// Clear the CSE cache. Called at function/method boundaries to prevent
// stale register references from leaking across functions. The cross-method
// CSE bug (Feb 23 2026) was caused by forgetting cseClear() at the start
// of generateClassMethod: a key like "%4*%7" in method A could match the
// same register numbers in method B, producing self-referential IR.
fun cseClear() r: Void {
    g_cseKeysArr = Array<String>()
    g_cseValsArr = Array<String>()
    g_cseCount = 0
}

// --- Call Count Tracking ---
// Record a call to funcName. Appends entry (duplicates allowed, summed at lookup).
// Capped at 200 entries to avoid O(N^2) string growth on large codebases.
// Uses Array<String>.push() for O(1) amortized. Capped at 200 entries.
fun callCountRecord(funcName: String) r: Void {
    if g_callCountEntries >= 200 { return }
    g_callCountNamesArr.push(funcName)
    g_callCountEntries = g_callCountEntries + 1
}

// Counts occurrences in the array.
fun callCountLookup(funcName: String) r: Int {
    var count = 0
    var i = 0
    while i < g_callCountNamesArr.length() {
        if g_callCountNamesArr[i] == funcName { count = count + 1 }
        i = i + 1
    }
    return count
}

fun callCountClear() r: Void {
    g_callCountNamesArr = Array<String>()
    g_callCountEntries = 0
}

// Initialize boxing arrays for cross-module string collection functions.
// Must be called before collectStringConstantsImpl.
// Creates fresh arrays each time (avoids Array_pop declaration issue in frozen compiler).
fun initCollectionBoxes() r: Void {
    g_selfCallBox = Array<String>()
    g_selfCallBox.push(g_selfCallFuncs)
    g_selfCallBox.push(g_selfCallNames)
    g_selfCallCountBox = Array<Int>()
    g_selfCallCountBox.push(g_selfCallCount)
    g_callCountNamesBox = Array<String>()
    g_callCountNamesBox.push(g_callCountNames)
    g_callCountEntriesBox = Array<Int>()
    g_callCountEntriesBox.push(g_callCountEntries)
}

// Copy box values back to module-level variables after collection.
fun syncCollectionBoxes() r: Void {
    g_selfCallFuncs = g_selfCallBox[g_selfCallBox.length() - 2]
    g_selfCallNames = g_selfCallBox[g_selfCallBox.length() - 1]
    g_selfCallCount = g_selfCallCountBox[g_selfCallCountBox.length() - 1]
    g_callCountNames = g_callCountNamesBox[g_callCountNamesBox.length() - 1]
    g_callCountEntries = g_callCountEntriesBox[g_callCountEntriesBox.length() - 1]
}

// --- ML Decision Logging ---
// Log an optimization decision as a JSONL line.
fun mlLogDecision(category: String, action: String, detail: String) r: Void {
    if not g_mlLogEnabled { return }
    // Use tab-separated values for bootstrap safety (no quote escaping needed)
    let line = category + "\t" + action + "\t" + detail + "\n"
    g_mlDecisionLog = g_mlDecisionLog + line
}

// Log feature vector for ML training data collection.
// category: "inline", "vectorize", "unroll"
// funcName: the function or loop context
// f0-f4: numeric features (meaning depends on category)
fun mlLogFeatures(category: String, funcName: String, f0: Int, f1: Int, f2: Int, f3: Int, f4: Int) r: Void {
    if not g_mlLogEnabled { return }
    let line = "FEAT\t" + category + "\t" + funcName + "\t" + f0.toString() + "\t" + f1.toString() + "\t" + f2.toString() + "\t" + f3.toString() + "\t" + f4.toString() + "\n"
    g_mlDecisionLog = g_mlDecisionLog + line
}

// Set up ML logging with the given output path.
fun setupMLLogging(logPath: String) r: Void {
    if logPath != "" {
        g_mlLogEnabled = true
        g_mlLogPath = logPath
        g_mlDecisionLog = ""
    }
}

// Write accumulated ML decision log to file.
fun writeMLDecisionLog() r: Void {
    if not g_mlLogEnabled { return }
    if g_mlDecisionLog.length() == 0 { return }
    writeText(g_mlLogPath, g_mlDecisionLog)
}

// Get optimization statistics as a formatted string.
fun getOptStats() r: String {
    var stats = ""
    if g_branchesEliminated > 0 {
        stats = stats + "  Branches eliminated: " + g_branchesEliminated.toString() + "\n"
    }
    if g_deadStatementsEliminated > 0 {
        stats = stats + "  Dead statements eliminated: " + g_deadStatementsEliminated.toString() + "\n"
    }
    if g_constantsFolded > 0 {
        stats = stats + "  Constants folded: " + g_constantsFolded.toString() + "\n"
    }
    if g_cseHits > 0 {
        stats = stats + "  CSE hits: " + g_cseHits.toString() + "\n"
    }
    if g_loopsOptimized > 0 {
        stats = stats + "  Loops optimized: " + g_loopsOptimized.toString() + "\n"
    }
    if g_deadStoresEliminated > 0 {
        stats = stats + "  Dead stores eliminated: " + g_deadStoresEliminated.toString() + "\n"
    }
    if g_reductionChainsDetected > 0 {
        stats = stats + "  Reduction chains detected: " + g_reductionChainsDetected.toString() + "\n"
    }
    return stats
}

// Reset all optimization counters (for fresh compilation).
fun resetOptCounters() r: Void {
    g_deadStatementsEliminated = 0
    g_branchesEliminated = 0
    g_constantsFolded = 0
    g_cseHits = 0
    g_loopsOptimized = 0
    g_deadStoresEliminated = 0
    g_stringsDeduped = 0
    g_allocsSunk = 0
    g_escapedAllocsPromoted = 0
    g_reductionChainsDetected = 0
    cseClear()
    // NOTE: g_mlDecisionLog intentionally NOT cleared — accumulates across modules
    g_lastStoreVars = ""
    g_lastStoreCount = 0
    g_inductionVarName = ""
    g_deadStoreSkipVars = ""
    g_loopTileHints = ""
    g_reductionLoopIds = ""
    g_nestedLoopIds = ""
    g_currentFunctionHighPressure = false
    let fnOptions = getCurrentFunctionOptions()
    fnOptions.highPressure = false
    fnOptions.laneWidth = 0
}

// --- Section 9.6: E-Graph expression cost model ---
// --- Section 9.7: ML weight loading ---
// Load heuristic weights from .seen_ml_heuristics config file.
// Format: one "key=value" per line. Supported keys:
//   inline_threshold, unroll_threshold, vectorize_threshold
fun loadMLWeights() r: Void {
    if g_mlWeightsLoaded { return }
    g_mlWeightsLoaded = true
    let mlConfigPath = ".seen_ml_heuristics"
    if not exists(mlConfigPath) { return }
    let mlContent = readText(mlConfigPath)
    if mlContent.length() == 0 { return }
    // Parse line by line: scan for newlines
    var lineStart = 0
    var pos = 0
    while pos <= mlContent.length() {
        var isEnd = false
        if pos == mlContent.length() { isEnd = true }
        if not isEnd {
            if mlContent.charAt(pos) == '\n' { isEnd = true }
        }
        if isEnd {
            if pos > lineStart {
                let line = mlContent.substring(lineStart, pos)
                // Parse "key=value" — find '='
                var eqPos = -1
                var eqScan = 0
                while eqScan < line.length() {
                    if line.charAt(eqScan) == '=' {
                        eqPos = eqScan
                        break
                    }
                    eqScan = eqScan + 1
                }
                if eqPos > 0 {
                    let key = line.substring(0, eqPos)
                    let val = line.substring(eqPos + 1, line.length())
                    let intVal = parseIntManual(val)
                    if key == "inline_threshold" { g_mlInlineThreshold = intVal }
                    if key == "unroll_threshold" { g_mlUnrollThreshold = intVal }
                    if key == "vectorize_threshold" { g_mlVectorizeThreshold = intVal }
                    // ML trained weights (fixed-point scaled by 100)
                    if key == "inline_w0" { g_inlineW0 = parseFixedPoint100(val) }
                    if key == "inline_w1" { g_inlineW1 = parseFixedPoint100(val) }
                    if key == "inline_w2" { g_inlineW2 = parseFixedPoint100(val) }
                    if key == "inline_w3" { g_inlineW3 = parseFixedPoint100(val) }
                    if key == "inline_bias" { g_inlineBias = parseFixedPoint100(val) }
                    if key == "weights_active" { g_mlWeightsActive = true }
                }
            }
            lineStart = pos + 1
        }
        pos = pos + 1
    }
    mlLogDecision("ml-weights", "loaded", "inline:" + g_mlInlineThreshold.toString() + ",unroll:" + g_mlUnrollThreshold.toString() + ",vec:" + g_mlVectorizeThreshold.toString())
}

// ML deterministic replay: look up a prior decision
fun mlReplayLookup(category: String, detail: String) r: String {
    if not g_mlReplayEnabled { return "" }
    if g_mlReplayLog.length() == 0 { return "" }
    // Search for matching line: category\tACTION\tdetail
    var pos = 0
    var lineStart = 0
    while pos < g_mlReplayLog.length() {
        if g_mlReplayLog.charAt(pos) == '\n' {
            let line = g_mlReplayLog.substring(lineStart, pos)
            // Check if line starts with category\t and ends with \tdetail
            let catPrefix = category + "\t"
            if line.startsWith(catPrefix) {
                // Extract detail part (after second tab)
                var tabCount = 0
                var secondTabPos = 0
                var scanPos = 0
                while scanPos < line.length() {
                    if line.charAt(scanPos) == '\t' {
                        tabCount = tabCount + 1
                        if tabCount == 2 { secondTabPos = scanPos }
                    }
                    scanPos = scanPos + 1
                }
                if tabCount >= 2 {
                    let lineDetail = line.substring(secondTabPos + 1, line.length())
                    if lineDetail == detail {
                        // Extract action (between first and second tab)
                        var firstTabPos = 0
                        var ftScan = 0
                        while ftScan < line.length() {
                            if line.charAt(ftScan) == '\t' {
                                firstTabPos = ftScan
                                break
                            }
                            ftScan = ftScan + 1
                        }
                        return line.substring(firstTabPos + 1, secondTabPos)
                    }
                }
            }
            lineStart = pos + 1
        }
        pos = pos + 1
    }
    return ""
}

// Find Nth comma-delimited entry in a string. Returns "" if not found.
// Uses byteAt() to avoid per-byte string allocation (44 = ',')
fun commaGet(data: String, idx: Int) r: String {
    var pos = 0
    var count = 0
    var start = 0
    while pos < data.length() {
        if data.byteAt(pos) == 44 {
            if count == idx {
                return data.substring(start, pos)
            }
            count = count + 1
            start = pos + 1
        }
        pos = pos + 1
    }
    if count == idx {
        return data.substring(start, data.length())
    }
    return ""
}

// Count comma-delimited fields in a string (0 if empty, else count(,)+1).
// Uses byteAt() to avoid per-byte string allocation (44 = ',')
fun countCommaFields(data: String) r: Int {
    if data == "" {
        return 0
    }
    var count = 1
    var pos = 0
    while pos < data.length() {
        if data.byteAt(pos) == 44 {
            count = count + 1
        }
        pos = pos + 1
    }
    return count
}

// Quote LLVM IR identifiers that contain non-ASCII bytes.
// LLVM requires @"name" / %"name" syntax for identifiers with non-ASCII chars.
// ASCII-only names pass through unchanged (zero overhead for common case).
fun quoteIdentIfNeeded(name: String) r: String {
    var i = 0
    while i < name.length() {
        if name.charAt(i).toInt() >= 128 {
            return "\"" + name + "\""
        }
        i = i + 1
    }
    return name
}

fun getCurrentFunctionOptions() r: FunctionLoweringOptions {
    if not g_currentFunctionOptionsInitialized {
        g_currentFunctionOptions = FunctionLoweringOptions.new()
        g_currentFunctionOptionsInitialized = true
    }
    return g_currentFunctionOptions
}

// The main code generator class. One instance is created in main_compiler.seen
// and reused across modules (reset() clears per-module state between modules,
// but struct/function registries persist for cross-module type resolution).
//
// Key field groups:
//   Output buffer:       output (StringBuilder), stringConstants (Array<String>)
//   Register state:      nextReg, nextBlock (SSA counter; boxed in g_regBox/g_blockBox
//                        for mutation by extracted free functions)
//   Variable tracking:   varNames/varRegs/varTypes (parallel arrays, scoped by push,
//                        never popped — findVar searches backwards for shadowing)
//   Struct registry:     structNames/structLayouts/structFieldNames/structFieldTypes/
//                        structSizes/structMethodNames/structMethodRetTypes
//   Function registry:   funcNames/funcRetTypes (return type lookup for call codegen)
//   Per-function state:  currentFunctionReturnType, currentClassName, blockTerminated,
//                        currentLoopCondLabel/EndLabel, preAllocatedVars/Types
//   Dedup tracking:      generatedFunctions/generatedClasses (DO NOT remove reset()
//                        of these — causes "undefined reference" linker errors)
class LLVMIRGenerator {
    var output: StringBuilder
    var stringConstants: Array<String>
    var nextReg: Int
    var nextBlock: Int
    // Using parallel arrays as workaround for Map.get() bug
    var varNames: Array<String>
    var varRegs: Array<String>
    var varTypes: Array<String>
    var indent: Int
    var structNames: Array<String>
    var structLayouts: Array<String>
    var structFieldNames: Array<String>
    var structFieldTypes: Array<String>
    var structLlvmFieldTypes: Array<String>
    var structSizes: Array<Int>
    var structMethodNames: Array<String>
    var structMethodRetTypes: Array<String>
    var funcNames: Array<String>
    var funcRetTypes: Array<String>
    var classMethodBaseNames: Array<String>
    var typeHeaderPath: String
    // Current function context
    var currentFunctionReturnType: String
    var currentClassName: String  // Track current class for method type inference
    var blockTerminated: Bool  // Track if current block has a terminator
    // Loop context for break/continue
    var currentLoopCondLabel: String  // Label to jump to for continue
    var currentLoopEndLabel: String   // Label to jump to for break
    // Pre-allocated variable names and types (for hoisting allocas to entry block)
    var preAllocatedVars: Array<String>
    var preAllocatedTypes: Array<String>
    // Module prefix for per-module compilation (empty for multi-module)
    var stringConstantPrefix: String
    // Track which functions have been emitted in current module (reset per-module)
    var generatedFunctions: Array<String>
    // Track which class types have been emitted in current module (reset per-module)
    var generatedClasses: Array<String>
    // Track if types were loaded from header file (skip emitting class types)
    var typesLoadedFromHeader: Bool
    // Track if runtime declarations were loaded from header file (skip emitting core runtime decls)
    var runtimeDeclsLoaded: Bool
    // Expected array literal type (used to derive element type for [])
    var pendingArrayLiteralType: String
    // Module-level constants parsed from type header (parallel arrays)
    // These are constants like SND_PCM_FORMAT_FLOAT = 14 that are defined at module scope
    var moduleConstantNames: Array<String>
    var moduleConstantValues: Array<String>
    var moduleConstantTypes: Array<String>
    static fun new() r: LLVMIRGenerator {
        initBootstrapFragileGlobalArrays()
        let gen = LLVMIRGenerator{
            output: StringBuilder.new(),
            stringConstants: Array<String>(),
            nextReg: 1,
            nextBlock: 0,
            varNames: Array<String>(),
            varRegs: Array<String>(),
            varTypes: Array<String>(),
            indent: 0,
            structNames: Array<String>(),
            structLayouts: Array<String>(),
            structFieldNames: Array<String>(),
            structFieldTypes: Array<String>(),
            structLlvmFieldTypes: Array<String>(),
            structSizes: Array<Int>(),
            structMethodNames: Array<String>(),
            structMethodRetTypes: Array<String>(),
            funcNames: Array<String>(),
            funcRetTypes: Array<String>(),
            classMethodBaseNames: Array<String>(),
            typeHeaderPath: "",
            currentFunctionReturnType: "",
            currentClassName: "",
            blockTerminated: false,
            currentLoopCondLabel: "",
            currentLoopEndLabel: "",
            preAllocatedVars: Array<String>(),
            preAllocatedTypes: Array<String>(),
            stringConstantPrefix: "",
            generatedFunctions: Array<String>(),
            generatedClasses: Array<String>(),
            typesLoadedFromHeader: false,
            runtimeDeclsLoaded: false,
            pendingArrayLiteralType: "",
            moduleConstantNames: Array<String>(),
            moduleConstantValues: Array<String>(),
            moduleConstantTypes: Array<String>()
        }
        gen.reset()
        return gen
    }

    // Set the path to the type header file (generated by --emit-type-header)
    fun setTypeHeaderPath(path: String) r: Void {
        // Check for encoded ML decision log path: "header_path|ml:log_path"
        var pipeIdx = 0
        var foundPipe = false
        while pipeIdx < path.length() {
            if path.charAt(pipeIdx) == '|' {
                foundPipe = true
                typeHeaderPath = path.substring(0, pipeIdx)
                let rest = path.substring(pipeIdx + 1, path.length())
                if rest.length() > 3 {
                    if rest.substring(0, 3) == "ml:" {
                        let mlPath = rest.substring(3, rest.length())
                        g_mlLogEnabled = true
                        g_mlLogPath = mlPath
                        g_mlDecisionLog = ""
                    }
                }
                break
            }
            pipeIdx = pipeIdx + 1
        }
        if not foundPipe {
            typeHeaderPath = path
        }
    }

    // Set the panic on overflow flag (uses module-level var for bootstrap compat)
    fun setPanicOnOverflow(enabled: Bool) r: Void {
        g_panicOnOverflow = enabled
    }

    // Set bounds checking flag
    fun setBoundsCheckEnabled(enabled: Int) r: Void {
        g_boundsCheckEnabled = enabled
    }

    // Set unused Result warning flag
    fun setWarnUnusedResult(enabled: Int) r: Void {
        g_warnUnusedResult = enabled
    }

    // Safety control setters
    fun setNullSafetyEnabled(enabled: Int) r: Void {
        g_nullSafetyEnabled = enabled
    }
    fun setUninitCheckEnabled(enabled: Int) r: Void {
        g_uninitCheckEnabled = enabled
    }
    fun setStackCheckEnabled(enabled: Int) r: Void {
        g_stackCheckEnabled = enabled
    }
    fun setSanitizerMode(mode: String) r: Void {
        g_sanitizerMode = mode
    }
    // : Set enabled feature flags (pipe-delimited)
    fun setEnabledFeatures(features: String) r: Void {
        g_enabledFeatures = features
    }

    // Reset generator state for per-module compilation (keeps struct/func registries)
    // Reset all per-module state for generating a new module's IR.
    // Clears output buffer, variable tracking, string constants, dedup lists,
    // optimization counters, and module constants. Keeps struct/function
    // registries intact (needed for cross-module type resolution).
    // WARNING: DO NOT remove the reset of generatedFunctions/generatedClasses —
    // they track deduplication within a module and removing them causes
    // "undefined reference" linker errors from missing definitions.
    fun reset() r: Void {
        output = StringBuilder.new()
        stringConstants = Array<String>()
        varNames = Array<String>()
        varRegs = Array<String>()
        varTypes = Array<String>()
        nextReg = 1
        nextBlock = 0
        // Initialize boxed counters (unconditional re-init to handle null module-level arrays)
        g_regBox = Array<Int>()
        g_regBox.push(1)
        g_blockBox = Array<Int>()
        g_blockBox.push(0)
        g_deferExprs = Array<ParserExpressionNode>()
        g_errdeferExprs = Array<ParserExpressionNode>()
        currentFunctionReturnType = ""
        currentClassName = ""
        blockTerminated = false
        currentLoopCondLabel = ""
        currentLoopEndLabel = ""
        preAllocatedVars = Array<String>()
        preAllocatedTypes = Array<String>()
        preAllocatedRegs = Array<String>()
        activeVarCount = 0
        declOrdinalNames = Array<String>()
        declOrdinalCounts = Array<Int>()
        stringConstantPrefix = ""
        generatedFunctions = Array<String>()
        generatedClasses = Array<String>()
        typesLoadedFromHeader = false
        runtimeDeclsLoaded = false
        pendingArrayLiteralType = ""
        g_lateXmDeclareNames = ""
        g_lateXmDeclareStrs = ""
        g_lateXmDeclareCount = 0
        g_initFuncNames = ""
        g_initFuncCount = 0
        // Reset module-level constants (must clear between modules to prevent stale lookups)
        moduleConstantNames = Array<String>()
        moduleConstantValues = Array<String>()
        moduleConstantTypes = Array<String>()
        g_moduleConstMutable = ""
        g_moduleConstSeenTypes = ""
        resetFunctionLoweringOptions(getCurrentFunctionOptions())
        indent = encodeFunctionLoweringOptions(getCurrentFunctionOptions())
        // Reset optimization counters (prevents stale data leaking between modules)
        resetOptCounters()
        // Reset class method tracking (prevents methods from module 0 affecting module 1)
        classMethodBaseNames = Array<String>()
        g_irgenFieldInfoCacheKeys = Array<String>()
        g_irgenFieldInfoCacheIdxs = Array<Int>()
        // Keep struct/func registries for cross-module references
    }

    fun syncIndentFromFunctionOptions() r: Void {
        indent = encodeFunctionLoweringOptions(getCurrentFunctionOptions())
    }

    fun resetFunctionLoweringOptionsState() r: Void {
        resetFunctionLoweringOptions(getCurrentFunctionOptions())
        g_currentFunctionHighPressure = false
        syncIndentFromFunctionOptions()
    }

    fun clearTransientFunctionLoweringState() r: Void {
        clearTransientFunctionLoweringOptions(getCurrentFunctionOptions())
        g_currentFunctionHighPressure = false
        syncIndentFromFunctionOptions()
    }

    fun configureFunctionLoweringOptions(fn: FunctionNode) r: Void {
        let opts = getCurrentFunctionOptions()
        resetFunctionLoweringOptions(opts)
        if hasDecorator(fn, "no_vectorize") {
            opts.vectorizeEnabled = false
        }

        var decIdx = 0
        while decIdx < fn.decorators.length() {
            let dec = fn.decorators[decIdx]
            let decName = dec.name
            let decArgs = dec.arguments
            let decArgCount = decArgs.length()
            if decName == "prefetch" {
                if decArgCount > 0 {
                    let prefetchArg = decArgs[0]
                    if prefetchArg == "write" {
                        opts.prefetchMode = 2
                    } else {
                        opts.prefetchMode = 1
                    }
                } else {
                    opts.prefetchMode = 1
                }
            }
            if decName == "unroll" {
                var unrollVal = 4
                if decArgCount > 0 {
                    let unrollStr = decArgs[0]
                    if unrollStr == "2" { unrollVal = 2 }
                    if unrollStr == "4" { unrollVal = 4 }
                    if unrollStr == "8" { unrollVal = 8 }
                    if unrollStr == "16" { unrollVal = 16 }
                    if unrollStr == "32" { unrollVal = 32 }
                }
                opts.unrollCount = unrollVal
            }
            if decName == "align_to" {
                if decArgCount > 0 {
                    let alignStr = decArgs[0]
                    var alignVal = 0
                    if alignStr == "16" { alignVal = 16 }
                    if alignStr == "32" { alignVal = 32 }
                    if alignStr == "64" { alignVal = 64 }
                    if alignStr == "128" { alignVal = 128 }
                    if alignStr == "256" { alignVal = 256 }
                    if alignVal > 0 {
                        opts.alignTo = alignVal
                    }
                }
            }
            if decName == "preallocate" {
                var regionSizeBytes = 65536
                if decArgCount > 0 {
                    let sizeArg = decArgs[0]
                    if sizeArg == "1024" { regionSizeBytes = 1024 }
                    if sizeArg == "2048" { regionSizeBytes = 2048 }
                    if sizeArg == "4096" { regionSizeBytes = 4096 }
                    if sizeArg == "8192" { regionSizeBytes = 8192 }
                    if sizeArg == "16384" { regionSizeBytes = 16384 }
                    if sizeArg == "32768" { regionSizeBytes = 32768 }
                    if sizeArg == "65536" { regionSizeBytes = 65536 }
                }
                opts.regionSizeBytes = regionSizeBytes
            }
            decIdx = decIdx + 1
        }

        opts.isAsync = fn.isAsync
        syncIndentFromFunctionOptions()
    }

    fun currentFunctionAlignTo() r: Int {
        return getCurrentFunctionOptions().alignTo
    }

    fun currentFunctionRegionSizeBytes() r: Int {
        return getCurrentFunctionOptions().regionSizeBytes
    }

    fun currentFunctionPrefetchMode() r: Int {
        return getCurrentFunctionOptions().prefetchMode
    }

    fun isCurrentFunctionAsyncLowering() r: Bool {
        return getCurrentFunctionOptions().isAsync
    }

    fun markTailCallPosition() r: Void {
        let opts = getCurrentFunctionOptions()
        opts.emitTailCall = true
        syncIndentFromFunctionOptions()
    }

    fun takeTailCallPosition() r: Bool {
        let opts = getCurrentFunctionOptions()
        if opts.emitTailCall {
            opts.emitTailCall = false
            syncIndentFromFunctionOptions()
            return true
        }
        return false
    }

    fun syncState() r: Void {
        let state = getSharedCodegenState()
        syncIndentFromFunctionOptions()
        state.output = output
        state.stringConstants = stringConstants
        state.regBox = g_regBox
        state.blockBox = g_blockBox
        state.varNames = varNames
        state.varRegs = varRegs
        state.varTypes = varTypes
        state.indent = indent
        state.functionOptions = getCurrentFunctionOptions()
        state.registry.structNames = structNames
        state.registry.structLayouts = structLayouts
        state.registry.structFieldNames = structFieldNames
        state.registry.structFieldTypes = structFieldTypes
        state.registry.structLlvmFieldTypes = structLlvmFieldTypes
        state.registry.structSizes = structSizes
        state.registry.structMethodNames = structMethodNames
        state.registry.structMethodRetTypes = structMethodRetTypes
        state.registry.funcNames = funcNames
        state.registry.funcRetTypes = funcRetTypes
        state.registry.classMethodBaseNames = classMethodBaseNames
        state.registry.typeHeaderPath = typeHeaderPath
        state.currentFunctionReturnType = currentFunctionReturnType
        state.currentClassName = currentClassName
        if blockTerminated {
            state.blockTerminated = 1
        } else {
            state.blockTerminated = 0
        }
        state.currentLoopCondLabel = currentLoopCondLabel
        state.currentLoopEndLabel = currentLoopEndLabel
        state.preAllocatedVars = preAllocatedVars
        state.preAllocatedTypes = preAllocatedTypes
        state.stringConstantPrefix = stringConstantPrefix
        state.generatedFunctions = generatedFunctions
        state.generatedClasses = generatedClasses
        state.pendingArrayLiteralType = pendingArrayLiteralType
        state.moduleConstantNames = moduleConstantNames
        state.moduleConstantValues = moduleConstantValues
        state.moduleConstantTypes = moduleConstantTypes
    }

    fun writeBackState() r: Void {
        let state = getSharedCodegenState()
        output = state.output
        stringConstants = state.stringConstants
        varNames = state.varNames
        varRegs = state.varRegs
        varTypes = state.varTypes
        structNames = state.registry.structNames
        structLayouts = state.registry.structLayouts
        structFieldNames = state.registry.structFieldNames
        structFieldTypes = state.registry.structFieldTypes
        structLlvmFieldTypes = state.registry.structLlvmFieldTypes
        structSizes = state.registry.structSizes
        structMethodNames = state.registry.structMethodNames
        structMethodRetTypes = state.registry.structMethodRetTypes
        funcNames = state.registry.funcNames
        funcRetTypes = state.registry.funcRetTypes
        classMethodBaseNames = state.registry.classMethodBaseNames
        typeHeaderPath = state.registry.typeHeaderPath
        currentFunctionReturnType = state.currentFunctionReturnType
        currentClassName = state.currentClassName
        blockTerminated = state.blockTerminated > 0
        currentLoopCondLabel = state.currentLoopCondLabel
        currentLoopEndLabel = state.currentLoopEndLabel
        preAllocatedVars = state.preAllocatedVars
        preAllocatedTypes = state.preAllocatedTypes
        stringConstantPrefix = state.stringConstantPrefix
        generatedFunctions = state.generatedFunctions
        generatedClasses = state.generatedClasses
        pendingArrayLiteralType = state.pendingArrayLiteralType
        moduleConstantNames = state.moduleConstantNames
        moduleConstantValues = state.moduleConstantValues
        moduleConstantTypes = state.moduleConstantTypes
        syncIndentFromFunctionOptions()
    }

    fun getFloatParamRegistryName(fn: FunctionNode) r: String {
        var registryName = fn.name
        if fn.params.length() > 0 {
            let firstParam = fn.params[0]
            if firstParam.name == "this" {
                let firstParamType = firstParam.paramType.typeName
                if isClassType(firstParamType) {
                    let expectedPrefix = firstParamType + "_"
                    if not registryName.startsWith(expectedPrefix) {
                        registryName = expectedPrefix + registryName
                    }
                }
            }
        }
        return registryName
    }

    fun registerFloatParamMetadata(funcName: String, params: Array<ParamNode>) r: Void {
        var paramIdx = 0
        while paramIdx < params.length() {
            let paramTypeName = normalizeDeclaredTypeNode(params[paramIdx].paramType)
            if paramTypeName == "Float" {
                if not hasFloatParamFuncImpl(funcName, paramIdx, g_floatParamFuncNames, g_floatParamParamIdxs) {
                    g_floatParamFuncNames.push(funcName)
                    g_floatParamParamIdxs.push(paramIdx)
                }
            }
            paramIdx = paramIdx + 1
        }
    }

    // Register known data types from the parser that are used as value types
    // These need to be manually registered because 'data' definitions aren't
    // captured as program items like 'class' definitions
    fun registerKnownDataTypes() r: Void {
        registerKnownDataTypesReg(structNames, structLayouts, structFieldNames, structFieldTypes, structLlvmFieldTypes, structSizes, structMethodNames, structMethodRetTypes)
    }


    // Pass 1 entry point: scan a ProgramNode and register all declarations
    // without generating any IR. This populates:
    //   - Struct layouts (structFieldNames/Types/Layouts via registerStructLayout)
    //   - Function signatures (funcNames/funcRetTypes via registerFunction)
    //   - Async function registry (g_asyncFuncNames/RetTypes)
    //   - Enum variant registry (g_enumVariantNames/Tags/FieldTypes)
    //   - Cross-module declare strings (g_xmDeclareNames/Strs for `declare` stubs)
    // Called once per module by main_compiler.seen before any generateSingle().
    // The registries built here form the declarationsHash component of the
    // content-addressed IR cache key.
    fun isRuntimeBackedStringCompatFunction(funcName: String) r: Bool {
        if funcName == "String_toUpperCase" or funcName == "String_toLowerCase" or funcName == "String_toInt" or funcName == "String_toFloat" or funcName == "String_reverse" or funcName == "String_isEmpty" or funcName == "String_count" or funcName == "String_replace" {
            return true
        }
        if funcName == "split" or funcName == "startsWith" or funcName == "endsWith" or funcName == "contains" or funcName == "indexOf" {
            return true
        }
        return false
    }

    fun registerDeclarations(program: ProgramNode) r: Void {
        // First, register known data types
        registerKnownDataTypes()

        preRegisterClassTypes(program)

        var i = 0
        while i < program.items.length() {
            let item = program.items[i]

            if item.itemType == "Class" {
                registerClassDeclarationItem(item)
            }

            // Data types use the same ClassNode structure for their fields
            if item.itemType == "Data" {
                registerDataDeclarationItem(item)
            }

            // Register enum variants for codegen
            // EnumNode.variants is Array<String> (just variant names)
            if item.itemType == "Enum" {
                let enumNode = item.enumNode
                let enumName = enumNode.name
                registerEnumVariants(enumName, enumNode.variants)
            }

            if item.itemType == "Function" {
                registerFunctionDeclarationItem(item)
            }

            i = i + 1
        }

        registerCrossModuleConstants(program)
    }

    fun preRegisterClassTypes(program: ProgramNode) r: Void {
        var itemIdx = 0
        while itemIdx < program.items.length() {
            let item = program.items[itemIdx]
            if item.itemType == "Class" {
                ensureStructEntry(item.classNode.name)
            }
            itemIdx = itemIdx + 1
        }
    }

    fun collectDeclaredParamTypeInfo(params: Array<ParamNode>, paramSeenTypes: Array<String>,
        paramLlvmTypes: Array<String>) r: Void {

        var paramIdx = 0
        while paramIdx < params.length() {
            let paramTypeName = normalizeDeclaredTypeNode(params[paramIdx].paramType)
            paramSeenTypes.push(paramTypeName)
            paramLlvmTypes.push(mapType(paramTypeName))
            paramIdx = paramIdx + 1
        }
    }

    fun registerClassDeclarationItem(item: ItemNode) r: Void {
        registerStructLayout(item.classNode)

        let isStringBuilder = item.classNode.name == "StringBuilder"
        var methodIdx = 0
        while methodIdx < item.classNode.methods.length() {
            let method = item.classNode.methods[methodIdx]
            if isStringBuilder and shouldSkipStringBuilderMethodDeclImpl(method.name) {
                methodIdx = methodIdx + 1
                continue
            }

            let mangledName = item.classNode.name + "_" + method.name
            let methodRetTypeName = resolveMethodReturnType(item.classNode.name, method)
            registerFunction(mangledName, methodRetTypeName)
            if method.isAsync {
                registerAsyncFunction(mangledName, methodRetTypeName)
            }
            registerFloatParamMetadata(mangledName, method.params)

            var methodRetLlvm = mapType(methodRetTypeName)
            if method.isAsync {
                methodRetLlvm = "ptr"
            }
            let methodSeenParamTypes = Array<String>()
            let methodLlvmParamTypes = Array<String>()
            collectDeclaredParamTypeInfo(method.params, methodSeenParamTypes, methodLlvmParamTypes)
            let methodDeclParams = buildDeclareParamsImpl(methodSeenParamTypes, methodLlvmParamTypes, not method.isStatic)
            let methodDecl = buildDeclareStringImpl(quoteIdentIfNeeded(mangledName), methodRetLlvm, methodDeclParams, false)
            recordCrossModuleDeclareEntry(mangledName, methodDecl, item.visibility)
            methodIdx = methodIdx + 1
        }
    }

    fun registerDataDeclarationItem(item: ItemNode) r: Void {
        registerStructLayout(item.classNode)
    }

    fun registerFunctionDeclarationItem(item: ItemNode) r: Void {
        let funcObj = item.function
        let isRuntimeStringCompat = isRuntimeBackedStringCompatFunction(funcObj.name)
        let floatRegistryFuncName = getFloatParamRegistryName(funcObj)
        let funcRetTypeName = resolveFunctionReturnType(funcObj)
        registerFunction(funcObj.name, funcRetTypeName)
        if funcObj.isAsync {
            registerAsyncFunction(funcObj.name, funcRetTypeName)
        }
        registerFloatParamMetadata(floatRegistryFuncName, funcObj.params)

        let bodyStmtCount = funcObj.body.statements.length()
        if not shouldRegisterCrossModuleFunctionImpl(funcObj.name, funcObj.isExtern, bodyStmtCount, isRuntimeStringCompat) {
            return
        }

        var declRetLlvm = mapType(funcRetTypeName)
        if funcObj.isAsync {
            declRetLlvm = "ptr"
        }
        let declSeenParamTypes = Array<String>()
        let declLlvmParamTypes = Array<String>()
        collectDeclaredParamTypeInfo(funcObj.params, declSeenParamTypes, declLlvmParamTypes)
        let declParams = buildDeclareParamsImpl(declSeenParamTypes, declLlvmParamTypes, false)
        let declStr = buildDeclareStringImpl(quoteIdentIfNeeded(funcObj.name), declRetLlvm, declParams, funcObj.isExtern and bodyStmtCount == 0)
        recordCrossModuleDeclareEntry(funcObj.name, declStr, item.visibility)
    }

    fun recordCrossModuleDeclareEntry(symbolName: String, declStr: String, visibility: String) r: Void {
        let namesBox = Array<String>()
        namesBox.push(g_xmDeclareNames)
        let declsBox = Array<String>()
        declsBox.push(g_xmDeclareStrs)
        let visBox = Array<String>()
        visBox.push(g_xmDeclareVis)
        let countBox = Array<Int>()
        countBox.push(g_xmDeclareCount)
        recordCrossModuleDeclareImpl(symbolName, declStr, visibility, namesBox, declsBox, visBox, countBox)
        g_xmDeclareNames = namesBox[0]
        g_xmDeclareStrs = declsBox[0]
        g_xmDeclareVis = visBox[0]
        g_xmDeclareCount = countBox[0]
    }

    fun registerEnumVariants(enumName: String, variants: Array<String>) r: Void {
        let enumTypeNamesBox = Array<String>()
        enumTypeNamesBox.push(g_enumTypeNames)
        let enumVariantNamesBox = Array<String>()
        enumVariantNamesBox.push(g_enumVariantNames)
        let enumVariantTagsBox = Array<String>()
        enumVariantTagsBox.push(g_enumVariantTags)
        let enumVariantFieldTypesBox = Array<String>()
        enumVariantFieldTypesBox.push(g_enumVariantFieldTypes)
        let enumVariantFieldCountsBox = Array<String>()
        enumVariantFieldCountsBox.push(g_enumVariantFieldCounts)
        let enumVariantParentBox = Array<String>()
        enumVariantParentBox.push(g_enumVariantParent)
        let enumTypeCountBox = Array<Int>()
        enumTypeCountBox.push(g_enumTypeCount)
        let enumVariantCountBox = Array<Int>()
        enumVariantCountBox.push(g_enumVariantCount)
        registerEnumVariantsImpl(enumName, variants, enumTypeNamesBox, enumVariantNamesBox, enumVariantTagsBox, enumVariantFieldTypesBox, enumVariantFieldCountsBox, enumVariantParentBox, enumTypeCountBox, enumVariantCountBox)
        g_enumTypeNames = enumTypeNamesBox[0]
        g_enumVariantNames = enumVariantNamesBox[0]
        g_enumVariantTags = enumVariantTagsBox[0]
        g_enumVariantFieldTypes = enumVariantFieldTypesBox[0]
        g_enumVariantFieldCounts = enumVariantFieldCountsBox[0]
        g_enumVariantParent = enumVariantParentBox[0]
        g_enumTypeCount = enumTypeCountBox[0]
        g_enumVariantCount = enumVariantCountBox[0]
    }

    fun registerCrossModuleConstants(program: ProgramNode) r: Void {
        let namesBox = Array<String>()
        namesBox.push(g_xmConstNames)
        let typesBox = Array<String>()
        typesBox.push(g_xmConstTypes)
        let mutableBox = Array<String>()
        mutableBox.push(g_xmConstMutable)
        let seenTypesBox = Array<String>()
        seenTypesBox.push(g_xmConstSeenTypes)
        let countBox = Array<Int>()
        countBox.push(g_xmConstCount)
        registerCrossModuleConstantsImpl(program, namesBox, typesBox, mutableBox, seenTypesBox, countBox)
        g_xmConstNames = namesBox[0]
        g_xmConstTypes = typesBox[0]
        g_xmConstMutable = mutableBox[0]
        g_xmConstSeenTypes = seenTypesBox[0]
        g_xmConstCount = countBox[0]
    }

    // Register a function's return type in the function registry.
    // Used by inferExpressionType/getFunctionReturnType during codegen
    // to determine the result type of function calls.
    fun registerFunction(name: String, retType: String) r: Void {
        funcNames.push(name)
        funcRetTypes.push(retType)
    }


    // Register a method on an existing struct (adds to structMethodNames/RetTypes).
    // Called by @derive/@reflect/@binary/@packet codegen during generateClass()
    // to make synthesized method return types available to inferExpressionType.
    // NOTE: structMethodNames uses comma separator, structMethodRetTypes uses
    // pipe separator — this asymmetry is intentional and must be preserved.
    fun registerStructMethod(className: String, methodName: String, retType: String) r: Void {
        registerStructMethodReg(className, methodName, retType, structNames, structMethodNames, structMethodRetTypes, funcNames, funcRetTypes)
    }


    // Register an async function and its declared return type (pipe-delimited globals)
    fun registerAsyncFunction(name: String, declaredRetType: String) r: Void {
        let namesBox = Array<String>()
        namesBox.push(g_asyncFuncNames)
        let retTypesBox = Array<String>()
        retTypesBox.push(g_asyncFuncRetTypes)
        let countBox = Array<Int>()
        countBox.push(g_asyncFuncCount)
        registerAsyncFunctionImpl(name, declaredRetType, namesBox, retTypesBox, countBox)
        g_asyncFuncNames = namesBox[0]
        g_asyncFuncRetTypes = retTypesBox[0]
        g_asyncFuncCount = countBox[0]
    }

    // Check if a function is async (simple contains check with pipe delimiters)
    fun isAsyncFunction(name: String) r: Bool {
        return isAsyncFunctionImpl(name, g_asyncFuncNames, g_asyncFuncCount)
    }

    // Get the declared return type of an async function
    // Uses byteAt() for scanning (124 = '|')
    fun getAsyncDeclaredRetType(name: String) r: String {
        return getAsyncDeclaredRetTypeImpl(name, g_asyncFuncNames, g_asyncFuncRetTypes, g_asyncFuncCount)
    }

    // Look up a function's return type from the registry. Searches backwards
    // because the same function name can be registered multiple times (e.g.,
    // when a module re-exports it), and the last registration is canonical.
    fun getFunctionReturnType(name: String) r: String {
        return getFunctionReturnTypeReg(name, funcNames, funcRetTypes)
    }

    fun hasCrossModuleDeclare(name: String) r: Bool {
        var i = 0
        while i < g_xmDeclareCount {
            if pipeGet(g_xmDeclareNames, i) == name {
                return true
            }
            i = i + 1
        }
        return false
    }

    fun hasLateUserDeclare(name: String) r: Bool {
        var i = 0
        while i < g_lateXmDeclareCount {
            if pipeGet(g_lateXmDeclareNames, i) == name {
                return true
            }
            i = i + 1
        }
        return false
    }

    fun recordLateUserDeclare(name: String, llvmReturnType: String, argTypeStrs: Array<String>, hasImplicitThis: Int) r: Void {
        if name == "" {
            return
        }
        if name.startsWith("__") {
            return
        }
        if getFunctionReturnType(name) != "" {
            return
        }
        if hasCrossModuleDeclare(name) {
            return
        }
        if hasLateUserDeclare(name) {
            return
        }

        var declRetType = llvmReturnType
        if declRetType == "" {
            declRetType = "void"
        }

        var decl = "declare " + declRetType + " @" + quoteIdentIfNeeded(name) + "("
        if hasImplicitThis == 1 {
            decl = decl + "ptr"
        }

        var i = 0
        while i < argTypeStrs.length() {
            if i > 0 or hasImplicitThis == 1 {
                decl = decl + ", "
            }
            decl = decl + argTypeStrs[i]
            i = i + 1
        }
        decl = decl + ") nounwind\n"

        if g_lateXmDeclareNames == "" {
            g_lateXmDeclareNames = name + "|"
            g_lateXmDeclareStrs = decl + "|"
        } else {
            g_lateXmDeclareNames = g_lateXmDeclareNames + name + "|"
            g_lateXmDeclareStrs = g_lateXmDeclareStrs + decl + "|"
        }
        g_lateXmDeclareCount = g_lateXmDeclareCount + 1
    }

    fun moduleAlreadyDeclaresFunction(ir: String, name: String) r: Bool {
        let symbolSig = "@" + quoteIdentIfNeeded(name) + "("
        var lineStart = 0
        while lineStart < ir.length() {
            var lineEnd = ir.indexOf("\n", lineStart)
            if lineEnd < 0 {
                lineEnd = ir.length()
            }
            let line = ir.substring(lineStart, lineEnd)
            if (line.startsWith("declare ") or line.startsWith("define ")) and line.contains(symbolSig) {
                return true
            }
            lineStart = lineEnd + 1
        }
        return false
    }

    fun emitLateUserDeclares(definedFuncs: Array<String>) r: Void {
        if g_lateXmDeclareCount == 0 {
            return
        }

        var currentIr = output.toString()
        output.append("\n; Late-discovered user external declarations\n")
        var i = 0
        while i < g_lateXmDeclareCount {
            let declName = pipeGet(g_lateXmDeclareNames, i)
            if not isFuncDefinedInModule(declName, definedFuncs) and not moduleAlreadyDeclaresFunction(currentIr, declName) {
                let declStr = pipeGet(g_lateXmDeclareStrs, i)
                output.append(declStr)
                currentIr = currentIr + declStr
                definedFuncs.push(declName)
            }
            i = i + 1
        }
    }


    fun hexToDecimal(value: String) r: String { return hexToDecimalImpl(value) }
    fun trimSpaces(value: String) r: String { return trimSpacesImpl(value) }
    fun removeSpaces(value: String) r: String { return removeSpacesImpl(value) }
    fun getBaseTypeName(typeName: String) r: String { return getBaseTypeNameImpl(typeName) }
    fun normalizeHeaderType(typeName: String) r: String { return normalizeHeaderTypeImpl(typeName) }

    fun alignUp(value: Int, align: Int) r: Int {
        if align <= 1 {
            return value
        }
        let rem = value % align
        if rem == 0 {
            return value
        }
        return value + (align - rem)
    }

    fun extractStructFieldTypes(layout: String) r: Array<String> { return extractStructFieldTypesImpl(layout) }
    fun parseArrayLength(typeName: String) r: Int { return parseArrayLengthImpl(typeName) }
    fun parseArrayElementType(typeName: String) r: String { return parseArrayElementTypeImpl(typeName) }
    fun extractArrayLiteralElementType(arrayType: String) r: String { return extractArrayLiteralElementTypeImpl(arrayType) }
    fun parseSeenStaticArrayLength(typeName: String) r: Int { return parseSeenStaticArrayLengthImpl(typeName) }
    fun parseSeenStaticArrayElementType(typeName: String) r: String { return parseSeenStaticArrayElementTypeImpl(typeName) }
    fun isSeenStaticArrayType(typeName: String) r: Bool { return isSeenStaticArrayTypeImpl(typeName) }

    fun getLlvmTypeAlign(typeName: String) r: Int {
        let trimmed = trimSpaces(typeName)
        let compact = removeSpaces(trimmed)
        if compact == "i1" or compact == "i8" {
            return 1
        }
        if compact == "i16" {
            return 2
        }
        if compact == "i32" or compact == "float" {
            return 4
        }
        if compact == "i64" or compact == "double" or compact == "ptr" {
            return 8
        }
        if compact == "%SeenString" or compact == "{{i64,ptr}}" {
            return 8
        }
        if compact == "%SeenArray" or compact == "{{i64,i64,i64,ptr}}" {
            return 8
        }
        if compact.startsWith("%") {
            let name = trimmed.substring(1, trimmed.length())
            let idx = findStruct(name)
            if idx >= 0 {
                let layout = structLayouts[idx]
                if layout != "" {
                    let fields = extractStructFieldTypes(layout)
                    var maxAlign = 1
                    var i = 0
                    while i < fields.length() {
                        let a = getLlvmTypeAlign(fields[i])
                        if a > maxAlign {
                            maxAlign = a
                        }
                        i = i + 1
                    }
                    return maxAlign
                }
            }
            return 8
        }
        if compact.startsWith("{") {
            let fields = extractStructFieldTypes(trimmed)
            var maxAlign = 1
            var i = 0
            while i < fields.length() {
                let a = getLlvmTypeAlign(fields[i])
                if a > maxAlign {
                    maxAlign = a
                }
                i = i + 1
            }
            return maxAlign
        }
        if compact.startsWith("[") {
            let elemType = parseArrayElementType(trimmed)
            if elemType != "" {
                return getLlvmTypeAlign(elemType)
            }
        }
        return 8
    }

    fun getLlvmTypeSize(typeName: String) r: Int {
        let trimmed = trimSpaces(typeName)
        let compact = removeSpaces(trimmed)
        if compact == "i1" or compact == "i8" {
            return 1
        }
        if compact == "i16" {
            return 2
        }
        if compact == "i32" or compact == "float" {
            return 4
        }
        if compact == "i64" or compact == "double" {
            return 8
        }
        if compact == "ptr" {
            return 8
        }
        if compact == "%SeenString" or compact == "{{i64,ptr}}" {
            return 16
        }
        if compact == "%SeenArray" or compact == "{{i64,i64,i64,ptr}}" {
            return 32
        }
        if compact.startsWith("%") {
            let name = trimmed.substring(1, trimmed.length())
            let idx = findStruct(name)
            if idx >= 0 {
                let sizeVal = structSizes[idx]
                if sizeVal > 0 {
                    return sizeVal
                }
                let layout = structLayouts[idx]
                if layout != "" {
                    return computeStructSizeFromLayout(layout)
                }
            }
            return 0
        }
        if compact.startsWith("{") {
            return computeStructSizeFromLayout(trimmed)
        }
        if compact.startsWith("[") {
            let len = parseArrayLength(trimmed)
            let elemType = parseArrayElementType(trimmed)
            if len >= 0 and elemType != "" {
                let elemSize = getLlvmTypeSize(elemType)
                if elemSize > 0 {
                    return len * elemSize
                }
            }
        }
        return 0
    }

    fun computeStructSizeFromLayout(layout: String) r: Int {
        let fields = extractStructFieldTypes(layout)
        var offset = 0
        var maxAlign = 1
        var i = 0
        while i < fields.length() {
            let fieldType = fields[i]
            let align = getLlvmTypeAlign(fieldType)
            let size = getLlvmTypeSize(fieldType)
            if size <= 0 or align <= 0 {
                return 0
            }
            offset = alignUp(offset, align)
            offset = offset + size
            if align > maxAlign {
                maxAlign = align
            }
            i = i + 1
        }
        return alignUp(offset, maxAlign)
    }

    fun computeMissingStructSizes() r: Void {
        var changed = true
        var pass = 0
        while changed and pass < 8 {
            changed = false
            var i = 0
            while i < structNames.length() {
                if structSizes[i] == 0 {
                    let structName = structNames[i]
                    if not isDataType(structName) {
                        i = i + 1
                        continue
                    }
                    traceGen("computeMissingStructSizes: " + structName)
                    let layout = structLayouts[i]
                    if layout != "" {
                        let sizeVal = computeStructSizeFromLayout(layout)
                        if sizeVal > 0 {
                            structSizes[i] = sizeVal
                            changed = true
                        }
                    }
                }
                i = i + 1
            }
            pass = pass + 1
        }
    }

    fun parseDecimalInt(value: String) r: Int { return parseDecimalIntImpl(value) }
    fun findSubstring(value: String, needle: String) r: Int { return findSubstringImpl(value, needle) }

    // Find a field's Seen type from parallel name/type lists
    // Use byteAt for byte-indexed access (44=',', 124='|')
    fun getFieldTypeFromLists(fieldNamesStr: String, fieldTypesStr: String, fieldName: String) r: String {
        var fieldIdx = 0
        var nameStart = 0
        var pos = 0
        var foundField = false
        while pos <= fieldNamesStr.length() and not foundField {
            if pos == fieldNamesStr.length() or (pos < fieldNamesStr.length() and fieldNamesStr.byteAt(pos) == 44) {
                let name = fieldNamesStr.substring(nameStart, pos)
                if name == fieldName {
                    foundField = true
                } else {
                    fieldIdx = fieldIdx + 1
                    nameStart = pos + 1
                }
            }
            pos = pos + 1
        }

        if not foundField {
            return ""
        }

        var typeIdx = 0
        var typeStart = 0
        pos = 0
        while pos <= fieldTypesStr.length() {
            if pos == fieldTypesStr.length() or (pos < fieldTypesStr.length() and fieldTypesStr.byteAt(pos) == 124) {
                if typeIdx == fieldIdx {
                    return fieldTypesStr.substring(typeStart, pos)
                }
                typeIdx = typeIdx + 1
                typeStart = pos + 1
            }
            pos = pos + 1
        }
        return ""
    }

    fun reorderFieldTypes(existingNames: String, existingTypes: String, newNames: String) r: String {
        var result = ""
        var start = 0
        var pos = 0
        while pos <= newNames.length() {
            var c = '\0'
            if pos < newNames.length() {
                c = newNames.charAt(pos)
            }
            if c == ',' or pos == newNames.length() {
                let name = newNames.substring(start, pos)
                var mappedType = getFieldTypeFromLists(existingNames, existingTypes, name)
                if mappedType == "" {
                    mappedType = "Int"
                }
                if result != "" {
                    result = result + "|"
                }
                result = result + mappedType
                start = pos + 1
            }
            pos = pos + 1
        }
        return result
    }

    fun updateStructLayoutFromHeader(structName: String, structLayout: String) r: Void {
        var idx = findStruct(structName)
        if idx < 0 {
            idx = ensureStructEntry(structName)
        }
        if structLayout != "" {
            structLayouts[idx] = structLayout + ""
            // Force size recomputation from the authoritative header layout.
            structSizes[idx] = 0
        }
    }

    fun updateStructFieldsFromHeader(structName: String, fieldsStr: String) r: Void {
        var idx = findStruct(structName)
        if idx < 0 {
            idx = ensureStructEntry(structName)
        }
        let existingNames = structFieldNames[idx]
        let existingTypes = structFieldTypes[idx]
        let trimmedFields = trimSpaces(fieldsStr)
        if trimmedFields == "" {
            return
        }

        var namesOut = ""
        var llvmTypesOut = ""
        var entryStart = 0
        var pos = 0
        var nesting = 0
        while pos <= trimmedFields.length() {
            var c = '\0'
            if pos < trimmedFields.length() {
                c = trimmedFields.charAt(pos)
            }
            if c == '{' or c == '[' or c == '<' {
                nesting = nesting + 1
            }
            if c == '}' or c == ']' or c == '>' {
                if nesting > 0 {
                    nesting = nesting - 1
                }
            }
            if pos == trimmedFields.length() or (c == ',' and nesting == 0) {
                let entry = trimmedFields.substring(entryStart, pos)
                var colonIdx = -1
                var scan = 0
                while scan < entry.length() {
                    if entry.charAt(scan) == ':' {
                        colonIdx = scan
                        break
                    }
                    scan = scan + 1
                }
                if colonIdx >= 0 {
                    let rawName = trimSpaces(entry.substring(0, colonIdx))
                    let rawType = trimSpaces(entry.substring(colonIdx + 1, entry.length()))
                    let normalizedType = normalizeHeaderType(rawType)
                    if rawName != "" {
                        if namesOut != "" {
                            namesOut = namesOut + ","
                            llvmTypesOut = llvmTypesOut + "|"
                        }
                        namesOut = namesOut + rawName
                        llvmTypesOut = llvmTypesOut + normalizedType
                    }
                }
                entryStart = pos + 1
            }
            pos = pos + 1
        }

        if namesOut == "" {
            return
        }

        structFieldNames[idx] = namesOut
        structLlvmFieldTypes[idx] = llvmTypesOut

        if existingNames != "" and existingTypes != "" {
            let reordered = reorderFieldTypes(existingNames, existingTypes, namesOut)
            if reordered != "" {
                structFieldTypes[idx] = reordered
            }
        }
    }

    fun updateStructSizeFromHeader(structName: String, sizeStr: String) r: Void {
        var idx = findStruct(structName)
        if idx < 0 {
            idx = ensureStructEntry(structName)
        }
        let trimmed = trimSpaces(sizeStr)
        if trimmed == "" {
            return
        }
        let sizeVal = parseDecimalInt(trimmed)
        if sizeVal > 0 {
            structSizes[idx] = sizeVal
        }
    }

    fun applyTypeHeader(headerContent: String) r: Void {
        var currentStruct = ""
        var lineStart = 0
        var pos = 0
        var lineCount = 0
        while pos <= headerContent.length() {
            var isEnd = false
            var c = '\0'
            if pos == headerContent.length() {
                isEnd = true
            }
            if not isEnd {
                c = headerContent.charAt(pos)
            }
            if isEnd or c == '\n' {
                let line = headerContent.substring(lineStart, pos)
                let trimmedLine = trimSpaces(line)
                lineCount = lineCount + 1
                if trimmedLine.startsWith("; Runtime Function Declarations") or trimmedLine.startsWith("; End of auto-generated type declarations") {
                    return
                }
                if trimmedLine.startsWith("%") and trimmedLine.contains("= type") {
                    // Parse "%NAME = type LAYOUT" by finding " = type " position
                    // Since findSubstring is broken, find "=" and verify context
                    var parseIdx = 1 // start after %
                    var foundName = ""
                    var foundLayout = ""
                    while parseIdx < trimmedLine.length() - 7 {
                        // Look for " = type {"
                        if trimmedLine.substring(parseIdx, parseIdx + 9) == " = type {" {
                            foundName = trimmedLine.substring(1, parseIdx)
                            foundLayout = trimmedLine.substring(parseIdx + 8, trimmedLine.length())
                            parseIdx = trimmedLine.length() // break
                        }
                        parseIdx = parseIdx + 1
                    }
                    if foundName != "" {
                        currentStruct = foundName
                        updateStructLayoutFromHeader(foundName, foundLayout)
                    }
                }
                if trimmedLine.startsWith("; Size:") and currentStruct != "" {
                    let sizePart = trimmedLine.substring(7, trimmedLine.length())
                    updateStructSizeFromHeader(currentStruct, sizePart)
                }
                if trimmedLine.startsWith("; Fields:") and currentStruct != "" {
                    let fieldsPart = trimmedLine.substring(9, trimmedLine.length())
                    updateStructFieldsFromHeader(currentStruct, fieldsPart)
                }
                // Parse module-level constants: @NAME = constant i64 VALUE
                if trimmedLine.startsWith("@") and trimmedLine.contains("= constant") {
                    // Extract name (between @ and first space)
                    var nameEnd = 1
                    while nameEnd < trimmedLine.length() and trimmedLine.charAt(nameEnd) != ' ' {
                        nameEnd = nameEnd + 1
                    }
                    let constName = trimmedLine.substring(1, nameEnd)

                    // Find "constant " and extract type and value
                    // Format: @NAME = constant TYPE VALUE
                    var constIdx = 0
                    var foundConst = false
                    while constIdx < trimmedLine.length() - 9 {
                        if trimmedLine.substring(constIdx, constIdx + 9) == "constant " {
                            foundConst = true
                            // After "constant " comes type and value
                            let remainder = trimmedLine.substring(constIdx + 9, trimmedLine.length())
                            // Find space between type and value
                            var spaceIdx = 0
                            while spaceIdx < remainder.length() and remainder.charAt(spaceIdx) != ' ' {
                                spaceIdx = spaceIdx + 1
                            }
                            let constType = remainder.substring(0, spaceIdx)
                            let constValue = remainder.substring(spaceIdx + 1, remainder.length())

                            moduleConstantNames.push(constName)
                            moduleConstantTypes.push(constType)
                            moduleConstantValues.push(constValue)
                            break
                        }
                        constIdx = constIdx + 1
                    }
                }
                lineStart = pos + 1
            }
            pos = pos + 1
        }
    }

    // Helper to store variable
    // Push or reactivate a variable binding in the current lexical scope.
    fun storeVar(name: String, reg: String, varType: String) r: Void {
        if activeVarCount < varNames.length() {
            varNames[activeVarCount] = name
            varRegs[activeVarCount] = reg
            varTypes[activeVarCount] = varType
        } else {
            varNames.push(name)
            varRegs.push(reg)
            varTypes.push(varType)
        }
        activeVarCount = activeVarCount + 1
    }

    // Helper to find variable. Searches backwards (newest variable first) since
    // most references are to recently declared variables.
    fun findVar(name: String) r: Int {
        var i = activeVarCount - 1
        while i >= 0 {
            if varNames[i] == name {
                return i
            }
            i = i - 1
        }
        return -1
    }

    // Helper to find variable type (checks both varTypes and preAllocatedTypes)
    // Searches backwards for speed.
    fun findVarType(name: String) r: String {
        // First check active variables
        let idx = findVar(name)
        if idx >= 0 {
            return varTypes[idx]
        }
        // Then check pre-allocated variables (during collection phase)
        var i = preAllocatedVars.length() - 1
        while i >= 0 {
            if preAllocatedVars[i] == name {
                return preAllocatedTypes[i]
            }
            i = i - 1
        }
        let constIdx = findModuleConstant(name)
        if constIdx >= 0 {
            let seenType = getModuleConstSeenType(constIdx)
            if seenType != "" {
                return seenType
            }
            let constType = moduleConstantTypes[constIdx]
            if constType == "double" { return "Float" }
            if constType == "i1" { return "Bool" }
            if constType == "%SeenString" { return "String" }
            if constType == "ptr" { return "ptr" }
            return "Int"
        }
        return ""
    }

    // Helper to find module constant by name. Searches backwards.
    // Falls back to cross-module constant registry if not found in current module.
    fun findModuleConstant(name: String) r: Int {
        var i = moduleConstantNames.length() - 1
        while i >= 0 {
            if moduleConstantNames[i] == name {
                return i
            }
            i = i - 1
        }
        // Check cross-module constant registry (pipe-delimited)
        if g_xmConstCount > 0 {
            var xi = 0
            while xi < g_xmConstCount {
                let xcName = pipeGet(g_xmConstNames, xi)
                let xcType = pipeGet(g_xmConstTypes, xi)
                if isValidCrossModuleConstantEntryImpl(xcName, xcType) and xcName == name {
                    // Promote into per-module arrays so subsequent lookups
                    // and type/mutability access work at the returned index
                    let xcMut = pipeGet(g_xmConstMutable, xi)
                    let xcSeenType = pipeGet(g_xmConstSeenTypes, xi)
                    moduleConstantNames.push(name)
                    moduleConstantTypes.push(xcType)
                    moduleConstantValues.push("0")
                    if g_moduleConstMutable == "" {
                        g_moduleConstMutable = xcMut
                    } else {
                        g_moduleConstMutable = g_moduleConstMutable + "|" + xcMut
                    }
                    if g_moduleConstSeenTypes == "" {
                        g_moduleConstSeenTypes = xcSeenType
                    } else {
                        g_moduleConstSeenTypes = g_moduleConstSeenTypes + "|" + xcSeenType
                    }
                    return moduleConstantNames.length() - 1
                }
                xi = xi + 1
            }
        }
        return -1
    }

    // Helper to get module constant value as LLVM IR reference
    // Returns "@NAME" if found, or empty string if not a module constant
    fun getModuleConstantRef(name: String) r: String {
        let idx = findModuleConstant(name)
        if idx >= 0 {
            return "@" + quoteIdentIfNeeded(name)
        }
        return ""
    }

    // Helper to check if a name is a module constant
    fun isModuleConstant(name: String) r: Bool {
        return findModuleConstant(name) >= 0
    }

    // Look up a struct/class by name in the struct registry, returning its
    // index or -1 if not found. Searches backwards because recently registered
    // structs (from the current module) are more likely to be referenced than
    // early ones (from the standard library), giving O(1) for local types.
    fun findStruct(name: String) r: Int {
        return findStructReg(name, structNames)
    }


    // Register a child→parent inheritance relationship
    fun registerParentClass(childName: String, parentName: String) r: Void {
        if g_inheritanceCount > 0 {
            g_inheritanceChildNames = g_inheritanceChildNames + "|"
            g_inheritanceParentNames = g_inheritanceParentNames + "|"
        }
        g_inheritanceChildNames = g_inheritanceChildNames + childName
        g_inheritanceParentNames = g_inheritanceParentNames + parentName
        g_inheritanceCount = g_inheritanceCount + 1
    }

    // Look up the parent class name for a given child class (returns "" if none)
    fun lookupParentClass(childName: String) r: String {
        var idx = 0
        while idx < g_inheritanceCount {
            let child = pipeGet(g_inheritanceChildNames, idx)
            if child == childName {
                var s = pipeGet(g_inheritanceParentNames, idx)
                return s
            }
            idx = idx + 1
        }
        return ""
    }

    // Get or create a placeholder struct registry entry. Returns the index.
    // Used during registerDeclarations to pre-register class names before
    // their full layout is known, enabling self-referential struct fields.
    fun ensureStructEntry(name: String) r: Int {
        return ensureStructEntryReg(name, structNames, structLayouts, structFieldNames, structFieldTypes, structLlvmFieldTypes, structSizes, structMethodNames, structMethodRetTypes)
    }


    // Pre-scan a function's block to collect all variable declarations.
    // This enables alloca hoisting: all allocas are emitted in the entry
    // block (before any branches), which is required by LLVM for correct
    // mem2reg promotion to SSA registers. Without hoisting, allocas inside
    // loops would create new stack slots per iteration.
    // Stores names and types in preAllocatedVars/preAllocatedTypes.
    fun collectVariableDeclarations(block: BlockNode) r: Void {
        var i = 0
        while i < block.statements.length() {
            let stmt = block.statements[i]
            collectStmtVars(stmt)
            i = i + 1
        }
    }

    // Infer a declaration initializer type with an extra fast path for
    // static method calls like Counter.new() and Foo.fromJson(...).
    fun inferDeclarationInitializerType(expr: ParserExpressionNode) r: String {
        if expr.kind == "MethodCall" {
            var receiverName = expr.literalValue
            if receiverName == "" and expr.operands.length() > 0 {
                let receiverExpr = expr.operands[0]
                if receiverExpr.kind == "Variable" or receiverExpr.kind == "VarExpr" {
                    receiverName = receiverExpr.variableName
                    if receiverName == "" {
                        receiverName = receiverExpr.literalValue
                    }
                }
            }
            if receiverName != "" {
                let staticReturnType = getMethodReturnType(receiverName, expr.callee)
                if staticReturnType != "" {
                    return staticReturnType
                }
                if expr.callee == "new" and findStruct(receiverName) >= 0 {
                    return receiverName
                }
            }
        }
        return inferExpressionType(expr)
    }

    // Helper to collect variables from a single statement - separate method to avoid merging
    fun collectStmtVars(stmt: StatementNode) r: Void {
        // Handle Let/Var declarations
        if stmt.kind == "Let" or stmt.kind == "Var" {
            var varType = normalizeDeclaredTypeNode(stmt.variableType)
            if varType == "" or varType == "Unknown" or varType == "Void" {
                varType = inferDeclarationInitializerType(stmt.initializer)
            }
            if varType == "" or varType == "Unknown" or varType == "Void" {
                varType = "Int"
            }
            // Debug: trace VNode-related variable types
            if varType.contains("VNode") or varType.contains("Vec<") or stmt.variableName == "div" or stmt.variableName == "spanChild" or stmt.variableName == "span" {
                traceGen("collectStmtVars: " + stmt.variableName + " -> " + varType)
            }
            preAllocatedVars.push(stmt.variableName)
            preAllocatedTypes.push(varType)
        }
        // Handle If statements
        if stmt.kind == "If" {
            collectVariableDeclarations(stmt.thenBranch)
            collectVariableDeclarations(stmt.elseBranch)
        }
        // Handle While statements
        if stmt.kind == "While" {
            collectVariableDeclarations(stmt.loopBody)
        }
        // Handle For statements
        if stmt.kind == "For" {
            collectVariableDeclarations(stmt.loopBody)
        }
        // Handle ForIn statements - pre-allocate loop variable and collect body vars
        // ForIn stores: variableName=loop var, expression=iterable, loopBody=body
        if stmt.kind == "ForIn" {
            if stmt.variableName != "" {
                preAllocatedVars.push(stmt.variableName)
                // Infer element type from iterable
                var forInElemType = "Int"
                let forInExpr = stmt.expression
                let forInExprKind = forInExpr.kind
                if forInExprKind != "Range" {
                    // Try direct inference first
                    let iterType = inferExpressionType(forInExpr)
                    var iterTypeResolved = false
                    if iterType.startsWith("Array<") {
                        forInElemType = iterType.substring(6, iterType.length() - 1)
                        iterTypeResolved = true
                    }
                    if not iterTypeResolved and iterType == "String" {
                        forInElemType = "Char"
                        iterTypeResolved = true
                    }
                    // If iterable is ArrayLiteral, infer from first element
                    if not iterTypeResolved and forInExprKind == "ArrayLiteral" {
                        if forInExpr.arguments.length() > 0 {
                            let firstElem = forInExpr.arguments[0]
                            let firstType = inferExpressionType(firstElem)
                            if firstType != "" {
                                forInElemType = firstType
                            }
                        }
                    }
                }
                preAllocatedTypes.push(forInElemType)
                // Pre-allocate index counter in entry block (allows LLVM mem2reg promotion)
                let forInIdxName = "__forin_idx_" + stmt.variableName
                preAllocatedVars.push(forInIdxName)
                preAllocatedTypes.push("Int")
            }
            collectVariableDeclarations(stmt.loopBody)
        }
        return
    }

    // Check if a variable has been pre-allocated, return its index or -1
    fun findPreAllocated(name: String) r: Int {
        var i = 0
        while i < preAllocatedVars.length() {
            if preAllocatedVars[i] == name {
                return i
            }
            i = i + 1
        }
        return -1
    }

    fun findPreAllocatedOccurrence(name: String, ordinal: Int) r: Int {
        var seen = 0
        var i = 0
        while i < preAllocatedVars.length() {
            if preAllocatedVars[i] == name {
                seen = seen + 1
                if seen == ordinal {
                    return i
                }
            }
            i = i + 1
        }
        return -1
    }

    fun nextDeclarationOrdinal(name: String) r: Int {
        var i = 0
        while i < declOrdinalNames.length() {
            if declOrdinalNames[i] == name {
                let nextOrdinal = declOrdinalCounts[i] + 1
                declOrdinalCounts[i] = nextOrdinal
                return nextOrdinal
            }
            i = i + 1
        }
        declOrdinalNames.push(name)
        declOrdinalCounts.push(1)
        return 1
    }

    // Emit pool_free calls for all local class-type variables before a return
    // skipVar: name of the variable being returned (should not be freed)
    // Emit free calls for all heap-allocated local variables at function exit.
    // Implements automatic memory management: class-type and Array-type locals
    // are freed. The skipVar parameter excludes the return value variable
    // (which is transferred to the caller, not freed).
    fun emitAutoFreeLocals(skipVar: String) r: Void {
        var i = 0
        while i < preAllocatedVars.length() {
            let varName = preAllocatedVars[i]
            let varType = preAllocatedTypes[i]
            // Only free class types (heap-allocated, stored as i64 pointer-as-int)
            // @repr(C) value types are stack-allocated — do NOT free
            var isReprCLocal = false
            if g_reprCClassNames != "" {
                if g_reprCClassNames.contains(varType + "|") {
                    isReprCLocal = true
                }
            }
            if isClassType(varType) and varName != skipVar and not isReprCLocal {
                // Look up struct size for pool_free
                let baseType = getBaseTypeName(varType)
                let sIdx = findStruct(baseType)
                var sSize = 0
                if sIdx >= 0 {
                    sSize = structSizes[sIdx]
                }
                // Only free if we know the size and it fits in pool
                if sSize > 0 and sSize <= 80 {
                    let vidx = findVar(varName)
                    if vidx >= 0 {
                        let varReg = varRegs[vidx]
                        let loadReg = getNextReg()
                        output.append("  " + loadReg + " = load i64, ptr " + varReg + "\n")
                        let ptrReg = getNextReg()
                        output.append("  " + ptrReg + " = inttoptr i64 " + loadReg + " to ptr\n")
                        output.append("  call void @seen_pool_free(ptr " + ptrReg + ", i64 " + sSize.toString() + ")\n")
                    }
                }
            }
            i = i + 1
        }
        // @c_resource scope-exit destructor: call registered destructor for each local
        if g_cResourceClasses != "" {
            i = 0
            while i < preAllocatedVars.length() {
                let crVarName = preAllocatedVars[i]
                let crVarType = preAllocatedTypes[i]
                if crVarName != skipVar and g_cResourceClasses.contains(crVarType + "|") {
                    // Find destructor by matching pipe index in g_cResourceClasses/g_cResourceDestructors
                    var crDestructor = "free"
                    var crSearchPos = 0
                    var crIdx = 0
                    while crSearchPos < g_cResourceClasses.length() {
                        var crNextPipe = g_cResourceClasses.indexOf("|", crSearchPos)
                        if crNextPipe < 0 { crNextPipe = g_cResourceClasses.length() }
                        let crEntry = g_cResourceClasses.substring(crSearchPos, crNextPipe)
                        if crEntry == crVarType {
                            // Found matching index, extract destructor at same index
                            var dSearchPos = 0
                            var dIdx = 0
                            while dSearchPos < g_cResourceDestructors.length() {
                                var dNextPipe = g_cResourceDestructors.indexOf("|", dSearchPos)
                                if dNextPipe < 0 { dNextPipe = g_cResourceDestructors.length() }
                                if dIdx == crIdx {
                                    crDestructor = g_cResourceDestructors.substring(dSearchPos, dNextPipe)
                                    dSearchPos = g_cResourceDestructors.length()
                                }
                                dIdx = dIdx + 1
                                dSearchPos = dNextPipe + 1
                            }
                            crSearchPos = g_cResourceClasses.length()
                        }
                        crIdx = crIdx + 1
                        crSearchPos = crNextPipe + 1
                    }
                    let crVarIdx = findVar(crVarName)
                    if crVarIdx >= 0 {
                        let crVarReg = varRegs[crVarIdx]
                        let crLoadReg = getNextReg()
                        output.append("  " + crLoadReg + " = load i64, ptr " + crVarReg + "\n")
                        output.append("  call void @" + crDestructor + "(i64 " + crLoadReg + ") ; @c_resource destructor\n")
                    }
                }
                i = i + 1
            }
        }
    }

    // Emit allocas for all pre-allocated variables at function entry
    // This ensures all allocas are in the entry block, avoiding domination errors
    fun emitPreAllocatedAllocas() r: Void {
        preAllocatedRegs = Array<String>()
        var i = 0
        while i < preAllocatedVars.length() {
            let varType = preAllocatedTypes[i]
            let llvmType = mapType(varType)
            let reg = getNextReg()
            // Add explicit alignment for better SIMD codegen
            if llvmType == "i64" or llvmType == "double" or llvmType == "ptr" {
                output.append("  " + reg + " = alloca " + llvmType + ", align 8\n")
            } else {
                output.append("  " + reg + " = alloca " + llvmType + "\n")
            }
            preAllocatedRegs.push(reg)
            i = i + 1
        }
    }

    // Get size of a Seen type in bytes when stored in a class/struct field
    // This is the STORAGE size, not the full object size
    // - Primitives: their natural size (aligned to 8)
    // - String: 16 bytes (inline %SeenString struct)
    // - Array: 8 bytes (ptr to heap-allocated SeenArray)
    // - Classes: 8 bytes (i64 pointer-as-int)
    // - Data types: their full inline size
    fun getTypeSize(typeName: String) r: Int {
        if isSeenStaticArrayType(typeName) {
            let arrayLen = parseSeenStaticArrayLength(typeName)
            let elementSeenType = parseSeenStaticArrayElementType(typeName)
            if arrayLen > 0 and elementSeenType != "" {
                let elementSize = getLlvmTypeSize(mapType(elementSeenType))
                if elementSize > 0 {
                    return arrayLen * elementSize
                }
            }
        }
        if typeName == "Int" {
            return 8
        }
        if typeName == "Bool" or typeName == "Boolean" {
            // Bool is i1 but takes 8 bytes in struct layout due to alignment
            // (next field will be aligned to 8 bytes anyway)
            return 8
        }
        if typeName == "Float" {
            return 8
        }
        if typeName == "String" {
            return 16  // %SeenString = { i64, ptr } = 8 + 8 (stored inline)
        }
        if typeName.startsWith("Array<") or typeName.startsWith("List<") {
            // Arrays are stored as ptr to heap-allocated SeenArray (NOT inline!)
            return 8
        }
        // Check if this is a data type (stored inline)
        if isDataType(typeName) {
            return getDataTypeSize(typeName)
        }
        // All other types (classes) are stored as i64 (pointer-as-int) = 8 bytes
        return 8
    }

    // Register a struct layout from a ClassNode
    // Build and register the LLVM struct layout for a class/data type.
    // Computes the layout string (e.g., "{ %SeenString, i64, ptr }"), field
    // name/type lists, and byte size. If the class extends a parent, parent
    // fields are prepended (inheritance uses composition, not vtables).
    // Also registers class methods into structMethodNames/structMethodRetTypes
    // and builds classMethodBaseNames for skipping standalone function duplicates.
    // WARNING: field order must exactly match struct_layouts.seen — a GEP index
    // mismatch causes "out of bounds" crashes at runtime.
    fun registerStructLayout(classNode: ClassNode) r: Void {
        // Ensure entry exists (supports self-references during layout)
        let structIdx = ensureStructEntry(classNode.name)
        let hasLayout = structLayouts[structIdx] != ""
        traceGen("registerStructLayout: " + classNode.name + " structIdx=" + structIdx.toString() + " namesLen=" + structNames.length().toString() + " fieldNamesLen=" + structFieldNames.length().toString())
        traceGen("registerStructLayout: " + classNode.name + " fields=" + classNode.fields.length().toString())

        // Const generics: extract numeric values from type name (e.g., "Grid<Int,8,8>")
        let cgName = classNode.name
        if cgName.contains("<") {
            let cgLt = cgName.indexOf("<", 0)
            let cgGt = cgName.indexOf(">", cgLt)
            if cgLt > 0 and cgGt > cgLt {
                let cgInner = cgName.substring(cgLt + 1, cgGt)
                // Parse comma-separated params, register numeric ones
                var cgPos = 0
                var cgParamIdx = 0
                while cgPos <= cgInner.length() {
                    var cgNextComma = cgInner.indexOf(",", cgPos)
                    if cgNextComma < 0 { cgNextComma = cgInner.length() }
                    let cgParam = cgInner.substring(cgPos, cgNextComma)
                    // Check if param is numeric (starts with digit)
                    if cgParam.length() > 0 {
                        let cgFirstChar = cgParam.byteAt(0)
                        if cgFirstChar >= 48 and cgFirstChar <= 57 {
                            let cgKey = cgName + ":param" + cgParamIdx.toString()
                            g_constGenericNames = g_constGenericNames + cgKey + "|"
                            g_constGenericValues = g_constGenericValues + cgParam + "|"
                        }
                    }
                    cgParamIdx = cgParamIdx + 1
                    cgPos = cgNextComma + 1
                }
            }
        }

        // Build the layout from fields
        var layout = "{ "
        var fieldNames = ""
        var fieldTypes = ""
        var totalSize = 0

        // Prepend parent fields if this class extends another
        var pfcount = 0
        let pnLen = classNode.parentName.length()
        if pnLen > 0 {
            registerParentClass(classNode.name, classNode.parentName)
            let parentIdx = findStruct(classNode.parentName)
            if parentIdx >= 0 {
                let parentFN = structFieldNames[parentIdx]
                let parentFT = structFieldTypes[parentIdx]
                pfcount = countCommaFields(parentFN)
                var pfi = 0
                while pfi < pfcount {
                    let pfn = commaGet(parentFN, pfi)
                    let pft = pipeGet(parentFT, pfi)
                    let pllvm = mapType(pft)
                    if pfi > 0 {
                        layout = layout + ", "
                        fieldNames = fieldNames + ","
                        fieldTypes = fieldTypes + "|"
                    }
                    layout = layout + pllvm
                    fieldNames = fieldNames + pfn
                    fieldTypes = fieldTypes + pft
                    totalSize = totalSize + getTypeSize(pft)
                    pfi = pfi + 1
                }
            }
        }

        // Count own fields, skipping @type_alias: synthetic fields
        var ownCount = 0
        var ownScanI = 0
        while ownScanI < classNode.fields.length() {
            let ownScanField = classNode.fields[ownScanI]
            let ownScanName = ownScanField.name
            if not ownScanName.startsWith("@type_alias:") {
                ownCount = ownCount + 1
            }
            ownScanI = ownScanI + 1
        }
        var totalFieldCount = pfcount + ownCount
        if totalFieldCount == 0 {
            // Empty struct - add dummy i8 byte for LLVM validity
            layout = layout + "i8"
            totalSize = 1
        } else {
            var i = 0
            var realOwnIdx = 0
            while i < classNode.fields.length() {
                let field = classNode.fields[i]
                let fieldNameStr = field.name
                // Skip synthetic @type_alias fields
                if fieldNameStr.startsWith("@type_alias:") {
                    i = i + 1
                    // continue workaround (stage1 doesn't have continue)
                } else {
                    traceGen("registerStructLayout: " + classNode.name + " field idx=" + realOwnIdx.toString())
                    let sepIdx = pfcount + realOwnIdx
                    if sepIdx > 0 {
                        layout = layout + ", "
                        fieldNames = fieldNames + ","
                        fieldTypes = fieldTypes + "|"  // Use | as separator for types (not comma, due to generics)
                    }
                    // Strip :bitfield(N) annotation from type for layout, extract width
                    let fieldParamType = field.paramType
                    var fieldType = normalizeDeclaredTypeNode(fieldParamType)
                    if fieldType.contains(":bitfield(") {
                        let bfLayoutPos = fieldType.indexOf(":bitfield(", 0)
                        if bfLayoutPos >= 0 {
                            let bfWidthStart = bfLayoutPos + 10
                            let bfWidthEnd = fieldType.indexOf(")", bfWidthStart)
                            if bfWidthEnd > bfWidthStart {
                                let bfWidthStr = fieldType.substring(bfWidthStart, bfWidthEnd)
                                // Register bitfield metadata
                                let bfKey = classNode.name + "." + fieldNameStr
                                g_bitfieldKeys = g_bitfieldKeys + bfKey + "|"
                                g_bitfieldWidths = g_bitfieldWidths + bfWidthStr + "|"
                                g_bitfieldOffsets = g_bitfieldOffsets + "0|"
                                g_bitfieldCount = g_bitfieldCount + 1
                            }
                            fieldType = fieldType.substring(0, bfLayoutPos)
                        }
                    }
                    let llvmType = mapType(fieldType)

                    layout = layout + llvmType
                    fieldNames = fieldNames + fieldNameStr
                    fieldTypes = fieldTypes + fieldType
                    totalSize = totalSize + getLlvmTypeSize(llvmType)

                    realOwnIdx = realOwnIdx + 1
                    i = i + 1
                }
            }
        }

        layout = layout + " }"
        traceGen("registerStructLayout: " + classNode.name + " layout built")

        // Collect method signatures
        var methodNames = ""
        var methodRetTypes = ""
        var mi = 0
        traceGen("registerStructLayout: " + classNode.name + " methods len=" + classNode.methods.length().toString())
        while mi < classNode.methods.length() {
            if mi > 0 {
                methodNames = methodNames + ","
                methodRetTypes = methodRetTypes + "|"
            }
            let method = classNode.methods[mi]
            methodNames = methodNames + method.name
            methodRetTypes = methodRetTypes + resolveMethodReturnType(classNode.name, method)
            // Register base method name for generic class method skip detection
            // Check if already registered to avoid duplicates
            var alreadyRegistered = false
            var cri = 0
            while cri < classMethodBaseNames.length() {
                if classMethodBaseNames[cri] == method.name {
                    alreadyRegistered = true
                }
                cri = cri + 1
            }
            if not alreadyRegistered {
                classMethodBaseNames.push(method.name)
            }
            mi = mi + 1
        }

        // Store in registry - always overwrite layout from classNode.fields
        // because it is authoritative (matches emitClassType output)
        traceGen("registerStructLayout: " + classNode.name + " updating registry")
        structLayouts[structIdx] = layout
        traceGen("registerStructLayout: " + classNode.name + " updating field types")
        traceGen("registerStructLayout: " + classNode.name + " fieldNamesLen(before)=" + structFieldNames.length().toString())
        structFieldNames[structIdx] = fieldNames
        structFieldTypes[structIdx] = fieldTypes
        // Only update size if not already set (preserve hardcoded sizes for data types)
        // Class types always compute size from fields since their layout can vary
        if structSizes[structIdx] == 0 or not isDataType(classNode.name) {
            structSizes[structIdx] = totalSize
        }
        structMethodNames[structIdx] = methodNames
        structMethodRetTypes[structIdx] = methodRetTypes
    }

    // Get field index and type from registered struct
    // Resolve the GEP (getelementptr) index for a struct field access.
    // Returns the 0-based field index within the LLVM struct type.
    // Hardcodes indices for known AST types (FunctionNode, ClassNode, etc.)
    // to ensure correctness even when the registry is only partially populated
    // (e.g., when a type header is loaded but source hasn't been fully parsed).
    // For user-defined types, falls back to the struct registry.
    // WARNING: Cross-module GEP is unsafe — `getelementptr %ClassName` in
    // module X fails if %ClassName is defined in module Y. Use byte-offset
    // i8 GEP or memset zero-init instead.
    fun getFieldInfo(structName: String, fieldName: String) r: Int {
        let cacheKey = structName + "." + fieldName
        let cached = findCachedIrgenFieldIndex(cacheKey)
        if cached >= 0 {
            return cached
        }
        traceGen("getFieldInfo: " + structName + "." + fieldName)
        if structName == "FrontendResult" {
            let idxCheck = findStruct(structName)
            if idxCheck >= 0 {
                traceGen("FrontendResult fields=" + structFieldNames[idxCheck])
            }
        }

        // CRITICAL: Check hardcoded field indices FIRST for known AST types
        // This ensures correct indices even when registry is partially populated
        // (e.g., when type header is loaded but source hasn't been fully parsed)
        if structName == "FunctionNode" {
            if fieldName == "name" { cacheIrgenFieldIndex(cacheKey, 0); return 0 }
            if fieldName == "params" { cacheIrgenFieldIndex(cacheKey, 1); return 1 }
            if fieldName == "returnType" { cacheIrgenFieldIndex(cacheKey, 2); return 2 }
            if fieldName == "body" { cacheIrgenFieldIndex(cacheKey, 3); return 3 }
            if fieldName == "isAsync" { cacheIrgenFieldIndex(cacheKey, 4); return 4 }
            if fieldName == "isInline" { cacheIrgenFieldIndex(cacheKey, 5); return 5 }
            if fieldName == "isStatic" { cacheIrgenFieldIndex(cacheKey, 6); return 6 }
            if fieldName == "isExtern" { cacheIrgenFieldIndex(cacheKey, 7); return 7 }
            if fieldName == "isDeterministic" { cacheIrgenFieldIndex(cacheKey, 8); return 8 }
            if fieldName == "isNondeterministic" { cacheIrgenFieldIndex(cacheKey, 9); return 9 }
            if fieldName == "decorators" { cacheIrgenFieldIndex(cacheKey, 10); return 10 }
            if fieldName == "line" { cacheIrgenFieldIndex(cacheKey, 11); return 11 }
            if fieldName == "column" { cacheIrgenFieldIndex(cacheKey, 12); return 12 }
            if fieldName == "isOverride" { cacheIrgenFieldIndex(cacheKey, 13); return 13 }
        }
        if structName == "ClassNode" {
            if fieldName == "name" { return 0 }
            if fieldName == "fields" { return 1 }
            if fieldName == "methods" { return 2 }
            if fieldName == "decorators" { return 3 }
            if fieldName == "isNondeterministic" { return 4 }
            if fieldName == "parentName" { return 5 }
        }
        if structName == "TypeNode" {
            if fieldName == "typeName" { return 0 }
            if fieldName == "isNullable" { return 1 }
        }
        if structName == "ParamNode" {
            if fieldName == "name" { return 0 }
            if fieldName == "paramType" { return 1 }
            if fieldName == "isMutable" { return 2 }
        }
        if structName == "ItemNode" {
            if fieldName == "itemType" { return 0 }
            if fieldName == "name" { return 1 }
            if fieldName == "visibility" { return 2 }
            if fieldName == "importPath" { return 3 }
            if fieldName == "importSymbols" { return 4 }
            if fieldName == "function" { return 5 }
            if fieldName == "classNode" { return 6 }
            if fieldName == "enumNode" { return 7 }
        }
        if structName == "ProgramNode" {
            if fieldName == "items" { return 0 }
        }
        if structName == "BlockNode" {
            if fieldName == "statements" { return 0 }
        }
        if structName == "FrontendResult" {
            if fieldName == "success" { return 0 }
            if fieldName == "diagnostics" { return 1 }
            if fieldName == "program" { return 2 }
        }
        if structName == "StatementNode" {
            if fieldName == "kind" { return 0 }
            if fieldName == "variableName" { return 1 }
            if fieldName == "variableType" { return 2 }
            if fieldName == "initializer" { return 3 }
            if fieldName == "expression" { return 4 }
            if fieldName == "condition" { return 5 }
            if fieldName == "thenBranch" { return 6 }
            if fieldName == "elseBranch" { return 7 }
            if fieldName == "loopCondition" { return 8 }
            if fieldName == "loopBody" { return 9 }
            if fieldName == "returnValue" { return 10 }
        }
        if structName == "ParserExpressionNode" {
            if fieldName == "kind" { return 0 }
            if fieldName == "operands" { return 1 }
            if fieldName == "operator" { return 2 }
            if fieldName == "literalValue" { return 3 }
            if fieldName == "literalType" { return 4 }
            if fieldName == "variableName" { return 5 }
            if fieldName == "callee" { return 6 }
            if fieldName == "arguments" { return 7 }
        }

        let idx = findStruct(structName)
        if idx < 0 {
            return -1  // Struct not found
        }

        let fieldNamesStr = structFieldNames[idx]
        // Parse comma-separated field names to find index
        // Use byteAt instead of charAt (44 = ',')
        var fieldIdx = 0
        var start = 0
        var pos = 0
        while pos <= fieldNamesStr.length() {
            var byteVal = 0
            if pos < fieldNamesStr.length() {
                byteVal = fieldNamesStr.byteAt(pos)
            }
            if byteVal == 44 or pos == fieldNamesStr.length() {
                let name = fieldNamesStr.substring(start, pos)
                if name == fieldName {
                    cacheIrgenFieldIndex(cacheKey, fieldIdx)
                    return fieldIdx
                }
                fieldIdx = fieldIdx + 1
                start = pos + 1
            }
            pos = pos + 1
        }

        // Fallback hardcoded field indices for less common types (not covered above)
        if structName == "FrontendDiagnostic" {
            if fieldName == "file" { cacheIrgenFieldIndex(cacheKey, 0); return 0 }
            if fieldName == "line" { cacheIrgenFieldIndex(cacheKey, 1); return 1 }
            if fieldName == "column" { cacheIrgenFieldIndex(cacheKey, 2); return 2 }
            if fieldName == "severity" { cacheIrgenFieldIndex(cacheKey, 3); return 3 }
            if fieldName == "message" { cacheIrgenFieldIndex(cacheKey, 4); return 4 }
        }
        if structName == "Token" {
            if fieldName == "tokenType" { cacheIrgenFieldIndex(cacheKey, 0); return 0 }
            if fieldName == "value" { cacheIrgenFieldIndex(cacheKey, 1); return 1 }
            if fieldName == "line" { cacheIrgenFieldIndex(cacheKey, 2); return 2 }
            if fieldName == "column" { cacheIrgenFieldIndex(cacheKey, 3); return 3 }
        }
        if structName == "FieldNode" {
            if fieldName == "name" { cacheIrgenFieldIndex(cacheKey, 0); return 0 }
            if fieldName == "fieldType" { cacheIrgenFieldIndex(cacheKey, 1); return 1 }
            if fieldName == "isMutable" { cacheIrgenFieldIndex(cacheKey, 2); return 2 }
            if fieldName == "defaultValue" { cacheIrgenFieldIndex(cacheKey, 3); return 3 }
            if fieldName == "visibility" { cacheIrgenFieldIndex(cacheKey, 4); return 4 }
        }
        return -1  // Field not found
    }

    // Get field type from registered struct
    // Note: fieldTypes uses | as separator (not comma) to handle generic types like Map<K,V>
    fun getFieldType(structName: String, fieldName: String) r: String {
        let idx = findStruct(structName)
        if idx < 0 {
            return "i64"  // Default
        }

        let fieldNamesStr = structFieldNames[idx]
        let fieldTypesStr = structFieldTypes[idx]
        let llvmFieldTypesStr = structLlvmFieldTypes[idx]

        // If struct was loaded from header with empty field names, use hardcoded fallbacks
        if fieldNamesStr == "" {
            let hdr = getFieldTypeForHeaderStruct(structName, fieldName)
            if hdr != "" { return hdr }
        }

        // Parse to find matching field by index
        var fieldIdx = 0
        var nameStart = 0
        var nameEnd = 0

        // Find field index from names string (comma-separated)
        // Use byteAt instead of charAt (44=',', 124='|')
        var foundField = false
        var pos = 0
        while pos <= fieldNamesStr.length() and not foundField {
            if pos == fieldNamesStr.length() or (pos < fieldNamesStr.length() and fieldNamesStr.byteAt(pos) == 44) {
                let name = fieldNamesStr.substring(nameStart, pos)
                if name == fieldName {
                    foundField = true
                } else {
                    fieldIdx = fieldIdx + 1
                    nameStart = pos + 1
                }
            }
            pos = pos + 1
        }

        // Hardcoded fallbacks for known structs (avoid string parsing bugs)
        // NOTE: Check these BEFORE returning default i64 for unknown fields
        if structName == "LLVMIRGenerator" {
            let llvmGenType = getLLVMIRGeneratorFieldType(fieldName)
            if llvmGenType != "" { return llvmGenType }
        }
        let knownType = getFieldTypeForKnownStruct(structName, fieldName)
        if knownType != "" { return knownType }

        // If field wasn't found in the field names list, return default
        // (can't use fieldIdx if foundField is false)
        if not foundField {
            return "i64"
        }

        // Prefer LLVM field types from header if available
        if llvmFieldTypesStr != "" {
            var llvmTypeIdx = 0
            var llvmTypeStart = 0
            pos = 0
            while pos <= llvmFieldTypesStr.length() {
                if pos == llvmFieldTypesStr.length() or (pos < llvmFieldTypesStr.length() and llvmFieldTypesStr.byteAt(pos) == 124) {
                    if llvmTypeIdx == fieldIdx {
                        return llvmFieldTypesStr.substring(llvmTypeStart, pos)
                    }
                    llvmTypeIdx = llvmTypeIdx + 1
                    llvmTypeStart = pos + 1
                }
                pos = pos + 1
            }
        }

        // Now find the type at fieldIdx (pipe-separated)
        var typeIdx = 0
        var typeStart = 0
        pos = 0
        while pos <= fieldTypesStr.length() {
            if pos == fieldTypesStr.length() or (pos < fieldTypesStr.length() and fieldTypesStr.byteAt(pos) == 124) {
                if typeIdx == fieldIdx {
                    let typeName = fieldTypesStr.substring(typeStart, pos)
                    return mapType(typeName)
                }
                typeIdx = typeIdx + 1
                typeStart = pos + 1
            }
            pos = pos + 1
        }

        return "i64"  // Default
    }

    fun getLLVMIRGeneratorFieldIndex(fieldName: String) r: Int {
        if fieldName == "output" { return 0 }
        if fieldName == "stringConstants" { return 1 }
        if fieldName == "nextReg" { return 2 }
        if fieldName == "nextBlock" { return 3 }
        if fieldName == "varNames" { return 4 }
        if fieldName == "varRegs" { return 5 }
        if fieldName == "varTypes" { return 6 }
        if fieldName == "indent" { return 7 }
        if fieldName == "structNames" { return 8 }
        if fieldName == "structLayouts" { return 9 }
        if fieldName == "structFieldNames" { return 10 }
        if fieldName == "structFieldTypes" { return 11 }
        if fieldName == "structLlvmFieldTypes" { return 12 }
        if fieldName == "structSizes" { return 13 }
        if fieldName == "structMethodNames" { return 14 }
        if fieldName == "structMethodRetTypes" { return 15 }
        if fieldName == "funcNames" { return 16 }
        if fieldName == "funcRetTypes" { return 17 }
        if fieldName == "classMethodBaseNames" { return 18 }
        if fieldName == "typeHeaderPath" { return 19 }
        if fieldName == "currentFunctionReturnType" { return 20 }
        if fieldName == "currentClassName" { return 21 }
        if fieldName == "blockTerminated" { return 22 }
        if fieldName == "currentLoopCondLabel" { return 23 }
        if fieldName == "currentLoopEndLabel" { return 24 }
        if fieldName == "preAllocatedVars" { return 25 }
        if fieldName == "preAllocatedTypes" { return 26 }
        if fieldName == "stringConstantPrefix" { return 27 }
        if fieldName == "generatedFunctions" { return 28 }
        if fieldName == "generatedClasses" { return 29 }
        if fieldName == "typesLoadedFromHeader" { return 30 }
        if fieldName == "runtimeDeclsLoaded" { return 31 }
        if fieldName == "pendingArrayLiteralType" { return 32 }
        if fieldName == "moduleConstantNames" { return 33 }
        if fieldName == "moduleConstantValues" { return 34 }
        if fieldName == "moduleConstantTypes" { return 35 }
        return -1
    }


    fun getLLVMIRGeneratorFieldType(fieldName: String) r: String {
        if fieldName == "output" { return "i64" }
        if fieldName == "stringConstants" { return "ptr" }
        if fieldName == "nextReg" { return "i64" }
        if fieldName == "nextBlock" { return "i64" }
        if fieldName == "varNames" { return "ptr" }
        if fieldName == "varRegs" { return "ptr" }
        if fieldName == "varTypes" { return "ptr" }
        if fieldName == "indent" { return "i64" }
        if fieldName == "structNames" { return "ptr" }
        if fieldName == "structLayouts" { return "ptr" }
        if fieldName == "structFieldNames" { return "ptr" }
        if fieldName == "structFieldTypes" { return "ptr" }
        if fieldName == "structLlvmFieldTypes" { return "ptr" }
        if fieldName == "structSizes" { return "ptr" }
        if fieldName == "structMethodNames" { return "ptr" }
        if fieldName == "structMethodRetTypes" { return "ptr" }
        if fieldName == "funcNames" { return "ptr" }
        if fieldName == "funcRetTypes" { return "ptr" }
        if fieldName == "classMethodBaseNames" { return "ptr" }
        if fieldName == "typeHeaderPath" { return "%SeenString" }
        if fieldName == "currentFunctionReturnType" { return "%SeenString" }
        if fieldName == "currentClassName" { return "%SeenString" }
        if fieldName == "blockTerminated" { return "i1" }
        if fieldName == "currentLoopCondLabel" { return "%SeenString" }
        if fieldName == "currentLoopEndLabel" { return "%SeenString" }
        if fieldName == "preAllocatedVars" { return "ptr" }
        if fieldName == "preAllocatedTypes" { return "ptr" }
        if fieldName == "stringConstantPrefix" { return "%SeenString" }
        if fieldName == "generatedFunctions" { return "ptr" }
        if fieldName == "generatedClasses" { return "ptr" }
        if fieldName == "typesLoadedFromHeader" { return "i1" }
        if fieldName == "runtimeDeclsLoaded" { return "i1" }
        if fieldName == "pendingArrayLiteralType" { return "%SeenString" }
        if fieldName == "moduleConstantNames" { return "ptr" }
        if fieldName == "moduleConstantValues" { return "ptr" }
        if fieldName == "moduleConstantTypes" { return "ptr" }
        return ""
    }


    fun getSeenTokenTypeValue(memberName: String) r: Int { return getSeenTokenTypeValueImpl(memberName) }

    // Delegates to free function in ir_type_info.seen
    fun getSeenFieldType(structName: String, fieldName: String) r: String {
        return getSeenFieldTypeImpl(structName, fieldName, structNames, structFieldNames, structFieldTypes)
    }

    fun inferTypeRegistryFieldType(fieldName: String) r: String {
        if fieldName == "structNames" { return "Array<String>" }
        if fieldName == "structLayouts" { return "Array<String>" }
        if fieldName == "structFieldNames" { return "Array<String>" }
        if fieldName == "structFieldTypes" { return "Array<String>" }
        if fieldName == "structLlvmFieldTypes" { return "Array<String>" }
        if fieldName == "structSizes" { return "Array<Int>" }
        if fieldName == "structMethodNames" { return "Array<String>" }
        if fieldName == "structMethodRetTypes" { return "Array<String>" }
        if fieldName == "funcNames" { return "Array<String>" }
        if fieldName == "funcRetTypes" { return "Array<String>" }
        if fieldName == "classMethodBaseNames" { return "Array<String>" }
        if fieldName == "typeHeaderPath" { return "String" }
        return ""
    }

    fun getSemanticFieldType(structName: String, fieldName: String) r: String {
        let structIdx = findStruct(structName)
        if structIdx >= 0 {
            let fieldNamesStr = structFieldNames[structIdx]
            let fieldTypesStr = structFieldTypes[structIdx]
            if fieldNamesStr != "" and fieldTypesStr != "" {
                let semanticFieldType = getFieldTypeFromListsReg(fieldNamesStr, fieldTypesStr, fieldName)
                if semanticFieldType != "" {
                    return semanticFieldType
                }
            }
        }
        if structName == "TypeRegistry" {
            return inferTypeRegistryFieldType(fieldName)
        }
        return ""
    }


    fun splitChainedPath(path: String) r: Array<String> {
        let segments = Array<String>()
        var segmentStart = 0
        var idx = 0
        while idx <= path.length() {
            if idx == path.length() or path.byteAt(idx) == 46 {
                if idx > segmentStart {
                    segments.push(path.substring(segmentStart, idx))
                }
                segmentStart = idx + 1
            }
            idx = idx + 1
        }
        return segments
    }

    fun buildChainedPathExpr(path: String) r: ParserExpressionNode {
        let segments = splitChainedPath(path)
        if segments.length() == 0 {
            return ParserExpressionNode.new()
        }

        let baseExpr = ParserExpressionNode.new()
        baseExpr.kind = "Variable"
        baseExpr.variableName = segments[0]

        var currentExpr = baseExpr
        var idx = 1
        while idx < segments.length() {
            let segment = segments[idx]
            let nextExpr = ParserExpressionNode.new()
            if segment.endsWith("()") {
                nextExpr.kind = "MethodCall"
                nextExpr.callee = segment.substring(0, segment.length() - 2)
                nextExpr.operands.push(currentExpr)
            } else {
                nextExpr.kind = "MemberAccess"
                nextExpr.variableName = segment
                nextExpr.operands.push(currentExpr)
            }
            currentExpr = nextExpr
            idx = idx + 1
        }

        return currentExpr
    }

    // Resolve the type of a chained path like "item.function.returnType"
    // Returns the type of the final field in the chain
    fun resolveChainedPathType(path: String) r: String {
        if path.contains("()") {
            let chainExpr = buildChainedPathExpr(path)
            if chainExpr.kind != "None" {
                return inferExpressionType(chainExpr)
            }
        }
        // Split the path at the first dot (46 = '.')
        var firstDot = -1
        var idx = 0
        while idx < path.length() {
            if path.byteAt(idx) == 46 {
                firstDot = idx
                idx = path.length()
            }
            idx = idx + 1
        }

        if firstDot < 0 {
            // No dot - simple variable name
            return findVarType(path)
        }

        // Get base variable and rest of path
        let baseName = path.substring(0, firstDot)
        let restPath = path.substring(firstDot + 1, path.length())

        // Get base type
        var currentType = findVarType(baseName)
        if currentType == "" {
            return ""
        }

        // Walk through the rest of the path
        var remainingPath = restPath
        while remainingPath.length() > 0 {
            // Find next dot
            var nextDot = -1
            var searchIdx = 0
            while searchIdx < remainingPath.length() {
                if remainingPath.byteAt(searchIdx) == 46 {
                    nextDot = searchIdx
                    searchIdx = remainingPath.length()  // break
                }
                searchIdx = searchIdx + 1
            }

            var fieldName = ""
            if nextDot < 0 {
                // Last field in the chain
                fieldName = remainingPath
                remainingPath = ""
            }
            if nextDot >= 0 {
                fieldName = remainingPath.substring(0, nextDot)
                remainingPath = remainingPath.substring(nextDot + 1, remainingPath.length())
            }

            var segmentName = fieldName
            var segmentIsMethod = false
            if segmentName.endsWith("()") {
                segmentName = segmentName.substring(0, segmentName.length() - 2)
                segmentIsMethod = true
            }

            var nextType = ""
            if not segmentIsMethod {
                nextType = getSeenFieldType(currentType, segmentName)
            }
            if nextType == "" {
                if segmentName == "unwrap" {
                    var isClassInner = 0
                    if isClassType(currentType) { isClassInner = 1 }
                    nextType = resolveUnwrapTypeImpl(currentType, isClassInner)
                }
                if nextType == "" and segmentName == "tryPropagate" {
                    nextType = resolveTryPropagateTypeImpl(currentType)
                }
                if nextType == "" {
                    nextType = getMethodReturnType(currentType, segmentName)
                }
            }

            currentType = nextType
            if currentType == "" or currentType == "Int" {
                // Can't resolve further
                return currentType
            }
        }

        return currentType
    }

    // Delegates to free function in ir_type_info.seen
    fun getMethodReturnType(structName: String, methodName: String) r: String {
        let retType = getMethodReturnTypeImpl(structName, methodName, structNames, structMethodNames, structMethodRetTypes)
        if retType == "Unknown" {
            return ""
        }
        return retType
    }

    // Single-module entry point: wraps generateMultiple with one program.
    fun generate(program: ProgramNode) r: String {
        // Single module compilation
        let programs = Array<ProgramNode>()
        programs.push(program)
        return generateMultiple(programs)
    }

    // Multi-module monolithic entry point: generates a single .ll file
    // containing IR for ALL programs. Used by the `--release` path and
    // single-file compilation. Follows the three-pass architecture:
    //   1. Collect string constants from all programs
    //   2. Emit prologue, struct types, globals, string constants, runtime decls
    //   3. Generate class methods (BEFORE top-level functions — see ordering
    //      note below), then top-level functions, then closures
    // Class methods are generated before top-level functions so that
    // registerStructMethod() calls from @derive/@reflect/@binary/@packet
    // decorators complete before generateFunction(main) tries to resolve
    // method return types.
    fun generateMultiple(programs: Array<ProgramNode>) r: String {
        output = StringBuilder.new()
        stringConstants = Array<String>()
        stringConstantPrefix = ""  // No prefix for multi-module
        g_closureCount = 0
        g_closureDefs = ""
        g_pforCount = 0
        g_comptimeNames = ""
        g_comptimeValues = ""
        g_comptimeCount = 0
        g_intrinsicFuncNames = ""
        g_intrinsicLlvmNames = ""
        g_intrinsicCount = 0
        g_sendTypes = ""
        g_syncTypes = ""

        // First pass: collect string constants from all programs
        var pi = 0
        while pi < programs.length() {
            collectStringConstants(programs[pi])
            pi = pi + 1
        }

        // Emit module header
        emitPrologue()

        // Emit class struct type definitions from all programs
        pi = 0
        while pi < programs.length() {
            let program = programs[pi]
            var i = 0
            while i < program.items.length() {
                let item = program.items[i]
                if item.itemType == "Class" {
                    emitClassType(item.classNode)
                }
                i = i + 1
            }
            pi = pi + 1
        }

        // Emit global variable declarations from all programs
        pi = 0
        while pi < programs.length() {
            emitProgramGlobalVariables(programs[pi])
            pi = pi + 1
        }

        // Emit string constants
        emitStringConstants()

        // Emit runtime declarations
        emitRuntimeDeclarations()

        // Sync class fields → CodegenState before code generation begins.
        syncState()

        // WHY class methods BEFORE top-level functions:
        // @derive/@reflect/@binary/@packet decorators on classes call
        // registerStructMethod() during generateClass(), which populates
        // structMethodNames/structMethodRetTypes. If generateFunction(main)
        // runs first, it calls inferExpressionType on method calls like
        // obj.serialize(), but the method return type isn't registered yet,
        // causing type inference to fail and generate incorrect IR.
        pi = 0
        while pi < programs.length() {
            let program = programs[pi]
            var i = 0
            while i < program.items.length() {
                if program.items[i].itemType == "Class" {
                    if canUseLargePlainClassPath(program.items[i].classNode.parentName, program.items[i].classNode.decorators, program.items[i].classNode.methods) {
                        generatePlainLargeClass(program.items[i].classNode.name, program.items[i].classNode.parentName, program.items[i].classNode.methods)
                    } else {
                        let item = program.items[i]
                        generateClass(item.classNode)
                    }
                }
                i = i + 1
            }
            pi = pi + 1
        }

        // Emit functions (top-level) from all programs
        pi = 0
        while pi < programs.length() {
            let program = programs[pi]
            var i = 0
            while i < program.items.length() {
                let item = program.items[i]
                if item.itemType == "Function" {
                    let fnName = item.function.name
                    // Skip 'new' - it's always a class method, never a standalone function
                    if fnName == "new" {
                        i = i + 1
                        continue
                    }
                    if isRuntimeBackedStringCompatFunction(fnName) {
                        i = i + 1
                        continue
                    }
                    // : @cImport("header.h") — auto-generate extern declarations from C headers
                    if fnName == "__cImport" and item.function.hasDecorator("cImport") {
                        var cImportHeaderPath = ""
                        var ciDecIdx = 0
                        while ciDecIdx < item.function.decorators.length() {
                            if item.function.decorators[ciDecIdx].name == "cImport" {
                                if item.function.decorators[ciDecIdx].arguments.length() > 0 {
                                    cImportHeaderPath = item.function.decorators[ciDecIdx].arguments[0]
                                }
                            }
                            ciDecIdx = ciDecIdx + 1
                        }
                        if cImportHeaderPath != "" {
                            output.append("; @cImport(\"" + cImportHeaderPath + "\")\n")
                            // Use clang to extract function declarations from the C header
                            let ciCmd = "clang -Xclang -ast-dump -fsyntax-only " + cImportHeaderPath + " 2>/dev/null"
                            let ciResult: CommandResult = runCommand(ciCmd)
                            if ciResult.success {
                                // Parse clang AST dump: look for FunctionDecl lines
                                let ciLines = ciResult.output.split("\n")
                                var ciLi = 0
                                while ciLi < ciLines.length() {
                                    let ciLine = ciLines[ciLi]
                                    // Match: FunctionDecl ... <name> '<rettype> (<paramtypes>)'
                                    if ciLine.contains("FunctionDecl") and not ciLine.contains("implicit") {
                                        // Extract function name and type from the AST dump line
                                        // Format: |-FunctionDecl 0xADDR <loc> <loc> <name> '<type>'
                                        let ciQuoteStart = ciLine.indexOf("'")
                                        let ciQuoteEnd = ciLine.lastIndexOf("'")
                                        if ciQuoteStart >= 0 and ciQuoteEnd > ciQuoteStart {
                                            let ciProto = ciLine.substring(ciQuoteStart + 1, ciQuoteEnd)
                                            // ciProto is like "double (double)" or "int (const char *, ...)"
                                            let ciParenStart = ciProto.indexOf("(")
                                            if ciParenStart >= 0 {
                                                let ciRetType = ciProto.substring(0, ciParenStart).trim()
                                                let ciRetLlvm = mapCTypeToLlvm(ciRetType)
                                                // Extract function name: last non-quoted word before the quote
                                                var ciFuncName = ""
                                                let ciBeforeQuote = ciLine.substring(0, ciQuoteStart).trim()
                                                let ciWords = ciBeforeQuote.split(" ")
                                                if ciWords.length() > 0 {
                                                    ciFuncName = ciWords[ciWords.length() - 1]
                                                }
                                                if ciFuncName != "" and not ciFuncName.startsWith("__") {
                                                    // Parse parameter types
                                                    let ciParamPart = ciProto.substring(ciParenStart + 1, ciProto.length() - 1)
                                                    var ciParamStr = ""
                                                    var ciIsVariadic = false
                                                    if ciParamPart != "void" and ciParamPart != "" {
                                                        let ciParams = ciParamPart.split(",")
                                                        var ciPi = 0
                                                        while ciPi < ciParams.length() {
                                                            let ciP = ciParams[ciPi].trim()
                                                            if ciP == "..." {
                                                                ciIsVariadic = true
                                                            } else {
                                                                if ciParamStr != "" { ciParamStr = ciParamStr + ", " }
                                                                ciParamStr = ciParamStr + mapCTypeToLlvm(ciP)
                                                            }
                                                            ciPi = ciPi + 1
                                                        }
                                                    }
                                                    if ciIsVariadic {
                                                        if ciParamStr != "" { ciParamStr = ciParamStr + ", " }
                                                        ciParamStr = ciParamStr + "..."
                                                    }
                                                    output.append("declare " + ciRetLlvm + " @" + ciFuncName + "(" + ciParamStr + ") nounwind\n")
                                                    registerFunction(ciFuncName, ciRetType)
                                                }
                                            }
                                        }
                                    }
                                    ciLi = ciLi + 1
                                }
                            }
                        }
                        i = i + 1
                        continue
                    }
                    // : Variadic generic expansion
                    if item.function.hasDecorator("variadic_generic") {
                        generateVariadicGenericExpansion(item.function)
                        i = i + 1
                        continue
                    }
                    generateFunction(item.function)
                }
                i = i + 1
            }
            pi = pi + 1
        }

        // Emit vtable constants for trait implementations
        emitTraitVtableConstants()

        // Emit closure definitions generated during compilation
        if g_closureDefs.length() > 0 {
            output.append(g_closureDefs)
        }

        // Emit optimization stats as IR comments
        if g_branchesEliminated > 0 or g_deadStatementsEliminated > 0 or g_constantsFolded > 0 or g_cseHits > 0 {
            output.append("\n; --- Optimization Statistics ---\n")
            if g_branchesEliminated > 0 {
                output.append("; Branches eliminated: " + g_branchesEliminated.toString() + "\n")
            }
            if g_deadStatementsEliminated > 0 {
                output.append("; Dead statements eliminated: " + g_deadStatementsEliminated.toString() + "\n")
            }
            if g_constantsFolded > 0 {
                output.append("; Constants folded: " + g_constantsFolded.toString() + "\n")
            }
            if g_cseHits > 0 {
                output.append("; CSE hits: " + g_cseHits.toString() + "\n")
            }
        }

        // Emit @llvm.global_ctors for @init functions
        emitGlobalConstructors()

        // Emit TBAA metadata at end of module
        emitTBAAMetadata()
        emitLoopMetadata()

        // Write ML decision log and print stats (single-module path)
        writeMLDecisionLog()

        return output.toString()
    }

    // Per-module entry point: generates one .ll file for a single source
    // module, identified by moduleIndex. This is the hot path used by the
    // ThinLTO build pipeline and fork-parallel IR generation.
    //
    // Resets all per-module state (reset()), then:
    //   1. Collects string constants and call counts for ML inline decisions
    //   2. Emits prologue with module-specific string constant prefix (M0., M1., ...)
    //   3. Emits struct types, globals, cross-module declares, runtime decls
    //   4. Generates class methods BEFORE top-level functions (same ordering
    //      rationale as generateMultiple — registerStructMethod must run first)
    //   5. Emits closures, optimization stats, @init constructors, TBAA metadata
    //
    // The struct/function registries are NOT reset — they persist from Pass 1
    // (registerDeclarations) and are shared across all modules.
    fun generateSingle(program: ProgramNode, moduleIndex: Int) r: String {
        let moduleStartTime = getIrgenTraceTimeSeconds()
        println("[irgen module " + moduleIndex.toString() + "] reset start")
        // Reset ALL per-module codegen state (generatedFunctions, generatedClasses,
        // nextReg, nextBlock, currentFunctionReturnType, loop labels, opt counters, etc.)
        reset()
        // Module-specific state not covered by reset()
        g_closureCount = 0
        g_closureDefs = ""
        g_pforCount = 0
        g_comptimeNames = ""
        g_comptimeValues = ""
        g_comptimeCount = 0
        g_intrinsicFuncNames = ""
        g_intrinsicLlvmNames = ""
        g_intrinsicCount = 0
        g_sendTypes = ""
        g_syncTypes = ""
        // Set module prefix for string constants (e.g., "M0.", "M1.", etc.)
        stringConstantPrefix = "M" + moduleIndex.toString() + "."

        // Load ML heuristic weights (once per compilation)
        loadMLWeights()

        // Collect string constants for THIS module only
        // Also piggybacks call counting for ML inline decisions + self-call detection
        println("[irgen module " + moduleIndex.toString() + "] collect strings start")
        let collectStringsStartTime = getIrgenTraceTimeSeconds()
        callCountClear()
        g_selfCallFuncs = ""
        g_selfCallNames = ""
        g_selfCallCount = 0
        collectStringConstants(program)
        let collectStringsEndTime = getIrgenTraceTimeSeconds()
        println("[irgen module " + moduleIndex.toString() + "] collect strings done in " + (collectStringsEndTime - collectStringsStartTime).toString() + "s")

        // Emit module header
        println("[irgen module " + moduleIndex.toString() + "] prologue start")
        let prologueStartTime = getIrgenTraceTimeSeconds()
        emitPrologue()
        let prologueEndTime = getIrgenTraceTimeSeconds()
        println("[irgen module " + moduleIndex.toString() + "] prologue done in " + (prologueEndTime - prologueStartTime).toString() + "s")

        // Emit class struct type definitions for THIS module
        println("[irgen module " + moduleIndex.toString() + "] class type scan start")
        let classTypeStartTime = getIrgenTraceTimeSeconds()
        var i = 0
        while i < program.items.length() {
            let item = program.items[i]
            if item.itemType == "Class" {
                emitClassType(item.classNode)
            }
            i = i + 1
        }
        let classTypeEndTime = getIrgenTraceTimeSeconds()
        println("[irgen module " + moduleIndex.toString() + "] class type scan done in " + (classTypeEndTime - classTypeStartTime).toString() + "s")

        // NOTE: vtable constants are emitted AFTER function generation (see below)
        // because g_traitImplRegistry is populated during generateFunction's impl detection.

        // Emit global variable declarations for THIS module
        println("[irgen module " + moduleIndex.toString() + "] globals start")
        let globalsStartTime = getIrgenTraceTimeSeconds()
        emitProgramGlobalVariables(program)
        let globalsEndTime = getIrgenTraceTimeSeconds()
        println("[irgen module " + moduleIndex.toString() + "] globals done in " + (globalsEndTime - globalsStartTime).toString() + "s")

        // Emit external declarations for cross-module constants not defined in this module
        emitCrossModuleConstantDeclares()

        // Emit string constants with module prefix
        println("[irgen module " + moduleIndex.toString() + "] string constants start")
        let stringConstantsStartTime = getIrgenTraceTimeSeconds()
        emitStringConstantsWithPrefix(moduleIndex)
        let stringConstantsEndTime = getIrgenTraceTimeSeconds()
        println("[irgen module " + moduleIndex.toString() + "] string constants done in " + (stringConstantsEndTime - stringConstantsStartTime).toString() + "s")
        // Track how many string constants exist before class/function generation
        // (derive/reflect/json codegen may add new constants that need separate emission)
        var stringConstCountBeforeGen = stringConstants.length()

        // Collect function names defined in this module (to skip their declarations)
        var definedFuncs = Array<String>()
        var collectIdx = 0
        while collectIdx < program.items.length() {
            let collectItem = program.items[collectIdx]
            if collectItem.itemType == "Function" {
                if not isRuntimeBackedStringCompatFunction(collectItem.function.name) {
                    definedFuncs.push(collectItem.function.name)
                }
            }
            if collectItem.itemType == "Class" {
                // Also collect class method names (format: ClassName_methodName)
                let className = collectItem.classNode.name
                var methodIdx = 0
                while methodIdx < collectItem.classNode.methods.length() {
                    let method = collectItem.classNode.methods[methodIdx]
                    definedFuncs.push(className + "_" + method.name)
                    methodIdx = methodIdx + 1
                }
            }
            // Add global var names to prevent duplicate extern declarations
            if collectItem.itemType == "GlobalVar" {
                definedFuncs.push(collectItem.name)
            }
            collectIdx = collectIdx + 1
        }

        // Emit declares for cross-module user-defined functions
        // These are built during registerDeclarations (Pass 1) and emitted here (Pass 2)
        // Adding to definedFuncs prevents duplicate declares in emitRuntimeDeclarations
        var xmIdx = 0
        while xmIdx < g_xmDeclareCount {
            let xmName = pipeGet(g_xmDeclareNames, xmIdx)
            if not isFuncDefinedInModule(xmName, definedFuncs) {
                output.append(pipeGet(g_xmDeclareStrs, xmIdx))
                definedFuncs.push(xmName)
            }
            xmIdx = xmIdx + 1
        }

        // Emit runtime declarations (skip functions defined in this module)
        println("[irgen module " + moduleIndex.toString() + "] runtime decls start")
        let runtimeDeclsStartTime = getIrgenTraceTimeSeconds()
        emitRuntimeDeclarations(definedFuncs)
        let runtimeDeclsEndTime = getIrgenTraceTimeSeconds()
        println("[irgen module " + moduleIndex.toString() + "] runtime decls done in " + (runtimeDeclsEndTime - runtimeDeclsStartTime).toString() + "s")

        // Sync class fields → CodegenState before code generation begins.
        // Free functions in satellite modules use state.* for shared access.
        println("[irgen module " + moduleIndex.toString() + "] sync state start")
        let syncStateStartTime = getIrgenTraceTimeSeconds()
        syncState()
        let syncStateEndTime = getIrgenTraceTimeSeconds()
        println("[irgen module " + moduleIndex.toString() + "] sync state done in " + (syncStateEndTime - syncStateStartTime).toString() + "s")

        // WHY class methods BEFORE top-level functions: see generateMultiple.
        // registerStructMethod() must populate method return types before
        // generateFunction(main) calls inferExpressionType on method calls.
        println("[irgen module " + moduleIndex.toString() + "] classes start")
        let classesStartTime = getIrgenTraceTimeSeconds()
        i = 0
        while i < program.items.length() {
            if program.items[i].itemType == "Class" {
                if canUseLargePlainClassPath(program.items[i].classNode.parentName, program.items[i].classNode.decorators, program.items[i].classNode.methods) {
                    generatePlainLargeClass(program.items[i].classNode.name, program.items[i].classNode.parentName, program.items[i].classNode.methods)
                } else {
                    let item = program.items[i]
                    generateClass(item.classNode)
                }
            }
            i = i + 1
        }
        let classesEndTime = getIrgenTraceTimeSeconds()
        println("[irgen module " + moduleIndex.toString() + "] classes done in " + (classesEndTime - classesStartTime).toString() + "s")

        // Emit functions (top-level) for THIS module
        println("[irgen module " + moduleIndex.toString() + "] functions start")
        let functionsStartTime = getIrgenTraceTimeSeconds()
        i = 0
        while i < program.items.length() {
            let item = program.items[i]
            println("[irgen module " + moduleIndex.toString() + "] function loop item " + i.toString() + ": " + item.itemType)
            if item.itemType == "Function" {
                println("[irgen module " + moduleIndex.toString() + "] function item confirmed at idx " + i.toString())
                let fnName = item.function.name
                // Skip 'new' - it's always a class method, never a standalone function
                if fnName == "new" {
                    i = i + 1
                    continue
                }
                if isRuntimeBackedStringCompatFunction(fnName) {
                    i = i + 1
                    continue
                }
                println("[irgen module " + moduleIndex.toString() + "] function name resolved: " + fnName)
                println("[irgen module " + moduleIndex.toString() + "] function start: " + fnName)
                generateFunction(item.function)
                println("[irgen module " + moduleIndex.toString() + "] function done: " + fnName)
            }
            i = i + 1
        }
        let functionsEndTime = getIrgenTraceTimeSeconds()
        println("[irgen module " + moduleIndex.toString() + "] functions done in " + (functionsEndTime - functionsStartTime).toString() + "s")

        emitLateUserDeclares(definedFuncs)

        // Emit vtable constants for trait implementations found in this module
        // Must be AFTER generateFunction so g_traitImplRegistry is populated
        emitTraitVtableConstants()

        // Emit any new string constants added during class/function generation
        // (e.g., by @derive(Debug), @reflect, @derive(Json) codegen)
        if stringConstants.length() > stringConstCountBeforeGen {
            output.append("\n; Additional string constants from derive/reflect codegen\n")
            var sci = stringConstCountBeforeGen
            while sci < stringConstants.length() {
                let scStr = stringConstants[sci]
                let scLen = scStr.length() + 1
                output.append("@.str." + stringConstantPrefix + sci.toString() + " = private unnamed_addr constant [" + scLen.toString() + " x i8] c\"")
                output.append(scStr)
                output.append("\\00\"\n")
                sci = sci + 1
            }
        }

        // Emit closure definitions generated during this module
        if g_closureDefs.length() > 0 {
            output.append(g_closureDefs)
        }

        // Unused function pruning warnings (9.10c)
        // AST-level check: scan all function bodies for Call expressions that reference each function
        // Only check small modules (< 20 functions) to avoid O(n^2) cost on large modules
        if program.items.length() < 20 {
            i = 0
            while i < program.items.length() {
                let ufItem = program.items[i]
                if ufItem.itemType == "Function" {
                    let ufName = ufItem.function.name
                    if ufName != "main" and not ufName.startsWith("__") and not ufItem.function.isExtern {
                        // Check if any other function calls this one
                        var ufCalled = false
                        var ufJ = 0
                        while ufJ < program.items.length() {
                            let ufCaller = program.items[ufJ]
                            if ufCaller.itemType == "Function" and ufCaller.function.name != ufName {
                                // Scan caller's body statements for Call to ufName
                                var ufK = 0
                                while ufK < ufCaller.function.body.statements.length() {
                                    let ufStmt = ufCaller.function.body.statements[ufK]
                                    if ufStmt.kind == "Expression" and ufStmt.expression.kind == "Call" {
                                        if ufStmt.expression.callee == ufName { ufCalled = true }
                                    }
                                    // Check return with call
                                    if ufStmt.kind == "Return" and ufStmt.expression.kind == "Call" {
                                        if ufStmt.expression.callee == ufName { ufCalled = true }
                                    }
                                    // Check let/var init with call
                                    if (ufStmt.kind == "Let" or ufStmt.kind == "Var") and ufStmt.expression.kind == "Call" {
                                        if ufStmt.expression.callee == ufName { ufCalled = true }
                                    }
                                    ufK = ufK + 1
                                }
                            }
                            ufJ = ufJ + 1
                        }
                        if not ufCalled {
                            output.append("; WARNING: unused function: " + ufName + "\n")
                            mlLogDecision("dead-func", "unused", ufName)
                        }
                    }
                }
                i = i + 1
            }
        }

        // Emit optimization stats as IR comments
        let hasAnyOpts = g_branchesEliminated > 0 or g_deadStatementsEliminated > 0 or g_constantsFolded > 0 or g_cseHits > 0 or g_loopsOptimized > 0 or g_deadStoresEliminated > 0 or g_reductionChainsDetected > 0
        if hasAnyOpts {
            output.append("\n; --- Optimization Statistics ---\n")
            if g_branchesEliminated > 0 {
                output.append("; Branches eliminated: " + g_branchesEliminated.toString() + "\n")
            }
            if g_deadStatementsEliminated > 0 {
                output.append("; Dead statements eliminated: " + g_deadStatementsEliminated.toString() + "\n")
            }
            if g_constantsFolded > 0 {
                output.append("; Constants folded: " + g_constantsFolded.toString() + "\n")
            }
            if g_cseHits > 0 {
                output.append("; CSE hits: " + g_cseHits.toString() + "\n")
            }
            if g_loopsOptimized > 0 {
                output.append("; Loops optimized: " + g_loopsOptimized.toString() + "\n")
            }
            if g_deadStoresEliminated > 0 {
                output.append("; Dead stores eliminated: " + g_deadStoresEliminated.toString() + "\n")
            }
            if g_reductionChainsDetected > 0 {
                output.append("; Reduction chains detected: " + g_reductionChainsDetected.toString() + "\n")
            }
            // Also print stats to stdout for user visibility
            println("  Optimization stats (module " + moduleIndex.toString() + "):")
            if g_branchesEliminated > 0 {
                println("    Branches eliminated: " + g_branchesEliminated.toString())
            }
            if g_deadStatementsEliminated > 0 {
                println("    Dead statements eliminated: " + g_deadStatementsEliminated.toString())
            }
            if g_constantsFolded > 0 {
                println("    Constants folded: " + g_constantsFolded.toString())
            }
            if g_cseHits > 0 {
                println("    CSE hits: " + g_cseHits.toString())
            }
            if g_loopsOptimized > 0 {
                println("    Loops optimized: " + g_loopsOptimized.toString())
            }
            if g_deadStoresEliminated > 0 {
                println("    Dead stores eliminated: " + g_deadStoresEliminated.toString())
            }
            if g_reductionChainsDetected > 0 {
                println("    Reduction chains detected: " + g_reductionChainsDetected.toString())
            }
        }

        // Clear per-module CSE cache (expressions don't carry across modules)
        cseClear()

        // Flush ML decision log if enabled (appends per-module decisions)
        if g_mlLogEnabled {
            if g_mlDecisionLog.length() > 0 {
                writeText(g_mlLogPath, g_mlDecisionLog)
            }
        }

        // Emit @llvm.global_ctors for @init functions (multi-module path)
        emitGlobalConstructors()

        // Emit TBAA metadata at end of module
        emitTBAAMetadata()
        emitLoopMetadata()

        let moduleEndTime = getIrgenTraceTimeSeconds()
        println("[irgen module " + moduleIndex.toString() + "] done in " + (moduleEndTime - moduleStartTime).toString() + "s")

        return output.toString()
    }

    // Emit the LLVM IR module header: target datalayout, target triple,
    // and the %SeenString / %SeenArray struct type definitions that are
    // used by all generated code.
    fun emitPrologue() r: Void {
        detectHostPlatform()
        output.append("; Generated by Seen Stage1 Compiler (LLVM backend)\n")
        output.append("target datalayout = \"" + g_hostDataLayout + "\"\n")
        output.append("target triple = \"" + g_hostTargetTriple + "\"\n\n")

        // Try to read type declarations from header file (generated by Rust bootstrap compiler)
        // This ensures ABI compatibility between Rust and Seen compilers
        if typeHeaderPath != "" and exists(typeHeaderPath) {
            let headerContent = readText(typeHeaderPath)
            if headerContent != "" {
                output.append("; Type declarations loaded from: " + typeHeaderPath + "\n")
                output.append(headerContent)
                output.append("\n")
                typesLoadedFromHeader = true
                applyTypeHeader(headerContent)
                computeMissingStructSizes()
                // Check if header also contains runtime function declarations
                if headerContent.contains("; Runtime Function Declarations") {
                    runtimeDeclsLoaded = true
                }
                return
            }
        }

        // Fallback: emit hardcoded type definitions if no header file
        output.append("; Using built-in type definitions (no type header file)\n")
        output.append("%SeenString = type { i64, ptr }\n")
        // SeenArray: { len: i64, cap: i64, element_size: i64, data: ptr }
        output.append("%SeenArray = type { i64, i64, i64, ptr }\n")
        // TypeNode: { typeName: %SeenString, isNullable: i1 } - inline data type used in AST
        output.append("%TypeNode = type { %SeenString, i1 }\n")
        // ParamNode: { name: %SeenString, paramType: %TypeNode, isMutable: i1 } - inline data type
        output.append("%ParamNode = type { %SeenString, %TypeNode, i1 }\n")
        // ImportPathInfo: { text: %SeenString, segments: ptr (to SeenArray) } - inline data type
        output.append("%ImportPathInfo = type { %SeenString, ptr }\n")
        // ImportSymbolNode: { name: %SeenString, alias: %SeenString } - inline data type
        output.append("%ImportSymbolNode = type { %SeenString, %SeenString }\n")
        // AnnotationNode: { name: %SeenString, arguments: ptr (to SeenArray) } - inline data type for decorators
        output.append("%AnnotationNode = type { %SeenString, ptr }\n")
        // ItemNode: { itemType, name, visibility: %SeenString, importPath, importSymbols: ptr, function, classNode, enumNode: i64 }
        output.append("%ItemNode = type { %SeenString, %SeenString, %SeenString, ptr, ptr, i64, i64, i64 }\n")
        // CommandResult: { success: Bool, output: String } - from process.seen
        output.append("%CommandResult = type { i1, %SeenString }\n")
        // RemovalResult: { success: Bool, message: String, files_removed: Array, directories_removed: Array }
        output.append("%RemovalResult = type { i1, %SeenString, %SeenArray, %SeenArray }\n\n")
        // Mark built-in types as generated to prevent re-emission
        generatedClasses.push("TypeNode")
        generatedClasses.push("ParamNode")
        generatedClasses.push("ImportPathInfo")
        generatedClasses.push("ImportSymbolNode")
        generatedClasses.push("AnnotationNode")
        generatedClasses.push("ItemNode")
        generatedClasses.push("CommandResult")
        generatedClasses.push("RemovalResult")
    }

    fun emitTBAAMetadata() r: Void {
        output.append("\n; Function attributes\n")
        var attrStr = "mustprogress nounwind"
        if g_sanitizerMode == "address" {
            attrStr = attrStr + " sanitize_address"
        }
        if g_sanitizerMode == "thread" {
            attrStr = attrStr + " sanitize_thread"
        }
        output.append("attributes #0 = { " + attrStr + " }\n")
        output.append("\n; TBAA metadata for alias analysis\n")
        output.append("!100 = !{!\"SeenTBAA\"}\n")
        output.append("!101 = !{!\"pointer\", !100, i64 0}\n")
        output.append("!102 = !{!\"integer\", !100, i64 0}\n")
        output.append("!103 = !{!\"float\", !100, i64 0}\n")
        output.append("!104 = !{!101, !101, i64 0}\n")
        output.append("!105 = !{!102, !102, i64 0}\n")
        output.append("!106 = !{!103, !103, i64 0}\n")
        output.append("!107 = !{!\"struct_field\", !100, i64 0}\n")
        output.append("!108 = !{!107, !107, i64 0}\n")
    }

    fun emitLoopMetadata() r: Void {
        emitLoopMetadataImpl(output, getCurrentFunctionOptions(), g_blockBox, g_reductionLoopIds, g_nestedLoopIds, g_loopTileHints)
    }

    // Emit a named LLVM struct type definition (e.g., %MyClass = type { i64, ptr }).
    // Deduplicates by tracking emitted classes in generatedClasses[].
    // If types were loaded from a header file (typesLoadedFromHeader), skips
    // emission for types that already have a header-sourced layout (detected by
    // the presence of inline "{ i64, ptr }" for SeenString rather than "%SeenString").
    fun emitClassType(classNode: ClassNode) r: Void {
        // Skip if already emitted in this module (deduplication)
        var classIdx = 0
        while classIdx < generatedClasses.length() {
            if generatedClasses[classIdx] == classNode.name {
                return
            }
            classIdx = classIdx + 1
        }

        // Skip if types were loaded from header file AND this class has a layout from the header
        // The header uses inline type syntax { i64, ptr } while our code uses %SeenString
        // Key indicator: header uses "{ i64, ptr }" for SeenString, while we use "%SeenString"
        if typesLoadedFromHeader {
            let structIdx = findStruct(classNode.name)
            if structIdx >= 0 {
                let existingLayout = structLayouts[structIdx]
                // Header layouts use inline SeenString: { i64, ptr }
                // User-defined layouts would use named type: %SeenString
                // If layout has "{ i64, ptr }" (inline SeenString), it's definitely from header
                // If layout doesn't contain "%SeenString", it's from header
                let usesInlineSeenString = existingLayout.contains("{ i64, ptr }")
                let usesNamedSeenString = existingLayout.contains("%SeenString")
                // If has inline SeenString pattern or non-empty without %SeenString, it's from header
                if existingLayout != "" and (usesInlineSeenString or not usesNamedSeenString) {
                    // Type is from header - just register layout and skip emit
                    registerStructLayout(classNode)
                    generatedClasses.push(classNode.name)
                    return
                }
            }
        }

        generatedClasses.push(classNode.name)

        // Register struct layout for code generation
        registerStructLayout(classNode)

        // Emit struct type for class
        // %ClassName = type { field1Type, field2Type, ... }
        // @repr(C): sequential C-compatible layout (no field reordering, default padding)
        var hasReprC = false
        var hasPacked = false
        var hasCacheLine = false
        // Collect derive trait flags during first scan (boolean flags avoid local string method calls)
        var hasDeriveSerialize = false
        var hasDeriveDeserialize = false
        var hasDeriveClone = false
        var hasDeriveHash = false
        var hasDeriveEq = false
        var hasDeriveDebug = false
        var hasDeriveJson = false
        var hasBinaryDec = false
        var hasReflectDec = false
        var hasPacketDec = false
        var packetIdDec = "0"
        var reprCDecIdx = 0
        while reprCDecIdx < classNode.decorators.length() {
            if classNode.decorators[reprCDecIdx].name == "derive" {
                // Set boolean flags for each derive trait (avoids local string method calls)
                var daiLoop = 0
                while daiLoop < classNode.decorators[reprCDecIdx].arguments.length() {
                    if classNode.decorators[reprCDecIdx].arguments[daiLoop] == "Serialize" {
                        hasDeriveSerialize = true
                    }
                    if classNode.decorators[reprCDecIdx].arguments[daiLoop] == "Deserialize" {
                        hasDeriveDeserialize = true
                    }
                    if classNode.decorators[reprCDecIdx].arguments[daiLoop] == "Clone" {
                        hasDeriveClone = true
                    }
                    if classNode.decorators[reprCDecIdx].arguments[daiLoop] == "Hash" {
                        hasDeriveHash = true
                    }
                    if classNode.decorators[reprCDecIdx].arguments[daiLoop] == "Eq" {
                        hasDeriveEq = true
                    }
                    if classNode.decorators[reprCDecIdx].arguments[daiLoop] == "Debug" {
                        hasDeriveDebug = true
                    }
                    if classNode.decorators[reprCDecIdx].arguments[daiLoop] == "Json" {
                        hasDeriveJson = true
                    }
                    daiLoop = daiLoop + 1
                }
                output.append("; @derive detected on " + className + "\n")
            }
            if classNode.decorators[reprCDecIdx].name == "binary" {
                hasBinaryDec = true
            }
            if classNode.decorators[reprCDecIdx].name == "reflect" {
                hasReflectDec = true
            }
            if classNode.decorators[reprCDecIdx].name == "packet" {
                hasPacketDec = true
                if classNode.decorators[reprCDecIdx].arguments.length() > 0 {
                    packetIdDec = classNode.decorators[reprCDecIdx].arguments[0]
                }
            }
            if classNode.decorators[reprCDecIdx].name == "repr" {
                // @repr(C) is the only repr variant — detect by name alone
                // (decorator arguments not accessible due to phantom field GEP bug)
                hasReprC = true
                g_reprCClassNames = g_reprCClassNames + classNode.name + "|"
            }
            if classNode.decorators[reprCDecIdx].name == "packed" {
                hasPacked = true
            }
            if classNode.decorators[reprCDecIdx].name == "cache_line" {
                hasCacheLine = true
                // Track for aligned allocation in constructor
                g_cacheLineClasses = g_cacheLineClasses + classNode.name + "|"
            }
            // @send/@sync type annotations
            if classNode.decorators[reprCDecIdx].name == "send" {
                g_sendTypes = g_sendTypes + classNode.name + "|"
                output.append("; @send type: " + classNode.name + "\n")
            }
            if classNode.decorators[reprCDecIdx].name == "sync" {
                g_syncTypes = g_syncTypes + classNode.name + "|"
                output.append("; @sync type: " + classNode.name + "\n")
            }
            // : @layout(soa) / @layout(aos) decorators
            if classNode.decorators[reprCDecIdx].name == "layout" {
                if classNode.decorators[reprCDecIdx].arguments.length() > 0 {
                    if classNode.decorators[reprCDecIdx].arguments[0] == "soa" {
                        g_soaClassNames = g_soaClassNames + classNode.name + "|"
                        g_soaClassCount = g_soaClassCount + 1
                        output.append("; @layout(soa) type: " + classNode.name + "\n")
                    }
                    if classNode.decorators[reprCDecIdx].arguments[0] == "aos" {
                        output.append("; @layout(aos) type: " + classNode.name + " (default layout)\n")
                    }
                }
            }
            // : @trivially_copyable decorator
            if classNode.decorators[reprCDecIdx].name == "trivially_copyable" {
                g_triviallyCopyableClasses = g_triviallyCopyableClasses + classNode.name + "|"
                output.append("; @trivially_copyable type: " + classNode.name + "\n")
            }
            // : @move non-copyable types
            if classNode.decorators[reprCDecIdx].name == "move" {
                g_moveOnlyClasses = g_moveOnlyClasses + classNode.name + "|"
                output.append("; @move (non-copyable) type: " + classNode.name + "\n")
            }
            // : @c_resource(destroy="func") lifetime bridging
            if classNode.decorators[reprCDecIdx].name == "c_resource" {
                g_cResourceClasses = g_cResourceClasses + classNode.name + "|"
                if classNode.decorators[reprCDecIdx].arguments.length() > 0 {
                    g_cResourceDestructors = g_cResourceDestructors + classNode.decorators[reprCDecIdx].arguments[0] + "|"
                } else {
                    g_cResourceDestructors = g_cResourceDestructors + "free|"
                }
                output.append("; @c_resource type: " + classNode.name + "\n")
            }
            // P2 : @reflect RTTI decorator
            if classNode.decorators[reprCDecIdx].name == "reflect" {
                g_reflectClassNames = g_reflectClassNames + classNode.name + "|"
                g_reflectClassCount = g_reflectClassCount + 1
                output.append("; @reflect type: " + classNode.name + "\n")
            }
            // P2 : @binary serialization decorator
            if classNode.decorators[reprCDecIdx].name == "binary" {
                var binEndian = "le"
                var binVersion = "1"
                var binCompress = ""
                if classNode.decorators[reprCDecIdx].arguments.length() > 0 {
                    binEndian = classNode.decorators[reprCDecIdx].arguments[0]
                }
                if classNode.decorators[reprCDecIdx].arguments.length() > 1 {
                    binVersion = classNode.decorators[reprCDecIdx].arguments[1]
                }
                if classNode.decorators[reprCDecIdx].arguments.length() > 2 {
                    binCompress = classNode.decorators[reprCDecIdx].arguments[2]
                }
                g_binaryClassNames = g_binaryClassNames + classNode.name + "|"
                g_binaryEndianness = g_binaryEndianness + binEndian + "|"
                g_binaryVersions = g_binaryVersions + binVersion + "|"
                g_binaryClassCount = g_binaryClassCount + 1
                output.append("; @binary type: " + classNode.name + " (endian=" + binEndian + ", version=" + binVersion + ")\n")
            }
            // P2 : @packet(id=N) network packet decorator
            if classNode.decorators[reprCDecIdx].name == "packet" {
                var pktId = "0"
                if classNode.decorators[reprCDecIdx].arguments.length() > 0 {
                    pktId = classNode.decorators[reprCDecIdx].arguments[0]
                }
                g_packetClassNames = g_packetClassNames + classNode.name + "|"
                g_packetClassIds = g_packetClassIds + pktId + "|"
                g_packetCount = g_packetCount + 1
                output.append("; @packet type: " + classNode.name + " (id=" + pktId + ")\n")
            }
            // : @gpu_buffer(std140) / @gpu_buffer(std430) struct layout
            if classNode.decorators[reprCDecIdx].name == "gpu_buffer" {
                var gpuLayout = "std140"
                if classNode.decorators[reprCDecIdx].arguments.length() > 0 {
                    gpuLayout = classNode.decorators[reprCDecIdx].arguments[0]
                }
                g_gpuBufferClasses = g_gpuBufferClasses + classNode.name + "|"
                g_gpuBufferLayouts = g_gpuBufferLayouts + gpuLayout + "|"
                output.append("; @gpu_buffer(" + gpuLayout + ") type: " + classNode.name + "\n")
                // Emit struct with std140/std430 padding
                output.append("%" + quoteIdentIfNeeded(classNode.name) + " = type { ")
                var gpuFi = 0
                var gpuOffset = 0
                var gpuFieldIdx = 0
                while gpuFi < classNode.fields.length() {
                    let gpuField = classNode.fields[gpuFi]
                    let gpuFieldType = mapType(normalizeDeclaredTypeNode(gpuField.paramType))
                    // Determine field size and alignment for std140
                    var gpuFieldSize = 8
                    var gpuFieldAlign = 8
                    if gpuFieldType == "i32" { gpuFieldSize = 4; gpuFieldAlign = 4 }
                    if gpuFieldType == "float" { gpuFieldSize = 4; gpuFieldAlign = 4 }
                    if gpuFieldType == "double" { gpuFieldSize = 8; gpuFieldAlign = 8 }
                    if gpuFieldType == "i64" { gpuFieldSize = 8; gpuFieldAlign = 8 }
                    if gpuFieldType == "i1" { gpuFieldSize = 4; gpuFieldAlign = 4 }
                    // std140: vec3/vec4 align to 16; arrays align to 16
                    if gpuLayout == "std140" {
                        if gpuFieldAlign < 4 { gpuFieldAlign = 4 }
                    }
                    // Insert padding if needed
                    var gpuPadding = 0
                    if gpuOffset % gpuFieldAlign != 0 {
                        gpuPadding = gpuFieldAlign - (gpuOffset % gpuFieldAlign)
                    }
                    if gpuPadding > 0 {
                        if gpuFieldIdx > 0 { output.append(", ") }
                        output.append("[" + gpuPadding.toString() + " x i8]")
                        gpuFieldIdx = gpuFieldIdx + 1
                        gpuOffset = gpuOffset + gpuPadding
                    }
                    if gpuFieldIdx > 0 { output.append(", ") }
                    output.append(gpuFieldType)
                    gpuFieldIdx = gpuFieldIdx + 1
                    gpuOffset = gpuOffset + gpuFieldSize
                    gpuFi = gpuFi + 1
                }
                // std140: total size rounded to 16 bytes
                if gpuLayout == "std140" {
                    if gpuOffset % 16 != 0 {
                        let tailPad = 16 - (gpuOffset % 16)
                        output.append(", [" + tailPad.toString() + " x i8]")
                    }
                }
                output.append(" }\n")
                return
            }
            if classNode.decorators[reprCDecIdx].name == "union" {
                // Union type: emit as storage for the largest field
                var maxFieldSize = 0
                var maxFieldType = "i8"
                var ufi = 0
                while ufi < classNode.fields.length() {
                    let uField = classNode.fields[ufi]
                    let uFieldType = mapType(normalizeDeclaredTypeNode(uField.paramType))
                    let uFieldSize = getLlvmTypeSize(uFieldType)
                    if uFieldSize > maxFieldSize {
                        maxFieldSize = uFieldSize
                        maxFieldType = uFieldType
                    }
                    ufi = ufi + 1
                }
                if maxFieldSize == 0 { maxFieldSize = 1 }
                output.append("; @union — overlapping fields, max size = " + maxFieldSize.toString() + " bytes\n")
                output.append("%" + quoteIdentIfNeeded(classNode.name) + " = type { " + maxFieldType + " }\n")
                g_unionTypes = g_unionTypes + classNode.name + "|"
                return
            }
            reprCDecIdx = reprCDecIdx + 1
        }
        if hasReprC {
            output.append("; @repr(C) — sequential C-compatible layout\n")
        }
        if hasPacked {
            output.append("; @packed — no padding between fields\n")
        }
        if hasCacheLine {
            output.append("; @cache_line — 64-byte aligned allocation\n")
        }
        if hasPacked {
            output.append("%" + quoteIdentIfNeeded(classNode.name) + " = type <{ ")
        } else {
            output.append("%" + quoteIdentIfNeeded(classNode.name) + " = type { ")
        }

        // Count real fields (skip @type_alias: synthetic fields from )
        var realFieldCount = 0
        var rfi = 0
        while rfi < classNode.fields.length() {
            let rfiField = classNode.fields[rfi]
            let rfiName = rfiField.name
            if not rfiName.startsWith("@type_alias:") {
                realFieldCount = realFieldCount + 1
            } else {
                // : Register associated type alias
                let assocNameLen = rfiName.length()
                let assocParts = rfiName.substring(12, assocNameLen)
                let rfiPT = rfiField.paramType
                let assocTarget = rfiPT.typeName
                let fullAlias = classNode.name + "." + assocParts
                g_typeAliasNames = g_typeAliasNames + fullAlias + "|"
                g_typeAliasTargets = g_typeAliasTargets + assocTarget + "|"
                g_typeAliasCount = g_typeAliasCount + 1
            }
            rfi = rfi + 1
        }
        if realFieldCount == 0 {
            // Empty struct - add dummy i8 byte for LLVM validity
            output.append("i8")
        } else {
            var i = 0
            var emittedFirst = false
            while i < classNode.fields.length() {
                let emitField = classNode.fields[i]
                let emitFieldName = emitField.name
                // Skip synthetic @type_alias fields
                if not emitFieldName.startsWith("@type_alias:") {
                    if emittedFirst {
                        output.append(", ")
                    }
                    // : Strip bitfield annotation from type for LLVM
                    let emitFieldPT = emitField.paramType
                    var fieldTypeName = emitFieldPT.typeName
                    if fieldTypeName.contains(":bitfield(") {
                        let bfPos = fieldTypeName.indexOf(":bitfield(", 0)
                        if bfPos >= 0 {
                            fieldTypeName = fieldTypeName.substring(0, bfPos)
                        }
                    }
                    output.append(mapType(fieldTypeName))
                    emittedFirst = true
                }
                i = i + 1
            }
        }

        if hasPacked {
            output.append(" }>\n")
        } else {
            output.append(" }\n")
        }
    }

    fun generateHotReloadMethods(classNode: ClassNode) r: Void {
        generateHotReloadMethodsImpl(output, classNode)
    }

    fun canUseLargePlainClassPath(parentName: String, decorators: Array<AnnotationNode>, methods: Array<FunctionNode>) r: Bool {
        if parentName != "" {
            return false
        }
        if decorators.length() > 0 {
            return false
        }
        if methods.length() < 128 {
            return false
        }
        var methodIdx = 0
        while methodIdx < methods.length() {
            if methods[methodIdx].name == "__seen_hot_reload_marker__" {
                return false
            }
            methodIdx = methodIdx + 1
        }
        return true
    }

    fun generatePlainLargeClass(className: String, parentName: String, methods: Array<FunctionNode>) r: Void {
        if className == "" {
            return
        }

        let isStringBuilder = className == "StringBuilder"

        var methodIdx = 0
        while methodIdx < methods.length() {
            let methodName = methods[methodIdx].name
            if methodName == "__seen_hot_reload_marker__" {
                methodIdx = methodIdx + 1
                continue
            }
            if isStringBuilder {
                if methodName == "new" or methodName == "append" or methodName == "appendChar" or methodName == "toString" or methodName == "clear" or methodName == "length" {
                    methodIdx = methodIdx + 1
                    continue
                }
            }
            generateClassMethodFromList(className, parentName, methods, methodIdx)
            methodIdx = methodIdx + 1
        }

        g_currentClassParentName = ""
    }

    // Generate IR for all methods of a class, plus derived implementations
    // (@derive, @reflect, @binary, @packet decorators). Skips @trait
    // definitions (which only generate default method implementations).
    // Handles the `new` constructor specially: emits malloc + memset zero-init
    // followed by field initialization. For classes with Array<T> fields,
    // post-constructor code emits seen_arr_new_* calls using byte-offset
    // i8 GEP to initialize array headers (fixes null-ptr-after-constructor bug).
    // NOTE: Uses memset zero-init instead of per-field GEP to avoid the
    // cross-module GEP bug where %ClassName from module Y is not available in
    // module X.
    fun generateClass(classNode: ClassNode) r: Void {
        // Skip classes with parsing issues
        let className = classNode.name
        if className == "" {
            // Empty class name means parsing issue - skip to avoid bad code
            return
        }

        // Skip @trait definitions (no struct type, only method signatures for checking)
        var classIsTrait = false
        var classDecScanIdx = 0
        while classDecScanIdx < classNode.decorators.length() {
            if classNode.decorators[classDecScanIdx].name == "trait" {
                classIsTrait = true
            }
            classDecScanIdx = classDecScanIdx + 1
        }
        if classIsTrait {
            output.append("; trait " + className + " (method signatures + default impls)\n")
            // Register trait methods as expected signatures for validation
            var traitMI = 0
            while traitMI < classNode.methods.length() {
                let traitMethod = classNode.methods[traitMI]
                let traitFuncName = className + "_" + traitMethod.name
                let traitRetTypeName = resolveMethodReturnType(className, traitMethod)
                registerFunction(traitFuncName, traitRetTypeName)
                registerStructMethod(className, traitMethod.name, traitRetTypeName)
                // Generate default implementation for methods with a body
                if traitMethod.body.statements.length() > 0 {
                    let defaultFuncName = className + "_" + traitMethod.name + "_default"
                    output.append("; trait default method: " + defaultFuncName + "\n")
                    // Save and set per-function state
                    let savedRetType = currentFunctionReturnType
                    currentFunctionReturnType = traitRetTypeName
                    let savedVarNames = varNames
                    let savedVarRegs = varRegs
                    let savedVarTypes = varTypes
                    let savedPreAllocatedVars = preAllocatedVars
                    let savedPreAllocatedTypes = preAllocatedTypes
                    let savedPreAllocatedRegs = preAllocatedRegs
                    let savedDeclOrdinalNames = declOrdinalNames
                    let savedDeclOrdinalCounts = declOrdinalCounts
                    let savedActiveVarCount = activeVarCount
                    let savedNextReg = g_regBox[0]
                    let savedBlockTerm = blockTerminated
                    varNames = Array<String>()
                    varRegs = Array<String>()
                    varTypes = Array<String>()
                    preAllocatedVars = Array<String>()
                    preAllocatedTypes = Array<String>()
                    preAllocatedRegs = Array<String>()
                    declOrdinalNames = Array<String>()
                    declOrdinalCounts = Array<Int>()
                    activeVarCount = 0
                    g_regBox[0] = 1
                    blockTerminated = false
                    cseClear()
                    // Build parameter list
                    var defParamStr = ""
                    var defPI = 0
                    while defPI < traitMethod.params.length() {
                        if defPI > 0 {
                            defParamStr = defParamStr + ", "
                        }
                        let defParam = traitMethod.params[defPI]
                        let defParamType = mapType(normalizeDeclaredTypeNode(defParam.paramType))
                        let defParamReg = "%" + quoteIdentIfNeeded(defParam.name)
                        defParamStr = defParamStr + defParamType + " " + defParamReg
                        storeVar(defParam.name, defParamReg, normalizeDeclaredTypeNode(defParam.paramType))
                        defPI = defPI + 1
                    }
                    let defRetType = mapType(traitRetTypeName)
                    output.append("define " + defRetType + " @" + quoteIdentIfNeeded(defaultFuncName) + "(" + defParamStr + ") {\n")
                    output.append("entry:\n")
                    generateBlock(traitMethod.body)
                    if not blockTerminated {
                        if defRetType == "void" {
                            output.append("  ret void\n")
                        } else {
                            output.append("  ret " + defRetType + " zeroinitializer\n")
                        }
                    }
                    output.append("}\n\n")
                    // Restore state
                    currentFunctionReturnType = savedRetType
                    varNames = savedVarNames
                    varRegs = savedVarRegs
                    varTypes = savedVarTypes
                    preAllocatedVars = savedPreAllocatedVars
                    preAllocatedTypes = savedPreAllocatedTypes
                    preAllocatedRegs = savedPreAllocatedRegs
                    declOrdinalNames = savedDeclOrdinalNames
                    declOrdinalCounts = savedDeclOrdinalCounts
                    activeVarCount = savedActiveVarCount
                    g_regBox[0] = savedNextReg
                    blockTerminated = savedBlockTerm
                    registerFunction(defaultFuncName, traitRetTypeName)
                }
                traitMI = traitMI + 1
            }
            // : Emit vtable struct type for dyn Trait dispatch
            g_dynTraitNames = g_dynTraitNames + className + "|"
            output.append("; dyn " + className + " vtable type\n")
            output.append("%" + quoteIdentIfNeeded(className + "_vtable") + " = type { ")
            var vtMI = 0
            while vtMI < classNode.methods.length() {
                if vtMI > 0 {
                    output.append(", ")
                }
                output.append("ptr")
                vtMI = vtMI + 1
            }
            if classNode.methods.length() == 0 {
                output.append("i8")
            }
            output.append(" }\n\n")
            return
        }

        // Handle @type_alias: register alias in mapType lookup
        var classIsTypeAlias = false
        classDecScanIdx = 0
        while classDecScanIdx < classNode.decorators.length() {
            if classNode.decorators[classDecScanIdx].name == "type_alias" {
                classIsTypeAlias = true
                if classNode.decorators[classDecScanIdx].arguments.length() > 0 {
                    let aliasTarget = classNode.decorators[classDecScanIdx].arguments[0]
                    output.append("; type " + className + " = " + aliasTarget + "\n")
                    // Register as a type alias: when mapType sees className, resolve to target
                    if g_typeAliasCount > 0 {
                        g_typeAliasNames = g_typeAliasNames + "|" + className
                        g_typeAliasTargets = g_typeAliasTargets + "|" + aliasTarget
                    } else {
                        g_typeAliasNames = className
                        g_typeAliasTargets = aliasTarget
                    }
                    g_typeAliasCount = g_typeAliasCount + 1
                }
            }
            classDecScanIdx = classDecScanIdx + 1
        }
        if classIsTypeAlias {
            // Check if this is also a @distinct type
            var classIsDistinct = false
            var distDecIdx = 0
            while distDecIdx < classNode.decorators.length() {
                if classNode.decorators[distDecIdx].name == "distinct" {
                    classIsDistinct = true
                    if classNode.decorators[distDecIdx].arguments.length() > 0 {
                        let distinctTarget = classNode.decorators[distDecIdx].arguments[0]
                        output.append("; distinct " + className + " = " + distinctTarget + " (no implicit conversion)\n")
                        g_distinctTypeNames = g_distinctTypeNames + className + "|"
                    }
                }
                distDecIdx = distDecIdx + 1
            }
            return
        }

        // For StringBuilder, the runtime-backed methods should not be emitted from
        // the source class because call sites already dispatch to the C runtime ABI.
        let isStringBuilder = className == "StringBuilder"

        // Scan decorators for @derive/@binary/@reflect/@packet in generateClass
        // NOTE: use Int 0/1 not Bool — stage1_frozen has broken boolean variables
        var hasDeriveSerialize = 0
        var hasDeriveDeserialize = 0
        var hasDeriveClone = 0
        var hasDeriveHash = 0
        var hasDeriveEq = 0
        var hasDeriveDebug = 0
        var hasDeriveJson = 0
        var hasBinaryDec2 = 0
        var hasReflectDec2 = 0
        var hasPacketDec2 = 0
        var packetIdDec = "0"
        var gcDecScan = 0
        while gcDecScan < classNode.decorators.length() {
            if classNode.decorators[gcDecScan].name == "derive" {
                // Unconditionally enable all derive traits when @derive is detected
                // The argument scanning nested loop causes codegen issues with stage1_frozen
                // Instead, generate all derive methods — unused ones are harmless
                hasDeriveSerialize = 1
                hasDeriveDeserialize = 1
                hasDeriveClone = 1
                hasDeriveHash = 1
                hasDeriveEq = 1
                hasDeriveDebug = 1
                hasDeriveJson = 1
            }
            if classNode.decorators[gcDecScan].name == "binary" {
                hasBinaryDec2 = 1
            }
            if classNode.decorators[gcDecScan].name == "reflect" {
                hasReflectDec2 = 1
            }
            if classNode.decorators[gcDecScan].name == "packet" {
                hasPacketDec2 = 1
                if classNode.decorators[gcDecScan].arguments.length() > 0 {
                    packetIdDec = classNode.decorators[gcDecScan].arguments[0]
                }
            }
            gcDecScan = gcDecScan + 1
        }

        // Pre-scan methods for @hot_reload sentinel (avoids accessing classNode.decorators
        // which is at a broken GEP index due to the static fun phantom field bug).
        var isHotReload = 0
        var hrScan = 0
        while hrScan < classNode.methods.length() {
            if classNode.methods[hrScan].name == "__seen_hot_reload_marker__" {
                isHotReload = 1
                break
            }
            hrScan = hrScan + 1
        }

        // Generate all methods for this class
        var i = 0
        while i < classNode.methods.length() {
            let methodName = classNode.methods[i].name
            // Skip the @hot_reload sentinel marker
            if methodName == "__seen_hot_reload_marker__" {
                i = i + 1
                continue
            }
            // For StringBuilder, skip methods provided by C runtime
            if isStringBuilder {
                if methodName == "new" or methodName == "append" or methodName == "appendChar" or methodName == "toString" or methodName == "clear" or methodName == "length" {
                    i = i + 1
                    continue
                }
            }
            generateClassMethodByIndex(classNode, i)
            i = i + 1
        }

        // Generate @hot_reload synthesized methods if class has the decorator
        if isHotReload == 1 {
            generateHotReloadMethods(classNode)
        }

        // Dispatch decorator-generated methods using Int flags (not Bool — stage1 bug)
        if hasDeriveSerialize == 1 {
            generateDeriveSerialize(classNode)
        }
        if hasDeriveDeserialize == 1 {
            generateDeriveDeserialize(classNode)
        }
        if hasDeriveClone == 1 {
            generateDeriveClone(classNode)
        }
        if hasDeriveHash == 1 {
            generateDeriveHash(classNode)
        }
        if hasDeriveEq == 1 {
            generateDeriveEq(classNode)
        }
        if hasDeriveDebug == 1 {
            generateDeriveDebug(classNode)
        }
        if hasDeriveJson == 1 {
            generateJsonSerialize(classNode)
            generateJsonDeserialize(classNode)
        }
        if hasReflectDec2 == 1 {
            generateReflect(classNode)
        }
        if hasBinaryDec2 == 1 {
            generateBinarySerializer(classNode)
            generateBinaryDeserializer(classNode)
        }
        if hasPacketDec2 == 1 {
            generatePacketWriter(classNode, packetIdDec)
            generatePacketReader(classNode, packetIdDec)
        }

        // Generate inherited method thunks for methods defined on parent but not overridden
        let pnLen2 = classNode.parentName.length()
        if pnLen2 > 0 {
            let parentIdx = findStruct(classNode.parentName)
            if parentIdx >= 0 {
                let parentMethodList = structMethodNames[parentIdx]
                let parentRetTypes = structMethodRetTypes[parentIdx]
                let pmc = countCommaFields(parentMethodList)
                var pmi = 0
                while pmi < pmc {
                    let parentMethodName = commaGet(parentMethodList, pmi)
                    let parentRetType = pipeGet(parentRetTypes, pmi)
                    // Check if child already defines this method
                    var childHasIt = 0
                    var cmi = 0
                    while cmi < classNode.methods.length() {
                        if classNode.methods[cmi].name == parentMethodName {
                            childHasIt = 1
                        }
                        cmi = cmi + 1
                    }
                    if childHasIt == 0 {
                        let llvmRet = mapType(parentRetType)
                        let thunkName = classNode.name + "_" + parentMethodName
                        let parentFuncName = classNode.parentName + "_" + parentMethodName
                        output.append("define " + llvmRet + " @" + quoteIdentIfNeeded(thunkName) + "(ptr %this) {\n")
                        output.append("entry:\n")
                        if llvmRet == "void" {
                            output.append("  call void @" + quoteIdentIfNeeded(parentFuncName) + "(ptr %this)\n")
                            output.append("  ret void\n")
                        } else {
                            let r = getNextReg()
                            output.append("  " + r + " = call " + llvmRet + " @" + quoteIdentIfNeeded(parentFuncName) + "(ptr %this)\n")
                            output.append("  ret " + llvmRet + " " + r + "\n")
                        }
                        output.append("}\n\n")
                    }
                    pmi = pmi + 1
                }
            }
        }

        g_currentClassParentName = ""
    }

    // Generate toBytes() method for @derive(Serialize)
    fun generateDeriveSerialize(classNode: ClassNode) r: Void {
        generateDeriveSerializeImpl(output, classNode, structNames, structMethodNames, structMethodRetTypes, funcNames, funcRetTypes)
    }

    // Generate fromBytes() method for @derive(Deserialize)
    fun generateDeriveDeserialize(classNode: ClassNode) r: Void {
        generateDeriveDeserializeImpl(output, classNode, structNames, structMethodNames, structMethodRetTypes, funcNames, funcRetTypes)
    }

    // P2 : @derive(Clone) — deep copy all fields
    fun generateDeriveClone(classNode: ClassNode) r: Void {
        generateDeriveCloneImpl(output, classNode, structNames, structMethodNames, structMethodRetTypes, funcNames, funcRetTypes)
    }

    // P2 : @derive(Hash) — FNV-1a hash combining all fields
    fun generateDeriveHash(classNode: ClassNode) r: Void {
        generateDeriveHashImpl(output, classNode, structNames, structMethodNames, structMethodRetTypes, funcNames, funcRetTypes)
    }

    // P2 : @derive(Eq) — pairwise field comparison
    fun generateDeriveEq(classNode: ClassNode) r: Void {
        generateDeriveEqImpl(output, classNode, structNames, structMethodNames, structMethodRetTypes, funcNames, funcRetTypes)
    }

    // P2 : @derive(Debug) — string representation
    fun generateDeriveDebug(classNode: ClassNode) r: Void {
        generateDeriveDebugImpl(output, classNode, structNames, structMethodNames, structMethodRetTypes, funcNames, funcRetTypes, stringConstants, stringConstantPrefix)
    }

    // P2 : @reflect — RTTI methods
    fun generateReflect(classNode: ClassNode) r: Void {
        generateReflectImpl(output, classNode, structNames, structMethodNames, structMethodRetTypes, funcNames, funcRetTypes, stringConstants, stringConstantPrefix)
    }

    // P2 : @binary serialization
    fun generateBinarySerializer(classNode: ClassNode) r: Void {
        generateBinarySerializerImpl(output, classNode, structNames, structMethodNames, structMethodRetTypes, funcNames, funcRetTypes, g_binaryClassNames, g_binaryVersions, g_binaryEndianness, g_binaryClassCount)
    }

    // P2 : @binary deserialization
    fun generateBinaryDeserializer(classNode: ClassNode) r: Void {
        generateBinaryDeserializerImpl(output, classNode, structNames, structMethodNames, structMethodRetTypes, funcNames, funcRetTypes, g_binaryClassNames, g_binaryVersions, g_binaryEndianness, g_binaryClassCount)
    }

    // P2 : JSON serialization
    fun generateJsonSerialize(classNode: ClassNode) r: Void {
        generateJsonSerializeImpl(output, classNode, structNames, structSizes, structMethodNames, structMethodRetTypes, funcNames, funcRetTypes, stringConstants, stringConstantPrefix)
    }

    // P2 : JSON deserialization
    fun generateJsonDeserialize(classNode: ClassNode) r: Void {
        generateJsonDeserializeImpl(output, classNode, structNames, structSizes, structMethodNames, structMethodRetTypes, funcNames, funcRetTypes, stringConstants, stringConstantPrefix)
    }

    // P2 : Packet writer
    fun generatePacketWriter(classNode: ClassNode, packetIdStr: String) r: Void {
        generatePacketWriterImpl(output, classNode, packetIdStr, structNames, structMethodNames, structMethodRetTypes, funcNames, funcRetTypes)
    }

    // P2 : Packet reader
    fun generatePacketReader(classNode: ClassNode, packetIdStr: String) r: Void {
        generatePacketReaderImpl(output, classNode, packetIdStr, structNames, structMethodNames, structMethodRetTypes, funcNames, funcRetTypes)
    }

    // Generate IR for a single class method. The method name is mangled as
    // ClassName_methodName. Non-static methods receive an implicit `ptr %this`
    // first parameter pointing to the heap-allocated struct.
    //
    // Option class methods (isSome, isNone) are inlined against the direct-value
    // option object layout used by runtime unwrap helpers.
    // rather than delegated to the C runtime.
    //
    // CRITICAL: cseClear() is called at method entry to prevent the cross-method
    // CSE bug. Without it, a CSE key like "%4*%7->%8" cached from method A
    // could match the same register numbers in method B (since each method
    // resets nextReg to 1), producing self-referential IR that causes LLVM
    // verification failures.
    fun methodHasDecoratorInList(methods: Array<FunctionNode>, methodIdx: Int, decoratorName: String) r: Bool {
        var decoratorIdx = 0
        while decoratorIdx < methods[methodIdx].decorators.length() {
            if methods[methodIdx].decorators[decoratorIdx].name == decoratorName {
                return true
            }
            decoratorIdx = decoratorIdx + 1
        }
        return false
    }

    fun methodHasDecoratorByIndex(classNode: ClassNode, methodIdx: Int, decoratorName: String) r: Bool {
        return methodHasDecoratorInList(classNode.methods, methodIdx, decoratorName)
    }

    fun generateClassMethodFromList(className: String, parentName: String, methods: Array<FunctionNode>, methodIdx: Int) r: Void {
        let methodName = methods[methodIdx].name
        if className == "JsonParseResult" or className == "JsonParser" or className == "LLVMIRGenerator" {
            println("[irgen class method start] " + className + "." + methodName)
        }
        // Handle Option class methods specially.
        if className == "Option" or className.startsWith("Option<") {
            // Generate isSome/IsSome - load the hasValue field directly.
            if methodName == "isSome" or methodName == "IsSome" {
                output.append("define i1 @Option_" + methodName + "(ptr %this) {\n")
                output.append("entry:\n")
                output.append("  %hasValuePtr = getelementptr inbounds { i1, i64 }, ptr %this, i32 0, i32 0\n")
                output.append("  %hasValue = load i1, ptr %hasValuePtr\n")
                output.append("  ret i1 %hasValue\n")
                output.append("}\n\n")
                return
            }
            // Generate isNone/IsNone - negate the hasValue field.
            if methodName == "isNone" or methodName == "IsNone" {
                output.append("define i1 @Option_" + methodName + "(ptr %this) {\n")
                output.append("entry:\n")
                output.append("  %hasValuePtr = getelementptr inbounds { i1, i64 }, ptr %this, i32 0, i32 0\n")
                output.append("  %hasValue = load i1, ptr %hasValuePtr\n")
                output.append("  %isNone = xor i1 %hasValue, true\n")
                output.append("  ret i1 %isNone\n")
                output.append("}\n\n")
                return
            }
            // Skip other Option methods - use C runtime implementations
            output.append("; SKIPPED: Option_" + methodName + " (use C runtime implementation)\n")
            return
        }

        // Reset per-function state (nextBlock NOT reset - accumulates for per-loop metadata)
        g_regBox[0] = 1
        varNames = Array<String>()
        varRegs = Array<String>()
        varTypes = Array<String>()
        preAllocatedVars = Array<String>()
        preAllocatedTypes = Array<String>()
        preAllocatedRegs = Array<String>()
        activeVarCount = 0
        declOrdinalNames = Array<String>()
        declOrdinalCounts = Array<Int>()
        currentFunctionReturnType = resolveMethodReturnTypeFromList(className, methods, methodIdx)
        currentClassName = className  // Track class for method type inference
        g_currentClassParentName = parentName
        blockTerminated = false
        resetFunctionLoweringOptionsState()
        cseClear()  // CSE cache must not carry over between class methods (cross-method register collision)

        // Pre-register parameter types for use during variable collection
        // (needed so inferExpressionType can find parameter types)
        // Also pre-register 'this' for instance methods (non-static)
        let isStaticMethod = methods[methodIdx].isStatic
        if not isStaticMethod {
            storeVar("this", "", className)
        }
        var preParamIdx = 0
        while preParamIdx < methods[methodIdx].params.length() {
            let param = methods[methodIdx].params[preParamIdx]
            storeVar(param.name, "", normalizeDeclaredTypeNode(param.paramType))
            preParamIdx = preParamIdx + 1
        }

        // Collect all variable declarations for hoisting allocas to entry block
        collectVariableDeclarations(methods[methodIdx].body)

        // Clear pre-registered parameters (will be re-added with proper registers)
        varNames = Array<String>()
        varRegs = Array<String>()
        varTypes = Array<String>()
        activeVarCount = 0

        let returnType = mapType(currentFunctionReturnType)

        // Determine if this is a static method (name is "new" or has isStatic flag)
        let isStatic = methods[methodIdx].isStatic or methodName == "new"

        // Build method attributes
        var methodAttrs = ""
        if methods[methodIdx].isInline {
            methodAttrs = " alwaysinline"
        }
        if methodHasDecoratorInList(methods, methodIdx, "noinline") {
            methodAttrs = " noinline"
        }
        if methodHasDecoratorInList(methods, methodIdx, "cold") {
            methodAttrs = methodAttrs + " cold"
        }
        if methodHasDecoratorInList(methods, methodIdx, "always_inline") {
            methodAttrs = " alwaysinline"
        }
        if methodHasDecoratorInList(methods, methodIdx, "hot") {
            methodAttrs = methodAttrs + " hot"
        }
        if methodHasDecoratorInList(methods, methodIdx, "pure") {
            methodAttrs = methodAttrs + " readonly nounwind"
        }

        // norecurse / noinline for recursive class methods; inlinehint for small methods
        let qualMethodName = className + "_" + methodName
        let isMethodSelfRecursive = selfCallCheck(qualMethodName, g_selfCallFuncs, g_selfCallNames, g_selfCallCount)
        if isMethodSelfRecursive {
            methodAttrs = methodAttrs.replace(" alwaysinline", "")
            methodAttrs = methodAttrs.replace(" inlinehint", "")
            methodAttrs = methodAttrs + " noinline"
        }
        if not isMethodSelfRecursive {
            methodAttrs = methodAttrs + " norecurse"
            // Add inlinehint for small non-recursive methods (≤15 statements)
            // This encourages LLVM to inline hot accessor/checker methods like .check()
            let methodBodySize = methods[methodIdx].body.statements.length()
            if methodBodySize <= 15 and not methodAttrs.contains("noinline") and not methodAttrs.contains("alwaysinline") {
                methodAttrs = methodAttrs + " inlinehint"
            }
        }

        // Function signature: ClassName_methodName or ClassName_new
        // Add noundef on primitive return types to enable stronger LLVM optimizations
        var methodRetPrefix = "define "
        if returnType == "i64" or returnType == "double" or returnType == "i1" {
            methodRetPrefix = "define noundef "
        }
        output.append(methodRetPrefix + returnType + " @" + quoteIdentIfNeeded(className + "_" + methodName) + "(")

        // For instance methods, first parameter is 'this' pointer
        var hasThis = false
        if not isStatic {
            output.append("ptr %this")
            hasThis = true
        }

        // Detect explicit receiver param: first param with name 'self' or 'this' and type == className
        // (Python/Rust-style explicit self parameter)
        var explicitReceiverName = ""
        if not isStatic {
            if methods[methodIdx].params.length() > 0 {
                let firstParam = methods[methodIdx].params[0]
                if firstParam.paramType.typeName == className {
                    if firstParam.name == "self" {
                        explicitReceiverName = "self"
                    }
                    if firstParam.name == "this" {
                        explicitReceiverName = "this"
                    }
                }
            }
        }

        // Other parameters (skip explicit receiver param — handled by implicit ptr %this)
        var paramIdx = 0
        while paramIdx < methods[methodIdx].params.length() {
            let param = methods[methodIdx].params[paramIdx]
            var isExplicitReceiver = 0
            if param.name == explicitReceiverName {
                if explicitReceiverName != "" {
                    isExplicitReceiver = 1
                }
            }
            if isExplicitReceiver == 0 {
                if paramIdx > 0 or hasThis {
                    output.append(", ")
                }
                let paramType = mapTypeForParameter(normalizeDeclaredTypeNode(param.paramType))
                output.append(paramType + " %" + quoteIdentIfNeeded(param.name + ".arg"))
            }
            paramIdx = paramIdx + 1
        }

        output.append(")" + methodAttrs + " #0 {\n")
        output.append("entry:\n")

        // For instance methods, store 'this' pointer
        var savedThisReg = ""
        if not isStatic {
            let thisReg = getNextReg()
            output.append("  " + thisReg + " = alloca ptr\n")
            output.append("  store ptr %this, ptr " + thisReg + "\n")
            storeVar("this", thisReg, className)
            savedThisReg = thisReg
            // If method has explicit receiver with different name (e.g. 'self'), register it too
            if explicitReceiverName != "this" {
                if explicitReceiverName != "" {
                    storeVar(explicitReceiverName, thisReg, className)
                }
            }
        }

        // Allocate space for parameters and store them (skip explicit receiver)
        paramIdx = 0
        while paramIdx < methods[methodIdx].params.length() {
            let param = methods[methodIdx].params[paramIdx]
            var isExplicitReceiver2 = 0
            if param.name == explicitReceiverName {
                if explicitReceiverName != "" {
                    isExplicitReceiver2 = 1
                }
            }
            if isExplicitReceiver2 == 0 {
                let seenTypeName = normalizeDeclaredTypeNode(param.paramType)
                let semanticSeenTypeName = normalizeSeenTypeName(seenTypeName)
                // Data type params come in as ptr (ABI compat with Rust backend)
                // Use the incoming ptr directly as the variable location
                if isDataType(semanticSeenTypeName) {
                    storeVar(param.name, "%" + quoteIdentIfNeeded(param.name + ".arg"), semanticSeenTypeName)
                } else {
                    let paramType = mapStorageTypeForParameter(seenTypeName)
                    let reg = getNextReg()
                    output.append("  " + reg + " = alloca " + paramType + "\n")
                    output.append("  store " + paramType + " %" + quoteIdentIfNeeded(param.name + ".arg") + ", ptr " + reg + "\n")
                    storeVar(param.name, reg, semanticSeenTypeName)
                }
            }
            paramIdx = paramIdx + 1
        }

        // Emit allocas for all local variables at entry (avoids domination errors)
        emitPreAllocatedAllocas()

        // For constructor 'new' methods: allocate object, zero-init, register 'this'
        if methodName == "new" {
            let cStructIdx = findStruct(className)
            var cStructSize = 16
            if cStructIdx >= 0 {
                cStructSize = structSizes[cStructIdx]
                if cStructSize == 0 {
                    cStructSize = 16
                }
            }
            let cAllocReg = getNextReg()
            if cStructSize <= 80 {
                output.append("  " + cAllocReg + " = call ptr @seen_pool_alloc(i64 " + cStructSize.toString() + ")\n")
            }
            if cStructSize > 80 {
                output.append("  " + cAllocReg + " = call ptr @malloc(i64 " + cStructSize.toString() + ")\n")
            }
            output.append("  call void @llvm.memset.p0.i64(ptr " + cAllocReg + ", i8 0, i64 " + cStructSize.toString() + ", i1 false)\n")
            let cThisReg = getNextReg()
            output.append("  " + cThisReg + " = alloca ptr\n")
            output.append("  store ptr " + cAllocReg + ", ptr " + cThisReg + "\n")
            storeVar("this", cThisReg, className)
            // Initialize Array<T>/List<T> fields (memset leaves them as null ptrs)
            if cStructIdx >= 0 {
                var cFieldNamesStr = structFieldNames[cStructIdx]
                var cFieldTypesStr = structFieldTypes[cStructIdx]
                var cByteOffset = 0
                var cNamePos = 0
                var cTypePos = 0
                var cIterDone = 0
                while cIterDone == 0 {
                    var cNameEnd = cNamePos
                    while cNameEnd < cFieldNamesStr.length() and cFieldNamesStr.byteAt(cNameEnd) != 44 {
                        cNameEnd = cNameEnd + 1
                    }
                    var cTypeEnd = cTypePos
                    while cTypeEnd < cFieldTypesStr.length() and cFieldTypesStr.byteAt(cTypeEnd) != 124 {
                        cTypeEnd = cTypeEnd + 1
                    }
                    var cFieldSeenType = cFieldTypesStr.substring(cTypePos, cTypeEnd)
                    var cIsArrayField = 0
                    if cFieldSeenType.startsWith("Array<") {
                        cIsArrayField = 1
                    }
                    if cFieldSeenType.startsWith("List<") {
                        cIsArrayField = 1
                    }
                    if cIsArrayField == 1 {
                        let cFieldPtrReg = getNextReg()
                        output.append("  " + cFieldPtrReg + " = getelementptr inbounds i8, ptr " + cAllocReg + ", i64 " + cByteOffset.toString() + "\n")
                        var cElemType = ""
                        if cFieldSeenType.startsWith("Array<") {
                            cElemType = cFieldSeenType.substring(6, cFieldSeenType.length() - 1)
                        }
                        if cFieldSeenType.startsWith("List<") {
                            cElemType = cFieldSeenType.substring(5, cFieldSeenType.length() - 1)
                        }
                        let cArrInitReg = getNextReg()
                        if cElemType == "String" {
                            output.append("  " + cArrInitReg + " = call ptr @seen_arr_new_str_ptr()\n")
                        }
                        if cElemType != "String" {
                            var cUsedSizeInit = 0
                            if isDataType(cElemType) {
                                let cElemSize = getDataTypeSize(cElemType)
                                output.append("  " + cArrInitReg + " = call ptr @seen_arr_new_with_size_ptr(i64 " + cElemSize.toString() + ")\n")
                                cUsedSizeInit = 1
                            }
                            if cUsedSizeInit == 0 {
                                output.append("  " + cArrInitReg + " = call ptr @seen_arr_new_ptr_ptr()\n")
                            }
                        }
                        output.append("  store ptr " + cArrInitReg + ", ptr " + cFieldPtrReg + "\n")
                    }
                    cByteOffset = cByteOffset + getTypeSize(cFieldSeenType)
                    if cNameEnd < cFieldNamesStr.length() {
                        cNamePos = cNameEnd + 1
                        cTypePos = cTypeEnd + 1
                    }
                    if cNameEnd >= cFieldNamesStr.length() {
                        cIterDone = 1
                    }
                }
            }
        }

        // Generate method body
        generateBlock(methods[methodIdx].body)

        // For 'new' constructor: return the allocated object as i64
        if not blockTerminated {
            if methodName == "new" {
                let cThisVarIdx = findVar("this")
                if cThisVarIdx >= 0 {
                    let cThisLoad = getNextReg()
                    output.append("  " + cThisLoad + " = load ptr, ptr " + varRegs[cThisVarIdx] + "\n")
                    let cPtrToInt = getNextReg()
                    output.append("  " + cPtrToInt + " = ptrtoint ptr " + cThisLoad + " to i64\n")
                    output.append("  ret i64 " + cPtrToInt + "\n")
                    blockTerminated = true
                }
            }
        }

        // If no terminator was generated, add a default return
        if not blockTerminated {
            var emittedRet = false
            if returnType == "void" {
                output.append("  ret void\n")
                emittedRet = true
            }
            if not emittedRet and returnType == "i1" {
                output.append("  ret i1 false\n")
                emittedRet = true
            }
            if not emittedRet and returnType == "i64" {
                output.append("  ret i64 0\n")
                emittedRet = true
            }
            if not emittedRet and returnType == "ptr" {
                output.append("  ret ptr null\n")
                emittedRet = true
            }
            if not emittedRet and returnType == "%SeenString" {
                output.append("  ret %SeenString zeroinitializer\n")
                emittedRet = true
            }
            if not emittedRet and returnType == "%SeenArray" {
                output.append("  ret %SeenArray zeroinitializer\n")
                emittedRet = true
            }
            if not emittedRet {
                // Default for other types
                output.append("  ret " + returnType + " zeroinitializer\n")
            }
        }

        output.append("}\n\n")
    }

    fun generateClassMethodByIndex(classNode: ClassNode, methodIdx: Int) r: Void {
        generateClassMethodFromList(classNode.name, classNode.parentName, classNode.methods, methodIdx)
    }

    fun emitStringConstants() r: Void {
        var i = 0
        while i < stringConstants.length() {
            let str = stringConstants[i]
            let escaped = escapeString(str)
            let len = str.length() + 1  // +1 for null terminator
            output.append("@.str." + i.toString() + " = private unnamed_addr constant [" + len.toString() + " x i8] c\"" + escaped + "\\00\"\n")
            i = i + 1
        }
        if stringConstants.length() > 0 {
            output.append("\n")
        }
    }

    // Emit string constants with module prefix to avoid collisions in per-module compilation
    fun emitStringConstantsWithPrefix(moduleIndex: Int) r: Void {
        var i = 0
        while i < stringConstants.length() {
            let str = stringConstants[i]
            let escaped = escapeString(str)
            let len = str.length() + 1  // +1 for null terminator
            // Module-prefixed name: @.str.M0.0, @.str.M1.0, etc.
            output.append("@.str.M" + moduleIndex.toString() + "." + i.toString() + " = private unnamed_addr constant [" + len.toString() + " x i8] c\"" + escaped + "\\00\"\n")
            i = i + 1
        }
        if stringConstants.length() > 0 {
            output.append("\n")
        }
    }

    // Delegates to free functions in ir_decl_runtime/parser/features.seen
    // Emit `declare` statements for all runtime C functions (seen_runtime.c)
    // and standard library functions that might be called from user code.
    // Skips functions that are defined in this module (definedFuncs) to
    // avoid "invalid redefinition" LLVM errors. Delegates to specialized
    // emitters in ir_decl_runtime, ir_decl_parser, ir_decl_features.
    fun emitRuntimeDeclarations(definedFuncs: Array<String>) r: Void {
        emitCoreRuntimeDecls(output, runtimeDeclsLoaded, definedFuncs)
        emitStringAndIODecls(output, definedFuncs)
        emitParserDecls(output, definedFuncs)
        emitTypecheckerDecls(output, runtimeDeclsLoaded, definedFuncs)
        emitMacroAndLspDecls(output, definedFuncs)
        emitFeatureDecls(output, definedFuncs)
    }

    fun emitProgramGlobalVariables(program: ProgramNode) r: Void {
        let moduleConstMutableBox = Array<String>()
        moduleConstMutableBox.push(g_moduleConstMutable)
        let moduleConstSeenTypesBox = Array<String>()
        moduleConstSeenTypesBox.push(g_moduleConstSeenTypes)
        emitGlobalVariablesImpl(output, program, moduleConstantNames, moduleConstantTypes, moduleConstantValues, moduleConstMutableBox, moduleConstSeenTypesBox)
        g_moduleConstMutable = moduleConstMutableBox[0]
        g_moduleConstSeenTypes = moduleConstSeenTypesBox[0]
    }

    fun emitCrossModuleConstantDeclares() r: Void {
        emitCrossModuleConstantDeclaresImpl(output, moduleConstantNames, g_xmConstNames, g_xmConstTypes, g_xmConstCount)
    }

    fun emitTraitVtableConstants() r: Void {
        emitTraitVtableConstantsImpl(output, g_traitImplRegistry, g_traitImplCount, g_dynTraitNames)
    }

    fun emitGlobalConstructors() r: Void {
        emitGlobalConstructorsImpl(output, g_initFuncCount, g_initFuncNames)
    }

    // Helper to check if a function has a specific decorator
    fun hasDecorator(fn: FunctionNode, decoratorName: String) r: Bool {
        var i = 0
        while i < fn.decorators.length() {
            if fn.decorators[i].name == decoratorName {
                return true
            }
            i = i + 1
        }
        return false
    }

    // : Generate CPU dispatch wrapper for a GPU shader function
    // The wrapper takes the same parameters and calls seen_gpu_dispatch with buffer handles
    // NOTE: Simplified to avoid stage1_frozen "store %SeenString 0" bug in loop bodies
    fun generateGpuDispatchWrapper(fn: FunctionNode, stage: Int, bindingCount: Int, wgX: Int, wgY: Int, wgZ: Int) r: Void {
        // Generate a simple void dispatch wrapper that takes group counts + buffer handles
        // Avoids iterating fn.params with string let bindings (triggers stage1 codegen bug)
        output.append("define void @" + quoteIdentIfNeeded(fn.name + "_gpu_dispatch") + "(i64 %gpu_gx, i64 %gpu_gy, i64 %gpu_gz, ptr %gpu_bufs, i64 %gpu_nbufs) nounwind {\n")
        output.append("entry:\n")
        let dr = getNextReg()
        output.append("  " + dr + " = call i64 @seen_gpu_dispatch(i64 0, i64 %gpu_gx, i64 %gpu_gy, i64 %gpu_gz, ptr %gpu_bufs, i64 %gpu_nbufs)\n")
        output.append("  ret void\n")
        output.append("}\n\n")
    }

    // Add a string constant to the string constant table (deduplicating).
    // Returns the index, used to reference the global @.str.PREFIX.INDEX.
    fun addStringConstant(str: String) r: Int {
        // Check if already exists
        var idx = 0
        while idx < stringConstants.length() {
            if stringConstants[idx] == str {
                return idx
            }
            idx = idx + 1
        }
        // Add new string constant
        stringConstants.push(str)
        return stringConstants.length() - 1
    }

    // Get the index of an existing string constant
    fun getStringConstantIndex(str: String) r: Int {
        var idx = 0
        while idx < stringConstants.length() {
            if stringConstants[idx] == str {
                return idx
            }
            idx = idx + 1
        }
        // Not found - add it
        return addStringConstant(str)
    }

    // Generate IR for a top-level (free) function. Handles decorators:
    //   @cfg — conditional compilation (skip if predicate doesn't match)
    //   @intrinsic — emit thin wrapper calling an LLVM intrinsic
    //   @inline/@noinline — LLVM inlining hints (alwaysinline/noinline)
    //   @compute — GPU shader (skip IR, handled by GLSL codegen)
    //   @async — LLVM coroutine-based async function
    //   @profile — instrumentation profiling (call enter/exit hooks)
    //   @vectorize/@no_vectorize/@unroll/@prefetch — loop optimization hints
    //
    // Extern functions (body has no statements, name starts with "__") are
    // skipped — they must have explicit `declare` in ir_declarations.seen.
    //
    // Function bodies are wrapped in: entry block -> alloca hoisting ->
    // parameter stores -> body generation -> implicit void return.
    // ML-guided inlining decisions are logged when g_mlLogEnabled is set.
    fun generateFunction(fn: FunctionNode) r: Void {
        // @cfg conditional compilation: skip function if predicate doesn't match
        if hasDecorator(fn, "cfg") {
            var cfgMatch = false
            var cfgIdx = 0
            while cfgIdx < fn.decorators.length() {
                if fn.decorators[cfgIdx].name == "cfg" {
                    if fn.decorators[cfgIdx].arguments.length() > 0 {
                        let cfgPred = fn.decorators[cfgIdx].arguments[0]
                        if cfgPred == "linux" or cfgPred == "target_os_linux" {
                            cfgMatch = true
                        }
                        if cfgPred == "unix" {
                            cfgMatch = true
                        }
                        if cfgPred == "x86_64" or cfgPred == "target_arch_x86_64" {
                            cfgMatch = true
                        }
                        if cfgPred == "debug" {
                            cfgMatch = false
                        }
                        if cfgPred == "release" {
                            cfgMatch = true
                        }
                        // : Feature flag predicates — @cfg(feature: "vulkan")
                        if cfgPred.startsWith("feature:") {
                            let featureName = cfgPred.substring(8, cfgPred.length())
                            let featureNameTrimmed = trimSpaces(featureName)
                            // Strip quotes if present
                            var featureClean = featureNameTrimmed
                            if featureClean.startsWith("\"") {
                                featureClean = featureClean.substring(1, featureClean.length())
                            }
                            if featureClean.endsWith("\"") {
                                featureClean = featureClean.substring(0, featureClean.length() - 1)
                            }
                            if g_enabledFeatures.contains(featureClean + "|") {
                                cfgMatch = true
                            }
                        }
                    }
                }
                cfgIdx = cfgIdx + 1
            }
            if not cfgMatch {
                output.append("; SKIPPED: " + fn.name + " (@cfg predicate not met)\n")
                return
            }
        }

        // Where clause validation: check trait constraints against impl registry
        if hasDecorator(fn, "where_constraint") and g_traitImplCount > 0 {
            var wcIdx = 0
            while wcIdx < fn.decorators.length() {
                if fn.decorators[wcIdx].name == "where_constraint" {
                    if fn.decorators[wcIdx].arguments.length() > 0 {
                        let wcText = fn.decorators[wcIdx].arguments[0]
                        output.append("; where clause: " + wcText + "\n")
                        // Parse "T:Trait" patterns and validate against g_traitImplRegistry
                        // Simple v1: emit comment with constraint text for documentation
                        // Full validation happens at call site when T is resolved
                    }
                }
                wcIdx = wcIdx + 1
            }
        }

        // : @region_bound annotation on function — emit as comment (zero runtime cost)
        if hasDecorator(fn, "region_bound") {
            output.append("; @region_bound function: " + fn.name + "\n")
        }

        // @intrinsic("llvm.xxx") decorator: emit thin wrapper calling LLVM intrinsic
        if hasDecorator(fn, "intrinsic") {
            var intrLlvmName = ""
            var intrDecIdx = 0
            while intrDecIdx < fn.decorators.length() {
                if fn.decorators[intrDecIdx].name == "intrinsic" {
                    if fn.decorators[intrDecIdx].arguments.length() > 0 {
                        intrLlvmName = fn.decorators[intrDecIdx].arguments[0]
                    }
                }
                intrDecIdx = intrDecIdx + 1
            }
            if intrLlvmName != "" {
                // Build parameter types
                var intrParamTypes = ""
                var intrParamArgs = ""
                var intrPIdx = 0
                while intrPIdx < fn.params.length() {
                    let intrParam = fn.params[intrPIdx]
                    let intrPType = intrParam.paramType
                    let intrPTName = intrPType.typeName
                    let intrPT = mapType(intrPTName)
                    if intrPIdx > 0 {
                        intrParamTypes = intrParamTypes + ", "
                        intrParamArgs = intrParamArgs + ", "
                    }
                    intrParamTypes = intrParamTypes + intrPT
                    intrParamArgs = intrParamArgs + intrPT + " %" + intrPIdx.toString()
                    intrPIdx = intrPIdx + 1
                }
                let intrRetTN = fn.returnType
                let intrRetTName = intrRetTN.typeName
                let intrRetType = mapType(intrRetTName)
                // Emit declare for the LLVM intrinsic
                output.append("declare " + intrRetType + " @" + intrLlvmName + "(" + intrParamTypes + ") nounwind readnone\n")
                // Emit thin wrapper function
                output.append("define " + intrRetType + " @" + quoteIdentIfNeeded(fn.name) + "(" + intrParamArgs + ") nounwind {\n")
                output.append("entry:\n")
                let intrCallReg = getNextReg()
                output.append("  " + intrCallReg + " = call " + intrRetType + " @" + intrLlvmName + "(" + intrParamArgs + ")\n")
                output.append("  ret " + intrRetType + " " + intrCallReg + "\n")
                output.append("}\n\n")
                // Register for lookup
                if g_intrinsicCount > 0 {
                    g_intrinsicFuncNames = g_intrinsicFuncNames + "|"
                    g_intrinsicLlvmNames = g_intrinsicLlvmNames + "|"
                }
                g_intrinsicFuncNames = g_intrinsicFuncNames + fn.name
                g_intrinsicLlvmNames = g_intrinsicLlvmNames + intrLlvmName
                g_intrinsicCount = g_intrinsicCount + 1
                return
            }
        }

        // @impl_trait — register trait implementation for vtable dispatch
        if hasDecorator(fn, "impl_trait") {
            var itDecIdx = 0
            while itDecIdx < fn.decorators.length() {
                if fn.decorators[itDecIdx].name == "impl_trait" {
                    if fn.decorators[itDecIdx].arguments.length() > 0 {
                        let itInfo = fn.decorators[itDecIdx].arguments[0]
                        // itInfo is "TraitName:ClassName"
                        g_traitImplRegistry = g_traitImplRegistry + itInfo + ":" + fn.name + "|"
                        g_traitImplCount = g_traitImplCount + 1
                    }
                }
                itDecIdx = itDecIdx + 1
            }
        }

        // : @compute/@vertex/@fragment — register GPU shader function and generate CPU dispatch wrapper
        if hasDecorator(fn, "compute") or hasDecorator(fn, "vertex") or hasDecorator(fn, "fragment") {
            var gpuStage = 0
            if hasDecorator(fn, "vertex") {
                gpuStage = 1
            }
            if hasDecorator(fn, "fragment") {
                gpuStage = 2
            }
            // Extract workgroup size for compute shaders
            // NOTE: simplified to avoid stage1_frozen "store %SeenString 0" bug with string let in while
            var gpuWgX = 64
            var gpuWgY = 1
            var gpuWgZ = 1
            // Count bindings from parameters
            // NOTE: avoid "let str = ..." inside while loop — triggers stage1_frozen "store %SeenString 0" bug
            var gpuBindCount = fn.params.length()
            // Register in GPU shader registry
            if g_gpuShaderCount > 0 {
                g_gpuShaderNames = g_gpuShaderNames + "|"
                g_gpuShaderStages = g_gpuShaderStages + "|"
                g_gpuShaderWorkgroups = g_gpuShaderWorkgroups + "|"
                g_gpuShaderBindings = g_gpuShaderBindings + "|"
            }
            g_gpuShaderNames = g_gpuShaderNames + fn.name
            g_gpuShaderStages = g_gpuShaderStages + gpuStage.toString()
            g_gpuShaderWorkgroups = g_gpuShaderWorkgroups + gpuWgX.toString() + "," + gpuWgY.toString() + "," + gpuWgZ.toString()
            g_gpuShaderBindings = g_gpuShaderBindings + gpuBindCount.toString()
            g_gpuShaderCount = g_gpuShaderCount + 1
            // Generate CPU dispatch wrapper for the shader function
            output.append("; GPU shader function: " + fn.name + " (stage=" + gpuStage.toString() + ", bindings=" + gpuBindCount.toString() + ")\n")
            generateGpuDispatchWrapper(fn, gpuStage, gpuBindCount, gpuWgX, gpuWgY, gpuWgZ)
            return
        }

        // Skip 'new' - always a class method
        if fn.name == "new" {
            output.append("; SKIPPED: new (class constructor)\n")
            return
        }

        // Extern functions (C runtime primitives) - empty bodies with __ prefix
        // If isExtern is set, fall through to the @extern handler for proper declare generation
        // Otherwise skip — they'll be declared by emitAllRuntimeDeclarations
        if fn.name.startsWith("__") and fn.body.statements.length() == 0 and not fn.isExtern {
            output.append("; SKIPPED: " + fn.name + " (extern C function - declared by runtime)\n")
            return
        }

        // Handle @extern functions — declaration + optional wrapper delegated to ir_declarations.seen
        if fn.isExtern {
            // Skip __-prefixed extern functions — already declared by ir_declarations.seen with nounwind
            if fn.name.startsWith("__") {
                output.append("; SKIPPED: " + fn.name + " (extern runtime function - declared by ir_declarations)\n")
                registerFunction(fn.name, normalizeDeclaredTypeNode(fn.returnType))
                return
            }
            // Compute extern symbol name (map llvm_coro_* → llvm.coro.*)
            var externSymbol = fn.name
            if externSymbol.startsWith("llvm_coro_") {
                let suffix = externSymbol.substring(10, externSymbol.length())
                externSymbol = "llvm.coro." + suffix
            }
            // Pre-compute mapped types for all params
            var mappedPTypes = Array<String>()
            var mpIdx = 0
            while mpIdx < fn.params.length() {
                let param = fn.params[mpIdx]
                let ptn = param.paramType
                let ptName = normalizeDeclaredTypeNode(ptn)
                mappedPTypes.push(mapTypeForParameter(ptName))
                mpIdx = mpIdx + 1
            }
            let externRetType = mapType(normalizeDeclaredTypeNode(fn.returnType))
            var isVariadic = 0
            if hasDecorator(fn, "variadic") { isVariadic = 1 }
            emitExternDeclImpl(output, fn.name, externSymbol, mappedPTypes, fn.params.length(), externRetType, isVariadic)
            registerFunction(fn.name, normalizeDeclaredTypeNode(fn.returnType))
            return
        }

        // Detect impl methods: if first param is 'this' with a class type
        // and name doesn't already include the class prefix, add it.
        // This handles `impl ClassName { fun method(this: ClassName) ... }` blocks
        // where the parser pushes items with the raw method name.
        // Break chained field access into intermediate let bindings (stage1_frozen GEP bug).
        var implFuncName = fn.name
        var implFnParams = fn.params
        if implFnParams.length() > 0 {
            let implFirstP = implFnParams[0]
            let implFirstPName = implFirstP.name
            if implFirstPName == "this" {
                let implFirstPType = implFirstP.paramType
                let implFirstPTN = implFirstPType.typeName
                if isClassType(implFirstPTN) {
                    var implExpectedPrefix = implFirstPTN + "_"
                    if not implFuncName.startsWith(implExpectedPrefix) {
                        implFuncName = implExpectedPrefix + implFuncName
                    }
                    // Auto-detect trait impl: check if method name matches a trait method
                    if g_dynTraitNames != "" {
                        var traitScan = 0
                        while traitScan < g_dynTraitNames.length() {
                            var traitPipePos = g_dynTraitNames.indexOf("|", traitScan)
                            if traitPipePos < 0 { traitPipePos = g_dynTraitNames.length() }
                            let traitCandidate = g_dynTraitNames.substring(traitScan, traitPipePos)
                            if traitCandidate != "" {
                                let traitMethodCheck = getMethodReturnType(traitCandidate, fn.name)
                                if traitMethodCheck != "" {
                                    g_traitImplRegistry = g_traitImplRegistry + traitCandidate + ":" + implFirstPTN + ":" + implFuncName + "|"
                                    g_traitImplCount = g_traitImplCount + 1
                                }
                            }
                            traitScan = traitPipePos + 1
                        }
                    }
                }
            }
        }

        // Check if this function was already emitted in this module (duplicate detection)
        var alreadyGenerated = false
        var gi = 0
        while gi < generatedFunctions.length() {
            if generatedFunctions[gi] == implFuncName {
                alreadyGenerated = true
                gi = generatedFunctions.length()  // break
            }
            gi = gi + 1
        }
        if alreadyGenerated {
            return
        }
        // Skip user stubs that redefine runtime builtins (e.g. fun println(...) {})
        // The runtime already provides these — user stubs shadow them with no-ops
        if fn.body.statements.length() == 0 and implFuncName != "main" {
            if implFuncName == "println" or implFuncName == "print" or implFuncName == "eprintln" {
                output.append("; skipped user stub for runtime builtin: " + implFuncName + "\n")
                return
            }
        }
        generatedFunctions.push(implFuncName)

        // Register this function's return type for later call site inference
        // (may already be registered from registerDeclarations, but that's OK)
        let resolvedFunctionReturnType = resolveFunctionReturnType(fn)
        registerFunction(implFuncName, resolvedFunctionReturnType)

        // Reset per-function state (nextBlock NOT reset - accumulates for per-loop metadata)
        g_regBox[0] = 1
        varNames = Array<String>()
        varRegs = Array<String>()
        varTypes = Array<String>()
        preAllocatedVars = Array<String>()
        preAllocatedTypes = Array<String>()
        preAllocatedRegs = Array<String>()
        activeVarCount = 0
        declOrdinalNames = Array<String>()
        declOrdinalCounts = Array<Int>()
        currentFunctionReturnType = resolvedFunctionReturnType
        currentClassName = ""
        g_currentClassParentName = ""
        blockTerminated = false
        resetFunctionLoweringOptionsState()
        // : Reset move tracking per-function
        g_movedVarNames = ""
        g_movedVarCount = 0

        // Pre-register parameter types for use during variable collection
        // (needed so inferExpressionType can find parameter types)
        var preParamIdx = 0
        while preParamIdx < fn.params.length() {
            let param = fn.params[preParamIdx]
            let rawPreTypeName = param.paramType.typeName
            var preTypeName = normalizeDeclaredTypeNode(param.paramType)
            // Strip ownership/comptime qualifiers for type inference
            if preTypeName.startsWith("move:") {
                preTypeName = preTypeName.substring(5, preTypeName.length())
            }
            if preTypeName.startsWith("borrow:") {
                preTypeName = preTypeName.substring(7, preTypeName.length())
            }
            // Strip comptime qualifier and register param
            if preTypeName.startsWith("comptime:") {
                preTypeName = preTypeName.substring(9, preTypeName.length())
                // Register this function as having comptime params
                if g_comptimeParamCount == 0 or not g_comptimeParamFuncNames.contains(fn.name + "|") {
                    g_comptimeParamFuncNames = g_comptimeParamFuncNames + fn.name + ":" + preParamIdx.toString() + ":" + param.name + "|"
                    g_comptimeParamCount = g_comptimeParamCount + 1
                }
            }
            // Extract and register default parameter values
            var defaultTypeName = rawPreTypeName
            if defaultTypeName.startsWith("move:") {
                defaultTypeName = defaultTypeName.substring(5, defaultTypeName.length())
            }
            if defaultTypeName.startsWith("borrow:") {
                defaultTypeName = defaultTypeName.substring(7, defaultTypeName.length())
            }
            if defaultTypeName.startsWith("comptime:") {
                defaultTypeName = defaultTypeName.substring(9, defaultTypeName.length())
            }
            if defaultTypeName.contains("~default~") {
                let defSepPos = defaultTypeName.indexOf("~default~", 0)
                let defValue = defaultTypeName.substring(defSepPos + 9, defaultTypeName.length())
                let defTypeName = normalizeSeenTypeName(defaultTypeName.substring(0, defSepPos))
                g_funcDefaultsArr = g_funcDefaultsArr + implFuncName + ":" + preParamIdx.toString() + ":" + defValue + ":" + defTypeName + "|"
            }
            // Register dyn Trait parameters for fat pointer boxing at call sites
            if preTypeName.startsWith("dyn ") {
                let dynTraitParam = preTypeName.substring(4, preTypeName.length())
                g_dynParamFuncs = g_dynParamFuncs + implFuncName + ":" + preParamIdx.toString() + ":" + dynTraitParam + "|"
            }
            storeVar(param.name, "", normalizeSeenTypeName(preTypeName))
            preParamIdx = preParamIdx + 1
        }

        // Register expected param count for default param injection
        if fn.params.length() > 0 {
            g_funcParamCountArr = g_funcParamCountArr + implFuncName + ":" + fn.params.length().toString() + "|"
        }

        // Clear CSE cache at function boundaries
        cseClear()

        // Collect all variable declarations for hoisting allocas to entry block
        println("[irgen function] collect vars start: " + implFuncName)
        collectVariableDeclarations(fn.body)
        println("[irgen function] collect vars done: " + implFuncName)

        // Clear pre-registered parameters (will be re-added with proper registers)
        varNames = Array<String>()
        varRegs = Array<String>()
        varTypes = Array<String>()
        activeVarCount = 0

        let fnTypeName = currentFunctionReturnType
        println("[irgen function] return-type map start: " + implFuncName)
        let returnType = mapType(fnTypeName)
        let fnName = implFuncName
        println("[irgen function] return-type map done: " + fnName)

        // Special handling for main function - needs to accept argc/argv from OS
        if llvmIrGenIsMainFunctionName(fnName) {
            g_isMainFunc = 1
            // Force i32 return for C ABI compatibility (lli requires i32 @main)
            if returnType == "void" {
                returnType = "i32"
            }
            // Only use noundef for primitive non-void return types
            var mainRetPrefix = "define "
            if returnType == "i64" or returnType == "double" or returnType == "i1" {
                mainRetPrefix = "define noundef "
            }
            output.append(mainRetPrefix + returnType + " @main(i32 %argc, ptr %argv) #0 {\n")
            output.append("entry:\n")
            output.append("  call void @seen_runtime_init(i32 %argc, ptr %argv)\n")
            // Emit allocas for all local variables at entry (avoids domination errors)
            emitPreAllocatedAllocas()
            println("[irgen function] block start: " + fnName)
            generateBlock(fn.body)
            println("[irgen function] block done: " + fnName)
            // Add default return if no terminator generated
            if not blockTerminated {
                var emittedMainRet = false
                if returnType == "void" {
                    output.append("  ret void\n")
                    emittedMainRet = true
                }
                if not emittedMainRet and returnType == "i64" {
                    output.append("  ret i64 0\n")
                    emittedMainRet = true
                }
                if not emittedMainRet and returnType == "ptr" {
                    output.append("  ret ptr null\n")
                    emittedMainRet = true
                }
                if not emittedMainRet and returnType == "i32" {
                    output.append("  ret i32 0\n")
                    emittedMainRet = true
                }
                if not emittedMainRet {
                    // Default for other types (e.g., structs)
                    output.append("  ret " + returnType + " zeroinitializer\n")
                }
            }
            output.append("}\n\n")
            g_isMainFunc = 0
            return
        }

        // Build function attributes
        println("[irgen function] attrs start: " + fnName)
        var funcAttrs = ""
        if fn.isInline {
            funcAttrs = " alwaysinline"
        }
        if hasDecorator(fn, "noinline") {
            funcAttrs = " noinline"
        }
        if hasDecorator(fn, "cold") {
            funcAttrs = funcAttrs + " cold"
        }
        if hasDecorator(fn, "always_inline") {
            funcAttrs = " alwaysinline"
        }
        if hasDecorator(fn, "hot") {
            funcAttrs = funcAttrs + " hot"
        }
        if hasDecorator(fn, "pure") {
            funcAttrs = funcAttrs + " readonly nounwind"
        }
        if hasDecorator(fn, "likely") {
            funcAttrs = funcAttrs + " hot"
        }
        if hasDecorator(fn, "unlikely") {
            funcAttrs = funcAttrs + " cold"
        }
        // @init: register as module initializer for @llvm.global_ctors
        if hasDecorator(fn, "init") {
            g_initFuncNames = g_initFuncNames + fn.name + "|"
            g_initFuncCount = g_initFuncCount + 1
        }
        // : @trusted — suppress bounds/overflow checks inside this function
        if hasDecorator(fn, "trusted") {
            g_trustedFuncNames = g_trustedFuncNames + fn.name + "|"
            output.append("; @trusted function: " + fn.name + "\n")
        }
        // P2 : Sanitizer function attributes
        if g_sanitizerMode != "" {
            if g_sanitizerMode == "address" {
                funcAttrs = funcAttrs + " sanitize_address"
            }
            if g_sanitizerMode == "thread" {
                funcAttrs = funcAttrs + " sanitize_thread"
            }
            if g_sanitizerMode == "memory" {
                funcAttrs = funcAttrs + " sanitize_memory"
            }
        }
        // P2 : Generic specialization — @specialize(T=Int) etc.
        if hasDecorator(fn, "specialize") {
            var specIdx = 0
            while specIdx < fn.decorators.length() {
                if fn.decorators[specIdx].name == "specialize" {
                    if fn.decorators[specIdx].arguments.length() > 0 {
                        var specArg = fn.decorators[specIdx].arguments[0]
                        g_specializationNames = g_specializationNames + fn.name + ":" + specArg + "|"
                        g_specializationCount = g_specializationCount + 1
                        output.append("; @specialize: " + fn.name + " with " + specArg + "\n")
                    }
                }
                specIdx = specIdx + 1
            }
        }
        if fn.isAsync {
            funcAttrs = funcAttrs + " presplitcoroutine"
        }
        println("[irgen function] attrs done: " + fnName)

        // ML-guided inline decision
        println("[irgen function] inline-analysis start: " + fnName)
        if not fn.isInline and not hasDecorator(fn, "noinline") {
            let bodySize = fn.body.statements.length()
            // Check for replay first
            let replayInline = mlReplayLookup("inline", fnName)
            if replayInline == "yes" {
                funcAttrs = funcAttrs + " alwaysinline"
                mlLogDecision("inline", "yes", fnName + ":replay")
            }
            if replayInline == "" {
                // Use mlShouldInline with call count from string-constants pre-pass
                let fnCallCount = callCountLookup(fnName)
                // Compute extra features for weighted model
                var hasLoopsFlag = 0
                var loopScanIdx = 0
                while loopScanIdx < fn.body.statements.length() {
                    let loopScanStmt = fn.body.statements[loopScanIdx]
                    if loopScanStmt.kind == "While" or loopScanStmt.kind == "ForIn" {
                        hasLoopsFlag = 1
                    }
                    loopScanIdx = loopScanIdx + 1
                }
                let nestDepth = fn.params.length()
                // Log features for ML training data
                mlLogFeatures("inline", fnName, bodySize, fnCallCount, hasLoopsFlag, nestDepth, 0)
                let inlineDecision = mlShouldInlineWeighted(bodySize, fnCallCount, hasLoopsFlag, nestDepth)
                if inlineDecision == "always" {
                    funcAttrs = funcAttrs + " alwaysinline"
                    mlLogDecision("inline", "yes", fnName + ":sz=" + bodySize.toString())
                }
                if inlineDecision == "hint" {
                    funcAttrs = funcAttrs + " inlinehint"
                    mlLogDecision("inline", "hint", fnName + ":sz=" + bodySize.toString())
                }
                if inlineDecision == "noinline" {
                    funcAttrs = funcAttrs + " noinline"
                    mlLogDecision("inline", "no", fnName + ":sz=" + bodySize.toString())
                }
            }
        }
        println("[irgen function] inline-analysis done: " + fnName)

        // norecurse / noinline for recursive functions
        println("[irgen function] recursion flags start: " + fnName)
        let isSelfRecursive = selfCallCheck(fnName, g_selfCallFuncs, g_selfCallNames, g_selfCallCount)
        if isSelfRecursive {
            // Prevent catastrophic code explosion from inlining recursive calls
            funcAttrs = funcAttrs.replace(" alwaysinline", "")
            funcAttrs = funcAttrs.replace(" inlinehint", "")
            funcAttrs = funcAttrs + " noinline"
        }
        if not isSelfRecursive {
            funcAttrs = funcAttrs + " norecurse"
        }
        println("[irgen function] recursion flags done: " + fnName)

        // ML register pressure estimation (9.7): count unique variables
        println("[irgen function] reg-pressure start: " + fnName)
        var regPressureCount = fn.params.length()
        var rpIdx = 0
        while rpIdx < fn.body.statements.length() {
            let rpStmt = fn.body.statements[rpIdx]
            if rpStmt.kind == "Let" or rpStmt.kind == "Var" {
                regPressureCount = regPressureCount + 1
            }
            rpIdx = rpIdx + 1
        }
        if regPressureCount > 14 {
            output.append("; register pressure high: " + regPressureCount.toString() + " vars — capping unroll/vectorize\n")
            g_currentFunctionHighPressure = true
            getCurrentFunctionOptions().highPressure = true
            mlLogDecision("reg-pressure", "high", fnName + ":" + regPressureCount.toString())
        }
        println("[irgen function] reg-pressure done: " + fnName)

        // Function signature
        // Add noundef on primitive return types for stronger optimization
        var fnRetPrefix = "define "
        if returnType == "i64" or returnType == "double" or returnType == "i1" {
            fnRetPrefix = "define noundef "
        }
        // Async functions return ptr (coroutine handle) instead of declared type
        var actualLlvmReturnType = returnType
        if fn.isAsync {
            actualLlvmReturnType = "ptr"
            fnRetPrefix = "define "
        }
        if hasDecorator(fn, "init") and fn.name == "__seen_internal_module_init__" {
            fnRetPrefix = "define internal "
        }
        // @export("C"): add dso_local for C-compatible export
        if hasDecorator(fn, "export") {
            fnRetPrefix = fnRetPrefix + "dso_local "
        }
        println("[irgen function] signature start: " + fnName)
        output.append(fnRetPrefix + actualLlvmReturnType + " @" + quoteIdentIfNeeded(fnName) + "(")

        // Parameters
        var paramIdx = 0
        while paramIdx < fn.params.length() {
            if paramIdx > 0 {
                output.append(", ")
            }
            let param = fn.params[paramIdx]
            var sigTypeName = normalizeDeclaredTypeNode(param.paramType)
            // Strip ownership qualifiers for IR type
            if sigTypeName.startsWith("move:") {
                sigTypeName = sigTypeName.substring(5, sigTypeName.length())
            }
            if sigTypeName.startsWith("borrow:") {
                sigTypeName = sigTypeName.substring(7, sigTypeName.length())
            }
            // Strip default value suffix for IR type
            if sigTypeName.contains("~default~") {
                let sigDefPos = sigTypeName.indexOf("~default~", 0)
                sigTypeName = sigTypeName.substring(0, sigDefPos)
            }
            let paramType = mapTypeForParameter(sigTypeName)
            // @no_alias decorator: add noalias on pointer params
            var paramAttr = ""
            if paramType == "ptr" and hasDecorator(fn, "no_alias") {
                paramAttr = "noalias "
            }
            output.append(paramAttr + paramType + " %" + quoteIdentIfNeeded(param.name + ".arg"))
            paramIdx = paramIdx + 1
        }

        output.append(")" + funcAttrs + " #0 {\n")
        output.append("entry:\n")
    println("[irgen function] signature done: " + fnName)

        // Coroutine preamble for async functions
        if fn.isAsync {
            // Promise allocation (stores return value for coro.promise extraction)
            let promiseType = mapType(currentFunctionReturnType)
            if promiseType != "void" {
                let promiseReg = getNextReg()
                output.append("  " + promiseReg + " = alloca " + promiseType + ", align 8\n")
                g_asyncFunctionPromise = promiseReg
            } else {
                let promiseReg = getNextReg()
                output.append("  " + promiseReg + " = alloca i8, align 1\n")
                g_asyncFunctionPromise = promiseReg
            }

            let coroIdReg = getNextReg()
            let coroSizeReg = getNextReg()
            let coroAllocReg = getNextReg()
            let coroBeginReg = getNextReg()
            output.append("  " + coroIdReg + " = call token @llvm.coro.id(i32 0, ptr " + g_asyncFunctionPromise + ", ptr null, ptr null)\n")
            output.append("  " + coroSizeReg + " = call i32 @llvm.coro.size.i32()\n")
            output.append("  " + coroAllocReg + " = call noalias ptr @malloc(i32 " + coroSizeReg + ")\n")
            output.append("  " + coroBeginReg + " = call ptr @llvm.coro.begin(token " + coroIdReg + ", ptr " + coroAllocReg + ")\n")
            g_asyncFunctionCoroId = coroIdReg
            g_asyncFunctionCoroHdl = coroBeginReg

            // Pre-generate the final suspend label for return statements
            g_asyncFinalLabel = getNextBlockLabel()
            g_asyncCleanupLabel = getNextBlockLabel()   // pre-generate so yield sites can forward-ref it
        }

        // Allocate space for parameters and store them
        paramIdx = 0
        while paramIdx < fn.params.length() {
            let param = fn.params[paramIdx]
            var seenTypeName = normalizeDeclaredTypeNode(param.paramType)
            // Strip ownership qualifiers (move:/borrow:) for codegen
            var paramOwnership = ""
            if seenTypeName.startsWith("move:") {
                paramOwnership = "move"
                seenTypeName = seenTypeName.substring(5, seenTypeName.length())
            }
            if seenTypeName.startsWith("borrow:") {
                paramOwnership = "borrow"
                seenTypeName = seenTypeName.substring(7, seenTypeName.length())
            }
            // Strip default value suffix
            if seenTypeName.contains("~default~") {
                let allocDefPos = seenTypeName.indexOf("~default~", 0)
                seenTypeName = seenTypeName.substring(0, allocDefPos)
            }
            let semanticSeenTypeName = normalizeSeenTypeName(seenTypeName)
            // Data type params come in as ptr (ABI compat with Rust backend)
            // Use the incoming ptr directly as the variable location
            if isDataType(semanticSeenTypeName) {
                storeVar(param.name, "%" + quoteIdentIfNeeded(param.name + ".arg"), semanticSeenTypeName)
            } else {
                let paramType = mapStorageTypeForParameter(seenTypeName)
                let reg = getNextReg()
                output.append("  " + reg + " = alloca " + paramType + "\n")
                output.append("  store " + paramType + " %" + quoteIdentIfNeeded(param.name + ".arg") + ", ptr " + reg + "\n")
                storeVar(param.name, reg, semanticSeenTypeName)
            }
            // Borrow parameter: register generational handle for safety
            if paramOwnership == "borrow" {
                let currentRegion = getNextReg()
                output.append("  " + currentRegion + " = call ptr @__seen_region_current()\n")
                let handleReg = getNextReg()
                output.append("  " + handleReg + " = call i64 @__seen_region_alloc_handle(ptr " + currentRegion + ", ptr %" + quoteIdentIfNeeded(param.name + ".arg") + ")\n")
                output.append("  ; borrow handle for " + param.name + " = " + handleReg + "\n")
            }
            paramIdx = paramIdx + 1
        }
        println("[irgen function] params done: " + fnName)

        // Emit allocas for all local variables at entry (avoids domination errors)
        emitPreAllocatedAllocas()
        println("[irgen function] allocas done: " + fnName)

        // Clear CSE cache at function boundary (safe to re-enable within function scope)
        cseClear()

        // Dead argument detection (9.10e): warn about unused parameters
        println("[irgen function] dead-arg scan start: " + fnName)
        var daIdx = 0
        while daIdx < fn.params.length() {
            let daParam = fn.params[daIdx]
            var daFound = false
            // Scan function body statements for variable references matching param name
            var daScan = 0
            while daScan < fn.body.statements.length() {
                let daScanStmt = fn.body.statements[daScan]
                // Simple check: if the param name appears in an expression of any kind
                if daScanStmt.expression.kind == "Variable" and daScanStmt.expression.literalValue == daParam.name {
                    daFound = true
                }
                // Check return expressions
                if daScanStmt.kind == "Return" and daScanStmt.expression.kind == "Variable" {
                    if daScanStmt.expression.literalValue == daParam.name { daFound = true }
                }
                // Check assignment RHS
                if daScanStmt.kind == "Expression" and daScanStmt.expression.kind == "Assignment" {
                    if daScanStmt.expression.operands.length() > 0 {
                        if daScanStmt.expression.operands[0].kind == "Variable" and daScanStmt.expression.operands[0].literalValue == daParam.name {
                            daFound = true
                        }
                    }
                }
                // Check let/var initializer
                if daScanStmt.kind == "Let" or daScanStmt.kind == "Var" {
                    if daScanStmt.expression.kind == "Variable" and daScanStmt.expression.literalValue == daParam.name {
                        daFound = true
                    }
                }
                // Conservative: any body at all means probably used (deep scan is expensive)
                if fn.body.statements.length() > 5 { daFound = true }
                daScan = daScan + 1
            }
            if not daFound and fn.body.statements.length() > 0 {
                output.append("  ; WARNING: unused parameter: " + daParam.name + " in " + fnName + "\n")
                mlLogDecision("dead-arg", "unused", daParam.name + ":" + fnName)
            }
            daIdx = daIdx + 1
        }
        println("[irgen function] dead-arg scan done: " + fnName)

        // Check for @profile decorator and emit profile_enter
        g_currentFunctionIsProfiled = hasDecorator(fn, "profile")
        g_currentFunctionNameForProfile = fnName
        if g_currentFunctionIsProfiled {
            // Get string constant index for function name
            let strIdx = addStringConstant(fnName)
            output.append("  ; @profile instrumentation - enter\n")
            output.append("  call void @__seen_profile_enter(ptr @.str." + strIdx.toString() + ")\n")
        }

        configureFunctionLoweringOptions(fn)

        // Emit prefetch intrinsic calls for pointer parameters
        if currentFunctionPrefetchMode() > 0 {
            var prefetchRW = "0"
            if currentFunctionPrefetchMode() == 2 {
                prefetchRW = "1"
            }
            var prefetchModeStr = "read"
            if currentFunctionPrefetchMode() == 2 {
                prefetchModeStr = "write"
            }
            output.append("  ; @prefetch(" + prefetchModeStr + ") instrumentation\n")
            var pi = 0
            while pi < fn.params.length() {
                let param = fn.params[pi]
                let paramTypeName = param.paramType.typeName
                if paramTypeName == "Array<Int>" or paramTypeName == "Array<Float>" or contains(paramTypeName, "Array") {
                    let allocaName = "%" + quoteIdentIfNeeded(param.name)
                    let ptrReg = getNextReg()
                    output.append("  " + ptrReg + " = load ptr, ptr " + allocaName + "\n")
                    output.append("  call void @llvm.prefetch.p0(ptr " + ptrReg + ", i32 " + prefetchRW + ", i32 3, i32 1)\n")
                }
                pi = pi + 1
            }
        }

        if currentFunctionRegionSizeBytes() > 0 {
            output.append("  ; @preallocate region allocator - create\n")
            let regionReg = getNextReg()
            output.append("  " + regionReg + " = call ptr @__seen_region_create(i64 " + currentFunctionRegionSizeBytes().toString() + ", i32 1)\n")
            output.append("  %__region_ptr = alloca ptr\n")
            output.append("  store ptr " + regionReg + ", ptr %__region_ptr\n")
        }

        // Generate function body
        generateBlock(fn.body)

        // If no terminator was generated, add a default return
        if not blockTerminated {
            // Emit region destroy before default return if using @preallocate
            if currentFunctionRegionSizeBytes() > 0 {
                let regionDefReg = getNextReg()
                output.append("  " + regionDefReg + " = load ptr, ptr %__region_ptr\n")
                output.append("  call void @__seen_region_destroy(ptr " + regionDefReg + ") ; @preallocate cleanup\n")
            }
            // Emit profile_exit before default return if profiled
            if g_currentFunctionIsProfiled {
                let strIdx = getStringConstantIndex(g_currentFunctionNameForProfile)
                output.append("  ; @profile instrumentation - exit (default return)\n")
                output.append("  call void @__seen_profile_exit(ptr @.str." + strIdx.toString() + ")\n")
            }

            // For async functions, store default return value in promise and branch to final suspend
            if isCurrentFunctionAsyncLowering() {
                let promiseType = mapType(currentFunctionReturnType)
                if promiseType != "void" {
                    output.append("  store " + promiseType + " zeroinitializer, ptr " + g_asyncFunctionPromise + "\n")
                }
                output.append("  br label %" + g_asyncFinalLabel + "\n")
            }

            if not fn.isAsync {
                var emittedRet = false
                if returnType == "void" {
                    output.append("  ret void\n")
                    emittedRet = true
                }
                if not emittedRet and returnType == "i1" {
                    output.append("  ret i1 false\n")
                    emittedRet = true
                }
                if not emittedRet and returnType == "i64" {
                    output.append("  ret i64 0\n")
                    emittedRet = true
                }
                if not emittedRet and returnType == "ptr" {
                    output.append("  ret ptr null\n")
                    emittedRet = true
                }
                if not emittedRet and returnType == "%SeenString" {
                    output.append("  ret %SeenString zeroinitializer\n")
                    emittedRet = true
                }
                if not emittedRet and returnType == "%SeenArray" {
                    output.append("  ret %SeenArray zeroinitializer\n")
                    emittedRet = true
                }
                if not emittedRet {
                    // Default for other types
                    output.append("  ret " + returnType + " zeroinitializer\n")
                }
            }
        }

        // Emit coroutine final suspend and cleanup blocks for async functions
        if fn.isAsync {
            // Final suspend block
            output.append("\n" + g_asyncFinalLabel + ":\n")
            let finalSuspendReg = getNextReg()
            output.append("  " + finalSuspendReg + " = call i8 @llvm.coro.suspend(token none, i1 true)\n")

            let coroCleanupLabel = g_asyncCleanupLabel     // use the pre-generated label (yield sites forward-ref it)
            let coroSuspendLabel = getNextBlockLabel()

            output.append("  switch i8 " + finalSuspendReg + ", label %" + coroSuspendLabel + " [\n")
            output.append("    i8 0, label %" + coroSuspendLabel + "\n")
            output.append("    i8 1, label %" + coroCleanupLabel + "\n")
            output.append("  ]\n")

            // Cleanup: free coroutine frame
            output.append("\n" + coroCleanupLabel + ":\n")
            let coroMemReg = getNextReg()
            output.append("  " + coroMemReg + " = call ptr @llvm.coro.free(token " + g_asyncFunctionCoroId + ", ptr " + g_asyncFunctionCoroHdl + ")\n")
            output.append("  call void @free(ptr " + coroMemReg + ")\n")
            output.append("  br label %" + coroSuspendLabel + "\n")

            // Suspend: end coroutine, return handle
            output.append("\n" + coroSuspendLabel + ":\n")
            let coroEndReg = getNextReg()
            output.append("  " + coroEndReg + " = call i1 @llvm.coro.end(ptr " + g_asyncFunctionCoroHdl + ", i1 false, token none)\n")
            output.append("  ret ptr " + g_asyncFunctionCoroHdl + "\n")
        }

        // Reset profiling state (module-level vars - writes are no-ops but kept for clarity)
        g_currentFunctionIsProfiled = false
        g_currentFunctionNameForProfile = ""
        g_currentFunctionHighPressure = false
        // Reset async coroutine state
        g_asyncFunctionCoroId = ""
        g_asyncFunctionCoroHdl = ""
        g_asyncFunctionPromise = ""
        g_asyncFinalLabel = ""
        g_asyncCleanupLabel = ""
        clearTransientFunctionLoweringState()

        output.append("}\n\n")
    }

    // Generate IR for a block of statements. Manages the defer stack depth
    // (saves on entry, emits deferred expressions in LIFO order on exit).
    // Performs dead store elimination: scans for "var x = literal; x = expr"
    // patterns where x is not read between the two stores, and skips the
    // first literal initialization.
    fun generateBlock(block: BlockNode) r: Void {
        // Save defer stack depth for this block scope
        let savedDeferCount = g_deferCount
        // Dead store elimination (9.10b): scan for var x = literal; x = expr2 with no read of x
        // Only skip literal initializers (Int, Float, Bool, String) to preserve side effects
        let savedDeadStoreSkip = g_deadStoreSkipVars
        let savedActiveVarCount = activeVarCount
        var dsIdx = 0
        while dsIdx < block.statements.length() - 1 {
            let dsStmt = block.statements[dsIdx]
            let dsNext = block.statements[dsIdx + 1]
            // Pattern: var x = <literal> followed by x = <new value>
            if (dsStmt.kind == "Let" or dsStmt.kind == "Var") and dsNext.kind == "Expression" {
                if dsNext.expression.kind == "Assignment" {
                    if dsNext.expression.variableName == dsStmt.variableName {
                        // Check if RHS reads the same variable (read-modify-write: x = x + y)
                        var dsIsReadModWrite = false
                        if dsNext.expression.operands.length() > 0 {
                            let dsRhs = dsNext.expression.operands[0]
                            // Direct: x = x
                            if dsRhs.kind == "Variable" or dsRhs.kind == "VarExpr" {
                                var dsRhsName = dsRhs.literalValue
                                if dsRhsName == "" { dsRhsName = dsRhs.variableName }
                                if dsRhsName == dsStmt.variableName { dsIsReadModWrite = true }
                            }
                            // Binary: x = x + something
                            if dsRhs.kind == "Binary" {
                                if dsRhs.operands.length() > 0 {
                                    let dsLhsOp = dsRhs.operands[0]
                                    var dsLhsName = dsLhsOp.literalValue
                                    if dsLhsName == "" { dsLhsName = dsLhsOp.variableName }
                                    if dsLhsName == dsStmt.variableName { dsIsReadModWrite = true }
                                }
                            }
                        }
                        if not dsIsReadModWrite {
                            g_deadStoresEliminated = g_deadStoresEliminated + 1
                            // Only skip the initializer if it's a pure literal (no side effects)
                            if dsStmt.initializer.kind == "Literal" {
                                output.append("  ; dead store eliminated: " + dsStmt.variableName + " literal init skipped\n")
                                if g_deadStoreSkipVars == "" {
                                    g_deadStoreSkipVars = dsStmt.variableName
                                } else {
                                    g_deadStoreSkipVars = g_deadStoreSkipVars + "|" + dsStmt.variableName
                                }
                                mlLogDecision("dead-store", "skip-init", dsStmt.variableName)
                            } else {
                                output.append("  ; dead store: " + dsStmt.variableName + " initialized then immediately overwritten\n")
                                mlLogDecision("dead-store", "detected", dsStmt.variableName)
                            }
                        }
                    }
                }
            }
            dsIdx = dsIdx + 1
        }

        var i = 0
        while i < block.statements.length() {
            // Skip statements after a terminator (ret, br unconditional)
            if blockTerminated {
                let remaining = block.statements.length() - i
                if remaining > 0 {
                    g_deadStatementsEliminated = g_deadStatementsEliminated + remaining
                    output.append("  ; dead code eliminated: " + remaining.toString() + " statements\n")
                }
                break
            }
            generateStatement(block.statements[i])
            i = i + 1
        }
        // Emit deferred statements in LIFO order at block end
        if g_deferCount > savedDeferCount and not blockTerminated {
            output.append("  ; defer cleanup (LIFO)\n")
            var dIdx = g_deferCount - 1
            while dIdx >= savedDeferCount {
                generateExpression(g_deferExprs[dIdx])
                dIdx = dIdx - 1
            }
        }
        // Restore defer stack to saved depth
        g_deferCount = savedDeferCount
        // Restore dead store skip list (scoped to this block)
        g_deadStoreSkipVars = savedDeadStoreSkip
        activeVarCount = savedActiveVarCount
    }

    // Top-level statement dispatch. Routes each statement kind to its
    // specialized generator: Let/Var, Return, If, IfLet, While, ForIn,
    // Match, Expression (which may be Assignment, MemberAssignment,
    // IndexAssignment, or a general expression), Defer, Errdefer,
    // TryCatch, UnsafeBlock, Region, ComptimeIf/Block, ParallelFor.
    // Uses flag-based dispatch (not early returns) for stage1 compatibility.
    fun generateStatement(stmt: StatementNode) r: Void {
        var handled = false
        if stmt.kind == "Let" or stmt.kind == "Var" {
            generateLetStatement(stmt)
            handled = true
        }
        if not handled and stmt.kind == "Return" {
            generateReturnStatement(stmt)
            handled = true
        }
        if not handled and stmt.kind == "Expression" {
            // Check if the expression is actually an assignment
            var exprHandled = false
            if stmt.expression.kind == "Assignment" {
                generateAssignmentExpr(stmt.expression)
                exprHandled = true
            }
            if not exprHandled and stmt.expression.kind == "MemberAssignment" {
                generateMemberAssignment(stmt.expression)
                exprHandled = true
            }
            if not exprHandled and stmt.expression.kind == "IndexAssignment" {
                generateIndexAssignment(stmt.expression)
                exprHandled = true
            }
            if not exprHandled {
                // : Warn about unused Result from function calls
                if g_warnUnusedResult == 1 and stmt.expression.kind == "Call" {
                    let unusedCallName = stmt.expression.callee
                    let unusedRetType = getFunctionReturnType(unusedCallName)
                    if unusedRetType.startsWith("Result<") or unusedRetType.startsWith("Result ") {
                        if g_tryCatchLabel == "" {
                            output.append("; WARNING: unused Result from call to " + unusedCallName + "\n")
                            println("[WARNING] unused error result from '" + unusedCallName + "'")
                        }
                    }
                }
                generateExpression(stmt.expression)
            }
            handled = true
        }
        if not handled and stmt.kind == "If" {
            generateIfStatement(stmt)
            handled = true
        }
        if not handled and stmt.kind == "IfLet" {
            generateIfLetStatement(stmt)
            handled = true
        }
        if not handled and stmt.kind == "While" {
            generateWhileStatement(stmt)
            handled = true
        }
        if not handled and stmt.kind == "Assignment" {
            generateAssignment(stmt)
            handled = true
        }
        if not handled and stmt.kind == "Continue" {
            // Jump to loop condition with vectorization hint
            // currentLoopCondLabel is encoded as "label|metaId"
            if currentLoopCondLabel == "" {
                output.append("  ; ERROR: continue used outside of loop\n")
            }
            if currentLoopCondLabel != "" {
                let pipeIdx = currentLoopCondLabel.indexOf("|")
                if pipeIdx >= 0 {
                    let actualLabel = currentLoopCondLabel.substring(0, pipeIdx)
                    let metaIdStr = currentLoopCondLabel.substring(pipeIdx + 1, currentLoopCondLabel.length())
                    output.append("  br label %" + actualLabel + ", !llvm.loop !" + metaIdStr + "\n")
                }
                if pipeIdx < 0 {
                    // Fallback: no metadata encoded (old format)
                    output.append("  br label %" + currentLoopCondLabel + ", !llvm.loop !202\n")
                }
                blockTerminated = true
            }
            handled = true
        }
        if not handled and stmt.kind == "Break" {
            // Jump to loop end
            if currentLoopEndLabel == "" {
                output.append("  ; ERROR: break used outside of loop\n")
            }
            if currentLoopEndLabel != "" {
                output.append("  br label %" + currentLoopEndLabel + "\n")
                blockTerminated = true
            }
            handled = true
        }
        if not handled and stmt.kind == "ForIn" {
            generateForInStatement(stmt)
            handled = true
        }
        if not handled and stmt.kind == "Region" {
            generateRegionStatement(stmt)
            handled = true
        }
        if not handled and stmt.kind == "Defer" {
            // Collect deferred expression for LIFO execution at block/function end
            if stmt.expression.kind != "" {
                g_deferExprs.push(stmt.expression)
                g_deferCount = g_deferCount + 1
            }
            handled = true
        }
        if not handled and stmt.kind == "Errdefer" {
            // Collect errdefer expression for LIFO execution on error returns only
            if stmt.expression.kind != "" {
                g_errdeferExprs.push(stmt.expression)
                g_errdeferCount = g_errdeferCount + 1
            }
            handled = true
        }
        if not handled and stmt.kind == "Block" {
            // Inline block
            if stmt.thenBranch.statements.length() > 0 {
                generateBlock(stmt.thenBranch)
            }
            handled = true
        }
        if not handled and stmt.kind == "Unsafe" {
            // Unsafe block — track nesting, generate contents
            output.append("  ; unsafe {\n")
            g_insideUnsafe = g_insideUnsafe + 1
            if stmt.thenBranch.statements.length() > 0 {
                generateBlock(stmt.thenBranch)
            }
            g_insideUnsafe = g_insideUnsafe - 1
            output.append("  ; } // end unsafe\n")
            handled = true
        }
        if not handled and stmt.kind == "TryCatch" {
            // try { ... } catch (e) { ... }
            let tryCatchLabel = "catch." + g_blockBox[0].toString()
            g_blockBox[0] = g_blockBox[0] + 1
            let tryEndLabel = "try.end." + g_blockBox[0].toString()
            g_blockBox[0] = g_blockBox[0] + 1
            // Save previous try/catch state
            let savedTryCatchLabel = g_tryCatchLabel
            let savedTryCatchEndLabel = g_tryCatchEndLabel
            g_tryCatchLabel = tryCatchLabel
            g_tryCatchEndLabel = tryEndLabel
            output.append("  ; try {\n")
            if stmt.thenBranch.statements.length() > 0 {
                generateBlock(stmt.thenBranch)
            }
            if not blockTerminated {
                output.append("  br label %" + tryEndLabel + "\n")
            }
            blockTerminated = false
            // Catch block
            output.append(tryCatchLabel + ":\n")
            output.append("  ; catch {\n")
            // If catch variable was declared, bind it (as i64 0 for now)
            let savedCatchVarCount = activeVarCount
            if stmt.variableName != "" {
                let catchVarReg = getNextReg()
                storeVar(stmt.variableName, catchVarReg, "Int")
                output.append("  " + catchVarReg + " = add i64 0, 0 ; catch binding\n")
            }
            if stmt.elseBranch.statements.length() > 0 {
                generateBlock(stmt.elseBranch)
            }
            activeVarCount = savedCatchVarCount
            if not blockTerminated {
                output.append("  br label %" + tryEndLabel + "\n")
            }
            blockTerminated = false
            output.append(tryEndLabel + ":\n")
            output.append("  ; } // end try/catch\n")
            // Restore previous try/catch state
            g_tryCatchLabel = savedTryCatchLabel
            g_tryCatchEndLabel = savedTryCatchEndLabel
            handled = true
        }
        // parallel_for statement
        if not handled and stmt.kind == "ParallelFor" {
            generateParallelForStatement(stmt)
            handled = true
        }
        // comptime block
        if not handled and stmt.kind == "ComptimeBlock" {
            generateComptimeBlock(stmt)
            handled = true
        }
        // comptime assert
        if not handled and stmt.kind == "ComptimeAssert" {
            generateComptimeAssert(stmt)
            handled = true
        }
        // comptime if
        if not handled and stmt.kind == "ComptimeIf" {
            generateComptimeIf(stmt)
            handled = true
        }
    }

    fun generateRegionStatement(stmt: StatementNode) r: Void {
        // region [strategy] [name] { body }
        // Strategy: 0=auto, 1=bump, 2=stack, 3=cxl_near, 4=cxl_far, 5=gpu
        var strategyInt = "0"
        let strategy = normalizeDeclaredTypeNode(stmt.variableType)
        if strategy == "bump" { strategyInt = "1" }
        if strategy == "stack" { strategyInt = "2" }
        if strategy == "cxl_near" { strategyInt = "3" }
        if strategy == "cxl_far" { strategyInt = "4" }
        if strategy == "gpu" { strategyInt = "5" }
        let regionName = stmt.variableName
        output.append("  ; region block")
        if strategy != "" { output.append(" strategy=" + strategy) }
        if regionName != "" { output.append(" name=" + regionName) }
        output.append("\n")
        // Create region (64KB default)
        let regionReg = getNextReg()
        output.append("  " + regionReg + " = call ptr @__seen_region_create(i64 65536, i32 " + strategyInt + ")\n")
        // Push region onto stack
        output.append("  call void @__seen_region_push(ptr " + regionReg + ")\n")
        // Store region ptr for cleanup
        let regionSlot = getNextReg()
        output.append("  " + regionSlot + " = alloca ptr\n")
        output.append("  store ptr " + regionReg + ", ptr " + regionSlot + "\n")
        // Generate body
        generateBlock(stmt.thenBranch)
        // Pop and destroy region
        let popReg = getNextReg()
        output.append("  " + popReg + " = call ptr @__seen_region_pop()\n")
        let loadReg = getNextReg()
        output.append("  " + loadReg + " = load ptr, ptr " + regionSlot + "\n")
        output.append("  call void @__seen_region_destroy(ptr " + loadReg + ")\n")
    }

    // : Map C type string to LLVM IR type
    fun mapCTypeToLlvm(cType: String) r: String {
        let ct = cType.trim()
        if ct == "void" { return "void" }
        if ct == "int" or ct == "int32_t" or ct == "signed int" { return "i32" }
        if ct == "long" or ct == "int64_t" or ct == "long long" { return "i64" }
        if ct == "short" or ct == "int16_t" { return "i16" }
        if ct == "unsigned int" or ct == "uint32_t" { return "i32" }
        if ct == "unsigned long" or ct == "uint64_t" or ct == "size_t" { return "i64" }
        if ct == "char" or ct == "signed char" or ct == "unsigned char" { return "i8" }
        if ct == "bool" or ct == "_Bool" { return "i1" }
        if ct == "float" { return "float" }
        if ct == "double" { return "double" }
        if ct.endsWith("*") or ct.contains("*") { return "ptr" }
        return "i64"
    }

    // : Generate variadic generic expansion (arities 1-8)
    fun generateVariadicGenericExpansion(funcNode: FunctionNode) r: Void {
        // Extract pack name from @variadic_generic decorator
        var packName = "Ts"
        var vgDecIdx = 0
        while vgDecIdx < funcNode.decorators.length() {
            if funcNode.decorators[vgDecIdx].name == "variadic_generic" {
                if funcNode.decorators[vgDecIdx].arguments.length() > 0 {
                    packName = funcNode.decorators[vgDecIdx].arguments[0]
                }
            }
            vgDecIdx = vgDecIdx + 1
        }
        g_variadicGenericNames = g_variadicGenericNames + funcNode.name + "|"
        g_variadicGenericCount = g_variadicGenericCount + 1
        output.append("; : variadic generic expansion for " + funcNode.name + "<..." + packName + ">\n")
        // Generate arity-specific overloads (1 through 8)
        var arity = 1
        while arity <= 8 {
            let mangledName = funcNode.name + "_" + arity.toString()
            // Emit a stub function that takes arity i64 params and returns i64
            var paramList = ""
            var pi = 0
            while pi < arity {
                if pi > 0 { paramList = paramList + ", " }
                paramList = paramList + "i64 %t" + pi.toString()
                pi = pi + 1
            }
            output.append("define i64 @" + quoteIdentIfNeeded(mangledName) + "(" + paramList + ") nounwind {\n")
            output.append("entry:\n")
            // Allocate and store params into a tuple struct
            let tupleType = "%SeenTuple" + arity.toString()
            let tupleReg = "%tuple"
            output.append("  " + tupleReg + " = alloca " + tupleType + "\n")
            var si = 0
            while si < arity {
                let gepReg = "%gep" + si.toString()
                output.append("  " + gepReg + " = getelementptr " + tupleType + ", ptr " + tupleReg + ", i32 0, i32 " + si.toString() + "\n")
                output.append("  store i64 %t" + si.toString() + ", ptr " + gepReg + "\n")
                si = si + 1
            }
            // Return pointer to tuple as i64
            let retReg = "%ret"
            output.append("  " + retReg + " = ptrtoint ptr " + tupleReg + " to i64\n")
            output.append("  ret i64 " + retReg + "\n")
            output.append("}\n\n")
            arity = arity + 1
        }
    }

    // parallel_for i in start..end { body } → extract closure, call seen_parallel_for
    fun generateParallelForStatement(stmt: StatementNode) r: Void {
        // The expression should be a range: start..end (parsed as Binary with operator "..")
        let rangeExpr = stmt.expression
        var startReg = ""
        var endReg = ""
        if rangeExpr.kind == "Binary" and rangeExpr.operator == ".." {
            startReg = generateExpression(rangeExpr.operands[0])
            endReg = generateExpression(rangeExpr.operands[1])
        } else {
            // Fallback: treat expression as end, start = 0
            startReg = "0"
            endReg = generateExpression(rangeExpr)
        }

        // Generate the loop body as an anonymous function
        let pforIdx = g_pforCount
        g_pforCount = g_pforCount + 1
        let bodyFuncName = "@__seen_pfor_body_" + pforIdx.toString()

        // Save current state
        let savedOutput = output
        let savedVarNames = varNames
        let savedVarRegs = varRegs
        let savedVarTypes = varTypes
        let savedPreAllocatedVars = preAllocatedVars
        let savedPreAllocatedTypes = preAllocatedTypes
        let savedPreAllocatedRegs = preAllocatedRegs
        let savedDeclOrdinalNames = declOrdinalNames
        let savedDeclOrdinalCounts = declOrdinalCounts
        let savedActiveVarCount = activeVarCount
        let savedNextReg = g_regBox[0]
        let savedBlockTerm = blockTerminated

        // Generate body function in a new buffer
        output = StringBuilder.new()
        varNames = Array<String>()
        varRegs = Array<String>()
        varTypes = Array<String>()
        preAllocatedVars = Array<String>()
        preAllocatedTypes = Array<String>()
        preAllocatedRegs = Array<String>()
        declOrdinalNames = Array<String>()
        declOrdinalCounts = Array<Int>()
        activeVarCount = 0
        g_regBox[0] = 1
        blockTerminated = false

        output.append("define i64 " + bodyFuncName + "(i64 %0) nounwind {\n")
        output.append("entry:\n")
        // Bind loop variable to %0
        storeVar(stmt.variableName, "%0", "Int")
        // Generate body block
        generateBlock(stmt.loopBody)
        if not blockTerminated {
            output.append("  ret i64 0\n")
        }
        output.append("}\n\n")

        // Store generated body function in closures list
        let bodyFuncIR = output.toString()
        g_closureDefs = g_closureDefs + bodyFuncIR

        // Restore state
        output = savedOutput
        varNames = savedVarNames
        varRegs = savedVarRegs
        varTypes = savedVarTypes
        preAllocatedVars = savedPreAllocatedVars
        preAllocatedTypes = savedPreAllocatedTypes
        preAllocatedRegs = savedPreAllocatedRegs
        declOrdinalNames = savedDeclOrdinalNames
        declOrdinalCounts = savedDeclOrdinalCounts
        activeVarCount = savedActiveVarCount
        g_regBox[0] = savedNextReg
        blockTerminated = savedBlockTerm

        // Emit call to seen_parallel_for(start, end, body_fn_ptr, nthreads=0 for auto)
        output.append("  ; parallel_for " + stmt.variableName + "\n")
        output.append("  call void @seen_parallel_for(i64 " + startReg + ", i64 " + endReg + ", ptr " + bodyFuncName + ", i64 0)\n")
    }

    // comptime { block } — evaluate let bindings at compile time, store in comptime registry
    fun generateComptimeBlock(stmt: StatementNode) r: Void {
        output.append("  ; comptime block\n")
        processComptimeStatements(stmt.thenBranch)
    }

    // Process comptime block statements, supporting Let/Var, Assignment, While
    fun processComptimeStatements(block: BlockNode) r: Void {
        var ctIdx = 0
        while ctIdx < block.statements.length() {
            let ctStmt = block.statements[ctIdx]
            if ctStmt.kind == "Let" or ctStmt.kind == "Var" {
                // Try integer evaluation first
                let ctVal = evaluateConstExpr(ctStmt.initializer)
                if ctVal != -9999999 {
                    registerComptimeVar(ctStmt.variableName, ctVal)
                    output.append("  ; comptime let " + ctStmt.variableName + " = " + ctVal.toString() + "\n")
                } else {
                    // Try string evaluation
                    let ctStrVal = evaluateConstExprStr(ctStmt.initializer)
                    if ctStrVal != "__EVAL_FAIL__" {
                        registerComptimeStrVar(ctStmt.variableName, ctStrVal)
                        output.append("  ; comptime let " + ctStmt.variableName + " = \"" + ctStrVal + "\"\n")
                    }
                }
            }
            // comptime Assignment — update existing comptime variable
            if ctStmt.kind == "Assignment" or ctStmt.kind == "Expression" {
                if ctStmt.expression.kind == "Assignment" {
                    let ctAssignName = ctStmt.expression.variableName
                    if ctAssignName == "" {
                        let ctAssignName2 = ctStmt.expression.literalValue
                        if ctAssignName2 != "" {
                            let ctNewVal = evaluateConstExpr(ctStmt.expression.operands[0])
                            if ctNewVal != -9999999 {
                                updateComptimeVar(ctAssignName2, ctNewVal)
                                output.append("  ; comptime " + ctAssignName2 + " = " + ctNewVal.toString() + "\n")
                            }
                        }
                    } else {
                        let ctNewVal = evaluateConstExpr(ctStmt.expression.operands[0])
                        if ctNewVal != -9999999 {
                            updateComptimeVar(ctAssignName, ctNewVal)
                            output.append("  ; comptime " + ctAssignName + " = " + ctNewVal.toString() + "\n")
                        }
                    }
                }
            }
            // comptime While — unroll loop at compile time
            if ctStmt.kind == "While" {
                var ctWhileIter = 0
                while ctWhileIter < 1000 {
                    let ctWhileCond = evaluateConstExpr(ctStmt.expression)
                    if ctWhileCond == 0 or ctWhileCond == -9999999 { break }
                    // Process body: comptime statements update vars, runtime statements get emitted
                    processComptimeStatements(ctStmt.thenBranch)
                    ctWhileIter = ctWhileIter + 1
                }
                output.append("  ; comptime while unrolled " + ctWhileIter.toString() + " iterations\n")
            }
            // Other statement kinds: emit as runtime code (code generation use case)
            if ctStmt.kind != "Let" and ctStmt.kind != "Var" and ctStmt.kind != "Assignment" and ctStmt.kind != "Expression" and ctStmt.kind != "While" {
                generateStatement(ctStmt)
            }
            ctIdx = ctIdx + 1
        }
    }

    // Register a new comptime integer variable
    fun registerComptimeVar(name: String, value: Int) r: Void {
        // Check if already exists — update instead
        let existingVal = lookupComptimeVar(name)
        if existingVal != -9999999 {
            updateComptimeVar(name, value)
            return
        }
        if g_comptimeCount > 0 {
            g_comptimeNames = g_comptimeNames + "|"
            g_comptimeValues = g_comptimeValues + "|"
        }
        g_comptimeNames = g_comptimeNames + name
        g_comptimeValues = g_comptimeValues + value.toString()
        g_comptimeCount = g_comptimeCount + 1
    }

    // Update an existing comptime integer variable
    fun updateComptimeVar(name: String, value: Int) r: Void {
        if g_comptimeCount == 0 { return }
        // Rebuild the values string with updated value
        var newValues = ""
        var searchPos = 0
        var valPos = 0
        var idx = 0
        while idx < g_comptimeCount {
            var curName = ""
            var nextPipe = g_comptimeNames.indexOf("|", searchPos)
            if nextPipe < 0 {
                curName = g_comptimeNames.substring(searchPos, g_comptimeNames.length())
            } else {
                curName = g_comptimeNames.substring(searchPos, nextPipe)
                searchPos = nextPipe + 1
            }
            var curVal = ""
            var nextValPipe = g_comptimeValues.indexOf("|", valPos)
            if nextValPipe < 0 {
                curVal = g_comptimeValues.substring(valPos, g_comptimeValues.length())
            } else {
                curVal = g_comptimeValues.substring(valPos, nextValPipe)
                valPos = nextValPipe + 1
            }
            if idx > 0 { newValues = newValues + "|" }
            if curName == name {
                newValues = newValues + value.toString()
            } else {
                newValues = newValues + curVal
            }
            idx = idx + 1
        }
        g_comptimeValues = newValues
    }

    // Register a comptime string variable
    fun registerComptimeStrVar(name: String, value: String) r: Void {
        if g_comptimeStrCount > 0 {
            g_comptimeStrNames = g_comptimeStrNames + "|"
            g_comptimeStrValues = g_comptimeStrValues + "|"
        }
        g_comptimeStrNames = g_comptimeStrNames + name
        g_comptimeStrValues = g_comptimeStrValues + value
        g_comptimeStrCount = g_comptimeStrCount + 1
    }

    // Look up a comptime string variable
    fun lookupComptimeStrVar(name: String) r: String {
        return lookupComptimeStrVarImpl(name, g_comptimeStrNames, g_comptimeStrValues, g_comptimeStrCount)
    }

    // Evaluate a constant expression as a string at compile time
    fun evaluateConstExprStr(expr: ParserExpressionNode) r: String {
        return evaluateConstExprStrImpl(expr, g_comptimeNames, g_comptimeValues, g_comptimeCount, g_comptimeStrNames, g_comptimeStrValues, g_comptimeStrCount, structNames, structFieldNames, structFieldTypes)
    }

    // comptime assert(cond, "msg") — compile-time assertion
    fun generateComptimeAssert(stmt: StatementNode) r: Void {
        let condVal = evaluateConstExpr(stmt.expression)
        if condVal == 0 {
            // Assertion failed
            var msg = "comptime assertion failed"
            if stmt.condition.kind == "Literal" and stmt.condition.literalType == "String" {
                msg = stmt.condition.literalValue
            }
            output.append("  ; COMPTIME ASSERT FAILED: " + msg + "\n")
            // Emit compile error via runtime abort
            let msgReg = getNextReg()
            output.append("  " + msgReg + " = call %SeenString @seen_cstr_to_str(ptr @.str.comptime_assert)\n")
            output.append("  call void @println(%SeenString " + msgReg + ")\n")
            output.append("  call void @exit(i64 1)\n")
        } else {
            output.append("  ; comptime assert passed\n")
        }
    }

    // comptime if (cond) { then } else { else } — dead code elimination
    fun generateComptimeIf(stmt: StatementNode) r: Void {
        let condVal = evaluateConstExpr(stmt.expression)
        if condVal != 0 {
            // Condition is true — generate then branch only
            output.append("  ; comptime if: true branch\n")
            generateBlock(stmt.thenBranch)
        } else {
            // Condition is false — generate else branch only (if present)
            if stmt.elseBranch.statements.length() > 0 {
                output.append("  ; comptime if: false branch (else)\n")
                generateBlock(stmt.elseBranch)
            } else {
                output.append("  ; comptime if: false, no else branch — eliminated\n")
            }
        }
    }

    // Evaluate a constant expression at compile time
    fun evaluateConstExpr(expr: ParserExpressionNode) r: Int {
        return evaluateConstExprImpl(expr, g_comptimeNames, g_comptimeValues, g_comptimeCount, g_comptimeStrNames, g_comptimeStrValues, g_comptimeStrCount, structNames, structFieldNames, structFieldTypes)
    }

    // Look up a comptime variable value
    fun lookupComptimeVar(name: String) r: Int {
        return lookupComptimeVarImpl(name, g_comptimeNames, g_comptimeValues, g_comptimeCount)
    }

    // Comptime sizeof for common types
    fun comptimeSizeof(typeName: String) r: Int {
        return comptimeSizeofImpl(typeName)
    }

    // Comptime type field count — look up struct by name, count comma-separated fields
    fun comptimeTypeFieldCount(typeName: String) r: Int {
        return comptimeTypeFieldCountImpl(typeName, structNames, structFieldNames)
    }

    // Comptime type field name — get Nth field name from struct
    fun comptimeTypeFieldName(typeName: String, fieldIdx: Int) r: String {
        return comptimeTypeFieldNameImpl(typeName, fieldIdx, structNames, structFieldNames)
    }

    // Comptime type field type — get Nth field type from struct
    fun comptimeTypeFieldType(typeName: String, fieldIdx: Int) r: String {
        return comptimeTypeFieldTypeImpl(typeName, fieldIdx, structNames, structFieldTypes)
    }

    // Simple integer parser for comptime
    fun parseSimpleInt(s: String) r: Int {
        return parseSimpleIntImpl(s)
    }

    // Generate IR for a let/var declaration. Resolves the variable type from
    // the explicit annotation, falling back to inferExpressionType on the
    // initializer, then preAllocatedTypes, then "Int" as final fallback.
    // If the variable was pre-allocated at function entry (by
    // collectVariableDeclarations), reuses the existing alloca register.
    // Supports dead store elimination: skips literal initializers that are
    // immediately overwritten (tracked in g_deadStoreSkipVars).
    fun generateLetStatement(stmt: StatementNode) r: Void {
        let declOrdinal = nextDeclarationOrdinal(stmt.variableName)
        let preIdx = findPreAllocatedOccurrence(stmt.variableName, declOrdinal)
        // Get variable type - prefer explicit type, fall back to inference
        var varType = normalizeDeclaredTypeNode(stmt.variableType)
        if varType == "" or varType == "Unknown" or varType == "Void" {
            // Infer type from initializer
            if stmt.initializer.kind != "None" {
                varType = inferDeclarationInitializerType(stmt.initializer)
            }
        }
        // Final fallback: "Void" or "" type → use pre-allocated type or "Int"
        if varType == "" or varType == "Unknown" or varType == "Void" {
            if preIdx >= 0 {
                varType = preAllocatedTypes[preIdx]
            }
        }
        if varType == "" or varType == "Unknown" or varType == "Void" {
            varType = "Int"
        }
        let llvmType = mapType(varType)
        var reg = ""
        if preIdx >= 0 and preIdx < preAllocatedRegs.length() {
            let existingLlvmType = mapType(preAllocatedTypes[preIdx])
            if existingLlvmType == llvmType {
                reg = preAllocatedRegs[preIdx]
            }
        }
        if reg == "" {
            // Fallback: allocate here (shouldn't happen with proper collection)
            reg = getNextReg()
            output.append("  " + reg + " = alloca " + llvmType + "\n")
        }
        storeVar(stmt.variableName, reg, varType)

        // Initialize if there's an initializer
        if stmt.initializer.kind != "None" {
            // Dead store elimination: skip literal initializer if immediately overwritten
            var skipDeadInit = false
            if g_deadStoreSkipVars != "" and stmt.initializer.kind == "Literal" {
                // Check if this variable is in the skip list (pipe-delimited)
                var dsScanIdx = 0
                while dsScanIdx < g_deadStoreSkipVars.length() {
                    let dsEntry = pipeGet(g_deadStoreSkipVars, dsScanIdx)
                    if dsEntry == "" { dsScanIdx = g_deadStoreSkipVars.length() }
                    if dsEntry != "" {
                        if dsEntry == stmt.variableName {
                            skipDeadInit = true
                            dsScanIdx = g_deadStoreSkipVars.length()
                        }
                    }
                    dsScanIdx = dsScanIdx + 1
                }
            }
            if skipDeadInit {
                output.append("  ; DSE: skipped dead literal init for " + stmt.variableName + "\n")
            }
            if not skipDeadInit {
                let savedPendingType = pendingArrayLiteralType
                if stmt.initializer.kind == "ArrayLiteral" and (varType.startsWith("Array") or varType.startsWith("List")) {
                    pendingArrayLiteralType = varType
                }
                let valueReg = generateExpression(stmt.initializer)
                pendingArrayLiteralType = savedPendingType
                output.append("  store " + llvmType + " " + valueReg + ", ptr " + reg + "\n")
            }
        }
    }

    // Generate IR for a return statement. Emits pending defer expressions
    // in LIFO order before the return. For async functions, stores the return
    // value into the coroutine promise and branches to the async cleanup label.
    // Handles type coercion (int-to-float, class-to-ptr, data-type-to-ptr).
    // Sets blockTerminated=true to prevent unreachable instructions after ret.
    fun generateReturnStatement(stmt: StatementNode) r: Void {
        // Emit pending defers before return (LIFO order)
        if g_deferCount > 0 {
            output.append("  ; defer cleanup before return (LIFO)\n")
            var dRetIdx = g_deferCount - 1
            while dRetIdx >= 0 {
                generateExpression(g_deferExprs[dRetIdx])
                dRetIdx = dRetIdx - 1
            }
        }
        // Emit errdefer cleanup only on error return path (Result convention: 0=Err)
        // Evaluates return expression into temp, checks if error (null/zero), branches
        if g_errdeferCount > 0 and stmt.returnValue.kind != "None" {
            // Store return value in temp alloca to avoid double-evaluation
            let edTempAlloca = getNextReg()
            output.append("  " + edTempAlloca + " = alloca i64\n")
            let edRetVal = generateExpression(stmt.returnValue)
            output.append("  store i64 " + edRetVal + ", ptr " + edTempAlloca + "\n")
            let edCheckReg = getNextReg()
            output.append("  " + edCheckReg + " = icmp eq i64 " + edRetVal + ", 0 ; errdefer: check if error\n")
            let edErrLabel = getNextBlockLabel()
            let edOkLabel = getNextBlockLabel()
            output.append("  br i1 " + edCheckReg + ", label %" + edErrLabel + ", label %" + edOkLabel + "\n")
            output.append(edErrLabel + ":\n")
            output.append("  ; errdefer cleanup (error path, LIFO)\n")
            var edRetIdx = g_errdeferCount - 1
            while edRetIdx >= 0 {
                generateExpression(g_errdeferExprs[edRetIdx])
                edRetIdx = edRetIdx - 1
            }
            output.append("  br label %" + edOkLabel + "\n")
            output.append(edOkLabel + ":\n")
            // Mark that return value is pre-evaluated (will be loaded from alloca)
            // We set a flag so the return generation below can reuse the temp
            g_errdeferTempAlloca = edTempAlloca
        }
        if g_errdeferCount > 0 and stmt.returnValue.kind == "None" {
            // Void return with errdefer — run errdefer unconditionally (no return value to check)
            output.append("  ; errdefer cleanup before void return (LIFO)\n")
            var edRetIdx = g_errdeferCount - 1
            while edRetIdx >= 0 {
                generateExpression(g_errdeferExprs[edRetIdx])
                edRetIdx = edRetIdx - 1
            }
        }
        if currentFunctionRegionSizeBytes() > 0 {
            let regionLoadReg = getNextReg()
            output.append("  " + regionLoadReg + " = load ptr, ptr %__region_ptr\n")
            output.append("  call void @__seen_region_destroy(ptr " + regionLoadReg + ") ; @preallocate cleanup\n")
        }
        // Emit profile_exit before return if profiled
        if g_currentFunctionIsProfiled {
            let strIdx = getStringConstantIndex(g_currentFunctionNameForProfile)
            output.append("  ; @profile instrumentation - exit (explicit return)\n")
            output.append("  call void @__seen_profile_exit(ptr @.str." + strIdx.toString() + ")\n")
        }

        // For async functions, store return value in promise and branch to final suspend
        if isCurrentFunctionAsyncLowering() {
            if stmt.returnValue.kind != "None" {
                // Evaluate the return expression
                let savedPendingType = pendingArrayLiteralType
                if stmt.returnValue.kind == "ArrayLiteral" and (currentFunctionReturnType.startsWith("Array") or currentFunctionReturnType.startsWith("List")) {
                    pendingArrayLiteralType = currentFunctionReturnType
                }
                // Tail call optimization for async: still mark call position
                if stmt.returnValue.kind == "Call" {
                    markTailCallPosition()
                }
                let valueReg = generateExpression(stmt.returnValue)
                pendingArrayLiteralType = savedPendingType
                let promiseType = mapType(currentFunctionReturnType)
                output.append("  store " + promiseType + " " + valueReg + ", ptr " + g_asyncFunctionPromise + "\n")
            }
            output.append("  br label %" + g_asyncFinalLabel + "\n")
            blockTerminated = true
            return
        }

        if stmt.returnValue.kind == "None" {
            // Check if function has non-void return type - use default value
            let llvmType = mapType(currentFunctionReturnType)
            var emittedDefRet = false
            if llvmType == "void" or currentFunctionReturnType == "" or currentFunctionReturnType == "Void" {
                if g_isMainFunc == 1 {
                    output.append("  ret i32 0\n")
                } else {
                    output.append("  ret void\n")
                }
                emittedDefRet = true
            }
            if not emittedDefRet and llvmType == "i1" {
                output.append("  ret i1 false\n")
                emittedDefRet = true
            }
            if not emittedDefRet and llvmType == "i64" {
                output.append("  ret i64 0\n")
                emittedDefRet = true
            }
            if not emittedDefRet and llvmType == "ptr" {
                output.append("  ret ptr null\n")
                emittedDefRet = true
            }
            if not emittedDefRet and llvmType == "%SeenString" {
                output.append("  ret %SeenString zeroinitializer\n")
                emittedDefRet = true
            }
            if not emittedDefRet and llvmType == "%SeenArray" {
                output.append("  ret %SeenArray zeroinitializer\n")
                emittedDefRet = true
            }
            if not emittedDefRet {
                // Generic struct type - return zeroinitializer
                output.append("  ret " + llvmType + " zeroinitializer\n")
            }
        }
        if stmt.returnValue.kind != "None" {
            // Tail call optimization: if returning a direct function call, mark for tail call
            if stmt.returnValue.kind == "Call" {
                markTailCallPosition()
            }
            // Special handling for Char return type with string literals
            if currentFunctionReturnType == "Char" and stmt.returnValue.kind == "Literal" and stmt.returnValue.literalType == "String" {
                // Convert single-char string to its code point
                let charValue = stmt.returnValue.literalValue
                if charValue.length() == 1 {
                    // Get first character's code point
                    let codeStr = charToCodeStr(charValue)
                    output.append("  ret i64 " + codeStr + "\n")
                    blockTerminated = true
                    return
                }
            }

            // If errdefer already evaluated the return expression, load from temp alloca
            var valueReg = ""
            if g_errdeferTempAlloca != "" {
                let edLoadReg = getNextReg()
                output.append("  " + edLoadReg + " = load i64, ptr " + g_errdeferTempAlloca + "\n")
                valueReg = edLoadReg
                g_errdeferTempAlloca = ""
            } else {
                let savedPendingType = pendingArrayLiteralType
                if stmt.returnValue.kind == "ArrayLiteral" and (currentFunctionReturnType.startsWith("Array") or currentFunctionReturnType.startsWith("List")) {
                    pendingArrayLiteralType = currentFunctionReturnType
                }
                valueReg = generateExpression(stmt.returnValue)
                pendingArrayLiteralType = savedPendingType
            }
            // Use the function's declared return type, not inferred type
            let llvmType = mapType(currentFunctionReturnType)
            // If returning a data type from a struct literal, we need to load the struct
            // (struct literals return ptr, but data type functions should return inline struct)
            if isDataType(currentFunctionReturnType) and stmt.returnValue.kind == "StructLiteral" {
                let loadReg = getNextReg()
                output.append("  " + loadReg + " = load " + llvmType + ", ptr " + valueReg + "\n")
                valueReg = loadReg
            }
            // Note: class types use mapType → i64, and generateStructLiteral already returns i64
            // for class types (via ptrtoint). No conversion needed here.
            // Handle default return values when expression generation fails
            if valueReg == "0" {
                var fixedValReg = false
                if llvmType == "ptr" {
                    valueReg = "null"
                    fixedValReg = true
                }
                if not fixedValReg and llvmType == "%SeenString" {
                    // Return empty string { 0, null }
                    valueReg = "zeroinitializer"
                    fixedValReg = true
                }
                if not fixedValReg and llvmType == "%SeenArray" {
                    // Return empty array { 0, 0, null }
                    valueReg = "zeroinitializer"
                    fixedValReg = true
                }
                if not fixedValReg and llvmType == "i1" {
                    valueReg = "false"
                }
            }
            output.append("  ret " + llvmType + " " + valueReg + "\n")
        }
        blockTerminated = true
    }

    // Generate IR for an if/else statement. Performs branch elimination at
    // compile time for constant conditions (BoolLiteral true/false).
    // Emits conditional branch (br i1 %cond, label %then, label %else),
    // generates then/else blocks, and emits a merge block if neither branch
    // terminates (both have a path to the merge point).
    fun generateIfStatement(stmt: StatementNode) r: Void {
        // Branch elimination: fold compile-time constant conditions (9.10)
        if stmt.condition.kind == "BoolLiteral" {
            if stmt.condition.literalValue == "true" {
                g_branchesEliminated = g_branchesEliminated + 1
                mlLogDecision("branch-elim", "folded", "if-true")
                output.append("  ; branch eliminated: if true\n")
                generateBlock(stmt.thenBranch)
                return
            }
            if stmt.condition.literalValue == "false" {
                g_branchesEliminated = g_branchesEliminated + 1
                mlLogDecision("branch-elim", "folded", "if-false")
                output.append("  ; branch eliminated: if false\n")
                if stmt.elseBranch.statements.length() > 0 {
                    generateBlock(stmt.elseBranch)
                }
                return
            }
        }

        // --- Select optimization: if/else with single assignment to same variable ---
        // Pattern: if <cond> { x = A } else { x = B } → select i1 %cond, A, B
        var selectHandled = false
        if stmt.thenBranch.statements.length() == 1 and stmt.elseBranch.statements.length() == 1 {
            let thenSt = stmt.thenBranch.statements[0]
            let elseSt = stmt.elseBranch.statements[0]
            // Check both are assignments (Expression with Assignment kind)
            var thenAssignName = ""
            var elseAssignName = ""
            var thenIsExprAssign = false
            var elseIsExprAssign = false
            var thenIsStmtAssign = false
            var elseIsStmtAssign = false
            if thenSt.kind == "Expression" and thenSt.expression.kind == "Assignment" {
                thenAssignName = thenSt.expression.variableName
                thenIsExprAssign = true
            }
            if thenSt.kind == "Assignment" {
                thenAssignName = thenSt.variableName
                thenIsStmtAssign = true
            }
            if elseSt.kind == "Expression" and elseSt.expression.kind == "Assignment" {
                elseAssignName = elseSt.expression.variableName
                elseIsExprAssign = true
            }
            if elseSt.kind == "Assignment" {
                elseAssignName = elseSt.variableName
                elseIsStmtAssign = true
            }
            // Only proceed if both are confirmed assignments
            var thenHasRHS = false
            var elseHasRHS = false
            if thenIsExprAssign and thenSt.expression.operands.length() > 0 { thenHasRHS = true }
            if thenIsStmtAssign { thenHasRHS = true }
            if elseIsExprAssign and elseSt.expression.operands.length() > 0 { elseHasRHS = true }
            if elseIsStmtAssign { elseHasRHS = true }
            if thenAssignName != "" and thenAssignName == elseAssignName and thenHasRHS and elseHasRHS {
                // Determine variable type first
                let selVarIdx = findVar(thenAssignName)
                if selVarIdx >= 0 {
                    let selVarType = varTypes[selVarIdx]
                    let selLlvmType = mapType(selVarType)
                    if selLlvmType == "i64" or selLlvmType == "double" {
                        // Get RHS expressions safely
                        var thenRHS = thenSt.initializer
                        if thenIsExprAssign { thenRHS = thenSt.expression.operands[0] }
                        var elseRHS = elseSt.initializer
                        if elseIsExprAssign { elseRHS = elseSt.expression.operands[0] }
                        // Check both RHS are cheap (no calls, no index ops)
                        let thenCost = exprCost(thenRHS)
                        let elseCost = exprCost(elseRHS)
                        if thenCost < 8 and elseCost < 8 {
                            let selCondReg = generateExpression(stmt.condition)
                            let selThenReg = generateExpression(thenRHS)
                            let selElseReg = generateExpression(elseRHS)
                            let selResultReg = getNextReg()
                            output.append("  " + selResultReg + " = select i1 " + selCondReg + ", " + selLlvmType + " " + selThenReg + ", " + selLlvmType + " " + selElseReg + " ; branchless if/else\n")
                            output.append("  store " + selLlvmType + " " + selResultReg + ", ptr " + varRegs[selVarIdx] + "\n")
                            selectHandled = true
                            g_branchesEliminated = g_branchesEliminated + 1
                            mlLogDecision("select", "if-else", thenAssignName)
                        }
                    }
                }
            }
        }
        // --- Select optimization: single-arm if for max/min pattern ---
        // Pattern: if x > y { y = x } → select i1 %cmp, x, y (conditional max)
        // Pattern: if x < y { y = x } → select i1 %cmp, x, y (conditional min)
        if not selectHandled and stmt.thenBranch.statements.length() == 1 and stmt.elseBranch.statements.length() == 0 {
            let maxSt = stmt.thenBranch.statements[0]
            var maxAssignName = ""
            var maxIsExprAssign = false
            var maxIsStmtAssign = false
            if maxSt.kind == "Expression" and maxSt.expression.kind == "Assignment" {
                maxAssignName = maxSt.expression.variableName
                maxIsExprAssign = true
            }
            if maxSt.kind == "Assignment" {
                maxAssignName = maxSt.variableName
                maxIsStmtAssign = true
            }
            // Condition must be a comparison
            if maxAssignName != "" and stmt.condition.kind == "Binary" {
                var isCompareOp = false
                if stmt.condition.operator == ">" or stmt.condition.operator == ">=" or stmt.condition.operator == "<" or stmt.condition.operator == "<=" {
                    isCompareOp = true
                }
                // Check RHS availability
                var maxHasRHS = false
                if maxIsExprAssign and maxSt.expression.operands.length() > 0 { maxHasRHS = true }
                if maxIsStmtAssign { maxHasRHS = true }
                if isCompareOp and stmt.condition.operands.length() >= 2 and maxHasRHS {
                    var maxRHS = maxSt.initializer
                    if maxIsExprAssign { maxRHS = maxSt.expression.operands[0] }
                    let maxRHSCost = exprCost(maxRHS)
                    if maxRHSCost < 5 {
                        let maxVarIdx = findVar(maxAssignName)
                        if maxVarIdx >= 0 {
                            let maxVarType = varTypes[maxVarIdx]
                            let maxLlvmType = mapType(maxVarType)
                            if maxLlvmType == "i64" or maxLlvmType == "double" {
                                let maxCondReg = generateExpression(stmt.condition)
                                let maxNewReg = generateExpression(maxRHS)
                                // Current value of the assigned variable
                                let maxOldReg = getNextReg()
                                output.append("  " + maxOldReg + " = load " + maxLlvmType + ", ptr " + varRegs[maxVarIdx] + "\n")
                                let maxSelReg = getNextReg()
                                output.append("  " + maxSelReg + " = select i1 " + maxCondReg + ", " + maxLlvmType + " " + maxNewReg + ", " + maxLlvmType + " " + maxOldReg + " ; branchless max/min\n")
                                output.append("  store " + maxLlvmType + " " + maxSelReg + ", ptr " + varRegs[maxVarIdx] + "\n")
                                selectHandled = true
                                g_branchesEliminated = g_branchesEliminated + 1
                                mlLogDecision("select", "max-min", maxAssignName)
                            }
                        }
                    }
                }
            }
        }
        if selectHandled { return }

        let condReg = generateExpression(stmt.condition)

        // Ensure condition is i1 — comparisons/not/literals already return i1,
        // but variable loads (Int, Bool stored as i64) need icmp ne conversion
        var condBool = condReg
        let condKind = stmt.condition.kind
        var condIsI1 = false
        if condKind == "Binary" {
            let condOp = stmt.condition.operator
            if condOp == "==" or condOp == "!=" or condOp == "<" or condOp == ">" or condOp == "<=" or condOp == ">=" {
                condIsI1 = true
            }
            if condOp == "and" or condOp == "or" {
                condIsI1 = true
            }
        }
        if condKind == "Not" {
            condIsI1 = true
        }
        if condKind == "Literal" {
            let condLitVal = stmt.condition.literalValue
            if condLitVal == "true" or condLitVal == "false" {
                condIsI1 = true
            }
        }
        if condKind == "Call" {
            // Function calls returning Bool produce i1
            let callRetType = inferExpressionType(stmt.condition)
            if callRetType == "Bool" or callRetType == "Boolean" {
                condIsI1 = true
            }
        }
        // General fallback: check expression type for Bool (covers variables, field access, etc.)
        if not condIsI1 {
            let condExprType = inferExpressionType(stmt.condition)
            if condExprType == "Bool" or condExprType == "Boolean" {
                condIsI1 = true
            }
        }
        if not condIsI1 {
            condBool = getNextReg()
            output.append("  " + condBool + " = icmp ne i64 " + condReg + ", 0\n")
        }

        let thenLabel = getNextBlockLabel()
        let elseLabel = getNextBlockLabel()
        let endLabel = getNextBlockLabel()

        // Branch weight heuristic: short then-block ending in return is likely error/early-exit path
        var branchWeightMeta = ""
        if stmt.thenBranch.statements.length() > 0 and stmt.thenBranch.statements.length() <= 3 {
            let lastThenStmt = stmt.thenBranch.statements[stmt.thenBranch.statements.length() - 1]
            if lastThenStmt.kind == "Return" {
                branchWeightMeta = ", !prof !197"
            }
        }

        // Branch on condition
        output.append("  br i1 " + condBool + ", label %" + thenLabel + ", label %" + elseLabel + branchWeightMeta + "\n")

        // Then block
        output.append(thenLabel + ":\n")
        cseClear()  // CSE cache invalid across basic block boundaries
        blockTerminated = false
        generateBlock(stmt.thenBranch)
        let thenTerminated = blockTerminated
        if not thenTerminated {
            output.append("  br label %" + endLabel + "\n")
        }

        // Else block
        output.append(elseLabel + ":\n")
        cseClear()  // CSE cache invalid across basic block boundaries
        blockTerminated = false
        if stmt.elseBranch.statements.length() > 0 {
            generateBlock(stmt.elseBranch)
        }
        let elseTerminated = blockTerminated
        if not elseTerminated {
            output.append("  br label %" + endLabel + "\n")
        }

        // End block
        output.append(endLabel + ":\n")
        cseClear()  // CSE cache invalid across basic block boundaries
        // Only set blockTerminated if BOTH branches terminate
        if thenTerminated and elseTerminated {
            blockTerminated = true
            output.append("  unreachable\n")
        }
        if not (thenTerminated and elseTerminated) {
            blockTerminated = false
        }
    }

    // if let name = expr { ... } else { ... }
    // Evaluate expr, if non-null bind name to value and run then-block
    fun generateIfLetStatement(stmt: StatementNode) r: Void {
        let exprReg = generateExpression(stmt.condition)
        let cmpReg = getNextReg()
        output.append("  " + cmpReg + " = icmp ne i64 " + exprReg + ", 0\n")

        let thenLabel = getNextBlockLabel()
        let elseLabel = getNextBlockLabel()
        let endLabel = getNextBlockLabel()

        output.append("  br i1 " + cmpReg + ", label %" + thenLabel + ", label %" + elseLabel + "\n")

        // Then block: bind variable to the unwrapped value
        output.append(thenLabel + ":\n")
        cseClear()
        blockTerminated = false
        // Create local variable binding for the unwrapped value
        let bindName = stmt.variableName
        let bindReg = getNextReg()
        output.append("  " + bindReg + " = alloca i64, align 8\n")
        output.append("  store i64 " + exprReg + ", ptr " + bindReg + "\n")
        let savedIfLetVarCount = activeVarCount
        storeVar(bindName, bindReg, "Int")
        generateBlock(stmt.thenBranch)
        activeVarCount = savedIfLetVarCount
        let thenTerminated = blockTerminated
        if not thenTerminated {
            output.append("  br label %" + endLabel + "\n")
        }

        // Else block
        output.append(elseLabel + ":\n")
        cseClear()
        blockTerminated = false
        if stmt.elseBranch.statements.length() > 0 {
            generateBlock(stmt.elseBranch)
        }
        let elseTerminated = blockTerminated
        if not elseTerminated {
            output.append("  br label %" + endLabel + "\n")
        }

        output.append(endLabel + ":\n")
        cseClear()
        if thenTerminated and elseTerminated {
            blockTerminated = true
            output.append("  unreachable\n")
        }
        if not (thenTerminated and elseTerminated) {
            blockTerminated = false
        }
    }

    fun blockHasTerminator(block: BlockNode) r: Bool {
        if block.statements.length() == 0 {
            return false
        }
        let lastStmt = block.statements[block.statements.length() - 1]
        return lastStmt.kind == "Return"
    }

    // Generate IR for a while loop. Emits cond/body/end blocks with
    // back-edge from body to cond. Attaches LLVM loop metadata for:
    //   - !llvm.loop.vectorize.enable/width (from @vectorize decorator)
    //   - !llvm.loop.unroll.count (from @unroll decorator or tile hints)
    //   - !llvm.loop.distribute.enable (for nested loops)
    // Performs pattern detection for memcpy/memmove idioms and replaces
    // them with llvm.memcpy/memmove intrinsics.
    // Saves/restores outer loop context (currentLoopCondLabel/EndLabel)
    // for nested loop support. Break jumps to endLabel, continue to condLabel.
    fun generateWhileStatement(stmt: StatementNode) r: Void {
        // Capture block counter before allocating labels - unique per loop
        // Metadata ID = g_blockBox[0] + 202 (to avoid collision with TBAA nodes 100-106)
        let loopMetaId = g_blockBox[0] + 202
        let loopMetaIdStr = loopMetaId.toString()
        let condLabel = getNextBlockLabel()
        let bodyLabel = getNextBlockLabel()
        let endLabel = getNextBlockLabel()

        // Save outer loop context (for nested loops)
        let savedCondLabel = currentLoopCondLabel
        let savedEndLabel = currentLoopEndLabel
        // Set current loop context for break/continue
        // Encode metadata ID into condLabel with "|" separator for continue to use
        currentLoopCondLabel = condLabel + "|" + loopMetaIdStr
        currentLoopEndLabel = endLabel

        // --- Memcpy/Memmove Pattern Detection ---
        // Pattern 1 (memcpy): while i < n { dest[i] = src[i]; i = i + 1 }
        // Pattern 2 (memmove-shift): while i < n { arr[i] = arr[i + 1]; i = i + 1 }
        // Only apply for large literal bounds (>= 64 elements) where function call overhead is amortized.
        // For small/variable bounds, LLVM's loop optimizations produce better code (register promotion, unrolling).
        var memcpyDetected = 0
        var mcBoundIsLargeLiteral = 0
        if stmt.loopCondition.kind == "Binary" and stmt.loopCondition.operator == "<" {
            if stmt.loopCondition.operands.length() >= 2 {
                let mcBoundCheck = stmt.loopCondition.operands[1]
                if mcBoundCheck.kind == "Literal" and mcBoundCheck.literalType == "Int" {
                    let mcBoundVal = parseIntManual(mcBoundCheck.literalValue)
                    if mcBoundVal >= 64 {
                        mcBoundIsLargeLiteral = 1
                    }
                }
            }
        }
        if mcBoundIsLargeLiteral == 1 and stmt.loopCondition.kind == "Binary" and stmt.loopCondition.operator == "<" {
            if stmt.loopBody.statements.length() == 2 {
                let mcStmt0 = stmt.loopBody.statements[0]
                let mcStmt1 = stmt.loopBody.statements[1]
                // Check stmt[0] is IndexAssignment: arr[i] = expr
                var mcIsIdxAssign = 0
                if mcStmt0.kind == "Expression" {
                    if mcStmt0.expression.kind == "IndexAssignment" {
                        mcIsIdxAssign = 1
                    }
                }
                // Check stmt[1] is i = i + 1
                var mcIsIncrement = 0
                var mcIncrVarName = ""
                if mcStmt1.kind == "Expression" {
                    if mcStmt1.expression.kind == "Assignment" {
                        mcIncrVarName = mcStmt1.expression.variableName
                        if mcStmt1.expression.operands.length() > 0 {
                            let mcIncrRHS = mcStmt1.expression.operands[0]
                            if mcIncrRHS.kind == "Binary" and mcIncrRHS.operator == "+" {
                                if mcIncrRHS.operands.length() >= 2 {
                                    let mcIncrLeft = mcIncrRHS.operands[0]
                                    let mcIncrRight = mcIncrRHS.operands[1]
                                    var mcIncrLeftName = mcIncrLeft.literalValue
                                    if mcIncrLeftName == "" { mcIncrLeftName = mcIncrLeft.variableName }
                                    if mcIncrLeftName == mcIncrVarName and mcIncrRight.kind == "Literal" and mcIncrRight.literalValue == "1" {
                                        mcIsIncrement = 1
                                    }
                                }
                            }
                        }
                    }
                }
                if mcIsIdxAssign == 1 and mcIsIncrement == 1 {
                    // Extract LHS array/index and RHS
                    let mcIdxAssign = mcStmt0.expression
                    let mcLHSAccess = mcIdxAssign.operands[0]
                    let mcRHSExpr = mcIdxAssign.operands[1]
                    let mcLHSArr = mcLHSAccess.operands[0]
                    let mcLHSIdx = mcLHSAccess.operands[1]
                    // Get LHS array variable name
                    var mcLHSArrName = mcLHSArr.literalValue
                    if mcLHSArrName == "" { mcLHSArrName = mcLHSArr.variableName }
                    // Get LHS index variable name
                    var mcLHSIdxName = mcLHSIdx.literalValue
                    if mcLHSIdxName == "" { mcLHSIdxName = mcLHSIdx.variableName }
                    // Get condition variable name (loop var)
                    var mcCondVarName = ""
                    if stmt.loopCondition.operands.length() >= 2 {
                        let mcCondLeft = stmt.loopCondition.operands[0]
                        mcCondVarName = mcCondLeft.literalValue
                        if mcCondVarName == "" { mcCondVarName = mcCondLeft.variableName }
                    }
                    // Verify index var matches loop induction var
                    if mcLHSIdxName == mcIncrVarName and mcCondVarName == mcIncrVarName {
                        // Check if RHS is IndexAccess with same index (memcpy) or index+1 (memmove)
                        if mcRHSExpr.kind == "IndexAccess" {
                            let mcRHSArr = mcRHSExpr.operands[0]
                            let mcRHSIdx = mcRHSExpr.operands[1]
                            var mcRHSArrName = mcRHSArr.literalValue
                            if mcRHSArrName == "" { mcRHSArrName = mcRHSArr.variableName }
                            // Check: is RHS index just the same variable? (memcpy pattern)
                            var mcRHSIdxName = ""
                            if mcRHSIdx.kind == "Variable" or mcRHSIdx.kind == "VarExpr" {
                                mcRHSIdxName = mcRHSIdx.literalValue
                                if mcRHSIdxName == "" { mcRHSIdxName = mcRHSIdx.variableName }
                            }
                            // Pattern 1: dest[i] = src[i] where dest != src
                            if mcRHSIdxName == mcIncrVarName and mcLHSArrName != mcRHSArrName {
                                // Verify both are Array<Int> (8-byte elements)
                                let mcDstType = findVarType(mcLHSArrName)
                                let mcSrcType = findVarType(mcRHSArrName)
                                if mcDstType == "Array<Int>" and mcSrcType == "Array<Int>" {
                                    // Generate memcpy: get data pointers, compute byte count, call intrinsic
                                    let mcBoundExpr = stmt.loopCondition.operands[1]
                                    let mcBoundReg = generateExpression(mcBoundExpr)
                                    let mcDstIdx = findVar(mcLHSArrName)
                                    let mcSrcIdx = findVar(mcRHSArrName)
                                    if mcDstIdx >= 0 and mcSrcIdx >= 0 {
                                        // Load array struct pointers from allocas first
                                        let mcDstPtr = getNextReg()
                                        output.append("  " + mcDstPtr + " = load ptr, ptr " + varRegs[mcDstIdx] + "\n")
                                        let mcSrcPtr = getNextReg()
                                        output.append("  " + mcSrcPtr + " = load ptr, ptr " + varRegs[mcSrcIdx] + "\n")
                                        let mcDstPP = getNextReg()
                                        output.append("  " + mcDstPP + " = getelementptr inbounds %SeenArray, ptr " + mcDstPtr + ", i32 0, i32 3\n")
                                        let mcDstData = getNextReg()
                                        output.append("  " + mcDstData + " = load ptr, ptr " + mcDstPP + ", !tbaa !104\n")
                                        let mcSrcPP = getNextReg()
                                        output.append("  " + mcSrcPP + " = getelementptr inbounds %SeenArray, ptr " + mcSrcPtr + ", i32 0, i32 3\n")
                                        let mcSrcData = getNextReg()
                                        output.append("  " + mcSrcData + " = load ptr, ptr " + mcSrcPP + ", !tbaa !104\n")
                                        let mcByteCount = getNextReg()
                                        output.append("  " + mcByteCount + " = shl nsw i64 " + mcBoundReg + ", 3\n")
                                        output.append("  call void @llvm.memcpy.p0.p0.i64(ptr " + mcDstData + ", ptr " + mcSrcData + ", i64 " + mcByteCount + ", i1 false)\n")
                                        // Update loop var to bound value (skip loop)
                                        let mcLoopVarIdx = findVar(mcIncrVarName)
                                        if mcLoopVarIdx >= 0 {
                                            output.append("  store i64 " + mcBoundReg + ", ptr " + varRegs[mcLoopVarIdx] + "\n")
                                        }
                                        output.append("  ; memcpy optimization: " + mcLHSArrName + "[i] = " + mcRHSArrName + "[i] → llvm.memcpy\n")
                                        mlLogDecision("memcpy", "applied", mcLHSArrName + "<-" + mcRHSArrName)
                                        g_loopsOptimized = g_loopsOptimized + 1
                                        memcpyDetected = 1
                                    }
                                }
                            }
                            // Pattern 2: arr[i] = arr[i + 1] (shift-left by one) → memmove
                            if mcLHSArrName == mcRHSArrName and mcRHSIdx.kind == "Binary" {
                                if mcRHSIdx.operator == "+" and mcRHSIdx.operands.length() >= 2 {
                                    let mcShiftLeft = mcRHSIdx.operands[0]
                                    let mcShiftRight = mcRHSIdx.operands[1]
                                    var mcShiftLeftName = mcShiftLeft.literalValue
                                    if mcShiftLeftName == "" { mcShiftLeftName = mcShiftLeft.variableName }
                                    if mcShiftLeftName == mcIncrVarName and mcShiftRight.kind == "Literal" and mcShiftRight.literalValue == "1" {
                                        let mcArrType = findVarType(mcLHSArrName)
                                        if mcArrType == "Array<Int>" {
                                            let mcBoundExpr2 = stmt.loopCondition.operands[1]
                                            let mcBoundReg2 = generateExpression(mcBoundExpr2)
                                            let mcArrIdx2 = findVar(mcLHSArrName)
                                            if mcArrIdx2 >= 0 {
                                                // Load array struct pointer from alloca
                                                let mcArrPtr2 = getNextReg()
                                                output.append("  " + mcArrPtr2 + " = load ptr, ptr " + varRegs[mcArrIdx2] + "\n")
                                                let mcDP2 = getNextReg()
                                                output.append("  " + mcDP2 + " = getelementptr inbounds %SeenArray, ptr " + mcArrPtr2 + ", i32 0, i32 3\n")
                                                let mcData2 = getNextReg()
                                                output.append("  " + mcData2 + " = load ptr, ptr " + mcDP2 + ", !tbaa !104\n")
                                                let mcSrc2 = getNextReg()
                                                output.append("  " + mcSrc2 + " = getelementptr i64, ptr " + mcData2 + ", i64 1\n")
                                                let mcBytes2 = getNextReg()
                                                output.append("  " + mcBytes2 + " = shl nsw i64 " + mcBoundReg2 + ", 3\n")
                                                output.append("  call void @llvm.memmove.p0.p0.i64(ptr " + mcData2 + ", ptr " + mcSrc2 + ", i64 " + mcBytes2 + ", i1 false)\n")
                                                let mcLoopVarIdx2 = findVar(mcIncrVarName)
                                                if mcLoopVarIdx2 >= 0 {
                                                    output.append("  store i64 " + mcBoundReg2 + ", ptr " + varRegs[mcLoopVarIdx2] + "\n")
                                                }
                                                output.append("  ; memmove optimization: " + mcLHSArrName + "[i] = " + mcLHSArrName + "[i+1] → llvm.memmove\n")
                                                mlLogDecision("memmove", "applied", mcLHSArrName + "[i]<-[i+1]")
                                                g_loopsOptimized = g_loopsOptimized + 1
                                                memcpyDetected = 1
                                            }
                                        }
                                    }
                                }
                            }
                        }
                    }
                }
            }
        }
        // If memcpy/memmove was applied, skip normal loop generation entirely
        if memcpyDetected == 1 {
            // Jump past the loop — no cond/body/end blocks needed
            // But we still need to emit the allocated labels as empty blocks for SSA validity
            output.append("  br label %" + endLabel + "\n")
            output.append(condLabel + ":\n")
            output.append("  br label %" + endLabel + "\n")
            output.append(bodyLabel + ":\n")
            output.append("  br label %" + endLabel + "\n")
            output.append(endLabel + ":\n")
            currentLoopCondLabel = savedCondLabel
            currentLoopEndLabel = savedEndLabel
            return
        }

        // --- Section 9.8: Advanced Loop Optimizations ---
        // Detect loop bound from condition: i < N where N is literal
        var loopBoundLiteral = 0
        var hasLiteralBound = false
        if stmt.loopCondition.kind == "Binary" {
            if stmt.loopCondition.operator == "<" or stmt.loopCondition.operator == "<=" {
                if stmt.loopCondition.operands.length() >= 2 {
                    let boundExpr = stmt.loopCondition.operands[1]
                    if boundExpr.kind == "Literal" and boundExpr.literalType == "Int" {
                        loopBoundLiteral = parseIntManual(boundExpr.literalValue)
                        hasLiteralBound = true
                    }
                }
            }
        }

        // Loop tiling (9.8): for large literal bounds, emit per-loop unroll.count metadata
        if hasLiteralBound and loopBoundLiteral > 64 {
            var tileSize = loopBoundLiteral / 8
            if tileSize > 32 { tileSize = 32 }
            // ML threshold: use g_mlUnrollThreshold as minimum tile size
            if tileSize < g_mlUnrollThreshold { tileSize = g_mlUnrollThreshold }
            output.append("  ; loop tiling: bound=" + loopBoundLiteral.toString() + " → unroll.count=" + tileSize.toString() + "\n")
            g_loopsOptimized = g_loopsOptimized + 1
            // Record tile hint for emitLoopMetadata to emit per-loop unroll.count
            let tileMetaIdx = loopMetaId - 202
            let tileEntry = tileMetaIdx.toString() + ":" + tileSize.toString()
            if g_loopTileHints == "" {
                g_loopTileHints = tileEntry
            } else {
                g_loopTileHints = g_loopTileHints + "|" + tileEntry
            }
            mlLogDecision("loop-tile", "unroll", "bound:" + loopBoundLiteral.toString() + ",tile:" + tileSize.toString())
        }
        // ML vectorize threshold: disable vectorization for very small loops
        if hasLiteralBound and loopBoundLiteral < g_mlVectorizeThreshold and loopBoundLiteral > 0 {
            output.append("  ; ML: loop bound " + loopBoundLiteral.toString() + " < vectorize threshold " + g_mlVectorizeThreshold.toString() + " → skip vectorize\n")
            // Record this loop for no-vectorize in emitLoopMetadata
            let noVecMetaIdx = loopMetaId - 202
            // Use tileSize=-1 as a per-loop no-vectorize marker
            let noVecEntry = noVecMetaIdx.toString() + ":-1"
            if g_loopTileHints == "" {
                g_loopTileHints = noVecEntry
            } else {
                g_loopTileHints = g_loopTileHints + "|" + noVecEntry
            }
            mlLogDecision("ml-vec", "skip", "bound:" + loopBoundLiteral.toString() + "<threshold:" + g_mlVectorizeThreshold.toString())
        }

        // LICM annotation (9.8): check for module-level constant loads in loop body
        var licmIdx = 0
        while licmIdx < stmt.loopBody.statements.length() {
            let licmStmt = stmt.loopBody.statements[licmIdx]
            if licmStmt.kind == "Let" or licmStmt.kind == "Var" {
                // Check if RHS is a module-level constant variable
                if licmStmt.expression.kind == "Variable" or licmStmt.expression.kind == "VarExpr" {
                    var licmVarName = licmStmt.expression.literalValue
                    if licmVarName == "" { licmVarName = licmStmt.expression.variableName }
                    var mcIdx = 0
                    while mcIdx < moduleConstantNames.length() {
                        if moduleConstantNames[mcIdx] == licmVarName {
                            var licmImmutable = true
                            if isModuleConstMutable(mcIdx) { licmImmutable = false }
                            if licmImmutable {
                                output.append("  ; LICM: " + licmVarName + " is immutable module constant (!invariant.load applied)\n")
                                mlLogDecision("licm", "applied", licmVarName)
                            } else {
                                output.append("  ; LICM candidate: " + licmVarName + " is mutable (var), skipped\n")
                                mlLogDecision("licm", "skipped-mutable", licmVarName)
                            }
                            g_loopsOptimized = g_loopsOptimized + 1
                            mcIdx = moduleConstantNames.length()
                        }
                        mcIdx = mcIdx + 1
                    }
                }
            }
            licmIdx = licmIdx + 1
        }

        // Detect nested loop for interchange hint (9.8)
        var nestedLoopIdx = 0
        while nestedLoopIdx < stmt.loopBody.statements.length() {
            let nlStmt = stmt.loopBody.statements[nestedLoopIdx]
            if nlStmt.kind == "While" {
                output.append("  ; nested loop detected - interchange candidate\n")
                g_loopsOptimized = g_loopsOptimized + 1
                mlLogDecision("loop-interchange", "candidate", "nested-while")
                // Record this loop for distribute.enable metadata
                let nestedMetaIdx = loopMetaId - 202
                if g_nestedLoopIds == "" {
                    g_nestedLoopIds = nestedMetaIdx.toString()
                } else {
                    g_nestedLoopIds = g_nestedLoopIds + "|" + nestedMetaIdx.toString()
                }
            }
            nestedLoopIdx = nestedLoopIdx + 1
        }

        // Small-loop full-unroll hint: ≤ 8 statements and no nested loops → unroll.full
        var hasNestedWhile = false
        var snlIdx = 0
        while snlIdx < stmt.loopBody.statements.length() {
            let snlStmt = stmt.loopBody.statements[snlIdx]
            if snlStmt.kind == "While" { hasNestedWhile = true }
            if snlStmt.kind == "For" { hasNestedWhile = true }
            if snlStmt.kind == "ForIn" { hasNestedWhile = true }
            snlIdx = snlIdx + 1
        }
        if hasLiteralBound and loopBoundLiteral > 0 and loopBoundLiteral <= 32 and not hasNestedWhile and stmt.loopBody.statements.length() <= 8 {
            let fullUnrollMetaIdx = loopMetaId - 202
            let fullUnrollEntry = fullUnrollMetaIdx.toString() + ":-2"
            if g_loopTileHints == "" {
                g_loopTileHints = fullUnrollEntry
            } else {
                g_loopTileHints = g_loopTileHints + "|" + fullUnrollEntry
            }
            output.append("  ; small loop (bound=" + loopBoundLiteral.toString() + ", " + stmt.loopBody.statements.length().toString() + " stmts) → full unroll hint\n")
        }

        // GCD-pattern aggressive unroll: while Y > 0 with modulo in body → unroll 8
        if stmt.loopCondition.kind == "Binary" and stmt.loopCondition.operator == ">" {
            if stmt.loopCondition.operands.length() >= 2 {
                let gcdBound = stmt.loopCondition.operands[1]
                if gcdBound.kind == "Literal" and gcdBound.literalValue == "0" {
                    // Check body for modulo assignment
                    var hasModuloAssign = false
                    var gcdIdx = 0
                    while gcdIdx < stmt.loopBody.statements.length() {
                        let gcdStmt = stmt.loopBody.statements[gcdIdx]
                        if gcdStmt.kind == "Expression" and gcdStmt.expression.kind == "Assignment" {
                            if gcdStmt.expression.operands.length() > 0 {
                                let gcdRHS = gcdStmt.expression.operands[0]
                                if gcdRHS.kind == "Binary" and gcdRHS.operator == "%" {
                                    hasModuloAssign = true
                                }
                            }
                        }
                        gcdIdx = gcdIdx + 1
                    }
                    if hasModuloAssign and stmt.loopBody.statements.length() <= 5 {
                        let gcdMetaIdx = loopMetaId - 202
                        let gcdEntry = gcdMetaIdx.toString() + ":8"
                        if g_loopTileHints == "" {
                            g_loopTileHints = gcdEntry
                        } else {
                            g_loopTileHints = g_loopTileHints + "|" + gcdEntry
                        }
                        output.append("  ; GCD-pattern loop → unroll.count=8\n")
                    }
                }
            }
        }

        // Detect reduction pattern in loop body (9.9)
        var reductionVar = ""
        var isReduction = false
        var riIdx = 0
        while riIdx < stmt.loopBody.statements.length() {
            let riStmt = stmt.loopBody.statements[riIdx]
            if riStmt.kind == "Expression" and riStmt.expression.kind == "Assignment" {
                let riAssignName = riStmt.expression.variableName
                if riStmt.expression.operands.length() > 0 {
                    let riRHS = riStmt.expression.operands[0]
                    if riRHS.kind == "Binary" {
                        if riRHS.operator == "+" or riRHS.operator == "*" {
                            if riRHS.operands.length() >= 2 {
                                let riLeft = riRHS.operands[0]
                                // Parser uses VarExpr with variableName (not Variable/literalValue)
                                var riLeftName = riLeft.literalValue
                                if riLeftName == "" { riLeftName = riLeft.variableName }
                                if (riLeft.kind == "Variable" or riLeft.kind == "VarExpr") and riLeftName == riAssignName {
                                    reductionVar = riAssignName
                                    isReduction = true
                                }
                            }
                        }
                    }
                }
            }
            riIdx = riIdx + 1
        }
        if isReduction {
            var reductionType = "sum"
            output.append("  ; reduction chain detected: " + reductionType + " on " + reductionVar + " → 2x vectorize width\n")
            g_reductionChainsDetected = g_reductionChainsDetected + 1
            // Record this loop's metadata index for wider vectorize width in emitLoopMetadata
            let reductionMetaIdx = loopMetaId - 202
            if g_reductionLoopIds == "" {
                g_reductionLoopIds = reductionMetaIdx.toString()
            } else {
                g_reductionLoopIds = g_reductionLoopIds + "|" + reductionMetaIdx.toString()
            }
            mlLogDecision("reduction", reductionType, reductionVar)
        }

        // Save outer loop's induction var for nested loop support
        let savedInductionVarName = g_inductionVarName

        // Detect induction variable pattern: i = i + 1 or i = i - 1 (9.8)
        var hasInductionVar = false
        var inductionVarName = ""
        var ivIdx = 0
        while ivIdx < stmt.loopBody.statements.length() {
            let ivStmt = stmt.loopBody.statements[ivIdx]
            if ivStmt.kind == "Expression" and ivStmt.expression.kind == "Assignment" {
                let ivAssignName = ivStmt.expression.variableName
                if ivStmt.expression.operands.length() > 0 {
                    let ivRHS = ivStmt.expression.operands[0]
                    if ivRHS.kind == "Binary" and (ivRHS.operator == "+" or ivRHS.operator == "-") {
                        if ivRHS.operands.length() >= 2 {
                            let ivLeft = ivRHS.operands[0]
                            let ivRight = ivRHS.operands[1]
                            // Parser uses VarExpr with variableName (not Variable/literalValue)
                            var ivLeftName = ivLeft.literalValue
                            if ivLeftName == "" { ivLeftName = ivLeft.variableName }
                            if (ivLeft.kind == "Variable" or ivLeft.kind == "VarExpr") and ivLeftName == ivAssignName {
                                if ivRight.kind == "Literal" and ivRight.literalValue == "1" {
                                    hasInductionVar = true
                                    inductionVarName = ivAssignName
                                    output.append("  ; induction variable: " + ivAssignName + " → nsw\n")
                                }
                            }
                        }
                    }
                }
            }
            ivIdx = ivIdx + 1
        }
        // Set induction var name for generateBinary to emit nuw flag
        if hasInductionVar {
            g_inductionVarName = inductionVarName
        }

        // --- Break-on-flag optimization ---
        // Pattern: while i < n { if found == 0 { ... found = 1 } i = i + 1 }
        // Merge flag check into loop condition for early exit
        var breakFlagVar = ""
        if stmt.loopBody.statements.length() >= 2 {
            var bfIdx = 0
            while bfIdx < stmt.loopBody.statements.length() {
                let bfStmt = stmt.loopBody.statements[bfIdx]
                if bfStmt.kind == "If" and bfStmt.elseBranch.statements.length() == 0 {
                    // Check condition: flag == 0
                    if bfStmt.condition.kind == "Binary" and bfStmt.condition.operator == "==" {
                        if bfStmt.condition.operands.length() >= 2 {
                            let bfRight = bfStmt.condition.operands[1]
                            if bfRight.kind == "Literal" and bfRight.literalValue == "0" {
                                let bfLeft = bfStmt.condition.operands[0]
                                var bfLeftName = bfLeft.literalValue
                                if bfLeftName == "" { bfLeftName = bfLeft.variableName }
                                // Check body sets flag = 1
                                var bfSetsFlag = false
                                var bfCheckIdx = 0
                                while bfCheckIdx < bfStmt.thenBranch.statements.length() {
                                    let bfCheckSt = bfStmt.thenBranch.statements[bfCheckIdx]
                                    if bfCheckSt.kind == "Expression" and bfCheckSt.expression.kind == "Assignment" {
                                        if bfCheckSt.expression.variableName == bfLeftName {
                                            if bfCheckSt.expression.operands.length() > 0 {
                                                let bfVal = bfCheckSt.expression.operands[0]
                                                if bfVal.kind == "Literal" and bfVal.literalValue == "1" {
                                                    bfSetsFlag = true
                                                }
                                            }
                                        }
                                    }
                                    if bfCheckSt.kind == "Assignment" and bfCheckSt.variableName == bfLeftName {
                                        if bfCheckSt.initializer.kind == "Literal" and bfCheckSt.initializer.literalValue == "1" {
                                            bfSetsFlag = true
                                        }
                                    }
                                    bfCheckIdx = bfCheckIdx + 1
                                }
                                if bfSetsFlag and bfLeftName != "" {
                                    breakFlagVar = bfLeftName
                                    output.append("  ; break-on-flag: " + bfLeftName + " → early loop exit\n")
                                    mlLogDecision("break-flag", "early-exit", bfLeftName)
                                }
                            }
                        }
                    }
                }
                bfIdx = bfIdx + 1
            }
        }

        // Jump to condition check
        output.append("  br label %" + condLabel + "\n")

        // Condition block
        output.append(condLabel + ":\n")
        cseClear()  // CSE cache invalid across basic block boundaries
        let condReg = generateExpression(stmt.loopCondition)
        // If break-on-flag detected, add flag check to loop condition
        if breakFlagVar != "" {
            let bfVarIdx = findVar(breakFlagVar)
            if bfVarIdx >= 0 {
                let bfFlagReg = getNextReg()
                output.append("  " + bfFlagReg + " = load i64, ptr " + varRegs[bfVarIdx] + "\n")
                let bfNotFoundReg = getNextReg()
                output.append("  " + bfNotFoundReg + " = icmp eq i64 " + bfFlagReg + ", 0\n")
                let bfCombinedReg = getNextReg()
                output.append("  " + bfCombinedReg + " = and i1 " + condReg + ", " + bfNotFoundReg + " ; early exit when flag set\n")
                output.append("  br i1 " + bfCombinedReg + ", label %" + bodyLabel + ", label %" + endLabel + ", !prof !196\n")
            }
            if bfVarIdx < 0 {
                output.append("  br i1 " + condReg + ", label %" + bodyLabel + ", label %" + endLabel + ", !prof !196\n")
            }
        }
        if breakFlagVar == "" {
            output.append("  br i1 " + condReg + ", label %" + bodyLabel + ", label %" + endLabel + ", !prof !196\n")
        }

        // Body block
        output.append(bodyLabel + ":\n")
        cseClear()  // CSE cache invalid across basic block boundaries
        blockTerminated = false  // Reset for body
        generateBlock(stmt.loopBody)
        let bodyTerminated = blockTerminated
        // Only add loop branch if body didn't terminate (return/break/continue)
        if not bodyTerminated {
            output.append("  br label %" + condLabel + ", !llvm.loop !" + loopMetaIdStr + "\n")
        }

        // End block - reached when condition is false
        output.append(endLabel + ":\n")
        cseClear()  // CSE cache invalid across basic block boundaries
        // While loop end is always reachable (condition can be false)
        blockTerminated = false

        // Restore outer loop's induction variable
        g_inductionVarName = savedInductionVarName
        // Restore outer loop context
        currentLoopCondLabel = savedCondLabel
        currentLoopEndLabel = savedEndLabel
    }

    // Generate IR for a for-in loop over a range or array.
    // Range loops (for i in 0..n) emit a simple counter-based loop.
    // Array loops (for item in arr) emit index-based iteration with
    // element load per iteration. Attaches the same loop metadata as
    // generateWhileStatement for vectorization/unrolling hints.
    fun generateForInStatement(stmt: StatementNode) r: Void {
        let loopMetaId = g_blockBox[0] + 202
        let loopMetaIdStr = loopMetaId.toString()
        let condLabel = getNextBlockLabel()
        let bodyLabel = getNextBlockLabel()
        let endLabel = getNextBlockLabel()

        // Save outer loop context
        let savedCondLabel = currentLoopCondLabel
        let savedEndLabel = currentLoopEndLabel
        let savedForInVarCount = activeVarCount
        currentLoopCondLabel = condLabel + "|" + loopMetaIdStr
        currentLoopEndLabel = endLabel

        // Find the pre-allocated loop variable
        // ForIn stores: variableName=loop var, expression=iterable, loopBody=body
        let loopVarName = stmt.variableName
        var loopVarType = findVarType(loopVarName)
        if loopVarType == "" {
            loopVarType = "Int"
        }
        let loopVarOrdinal = nextDeclarationOrdinal(loopVarName)
        let loopVarPreIdx = findPreAllocatedOccurrence(loopVarName, loopVarOrdinal)
        var loopVarReg = ""
        if loopVarPreIdx >= 0 and loopVarPreIdx < preAllocatedRegs.length() {
            loopVarReg = preAllocatedRegs[loopVarPreIdx]
        }
        if loopVarReg == "" {
            let loopVarLlvmType = mapType(loopVarType)
            loopVarReg = getNextReg()
            if loopVarLlvmType == "i64" or loopVarLlvmType == "double" or loopVarLlvmType == "ptr" {
                output.append("  " + loopVarReg + " = alloca " + loopVarLlvmType + ", align 8\n")
            } else {
                output.append("  " + loopVarReg + " = alloca " + loopVarLlvmType + "\n")
            }
        }
        let forInIterable = stmt.expression
        let forInIterKind = forInIterable.kind
        if forInIterKind == "Range" {
            // Range-based for-in: for i in start..end
            let startReg = generateExpression(forInIterable.operands[0])
            let endReg = generateExpression(forInIterable.operands[1])

            // Use pre-allocated entry-block alloca for index counter (enables mem2reg)
            let idxName = "__forin_idx_" + loopVarName
            var idxReg = ""
            let idxPreIdx = findPreAllocatedOccurrence(idxName, 1)
            if idxPreIdx >= 0 and idxPreIdx < preAllocatedRegs.length() {
                idxReg = preAllocatedRegs[idxPreIdx]
            }
            if idxReg == "" {
                idxReg = getNextReg()
                output.append("  " + idxReg + " = alloca i64, align 8\n")
            }
            storeVar(loopVarName, loopVarReg, loopVarType)
            output.append("  store i64 " + startReg + ", ptr " + idxReg + "\n")

            // Jump to condition
            output.append("  br label %" + condLabel + "\n")

            // Condition: load index, compare < end
            output.append(condLabel + ":\n")
            cseClear()
            let loadIdx = getNextReg()
            output.append("  " + loadIdx + " = load i64, ptr " + idxReg + ", align 8\n")
            let cmpReg = getNextReg()
            output.append("  " + cmpReg + " = icmp slt i64 " + loadIdx + ", " + endReg + "\n")
            output.append("  br i1 " + cmpReg + ", label %" + bodyLabel + ", label %" + endLabel + ", !prof !196\n")

            // Body: store current index into loop variable, run body, increment
            output.append(bodyLabel + ":\n")
            cseClear()
            blockTerminated = false
            // Store current index value into the loop variable
            if loopVarReg != "" {
                output.append("  store i64 " + loadIdx + ", ptr " + loopVarReg + ", align 8\n")
            }
            generateBlock(stmt.loopBody)
            let bodyTerminated = blockTerminated
            if not bodyTerminated {
                // Increment index
                let curIdx = getNextReg()
                output.append("  " + curIdx + " = load i64, ptr " + idxReg + ", align 8\n")
                let nextIdx = getNextReg()
                output.append("  " + nextIdx + " = add nuw nsw i64 " + curIdx + ", 1\n")
                output.append("  store i64 " + nextIdx + ", ptr " + idxReg + ", align 8\n")
                output.append("  br label %" + condLabel + ", !llvm.loop !" + loopMetaIdStr + "\n")
            }
        } else {
            // Check for iterator protocol: type has iter() / hasNext() / next()
            let iterableType = inferExpressionType(forInIterable)
            let iterFuncName = iterableType + "_iter"
            let iterFuncRet = getFunctionReturnType(iterFuncName)
            if iterFuncRet != "" {
                // Iterator protocol: desugar to while __iter.hasNext() { var x = __iter.next(); ... }
                let iterableReg = generateExpression(forInIterable)
                let iterThisReg = getNextReg()
                output.append("  " + iterThisReg + " = inttoptr i64 " + iterableReg + " to ptr\n")
                let iterObjReg = getNextReg()
                let iterRetLlvm = mapType(iterFuncRet)
                output.append("  " + iterObjReg + " = call " + iterRetLlvm + " @" + quoteIdentIfNeeded(iterFuncName) + "(ptr " + iterThisReg + ")\n")
                // Store iterator handle
                let iterStoreReg = getNextReg()
                output.append("  " + iterStoreReg + " = alloca i64, align 8\n")
                output.append("  store i64 " + iterObjReg + ", ptr " + iterStoreReg + "\n")
                storeVar(loopVarName, loopVarReg, loopVarType)

                output.append("  br label %" + condLabel + "\n")
                output.append(condLabel + ":\n")
                cseClear()
                // Call hasNext on iterator
                let iterLoadReg = getNextReg()
                output.append("  " + iterLoadReg + " = load i64, ptr " + iterStoreReg + "\n")
                let iterPtrReg = getNextReg()
                output.append("  " + iterPtrReg + " = inttoptr i64 " + iterLoadReg + " to ptr\n")
                let hasNextFunc = iterFuncRet + "_hasNext"
                let hasNextReg = getNextReg()
                output.append("  " + hasNextReg + " = call i1 @" + quoteIdentIfNeeded(hasNextFunc) + "(ptr " + iterPtrReg + ")\n")
                output.append("  br i1 " + hasNextReg + ", label %" + bodyLabel + ", label %" + endLabel + "\n")

                output.append(bodyLabel + ":\n")
                cseClear()
                blockTerminated = false
                // Call next() to get current element
                let nextFunc = iterFuncRet + "_next"
                let nextRetType = getFunctionReturnType(nextFunc)
                var nextRetLlvm = "i64"
                if nextRetType != "" { nextRetLlvm = mapType(nextRetType) }
                let nextReg = getNextReg()
                output.append("  " + nextReg + " = call " + nextRetLlvm + " @" + quoteIdentIfNeeded(nextFunc) + "(ptr " + iterPtrReg + ")\n")
                if loopVarReg != "" {
                    output.append("  store " + nextRetLlvm + " " + nextReg + ", ptr " + loopVarReg + "\n")
                }
                generateBlock(stmt.loopBody)
                let bodyTerminated = blockTerminated
                if not bodyTerminated {
                    output.append("  br label %" + condLabel + "\n")
                }
            } else {
            // Array-based for-in: for elem in array
            let arrReg = generateExpression(forInIterable)
            let iterType = inferExpressionType(forInIterable)
            var elementType = "Int"
            if iterType.startsWith("Array<") {
                elementType = iterType.substring(6, iterType.length() - 1)
            }

            // Get array length - inlined GEP (field 0 of %SeenArray) instead of C runtime call
            var isStringIterable = 0
            if iterType == "String" {
                isStringIterable = 1
                elementType = "Char"
            }
            var lenReg = ""
            if isStringIterable == 1 {
                lenReg = getNextReg()
                var arrStrReg = arrReg
                if arrReg == "0" {
                    arrStrReg = "zeroinitializer"
                }
                output.append("  " + lenReg + " = call i64 @seen_length(%SeenString " + arrStrReg + ")\n")
            }
            if isStringIterable == 0 {
                let lenPtrReg = getNextReg()
                lenReg = getNextReg()
                output.append("  " + lenPtrReg + " = getelementptr inbounds %SeenArray, ptr " + arrReg + ", i32 0, i32 0\n")
                output.append("  " + lenReg + " = load i64, ptr " + lenPtrReg + ", !tbaa !108, !range !188\n")
            }

            // Use pre-allocated entry-block alloca for index counter (enables mem2reg)
            let arrIdxName = "__forin_idx_" + loopVarName
            var idxReg = ""
            let arrIdxPreIdx = findPreAllocatedOccurrence(arrIdxName, 1)
            if arrIdxPreIdx >= 0 and arrIdxPreIdx < preAllocatedRegs.length() {
                idxReg = preAllocatedRegs[arrIdxPreIdx]
            }
            if idxReg == "" {
                idxReg = getNextReg()
                output.append("  " + idxReg + " = alloca i64, align 8\n")
            }
            storeVar(loopVarName, loopVarReg, loopVarType)
            output.append("  store i64 0, ptr " + idxReg + "\n")

            // Jump to condition
            output.append("  br label %" + condLabel + "\n")

            // Condition: index < length
            output.append(condLabel + ":\n")
            cseClear()
            let loadIdx = getNextReg()
            output.append("  " + loadIdx + " = load i64, ptr " + idxReg + ", align 8\n")
            let cmpReg = getNextReg()
            output.append("  " + cmpReg + " = icmp slt i64 " + loadIdx + ", " + lenReg + "\n")
            output.append("  br i1 " + cmpReg + ", label %" + bodyLabel + ", label %" + endLabel + ", !prof !196\n")

            // Body: get element, store in loop var, run body, increment
            output.append(bodyLabel + ":\n")
            cseClear()
            blockTerminated = false

            // Get element based on type — delegated to ir_control_flow.seen
            if isStringIterable == 1 {
                var arrStrReg2 = arrReg
                if arrReg == "0" {
                    arrStrReg2 = "zeroinitializer"
                }
                let charReg = getNextReg()
                output.append("  " + charReg + " = call i64 @seen_char_at(%SeenString " + arrStrReg2 + ", i64 " + loadIdx + ")\n")
                output.append("  store i64 " + charReg + ", ptr " + loopVarReg + ", align 8\n")
            }
            if isStringIterable == 0 {
                var isString = 0
                var isFloat = 0
                if elementType == "String" { isString = 1 }
                if elementType == "Float" { isFloat = 1 }
                emitForInElementFetchImpl(output, g_regBox, arrReg, loadIdx, loopVarReg, elementType, isString, isFloat)

                // Auto-prefetch: prefetch element i+8 for sequential array traversals
                emitForInPrefetchImpl(output, g_regBox, g_blockBox, arrReg, loadIdx, lenReg, elementType)
            }

            generateBlock(stmt.loopBody)
            let bodyTerminated = blockTerminated
            if not bodyTerminated {
                emitForInIncrementImpl(output, g_regBox, idxReg, condLabel, loopMetaIdStr)
            }
            } // end array-based else
        }

        // End block
        output.append(endLabel + ":\n")
        cseClear()
        blockTerminated = false

        // Restore outer loop context
        activeVarCount = savedForInVarCount
        currentLoopCondLabel = savedCondLabel
        currentLoopEndLabel = savedEndLabel
    }

    // Handle assignment expression (from parser)
    fun generateAssignmentExpr(expr: ParserExpressionNode) r: Void {
        let varName = expr.variableName
        let idx = findVar(varName)

        if idx < 0 {
            // Check if it's a global variable (module constant)
            let gvConstIdx = findModuleConstant(varName)
            if gvConstIdx >= 0 {
                let gvConstType = moduleConstantTypes[gvConstIdx]
                let gvSavedPending = pendingArrayLiteralType
                let gvValueReg = generateExpression(expr.operands[0])
                pendingArrayLiteralType = gvSavedPending
                output.append("  store " + gvConstType + " " + gvValueReg + ", ptr @" + varName + "\n")
                return
            }
            // Variable not found - check if 'this' exists and varName is a field
            let thisIdx = findVar("this")
            if thisIdx >= 0 {
                let thisReg = varRegs[thisIdx]
                let thisType = varTypes[thisIdx]

                // Check if this type has the field
                let structIdx = findStruct(thisType)
                if structIdx >= 0 {
                    let fieldIdx = getFieldInfo(thisType, varName)
                    if fieldIdx >= 0 {
                        // Generate field assignment to fieldName
                        let savedPendingType = pendingArrayLiteralType
                        let fieldSeenType = getSeenFieldType(thisType, varName)
                        if expr.operands[0].kind == "ArrayLiteral" and (fieldSeenType.startsWith("Array") or fieldSeenType.startsWith("List")) {
                            pendingArrayLiteralType = fieldSeenType
                        }
                        let valueReg = generateExpression(expr.operands[0])
                        pendingArrayLiteralType = savedPendingType

                        // Load 'this' pointer
                        let thisPtrReg = getNextReg()
                        output.append("  " + thisPtrReg + " = load ptr, ptr " + thisReg + "\n")

                        // Get struct layout and field type
                        let structLayout = structLayouts[structIdx]
                        let fieldType = getFieldType(thisType, varName)

                        // Generate GEP to field
                        let fieldPtrReg = getNextReg()
                        output.append("  " + fieldPtrReg + " = getelementptr inbounds " + structLayout + ", ptr " + thisPtrReg + ", i32 0, i32 " + fieldIdx.toString() + "\n")

                        // Store the value
                        output.append("  store " + fieldType + " " + valueReg + ", ptr " + fieldPtrReg + "\n")
                        return
                    }
                }
            }
            return
        }

        let savedPendingType = pendingArrayLiteralType
        let varType = varTypes[idx]
        if expr.operands[0].kind == "ArrayLiteral" and (varType.startsWith("Array") or varType.startsWith("List")) {
            pendingArrayLiteralType = varType
        }
        let valueReg = generateExpression(expr.operands[0])
        pendingArrayLiteralType = savedPendingType
        let varReg = varRegs[idx]
        let llvmType = mapType(varType)
        output.append("  store " + llvmType + " " + valueReg + ", ptr " + varReg + "\n")
    }

    // Generate IR for a variable assignment statement (x = expr).
    // Finds the variable's alloca register via findVar and emits a store.
    // Handles compound assignments (+=, -=, *=, /=, %=, &=, |=, ^=, <<=, >>=)
    // by loading the current value, performing the operation, and storing back.
    fun generateAssignment(stmt: StatementNode) r: Void {
        let varName = stmt.variableName
        let idx = findVar(varName)

        if idx < 0 {
            // Check if it's a global variable (module constant)
            let gvConstIdx2 = findModuleConstant(varName)
            if gvConstIdx2 >= 0 {
                let gvConstType2 = moduleConstantTypes[gvConstIdx2]
                let gvSavedPending2 = pendingArrayLiteralType
                let gvValueReg2 = generateExpression(stmt.initializer)
                pendingArrayLiteralType = gvSavedPending2
                output.append("  store " + gvConstType2 + " " + gvValueReg2 + ", ptr @" + varName + "\n")
                return
            }
            // Variable not found - check if 'this' exists and varName is a field
            let thisIdx = findVar("this")
            if thisIdx >= 0 {
                let thisReg = varRegs[thisIdx]
                let thisType = varTypes[thisIdx]

                // Check if this type has the field
                let structIdx = findStruct(thisType)
                if structIdx >= 0 {
                    let fieldIdx = getFieldInfo(thisType, varName)
                    if fieldIdx >= 0 {
                        // Generate field assignment to fieldName
                        let savedPendingType = pendingArrayLiteralType
                        let fieldSeenType = getSeenFieldType(thisType, varName)
                        if stmt.initializer.kind == "ArrayLiteral" and (fieldSeenType.startsWith("Array") or fieldSeenType.startsWith("List")) {
                            pendingArrayLiteralType = fieldSeenType
                        }
                        let valueReg = generateExpression(stmt.initializer)
                        pendingArrayLiteralType = savedPendingType

                        // Load 'this' pointer
                        let thisPtrReg = getNextReg()
                        output.append("  " + thisPtrReg + " = load ptr, ptr " + thisReg + "\n")

                        // Get struct layout and field type
                        let structLayout = structLayouts[structIdx]
                        let fieldType = getFieldType(thisType, varName)

                        // Generate GEP to field
                        let fieldPtrReg = getNextReg()
                        output.append("  " + fieldPtrReg + " = getelementptr inbounds " + structLayout + ", ptr " + thisPtrReg + ", i32 0, i32 " + fieldIdx.toString() + "\n")

                        // Store the value
                        output.append("  store " + fieldType + " " + valueReg + ", ptr " + fieldPtrReg + "\n")
                        return
                    }
                }
            }
            return
        }

        let savedPendingType = pendingArrayLiteralType
        let varType = varTypes[idx]
        if stmt.initializer.kind == "ArrayLiteral" and (varType.startsWith("Array") or varType.startsWith("List")) {
            pendingArrayLiteralType = varType
        }

        // Distinct type enforcement: check that RHS type matches exactly
        if g_distinctTypeNames != "" and g_distinctTypeNames.contains(varType + "|") {
            let rhsType = inferExpressionType(stmt.initializer)
            if rhsType != varType and rhsType != "" {
                output.append("  ; WARNING: distinct type mismatch — cannot assign " + rhsType + " to " + varType + "\n")
            }
        }

        let valueReg = generateExpression(stmt.initializer)
        pendingArrayLiteralType = savedPendingType
        let varReg = varRegs[idx]
        let llvmType = mapType(varType)
        output.append("  store " + llvmType + " " + valueReg + ", ptr " + varReg + "\n")

        // : Move enforcement — if RHS is a variable of a @move type, null the source
        if g_moveOnlyClasses != "" {
            if stmt.initializer.kind == "Variable" or stmt.initializer.kind == "VarExpr" {
                var rhsVarName = stmt.initializer.variableName
                if rhsVarName == "" {
                    rhsVarName = stmt.initializer.literalValue
                }
                if rhsVarName != "" {
                    let rhsIdx = findVar(rhsVarName)
                    if rhsIdx >= 0 {
                        let rhsType = varTypes[rhsIdx]
                        if g_moveOnlyClasses.contains(rhsType + "|") {
                            // Null the source register (move semantics)
                            let rhsSrcReg = varRegs[rhsIdx]
                            output.append("  store i64 0, ptr " + rhsSrcReg + " ; @move: nullify source\n")
                            // Track this variable as moved
                            g_movedVarNames = g_movedVarNames + rhsVarName + "|"
                            g_movedVarCount = g_movedVarCount + 1
                        }
                    }
                }
            }
        }

        // : @trivially_copyable — emit IR comment for trivial copy
        if g_triviallyCopyableClasses != "" {
            if g_triviallyCopyableClasses.contains(varType + "|") {
                output.append("  ; @trivially_copyable: bitwise copy of " + varType + "\n")
            }
        }
    }

    // Generate member assignment: a.b = value or a.b = value
    // Generate IR for a member assignment (obj.field = expr). Resolves the
    // receiver to a pointer, computes the GEP index for the field, generates
    // the value expression, and emits a store. For class-type receivers,
    // converts the i64 handle to ptr via inttoptr before GEP.
    fun generateMemberAssignment(expr: ParserExpressionNode) r: Void {
        // expr.operands[0] = lhs MemberAccess, expr.operands[1] = rhs value
        let memberAccess = expr.operands[0]
        let value = expr.operands[1]

        // Get the receiver and field name from MemberAccess
        // memberAccess.literalValue = receiver (e.g., "this" or variable name)
        // memberAccess.variableName = field name
        let receiverName = memberAccess.literalValue
        let fieldName = memberAccess.variableName
        output.append("; DEBUG generateMemberAssignment: receiverName=" + receiverName + " fieldName=" + fieldName + "\n")

        // Generate the value first
        let valueReg = generateExpression(value)

        // Resolve the receiver chain
        // If receiver is another MemberAccess (e.g., lastFunction.name), handle recursively
        if memberAccess.operands.length() > 0 and memberAccess.literalValue == "" {
            // Receiver is an expression (chained access like a.b where a is stored in operands[0])
            let receiverExpr = memberAccess.operands[0]
            let receiverReg = generateExpression(receiverExpr)

            // Infer receiver type to get struct layout
            let receiverType = inferExpressionType(receiverExpr)
            let structIdx = findStruct(receiverType)
            if structIdx >= 0 {
                let fieldIdx = getFieldInfo(receiverType, fieldName)
                if fieldIdx >= 0 {
                    let structLayout = structLayouts[structIdx]
                    // Note: getFieldType already returns LLVM type (it calls mapType internally)
                    let llvmFieldType = getFieldType(receiverType, fieldName)

                    // Ensure we have a pointer to the receiver struct
                    let receiverPtrReg = convertReceiverToPtr(receiverReg, receiverType)
                    if isDataType(receiverType) {
                        let tmpReg = getNextReg()
                        output.append("  " + tmpReg + " = alloca %" + receiverType + "\n")
                        output.append("  store %" + receiverType + " " + receiverReg + ", ptr " + tmpReg + "\n")
                        receiverPtrReg = tmpReg
                    }

                    // GEP to field + store via emitFieldStoreImpl
                    let fieldPtrReg = getNextReg()
                    output.append("  " + fieldPtrReg + " = getelementptr inbounds " + structLayout + ", ptr " + receiverPtrReg + ", i32 0, i32 " + fieldIdx.toString() + "\n")
                    emitFieldStoreImpl(output, g_regBox, valueReg, llvmFieldType, fieldPtrReg, 0, 0)
                    return
                }
            }
            return
        }

        // Handle chained receiver like "fn.returnType" with fieldName "typeName"
        if receiverName.contains(".") {
            // Split into base variable and remaining path (46 = '.')
            var dotIdx = 0
            var di = 0
            while di < receiverName.length() {
                if receiverName.byteAt(di) == 46 {
                    dotIdx = di
                    di = receiverName.length()
                }
                di = di + 1
            }
            if dotIdx > 0 {
                let baseVarName = receiverName.substring(0, dotIdx)
                let restPath = receiverName.substring(dotIdx + 1, receiverName.length())
                let baseIdx = findVar(baseVarName)
                if baseIdx >= 0 {
                    let baseReg = varRegs[baseIdx]
                    let baseType = varTypes[baseIdx]
                    var basePtrReg = ""
                    if isClassType(baseType) {
                        let loadReg = getNextReg()
                        output.append("  " + loadReg + " = load i64, ptr " + baseReg + "\n")
                        basePtrReg = getNextReg()
                        output.append("  " + basePtrReg + " = inttoptr i64 " + loadReg + " to ptr\n")
                    } else {
                        if isDataType(baseType) {
                            basePtrReg = baseReg
                        } else {
                            basePtrReg = getNextReg()
                            output.append("  " + basePtrReg + " = load ptr, ptr " + baseReg + "\n")
                        }
                    }

                    // Walk the restPath to find the intermediate type
                    var intermediateType = ""
                    if restPath.contains(".") {
                        var pathSegments = Array<String>()
                        var segStart = 0
                        var segIdx = 0
                        while segIdx <= restPath.length() {
                            if segIdx == restPath.length() or restPath.byteAt(segIdx) == 46 {
                                if segIdx > segStart {
                                    pathSegments.push(restPath.substring(segStart, segIdx))
                                }
                                segStart = segIdx + 1
                            }
                            segIdx = segIdx + 1
                        }
                        var currentType = baseType
                        var pi = 0
                        while pi < pathSegments.length() and currentType != "" {
                            let currField = pathSegments[pi]
                            currentType = getSeenFieldType(currentType, currField)
                            pi = pi + 1
                        }
                        intermediateType = currentType
                    }
                    if not restPath.contains(".") {
                        intermediateType = getSeenFieldType(baseType, restPath)
                    }

                    if intermediateType != "" {
                        var intermediatePtrReg = ""
                        if isClassType(intermediateType) {
                            let intermediateValReg = generateFieldAccess(basePtrReg, baseType, restPath)
                            let ptrConvReg = getNextReg()
                            output.append("  " + ptrConvReg + " = inttoptr i64 " + intermediateValReg + " to ptr\n")
                            intermediatePtrReg = ptrConvReg
                        } else {
                            // Handle chained paths like "function.returnType" by walking through each segment
                            if restPath.contains(".") {
                                var chainPtr = basePtrReg
                                var chainType = baseType
                                var chainSegStart = 0
                                var chainSegIdx = 0
                                while chainSegIdx <= restPath.length() {
                                    if chainSegIdx == restPath.length() or restPath.byteAt(chainSegIdx) == 46 {
                                        if chainSegIdx > chainSegStart {
                                            let chainField = restPath.substring(chainSegStart, chainSegIdx)
                                            let chainFieldType = getSeenFieldType(chainType, chainField)
                                            if isClassType(chainFieldType) {
                                                let loadedVal = generateFieldAccess(chainPtr, chainType, chainField)
                                                let convPtr = getNextReg()
                                                output.append("  " + convPtr + " = inttoptr i64 " + loadedVal + " to ptr\n")
                                                chainPtr = convPtr
                                            } else {
                                                if isDataType(chainFieldType) {
                                                    chainPtr = generateFieldAccessPtr(chainPtr, chainType, chainField)
                                                } else {
                                                    chainPtr = generateFieldAccessPtr(chainPtr, chainType, chainField)
                                                }
                                            }
                                            chainType = chainFieldType
                                        }
                                        chainSegStart = chainSegIdx + 1
                                    }
                                    chainSegIdx = chainSegIdx + 1
                                }
                                intermediatePtrReg = chainPtr
                            } else {
                                intermediatePtrReg = generateFieldAccessPtr(basePtrReg, baseType, restPath)
                            }
                        }

                        // Union types: store directly at offset 0 (no GEP)
                        if g_unionTypes != "" and g_unionTypes.contains(intermediateType + "|") {
                            let unionFieldType = getFieldType(intermediateType, fieldName)
                            var storeValueReg = valueReg
                            if unionFieldType == "%SeenString" and valueReg == "0" {
                                storeValueReg = "zeroinitializer"
                            }
                            output.append("  store " + unionFieldType + " " + storeValueReg + ", ptr " + intermediatePtrReg + " ; union field store\n")
                            return
                        }
                        let structIdx = findStruct(intermediateType)
                        if structIdx >= 0 {
                            let fieldIdx = getFieldInfo(intermediateType, fieldName)
                            if fieldIdx >= 0 {
                                let structLayout = structLayouts[structIdx]
                                let llvmFieldType = getFieldType(intermediateType, fieldName)
                                let fieldPtrReg = getNextReg()
                                output.append("  " + fieldPtrReg + " = getelementptr inbounds " + structLayout + ", ptr " + intermediatePtrReg + ", i32 0, i32 " + fieldIdx.toString() + "\n")
                                emitFieldStoreImpl(output, g_regBox, valueReg, llvmFieldType, fieldPtrReg, 0, 0)
                                return
                            }
                        }
                    }
                }
            }
        }

        // Simple case: receiver is a variable name like "this" or "someVar"
        let varIdx = findVar(receiverName)
        output.append("; DEBUG generateMemberAssignment: varIdx=" + varIdx.toString() + "\n")
        if varIdx >= 0 {
            let varReg = varRegs[varIdx]
            let varType = varTypes[varIdx]
            output.append("; DEBUG generateMemberAssignment: varType=" + varType + "\n")

            // Load the receiver - class types are stored as i64, data types are inline
            var receiverPtrReg = ""
            if isClassType(varType) {
                let loadReg = getNextReg()
                output.append("  " + loadReg + " = load i64, ptr " + varReg + "\n")
                receiverPtrReg = getNextReg()
                output.append("  " + receiverPtrReg + " = inttoptr i64 " + loadReg + " to ptr\n")
            } else {
                if isDataType(varType) {
                    // Data types are stored inline - use the alloca pointer directly
                    receiverPtrReg = varReg
                } else {
                    receiverPtrReg = getNextReg()
                    output.append("  " + receiverPtrReg + " = load ptr, ptr " + varReg + "\n")
                }
            }

            // Find struct and field
            // Union types: store directly at offset 0 (no GEP)
            if g_unionTypes != "" and g_unionTypes.contains(varType + "|") {
                let unionFieldType = getFieldType(varType, fieldName)
                var unionStoreVal = valueReg
                if unionFieldType == "%SeenString" and valueReg == "0" {
                    unionStoreVal = "zeroinitializer"
                }
                output.append("  store " + unionFieldType + " " + unionStoreVal + ", ptr " + receiverPtrReg + " ; union field store\n")
                return
            }
            let structIdx = findStruct(varType)
            output.append("; DEBUG generateMemberAssignment: structIdx=" + structIdx.toString() + " fieldName=" + fieldName + "\n")
            if structIdx >= 0 {
                let fieldIdx = getFieldInfo(varType, fieldName)
                if fieldIdx >= 0 {
                    let structLayout = structLayouts[structIdx]
                    // Note: getFieldType already returns LLVM type
                    let llvmFieldType = getFieldType(varType, fieldName)
                    let seenFieldType = getSeenFieldType(varType, fieldName)

                    // GEP to field
                    let fieldPtrReg = getNextReg()
                    output.append("  " + fieldPtrReg + " = getelementptr inbounds " + structLayout + ", ptr " + receiverPtrReg + ", i32 0, i32 " + fieldIdx.toString() + "\n")

                    // Bitfield write: read-modify-write with mask (must check before emitFieldStoreImpl)
                    if g_bitfieldCount > 0 and llvmFieldType == "i64" {
                        let bfWKey = varType + "." + fieldName
                        if g_bitfieldKeys.contains(bfWKey + "|") {
                            var bfWSearchPos = 0
                            var bfWIdx = 0
                            var bfWWidth = 0
                            while bfWSearchPos < g_bitfieldKeys.length() and bfWWidth == 0 {
                                var bfWNextPipe = g_bitfieldKeys.indexOf("|", bfWSearchPos)
                                if bfWNextPipe < 0 { bfWNextPipe = g_bitfieldKeys.length() }
                                let bfWEntry = g_bitfieldKeys.substring(bfWSearchPos, bfWNextPipe)
                                if bfWEntry == bfWKey {
                                    var bfWWSearchPos = 0
                                    var bfWWIdx = 0
                                    while bfWWSearchPos < g_bitfieldWidths.length() {
                                        var bfWWNextPipe = g_bitfieldWidths.indexOf("|", bfWWSearchPos)
                                        if bfWWNextPipe < 0 { bfWWNextPipe = g_bitfieldWidths.length() }
                                        if bfWWIdx == bfWIdx {
                                            let bfWWStr = g_bitfieldWidths.substring(bfWWSearchPos, bfWWNextPipe)
                                            bfWWidth = parseSimpleInt(bfWWStr)
                                            bfWWSearchPos = g_bitfieldWidths.length()
                                        }
                                        bfWWIdx = bfWWIdx + 1
                                        bfWWSearchPos = bfWWNextPipe + 1
                                    }
                                }
                                bfWIdx = bfWIdx + 1
                                bfWSearchPos = bfWNextPipe + 1
                            }
                            if bfWWidth > 0 and bfWWidth < 64 {
                                var bfWMask = 1
                                var bfWSh = 0
                                while bfWSh < bfWWidth {
                                    bfWMask = bfWMask * 2
                                    bfWSh = bfWSh + 1
                                }
                                bfWMask = bfWMask - 1
                                let bfWOldReg = getNextReg()
                                output.append("  " + bfWOldReg + " = load i64, ptr " + fieldPtrReg + "\n")
                                let bfWInvMask = -1 - bfWMask
                                let bfWClearReg = getNextReg()
                                output.append("  " + bfWClearReg + " = and i64 " + bfWOldReg + ", " + bfWInvMask.toString() + "\n")
                                let bfWNewMasked = getNextReg()
                                output.append("  " + bfWNewMasked + " = and i64 " + valueReg + ", " + bfWMask.toString() + "\n")
                                let bfWMerged = getNextReg()
                                output.append("  " + bfWMerged + " = or i64 " + bfWClearReg + ", " + bfWNewMasked + " ; bitfield write(" + bfWWidth.toString() + ")\n")
                                output.append("  store i64 " + bfWMerged + ", ptr " + fieldPtrReg + "\n")
                                return
                            }
                        }
                    }
                    // Store via emitFieldStoreImpl (handles data type load, nullable String, ptr coercion)
                    var valueIsStructLit = 0
                    if value.kind == "StructLiteral" { valueIsStructLit = 1 }
                    var isDataField = 0
                    if isDataType(seenFieldType) { isDataField = 1 }
                    emitFieldStoreImpl(output, g_regBox, valueReg, llvmFieldType, fieldPtrReg, valueIsStructLit, isDataField)
                    return
                }
            }
        }

        // Check if it's a field of 'this'
        let thisIdx = findVar("this")
        if thisIdx >= 0 {
            let thisReg = varRegs[thisIdx]
            let thisType = varTypes[thisIdx]

            // Check if receiverName is a field of 'this'
            let thisStructIdx = findStruct(thisType)
            if thisStructIdx >= 0 {
                let firstFieldIdx = getFieldInfo(thisType, receiverName)
                if firstFieldIdx >= 0 {
                    // Load 'this' pointer
                    let thisPtrReg = getNextReg()
                    output.append("  " + thisPtrReg + " = load ptr, ptr " + thisReg + "\n")

                    // Resolve the Seen type for the first field
                    let firstFieldType = getSeenFieldType(thisType, receiverName)
                    if firstFieldType == "" {
                        return
                    }

                    // Obtain a pointer to the nested struct
                    var nestedPtrReg = ""
                    if isClassType(firstFieldType) {
                        // Class fields are stored as i64 pointer-as-int
                        let firstFieldValReg = generateFieldAccess(thisPtrReg, thisType, receiverName)
                        let ptrConvReg = getNextReg()
                        output.append("  " + ptrConvReg + " = inttoptr i64 " + firstFieldValReg + " to ptr\n")
                        nestedPtrReg = ptrConvReg
                    } else {
                        // Inline data types (or non-class structs) are stored by value
                        nestedPtrReg = generateFieldAccessPtr(thisPtrReg, thisType, receiverName)
                    }

                    let nestedStructIdx = findStruct(firstFieldType)
                    if nestedStructIdx >= 0 {
                        let finalFieldIdx = getFieldInfo(firstFieldType, fieldName)
                        if finalFieldIdx >= 0 {
                            let nestedStructLayout = structLayouts[nestedStructIdx]
                            let llvmFinalFieldType = getFieldType(firstFieldType, fieldName)

                            // GEP to final field + store via emitFieldStoreImpl
                            let finalFieldPtrReg = getNextReg()
                            output.append("  " + finalFieldPtrReg + " = getelementptr inbounds " + nestedStructLayout + ", ptr " + nestedPtrReg + ", i32 0, i32 " + finalFieldIdx.toString() + "\n")
                            emitFieldStoreImpl(output, g_regBox, valueReg, llvmFinalFieldType, finalFieldPtrReg, 0, 0)
                            return
                        }
                    }
                }
            }
        }
    }

    // Generate index assignment: a[i] = value
    // Generate IR for an index assignment (arr[idx] = expr). Dispatches to
    // runtime helpers based on element type: seen_arr_set_str, seen_arr_set,
    // or type-specific variants. Also handles HashMap index assignment.
    fun generateIndexAssignment(expr: ParserExpressionNode) r: Void {
        // expr.operands[0] = lhs IndexAccess, expr.operands[1] = rhs value
        let indexAccess = expr.operands[0]
        let value = expr.operands[1]

        // indexAccess.operands[0] = array, indexAccess.operands[1] = index
        let array = indexAccess.operands[0]
        let index = indexAccess.operands[1]

        // Generate the array, index, and value
        let arrayReg = generateExpression(array)
        let indexReg = generateExpression(index)
        let valueReg = generateExpression(value)

        // : Bounds checking on array assignment
        if g_boundsCheckEnabled == 1 {
            let bcaFailLabel = "bounds_fail_" + g_boundsCheckLabelCount.toString()
            let bcaOkLabel = "bounds_ok_" + g_boundsCheckLabelCount.toString()
            g_boundsCheckLabelCount = g_boundsCheckLabelCount + 1
            let bcaLenPtr = getNextReg()
            output.append("  " + bcaLenPtr + " = getelementptr inbounds %SeenArray, ptr " + arrayReg + ", i32 0, i32 0\n")
            let bcaLen = getNextReg()
            output.append("  " + bcaLen + " = load i64, ptr " + bcaLenPtr + "\n")
            let bcaOob = getNextReg()
            output.append("  " + bcaOob + " = icmp uge i64 " + indexReg + ", " + bcaLen + "\n")
            output.append("  br i1 " + bcaOob + ", label %" + bcaFailLabel + ", label %" + bcaOkLabel + "\n")
            output.append(bcaFailLabel + ":\n")
            output.append("  call void @seen_bounds_check(i64 " + indexReg + ", i64 " + bcaLen + ")\n")
            output.append("  unreachable\n")
            output.append(bcaOkLabel + ":\n")
            cseClear()
        }

        // Infer the array element type
        let arrayType = inferExpressionType(array)
        var elementType = "ptr"
        if arrayType.startsWith("Array<") {
            elementType = arrayType.substring(6, arrayType.length() - 1)
        }
        let llvmElementType = mapType(elementType)

        // Inline array writes for primitive types: direct GEP+store to data pointer (field 3)
        // Eliminates function call overhead, enables vectorization and loop optimizations
        if elementType == "Int" or elementType == "Char" {
            let dataPtrPtrReg = getNextReg()
            output.append("  " + dataPtrPtrReg + " = getelementptr inbounds %SeenArray, ptr " + arrayReg + ", i32 0, i32 3\n")
            let dataPtrReg = getNextReg()
            output.append("  " + dataPtrReg + " = load ptr, ptr " + dataPtrPtrReg + ", !tbaa !104\n")
            let elemPtrReg = getNextReg()
            output.append("  " + elemPtrReg + " = getelementptr inbounds nuw i64, ptr " + dataPtrReg + ", i64 " + indexReg + "\n")
            output.append("  store i64 " + valueReg + ", ptr " + elemPtrReg + ", align 8, !tbaa !105\n")
        } else if elementType == "Float" {
            let dataPtrPtrReg = getNextReg()
            output.append("  " + dataPtrPtrReg + " = getelementptr inbounds %SeenArray, ptr " + arrayReg + ", i32 0, i32 3\n")
            let dataPtrReg = getNextReg()
            output.append("  " + dataPtrReg + " = load ptr, ptr " + dataPtrPtrReg + ", !tbaa !104\n")
            let elemPtrReg = getNextReg()
            output.append("  " + elemPtrReg + " = getelementptr inbounds nuw double, ptr " + dataPtrReg + ", i64 " + indexReg + "\n")
            output.append("  store double " + valueReg + ", ptr " + elemPtrReg + ", align 8, !tbaa !106\n")
        } else {
            // For non-primitive types, need to pass pointer to element value
            let valueIsStructLiteral = value.kind == "StructLiteral"
            var valuePtrReg = ""
            if isClassType(elementType) {
                let tmpReg = getNextReg()
                output.append("  " + tmpReg + " = alloca i64\n")
                output.append("  store i64 " + valueReg + ", ptr " + tmpReg + "\n")
                valuePtrReg = tmpReg
            } else if isDataType(elementType) {
                if valueIsStructLiteral {
                    valuePtrReg = valueReg
                } else {
                    let tmpReg = getNextReg()
                    output.append("  " + tmpReg + " = alloca %" + elementType + "\n")
                    output.append("  store %" + elementType + " " + valueReg + ", ptr " + tmpReg + "\n")
                    valuePtrReg = tmpReg
                }
            } else if llvmElementType == "ptr" {
                let tmpReg = getNextReg()
                var storedValue = valueReg
                if storedValue == "0" {
                    storedValue = "null"
                }
                output.append("  " + tmpReg + " = alloca ptr\n")
                output.append("  store ptr " + storedValue + ", ptr " + tmpReg + "\n")
                valuePtrReg = tmpReg
            } else {
                let tmpReg = getNextReg()
                output.append("  " + tmpReg + " = alloca " + llvmElementType + "\n")
                output.append("  store " + llvmElementType + " " + valueReg + ", ptr " + tmpReg + "\n")
                valuePtrReg = tmpReg
            }
            output.append("  call void @Array_set(ptr " + arrayReg + ", i64 " + indexReg + ", ptr " + valuePtrReg + ")\n")
        }
    }

    // Main expression codegen dispatcher. Returns the SSA register (or
    // immediate constant string) holding the expression's value.
    // Dispatches on expr.kind to specialized generators: Literal, Variable,
    // Binary, Call, MethodCall, Unary, Await, MemberAccess, IndexAccess,
    // StructLiteral, ArrayLiteral, StringInterpolation, Elvis/NullCoalesce,
    // SafeNavigation, WhenExpression, IfExpression, Cast, Closure, Lambda,
    // EnumVariant constructors, Result ? operator, etc.
    fun generateExpression(expr: ParserExpressionNode) r: String {
        if expr.kind == "Literal" {
            return generateLiteral(expr)
        }
        if expr.kind == "Variable" or expr.kind == "VarExpr" {
            return generateVariable(expr)
        }
        if expr.kind == "Binary" {
            return generateBinary(expr)
        }
        if expr.kind == "Call" {
            return generateCall(expr)
        }
        if expr.kind == "MethodCall" {
            return generateMethodCall(expr)
        }
        if expr.kind == "Unary" {
            return generateUnary(expr)
        }
        if expr.kind == "Await" {
            return generateAwaitExpression(expr)
        }
        if expr.kind == "MemberAccess" {
            return generateMemberAccess(expr)
        }
        if expr.kind == "IndexAccess" {
            return generateIndexAccess(expr)
        }
        if expr.kind == "StructLiteral" {
            return generateStructLiteral(expr)
        }
        if expr.kind == "ArrayLiteral" {
            return generateArrayLiteral(expr)
        }
        if expr.kind == "StringInterpolation" {
            return generateStringInterpolation(expr)
        }
        if expr.kind == "Elvis" {
            return generateElvis(expr)
        }
        if expr.kind == "NullCoalesce" {
            return generateElvis(expr)
        }
        if expr.kind == "SafeNavigation" {
            return generateSafeNavigation(expr)
        }
        if expr.kind == "WhenExpression" {
            return generateWhenExpression(expr)
        }
        if expr.kind == "IfExpression" {
            return generateIfExpression(expr)
        }
        if expr.kind == "Cast" {
            let cSrcReg = generateExpression(expr.operands[0])
            let cSrcType = inferExpressionType(expr.operands[0])
            let cTgtType = expr.literalValue
            return emitCastExprImpl(output, g_regBox, cSrcReg, cSrcType, cTgtType)
        }
        // 'is' type test: check enum tag or static type
        if expr.kind == "IsExpression" {
            let isSubjectReg = generateExpression(expr.operands[0])
            let isTypeName = expr.literalValue
            // For enum variants: load tag from ptr and compare
            let isTagIdx = lookupEnumVariantTag(isTypeName)
            if isTagIdx >= 0 {
                let isTagLoad = getNextReg()
                output.append("  " + isTagLoad + " = load i64, ptr " + isSubjectReg + "\n")
                let isCmpReg = getNextReg()
                output.append("  " + isCmpReg + " = icmp eq i64 " + isTagLoad + ", " + isTagIdx.toString() + "\n")
                return isCmpReg
            }
            // For class types: static type comparison — always true if types match at compile time
            let isSubjectType = inferExpressionType(expr.operands[0])
            if isSubjectType == isTypeName {
                return "1"
            }
            return "0"
        }
        // Closure literal: |params| body → generate anonymous function, return fn ptr as i64
        if expr.kind == "Closure" {
            return generateClosure(expr)
        }
        // '?' error propagation: inline Result check + early return on Err
        // Runtime layout: Ok(v) returns v as-is (non-zero i64), Err(msg) returns 0 (NULL)
        // So: check if value == 0, if so return 0 (propagate), else value IS the Ok payload
        if expr.kind == "TryPropagate" {
            let tryInnerReg = generateExpression(expr.operands[0])
            let tryInnerType = inferExpressionType(expr.operands[0])
            // Only apply Result semantics if type is Result
            if tryInnerType.startsWith("Result") {
                let tryIsOkReg = getNextReg()
                output.append("  " + tryIsOkReg + " = icmp ne i64 " + tryInnerReg + ", 0\n")

                let tryLabelSuffix = g_regBox[0].toString()
                let tryOkLabel = "try.ok." + tryLabelSuffix
                let tryErrLabel = "try.err." + tryLabelSuffix

                output.append("  br i1 " + tryIsOkReg + ", label %" + tryOkLabel + ", label %" + tryErrLabel + "\n")

                // Err path: return 0 (propagate error upward)
                output.append(tryErrLabel + ":\n")
                let tryRetType = mapType(currentFunctionReturnType)
                if tryRetType == "void" {
                    output.append("  ret void\n")
                } else {
                    output.append("  ret " + tryRetType + " 0\n")
                }

                // Ok path: the value IS the Ok payload (Ok just passes through)
                output.append(tryOkLabel + ":\n")
                return tryInnerReg
            }
            // Non-Result type: pass through unchanged
            return tryInnerReg
        }
        return "0"
    }

    // Generate IR for an if-expression (if cond { a } else { b } used as a
    // value). Emits then/else blocks and a phi node to merge the result.
    // Supports multi-expression blocks separated by semicolons, where side
    // effects execute before the final expression provides the block value.
    fun generateIfExpression(expr: ParserExpressionNode) r: String {
        // if-as-expression: if cond { thenExpr } else { elseExpr }
        // Generates SSA with phi node
        let condExpr = expr.operands[0]
        let thenExpr = expr.operands[1]
        let elseExpr = expr.operands[2]

        // Generate condition
        let condReg = generateExpression(condExpr)
        // Ensure condition is i1 — if condExpr is a comparison it already returns i1,
        // otherwise we need icmp ne i64 to convert integer/ptr to bool
        var condBool = condReg
        let condKind = condExpr.kind
        var condIsComparison = false
        if condKind == "Binary" {
            let op = condExpr.operator
            if op == "<" or op == ">" or op == "<=" or op == ">=" or op == "==" or op == "!=" {
                condIsComparison = true
            }
            if op == "and" or op == "or" {
                condIsComparison = true
            }
        }
        if condKind == "Not" {
            condIsComparison = true
        }
        if not condIsComparison {
            condBool = getNextReg()
            output.append("  " + condBool + " = icmp ne i64 " + condReg + ", 0\n")
        }

        let labelSuffix = g_regBox[0].toString()
        let thenLabel = "if.expr.then." + labelSuffix
        let elseLabel = "if.expr.else." + labelSuffix
        let mergeLabel = "if.expr.merge." + labelSuffix

        output.append("  br i1 " + condBool + ", label %" + thenLabel + ", label %" + elseLabel + "\n")

        // Generate then-branch side-effect expressions (before the value expression)
        output.append(thenLabel + ":\n")
        var ifSideIdx = 0
        while ifSideIdx < expr.arguments.length() {
            let sideExpr = expr.arguments[ifSideIdx]
            if sideExpr.kind == "Sentinel" {
                ifSideIdx = ifSideIdx + 1
                break
            }
            generateExpression(sideExpr)
            ifSideIdx = ifSideIdx + 1
        }
        let thenReg = generateExpression(thenExpr)
        // Capture current block for phi (may differ from thenLabel if side-effects added blocks)
        let thenPhiLabel = "if.expr.then.end." + g_regBox[0].toString()
        output.append("  br label %" + thenPhiLabel + "\n")
        output.append(thenPhiLabel + ":\n")
        output.append("  br label %" + mergeLabel + "\n")

        // Generate else-branch side-effect expressions
        output.append(elseLabel + ":\n")
        while ifSideIdx < expr.arguments.length() {
            generateExpression(expr.arguments[ifSideIdx])
            ifSideIdx = ifSideIdx + 1
        }
        let elseReg = generateExpression(elseExpr)
        let elsePhiLabel = "if.expr.else.end." + g_regBox[0].toString()
        output.append("  br label %" + elsePhiLabel + "\n")
        output.append(elsePhiLabel + ":\n")
        output.append("  br label %" + mergeLabel + "\n")

        // Merge with phi
        output.append(mergeLabel + ":\n")
        let resultType = inferExpressionType(thenExpr)
        let irType = mapType(resultType)
        let phiReg = getNextReg()
        output.append("  " + phiReg + " = phi " + irType + " [ " + thenReg + ", %" + thenPhiLabel + " ], [ " + elseReg + ", %" + elsePhiLabel + " ]\n")
        return phiReg
    }

    // Generate IR for a closure expression (|x| expr or |x, y| { ... }).
    // No-capture MVP: emits an anonymous `define` function, converts its
    // function pointer to i64 via ptrtoint, and returns the i64 handle.
    // Callers use inttoptr to convert back to a function pointer for indirect
    // calls. Closure definitions are accumulated in g_closureDefs and emitted
    // after all regular functions (to avoid forward-reference issues).
    fun generateClosure(expr: ParserExpressionNode) r: String {
        let closureId = g_closureCount
        g_closureCount = g_closureCount + 1
        let closureName = "__seen_closure_" + closureId.toString()

        // Build parameter list: all params are i64
        var paramList = ""
        var paramIdx = 0
        while paramIdx < expr.arguments.length() {
            if paramIdx > 0 { paramList = paramList + ", " }
            paramList = paramList + "i64 %__cp" + paramIdx.toString()
            paramIdx = paramIdx + 1
        }

        // Save codegen state
        let clSavedOutput = output
        let clSavedVarNames = varNames
        let clSavedVarRegs = varRegs
        let clSavedVarTypes = varTypes
        let clSavedPreAllocatedVars = preAllocatedVars
        let clSavedPreAllocatedTypes = preAllocatedTypes
        let clSavedPreAllocatedRegs = preAllocatedRegs
        let clSavedDeclOrdinalNames = declOrdinalNames
        let clSavedDeclOrdinalCounts = declOrdinalCounts
        let clSavedActiveVarCount = activeVarCount
        let clSavedNextReg = g_regBox[0]
        let clSavedBlockTerminated = blockTerminated
        let clSavedReturnType = currentFunctionReturnType

        // Generate closure function into a separate buffer
        output = StringBuilder.new()
        varNames = Array<String>()
        varRegs = Array<String>()
        varTypes = Array<String>()
        preAllocatedVars = Array<String>()
        preAllocatedTypes = Array<String>()
        preAllocatedRegs = Array<String>()
        declOrdinalNames = Array<String>()
        declOrdinalCounts = Array<Int>()
        activeVarCount = 0
        g_regBox[0] = 1
        blockTerminated = false
        currentFunctionReturnType = "Int"

        output.append("define i64 @" + quoteIdentIfNeeded(closureName) + "(" + paramList + ") {\n")
        output.append("entry:\n")

        // Bind params as local variables
        paramIdx = 0
        while paramIdx < expr.arguments.length() {
            let cpName = expr.arguments[paramIdx].literalValue
            let cpReg = "%__cp" + paramIdx.toString()
            let cpLocal = getNextReg()
            output.append("  " + cpLocal + " = alloca i64\n")
            output.append("  store i64 " + cpReg + ", ptr " + cpLocal + "\n")
            storeVar(cpName, cpLocal, "Int")
            paramIdx = paramIdx + 1
        }

        // Generate body expression
        let clBodyReg = generateExpression(expr.operands[0])
        if not blockTerminated {
            output.append("  ret i64 " + clBodyReg + "\n")
        }
        output.append("}\n\n")

        let closureDef = output.toString()
        g_closureDefs = g_closureDefs + closureDef

        // Restore codegen state
        output = clSavedOutput
        varNames = clSavedVarNames
        varRegs = clSavedVarRegs
        varTypes = clSavedVarTypes
        preAllocatedVars = clSavedPreAllocatedVars
        preAllocatedTypes = clSavedPreAllocatedTypes
        preAllocatedRegs = clSavedPreAllocatedRegs
        declOrdinalNames = clSavedDeclOrdinalNames
        declOrdinalCounts = clSavedDeclOrdinalCounts
        activeVarCount = clSavedActiveVarCount
        g_regBox[0] = clSavedNextReg
        blockTerminated = clSavedBlockTerminated
        currentFunctionReturnType = clSavedReturnType

        // Return function pointer as i64
        let clResultReg = getNextReg()
        output.append("  " + clResultReg + " = ptrtoint ptr @" + closureName + " to i64\n")
        return clResultReg
    }

    // Generate IR for an array literal [a, b, c]. Creates the array via
    // runtime helpers (seen_arr_new_str/int/float) to ensure element_size
    // is set correctly, then pushes each element. The element type is
    // resolved from pendingArrayLiteralType (set by the enclosing let/var
    // statement) or inferred from the first element.
    fun generateArrayLiteral(expr: ParserExpressionNode) r: String {
        let savedPendingType = pendingArrayLiteralType

        // Resolve element type from expected array type or first element
        var elementType = ""
        if pendingArrayLiteralType != "" {
            elementType = extractArrayLiteralElementType(pendingArrayLiteralType)
        }
        if elementType == "" and expr.arguments.length() > 0 {
            let firstExpr = expr.arguments[0]
            if firstExpr.kind == "StructLiteral" and firstExpr.literalType != "" {
                elementType = firstExpr.literalType
            } else {
                elementType = inferExpressionType(firstExpr)
            }
        }

        // Create array using runtime helpers so element_size stays consistent
        let arrReg = getNextReg()
        if elementType == "String" {
            output.append("  " + arrReg + " = call ptr @seen_arr_new_str_ptr()\n")
        } else if isDataType(elementType) {
            let elementSize = getDataTypeSize(elementType)
            output.append("  " + arrReg + " = call ptr @seen_arr_new_with_size_ptr(i64 " + elementSize.toString() + ")\n")
        } else {
            output.append("  " + arrReg + " = call ptr @seen_arr_new_ptr_ptr()\n")
        }

        // Populate elements
        var elemIdx = 0
        while elemIdx < expr.arguments.length() {
            let elemExpr = expr.arguments[elemIdx]
            let savedElemPending = pendingArrayLiteralType
            pendingArrayLiteralType = ""
            if elemExpr.kind == "ArrayLiteral" and (elementType.startsWith("Array") or elementType.startsWith("List")) {
                pendingArrayLiteralType = elementType
            }
            let argReg = generateExpression(elemExpr)
            pendingArrayLiteralType = savedElemPending

            var argType = elementType
            if argType == "" {
                if elemExpr.kind == "StructLiteral" and elemExpr.literalType != "" {
                    argType = elemExpr.literalType
                } else {
                    argType = inferExpressionType(elemExpr)
                }
            }
            let argIsStructLiteral = elemExpr.kind == "StructLiteral"

            if argType == "String" {
                output.append("  call void @seen_arr_push_str(ptr " + arrReg + ", %SeenString " + argReg + ")\n")
            } else if argType == "Int" {
                output.append("  call void @seen_arr_push_i64(ptr " + arrReg + ", i64 " + argReg + ")\n")
            } else {
                var ptrArgReg = argReg
                if ptrArgReg == "0" {
                    ptrArgReg = "null"
                }
                if isClassType(argType) {
                    let tmpClassReg = getNextReg()
                    output.append("  " + tmpClassReg + " = alloca i64\n")
                    output.append("  store i64 " + argReg + ", ptr " + tmpClassReg + "\n")
                    ptrArgReg = tmpClassReg
                }
                if isDataType(argType) and not argIsStructLiteral {
                    let tmpDataReg = getNextReg()
                    output.append("  " + tmpDataReg + " = alloca %" + argType + "\n")
                    output.append("  store %" + argType + " " + argReg + ", ptr " + tmpDataReg + "\n")
                    ptrArgReg = tmpDataReg
                }
                let pushReg = getNextReg()
                output.append("  " + pushReg + " = call i64 @Array_push(ptr " + arrReg + ", ptr " + ptrArgReg + ")\n")
            }
            elemIdx = elemIdx + 1
        }

        pendingArrayLiteralType = savedPendingType
        return arrReg
    }

    // Generate IR for index access (arr[idx]). Dispatches to runtime helpers
    // based on element type: seen_arr_get_str for String arrays, seen_arr_get
    // for Int arrays (with bitcast i64->double for Float arrays). Supports
    // bounds checking when g_boundsCheckEnabled is set. Also handles HashMap
    // index access (hash_get_*) and String character access (seen_str_char_at).
    fun generateIndexAccess(expr: ParserExpressionNode) r: String {
        // operands[0] = array expression
        // operands[1] = index expression
        // Pointer index access: ptr[i] → load from (ptr + i*8)
        let idxBaseType = inferExpressionType(expr.operands[0])
        if idxBaseType.startsWith("*") {
            let piaBaseReg = generateExpression(expr.operands[0])
            let piaIdxReg = generateExpression(expr.operands[1])
            // Compute byte offset: index * 8 (i64 element size)
            let piaMulReg = getNextReg()
            output.append("  " + piaMulReg + " = mul i64 " + piaIdxReg + ", 8\n")
            let piaOffsetReg = getNextReg()
            output.append("  " + piaOffsetReg + " = call i64 @seen_ptr_add(i64 " + piaBaseReg + ", i64 " + piaMulReg + ", i64 1)\n")
            let piaPtrReg = getNextReg()
            output.append("  " + piaPtrReg + " = inttoptr i64 " + piaOffsetReg + " to ptr\n")
            let piaResultReg = getNextReg()
            output.append("  " + piaResultReg + " = load i64, ptr " + piaPtrReg + " ; ptr[i] access\n")
            return piaResultReg
        }
        // Operator overloading: check for operator_index method on non-array types
        if not idxBaseType.startsWith("Array<") and not idxBaseType.startsWith("List<") and not idxBaseType.startsWith("Vec<") and idxBaseType != "String" {
            let idxOpFunc = idxBaseType + "_operator_index"
            let idxOpRet = getFunctionReturnType(idxOpFunc)
            if idxOpRet != "" {
                let idxBaseReg = generateExpression(expr.operands[0])
                let idxIdxReg = generateExpression(expr.operands[1])
                let idxThisReg = getNextReg()
                output.append("  " + idxThisReg + " = inttoptr i64 " + idxBaseReg + " to ptr\n")
                let idxRetLlvm = mapType(idxOpRet)
                let idxResReg = getNextReg()
                output.append("  " + idxResReg + " = call " + idxRetLlvm + " @" + quoteIdentIfNeeded(idxOpFunc) + "(ptr " + idxThisReg + ", i64 " + idxIdxReg + ")\n")
                return idxResReg
            }
        }

        output.append("; DEBUG generateIndexAccess: operands[0].kind=" + expr.operands[0].kind + " variableName=" + expr.operands[0].variableName + " literalValue=" + expr.operands[0].literalValue + "\n")
        var arrayReg = generateExpression(expr.operands[0])
        output.append("; DEBUG arrayReg=" + arrayReg + "\n")
        let indexReg = generateExpression(expr.operands[1])

        // Workaround: if arrayReg is 0 and the variable name is 'statements',
        // try to find a BlockNode variable with that field
        if arrayReg == "0" and expr.operands[0].variableName == "statements" {
            output.append("; DEBUG trying to find BlockNode for statements\n")
            // Look for any local variable of type BlockNode
            var blockIdx = 0
            while blockIdx < varTypes.length() {
                if varTypes[blockIdx] == "BlockNode" {
                    let blockVarReg = varRegs[blockIdx]
                    // Load the block pointer
                    let blockPtrReg = getNextReg()
                    output.append("  " + blockPtrReg + " = load ptr, ptr " + blockVarReg + "\n")
                    // Access the statements field
                    arrayReg = generateFieldAccess(blockPtrReg, "BlockNode", "statements")
                    output.append("; DEBUG found BlockNode, arrayReg=" + arrayReg + "\n")
                    blockIdx = varTypes.length()  // break
                }
                blockIdx = blockIdx + 1
            }
        }

        // : Bounds checking on array access
        if g_boundsCheckEnabled == 1 {
            let bcFailLabel = "bounds_fail_" + g_boundsCheckLabelCount.toString()
            let bcOkLabel = "bounds_ok_" + g_boundsCheckLabelCount.toString()
            g_boundsCheckLabelCount = g_boundsCheckLabelCount + 1
            let lenPtrReg = getNextReg()
            output.append("  " + lenPtrReg + " = getelementptr inbounds %SeenArray, ptr " + arrayReg + ", i32 0, i32 0\n")
            let lenReg = getNextReg()
            output.append("  " + lenReg + " = load i64, ptr " + lenPtrReg + "\n")
            let oobReg = getNextReg()
            output.append("  " + oobReg + " = icmp uge i64 " + indexReg + ", " + lenReg + "\n")
            output.append("  br i1 " + oobReg + ", label %" + bcFailLabel + ", label %" + bcOkLabel + "\n")
            output.append(bcFailLabel + ":\n")
            output.append("  call void @seen_bounds_check(i64 " + indexReg + ", i64 " + lenReg + ")\n")
            output.append("  unreachable\n")
            output.append(bcOkLabel + ":\n")
            cseClear()
        }

        // Infer the element type from the array type
        let arrayType = inferExpressionType(expr.operands[0])
        output.append("; DEBUG arrayType=" + arrayType + "\n")

        // Both List<T> and Array<T> are ptr to SeenArray on heap - use pointer-based accessors
        // to avoid struct-by-value ABI issues between LLVM and C

        var resultReg = ""
        var handledArr = false

        // Use typed array get functions based on element type (pointer-based variants)
        if arrayType == "Array<String>" {
            resultReg = getNextReg()
            output.append("  " + resultReg + " = call %SeenString @seen_arr_get_str_ptr(ptr " + arrayReg + ", i64 " + indexReg + ")\n")
            handledArr = true
        }
        if not handledArr and arrayType == "Array<FrontendDiagnostic>" {
            let ptrResultReg = getNextReg()
            output.append("  " + ptrResultReg + " = call ptr @seen_arr_get_diag_ptr(ptr " + arrayReg + ", i64 " + indexReg + ")\n")
            // FrontendDiagnostic is a class type stored as i64, convert ptr to i64
            resultReg = getNextReg()
            output.append("  " + resultReg + " = ptrtoint ptr " + ptrResultReg + " to i64\n")
            handledArr = true
        }
        if not handledArr and arrayType == "Array<Int>" {
            // Inline array read: direct GEP to data pointer (field 3) then index
            // Eliminates function call overhead, enables vectorization and unrolling
            let dataPtrPtrReg = getNextReg()
            output.append("  " + dataPtrPtrReg + " = getelementptr inbounds %SeenArray, ptr " + arrayReg + ", i32 0, i32 3\n")
            let dataPtrReg = getNextReg()
            output.append("  " + dataPtrReg + " = load ptr, ptr " + dataPtrPtrReg + ", !tbaa !104\n")
            let elemPtrReg = getNextReg()
            output.append("  " + elemPtrReg + " = getelementptr inbounds nuw i64, ptr " + dataPtrReg + ", i64 " + indexReg + "\n")
            resultReg = getNextReg()
            output.append("  " + resultReg + " = load i64, ptr " + elemPtrReg + ", align 8, !tbaa !105\n")
            handledArr = true
        }
        if not handledArr and arrayType == "Array<Float>" {
            // Inline array read: direct GEP to data pointer (field 3) then index
            let dataPtrPtrReg = getNextReg()
            output.append("  " + dataPtrPtrReg + " = getelementptr inbounds %SeenArray, ptr " + arrayReg + ", i32 0, i32 3\n")
            let dataPtrReg = getNextReg()
            output.append("  " + dataPtrReg + " = load ptr, ptr " + dataPtrPtrReg + ", !tbaa !104\n")
            let elemPtrReg = getNextReg()
            output.append("  " + elemPtrReg + " = getelementptr inbounds nuw double, ptr " + dataPtrReg + ", i64 " + indexReg + "\n")
            resultReg = getNextReg()
            output.append("  " + resultReg + " = load double, ptr " + elemPtrReg + ", align 8, !tbaa !106\n")
            handledArr = true
        }
        if not handledArr and arrayType == "Array<ProgramNode>" {
            // ProgramNode is a class type, so convert ptr to i64
            let ptrResultReg = getNextReg()
            output.append("  " + ptrResultReg + " = call ptr @seen_arr_get_ptr_ptr(ptr " + arrayReg + ", i64 " + indexReg + ")\n")
            resultReg = getNextReg()
            output.append("  " + resultReg + " = ptrtoint ptr " + ptrResultReg + " to i64\n")
            handledArr = true
        }
        if not handledArr {
            // Extract element type from arrayType (e.g., "Array<TypeError>" -> "TypeError")
            var elementType = ""
            if arrayType.startsWith("Array<") and arrayType.endsWith(">") {
                elementType = arrayType.substring(6, arrayType.length() - 1)
            }

            // Choose the right getter based on element type (pointer-based variants)
            let ptrResultReg = getNextReg()
            if isDataType(elementType) {
                // Data types are stored inline - use seen_arr_get_element_ptr which uses element_size
                output.append("  " + ptrResultReg + " = call ptr @seen_arr_get_element_ptr(ptr " + arrayReg + ", i64 " + indexReg + ")\n")
                // Load the inline struct value
                resultReg = getNextReg()
                output.append("  " + resultReg + " = load %" + elementType + ", ptr " + ptrResultReg + "\n")
            } else if isClassType(elementType) {
                // Class types are stored as pointers - inline GEP for ptr-sized elements
                // Note: ptrResultReg already allocated above, but we can't use it out-of-order.
                // Instead, emit a dummy instruction and use new sequential registers.
                output.append("  " + ptrResultReg + " = getelementptr inbounds %SeenArray, ptr " + arrayReg + ", i32 0, i32 3\n")
                let clsDataPtr = getNextReg()
                output.append("  " + clsDataPtr + " = load ptr, ptr " + ptrResultReg + ", !tbaa !104\n")
                let clsElemPtr = getNextReg()
                output.append("  " + clsElemPtr + " = getelementptr inbounds ptr, ptr " + clsDataPtr + ", i64 " + indexReg + "\n")
                let clsLoadReg = getNextReg()
                output.append("  " + clsLoadReg + " = load ptr, ptr " + clsElemPtr + "\n")
                // Convert ptr to i64 for class types
                resultReg = getNextReg()
                output.append("  " + resultReg + " = ptrtoint ptr " + clsLoadReg + " to i64\n")
            } else {
                // Default: use element_ptr - SAFER because it works with any element_size
                // seen_arr_get_element_ptr uses the stored element_size for correct offset calculation
                output.append("  " + ptrResultReg + " = call ptr @seen_arr_get_element_ptr(ptr " + arrayReg + ", i64 " + indexReg + ")\n")
                resultReg = ptrResultReg
            }
        }

        return resultReg
    }

    // Generate IR for member access (expr.field). Handles:
    //   - Array/String .length() — inline load from SeenArray.len field
    //   - Enum variant field access — load from heap offset (tag + fieldIdx*8)
    //   - Class field access — inttoptr receiver i64->ptr, then GEP + load
    //   - Data type field access — direct GEP on pointer
    //   - Chained access (a.b.c) — recursive resolution via generateFieldAccess
    fun generateMemberAccess(expr: ParserExpressionNode) r: String {
        // literalValue = receiver variable name (or chained path)
        // variableName = field/member name
        let receiverName = expr.literalValue
        let fieldName = expr.variableName

        if expr.operands.length() == 0 and not receiverName.contains("[") {
            var shouldRebuildReceiver = false
            if receiverName.contains("()") {
                shouldRebuildReceiver = true
            }
            if not shouldRebuildReceiver and receiverName.contains(".") {
                let receiverSegments = splitChainedPath(receiverName)
                if receiverSegments.length() > 0 {
                    if findVarType(receiverSegments[0]) != "" {
                        shouldRebuildReceiver = true
                    }
                }
            }
            if shouldRebuildReceiver {
                let rebuiltReceiverExpr = buildChainedPathExpr(receiverName)
                if rebuiltReceiverExpr.kind != "None" {
                    let rebuiltExpr = ParserExpressionNode.new()
                    rebuiltExpr.kind = "MemberAccess"
                    rebuiltExpr.variableName = fieldName
                    rebuiltExpr.operands.push(rebuiltReceiverExpr)
                    return generateMemberAccess(rebuiltExpr)
                }
            }
        }

        // Enum variant access: Color.Red -> generate tag value
        if g_enumVariantCount > 0 {
            if isEnumVariant(fieldName) {
                let parentEnum = lookupEnumParent(fieldName)
                if parentEnum == receiverName {
                    let varFieldCount = lookupEnumFieldCount(fieldName)
                    if varFieldCount > 0 {
                        // Data enum: construct heap object with tag + fields
                        let enumExpr = ParserExpressionNode.new()
                        return generateEnumConstructor(fieldName, enumExpr)
                    }
                    // Simple enum (no data fields): return tag as i64 constant
                    let simpleTag = lookupEnumVariantTag(fieldName)
                    return simpleTag.toString()
                }
            }
        }

        // Handle enum member access: SeenTokenType.KeywordImport -> integer value
        if receiverName == "SeenTokenType" {
            let enumValue = getSeenTokenTypeValue(fieldName)
            return enumValue.toString()
        }

        // SIMD swizzle syntax — vec.xzyw, vec.x, vec.xy
        if receiverName != "" {
            let swzVarType = findVarType(receiverName)
            if isSimdVectorType(swzVarType) == 1 {
                let swzLanes = simdLaneCount(swzVarType)
                if isSwizzlePattern(fieldName, swzLanes) == 1 {
                    let swzLT = mapType(swzVarType)
                    let swzST = simdScalarType(swzVarType)
                    let swzIdx = findVar(receiverName)
                    if swzIdx >= 0 {
                        let swzVecReg = getNextReg()
                        output.append("  " + swzVecReg + " = load " + swzLT + ", ptr " + varRegs[swzIdx] + "\n")
                        if fieldName.length() == 1 {
                            // Single lane extract: vec.x -> extractelement
                            let swzLaneIdx = swizzleLaneIndex(fieldName)
                            let swzExtReg = getNextReg()
                            output.append("  " + swzExtReg + " = extractelement " + swzLT + " " + swzVecReg + ", i32 " + swzLaneIdx.toString() + "\n")
                            return swzExtReg
                        }
                        // Multi-lane swizzle: shufflevector with undef second operand
                        var swzMask = "<"
                        var swzMI = 0
                        while swzMI < fieldName.length() {
                            if swzMI > 0 { swzMask = swzMask + ", " }
                            let swzCh = fieldName.substring(swzMI, swzMI + 1)
                            let swzChIdx = swizzleLaneIndex(swzCh)
                            swzMask = swzMask + "i32 " + swzChIdx.toString()
                            swzMI = swzMI + 1
                        }
                        swzMask = swzMask + ">"
                        let swzResReg = getNextReg()
                        output.append("  " + swzResReg + " = shufflevector " + swzLT + " " + swzVecReg + ", " + swzLT + " undef, <" + fieldName.length().toString() + " x i32> " + swzMask + "\n")
                        return swzResReg
                    }
                }
            }
        }

        // Check if receiver has an operand (chained expression like func().field)
        if expr.operands.length() > 0 {
            // Receiver is an expression result - get its type and generate field access
            let receiverReg = generateExpression(expr.operands[0])
            let receiverType = inferExpressionType(expr.operands[0])
            // @repr(C) value-type: receiver is already a struct value, use extractvalue directly
            var isReprCExprRec = false
            if g_reprCClassNames != "" {
                if g_reprCClassNames.contains(receiverType + "|") {
                    isReprCExprRec = true
                }
            }
            if isReprCExprRec {
                return generateFieldAccess(receiverReg, receiverType, fieldName)
            }
            // If receiver type is a class type, it's stored as i64, so convert to ptr
            let actualReceiverReg = convertReceiverToPtr(receiverReg, receiverType)
            // If receiver type is a data type, store to temp memory and use that ptr
            if isDataType(receiverType) {
                let tmpReg = getNextReg()
                output.append("  " + tmpReg + " = alloca %" + receiverType + "\n")
                output.append("  store %" + receiverType + " " + receiverReg + ", ptr " + tmpReg + "\n")
                actualReceiverReg = tmpReg
            }
            return generateFieldAccess(actualReceiverReg, receiverType, fieldName)
        }

        // Simple variable field access like frontend.success or frontend.program
        let idx = findVar(receiverName)
        if idx >= 0 {
            let varReg = varRegs[idx]
            let varType = varTypes[idx]

            // Load the variable value - class types are stored as i64, data types are inline
            // @repr(C) value-type classes: load as struct value, use extractvalue
            var isReprCVar = false
            if g_reprCClassNames != "" {
                if g_reprCClassNames.contains(varType + "|") {
                    isReprCVar = true
                }
            }
            if isReprCVar {
                let loadReg = getNextReg()
                output.append("  " + loadReg + " = load %" + varType + ", ptr " + varReg + "\n")
                return generateFieldAccess(loadReg, varType, fieldName)
            }
            if isClassType(varType) {
                let loadReg = getNextReg()
                output.append("  " + loadReg + " = load i64, ptr " + varReg + "\n")
                // Convert to ptr for field access
                let ptrReg = getNextReg()
                output.append("  " + ptrReg + " = inttoptr i64 " + loadReg + " to ptr\n")
                return generateFieldAccess(ptrReg, varType, fieldName)
            } else {
                if isDataType(varType) {
                    // Data types are stored inline - use the alloca pointer directly
                    return generateFieldAccess(varReg, varType, fieldName)
                } else {
                    // Non-class types stored as ptr
                    let ptrReg = getNextReg()
                    output.append("  " + ptrReg + " = load ptr, ptr " + varReg + "\n")
                    return generateFieldAccess(ptrReg, varType, fieldName)
                }
            }
        }

        let constIdx = findModuleConstant(receiverName)
        if constIdx >= 0 {
            let constType = moduleConstantTypes[constIdx]
            let constSeenType = findVarType(receiverName)
            var invSuffix = ""
            if not isModuleConstMutable(constIdx) {
                invSuffix = ", !invariant.load !190"
            }
            if constSeenType != "" and isClassType(constSeenType) {
                let loadReg = getNextReg()
                output.append("  " + loadReg + " = load i64, ptr @" + quoteIdentIfNeeded(receiverName) + invSuffix + "\n")
                let ptrReg = getNextReg()
                output.append("  " + ptrReg + " = inttoptr i64 " + loadReg + " to ptr\n")
                return generateFieldAccess(ptrReg, constSeenType, fieldName)
            }
            if constSeenType != "" and isDataType(constSeenType) {
                return generateFieldAccess("@" + quoteIdentIfNeeded(receiverName), constSeenType, fieldName)
            }
            if constType == "ptr" {
                let ptrReg = getNextReg()
                output.append("  " + ptrReg + " = load ptr, ptr @" + quoteIdentIfNeeded(receiverName) + invSuffix + "\n")
                return generateFieldAccess(ptrReg, constSeenType, fieldName)
            }
        }

        // Handle path with array indexing like "expr.operands[0]" for ".kind"
        if receiverName.contains("[") {
            output.append("; DEBUG generateMemberAccess: handling array path=" + receiverName + " fieldName=" + fieldName + "\n")
            // Find the bracket position (91='[', 93=']')
            var bracketIdx = 0
            var bi = 0
            while bi < receiverName.length() {
                if receiverName.byteAt(bi) == 91 {
                    bracketIdx = bi
                    bi = receiverName.length()
                }
                bi = bi + 1
            }

            // Parse the path before the bracket
            let pathBeforeBracket = receiverName.substring(0, bracketIdx)

            // Find the close bracket
            var actualClose = bracketIdx + 1
            while actualClose < receiverName.length() and receiverName.byteAt(actualClose) != 93 {
                actualClose = actualClose + 1
            }
            let indexStr = receiverName.substring(bracketIdx + 1, actualClose)

            output.append("; DEBUG array path: pathBeforeBracket=" + pathBeforeBracket + " indexStr=" + indexStr + "\n")

            // Generate the array access
            // First, generate the path before bracket (e.g., "expr.operands")
            if pathBeforeBracket.contains(".") {
                // Split into base variable and field (46 = '.')
                var dotIdx = 0
                var di = 0
                while di < pathBeforeBracket.length() {
                    if pathBeforeBracket.byteAt(di) == 46 {
                        dotIdx = di
                        di = pathBeforeBracket.length()
                    }
                    di = di + 1
                }
                let baseVar = pathBeforeBracket.substring(0, dotIdx)
                let arrayField = pathBeforeBracket.substring(dotIdx + 1, pathBeforeBracket.length())

                output.append("; DEBUG array path split: baseVar=" + baseVar + " arrayField=" + arrayField + "\n")

                let baseIdx = findVar(baseVar)
                if baseIdx >= 0 {
                    let baseReg = varRegs[baseIdx]
                    let baseType = varTypes[baseIdx]

                    // Load the base pointer
                    let ptrReg = getNextReg()
                    output.append("  " + ptrReg + " = load ptr, ptr " + baseReg + "\n")

                    // Access the array field
                    let arrayReg = generateFieldAccess(ptrReg, baseType, arrayField)
                    let arrayType = getSeenFieldType(baseType, arrayField)

                    output.append("; DEBUG array access: arrayReg=" + arrayReg + " arrayType=" + arrayType + "\n")

                    // Infer the element type BEFORE making the array access call
                    var elementType = "ptr"
                    if arrayType.startsWith("Array<") and arrayType.endsWith(">") {
                        elementType = arrayType.substring(6, arrayType.length() - 1)
                    }

                    // Now perform index access - use pointer-based accessors to avoid ABI issues
                    // arrayReg is ptr to SeenArray, pass pointer directly (no load needed)
                    let elementPtrReg = getNextReg()
                    // Use seen_arr_get_element_ptr for ALL types - it uses stored element_size for correct offset
                    // seen_arr_get_ptr_ptr only works for 8-byte elements, but element_ptr works for any size
                    output.append("  " + elementPtrReg + " = call ptr @seen_arr_get_element_ptr(ptr " + arrayReg + ", i64 " + indexStr + ")\n")

                    output.append("; DEBUG element access: elementPtrReg=" + elementPtrReg + " elementType=" + elementType + "\n")

                    // Finally, access the field on the element
                    return generateFieldAccess(elementPtrReg, elementType, fieldName)
                }
            }
        }

        // Handle chained receiver like "frontend.program" with fieldName "items"
        // Need to find base variable and chain through fields
        if receiverName.contains(".") {
            // Parse the chain: split by first dot to get base variable and remaining path (46='.')
            var dotIdx = 0
            var i = 0
            while i < receiverName.length() {
                if receiverName.byteAt(i) == 46 {
                    dotIdx = i
                    i = receiverName.length()
                }
                i = i + 1
            }

            if dotIdx > 0 {
                let baseVarName = receiverName.substring(0, dotIdx)
                let restPath = receiverName.substring(dotIdx + 1, receiverName.length())

                let baseIdx = findVar(baseVarName)
                if baseIdx >= 0 {
                    let baseReg = varRegs[baseIdx]
                    let baseType = varTypes[baseIdx]
                    // Load base - class types are stored as i64, data types are inline
                    var ptrReg = ""
                    if isClassType(baseType) {
                        let loadReg = getNextReg()
                        output.append("  " + loadReg + " = load i64, ptr " + baseReg + "\n")
                        ptrReg = getNextReg()
                        output.append("  " + ptrReg + " = inttoptr i64 " + loadReg + " to ptr\n")
                    } else {
                        if isDataType(baseType) {
                            // Data types are stored inline - use the alloca pointer directly
                            ptrReg = baseReg
                        } else {
                            ptrReg = getNextReg()
                            output.append("  " + ptrReg + " = load ptr, ptr " + baseReg + "\n")
                        }
                    }
                    // First, determine the intermediate type so we know how to access it
                    // Handle chained restPath (e.g., "function.returnType") by walking through types
                    var intermediateType = ""
                    output.append("; DEBUG generateMemberAccess: baseType=" + baseType + " restPath=" + restPath + " fieldName=" + fieldName + "\n")
                    if restPath.contains(".") {
                        // Walk through the chained path to find final type
                        // Parse the path into segments first
                        var pathSegments = Array<String>()
                        var segStart = 0
                        var segIdx = 0
                        while segIdx <= restPath.length() {
                            if segIdx == restPath.length() or restPath.byteAt(segIdx) == 46 {
                                if segIdx > segStart {
                                    pathSegments.push(restPath.substring(segStart, segIdx))
                                }
                                segStart = segIdx + 1
                            }
                            segIdx = segIdx + 1
                        }

                        var currentType = baseType
                        var pi = 0
                        while pi < pathSegments.length() and currentType != "" and currentType != "Int" {
                            let currField = pathSegments[pi]
                            output.append("; DEBUG chained type walk: currentType=" + currentType + " currField=" + currField + "\n")
                            currentType = getSeenFieldType(currentType, currField)
                            output.append("; DEBUG chained type walk: newType=" + currentType + "\n")
                            pi = pi + 1
                        }
                        intermediateType = currentType
                        output.append("; DEBUG chained type final: intermediateType=" + intermediateType + "\n")
                    }
                    if not restPath.contains(".") {
                        intermediateType = getSeenFieldType(baseType, restPath)
                    }
                    if intermediateType == "" {
                        intermediateType = "ProgramNode"  // Default for .program access
                    }

                    // Access intermediate field (e.g., "program")
                    // For class types: load value (i64) and convert to ptr
                    // For inline data types: get pointer to field directly
                    var actualIntermediateReg = ""
                    if isClassType(intermediateType) {
                        let intermediateReg = generateFieldAccess(ptrReg, baseType, restPath)
                        let ptrConvReg = getNextReg()
                        output.append("  " + ptrConvReg + " = inttoptr i64 " + intermediateReg + " to ptr\n")
                        actualIntermediateReg = ptrConvReg
                    } else {
                        // Inline data types: get pointer to the field (don't load the value)
                        // Handle chained paths like "function.returnType" by walking through each segment
                        if restPath.contains(".") {
                            // Walk through the chain, accessing each field in turn
                            var chainPtr = ptrReg
                            var chainType = baseType
                            var chainSegStart = 0
                            var chainSegIdx = 0
                            while chainSegIdx <= restPath.length() {
                                if chainSegIdx == restPath.length() or restPath.byteAt(chainSegIdx) == 46 {
                                    if chainSegIdx > chainSegStart {
                                        let chainField = restPath.substring(chainSegStart, chainSegIdx)
                                        let chainFieldType = getSeenFieldType(chainType, chainField)
                                        output.append("; DEBUG chained ptr access: chainType=" + chainType + " chainField=" + chainField + " chainFieldType=" + chainFieldType + "\n")
                                        if isClassType(chainFieldType) {
                                            // Class field: load i64 and convert to ptr
                                            let loadedVal = generateFieldAccess(chainPtr, chainType, chainField)
                                            let convPtr = getNextReg()
                                            output.append("  " + convPtr + " = inttoptr i64 " + loadedVal + " to ptr\n")
                                            chainPtr = convPtr
                                        } else {
                                            if isDataType(chainFieldType) {
                                                // Data type field: get pointer to inline struct
                                                chainPtr = generateFieldAccessPtr(chainPtr, chainType, chainField)
                                            } else {
                                                // Primitive or other: load value for intermediate, get ptr for final
                                                chainPtr = generateFieldAccessPtr(chainPtr, chainType, chainField)
                                            }
                                        }
                                        chainType = chainFieldType
                                    }
                                    chainSegStart = chainSegIdx + 1
                                }
                                chainSegIdx = chainSegIdx + 1
                            }
                            actualIntermediateReg = chainPtr
                        } else {
                            // Simple single field access
                            actualIntermediateReg = generateFieldAccessPtr(ptrReg, baseType, restPath)
                        }
                    }
                    return generateFieldAccess(actualIntermediateReg, intermediateType, fieldName)
                }
            }
        }

        // Handle field of 'this' - if receiverName isn't a local variable, check if it's a field on 'this'
        let thisIdx = findVar("this")
        if thisIdx >= 0 {
            let thisReg = varRegs[thisIdx]
            let thisType = varTypes[thisIdx]

            // Check if receiverName is a field of thisType
            let fieldIdx = getFieldInfo(thisType, receiverName)
            if fieldIdx >= 0 {
                // Load 'this' pointer and access the field chain
                let ptrReg = getNextReg()
                output.append("  " + ptrReg + " = load ptr, ptr " + thisReg + "\n")

                let intermediateType = getSeenFieldType(thisType, receiverName)

                output.append("; DEBUG this field access: thisType=" + thisType + " receiverName=" + receiverName + " intermediateType=" + intermediateType + " fieldName=" + fieldName + "\n")

                // Resolve pointer to intermediate field (class -> i64 to ptr, data -> field pointer)
                var accessReg = ""
                if isClassType(intermediateType) {
                    let intermediateReg = generateFieldAccess(ptrReg, thisType, receiverName)
                    let ptrConvReg = getNextReg()
                    output.append("  " + ptrConvReg + " = inttoptr i64 " + intermediateReg + " to ptr\n")
                    accessReg = ptrConvReg
                } else {
                    accessReg = generateFieldAccessPtr(ptrReg, thisType, receiverName)
                }

                // Now access the final field (e.g., 'statements')
                return generateFieldAccess(accessReg, intermediateType, fieldName)
            }
        }

        return "0"
    }

    // Generate a struct field load via GEP (getelementptr). For simple fields,
    // emits: getelementptr %StructType, ptr %ptrReg, i32 0, i32 <fieldIdx>
    // followed by a load. For chained field access (e.g., "a.b.c"), recursively
    // resolves each segment, converting class-type intermediates from i64 to
    // ptr via inttoptr. For inline data types, uses generateFieldAccessPtr to
    // get a pointer without loading (avoids copying the entire struct).
    // WARNING: DO NOT use `!invariant.load` on array data pointers — array
    // data changes on push/resize, so the invariant annotation would be
    // incorrect and could cause LLVM to cache stale pointers.
    fun generateFieldAccess(ptrReg: String, structType: String, fieldName: String) r: String {
        // @repr(C) value-type structs: use extractvalue instead of GEP+load
        if g_reprCClassNames != "" {
            if g_reprCClassNames.contains(structType + "|") {
                let structIdx = findStruct(structType)
                if structIdx >= 0 {
                    let regFieldIdx = getFieldInfo(structType, fieldName)
                    if regFieldIdx >= 0 {
                        let fieldType = getFieldType(structType, fieldName)
                        let evReg = getNextReg()
                        output.append("  " + evReg + " = extractvalue %" + structType + " " + ptrReg + ", " + regFieldIdx.toString() + "\n")
                        return evReg
                    }
                }
            }
        }
        // Handle known chained field access patterns directly (avoid substring for reliability)
        if fieldName == "program.items" {
            // FrontendResult.program -> ProgramNode, then ProgramNode.items
            let progReg = generateFieldAccess(ptrReg, structType, "program")
            // program is a class type (i64), convert to ptr for next field access
            let progPtrReg = getNextReg()
            output.append("  " + progPtrReg + " = inttoptr i64 " + progReg + " to ptr\n")
            return generateFieldAccess(progPtrReg, "ProgramNode", "items")
        }
        if fieldName == "program.items.length" {
            // Access through chain
            let progReg = generateFieldAccess(ptrReg, structType, "program")
            // program is a class type (i64), convert to ptr for next field access
            let progPtrReg = getNextReg()
            output.append("  " + progPtrReg + " = inttoptr i64 " + progReg + " to ptr\n")
            let itemsReg = generateFieldAccess(progPtrReg, "ProgramNode", "items")
            // Return length field of array
            let lenPtrReg = getNextReg()
            output.append("  " + lenPtrReg + " = getelementptr inbounds %SeenArray, ptr " + itemsReg + ", i32 0, i32 0\n")
            let lenReg = getNextReg()
            output.append("  " + lenReg + " = load i64, ptr " + lenPtrReg + "\n")
            return lenReg
        }
        if fieldName.contains(".") {
            // Generic chained access - split and resolve sequentially
            // Find the first dot
            var dotIdx = 0
            var searchIdx = 0
            while searchIdx < fieldName.length() {
                if fieldName.byteAt(searchIdx) == 46 {
                    dotIdx = searchIdx
                    searchIdx = fieldName.length()
                }
                searchIdx = searchIdx + 1
            }
            if dotIdx > 0 {
                let firstField = fieldName.substring(0, dotIdx)
                let restFields = fieldName.substring(dotIdx + 1, fieldName.length())

                // Get type of first field for next access
                let firstType = getSeenFieldType(structType, firstField)

                output.append("; DEBUG chained access: structType=" + structType + " firstField=" + firstField + " firstType=" + firstType + " restFields=" + restFields + "\n")

                // For class types (stored as i64), load and convert to ptr
                // For inline data types (stored by value), get pointer to field
                var actualFirstReg = ""
                if isClassType(firstType) {
                    // Class types are stored as i64 - load and convert to ptr
                    let firstReg = generateFieldAccess(ptrReg, structType, firstField)
                    let ptrConvReg = getNextReg()
                    output.append("  " + ptrConvReg + " = inttoptr i64 " + firstReg + " to ptr\n")
                    actualFirstReg = ptrConvReg
                } else {
                    // Inline data types - get pointer to the field directly (don't load)
                    let fieldPtrReg = generateFieldAccessPtr(ptrReg, structType, firstField)
                    actualFirstReg = fieldPtrReg
                }

                // Recursively access remaining fields
                return generateFieldAccess(actualFirstReg, firstType, restFields)
            }
            output.append("; ERROR: Unknown chained field access: " + fieldName + "\n")
            return "0"
        }

        // Union types: all fields overlap at offset 0, load directly (no GEP)
        if g_unionTypes != "" {
            if g_unionTypes.contains(structType + "|") {
                let unionFieldType = getFieldType(structType, fieldName)
                let unionResultReg = getNextReg()
                output.append("  " + unionResultReg + " = load " + unionFieldType + ", ptr " + ptrReg + " ; union field access\n")
                return unionResultReg
            }
        }

        var fieldIndex = 0
        var fieldType = "i64"
        // Note: structLayout initialization deferred to avoid brace parsing issue
        var structLayout = "default"
        // Helper vars for building layout strings with braces (avoid parser issues with literal braces in strings)
        let lb = "{"
        let rb = "}"
        let seenArr = lb + " i64, i64, i64, ptr " + rb  // %SeenArray: { len, cap, element_size, data }

        // Prefer registry layouts when available (type header is authoritative)
        let structIdx = findStruct(structType)
        var registryHasLayout = false
        if structIdx >= 0 {
            let registeredLayout = structLayouts[structIdx]
            // Check if the registered layout is not empty (has fields)
            // Use length check to avoid brace literal comparison issues
            if registeredLayout.length() > 5 {
                structLayout = registeredLayout
                let regFieldIdx = getFieldInfo(structType, fieldName)
                if regFieldIdx >= 0 {
                    fieldIndex = regFieldIdx
                    fieldType = getFieldType(structType, fieldName)
                    registryHasLayout = true
                }
            }
        }
        if not registryHasLayout {
            // Use hardcoded layouts for well-known types
            if structType == "LLVMIRGenerator" {
                structLayout = lb + " i64, ptr, i64, i64, ptr, ptr, ptr, i64, i64, %SeenString, %SeenString, i1, %SeenString, %SeenString, ptr, ptr, %SeenString, ptr, ptr, i1, i1, %SeenString, ptr, ptr, ptr " + rb
                let llvmType = getLLVMIRGeneratorFieldType(fieldName)
                let idx = getLLVMIRGeneratorFieldIndex(fieldName)
                if idx >= 0 {
                    fieldIndex = idx
                }
                if llvmType != "" {
                    fieldType = llvmType
                }
            }
            if structType == "MacroExpansionResult" {
                structLayout = lb + " i1, ptr, i64 " + rb
                if fieldName == "success" {
                    fieldIndex = 0
                    fieldType = "i1"
                }
                if fieldName == "errors" {
                    fieldIndex = 1
                    fieldType = "ptr"
                }
                if fieldName == "program" {
                    fieldIndex = 2
                    fieldType = "i64"
                }
            }
            if structType == "TypeError" {
                structLayout = lb + " %SeenString, i64, i64, i64, %SeenString " + rb
                if fieldName == "message" {
                    fieldIndex = 0
                    fieldType = "%SeenString"
                }
                if fieldName == "location" {
                    fieldIndex = 1
                    fieldType = "i64"
                }
                if fieldName == "expected" {
                    fieldIndex = 2
                    fieldType = "i64"
                }
                if fieldName == "actual" {
                    fieldIndex = 3
                    fieldType = "i64"
                }
                if fieldName == "context" {
                    fieldIndex = 4
                    fieldType = "%SeenString"
                }
            }
            if structType == "Type" {
                structLayout = lb + " %SeenString, i1 " + rb
                if fieldName == "name" {
                    fieldIndex = 0
                    fieldType = "%SeenString"
                }
                if fieldName == "isNullable" {
                    fieldIndex = 1
                    fieldType = "i1"
                }
            }
            if structType == "Location" or structType == "SourceLocation" {
                structLayout = lb + " i64, i64, %SeenString " + rb
                if fieldName == "line" {
                    fieldIndex = 0
                    fieldType = "i64"
                }
                if fieldName == "column" {
                    fieldIndex = 1
                    fieldType = "i64"
                }
                if fieldName == "file" {
                    fieldIndex = 2
                    fieldType = "%SeenString"
                }
            }
            if structType == "AstNode" {
                structLayout = lb + " %SeenString, i64, i64, i64, i64, i64, %SeenString, i1, i1, i1, i1, i1, i1 " + rb
                if fieldName == "nodeType" {
                    fieldIndex = 0
                    fieldType = "%SeenString"
                }
                if fieldName == "functionNode" {
                    fieldIndex = 1
                    fieldType = "i64"
                }
                if fieldName == "classNode" {
                    fieldIndex = 2
                    fieldType = "i64"
                }
                if fieldName == "statementNode" {
                    fieldIndex = 3
                    fieldType = "i64"
                }
                if fieldName == "expressionNode" {
                    fieldIndex = 4
                    fieldType = "i64"
                }
                if fieldName == "blockNode" {
                    fieldIndex = 5
                    fieldType = "i64"
                }
                if fieldName == "errorMessage" {
                    fieldIndex = 6
                    fieldType = "%SeenString"
                }
                if fieldName == "hasFunction" {
                    fieldIndex = 7
                    fieldType = "i1"
                }
                if fieldName == "hasClass" {
                    fieldIndex = 8
                    fieldType = "i1"
                }
                if fieldName == "hasStatement" {
                    fieldIndex = 9
                    fieldType = "i1"
                }
                if fieldName == "hasExpression" {
                    fieldIndex = 10
                    fieldType = "i1"
                }
                if fieldName == "hasBlock" {
                    fieldIndex = 11
                    fieldType = "i1"
                }
                if fieldName == "isError" {
                    fieldIndex = 12
                    fieldType = "i1"
                }
            }
            // Delegate to unified struct field lookup in ir_type_info
            if structType != "MacroExpansionResult" and structType != "TypeError" and structType != "Type" and structType != "Location" and structType != "SourceLocation" and structType != "AstNode" {
                let knownLayout = resolveKnownStructFieldImpl(structType, fieldName)
                if knownLayout != "" {
                    structLayout = knownLayout
                    fieldIndex = g_resolvedFieldIndex
                    fieldType = decodeFieldTypeCode(g_resolvedFieldTypeCode)
                }
            }
        }

        // Default structLayout if none matched (use simple single-field layout)
        if structLayout == "default" {
            structLayout = lb + " i64 " + rb
        }

        // Generate GEP to field
        let fieldPtrReg = getNextReg()
        output.append("  " + fieldPtrReg + " = getelementptr inbounds " + structLayout + ", ptr " + ptrReg + ", i32 0, i32 " + fieldIndex.toString() + "\n")

        // Load the field value
        var resultReg = getNextReg()
        output.append("  " + resultReg + " = load " + fieldType + ", ptr " + fieldPtrReg + "\n")

        // Bitfield read: mask to extract only the relevant bits
        if g_bitfieldCount > 0 {
            let bfKey = structType + "." + fieldName
            if g_bitfieldKeys.contains(bfKey + "|") {
                // Find width by matching key in pipe-delimited registry
                var bfSearchPos = 0
                var bfIdx = 0
                var bfWidth = 0
                while bfSearchPos < g_bitfieldKeys.length() and bfWidth == 0 {
                    var bfNextPipe = g_bitfieldKeys.indexOf("|", bfSearchPos)
                    if bfNextPipe < 0 { bfNextPipe = g_bitfieldKeys.length() }
                    let bfEntry = g_bitfieldKeys.substring(bfSearchPos, bfNextPipe)
                    if bfEntry == bfKey {
                        // Extract width at same index
                        var bfWSearchPos = 0
                        var bfWIdx = 0
                        while bfWSearchPos < g_bitfieldWidths.length() {
                            var bfWNextPipe = g_bitfieldWidths.indexOf("|", bfWSearchPos)
                            if bfWNextPipe < 0 { bfWNextPipe = g_bitfieldWidths.length() }
                            if bfWIdx == bfIdx {
                                let bfWStr = g_bitfieldWidths.substring(bfWSearchPos, bfWNextPipe)
                                bfWidth = parseSimpleInt(bfWStr)
                                bfWSearchPos = g_bitfieldWidths.length()
                            }
                            bfWIdx = bfWIdx + 1
                            bfWSearchPos = bfWNextPipe + 1
                        }
                    }
                    bfIdx = bfIdx + 1
                    bfSearchPos = bfNextPipe + 1
                }
                if bfWidth > 0 and bfWidth < 64 {
                    // mask = (1 << width) - 1
                    var bfMask = 1
                    var bfShift = 0
                    while bfShift < bfWidth {
                        bfMask = bfMask * 2
                        bfShift = bfShift + 1
                    }
                    bfMask = bfMask - 1
                    let bfMaskedReg = getNextReg()
                    output.append("  " + bfMaskedReg + " = and i64 " + resultReg + ", " + bfMask.toString() + " ; bitfield(" + bfWidth.toString() + ")\n")
                    resultReg = bfMaskedReg
                }
            }
        }

        // NOTE: Array fields return ptr to heap SeenArray (NOT the SeenArray itself)
        // Callers that need the SeenArray value should load it themselves
        // This keeps the return value consistent with the storage type

        // NOTE: Class fields return i64 (pointer-as-int) directly
        // Callers that need to use the value as a pointer (e.g., for method calls)
        // should convert using inttoptr themselves
        // This keeps the return value consistent with the storage type

        return resultReg
    }

    // Helper function to identify array fields (stored as ptr, need dereference to get SeenArray)
    fun isArrayField(structType: String, fieldName: String) r: Bool {
        if structType == "ProgramNode" and fieldName == "items" { return true }
        if structType == "ItemNode" and (fieldName == "importPath" or fieldName == "importSymbols") { return true }
        if structType == "FrontendResult" and fieldName == "diagnostics" { return true }
        if structType == "ImportPathInfo" and fieldName == "segments" { return true }
        if structType == "TypeInferenceResult" and (fieldName == "errors" or fieldName == "warnings") { return true }
        if structType == "MacroExpansionResult" and fieldName == "errors" { return true }
        if structType == "FunctionNode" and fieldName == "params" { return true }
        if structType == "ClassNode" and (fieldName == "fields" or fieldName == "methods" or fieldName == "decorators") { return true }
        if structType == "ParserExpressionNode" and (fieldName == "operands" or fieldName == "arguments") { return true }
        if structType == "FunctionType" and fieldName == "parameters" { return true }
        if structType == "BlockNode" and fieldName == "statements" { return true }
        return false
    }

    // Helper function to identify class fields (stored as i64, need inttoptr conversion)
    fun isClassField(structType: String, fieldName: String) r: Bool {
        if structType == "FrontendResult" and fieldName == "program" { return true }
        if structType == "ItemNode" and (fieldName == "function" or fieldName == "classNode" or fieldName == "enumNode") { return true }
        if structType == "TypeInferenceResult" and (fieldName == "type" or fieldName == "environment") { return true }
        if structType == "MacroExpansionResult" and fieldName == "program" { return true }
        if structType == "ComptimeValue" and fieldName == "astValue" { return true }
        if structType == "AstNode" and (fieldName == "functionNode" or fieldName == "classNode" or fieldName == "statementNode" or fieldName == "expressionNode" or fieldName == "blockNode") { return true }
        // Note: FunctionNode.returnType is inline data type (TypeNode), not a class
        if structType == "FunctionNode" and fieldName == "body" { return true }
        if structType == "FunctionType" and fieldName == "returnType" { return true }
        if structType == "TypeError" and (fieldName == "location" or fieldName == "expected" or fieldName == "actual") { return true }
        if structType == "StatementNode" and (fieldName == "variableType" or fieldName == "initializer" or fieldName == "expression" or fieldName == "condition" or fieldName == "thenBranch" or fieldName == "elseBranch" or fieldName == "loopCondition" or fieldName == "loopBody" or fieldName == "returnValue") { return true }
        if (structType == "FieldNode" or structType == "ParamNode") and fieldName == "paramType" { return true }
        return false
    }

    // Same as generateFieldAccess but returns the GEP pointer without loading
    // Used for methods like push that need to modify the field in place
    fun generateFieldAccessPtr(ptrReg: String, structType: String, fieldName: String) r: String {
        // Union types: all fields at offset 0, return pointer unchanged
        if g_unionTypes != "" {
            if g_unionTypes.contains(structType + "|") {
                return ptrReg
            }
        }

        var fieldIndex = 0
        // Helper vars for building layout strings with braces
        let lb = "{"
        let rb = "}"
        var structLayout = lb + " i64 " + rb  // Default

        // Try registry first
        let structIdx = findStruct(structType)
        if structIdx >= 0 {
            structLayout = structLayouts[structIdx]
            let regFieldIdx = getFieldInfo(structType, fieldName)
            if regFieldIdx >= 0 {
                fieldIndex = regFieldIdx
            }
        }
        if structType == "LLVMIRGenerator" {
            structLayout = lb + " i64, ptr, i64, i64, ptr, ptr, ptr, i64, i64, %SeenString, %SeenString, i1, %SeenString, %SeenString, ptr, ptr, %SeenString, ptr, ptr, i1, i1, %SeenString, ptr, ptr, ptr " + rb
            let idx = getLLVMIRGeneratorFieldIndex(fieldName)
            if idx >= 0 {
                fieldIndex = idx
            }
        }
        if structType == "MacroExpansionResult" {
            structLayout = lb + " i1, ptr, i64 " + rb
            if fieldName == "success" { fieldIndex = 0 }
            if fieldName == "errors" { fieldIndex = 1 }
            if fieldName == "program" { fieldIndex = 2 }
        }
        if structType == "TypeError" {
            structLayout = lb + " %SeenString, i64, i64, i64, %SeenString " + rb
            if fieldName == "message" { fieldIndex = 0 }
            if fieldName == "location" { fieldIndex = 1 }
            if fieldName == "expected" { fieldIndex = 2 }
            if fieldName == "actual" { fieldIndex = 3 }
            if fieldName == "context" { fieldIndex = 4 }
        }
        if structType == "Type" {
            structLayout = lb + " %SeenString, i1 " + rb
            if fieldName == "name" { fieldIndex = 0 }
            if fieldName == "isNullable" { fieldIndex = 1 }
        }
        if structType == "Location" or structType == "SourceLocation" {
            structLayout = lb + " i64, i64, %SeenString " + rb
            if fieldName == "line" { fieldIndex = 0 }
            if fieldName == "column" { fieldIndex = 1 }
            if fieldName == "file" { fieldIndex = 2 }
        }
        if structType == "AstNode" {
            structLayout = lb + " %SeenString, i64, i64, i64, i64, i64, %SeenString, i1, i1, i1, i1, i1, i1 " + rb
            if fieldName == "nodeType" { fieldIndex = 0 }
            if fieldName == "functionNode" { fieldIndex = 1 }
            if fieldName == "classNode" { fieldIndex = 2 }
            if fieldName == "statementNode" { fieldIndex = 3 }
            if fieldName == "expressionNode" { fieldIndex = 4 }
            if fieldName == "blockNode" { fieldIndex = 5 }
            if fieldName == "errorMessage" { fieldIndex = 6 }
            if fieldName == "hasFunction" { fieldIndex = 7 }
            if fieldName == "hasClass" { fieldIndex = 8 }
            if fieldName == "hasStatement" { fieldIndex = 9 }
            if fieldName == "hasExpression" { fieldIndex = 10 }
            if fieldName == "hasBlock" { fieldIndex = 11 }
            if fieldName == "isError" { fieldIndex = 12 }
        }
        // Delegate to unified struct field lookup in ir_type_info
        if structType != "MacroExpansionResult" and structType != "TypeError" and structType != "Type" and structType != "Location" and structType != "SourceLocation" and structType != "AstNode" {
            let knownLayout2 = resolveKnownStructFieldImpl(structType, fieldName)
            if knownLayout2 != "" {
                structLayout = knownLayout2
                fieldIndex = g_resolvedFieldIndex
            }
        }

        // Generate GEP to field (without loading)
        let fieldPtrReg = getNextReg()
        output.append("  " + fieldPtrReg + " = getelementptr inbounds " + structLayout + ", ptr " + ptrReg + ", i32 0, i32 " + fieldIndex.toString() + "\n")

        return fieldPtrReg
    }

    // Generate IR for a struct literal expression (StructName { field: val, ... }).
    // Allocates the struct on the heap via malloc, memsets to zero, then stores
    // each field at its GEP offset. Data types use value semantics and return
    // the allocated pointer directly. Class values follow the current ABI and
    // are represented as pointer-as-i64 in expression results.
    fun generateStructLiteral(expr: ParserExpressionNode) r: String {
        // Get struct name from literalType
        let structName = expr.literalType

        // Helper vars for building layout strings with braces
        let lb = "{"
        let rb = "}"

        // Try to get layout from registry first
        let structIdx = findStruct(structName)
        var structSize = 8  // Default size
        var structLayout = lb + " i64 " + rb  // Default layout

        if structIdx >= 0 {
            // Use registered layout
            structSize = structSizes[structIdx]
            structLayout = structLayouts[structIdx]
        }
        if structIdx < 0 {
            // Try unified struct field lookup for layout
            let knownLitLayout = resolveKnownStructFieldImpl(structName, "")
            if knownLitLayout != "" {
                structLayout = knownLitLayout
                // Estimate struct size from layout string by counting fields
                structSize = getLlvmTypeSize(structLayout)
                if structSize < 8 { structSize = 8 }
            }
            if knownLitLayout == "" {
                // Generic struct: estimate based on field count and infer field types from expressions
                let fieldCount = expr.arguments.length()
                structSize = 0
                var layoutFields = ""
                var fieldI = 0
                while fieldI < fieldCount {
                    if fieldI > 0 {
                        layoutFields = layoutFields + ", "
                    }
                    // Infer field type from the expression
                    var inferredFieldType = "i64"
                    if fieldI < expr.arguments.length() {
                        let fieldExpr = expr.arguments[fieldI]
                        if fieldExpr.operands.length() > 0 {
                            let valueExpr = fieldExpr.operands[0]
                            if valueExpr.kind == "Literal" and valueExpr.literalType == "String" {
                                inferredFieldType = "%SeenString"
                                structSize = structSize + 16
                            } else if valueExpr.kind == "Call" and valueExpr.callee.startsWith("Array") {
                                inferredFieldType = "ptr"
                                structSize = structSize + 8
                            } else if valueExpr.kind == "Literal" and valueExpr.literalType == "Bool" {
                                inferredFieldType = "i1"
                                structSize = structSize + 8  // Aligned
                            } else if valueExpr.kind == "StructLiteral" {
                                // Inline data type - use %TypeName if available
                                if valueExpr.literalType != "" {
                                    inferredFieldType = "%" + quoteIdentIfNeeded(valueExpr.literalType)
                                    structSize = structSize + 24  // Estimate
                                } else {
                                    structSize = structSize + 8
                                }
                            } else {
                                structSize = structSize + 8
                            }
                        } else {
                            structSize = structSize + 8
                        }
                    } else {
                        structSize = structSize + 8
                    }
                    layoutFields = layoutFields + inferredFieldType
                    fieldI = fieldI + 1
                }
                structLayout = lb + " " + layoutFields + " " + rb
                println("[WARN] Unknown struct type '" + structName + "' - using inferred layout: " + structLayout + " size=" + structSize.toString())
            }
        }

        // Allocate memory for struct (use pool allocator for small objects)
        let mallocReg = getNextReg()
        if structSize <= 80 {
            output.append("  " + mallocReg + " = call ptr @seen_pool_alloc(i64 " + structSize.toString() + ")\n")
        }
        if structSize > 80 {
            output.append("  " + mallocReg + " = call ptr @malloc(i64 " + structSize.toString() + ")\n")
        }
        // Escape analysis hint (9.11c): LLVM heap-to-stack promotion when pointer doesn't escape
        output.append("  ; escape-analysis: heap-to-stack candidate (" + structSize.toString() + " bytes)\n")

        // Collect field value registers, LLVM types, and GEP indices into parallel arrays
        var slFieldRegs = Array<String>()
        var slFieldTypes = Array<String>()
        var slGepIndices = Array<Int>()
        var fieldIdx = 0
        while fieldIdx < expr.arguments.length() {
            let fieldExpr = expr.arguments[fieldIdx]
            let fieldName = fieldExpr.variableName

            // Generate the field value
            var valueReg = "0"
            if fieldExpr.operands.length() > 0 {
                let savedPendingType = pendingArrayLiteralType
                var fieldSeenType = ""
                if structIdx >= 0 {
                    fieldSeenType = getSeenFieldType(structName, fieldName)
                }
                if fieldExpr.operands[0].kind == "ArrayLiteral" and (fieldSeenType.startsWith("Array") or fieldSeenType.startsWith("List")) {
                    pendingArrayLiteralType = fieldSeenType
                }
                valueReg = generateExpression(fieldExpr.operands[0])
                pendingArrayLiteralType = savedPendingType
            }
            slFieldRegs.push(valueReg)

            // Get field index and type - try registry first, then fallback
            var gepIndex = fieldIdx
            var fieldType = "i64"

            if structIdx >= 0 {
                let regFieldIdx = getFieldInfo(structName, fieldName)
                if regFieldIdx >= 0 {
                    gepIndex = regFieldIdx
                    fieldType = getFieldType(structName, fieldName)
                    output.append("; DEBUG fieldType for " + structName + "." + fieldName + " = " + fieldType + "\n")
                }
            }
            if structIdx < 0 {
                // Reuse known-struct metadata even when the type was not registered
                // in the local struct table for this module.
                let knownFieldLayout = resolveKnownStructFieldImpl(structName, fieldName)
                if knownFieldLayout != "" {
                    gepIndex = g_resolvedFieldIndex
                    fieldType = decodeFieldTypeCode(g_resolvedFieldTypeCode)
                } else {
                    // Hardcoded fallback — delegated to ir_struct_gen.seen
                    var fbGepBox = Array<Int>()
                    fbGepBox.push(fieldIdx)
                    let fbType = resolveStructLiteralFieldFallback(structName, fieldName, fbGepBox)
                    if fbType != "" {
                        gepIndex = fbGepBox[0]
                        fieldType = fbType
                    } else {
                        // Infer field type from expression
                        if fieldExpr.operands.length() > 0 {
                            let valueExpr = fieldExpr.operands[0]
                            if valueExpr.kind == "Literal" and valueExpr.literalType == "String" {
                                fieldType = "%SeenString"
                            } else if valueExpr.kind == "Literal" and valueExpr.literalType == "Bool" {
                                fieldType = "i1"
                            } else if valueExpr.kind == "Call" and valueExpr.callee.startsWith("Array") {
                                fieldType = "ptr"
                            } else if valueExpr.kind == "StructLiteral" and valueExpr.literalType != "" {
                                fieldType = "%" + quoteIdentIfNeeded(valueExpr.literalType)
                            } else if valueExpr.kind == "MethodCall" {
                                let calleeType = inferExpressionType(valueExpr)
                                if isDataType(calleeType) {
                                    fieldType = "%" + quoteIdentIfNeeded(calleeType)
                                }
                            }
                        }
                    }
                }
            }
            slFieldTypes.push(fieldType)
            slGepIndices.push(gepIndex)
            fieldIdx = fieldIdx + 1
        }

        // Emit GEP + store chain — delegated to ir_struct_gen.seen
        emitStructFieldStoresImpl(output, g_regBox, structLayout, mallocReg, slFieldRegs, slFieldTypes, slGepIndices)

        // Class types are stored as i64 (pointer-as-int), so convert ptr to i64
        if isClassType(structName) {
            let i64Reg = getNextReg()
            output.append("  " + i64Reg + " = ptrtoint ptr " + mallocReg + " to i64\n")
            return i64Reg
        }

        return mallocReg
    }

    // Thin wrapper: delegates to generateLiteralFree in ir_function_gen.seen,
    // then updates stats counters that aren't accessible from satellite modules.
    fun generateLiteral(expr: ParserExpressionNode) r: String {
        syncState()
        let litState = getSharedCodegenState()
        let litResult = generateLiteralFree(litState, expr)
        writeBackState()
        // Update stats counter (module-level, not accessible from satellite)
        if expr.literalType == "String" {
            if expr.literalValue.length() <= 15 {
                g_stringsDeduped = g_stringsDeduped + 1
                mlLogDecision("sso", "inlined", "len:" + expr.literalValue.length().toString())
            }
        }
        return litResult
    }

    // Generate IR for a variable reference. Looks up the variable in
    // varNames[] (via findVar, searching backwards for shadowing), then
    // emits a load from the alloca register. Falls back to module constants
    // (@global_name), enum variant tags (i64 constants), and 'this' field
    // access if the bare name matches a struct field on the current class.
    fun getExprVariableName(expr: ParserExpressionNode) r: String {
        if expr.variableName != "" {
            return expr.variableName
        }
        return expr.literalValue
    }

    fun generateVariable(expr: ParserExpressionNode) r: String {
        let varName = getExprVariableName(expr)
        if varName == "" {
            return "0"
        }

        // : Use-after-move check — if variable was moved, emit panic
        if g_movedVarCount > 0 {
            if g_movedVarNames.contains(varName + "|") {
                output.append("  ; ERROR: use after move of '" + varName + "'\n")
                output.append("  call void @seen_use_after_move()\n")
                output.append("  unreachable\n")
                return "0"
            }
        }

        // Comptime variable lookup — emit constant if in comptime registry
        if g_comptimeCount > 0 {
            let ctVal = lookupComptimeVar(varName)
            if ctVal != -9999999 {
                let ctReg = getNextReg()
                output.append("  " + ctReg + " = add i64 " + ctVal.toString() + ", 0 ; comptime constant\n")
                return ctReg
            }
        }

        let idx = findVar(varName)
        if idx < 0 {
            // Check if it's a module constant (from type header)
            let constIdx = findModuleConstant(varName)
            if constIdx >= 0 {
                // Load from global variable: @NAME
                let constType = moduleConstantTypes[constIdx]
                let loadReg = getNextReg()
                // LICM: annotate immutable globals with !invariant.load so LLVM can hoist/CSE
                var invSuffix = ""
                if not isModuleConstMutable(constIdx) {
                    invSuffix = ", !invariant.load !190"
                }
                output.append("  " + loadReg + " = load " + constType + ", ptr @" + varName + invSuffix + "\n")
                return loadReg
            }

            // Variable not found - check if 'this' exists and varName is a field
            let thisIdx = findVar("this")
            if thisIdx >= 0 {
                // Try to access as fieldName
                let thisReg = varRegs[thisIdx]
                let thisType = varTypes[thisIdx]

                if thisType == "LLVMIRGenerator" {
                    let idxCheck = getLLVMIRGeneratorFieldIndex(varName)
                    if idxCheck >= 0 {
                        let thisPtrReg = getNextReg()
                        output.append("  " + thisPtrReg + " = load ptr, ptr " + thisReg + "\n")
                        return generateFieldAccess(thisPtrReg, thisType, varName)
                    }
                }

                // Check if this type has the field
                let structIdx = findStruct(thisType)
                if structIdx >= 0 {
                    let fieldIdx = getFieldInfo(thisType, varName)
                    if fieldIdx >= 0 {
                        // Load 'this' pointer
                        let thisPtrReg = getNextReg()
                        output.append("  " + thisPtrReg + " = load ptr, ptr " + thisReg + "\n")
                        // Access the field
                        return generateFieldAccess(thisPtrReg, thisType, varName)
                    }
                }
            }
            // Function pointer interop: if name matches a registered function, emit ptrtoint
            let fpRetType = getFunctionReturnType(varName)
            if fpRetType != "" {
                let fpReg = getNextReg()
                output.append("  " + fpReg + " = ptrtoint ptr @" + quoteIdentIfNeeded(varName) + " to i64 ; function pointer\n")
                return fpReg
            }
            return "0"
        }

        let varReg = varRegs[idx]
        let varType = varTypes[idx]
        let llvmType = mapType(varType)
        let loadReg = getNextReg()
        output.append("  " + loadReg + " = load " + llvmType + ", ptr " + varReg + "\n")
        return loadReg
    }

    // Generate IR for a binary expression (+, -, *, /, %, ==, !=, <, >, etc.).
    // Type-dispatches: SIMD vector arithmetic, float operations (fadd/fsub/...),
    // string concatenation (seen_str_concat_ss), integer arithmetic, comparison
    // operators, bitwise ops, and short-circuit &&/||.
    // Includes constant folding for integer-literal operands via foldIntConstants.
    // Supports overflow-checked arithmetic when g_panicOnOverflow is set
    // (uses llvm.sadd.with.overflow intrinsics). Delegates to emitBinaryOpImpl
    // for the core LLVM instruction emission.
    fun generateBinary(expr: ParserExpressionNode) r: String {
        let leftExpr = expr.operands[0]
        let rightExpr = expr.operands[1]

        let leftType = inferExpressionType(leftExpr)
        let rightType = inferExpressionType(rightExpr)

        // --- Pointer arithmetic ---
        if leftType.startsWith("*") {
            let paLeftReg = generateExpression(leftExpr)
            if expr.operator == "+" or expr.operator == "-" {
                let paRightReg = generateExpression(rightExpr)
                var paOffsetReg = paRightReg
                if expr.operator == "-" and not rightType.startsWith("*") {
                    paOffsetReg = getNextReg()
                    output.append("  " + paOffsetReg + " = sub i64 0, " + paRightReg + "\n")
                }
                if rightType.startsWith("*") {
                    // ptr - ptr = integer byte difference
                    let paDiffReg = getNextReg()
                    output.append("  " + paDiffReg + " = sub i64 " + paLeftReg + ", " + paRightReg + " ; ptr - ptr\n")
                    return paDiffReg
                }
                // ptr +/- N = byte offset
                let paResultReg = getNextReg()
                output.append("  " + paResultReg + " = call i64 @seen_ptr_add(i64 " + paLeftReg + ", i64 " + paOffsetReg + ", i64 1) ; ptr arithmetic\n")
                return paResultReg
            }
        }

        // --- SIMD vector arithmetic ---
        if isSimdVectorType(leftType) == 1 {
            let simdLlvmType = mapType(leftType)
            let simdLeftReg = generateExpression(leftExpr)
            let simdRightReg = generateExpression(rightExpr)
            let simdIsFloat = leftType.startsWith("f32") or leftType.startsWith("f64")
            let simdResultReg = getNextReg()
            if expr.operator == "+" {
                if simdIsFloat {
                    output.append("  " + simdResultReg + " = fadd " + simdLlvmType + " " + simdLeftReg + ", " + simdRightReg + "\n")
                } else {
                    output.append("  " + simdResultReg + " = add " + simdLlvmType + " " + simdLeftReg + ", " + simdRightReg + "\n")
                }
                return simdResultReg
            }
            if expr.operator == "-" {
                if simdIsFloat {
                    output.append("  " + simdResultReg + " = fsub " + simdLlvmType + " " + simdLeftReg + ", " + simdRightReg + "\n")
                } else {
                    output.append("  " + simdResultReg + " = sub " + simdLlvmType + " " + simdLeftReg + ", " + simdRightReg + "\n")
                }
                return simdResultReg
            }
            if expr.operator == "*" {
                if simdIsFloat {
                    output.append("  " + simdResultReg + " = fmul " + simdLlvmType + " " + simdLeftReg + ", " + simdRightReg + "\n")
                } else {
                    output.append("  " + simdResultReg + " = mul " + simdLlvmType + " " + simdLeftReg + ", " + simdRightReg + "\n")
                }
                return simdResultReg
            }
            if expr.operator == "/" {
                if simdIsFloat {
                    output.append("  " + simdResultReg + " = fdiv " + simdLlvmType + " " + simdLeftReg + ", " + simdRightReg + "\n")
                } else {
                    output.append("  " + simdResultReg + " = sdiv " + simdLlvmType + " " + simdLeftReg + ", " + simdRightReg + "\n")
                }
                return simdResultReg
            }
            // SIMD comparison → mask vector
            if expr.operator == "==" or expr.operator == "!=" or expr.operator == "<" or expr.operator == ">" or expr.operator == "<=" or expr.operator == ">=" {
                if simdIsFloat {
                    var simdFcmpOp = "oeq"
                    if expr.operator == "!=" { simdFcmpOp = "one" }
                    if expr.operator == "<" { simdFcmpOp = "olt" }
                    if expr.operator == ">" { simdFcmpOp = "ogt" }
                    if expr.operator == "<=" { simdFcmpOp = "ole" }
                    if expr.operator == ">=" { simdFcmpOp = "oge" }
                    output.append("  " + simdResultReg + " = fcmp " + simdFcmpOp + " " + simdLlvmType + " " + simdLeftReg + ", " + simdRightReg + "\n")
                } else {
                    var simdIcmpOp = "eq"
                    if expr.operator == "!=" { simdIcmpOp = "ne" }
                    if expr.operator == "<" { simdIcmpOp = "slt" }
                    if expr.operator == ">" { simdIcmpOp = "sgt" }
                    if expr.operator == "<=" { simdIcmpOp = "sle" }
                    if expr.operator == ">=" { simdIcmpOp = "sge" }
                    output.append("  " + simdResultReg + " = icmp " + simdIcmpOp + " " + simdLlvmType + " " + simdLeftReg + ", " + simdRightReg + "\n")
                }
                return simdResultReg
            }
        }

        // --- E-graph peephole optimizations (consolidated via egraph lookup) ---
        // Integer peephole rules
        if leftType == "Int" and rightType == "Int" {
            let leftIsIntLit = leftExpr.kind == "Literal" and leftExpr.literalType == "Int"
            let rightIsIntLit = rightExpr.kind == "Literal" and rightExpr.literalType == "Int"
            let leftLitVal = leftExpr.literalValue
            let rightLitVal = rightExpr.literalValue

            // Self-comparison: both sides are the same variable (not a call)
            if leftExpr.kind == "Variable" and rightExpr.kind == "Variable" {
                if leftExpr.literalValue == rightExpr.literalValue {
                    let selfAction = egraphSelfComparison(expr.operator)
                    if selfAction == "const:0" {
                        g_constantsFolded = g_constantsFolded + 1
                        mlLogDecision("e-graph", "self-opt", leftExpr.literalValue + expr.operator + leftExpr.literalValue + "=0")
                        let selfReg = getNextReg()
                        output.append("  " + selfReg + " = add i64 0, 0 ; e-graph: x " + expr.operator + " x -> 0\n")
                        return selfReg
                    }
                    if selfAction == "const:1" {
                        g_constantsFolded = g_constantsFolded + 1
                        mlLogDecision("e-graph", "self-opt", leftExpr.literalValue + expr.operator + leftExpr.literalValue + "=1")
                        let selfReg = getNextReg()
                        output.append("  " + selfReg + " = add i64 1, 0 ; e-graph: x " + expr.operator + " x -> 1\n")
                        return selfReg
                    }
                    if selfAction == "identity_left" {
                        return generateExpression(leftExpr)
                    }
                    if selfAction == "const_true" {
                        g_constantsFolded = g_constantsFolded + 1
                        let selfReg = getNextReg()
                        output.append("  " + selfReg + " = add i1 1, 0 ; e-graph: x " + expr.operator + " x -> true\n")
                        return selfReg
                    }
                    if selfAction == "const_false" {
                        g_constantsFolded = g_constantsFolded + 1
                        let selfReg = getNextReg()
                        output.append("  " + selfReg + " = add i1 0, 0 ; e-graph: x " + expr.operator + " x -> false\n")
                        return selfReg
                    }
                }
            }

            // E-graph lookup for literal-based rules — delegated to ir_optimization.seen
            let action = egraphLookup(expr.operator, leftLitVal, rightLitVal, leftIsIntLit, rightIsIntLit)
            if action == "identity_left" {
                return generateExpression(leftExpr)
            }
            if action == "identity_right" {
                return generateExpression(rightExpr)
            }
            if action != "" {
                if action.startsWith("const:") {
                    g_constantsFolded = g_constantsFolded + 1
                    mlLogDecision("e-graph", "folded", expr.operator + "=" + action)
                }
                // For non-const actions, generate left operand (all remaining actions use leftReg)
                var egLeftReg = ""
                if not action.startsWith("const:") {
                    egLeftReg = generateExpression(leftExpr)
                }
                let egResult = emitEgraphPeepholeImpl(output, g_regBox, action, egLeftReg, "", expr.operator)
                if egResult != "" {
                    return egResult
                }
            }

            // Associative rewrite: (a + CONST1) + CONST2 → a + (CONST1+CONST2)
            if expr.operator == "+" and rightIsIntLit {
                if leftExpr.kind == "Binary" and leftExpr.operator == "+" {
                    if leftExpr.operands.length() >= 2 {
                        let innerRight = leftExpr.operands[1]
                        if innerRight.kind == "Literal" and innerRight.literalType == "Int" {
                            let combinedVal = foldIntConstants(innerRight.literalValue, rightLitVal, "+")
                            if combinedVal != "" {
                                let origCost = exprCost(expr) + exprCost(leftExpr)
                                let rewriteCost = exprCost(leftExpr.operands[0]) + 3 + 1
                                if rewriteCost <= origCost {
                                    g_constantsFolded = g_constantsFolded + 1
                                    mlLogDecision("e-graph", "assoc-fold", innerRight.literalValue + "+" + rightLitVal + "=" + combinedVal)
                                    let innerLeftReg = generateExpression(leftExpr.operands[0])
                                    let assocResultReg = getNextReg()
                                    output.append("  " + assocResultReg + " = add i64 " + innerLeftReg + ", " + combinedVal + " ; e-graph: (a+C1)+C2 -> a+(C1+C2)\n")
                                    return assocResultReg
                                }
                            }
                        }
                    }
                }
            }
            // Associative rewrite: (a * CONST1) * CONST2 → a * (CONST1*CONST2)
            if expr.operator == "*" and rightIsIntLit {
                if leftExpr.kind == "Binary" and leftExpr.operator == "*" {
                    if leftExpr.operands.length() >= 2 {
                        let innerRightMul = leftExpr.operands[1]
                        if innerRightMul.kind == "Literal" and innerRightMul.literalType == "Int" {
                            let combinedMulVal = foldIntConstants(innerRightMul.literalValue, rightLitVal, "*")
                            if combinedMulVal != "" {
                                let origMulCost = exprCost(expr) + exprCost(leftExpr)
                                let rewriteMulCost = exprCost(leftExpr.operands[0]) + 5 + 1
                                if rewriteMulCost <= origMulCost {
                                    g_constantsFolded = g_constantsFolded + 1
                                    mlLogDecision("e-graph", "assoc-fold", innerRightMul.literalValue + "*" + rightLitVal + "=" + combinedMulVal)
                                    let innerLeftMulReg = generateExpression(leftExpr.operands[0])
                                    let assocMulResultReg = getNextReg()
                                    output.append("  " + assocMulResultReg + " = mul nsw i64 " + innerLeftMulReg + ", " + combinedMulVal + " ; e-graph: (a*C1)*C2 -> a*(C1*C2)\n")
                                    return assocMulResultReg
                                }
                            }
                        }
                    }
                }
            }
            // Comparison of two integer literals: fold at compile time
            if leftIsIntLit and rightIsIntLit {
                let cmpResult = foldIntComparison(leftLitVal, rightLitVal, expr.operator)
                if cmpResult != "" {
                    g_constantsFolded = g_constantsFolded + 1
                    g_branchesEliminated = g_branchesEliminated + 1
                    mlLogDecision("const-fold", "cmp-folded", leftLitVal + expr.operator + rightLitVal + "=" + cmpResult)
                    let cmpFoldReg = getNextReg()
                    if cmpResult == "true" {
                        output.append("  " + cmpFoldReg + " = add i1 1, 0 ; constant-folded comparison\n")
                    } else {
                        output.append("  " + cmpFoldReg + " = add i1 0, 0 ; constant-folded comparison\n")
                    }
                    return cmpFoldReg
                }
            }
            // Constant folding: both operands are IntLiteral → compute at compile time
            if leftIsIntLit and rightIsIntLit {
                let folded = foldIntConstants(leftLitVal, rightLitVal, expr.operator)
                if folded != "" {
                    g_constantsFolded = g_constantsFolded + 1
                    mlLogDecision("const-fold", "folded", leftLitVal + expr.operator + rightLitVal + "=" + folded)
                    let foldResultReg = getNextReg()
                    output.append("  " + foldResultReg + " = add i64 " + folded + ", 0 ; constant-folded\n")
                    return foldResultReg
                }
            }
        }
        // Float peephole optimizations — delegated to ir_optimization.seen
        if leftType == "Float" and rightType == "Float" {
            let fLeftIsLit = leftExpr.kind == "Literal" and leftExpr.literalType == "Float"
            let fRightIsLit = rightExpr.kind == "Literal" and rightExpr.literalType == "Float"
            let fLeftLitVal = leftExpr.literalValue
            let fRightLitVal = rightExpr.literalValue
            let fAction = egraphLookupFloat(expr.operator, fLeftLitVal, fRightLitVal, fLeftIsLit, fRightIsLit)
            if fAction == "identity_left" {
                return generateExpression(leftExpr)
            }
            if fAction == "identity_right" {
                return generateExpression(rightExpr)
            }
            if fAction != "" {
                if fAction.startsWith("fconst:") {
                    g_constantsFolded = g_constantsFolded + 1
                }
                // Generate left/right operands as needed by the action
                var fgLeftReg = ""
                var fgRightReg = ""
                if fAction == "fneg" or fAction == "fneg_right" {
                    fgRightReg = generateExpression(rightExpr)
                }
                if fAction != "fneg" and fAction != "fneg_right" and not fAction.startsWith("fconst:") {
                    fgLeftReg = generateExpression(leftExpr)
                }
                let fResult = emitEgraphFloatPeepholeImpl(output, g_regBox, fAction, fgLeftReg, fgRightReg, expr.operator)
                if fResult != "" {
                    return fResult
                }
            }
        }
        // FMA detection: a + (b * c) or (a * b) + c → llvm.fmuladd.f64
        // NOTE: Int operands must be promoted to double via sitofp before use.
        if expr.operator == "+" and (leftType == "Float" or rightType == "Float") {
            // Check if right operand is a float multiply
            if rightExpr.kind == "Binary" and rightExpr.operator == "*" {
                let rLeftType = inferExpressionType(rightExpr.operands[0])
                let rRightType = inferExpressionType(rightExpr.operands[1])
                if rLeftType == "Float" or rRightType == "Float" {
                    var fmaAReg = generateExpression(rightExpr.operands[0])
                    if rLeftType != "Float" {
                        let cvtA = getNextReg()
                        output.append("  " + cvtA + " = sitofp i64 " + fmaAReg + " to double\n")
                        fmaAReg = cvtA
                    }
                    var fmaBReg = generateExpression(rightExpr.operands[1])
                    if rRightType != "Float" {
                        let cvtB = getNextReg()
                        output.append("  " + cvtB + " = sitofp i64 " + fmaBReg + " to double\n")
                        fmaBReg = cvtB
                    }
                    var fmaCReg = generateExpression(leftExpr)
                    if leftType != "Float" {
                        let cvtC = getNextReg()
                        output.append("  " + cvtC + " = sitofp i64 " + fmaCReg + " to double\n")
                        fmaCReg = cvtC
                    }
                    let fmaResultReg = getNextReg()
                    output.append("  " + fmaResultReg + " = call double @llvm.fmuladd.f64(double " + fmaAReg + ", double " + fmaBReg + ", double " + fmaCReg + ") ; FMA: c + a*b\n")
                    return fmaResultReg
                }
            }
            // Check if left operand is a float multiply
            if leftExpr.kind == "Binary" and leftExpr.operator == "*" {
                let lLeftType = inferExpressionType(leftExpr.operands[0])
                let lRightType = inferExpressionType(leftExpr.operands[1])
                if lLeftType == "Float" or lRightType == "Float" {
                    var fmaAReg = generateExpression(leftExpr.operands[0])
                    if lLeftType != "Float" {
                        let cvtA = getNextReg()
                        output.append("  " + cvtA + " = sitofp i64 " + fmaAReg + " to double\n")
                        fmaAReg = cvtA
                    }
                    var fmaBReg = generateExpression(leftExpr.operands[1])
                    if lRightType != "Float" {
                        let cvtB = getNextReg()
                        output.append("  " + cvtB + " = sitofp i64 " + fmaBReg + " to double\n")
                        fmaBReg = cvtB
                    }
                    var fmaCReg = generateExpression(rightExpr)
                    if rightType != "Float" {
                        let cvtC = getNextReg()
                        output.append("  " + cvtC + " = sitofp i64 " + fmaCReg + " to double\n")
                        fmaCReg = cvtC
                    }
                    let fmaResultReg = getNextReg()
                    output.append("  " + fmaResultReg + " = call double @llvm.fmuladd.f64(double " + fmaAReg + ", double " + fmaBReg + ", double " + fmaCReg + ") ; FMA: a*b + c\n")
                    return fmaResultReg
                }
            }
        }
        // --- End peephole optimizations ---

        // Short-circuit logical operators (must evaluate before eager left/right eval)
        if expr.operator == "and" {
            return generateShortCircuitAnd(expr)
        }
        if expr.operator == "or" {
            return generateShortCircuitOr(expr)
        }

        let leftReg = generateExpression(leftExpr)
        let rightReg = generateExpression(rightExpr)

        // CSE within function scope: re-enabled for pure int/float binary ops.
        // Cache is cleared at function entry and block boundaries (safe with dominance).
        if (leftType == "Int" or leftType == "Float") and (rightType == "Int" or rightType == "Float") {
            let isPureBinOp = expr.operator == "+" or expr.operator == "-" or expr.operator == "*" or expr.operator == "/"
            if isPureBinOp {
                let cseKey = leftReg + expr.operator + rightReg
                let cseCached = cseLookup(cseKey)
                if cseCached != "" {
                    mlLogDecision("cse", "hit", cseKey)
                    return cseCached
                }
            }
        }

        // Note: resultReg must be allocated AFTER any intermediate conversion registers
        // to maintain SSA sequential numbering

        // --- Operator overloading dispatch ---
        var opMethodSuffix = ""
        if expr.operator == "+" { opMethodSuffix = "operator_add" }
        if opMethodSuffix == "" and expr.operator == "-" { opMethodSuffix = "operator_sub" }
        if opMethodSuffix == "" and expr.operator == "*" { opMethodSuffix = "operator_mul" }
        if opMethodSuffix == "" and expr.operator == "/" { opMethodSuffix = "operator_div" }
        if opMethodSuffix == "" and expr.operator == "%" { opMethodSuffix = "operator_mod" }
        if opMethodSuffix == "" and expr.operator == "==" { opMethodSuffix = "operator_eq" }
        if opMethodSuffix == "" and expr.operator == "!=" { opMethodSuffix = "operator_neq" }
        if opMethodSuffix == "" and expr.operator == "<" { opMethodSuffix = "operator_lt" }
        if opMethodSuffix == "" and expr.operator == ">" { opMethodSuffix = "operator_gt" }
        if opMethodSuffix == "" and expr.operator == "<=" { opMethodSuffix = "operator_lte" }
        if opMethodSuffix == "" and expr.operator == ">=" { opMethodSuffix = "operator_gte" }

        if opMethodSuffix != "" {
            let opFuncName = leftType + "_" + opMethodSuffix
            let opRetType = getFunctionReturnType(opFuncName)
            if opRetType != "" {
                let thisPtrReg = getNextReg()
                output.append("  " + thisPtrReg + " = inttoptr i64 " + leftReg + " to ptr\n")
                let argPtrReg = getNextReg()
                output.append("  " + argPtrReg + " = inttoptr i64 " + rightReg + " to ptr\n")
                let opRetLlvm = mapType(opRetType)
                let opResultReg = getNextReg()
                output.append("  " + opResultReg + " = call " + opRetLlvm + " @" + quoteIdentIfNeeded(opFuncName) + "(ptr " + thisPtrReg + ", ptr " + argPtrReg + ")\n")
                return opResultReg
            }
        }
        // --- End operator overloading ---

        // Delegate to extracted binary op impl
        var boundsBox = Array<Int>()
        boundsBox.push(g_boundsCheckLabelCount)
        var cseSig = Array<Int>()
        cseSig.push(0)
        var panicFlag = 0
        if g_panicOnOverflow { panicFlag = 1 }
        let leftMT = mapType(leftType)
        let resultReg = emitBinaryOpImpl(output, g_regBox, boundsBox, cseSig,
            expr.operator, leftReg, rightReg, leftType, rightType,
            leftExpr.kind, leftExpr.literalValue, leftExpr.variableName,
            rightExpr.kind, rightExpr.literalValue,
            panicFlag, g_inductionVarName, leftMT)
        g_boundsCheckLabelCount = boundsBox[0]
        if cseSig[0] == 1 { cseClear() }

        // CSE recording for pure int/float binary ops (within function scope only)
        if (leftType == "Int" or leftType == "Float") and (rightType == "Int" or rightType == "Float") {
            let isPureBinOp2 = expr.operator == "+" or expr.operator == "-" or expr.operator == "*" or expr.operator == "/"
            if isPureBinOp2 {
                let cseKey2 = leftReg + expr.operator + rightReg
                cseRecord(cseKey2, resultReg)
            }
        }

        return resultReg
    }

    // Helper: check if an expression produces i1 (bool) rather than i64
    fun isExprBool(e: ParserExpressionNode, eType: String) r: Int {
        if eType == "Bool" { return 1 }
        if e.operator == "==" { return 1 }
        if e.operator == "!=" { return 1 }
        if e.operator == "<" { return 1 }
        if e.operator == ">" { return 1 }
        if e.operator == "<=" { return 1 }
        if e.operator == ">=" { return 1 }
        if e.operator == "and" { return 1 }
        if e.operator == "or" { return 1 }
        if e.operator == "not" { return 1 }
        return 0
    }

    // Short-circuit AND: left ? right : false
    // Uses bridge blocks so phi predecessors are always correct even with nested and/or
    // Generate short-circuit evaluation for logical AND (&&).
    // If the left operand is false, skips evaluating the right operand
    // entirely. Uses a phi node to merge the boolean result from both paths.
    fun generateShortCircuitAnd(expr: ParserExpressionNode) r: String {
        let leftExpr = expr.operands[0]
        let rightExpr = expr.operands[1]
        let leftType = inferExpressionType(leftExpr)
        let rightType = inferExpressionType(rightExpr)

        let checkLabel = getNextBlockLabel()
        let rightLabel = getNextBlockLabel()
        let doneLabel = getNextBlockLabel()
        let mergeLabel = getNextBlockLabel()

        // Evaluate left side (may emit multiple blocks for nested and/or)
        let leftReg = generateExpression(leftExpr)

        // Bridge to known block for phi correctness
        output.append("  br label %" + checkLabel + "\n")
        output.append(checkLabel + ":\n")
        cseClear()

        // Convert left to i1 if needed
        var leftBool = leftReg
        if isExprBool(leftExpr, leftType) == 0 {
            leftBool = getNextReg()
            output.append("  " + leftBool + " = icmp ne i64 " + leftReg + ", 0\n")
        }

        // If left is true, evaluate right; otherwise skip to merge with false
        output.append("  br i1 " + leftBool + ", label %" + rightLabel + ", label %" + mergeLabel + "\n")

        // Right side block
        output.append(rightLabel + ":\n")
        cseClear()
        let rightReg = generateExpression(rightExpr)

        // Bridge to known block after right evaluation
        output.append("  br label %" + doneLabel + "\n")
        output.append(doneLabel + ":\n")
        cseClear()

        // Convert right to i1 if needed
        var rightBool = rightReg
        if isExprBool(rightExpr, rightType) == 0 {
            rightBool = getNextReg()
            output.append("  " + rightBool + " = icmp ne i64 " + rightReg + ", 0\n")
        }

        output.append("  br label %" + mergeLabel + "\n")

        // Merge block with phi
        output.append(mergeLabel + ":\n")
        cseClear()
        let resultReg = getNextReg()
        output.append("  " + resultReg + " = phi i1 [ false, %" + checkLabel + " ], [ " + rightBool + ", %" + doneLabel + " ]\n")
        return resultReg
    }

    // Short-circuit OR: left ? true : right
    // Uses bridge blocks so phi predecessors are always correct even with nested and/or
    // Generate short-circuit evaluation for logical OR (||).
    // If the left operand is true, skips evaluating the right operand.
    fun generateShortCircuitOr(expr: ParserExpressionNode) r: String {
        let leftExpr = expr.operands[0]
        let rightExpr = expr.operands[1]
        let leftType = inferExpressionType(leftExpr)
        let rightType = inferExpressionType(rightExpr)

        let checkLabel = getNextBlockLabel()
        let rightLabel = getNextBlockLabel()
        let doneLabel = getNextBlockLabel()
        let mergeLabel = getNextBlockLabel()

        // Evaluate left side (may emit multiple blocks for nested and/or)
        let leftReg = generateExpression(leftExpr)

        // Bridge to known block for phi correctness
        output.append("  br label %" + checkLabel + "\n")
        output.append(checkLabel + ":\n")
        cseClear()

        // Convert left to i1 if needed
        var leftBool = leftReg
        if isExprBool(leftExpr, leftType) == 0 {
            leftBool = getNextReg()
            output.append("  " + leftBool + " = icmp ne i64 " + leftReg + ", 0\n")
        }

        // If left is true, skip to merge with true; otherwise evaluate right
        output.append("  br i1 " + leftBool + ", label %" + mergeLabel + ", label %" + rightLabel + "\n")

        // Right side block
        output.append(rightLabel + ":\n")
        cseClear()
        let rightReg = generateExpression(rightExpr)

        // Bridge to known block after right evaluation
        output.append("  br label %" + doneLabel + "\n")
        output.append(doneLabel + ":\n")
        cseClear()

        // Convert right to i1 if needed
        var rightBool = rightReg
        if isExprBool(rightExpr, rightType) == 0 {
            rightBool = getNextReg()
            output.append("  " + rightBool + " = icmp ne i64 " + rightReg + ", 0\n")
        }

        output.append("  br label %" + mergeLabel + "\n")

        // Merge block with phi
        output.append(mergeLabel + ":\n")
        cseClear()
        let resultReg = getNextReg()
        output.append("  " + resultReg + " = phi i1 [ true, %" + checkLabel + " ], [ " + rightBool + ", %" + doneLabel + " ]\n")
        return resultReg
    }

    // Generate IR for a function call expression. Handles a wide variety of
    // call types in priority order:
    //   1. Comptime parameter specialization (evaluate compile-time args)
    //   2. Builtins: sizeof/alignof/offsetof (compile-time constants)
    //   3. Print/println (variadic, type-dispatched formatting)
    //   4. Type constructors: Array/Vec/HashMap/BTreeMap/LinkedList/Option/etc.
    //   5. Enum variant constructors (checked via isEnumVariant)
    //   6. Closure/indirect calls (varNames match before enum/array check)
    //   7. Class constructors (malloc + memset + field init)
    //   8. Async function calls (return coroutine handle ptr)
    //   9. Regular function calls with ABI-correct parameter passing
    // Data types are passed as pointers (ptr) for ABI compatibility.
    // Collection constructors (HashMap_new_str_int, etc.) dispatch to
    // type-specialized runtime functions.
    fun generateCall(expr: ParserExpressionNode) r: String {
        var funcName = expr.callee

        // comptime parameter specialization — evaluate and register comptime args
        if g_comptimeParamCount > 0 {
            // Check if this function has comptime params
            var ctpSearchPos = 0
            while ctpSearchPos < g_comptimeParamFuncNames.length() {
                var ctpNextPipe = g_comptimeParamFuncNames.indexOf("|", ctpSearchPos)
                if ctpNextPipe < 0 { ctpNextPipe = g_comptimeParamFuncNames.length() }
                let ctpEntry = g_comptimeParamFuncNames.substring(ctpSearchPos, ctpNextPipe)
                // Entry format: "funcName:paramIdx:paramName"
                let ctpColon1 = ctpEntry.indexOf(":", 0)
                if ctpColon1 > 0 {
                    let ctpFuncName = ctpEntry.substring(0, ctpColon1)
                    if ctpFuncName == funcName {
                        let ctpColon2 = ctpEntry.indexOf(":", ctpColon1 + 1)
                        if ctpColon2 > ctpColon1 {
                            let ctpIdxStr = ctpEntry.substring(ctpColon1 + 1, ctpColon2)
                            let ctpParamName = ctpEntry.substring(ctpColon2 + 1, ctpEntry.length())
                            let ctpParamIdx = parseSimpleInt(ctpIdxStr)
                            if ctpParamIdx >= 0 and ctpParamIdx < expr.arguments.length() {
                                let ctpVal = evaluateConstExpr(expr.arguments[ctpParamIdx])
                                if ctpVal != -9999999 {
                                    registerComptimeVar(ctpParamName, ctpVal)
                                    output.append("  ; comptime param " + ctpParamName + " = " + ctpVal.toString() + "\n")
                                }
                            }
                        }
                    }
                }
                ctpSearchPos = ctpNextPipe + 1
            }
        }

        // sizeof(Type) — compile-time type size in bytes
        // NOTE: Use inferExpressionType instead of field access on arguments[0]
        // to avoid stage1_frozen cross-module GEP bug with ParserExpressionNode fields
        if funcName == "sizeof" {
            if expr.arguments.length() > 0 {
                // Try comptime evaluator first (handles bare type names like Int32)
                let ctSize = evaluateConstExpr(expr)
                if ctSize > 0 {
                    return ctSize.toString()
                }
                let sizeTypeName = inferExpressionType(expr.arguments[0])
                if sizeTypeName != "" {
                    let llvmT = mapType(sizeTypeName)
                    let sz = getLlvmTypeSize(llvmT)
                    if sz > 0 {
                        return sz.toString()
                    }
                }
            }
            return "0"
        }

        // alignof(Type) — compile-time type alignment in bytes
        if funcName == "alignof" {
            if expr.arguments.length() > 0 {
                let alignTypeName = inferExpressionType(expr.arguments[0])
                if alignTypeName != "" {
                    let llvmT = mapType(alignTypeName)
                    let al = getLlvmTypeAlign(llvmT)
                    if al > 0 {
                        return al.toString()
                    }
                }
            }
            return "0"
        }

        // offsetof(Type, field) — field walk delegated to ir_call_dispatch.seen
        if funcName == "offsetof" {
            if expr.arguments.length() >= 2 {
                let offTypeName = inferExpressionType(expr.arguments[0])
                let offFieldName = inferExpressionType(expr.arguments[1])
                if offTypeName != "" and offFieldName != "" {
                    let sIdx = findStruct(offTypeName)
                    if sIdx >= 0 {
                        let fNamesCsv = structFieldNames[sIdx]
                        let fTypesCsv = structFieldTypes[sIdx]
                        // Pre-compute field names, aligns, sizes into parallel arrays
                        var offFieldNamesArr = Array<String>()
                        var offFieldAlignsArr = Array<Int>()
                        var offFieldSizesArr = Array<Int>()
                        var offPos = 0
                        var offTPos = 0
                        while offPos < fNamesCsv.length() {
                            var offComma = fNamesCsv.indexOf(",", offPos)
                            if offComma < 0 { offComma = fNamesCsv.length() }
                            let offFn = fNamesCsv.substring(offPos, offComma)
                            var offTComma = fTypesCsv.indexOf(",", offTPos)
                            if offTComma < 0 { offTComma = fTypesCsv.length() }
                            let offFt = fTypesCsv.substring(offTPos, offTComma)
                            offFieldNamesArr.push(offFn)
                            offFieldAlignsArr.push(getLlvmTypeAlign(offFt))
                            offFieldSizesArr.push(getLlvmTypeSize(offFt))
                            offPos = offComma + 1
                            offTPos = offTComma + 1
                        }
                        let offResult = emitOffsetofImpl(offFieldNamesArr, offFieldAlignsArr, offFieldSizesArr, offFieldName)
                        if offResult >= 0 {
                            return offResult.toString()
                        }
                    }
                }
            }
            return "0"
        }

        // : transmute<TargetType>(value) — delegated to ir_method_gen.seen
        if funcName.startsWith("transmute<") {
            if g_insideUnsafe == 0 {
                output.append("  ; ERROR: transmute requires unsafe block\n")
                return "0"
            }
            if expr.arguments.length() > 0 {
                let tmSrcReg = generateExpression(expr.arguments[0])
                let tmSrcType = inferExpressionType(expr.arguments[0])
                let tmLt = funcName.indexOf("<", 0)
                let tmGt = funcName.indexOf(">", 0)
                var tmTargetTypeName = "Int"
                if tmLt >= 0 and tmGt > tmLt {
                    tmTargetTypeName = funcName.substring(tmLt + 1, tmGt)
                }
                return emitTransmuteImpl(output, g_regBox, tmSrcReg, mapType(tmSrcType), mapType(tmTargetTypeName))
            }
            return "0"
        }

        // comptime includeStr("path") — delegated to ir_call_dispatch.seen
        if funcName == "includeStr" {
            if expr.arguments.length() > 0 {
                let inclPath = expr.arguments[0].literalValue
                if inclPath != "" and exists(inclPath) {
                    let inclContent = readText(inclPath)
                    stringConstants.push(inclContent)
                    let inclIdx = stringConstants.length() - 1
                    let inclEscaped = escapeString(inclContent)
                    return emitIncludeStrImpl(output, g_regBox, inclContent, inclEscaped, stringConstantPrefix, inclIdx)
                }
                output.append("  ; WARNING: includeStr file not found: " + inclPath + "\n")
            }
            // Fallback: empty string
            let inclEmptyReg = getNextReg()
            output.append("  " + inclEmptyReg + " = insertvalue %SeenString undef, i64 0, 0\n")
            return inclEmptyReg
        }

        // comptime includeBytes("path") — delegated to ir_call_dispatch.seen
        if funcName == "includeBytes" {
            if expr.arguments.length() > 0 {
                let inclBPath = expr.arguments[0].literalValue
                if inclBPath != "" and exists(inclBPath) {
                    let inclBContent = readText(inclBPath)
                    stringConstants.push(inclBContent)
                    let inclBIdx = stringConstants.length() - 1
                    let inclBEscaped = escapeString(inclBContent)
                    return emitIncludeBytesImpl(output, g_regBox, inclBContent, inclBEscaped, stringConstantPrefix, inclBIdx)
                }
            }
            return "0"
        }

        // : ptr operations — delegated to ir_method_gen.seen emitPtrOpsImpl
        if funcName == "ptr_deref" or funcName == "ptr_deref_f64" or funcName == "ptr_store" or funcName == "ptr_store_f64" or funcName == "ptr_is_null" or funcName == "ptr_add" or funcName == "ptr_deref_i32" or funcName == "ptr_store_i32" or funcName == "ptr_deref_i16" or funcName == "ptr_store_i16" or funcName == "ptr_deref_i8" or funcName == "ptr_store_i8" or funcName == "ptr_deref_f32" or funcName == "ptr_store_f32" or funcName == "ptr_alloc_i32" or funcName == "ptr_alloc_i16" or funcName == "ptr_alloc_i8" {
            // Unsafe enforcement: ptr_deref/ptr_store require unsafe block
            if g_insideUnsafe == 0 {
                if funcName.startsWith("ptr_deref") or funcName.startsWith("ptr_store") {
                    output.append("  ; WARNING: " + funcName + " requires unsafe block\n")
                }
            }
            var ptArg0 = ""
            var ptArg1 = ""
            var ptArg2 = ""
            if expr.arguments.length() > 0 { ptArg0 = generateExpression(expr.arguments[0]) }
            if expr.arguments.length() > 1 { ptArg1 = generateExpression(expr.arguments[1]) }
            if expr.arguments.length() > 2 { ptArg2 = generateExpression(expr.arguments[2]) }
            let ptResult = emitPtrOpsImpl(output, g_regBox, funcName, ptArg0, ptArg1, ptArg2)
            if ptResult != "" { return ptResult }
            if funcName == "ptr_is_null" { return "1" }
            return "0"
        }
        // : barrier() — GPU workgroup synchronization (CPU: no-op)
        if funcName == "barrier" {
            output.append("  call void @seen_barrier()\n")
            return "0"
        }
        // : stackAlloc — delegated to ir_method_gen.seen
        if funcName == "stackAlloc" or funcName.startsWith("stackAlloc<") {
            var allocCount = "1"
            if expr.arguments.length() > 0 {
                allocCount = generateExpression(expr.arguments[0])
            }
            return emitStackAllocImpl(output, g_regBox, allocCount)
        }
        // : constructAt — delegated to ir_method_gen.seen
        if funcName == "constructAt" {
            if expr.arguments.length() >= 1 {
                let caPtr = generateExpression(expr.arguments[0])
                return emitConstructAtImpl(output, g_regBox, caPtr)
            }
            return "0"
        }

        // : debug_assert(condition) — delegated to ir_call_dispatch.seen
        if funcName == "debug_assert" {
            if g_boundsCheckEnabled == 1 {
                if expr.arguments.length() > 0 {
                    let condVal = generateExpression(expr.arguments[0])
                    var boundsCountBox = Array<Int>()
                    boundsCountBox.push(g_boundsCheckLabelCount)
                    emitDebugAssertCallImpl(output, g_regBox, boundsCountBox, condVal)
                    g_boundsCheckLabelCount = boundsCountBox[0]
                    cseClear()
                }
            }
            return "0"
        }

        // C string conversion builtins — delegated to ir_call_dispatch.seen
        if funcName == "str_to_cstr" {
            if expr.arguments.length() > 0 {
                let strArg = generateExpression(expr.arguments[0])
                return emitCStrConversionImpl(output, g_regBox, "str_to_cstr", strArg)
            }
            return "0"
        }
        if funcName == "split" {
            if expr.arguments.length() >= 2 {
                let textArg = generateExpression(expr.arguments[0])
                let delimArg = generateExpression(expr.arguments[1])
                let splitReg = getNextReg()
                output.append("  " + splitReg + " = call ptr @String_split(%SeenString " + textArg + ", %SeenString " + delimArg + ")\n")
                return splitReg
            }
        }
        if funcName == "cstr_to_str" {
            if expr.arguments.length() > 0 {
                let ptrArg = generateExpression(expr.arguments[0])
                return emitCStrConversionImpl(output, g_regBox, "cstr_to_str", ptrArg)
            }
            return "0"
        }

        // Inline __default<T>() as 0 - generic default is always null/zero
        if funcName == "__default" or funcName.startsWith("__default<") {
            return "0"
        }

        // async_yield() — delegated to ir_call_dispatch.seen
        if funcName == "async_yield" {
            var isInsideAsync = 0
            if g_asyncFunctionCoroHdl != "" {
                isInsideAsync = 1
            }
            if isInsideAsync == 1 {
                var yieldCounterBox = Array<Int>()
                yieldCounterBox.push(g_yieldCounter)
                emitAsyncYieldCallImpl(output, g_regBox, yieldCounterBox, g_asyncCleanupLabel)
                g_yieldCounter = yieldCounterBox[0]
            }
            return "0"
        }

        // SIMD builtins: constructors, load/store, select, shuffle, gather, scatter (/34/62/63/65)
        // Delegated to ir_type_tables.seen emitSimdBuiltinImpl
        let isSimdBuiltin = isSimdVectorType(funcName) == 1 or funcName.startsWith("simd_load_") or funcName.startsWith("simd_store_") or funcName == "simd_select" or funcName == "simd_shuffle" or funcName.startsWith("simd_gather_") or funcName.startsWith("simd_scatter_")
        if isSimdBuiltin {
            // Pre-generate all arguments
            var simdArgs = Array<String>()
            var simdArgTypes = Array<String>()
            var simdConstIndices = Array<Int>()
            var simdPreArgIdx = 0
            // For shuffle: first 2 args are vectors, rest are compile-time indices
            let isShuf = funcName == "simd_shuffle"
            while simdPreArgIdx < expr.arguments.length() {
                if isShuf and simdPreArgIdx >= 2 {
                    let shufConstIdx = evaluateConstExpr(expr.arguments[simdPreArgIdx])
                    simdConstIndices.push(shufConstIdx)
                } else {
                    let simdArgReg = generateExpression(expr.arguments[simdPreArgIdx])
                    simdArgs.push(simdArgReg)
                    let simdArgType = inferExpressionType(expr.arguments[simdPreArgIdx])
                    simdArgTypes.push(simdArgType)
                }
                simdPreArgIdx = simdPreArgIdx + 1
            }
            let simdResult = emitSimdBuiltinImpl(output, g_regBox, funcName, simdArgs, simdArgs.length(), simdArgTypes, simdConstIndices, simdConstIndices.length())
            if simdResult != "" {
                return simdResult
            }
        }

        // Indirect call: if callee is a local variable (closure/function pointer), do indirect call
        var icVarIdx = 0
        var icIsIndirect = false
        while icVarIdx < activeVarCount {
            if varNames[icVarIdx] == funcName {
                icIsIndirect = true
                break
            }
            icVarIdx = icVarIdx + 1
        }
        if icIsIndirect {
            let icFnPtrReg = getNextReg()
            output.append("  " + icFnPtrReg + " = load i64, ptr " + varRegs[icVarIdx] + "\n")
            let icFnPtrCast = getNextReg()
            output.append("  " + icFnPtrCast + " = inttoptr i64 " + icFnPtrReg + " to ptr\n")
            var icCallArgs = ""
            var icArgIdx = 0
            while icArgIdx < expr.arguments.length() {
                let icArgReg = generateExpression(expr.arguments[icArgIdx])
                if icArgIdx > 0 { icCallArgs = icCallArgs + ", " }
                icCallArgs = icCallArgs + "i64 " + icArgReg
                icArgIdx = icArgIdx + 1
            }
            let icResultReg = getNextReg()
            output.append("  " + icResultReg + " = call i64 " + icFnPtrCast + "(" + icCallArgs + ")\n")
            return icResultReg
        }

        // Enum variant constructor: only for data enums (with fields)
        // Simple enums (SeenTokenType etc.) are handled via normal call/member codegen
        if g_enumVariantCount > 0 {
            if isEnumVariant(funcName) {
                let varFieldCount = lookupEnumFieldCount(funcName)
                if varFieldCount > 0 {
                    return generateEnumConstructor(funcName, expr)
                }
            }
        }

        // Debug output for all calls to understand structure
        // Special case: Array<Type>() constructor - creates empty array
        // NOTE: Must check BEFORE stripping generic parameters
        if funcName.startsWith("Array<") or funcName == "Array" {
            // Extract element type from Array<ElementType>
            var elementType = ""
            if funcName.startsWith("Array<") and funcName.endsWith(">") {
                elementType = funcName.substring(6, funcName.length() - 1)
            }

            // Bulk initialization: Array<T>(count, value) — delegated to ir_call_dispatch.seen
            if expr.arguments.length() == 2 {
                let countReg = generateExpression(expr.arguments[0])
                let valueReg = generateExpression(expr.arguments[1])
                // Detect zero-fill from AST
                var isZeroFill = 0
                let fillValNode = expr.arguments[1]
                if fillValNode.kind == "Literal" and fillValNode.literalValue == "0" { isZeroFill = 1 }
                return emitArrayBulkInitImpl(output, g_regBox, g_blockBox, countReg, valueReg, elementType, isZeroFill, currentFunctionAlignTo())
            }

            // Pre-allocation constructor: Array<T>(capacity) — delegated to ir_call_dispatch.seen
            if expr.arguments.length() == 1 {
                let capReg = generateExpression(expr.arguments[0])
                var elemSz = 8
                if elementType == "String" { elemSz = 16 }
                if isDataType(elementType) { elemSz = getDataTypeSize(elementType) }
                return emitArrayPreallocImpl(output, g_regBox, capReg, elemSz)
            }

            // Inline zero-arg Array<T>() constructor — delegated to ir_call_dispatch.seen
            var elemSize = 8
            if funcName == "Array<String>" or funcName.startsWith("Array<String") { elemSize = 16 }
            if isDataType(elementType) { elemSize = getDataTypeSize(elementType) }
            return emitArrayInlineImpl(output, g_regBox, elemSize, currentFunctionAlignTo())
        }

        // SmallVec constructor — delegated to ir_call_dispatch.seen
        if funcName.startsWith("SmallVec<") or funcName.startsWith("SmallVec[") or funcName == "SmallVec" {
            var svCapArgReg = ""
            if expr.arguments.length() > 0 { svCapArgReg = generateExpression(expr.arguments[0]) }
            return emitSmallVecConstructorImpl(output, g_regBox, funcName, svCapArgReg)
        }

        // Vec<T>() creates a new empty Vec using C runtime
        // Must be BEFORE isClassType check since Vec is a class type
        // Collection constructors — delegated to ir_declarations.seen
        if funcName == "Vec" or funcName.startsWith("Vec<") or funcName == "BTreeMap" or funcName.startsWith("BTreeMap<") or funcName == "HashMap" or funcName.startsWith("HashMap<") or funcName == "LinkedList" or funcName.startsWith("LinkedList<") {
            var colCapArg = ""
            if expr.arguments.length() > 0 { colCapArg = generateExpression(expr.arguments[0]) }
            let colResult = emitCollectionConstructorImpl(output, g_regBox, funcName, colCapArg, expr.arguments.length())
            if colResult != "" { return colResult }
        }

        // Check if this is a class constructor call (e.g., Expr() creates new Expr instance)
        if isClassType(funcName) {
            // @repr(C) classes: stack-allocate value type instead of heap
            var isReprC = false
            if g_reprCClassNames != "" {
                if g_reprCClassNames.contains(funcName + "|") {
                    isReprC = true
                }
            }
            if isReprC {
                let structIdx = findStruct(funcName)
                if expr.arguments.length() == 0 or structIdx < 0 {
                    return "zeroinitializer"
                }
                // Pre-evaluate args and resolve field LLVM types for emitReprCConstructorImpl
                var reprCArgRegs = Array<String>()
                var reprCFieldTypes = Array<String>()
                var fieldTypesStr = structFieldTypes[structIdx]
                var reprCArgIdx = 0
                while reprCArgIdx < expr.arguments.length() {
                    reprCArgRegs.push(generateExpression(expr.arguments[reprCArgIdx]))
                    // Extract pipe-delimited Seen type at position reprCArgIdx
                    var rcTypePos = 0
                    var rcFldI = 0
                    while rcFldI < reprCArgIdx {
                        while rcTypePos < fieldTypesStr.length() and fieldTypesStr.byteAt(rcTypePos) != 124 { rcTypePos = rcTypePos + 1 }
                        rcTypePos = rcTypePos + 1
                        rcFldI = rcFldI + 1
                    }
                    var rcTypeEnd = rcTypePos
                    while rcTypeEnd < fieldTypesStr.length() and fieldTypesStr.byteAt(rcTypeEnd) != 124 { rcTypeEnd = rcTypeEnd + 1 }
                    reprCFieldTypes.push(mapType(fieldTypesStr.substring(rcTypePos, rcTypeEnd)))
                    reprCArgIdx = reprCArgIdx + 1
                }
                return emitReprCConstructorImpl(output, g_regBox, funcName, reprCArgRegs, reprCFieldTypes)
            }

            // Generate inline constructor: malloc + initialize fields + return pointer-as-int
            let structIdx = findStruct(funcName)
            let ptrReg = getNextReg()

            // Get struct size - use getDataTypeSize if we have field info, otherwise default
            var structSize = 8
            if structIdx >= 0 {
                // Use the registered struct size
                structSize = structSizes[structIdx]
                if structSize == 0 {
                    structSize = 16  // Default minimum for a class with at least one field
                }
            }

            // Allocate memory for the object (use pool allocator for small objects)
            if structSize <= 80 {
                output.append("  " + ptrReg + " = call ptr @seen_pool_alloc(i64 " + structSize.toString() + ")\n")
            }
            if structSize > 80 {
                output.append("  " + ptrReg + " = call ptr @malloc(i64 " + structSize.toString() + ")\n")
            }

            // Zero-initialize all fields with memset.
            // Avoids %ClassName GEP which requires the type definition in the current module -
            // cross-module construction would fail with "base element of getelementptr must be sized".
            // memset(ptr, 0, size) is correct for all field types:
            //   Int/Char/Float/class-ptr -> i64 0, Bool -> i1 false, String -> {0, null}, Array -> null
            output.append("  call void @llvm.memset.p0.i64(ptr " + ptrReg + ", i8 0, i64 " + structSize.toString() + ", i1 false)\n")

            // Initialize Array<T>/List<T> fields — memset leaves them as null ptrs (segfaults on .push())
            if structIdx >= 0 {
                var fieldNamesStr = structFieldNames[structIdx]
                var fieldTypesStr = structFieldTypes[structIdx]
                var byteOffset = 0
                var namePos = 0
                var typePos = 0
                var iterDone = 0
                while iterDone == 0 {
                    // Extract next field name (comma-delimited) — only to advance cursor
                    var nameEnd = namePos
                    while nameEnd < fieldNamesStr.length() and fieldNamesStr.byteAt(nameEnd) != 44 {
                        nameEnd = nameEnd + 1
                    }
                    // Extract next field type (pipe-delimited)
                    var typeEnd = typePos
                    while typeEnd < fieldTypesStr.length() and fieldTypesStr.byteAt(typeEnd) != 124 {
                        typeEnd = typeEnd + 1
                    }
                    var fieldSeenType = fieldTypesStr.substring(typePos, typeEnd)
                    // Emit init for Array<T> or List<T> fields
                    var isArrayField = 0
                    if fieldSeenType.startsWith("Array<") {
                        isArrayField = 1
                    }
                    if fieldSeenType.startsWith("List<") {
                        isArrayField = 1
                    }
                    if isArrayField == 1 {
                        let fieldPtrReg = getNextReg()
                        output.append("  " + fieldPtrReg + " = getelementptr inbounds i8, ptr " + ptrReg + ", i64 " + byteOffset.toString() + "\n")
                        // Extract element type from "Array<ElemType>" or "List<ElemType>"
                        var elemType = ""
                        if fieldSeenType.startsWith("Array<") {
                            elemType = fieldSeenType.substring(6, fieldSeenType.length() - 1)
                        }
                        if fieldSeenType.startsWith("List<") {
                            elemType = fieldSeenType.substring(5, fieldSeenType.length() - 1)
                        }
                        let arrInitReg = getNextReg()
                        if elemType == "String" {
                            output.append("  " + arrInitReg + " = call ptr @seen_arr_new_str_ptr()\n")
                        }
                        if elemType != "String" {
                            var usedSizeInit = 0
                            if isDataType(elemType) {
                                let elemSize = getDataTypeSize(elemType)
                                output.append("  " + arrInitReg + " = call ptr @seen_arr_new_with_size_ptr(i64 " + elemSize.toString() + ")\n")
                                usedSizeInit = 1
                            }
                            if usedSizeInit == 0 {
                                output.append("  " + arrInitReg + " = call ptr @seen_arr_new_ptr_ptr()\n")
                            }
                        }
                        output.append("  store ptr " + arrInitReg + ", ptr " + fieldPtrReg + "\n")
                    }
                    // Advance byte offset by this field's size
                    byteOffset = byteOffset + getTypeSize(fieldSeenType)
                    // Advance to next field
                    if nameEnd < fieldNamesStr.length() {
                        namePos = nameEnd + 1
                        typePos = typeEnd + 1
                    }
                    if nameEnd >= fieldNamesStr.length() {
                        iterDone = 1
                    }
                }
            }

            // Initialize positional constructor arguments in field order.
            // ClassName(a, b) should populate the first fields rather than
            // returning a zeroed object.
            if structIdx >= 0 and expr.arguments.length() > 0 {
                var ctorFieldTypesStr = structFieldTypes[structIdx]
                var ctorByteOffset = 0
                var ctorTypePos = 0
                var ctorArgIdx = 0
                while ctorArgIdx < expr.arguments.length() and ctorTypePos < ctorFieldTypesStr.length() {
                    var ctorTypeEnd = ctorTypePos
                    while ctorTypeEnd < ctorFieldTypesStr.length() and ctorFieldTypesStr.byteAt(ctorTypeEnd) != 124 {
                        ctorTypeEnd = ctorTypeEnd + 1
                    }
                    var ctorFieldSeenType = ctorFieldTypesStr.substring(ctorTypePos, ctorTypeEnd)
                    let ctorArgExpr = expr.arguments[ctorArgIdx]
                    let ctorArgReg = generateExpression(ctorArgExpr)
                    let ctorFieldPtrReg = getNextReg()
                    output.append("  " + ctorFieldPtrReg + " = getelementptr inbounds i8, ptr " + ptrReg + ", i64 " + ctorByteOffset.toString() + "\n")
                    if isDataType(ctorFieldSeenType) {
                        if ctorArgExpr.kind == "StructLiteral" {
                            let ctorFieldSize = getDataTypeSize(ctorFieldSeenType)
                            output.append("  call void @llvm.memcpy.p0.p0.i64(ptr " + ctorFieldPtrReg + ", ptr " + ctorArgReg + ", i64 " + ctorFieldSize.toString() + ", i1 false)\n")
                        } else {
                            output.append("  store %" + ctorFieldSeenType + " " + ctorArgReg + ", ptr " + ctorFieldPtrReg + "\n")
                        }
                    } else {
                        let ctorFieldLlvmType = mapType(ctorFieldSeenType)
                        var ctorStoreReg = ctorArgReg
                        if ctorFieldLlvmType == "ptr" and ctorStoreReg == "0" {
                            ctorStoreReg = "null"
                        }
                        output.append("  store " + ctorFieldLlvmType + " " + ctorStoreReg + ", ptr " + ctorFieldPtrReg + "\n")
                    }
                    ctorByteOffset = ctorByteOffset + getTypeSize(ctorFieldSeenType)
                    ctorArgIdx = ctorArgIdx + 1
                    if ctorTypeEnd < ctorFieldTypesStr.length() {
                        ctorTypePos = ctorTypeEnd + 1
                    } else {
                        ctorTypePos = ctorFieldTypesStr.length()
                    }
                }
            }

            // Convert pointer to i64 (class types are stored as pointer-as-int)
            let intReg = getNextReg()
            output.append("  " + intReg + " = ptrtoint ptr " + ptrReg + " to i64\n")
            return intReg
        }

        // Strip generic parameters from function name (e.g., "Err<String, String>" -> "Err")
        if funcName.contains("<") {
            var ltIdx = 0
            var scanIdx = 0
            while scanIdx < funcName.length() {
                if funcName.byteAt(scanIdx) == 60 {
                    ltIdx = scanIdx
                    scanIdx = funcName.length()
                }
                scanIdx = scanIdx + 1
            }
            if ltIdx > 0 {
                funcName = funcName.substring(0, ltIdx)
            }
        }

        // INLINE SOME/NONE GENERATION
        // Generate LLVM IR inline for Some/None to avoid ABI mismatches between
        // C runtime (pointer model) and Seen stdlib (struct model)
        // Option layout: { i1 hasValue, i64 value } - 16 bytes total
        // Some/None constructors — delegated to ir_declarations.seen
        if funcName == "Some" {
            var argReg = "0"
            var argType = "Int"
            if expr.arguments.length() > 0 {
                argReg = generateExpression(expr.arguments[0])
                argType = inferExpressionType(expr.arguments[0])
            }
            var isClassArg = 0
            if isClassType(argType) { isClassArg = 1 }
            return emitSomeConstructorImpl(output, g_regBox, argReg, argType, isClassArg)
        }
        if funcName == "None" {
            return emitNoneConstructorImpl(output, g_regBox)
        }

        // Special case: super() parent constructor call
        if funcName == "super" {
            if g_currentClassParentName != "" {
                let thisIdx = findVar("this")
                if thisIdx >= 0 {
                    let thisAlloca = varRegs[thisIdx]
                    let thisVal = getNextReg()
                    output.append("  " + thisVal + " = load ptr, ptr " + thisAlloca + "\n")
                    output.append("  call void @" + quoteIdentIfNeeded(g_currentClassParentName + "_init") + "(ptr " + thisVal + ")\n")
                }
            }
            return "0"
        }
        if funcName == "" {
            // Empty function name: evaluate arguments for side effects only
            var i = 0
            while i < expr.arguments.length() {
                generateExpression(expr.arguments[i])
                i = i + 1
            }
            return "0"
        }

        // Special case: println
        if funcName == "println" {
            if expr.arguments.length() > 0 {
                let argType = inferExpressionType(expr.arguments[0])
                let argReg = generateExpression(expr.arguments[0])
                var strReg = argReg
                if argType == "Int" {
                    strReg = getNextReg()
                    output.append("  " + strReg + " = call %SeenString @seen_int_to_string(i64 " + argReg + ")\n")
                } else {
                    if argType == "Float" {
                        strReg = getNextReg()
                        output.append("  " + strReg + " = call %SeenString @seen_float_to_string(double " + argReg + ")\n")
                    } else {
                        if argType == "Bool" {
                            strReg = getNextReg()
                            output.append("  " + strReg + " = call %SeenString @seen_bool_to_string(i1 " + argReg + ")\n")
                        } else {
                            if argType == "Char" {
                                strReg = getNextReg()
                                output.append("  " + strReg + " = call %SeenString @seen_char_to_str(i64 " + argReg + ")\n")
                            }
                        }
                    }
                }
                output.append("  call void @println(%SeenString " + strReg + ")\n")
            }
            return "0"
        }

        // Special case: print (no newline)
        if funcName == "print" {
            if expr.arguments.length() > 0 {
                let argType = inferExpressionType(expr.arguments[0])
                let argReg = generateExpression(expr.arguments[0])
                var strReg = argReg
                if argType == "Int" {
                    strReg = getNextReg()
                    output.append("  " + strReg + " = call %SeenString @seen_int_to_string(i64 " + argReg + ")\n")
                } else {
                    if argType == "Float" {
                        strReg = getNextReg()
                        output.append("  " + strReg + " = call %SeenString @seen_float_to_string(double " + argReg + ")\n")
                    } else {
                        if argType == "Bool" {
                            strReg = getNextReg()
                            output.append("  " + strReg + " = call %SeenString @seen_bool_to_string(i1 " + argReg + ")\n")
                        } else {
                            if argType == "Char" {
                                strReg = getNextReg()
                                output.append("  " + strReg + " = call %SeenString @seen_char_to_str(i64 " + argReg + ")\n")
                            }
                        }
                    }
                }
                output.append("  call void @print(%SeenString " + strReg + ")\n")
            }
            return "0"
        }

        // Special case: readText
        if funcName == "readText" {
            if expr.arguments.length() > 0 {
                let argReg = generateExpression(expr.arguments[0])
                let resultReg = getNextReg()
                output.append("  " + resultReg + " = call %SeenString @readText(%SeenString " + argReg + ")\n")
                return resultReg
            }
            return "0"
        }

        // Special case: writeText
        if funcName == "writeText" {
            if expr.arguments.length() >= 2 {
                let pathReg = generateExpression(expr.arguments[0])
                let contentReg = generateExpression(expr.arguments[1])
                let resultReg = getNextReg()
                output.append("  " + resultReg + " = call i1 @writeText(%SeenString " + pathReg + ", %SeenString " + contentReg + ")\n")
                return resultReg
            }
            return "0"
        }

        // Special case: args() returns ptr to heap-allocated SeenArray
        if funcName == "args" {
            let resultReg = getNextReg()
            output.append("  " + resultReg + " = call ptr @args()\n")
            // Return pointer to heap-allocated array (arrays are stored as ptr)
            return resultReg
        }

        // Special case: panic(msg) — abort with message and stack trace
        if funcName == "panic" {
            if expr.arguments.length() > 0 {
                let argReg = generateExpression(expr.arguments[0])
                let lenReg = getNextReg()
                let dataReg = getNextReg()
                output.append("  " + lenReg + " = extractvalue %SeenString " + argReg + ", 0\n")
                output.append("  " + dataReg + " = extractvalue %SeenString " + argReg + ", 1\n")
                output.append("  call void @__panic(i64 " + lenReg + ", ptr " + dataReg + ") noreturn\n")
                output.append("  unreachable\n")
            }
            return "0"
        }

        // Check if this is a method call on the current class (implicit this)
        // This handles calls like foo(x) inside a class method when foo is a method of the same class
        let thisIdx = findVar("this")
        if thisIdx >= 0 {
            let thisType = varTypes[thisIdx]

            // Special handling for misplaced RealParser class methods
            // These methods were incorrectly parsed as standalone functions but should be class methods
            let isMisplacedMethod = funcName == "isAtEnd" or funcName == "peek" or funcName == "peekTokenType" or funcName == "peekTokenTypeStr" or funcName == "previous" or funcName == "advance" or funcName == "consume" or funcName == "checkToken" or funcName == "matchTokenStr" or funcName == "skipExpression" or funcName == "toArray" or funcName == "parseExpressionStatement" or funcName == "parseReturnStatement" or funcName == "parseIfStatement" or funcName == "parseWhileStatement" or funcName == "parseLetStatement" or funcName == "parseVarStatement" or funcName == "parseStatement" or funcName == "parseExpression" or funcName == "parseAssignment" or funcName == "parseOr" or funcName == "parseAnd" or funcName == "parseEquality" or funcName == "parseComparison" or funcName == "parseTerm" or funcName == "parseFactor" or funcName == "parseUnary" or funcName == "parseCall" or funcName == "parsePrimary" or funcName == "parseBlock" or funcName == "parseParam" or funcName == "parseTypeNode" or funcName == "parseOptionalTypeAnnotation" or funcName == "parseOptionalReturnType" or funcName == "parseImportPath" or funcName == "parseImportSymbols" or funcName == "parseParameterList" or funcName == "parseFunctionItem" or funcName == "parseClassItem" or funcName == "parseEnumItem" or funcName == "parseImportItem" or funcName == "makeImportSymbol" or funcName == "inferVisibility" or funcName == "joinSegments" or funcName == "parseExpressionStatementByIdx" or funcName == "parseReturnStatementByIdx" or funcName == "parseIfStatementByIdx" or funcName == "parseWhileStatementByIdx" or funcName == "parseLetStatementByIdx" or funcName == "parseVarStatementByIdx" or funcName == "parseStatementInto" or funcName == "parseExpressionStatementInto" or funcName == "parseReturnStatementInto" or funcName == "parseIfStatementInto" or funcName == "parseWhileStatementInto" or funcName == "parseLetStatementInto" or funcName == "parseVarStatementInto" or funcName == "parseExpressionInto" or funcName == "parseExpressionIntoField" or funcName == "parseLetStatementField" or funcName == "parseVarStatementField" or funcName == "parseReturnStatementField" or funcName == "parseIfStatementField" or funcName == "parseWhileStatementField" or funcName == "parseExpressionStatementField" or funcName == "parseParameterListField" or funcName == "parseFunctionItemInto" or funcName == "parseClassItemInto" or funcName == "parseEnumItemInto" or funcName == "parseImportItemInto"
            if isMisplacedMethod and thisType == "RealParser" {
                // Generate call to the class method version
                let thisReg = varRegs[thisIdx]
                var argRegs = Array<String>()
                var argTypeStrs = Array<String>()
                var argIdx = 0
                prepareCallArguments(thisType + "_" + funcName, expr.arguments, argRegs, argTypeStrs, false, false, false, "")

                // Determine return type for misplaced methods
                var misplacedRetType = "ptr"
                var misplacedResolved = false
                if funcName == "isAtEnd" or funcName == "checkToken" or funcName == "matchTokenStr" {
                    misplacedRetType = "i1"
                    misplacedResolved = true
                }
                // Token-returning methods: consume, advance, peek, previous return Token (class type stored as i64)
                if not misplacedResolved and (funcName == "consume" or funcName == "advance" or funcName == "peek" or funcName == "previous") {
                    misplacedRetType = "i64"
                    misplacedResolved = true
                }
                if not misplacedResolved and funcName == "peekTokenType" {
                    misplacedRetType = "i64"
                    misplacedResolved = true
                }
                if not misplacedResolved and (funcName == "peekTokenTypeStr" or funcName == "inferVisibility" or funcName == "joinSegments") {
                    misplacedRetType = "%SeenString"
                    misplacedResolved = true
                }
                if not misplacedResolved and funcName == "parseParameterList" {
                    // parseParameterList returns Void (use i64 for void-like)
                    misplacedRetType = "i64"
                    misplacedResolved = true
                }
                if not misplacedResolved and funcName == "parseImportSymbols" {
                    misplacedRetType = "ptr"  // Array returned as pointer
                    misplacedResolved = true
                }
                // Parse methods returning class types (stored as i64)
                if not misplacedResolved and funcName == "parseBlock" {
                    misplacedRetType = "i64"  // BlockNode is a class type
                    misplacedResolved = true
                }
                // Parse methods returning data types (inline structs)
                if not misplacedResolved and (funcName == "parseOptionalReturnType" or funcName == "parseOptionalTypeAnnotation" or funcName == "parseTypeNode") {
                    misplacedRetType = "%TypeNode"  // TypeNode is a data type
                    misplacedResolved = true
                }
                if not misplacedResolved and funcName == "parseParam" {
                    misplacedRetType = "i64"  // ParamNode is a class type (heap-allocated i64 handle)
                    misplacedResolved = true
                }
                if not misplacedResolved and (funcName == "parsePrimary" or funcName == "parseCall" or funcName == "parseUnary" or funcName == "parseFactor" or funcName == "parseTerm" or funcName == "parseComparison" or funcName == "parseEquality" or funcName == "parseAnd" or funcName == "parseOr" or funcName == "parseAssignment" or funcName == "parseExpression") {
                    misplacedRetType = "i64"  // ParserExpressionNode
                    misplacedResolved = true
                }
                if not misplacedResolved and (funcName == "parseStatement" or funcName == "parseIfStatement" or funcName == "parseWhileStatement" or funcName == "parseLetStatement" or funcName == "parseVarStatement" or funcName == "parseExpressionStatement" or funcName == "parseReturnStatement") {
                    misplacedRetType = "i64"  // StatementNode
                    misplacedResolved = true
                }
                if not misplacedResolved and (funcName == "parseFunctionItem" or funcName == "parseClassItem" or funcName == "parseEnumItem" or funcName == "parseImportItem") {
                    misplacedRetType = "i64"  // ItemNode is a class type (heap-allocated i64 handle)
                    misplacedResolved = true
                }
                if not misplacedResolved and funcName == "makeImportSymbol" {
                    misplacedRetType = "i64"  // ImportSymbolNode is a class type (heap-allocated, stored as i64)
                    misplacedResolved = true
                }
                if not misplacedResolved and funcName == "parseImportPath" {
                    misplacedRetType = "%ImportPathInfo"  // ImportPathInfo is a data type
                    misplacedResolved = true
                }

                let methodFuncName = thisType + "_" + funcName
                fillDefaultParamsLocal(methodFuncName, argRegs, argTypeStrs)
                argRegs = g_defaultFillArgRegs
                argTypeStrs = g_defaultFillArgTypeStrs

                // Tail call optimization for misplaced method calls
                var mpCallPrefix = "call"
                if takeTailCallPosition() {
                    mpCallPrefix = "tail call"
                }

                // Load this pointer
                let thisPtrReg = getNextReg()
                output.append("  " + thisPtrReg + " = load ptr, ptr " + thisReg + "\n")

                if misplacedRetType == "void" {
                    output.append("  call void @" + quoteIdentIfNeeded(methodFuncName) + "(ptr " + thisPtrReg)
                    argIdx = 0
                    while argIdx < argRegs.length() {
                        output.append(", " + argTypeStrs[argIdx] + " " + argRegs[argIdx])
                        argIdx = argIdx + 1
                    }
                    output.append(")\n")
                    return "0"
                }
                if misplacedRetType != "void" {
                    let resultReg = getNextReg()
                    output.append("  " + resultReg + " = " + mpCallPrefix + " " + misplacedRetType + " @" + quoteIdentIfNeeded(methodFuncName) + "(ptr " + thisPtrReg)
                    argIdx = 0
                    while argIdx < argRegs.length() {
                        output.append(", " + argTypeStrs[argIdx] + " " + argRegs[argIdx])
                        argIdx = argIdx + 1
                    }
                    output.append(")\n")
                    return resultReg
                }
            }

            // Check if the function is a method of the current class
            let methodRetType = getMethodReturnType(thisType, funcName)
            if methodRetType != "" {
                // This is an implicit method() call
                let thisReg = varRegs[thisIdx]
                var argRegs = Array<String>()
                var argTypeStrs = Array<String>()
                var argIdx = 0
                prepareCallArguments(thisType + "_" + funcName, expr.arguments, argRegs, argTypeStrs, false, true, false, "")

                if thisType == "StringBuilder" and (funcName == "append" or funcName == "appendInt" or funcName == "appendFloat" or funcName == "appendChar" or funcName == "clear" or funcName == "length" or funcName == "toString") {
                    let thisPtrReg = getNextReg()
                    output.append("  " + thisPtrReg + " = load ptr, ptr " + thisReg + "\n")
                    var sbArg0 = ""
                    if argRegs.length() > 0 {
                        sbArg0 = argRegs[0]
                    }
                    return emitStringBuilderMethodImpl(output, g_regBox, funcName, thisPtrReg, sbArg0, 0)
                }

                let methodFuncName = thisType + "_" + funcName
                fillDefaultParamsLocal(methodFuncName, argRegs, argTypeStrs)
                argRegs = g_defaultFillArgRegs
                argTypeStrs = g_defaultFillArgTypeStrs
                let llvmReturnType = mapType(methodRetType)

                // Tail call optimization for implicit self-method calls
                var selfCallPrefix = "call"
                if takeTailCallPosition() {
                    selfCallPrefix = "tail call"
                }

                // Load this pointer
                let thisPtrReg = getNextReg()
                output.append("  " + thisPtrReg + " = load ptr, ptr " + thisReg + "\n")

                if llvmReturnType == "void" {
                    output.append("  call void @" + quoteIdentIfNeeded(methodFuncName) + "(ptr " + thisPtrReg)
                    argIdx = 0
                    while argIdx < argRegs.length() {
                        output.append(", " + argTypeStrs[argIdx] + " " + argRegs[argIdx])
                        argIdx = argIdx + 1
                    }
                    output.append(")\n")
                    return "0"
                }

                let resultReg = getNextReg()
                output.append("  " + resultReg + " = " + selfCallPrefix + " " + llvmReturnType + " @" + quoteIdentIfNeeded(methodFuncName) + "(ptr " + thisPtrReg)
                argIdx = 0
                while argIdx < argRegs.length() {
                    output.append(", " + argTypeStrs[argIdx] + " " + argRegs[argIdx])
                    argIdx = argIdx + 1
                }
                output.append(")\n")
                return resultReg
            }
        }

        // Math builtins + __ExecuteCommand — delegated to ir_declarations.seen
        if funcName == "__Sqrt" or funcName == "__Sin" or funcName == "__Cos" or funcName == "__Exp" or funcName == "__Log" or funcName == "__Log10" or funcName == "__Fabs" or funcName == "__Pow" or funcName == "__Asin" or funcName == "__Acos" or funcName == "__Atan" or funcName == "__Sinh" or funcName == "__Cosh" or funcName == "__Tanh" or funcName == "__Tan" or funcName == "__Atan2" or funcName == "__ExecuteCommand" or funcName == "absFloat" or funcName == "absInt" or funcName == "minInt" or funcName == "maxInt" {
            var mArg0 = ""
            var mArg1 = ""
            if expr.arguments.length() > 0 { mArg0 = generateExpression(expr.arguments[0]) }
            if expr.arguments.length() > 1 { mArg1 = generateExpression(expr.arguments[1]) }
            let mResult = emitMathBuiltinImpl(output, g_regBox, funcName, mArg0, mArg1)
            if mResult != "" { return mResult }
        }

        // Generic function call - generate args first, then result reg
        var argRegs = Array<String>()
        var argTypeStrs = Array<String>()
        var argIdx = 0
        prepareCallArguments(funcName, expr.arguments, argRegs, argTypeStrs, true, false, true, "fn call")

        // Default parameter injection — delegated to ir_call_dispatch.seen
        fillDefaultParamsLocal(funcName, argRegs, argTypeStrs)
        argRegs = g_defaultFillArgRegs
        argTypeStrs = g_defaultFillArgTypeStrs

        if currentClassName == "JsonParseResult" or currentClassName == "JsonParser" or currentClassName == "LLVMIRGenerator" {
            println("[irgen call pre-promote] class=" + currentClassName + " func=" + funcName + " regs=" + argRegs.length().toString() + " types=" + argTypeStrs.length().toString())
        }

        // Int→Float promotion — delegated to ir_call_dispatch.seen
        if argRegs.length() == argTypeStrs.length() and g_floatParamFuncNames.length() > 0 and g_floatParamParamIdxs.length() > 0 {
            promoteFloatArgsImpl(output, g_regBox, funcName, argRegs, argTypeStrs, g_floatParamFuncNames, g_floatParamParamIdxs)
        }

        // Infer return type from function name
        let returnType = inferExpressionType(expr)
        var llvmReturnType = mapType(returnType)
        if isAsyncFunction(funcName) {
            llvmReturnType = "ptr"
        }

        // For void functions, don't assign result
        if llvmReturnType == "void" {
            recordLateUserDeclare(funcName, llvmReturnType, argTypeStrs, 0)
            if takeTailCallPosition() {
                // Tail-position bookkeeping is transient even for void calls.
            }
            output.append("  call void @" + quoteIdentIfNeeded(funcName) + "(")

            argIdx = 0
            while argIdx < argRegs.length() {
                if argIdx > 0 {
                    output.append(", ")
                }
                output.append(argTypeStrs[argIdx] + " " + argRegs[argIdx])
                argIdx = argIdx + 1
            }

            output.append(")\n")
            return "0"  // No result for void functions
        }

        let resultReg = getNextReg()
        // Tail call optimization: emit 'tail call' for calls in return position
        var callPrefix = "call"
        recordLateUserDeclare(funcName, llvmReturnType, argTypeStrs, 0)
        if takeTailCallPosition() {
            callPrefix = "tail call"
        }
        output.append("  " + resultReg + " = " + callPrefix + " " + llvmReturnType + " @" + quoteIdentIfNeeded(funcName) + "(")

        argIdx = 0
        while argIdx < argRegs.length() {
            if argIdx > 0 {
                output.append(", ")
            }
            output.append(argTypeStrs[argIdx] + " " + argRegs[argIdx])
            argIdx = argIdx + 1
        }

        output.append(")\n")
        return resultReg
    }

    // Generate IR for a method call (receiver.method(args)). The largest and
    // most complex dispatch in the codegen — handles:
    //   - SIMD horizontal reductions (reduce_add/min/max)
    //   - Option methods (isSome/isNone/unwrap — inlined as null checks)
    //   - Hot-reload synthesized methods (__seen_hot_get_size etc.)
    //   - Collection methods: Vec, HashMap, BTreeMap, LinkedList (dispatched
    //     to type-specialized runtime functions via dispatchCollectionMethodImpl)
    //   - String methods (length, contains, indexOf, split, trim, etc.)
    //   - StringBuilder methods (append, toString)
    //   - Array methods (push, get, set, length, pop, etc. with type dispatch
    //     for Int/String/Float/Bool/data-type element types)
    //   - SmallVec/JsonValue methods
    //   - Numeric methods (toString, toFloat, abs, etc.)
    //   - User-defined class methods (ClassName_methodName mangling)
    //   - Simple variable receivers (separate handling path when operands is
    //     empty but callee contains the receiver)
    // NOTE: HashMap/BTreeMap methods must be handled in TWO locations — inside
    // the "operands.length() > 0" path AND the "simple variable receivers"
    // fallback section.
    fun generateMethodCall(expr: ParserExpressionNode) r: String {
        let methodName = expr.callee
        // Get receiver
        var receiverReg = ""
        var receiverType = "String"  // Default assumption for method calls

        if expr.operands.length() == 0 and expr.literalValue.contains(".") {
            let receiverSegments = splitChainedPath(expr.literalValue)
            if receiverSegments.length() > 0 {
                let baseReceiverName = receiverSegments[0]
                if findVarType(baseReceiverName) != "" {
                    let rebuiltReceiverExpr = buildChainedPathExpr(expr.literalValue)
                    if rebuiltReceiverExpr.kind != "None" {
                        receiverReg = generateExpression(rebuiltReceiverExpr)
                        receiverType = inferExpressionType(rebuiltReceiverExpr)
                    }
                }
            }
        }

        if expr.operands.length() > 0 {
            // Complex receiver (e.g., chained method call or expression)
            receiverReg = generateExpression(expr.operands[0])
            receiverType = inferExpressionType(expr.operands[0])

            // SIMD horizontal reduction ops — delegated to ir_type_tables.seen
            let simdRedResult = emitSimdReductionImpl(output, g_regBox, methodName, receiverReg, receiverType)
            if simdRedResult != "" { return simdRedResult }

            // dyn Trait vtable dispatch: receiver is fat pointer { ptr data, ptr vtable }
            if receiverType.startsWith("dyn ") {
                let dynTraitName = receiverType.substring(4, receiverType.length())
                // Look up trait method names and return types from registry
                let dynTraitIdx = findStruct(dynTraitName)
                var dynMethodNames = ""
                var dynRetTypes = ""
                if dynTraitIdx >= 0 {
                    dynMethodNames = structMethodNames[dynTraitIdx]
                    dynRetTypes = structMethodRetTypes[dynTraitIdx]
                }
                // Generate argument registers and types
                var dynArgRegs = Array<String>()
                var dynArgTypes = Array<String>()
                var dynAIdx = 0
                while dynAIdx < expr.arguments.length() {
                    let dynArgReg = generateExpression(expr.arguments[dynAIdx])
                    let dynArgType = inferExpressionType(expr.arguments[dynAIdx])
                    dynArgRegs.push(dynArgReg)
                    dynArgTypes.push(mapType(dynArgType))
                    dynAIdx = dynAIdx + 1
                }
                // Complex receivers pass data as ptr (useI64DataArg=0)
                return emitDynTraitVtableCallImpl(output, g_regBox, receiverReg, dynTraitName, methodName, dynMethodNames, dynRetTypes, dynArgRegs, dynArgTypes, 0)
            }

            // Fallback: Option methods should never use String as receiver
            // This handles cases where type inference fails for generic types
            if receiverType == "String" or receiverType == "" or receiverType == "Unknown" {
                if methodName == "isSome" or methodName == "isNone" or methodName == "unwrap" {
                    receiverType = "Option"
                }
            }

            // INLINE OPTION METHOD HANDLING (delegated to ir_type_tables.seen)
            let isOptionType = receiverType == "Option" or receiverType.startsWith("Option<")
            if isOptionType {
                var optDefaultReg = "0"
                if (methodName == "unwrapOr" or methodName == "UnwrapOr") and expr.arguments.length() > 0 {
                    optDefaultReg = generateExpression(expr.arguments[0])
                }
                let optResult = emitOptionMethodImpl(output, g_regBox, g_blockLabelBox, methodName, receiverReg, optDefaultReg)
                if optResult != "" {
                    return optResult
                }
            }

            // @hot_reload synthesized method intercept
            // These methods are generated by generateHotReloadMethods and return i64.
            // inferExpressionType won't find them in the registry, so we intercept here.
            // Note: methodName includes "__" prefix, so use "_" separator (not "___").
            // e.g. receiverType="GameState", methodName="__seen_hot_get_size"
            //   → @GameState___seen_hot_get_size (1 sep "_" + 2 from method = 3 total)
            if methodName == "__seen_hot_get_size" or methodName == "__seen_hot_get_version" or methodName == "__seen_hot_get_state" {
                let hotRecvPtr = convertReceiverToPtr(receiverReg, receiverType)
                let hotResultReg = getNextReg()
                output.append("  " + hotResultReg + " = call i64 @" + quoteIdentIfNeeded(receiverType + "_" + methodName) + "(ptr " + hotRecvPtr + ")\n")
                return hotResultReg
            }
            if methodName == "__seen_hot_set_state" {
                let hotRecvPtr2 = convertReceiverToPtr(receiverReg, receiverType)
                var hotStateArg = "0"
                if expr.arguments.length() > 0 {
                    hotStateArg = generateExpression(expr.arguments[0])
                }
                output.append("  call void @" + quoteIdentIfNeeded(receiverType + "_" + methodName) + "(ptr " + hotRecvPtr2 + ", i64 " + hotStateArg + ")\n")
                return "0"
            }

            // INLINE COLLECTION METHOD HANDLING (delegated to ir_type_tables.seen dispatchCollectionMethodImpl)
            let isCollectionTypeC = receiverType.startsWith("Vec<") or receiverType == "Vec" or receiverType.startsWith("BTreeMap<") or receiverType == "BTreeMap" or receiverType.startsWith("HashMap<") or receiverType == "HashMap" or receiverType.startsWith("StringHashMap<") or receiverType == "StringHashMap" or receiverType.startsWith("LinkedList<") or receiverType == "LinkedList"
            if isCollectionTypeC {
                var collArg0c = "0"
                var collArg1c = "0"
                if expr.arguments.length() > 0 {
                    collArg0c = generateExpression(expr.arguments[0])
                }
                if expr.arguments.length() > 1 {
                    collArg1c = generateExpression(expr.arguments[1])
                }
                let collResultC = dispatchCollectionMethodImpl(output, g_regBox, methodName, receiverReg, receiverType, collArg0c, collArg1c)
                if collResultC != "" {
                    return collResultC
                }
            }
        }
        if receiverReg == "" and expr.operands.length() == 0 and expr.literalValue.contains(".") {
            // Check for enum method calls like SeenTokenType.RightBrace.toString()
            let path = expr.literalValue

            // Find the dot index manually
            var dotIdx = 0
            var searchIdx = 0
            while searchIdx < path.length() {
                if path.byteAt(searchIdx) == 46 {
                    dotIdx = searchIdx
                    searchIdx = path.length()  // Exit loop
                }
                searchIdx = searchIdx + 1
            }

            let varName = path.substring(0, dotIdx)
            let fieldName = path.substring(dotIdx + 1, path.length())

            // Handle enum method calls: SeenTokenType.RightBrace.toString()
            var handledEnumMethod = false
            if varName == "SeenTokenType" {
                // Get the enum value as an integer
                let enumValue = getSeenTokenTypeValue(fieldName)
                receiverReg = enumValue.toString()
                receiverType = "Int"  // Enum values are integers
                // Continue to method call generation below (skip field access code)
                handledEnumMethod = true
            }
            if not handledEnumMethod {
                // Chained field access like diag.line.toString()
                // literalValue = "diag.line", callee = "toString"
                // Need to parse and load the field
                let idx = findVar(varName)
                var varFoundInLocalScope = false
                if idx >= 0 {
                varFoundInLocalScope = true
                let varReg = varRegs[idx]
                let varType = varTypes[idx]

                // Load the struct - class types are stored as i64, data types are inline
                // @repr(C): load as value type and use extractvalue
                var ptrReg = ""
                var reprCHandled = false
                if g_reprCClassNames != "" {
                    if g_reprCClassNames.contains(varType + "|") {
                        let rcLoadReg = getNextReg()
                        output.append("  " + rcLoadReg + " = load %" + varType + ", ptr " + varReg + "\n")
                        receiverReg = generateFieldAccess(rcLoadReg, varType, fieldName)
                        reprCHandled = true
                    }
                }
                if not reprCHandled {
                if isClassType(varType) {
                    let loadReg = getNextReg()
                    output.append("  " + loadReg + " = load i64, ptr " + varReg + "\n")
                    ptrReg = getNextReg()
                    output.append("  " + ptrReg + " = inttoptr i64 " + loadReg + " to ptr\n")
                } else if isDataType(varType) {
                    // Data types are stored inline - use the alloca pointer directly
                    ptrReg = varReg
                } else {
                    ptrReg = getNextReg()
                    output.append("  " + ptrReg + " = load ptr, ptr " + varReg + "\n")
                }

                // Generate field access
                receiverReg = generateFieldAccess(ptrReg, varType, fieldName)
                }

                // Infer receiver type from field - handle chained field names
                // FIRST: Try receiver-based lookup using getSeenFieldType
                // Only for simple field names (not chained paths like "program.items")
                var fieldTypeResolved = false
                if not fieldName.contains(".") {
                    let lookupFieldType = getSeenFieldType(varType, fieldName)
                    if lookupFieldType != "" and lookupFieldType != "Int" {
                        receiverType = lookupFieldType
                        fieldTypeResolved = true
                    }
                }
                // FALLBACK: Generic field name mappings (for backwards compatibility)
                if not fieldTypeResolved {
                    let mappedType = mapFieldNameToReceiverType(fieldName)
                    if mappedType != "" {
                        receiverType = mappedType
                        fieldTypeResolved = true
                    }
                }
                if not fieldTypeResolved and fieldName.contains(".") {
                    // Handle chained field names by walking through types
                    var currentType = varType
                    var remainingPath = fieldName
                    while remainingPath.length() > 0 and currentType != "" and currentType != "Int" {
                        var nextDot = -1
                        var searchIdx = 0
                        while searchIdx < remainingPath.length() {
                            if remainingPath.byteAt(searchIdx) == 46 {
                                nextDot = searchIdx
                                searchIdx = remainingPath.length()
                            }
                            searchIdx = searchIdx + 1
                        }
                        var currField = ""
                        if nextDot < 0 {
                            currField = remainingPath
                            remainingPath = ""
                        }
                        if nextDot >= 0 {
                            currField = remainingPath.substring(0, nextDot)
                            remainingPath = remainingPath.substring(nextDot + 1, remainingPath.length())
                        }
                        currentType = getSeenFieldType(currentType, currField)
                    }
                    receiverType = currentType
                    fieldTypeResolved = true
                }
                if not fieldTypeResolved {
                    receiverType = getSeenFieldType(varType, fieldName)
                }
            }
            if not varFoundInLocalScope {
                // varName is not a local variable - check if it's a field on 'this'
                let thisIdx = findVar("this")
                if thisIdx >= 0 {
                    let thisReg = varRegs[thisIdx]
                    let thisType = varTypes[thisIdx]

                    // Check if this type has the field
                    let structIdx = findStruct(thisType)
                    output.append("; DEBUG chainedFieldAccess: varName=" + varName + " fieldName=" + fieldName + " thisType=" + thisType + " structIdx=" + structIdx.toString() + "\n")
                    if structIdx >= 0 {
                        let fieldIdx = getFieldInfo(thisType, varName)
                        output.append("; DEBUG chainedFieldAccess: fieldIdx=" + fieldIdx.toString() + "\n")
                        if fieldIdx >= 0 {
                            // Load 'this' pointer
                            let thisPtrReg = getNextReg()
                            output.append("  " + thisPtrReg + " = load ptr, ptr " + thisReg + "\n")

                            // Get the type of the first field (varName)
                            let firstFieldType = getSeenFieldType(thisType, varName)
                            output.append("; DEBUG chainedFieldAccess: firstFieldType=" + firstFieldType + "\n")

                            // Resolve pointer to the first field (class -> i64 to ptr, data -> field pointer)
                            var accessFieldReg = ""
                            if isClassType(firstFieldType) {
                                let firstFieldReg = generateFieldAccess(thisPtrReg, thisType, varName)
                                let ptrConvReg = getNextReg()
                                output.append("  " + ptrConvReg + " = inttoptr i64 " + firstFieldReg + " to ptr\n")
                                accessFieldReg = ptrConvReg
                            } else {
                                accessFieldReg = generateFieldAccessPtr(thisPtrReg, thisType, varName)
                            }

                            // Now access the chained field(s) from this first field (e.g., items from currentProgram)
                            receiverReg = generateFieldAccess(accessFieldReg, firstFieldType, fieldName)

                            // Infer receiver type from fieldName
                            let chainedMappedType = mapFieldNameToReceiverType(fieldName)
                            if chainedMappedType != "" {
                                receiverType = chainedMappedType
                            } else {
                                receiverType = getSeenFieldType(firstFieldType, fieldName)
                            }
                            output.append("; DEBUG chainedFieldAccess: receiverType=" + receiverType + " receiverReg=" + receiverReg + "\n")
                        }
                    }
                }
                }
            }
        }
        if not (expr.operands.length() == 0 and expr.literalValue.contains(".")) and expr.literalValue != "" {
            // Simple variable receiver stored in literalValue
            let varName = expr.literalValue
            let idx = findVar(varName)
            var varFoundInMethodCall = false
            if idx >= 0 {
                varFoundInMethodCall = true
                let varReg = varRegs[idx]
                let varType = varTypes[idx]
                let llvmType = mapType(varType)
                receiverReg = getNextReg()
                receiverType = varType
                output.append("  " + receiverReg + " = load " + llvmType + ", ptr " + varReg + "\n")
                // dyn Trait vtable dispatch for simple variable receivers — delegated to ir_call_dispatch.seen
                if varType.startsWith("dyn ") {
                    let svDynTraitName = varType.substring(4, varType.length())
                    let svDynTraitIdx = findStruct(svDynTraitName)
                    var svDynMethodNames = ""
                    var svDynRetTypes = ""
                    if svDynTraitIdx >= 0 {
                        svDynMethodNames = structMethodNames[svDynTraitIdx]
                        svDynRetTypes = structMethodRetTypes[svDynTraitIdx]
                    }
                    var svDynArgRegs = Array<String>()
                    var svDynArgTypes = Array<String>()
                    var svDynAIdx = 0
                    while svDynAIdx < expr.arguments.length() {
                        let svDynArgReg = generateExpression(expr.arguments[svDynAIdx])
                        let svDynArgType = inferExpressionType(expr.arguments[svDynAIdx])
                        svDynArgRegs.push(svDynArgReg)
                        svDynArgTypes.push(mapType(svDynArgType))
                        svDynAIdx = svDynAIdx + 1
                    }
                    // Simple receivers pass data as i64 (useI64DataArg=1)
                    return emitDynTraitVtableCallImpl(output, g_regBox, receiverReg, svDynTraitName, methodName, svDynMethodNames, svDynRetTypes, svDynArgRegs, svDynArgTypes, 1)
                }
                // SIMD horizontal reduction ops for simple variable receivers — delegated to ir_call_dispatch.seen
                if isSimdVectorType(varType) == 1 {
                    let svSimdResult = emitSimdReductionVarImpl(output, g_regBox, methodName, receiverReg, varType)
                    if svSimdResult != "" { return svSimdResult }
                }
            }
            if not varFoundInMethodCall {
                // Check if it's a global variable (module constant)
                let gvMcIdx = findModuleConstant(varName)
                if gvMcIdx >= 0 {
                    let gvMcType = moduleConstantTypes[gvMcIdx]
                    receiverReg = getNextReg()
                    var gvMcInvSuffix = ""
                    if not isModuleConstMutable(gvMcIdx) {
                        gvMcInvSuffix = ", !invariant.load !190"
                    }
                    output.append("  " + receiverReg + " = load " + gvMcType + ", ptr @" + varName + gvMcInvSuffix + "\n")
                    let gvMcSeenType = getModuleConstSeenType(gvMcIdx)
                    if gvMcSeenType != "" {
                        receiverType = gvMcSeenType
                    } else {
                        if gvMcType == "i64" { receiverType = "Int" }
                        if gvMcType == "double" { receiverType = "Float" }
                        if gvMcType == "i1" { receiverType = "Bool" }
                        if gvMcType == "%SeenString" { receiverType = "String" }
                        if gvMcType == "ptr" { receiverType = "ptr" }
                    }
                    varFoundInMethodCall = true
                }
            }
            if not varFoundInMethodCall {
                // Variable not found - check if 'this' exists and varName is a field
                let thisIdx = findVar("this")
                if thisIdx >= 0 {
                    let thisReg = varRegs[thisIdx]
                    let thisType = varTypes[thisIdx]

                    if thisType == "LLVMIRGenerator" {
                        let idxCheck = getLLVMIRGeneratorFieldIndex(varName)
                        if idxCheck >= 0 {
                            let thisPtrReg = getNextReg()
                            output.append("  " + thisPtrReg + " = load ptr, ptr " + thisReg + "\n")
                            receiverReg = generateFieldAccess(thisPtrReg, thisType, varName)
                            receiverType = getSeenFieldType(thisType, varName)
                        }
                    }

                    // Check if this type has the field
                    let structIdx = findStruct(thisType)
                    output.append("; DEBUG methodCall: varName=" + varName + " thisType=" + thisType + " structIdx=" + structIdx.toString() + "\n")
                    if structIdx >= 0 {
                        let fieldIdx = getFieldInfo(thisType, varName)
                        output.append("; DEBUG fieldIdx=" + fieldIdx.toString() + "\n")
                        if fieldIdx >= 0 {
                            // Load 'this' pointer
                            let thisPtrReg = getNextReg()
                            output.append("  " + thisPtrReg + " = load ptr, ptr " + thisReg + "\n")
                            // Access the field
                            receiverReg = generateFieldAccess(thisPtrReg, thisType, varName)
                            output.append("; DEBUG after generateFieldAccess: receiverReg=" + receiverReg + "\n")
                            // Infer receiver type from field
                            receiverType = getSeenFieldType(thisType, varName)
                            output.append("; DEBUG receiverType=" + receiverType + "\n")
                        }
                    }
                    if structIdx < 0 {
                        // Fallback: hardcoded field access for well-known fields
                        // SeenLexer.keywordManager is at index 4
                        output.append("; DEBUG: thisType=" + thisType + " varName=" + varName + "\n")
                        if thisType == "SeenLexer" and varName == "keywordManager" {
                            output.append("; DEBUG: Matched SeenLexer.keywordManager!\n")
                            let thisPtrReg = getNextReg()
                            output.append("  " + thisPtrReg + " = load ptr, ptr " + thisReg + "\n")
                            let gepReg = getNextReg()
                            output.append("  " + gepReg + " = getelementptr inbounds { %SeenString, i64, %SeenString, i1, ptr, i64, i64, i64, %SeenArray }, ptr " + thisPtrReg + ", i32 0, i32 4\n")
                            receiverReg = getNextReg()
                            output.append("  " + receiverReg + " = load ptr, ptr " + gepReg + "\n")
                            receiverType = "KeywordManager"
                            output.append("; DEBUG: receiverReg=" + receiverReg + " receiverType=" + receiverType + "\n")
                        }
                    }
                }
            }
        }

        // INLINE OPTION METHOD HANDLING (for simple variable receivers like opt.isSome())
        // INLINE OPTION METHOD HANDLING for simple receivers (delegated to ir_type_tables.seen)
        let isOptionTypeSimple = receiverType == "Option" or receiverType.startsWith("Option<")
        if isOptionTypeSimple and receiverReg != "" {
            var optDefaultRegS = "0"
            if (methodName == "unwrapOr" or methodName == "UnwrapOr") and expr.arguments.length() > 0 {
                optDefaultRegS = generateExpression(expr.arguments[0])
            }
            let optResultS = emitOptionMethodImpl(output, g_regBox, g_blockLabelBox, methodName, receiverReg, optDefaultRegS)
            if optResultS != "" {
                return optResultS
            }
        }

        // : SmallVec methods — delegated to ir_method_gen.seen
        var isSmallVecSimple = 0
        if receiverType == "SmallVec" or receiverType.startsWith("SmallVec<") or receiverType.startsWith("SmallVec[") {
            isSmallVecSimple = 1
        }
        if isSmallVecSimple == 1 and receiverReg != "" {
            var svArgReg = ""
            if (methodName == "push" or methodName == "get") and expr.arguments.length() > 0 {
                svArgReg = generateExpression(expr.arguments[0])
            }
            let svResult = emitSmallVecMethodImpl(output, g_regBox, methodName, receiverReg, receiverType, svArgReg)
            if svResult != "" { return svResult }
        }

        // INLINE COLLECTION METHOD HANDLING for simple variable receivers (delegated)
        let isCollectionTypeSimple = receiverType.startsWith("Vec<") or receiverType == "Vec" or receiverType.startsWith("BTreeMap<") or receiverType == "BTreeMap" or receiverType.startsWith("HashMap<") or receiverType == "HashMap" or receiverType.startsWith("StringHashMap<") or receiverType == "StringHashMap" or receiverType.startsWith("LinkedList<") or receiverType == "LinkedList"
        if isCollectionTypeSimple and receiverReg != "" {
            var collArg0s = "0"
            var collArg1s = "0"
            if expr.arguments.length() > 0 {
                collArg0s = generateExpression(expr.arguments[0])
            }
            if expr.arguments.length() > 1 {
                collArg1s = generateExpression(expr.arguments[1])
            }
            let collResultS = dispatchCollectionMethodImpl(output, g_regBox, methodName, receiverReg, receiverType, collArg0s, collArg1s)
            if collResultS != "" {
                return collResultS
            }
        }

        // Array<T> simple variable receiver methods — delegated to ir_method_gen.seen
        let isArrayTypeSimple = receiverType.startsWith("Array<")
        if isArrayTypeSimple and receiverReg != "" {
            var arrArg0 = ""
            var arrArg1 = ""
            if expr.arguments.length() > 0 { arrArg0 = generateExpression(expr.arguments[0]) }
            if expr.arguments.length() > 1 { arrArg1 = generateExpression(expr.arguments[1]) }
            let arrResult = emitArrayBasicMethodImpl(output, g_regBox, methodName, receiverReg, receiverType, arrArg0, arrArg1)
            if arrResult != "" { return arrResult }
        }

        // Check if this is a static method call BEFORE setting receiver fallback
        // Static method call: ClassName.method() where ClassName is not a variable
        // Class names use PascalCase (start with uppercase letter)
        if receiverReg == "" and expr.literalValue != "" {
            var potentialClassName = expr.literalValue
            // Strip generic type parameters: Map<K, V> -> Map
            var ltIdx = 0
            var i = 0
            while i < potentialClassName.length() {
                if potentialClassName.byteAt(i) == 60 {
                    ltIdx = i
                    i = potentialClassName.length()
                }
                i = i + 1
            }
            let fullClassName = expr.literalValue  // Keep full name for type detection
            if ltIdx > 0 {
                potentialClassName = potentialClassName.substring(0, ltIdx)
            }
            let firstChar = potentialClassName.substring(0, 1)
            // Check if it starts with uppercase (A-Z) and is not a known variable
            let isUppercase = firstChar >= "A" and firstChar <= "Z"
            if isUppercase and findVar(potentialClassName) < 0 {
                // Static collection .new() — delegated to ir_call_dispatch.seen
                if methodName == "new" {
                    let collNewResult = emitStaticCollectionNewImpl(output, g_regBox, potentialClassName, fullClassName)
                    if collNewResult != "" { return collNewResult }
                }

                if methodName == "withCapacity" and (potentialClassName == "HashMap" or potentialClassName == "StringHashMap") and expr.arguments.length() > 0 {
                    let capArg = generateExpression(expr.arguments[0])
                    var hasStringKey = fullClassName.contains("<String")
                    let hasStringValue = fullClassName.contains(", String>") or fullClassName.contains(",String>") or fullClassName.contains("<String>")
                    if potentialClassName == "StringHashMap" {
                        hasStringKey = true
                    }
                    let rawReg = getNextReg()
                    if hasStringKey {
                        if hasStringValue {
                            output.append("  " + rawReg + " = call ptr @HashMap_new_str_str_with_capacity(i64 " + capArg + ")\n")
                        } else {
                            output.append("  " + rawReg + " = call ptr @HashMap_new_str_with_capacity(i64 " + capArg + ")\n")
                        }
                    } else {
                        if hasStringValue {
                            output.append("  " + rawReg + " = call ptr @HashMap_new_int_str_with_capacity(i64 " + capArg + ")\n")
                        } else {
                            output.append("  " + rawReg + " = call ptr @HashMap_new_with_capacity(i64 " + capArg + ")\n")
                        }
                    }
                    let resultReg = getNextReg()
                    output.append("  " + resultReg + " = ptrtoint ptr " + rawReg + " to i64\n")
                    return resultReg
                }

                // Array<T>.withLength(n) — delegated to ir_call_dispatch.seen
                if potentialClassName == "Array" and methodName == "withLength" {
                    let countReg = generateExpression(expr.arguments[0])
                    return emitArrayWithLengthImpl(output, g_regBox, fullClassName, countReg)
                }

                // This is a static method call
                let funcName = potentialClassName + "_" + methodName

                // Generate arguments
                var staticArgRegs = Array<String>()
                var staticArgTypeStrs = Array<String>()
                prepareCallArguments(funcName, expr.arguments, staticArgRegs, staticArgTypeStrs, false, false, false, "")

                // StringBuilder.new — delegated to ir_call_dispatch.seen
                if potentialClassName == "StringBuilder" and methodName == "new" {
                    return emitStringBuilderNewCallImpl(output, g_regBox, funcName, staticArgRegs, staticArgTypeStrs)
                }

                // String.fromCharCode — delegated to ir_call_dispatch.seen
                if potentialClassName == "String" and methodName == "fromCharCode" {
                    return emitStringFromCharCodeCallImpl(output, g_regBox, staticArgRegs, staticArgTypeStrs)
                }

                let registeredStaticReturnType = getMethodReturnType(potentialClassName, methodName)
                var staticReturnType = registeredStaticReturnType
                if staticReturnType == "" or staticReturnType == "Unknown" {
                    staticReturnType = inferExpressionType(expr)
                }
                let staticLlvmReturnType = mapType(staticReturnType)

                // Generic static call — delegated to ir_call_dispatch.seen
                var isClassRecv1 = 0
                if isClassType(potentialClassName) { isClassRecv1 = 1 }
                var isDataRecv1 = 0
                if isDataType(potentialClassName) { isDataRecv1 = 1 }
                // Static methods lower receiver-free. Do not synthesize a dummy
                // ptr argument here or the call ABI no longer matches the emitted
                // ClassName_methodName signature.
                let hasImplicitThis = 0
                fillDefaultParamsLocal(funcName, staticArgRegs, staticArgTypeStrs)
                staticArgRegs = g_defaultFillArgRegs
                staticArgTypeStrs = g_defaultFillArgTypeStrs
                recordLateUserDeclare(funcName, staticLlvmReturnType, staticArgTypeStrs, hasImplicitThis)
                return emitGenericStaticCallImpl(output, g_regBox, quoteIdentIfNeeded(funcName), staticLlvmReturnType, potentialClassName, staticArgRegs, staticArgTypeStrs, isClassRecv1, isDataRecv1, hasImplicitThis)
            }
        }

        // If receiver couldn't be resolved, check if this is a standalone function call
        // This handles cases where class methods were incorrectly parsed as standalone functions
        if receiverReg == "" {
            // If receiver resolution failed entirely but the callee still exists as
            // an implicit current-class method or a plain free function, lower it
            // through generateCall() instead of defaulting to String_* helpers.
            var lowerAsCall = false
            if currentClassName != "" {
                let implicitMethodRetType = getMethodReturnType(currentClassName, methodName)
                if implicitMethodRetType != "" {
                    lowerAsCall = true
                }
            }
            if not lowerAsCall and getFunctionReturnType(methodName) != "" {
                lowerAsCall = true
            }
            if lowerAsCall {
                return generateCall(expr)
            }
            // Check if this method name matches a known standalone function
            // These are methods that should be on RealParser class but are parsed as standalone
            let isStandaloneFunc = methodName == "checkToken" or methodName == "advance" or methodName == "isAtEnd" or methodName == "peek" or methodName == "peekTokenType" or methodName == "peekTokenTypeStr" or methodName == "previous" or methodName == "consume" or methodName == "matchTokenStr" or methodName == "joinSegments" or methodName == "skipExpression" or methodName == "toArray"

            if isStandaloneFunc {
                output.append("; INFO: calling standalone function " + methodName + " (parser workaround)\n")

                // Generate arguments
                var standaloneArgRegs = Array<String>()
                var standaloneArgTypes = Array<String>()
                prepareCallArguments(methodName, expr.arguments, standaloneArgRegs, standaloneArgTypes, false, false, false, "")

                // Infer return type from method name
                var standaloneRetType = "ptr"  // Default
                var standaloneRetTypeResolved = false
                if methodName == "checkToken" or methodName == "matchTokenStr" or methodName == "isAtEnd" {
                    standaloneRetType = "i1"
                    standaloneRetTypeResolved = true
                }
                if not standaloneRetTypeResolved and methodName == "peekTokenType" {
                    standaloneRetType = "i64"
                    standaloneRetTypeResolved = true
                }
                if not standaloneRetTypeResolved and (methodName == "peekTokenTypeStr" or methodName == "joinSegments") {
                    standaloneRetType = "%SeenString"
                    standaloneRetTypeResolved = true
                }
                if not standaloneRetTypeResolved and methodName == "toArray" {
                    standaloneRetType = "%SeenArray"
                    standaloneRetTypeResolved = true
                }
                if not standaloneRetTypeResolved and methodName == "skipExpression" {
                    standaloneRetType = "void"
                }

                // Generate the call — delegated to ir_call_dispatch.seen
                fillDefaultParamsLocal(methodName, standaloneArgRegs, standaloneArgTypes)
                standaloneArgRegs = g_defaultFillArgRegs
                standaloneArgTypes = g_defaultFillArgTypeStrs
                return emitUserFunctionCallImpl(output, g_regBox, quoteIdentIfNeeded(methodName), standaloneRetType, standaloneArgRegs, standaloneArgTypes, 0)
            }

            // Fallback: use default value based on inferred type
            output.append("; WARNING: receiver not resolved for " + methodName + ", receiverType='" + receiverType + "', currentClass='" + currentClassName + "', literal='" + expr.literalValue + "', operands=" + expr.operands.length().toString() + ", using default\n")

            // Special case: toString on unknown receiver type - return proper string
            if methodName == "toString" {
                // Always handle toString specially since we need a string result
                let toStrReg = getNextReg()
                if receiverType == "Float" {
                    output.append("  " + toStrReg + " = call %SeenString @seen_float_to_string(double " + receiverReg + ")\n")
                } else if receiverType == "Int" or receiverType == "" or receiverType == "Char" {
                    output.append("  " + toStrReg + " = call %SeenString @seen_int_to_string(i64 " + receiverReg + ")\n")
                } else if receiverType == "Bool" {
                    output.append("  " + toStrReg + " = call %SeenString @seen_bool_to_string(i1 " + receiverReg + ")\n")
                } else {
                    output.append("  " + toStrReg + " = call %SeenString @seen_int_to_string(i64 0)\n")
                }
                return toStrReg
            }

            // Special case: toInt on Float - use LLVM fptosi instruction
            if methodName == "toInt" and receiverType == "Float" {
                let toIntReg = getNextReg()
                output.append("  " + toIntReg + " = fptosi double " + receiverReg + " to i64\n")
                return toIntReg
            }

            // Special case: toFloat on Int - use LLVM sitofp instruction
            if methodName == "toFloat" and receiverType == "Int" {
                let toFloatReg = getNextReg()
                output.append("  " + toFloatReg + " = sitofp i64 " + receiverReg + " to double\n")
                return toFloatReg
            }

            // Original fallback - only for non-toString methods
            if methodName == "toString_disabled" and receiverType == "" {
                let emptyStrReg = getNextReg()
                output.append("  " + emptyStrReg + " = call %SeenString @seen_int_to_string(i64 0)\n")
                return emptyStrReg
            }

            var receiverFallbackResolved = false
            if receiverType == "Int" or receiverType == "" or receiverType == "Char" {
                receiverReg = "0"
                receiverFallbackResolved = true
            }
            if not receiverFallbackResolved and receiverType == "Bool" {
                receiverReg = "false"
                receiverFallbackResolved = true
            }
            if not receiverFallbackResolved {
                receiverReg = "0"  // Generic fallback for i64 operations
            }
        }

        // Generate arguments BEFORE allocating result register to keep numbers in order
        if methodName == "free" {
            // Resolve receiver type from literalValue if not already set
            var freeReceiverType = receiverType
            if (freeReceiverType == "String" or freeReceiverType == "") and expr.literalValue != "" {
                let freeTypeIdx = findVar(expr.literalValue)
                if freeTypeIdx >= 0 {
                    freeReceiverType = varTypes[freeTypeIdx]
                }
            }
            let isArrayType = freeReceiverType.startsWith("Array<") or freeReceiverType == "Array"
            if isArrayType {
                // Resolve receiver pointer from literalValue (variable name) or receiverReg
                var freePtrReg = receiverReg
                if freePtrReg == "" and expr.literalValue != "" {
                    let freeVarIdx = findVar(expr.literalValue)
                    if freeVarIdx >= 0 {
                        freePtrReg = getNextReg()
                        output.append("  " + freePtrReg + " = load ptr, ptr " + varRegs[freeVarIdx] + "\n")
                    }
                }
                if freePtrReg != "" {
                    // Free data buffer (field 3 of SeenArray struct)
                    let dataPtrPtrReg = getNextReg()
                    output.append("  " + dataPtrPtrReg + " = getelementptr inbounds %SeenArray, ptr " + freePtrReg + ", i32 0, i32 3\n")
                    let dataPtrReg = getNextReg()
                    output.append("  " + dataPtrReg + " = load ptr, ptr " + dataPtrPtrReg + "\n")
                    output.append("  call void @free(ptr " + dataPtrReg + ")\n")
                    // Free struct header
                    output.append("  call void @free(ptr " + freePtrReg + ")\n")
                    return "0"
                }
            }
            // Class type .free() - return to pool allocator
            if not isArrayType and isClassType(freeReceiverType) {
                var freeVarName = expr.literalValue
                if freeVarName == "" {
                    freeVarName = expr.variableName
                }
                let freeVarIdx = findVar(freeVarName)
                if freeVarIdx >= 0 {
                    let baseType = getBaseTypeName(freeReceiverType)
                    let sIdx = findStruct(baseType)
                    var sSize = 0
                    if sIdx >= 0 {
                        sSize = structSizes[sIdx]
                    }
                    let valReg = getNextReg()
                    output.append("  " + valReg + " = load i64, ptr " + varRegs[freeVarIdx] + "\n")
                    let pReg = getNextReg()
                    output.append("  " + pReg + " = inttoptr i64 " + valReg + " to ptr\n")
                    if sSize > 0 and sSize <= 80 {
                        output.append("  call void @seen_pool_free(ptr " + pReg + ", i64 " + sSize.toString() + ")\n")
                    }
                    if sSize == 0 or sSize > 80 {
                        output.append("  call void @free(ptr " + pReg + ")\n")
                    }
                    return "0"
                }
            }
        }

        if methodName == "length" or methodName == "len" or methodName == "size" {
            // Non-array collection types need class method convertReceiverToPtr
            let isNonArrayColl = receiverType.startsWith("List<") or receiverType == "List" or receiverType.startsWith("Vec<") or receiverType == "Vec" or receiverType.startsWith("BTreeMap<") or receiverType == "BTreeMap"
            if isNonArrayColl {
                let collectionPtrReg = convertReceiverToPtr(receiverReg, receiverType)
                let resultReg = getNextReg()
                output.append("  " + resultReg + " = call i64 @seen_arr_length_ptr(ptr " + collectionPtrReg + ")\n")
                return resultReg
            }
            if receiverType == "StringBuilder" {
                let sbPtrReg2 = convertReceiverToPtr(receiverReg, receiverType)
                return emitStringBuilderMethodImpl(output, g_regBox, "length", sbPtrReg2, "", 0)
            }
            // HashMap, LinkedList, Array, String — delegated to ir_method_gen.seen
            let lenResult = emitLengthSizeMethodImpl(output, g_regBox, receiverReg, receiverType)
            if lenResult != "" { return lenResult }
        }
        // StringBuilder method dispatch (append, appendInt, appendFloat, appendChar, clear, length, toString)
        if receiverType == "StringBuilder" and (methodName == "append" or methodName == "appendInt" or methodName == "appendFloat" or methodName == "appendChar" or methodName == "clear" or methodName == "length" or methodName == "toString") {
            var sbArg0 = ""
            var isFloatFused = 0
            if methodName == "append" and expr.arguments.length() > 0 {
                // Fused appendFloat: detect sb.append(__FloatToString(x)) pattern
                let appendArgExpr = expr.arguments[0]
                if appendArgExpr.kind == "Call" and appendArgExpr.callee == "__FloatToString" and appendArgExpr.arguments.length() > 0 {
                    sbArg0 = generateExpression(appendArgExpr.arguments[0])
                    isFloatFused = 1
                } else {
                    sbArg0 = generateExpression(expr.arguments[0])
                }
            } else {
                if expr.arguments.length() > 0 {
                    sbArg0 = generateExpression(expr.arguments[0])
                }
            }
            let sbPtrReg = convertReceiverToPtr(receiverReg, receiverType)
            return emitStringBuilderMethodImpl(output, g_regBox, methodName, sbPtrReg, sbArg0, isFloatFused)
        }
        // toString — delegated to ir_method_gen.seen
        if methodName == "toString" {
            var isClassReceiver = 0
            if isClassType(receiverType) { isClassReceiver = 1 }
            return emitToStringMethodImpl(output, g_regBox, receiverReg, receiverType, isClassReceiver)
        }
        // toInt — delegated to ir_method_gen.seen
        if methodName == "toInt" {
            let toIntResult = emitToIntMethodImpl(output, g_regBox, receiverReg, receiverType)
            if toIntResult != "" { return toIntResult }
        }
        // toFloat — delegated to ir_method_gen.seen
        if methodName == "toFloat" {
            return emitToFloatMethodImpl(output, g_regBox, receiverReg, receiverType)
        }
        // Numeric methods (abs/min/max/clamp/floor/ceil/round/sqrt/isNaN/isInfinite) — delegated to ir_method_gen.seen
        if methodName == "abs" or methodName == "min" or methodName == "max" or methodName == "clamp" or methodName == "floor" or methodName == "ceil" or methodName == "round" or methodName == "sqrt" or methodName == "isNaN" or methodName == "isInfinite" {
            var numArg0 = ""
            var numArg1 = ""
            if expr.arguments.length() > 0 { numArg0 = generateExpression(expr.arguments[0]) }
            if expr.arguments.length() > 1 { numArg1 = generateExpression(expr.arguments[1]) }
            let numResult = emitNumericMethodImpl(output, g_regBox, methodName, receiverReg, receiverType, numArg0, numArg1)
            if numResult != "" { return numResult }
        }
        // JsonValue methods — delegated to ir_type_tables.seen
        let jsonResult = emitJsonValueMethodImpl(output, g_regBox, methodName, receiverReg, receiverType)
        if jsonResult != "" { return jsonResult }
        // String/Char methods — delegated to ir_type_tables.seen
        var strArg0 = ""
        var strArg1 = ""
        var strArgCount = expr.arguments.length()
        if strArgCount > 0 { strArg0 = generateExpression(expr.arguments[0]) }
        if strArgCount > 1 { strArg1 = generateExpression(expr.arguments[1]) }
        let strResult = emitStringMethodImpl(output, g_regBox, methodName, receiverReg, receiverType, strArg0, strArg1, strArgCount)
        if strResult != "" { return strResult }
        if methodName == "toCString" and receiverType == "String" {
            return emitCStrConversionImpl(output, g_regBox, "str_to_cstr", receiverReg)
        }
        if methodName == "toSeenString" and receiverType == "Int" {
            return emitCStrConversionImpl(output, g_regBox, "cstr_to_str", receiverReg)
        }
        // trim on class receivers (non-String) — needs convertReceiverToPtr class method
        if methodName == "trim" {
            if receiverType != "String" and receiverType != "" {
                let funcName = receiverType + "_trim"
                let trimReceiverReg = convertReceiverToPtr(receiverReg, receiverType)
                let resultReg = getNextReg()
                output.append("  " + resultReg + " = call %SeenString @" + quoteIdentIfNeeded(funcName) + "(ptr " + trimReceiverReg + ", %SeenString " + strArg0 + ")\n")
                return resultReg
            }
        }
        if methodName == "push" and (receiverType.startsWith("Array<") or receiverType == "Array") {
            // push needs pointer to array to modify in place
            // Generate argument first
            let argExpr = expr.arguments[0]
            let argReg = generateExpression(argExpr)
            let argType = inferExpressionType(argExpr)
            // Track if arg is from a struct literal (returns ptr) vs method call (may return inline struct)
            let argIsStructLiteral = argExpr.kind == "StructLiteral"
            var elemType = ""
            if receiverType.startsWith("Array<") and receiverType.endsWith(">") {
                elemType = receiverType.substring(6, receiverType.length() - 1)
            }
            var pushElemType = argType
            if pushElemType == "" {
                pushElemType = elemType
            }

            // We need the field pointer, not the loaded value
            var arrayPtrReg = ""

            // First, check if receiver is a local variable - use its alloca directly
            let varName = expr.literalValue
            if varName != "" {
                // Check if this is a chained field access (contains .)
                if varName.contains(".") {
                    // Chained field access like currentProgram.items
                    // Parse the path and navigate through fields
                    var dotIdx = 0
                    var searchIdx = 0
                    while searchIdx < varName.length() {
                        if varName.byteAt(searchIdx) == 46 {
                            dotIdx = searchIdx
                            searchIdx = varName.length()  // Exit loop at first dot
                        }
                        searchIdx = searchIdx + 1
                    }
                    let firstPart = varName.substring(0, dotIdx)
                    let restPart = varName.substring(dotIdx + 1, varName.length())

                    output.append("; DEBUG push chained: firstPart=" + firstPart + " restPart=" + restPart + "\n")

                    // Check if first part is a local variable
                    let firstVarIdx = findVar(firstPart)
                    var firstPartHandled = false
                    if firstVarIdx >= 0 {
                        // First part is a local variable
                        let firstVarReg = varRegs[firstVarIdx]
                        let firstVarType = varTypes[firstVarIdx]
                        let firstPtrReg = getNextReg()
                        output.append("  " + firstPtrReg + " = load ptr, ptr " + firstVarReg + "\n")
                        // Get pointer to rest of the path (the array field)
                        let fieldPtrReg = generateFieldAccessPtr(firstPtrReg, firstVarType, restPart)
                        // Load the actual array pointer from the field (arrays are stored as ptr to heap SeenArray)
                        let loadedArrPtr = getNextReg()
                        output.append("  " + loadedArrPtr + " = load ptr, ptr " + fieldPtrReg + "\n")
                        arrayPtrReg = loadedArrPtr
                        firstPartHandled = true
                    }
                    if not firstPartHandled {
                        // First part might be a field on 'this'
                        let thisIdx = findVar("this")
                        if thisIdx >= 0 {
                            let thisReg = varRegs[thisIdx]
                            let thisType = varTypes[thisIdx]
                            let structIdx = findStruct(thisType)
                            if structIdx >= 0 {
                                let fieldIdx = getFieldInfo(thisType, firstPart)
                                output.append("; DEBUG push chained from this: thisType=" + thisType + " firstPart=" + firstPart + " fieldIdx=" + fieldIdx.toString() + "\n")
                                if fieldIdx >= 0 {
                                    // Load 'this' pointer
                                    let thisPtrReg = getNextReg()
                                    output.append("  " + thisPtrReg + " = load ptr, ptr " + thisReg + "\n")

                                    // Get the type and pointer of the first field
                                    let firstFieldType = getSeenFieldType(thisType, firstPart)
                                    let firstFieldReg = generateFieldAccess(thisPtrReg, thisType, firstPart)
                                    output.append("; DEBUG push chained: firstFieldType=" + firstFieldType + " firstFieldReg=" + firstFieldReg + "\n")

                                    // If firstFieldType is a class type, convert i64 to ptr
                                    var accessFieldReg = firstFieldReg
                                    if isClassType(firstFieldType) {
                                        let ptrConvReg = getNextReg()
                                        output.append("  " + ptrConvReg + " = inttoptr i64 " + firstFieldReg + " to ptr\n")
                                        accessFieldReg = ptrConvReg
                                    }

                                    // Now get pointer to the rest of the path (the array field)
                                    let fieldPtrReg = generateFieldAccessPtr(accessFieldReg, firstFieldType, restPart)
                                    // Load the actual array pointer from the field (arrays are stored as ptr to heap SeenArray)
                                    let loadedArrPtr = getNextReg()
                                    output.append("  " + loadedArrPtr + " = load ptr, ptr " + fieldPtrReg + "\n")
                                    arrayPtrReg = loadedArrPtr
                                    output.append("; DEBUG push chained: arrayPtrReg=" + arrayPtrReg + "\n")
                                }
                            }
                        }
                    }
                }
                if not varName.contains(".") {
                    // Simple variable name (no dots)
                    let varIdx = findVar(varName)
                    var pushVarHandled = false
                    if varIdx >= 0 {
                        // Local variable - load the array pointer from the alloca
                        // Arrays are stored as ptr to heap SeenArray
                        let loadReg = getNextReg()
                        output.append("  " + loadReg + " = load ptr, ptr " + varRegs[varIdx] + "\n")
                        arrayPtrReg = loadReg
                        pushVarHandled = true
                    }
                    if not pushVarHandled {
                        // Not a local variable - might be a field on 'this'
                        let thisIdx = findVar("this")
                        if thisIdx >= 0 {
                            let thisReg = varRegs[thisIdx]
                            let thisType = varTypes[thisIdx]
                            if thisType == "LLVMIRGenerator" {
                                let idxCheck = getLLVMIRGeneratorFieldIndex(varName)
                                if idxCheck >= 0 {
                                    let thisPtrReg = getNextReg()
                                    output.append("  " + thisPtrReg + " = load ptr, ptr " + thisReg + "\n")
                                    let fieldPtrReg = generateFieldAccessPtr(thisPtrReg, thisType, varName)
                                    let loadedArrPtr = getNextReg()
                                    output.append("  " + loadedArrPtr + " = load ptr, ptr " + fieldPtrReg + "\n")
                                    arrayPtrReg = loadedArrPtr
                                }
                            }
                            let structIdx = findStruct(thisType)
                            if structIdx >= 0 {
                                let fieldIdx = getFieldInfo(thisType, varName)
                                if fieldIdx >= 0 {
                                    // Load 'this' pointer and get field pointer
                                    let thisPtrReg = getNextReg()
                                    output.append("  " + thisPtrReg + " = load ptr, ptr " + thisReg + "\n")
                                    let fieldPtrReg = generateFieldAccessPtr(thisPtrReg, thisType, varName)
                                    // Load the actual array pointer from the field (arrays are stored as ptr to heap SeenArray)
                                    let loadedArrPtr = getNextReg()
                                    output.append("  " + loadedArrPtr + " = load ptr, ptr " + fieldPtrReg + "\n")
                                    arrayPtrReg = loadedArrPtr
                                }
                            }
                        }
                        // Cross-module global fallback: try loading ptr from @varName
                        if arrayPtrReg == "" {
                            let loadReg = getNextReg()
                            output.append("  " + loadReg + " = load ptr, ptr @" + varName + "\n")
                            arrayPtrReg = loadReg
                        }
                    }
                }
            }

            // Fall back: receiverReg is already a ptr to SeenArray on heap
            // (arrays are heap-allocated, so receiverReg from generateExpression is a ptr)
            if arrayPtrReg == "" and (receiverType.startsWith("Array<") or receiverType == "Array") {
                arrayPtrReg = receiverReg
            }

            if arrayPtrReg != "" {
                // Use type-specific push function for correct ABI
                var pushTypeHandled = false
                if pushElemType == "String" {
                    // For strings, use seen_arr_push_str which takes SeenString by value
                    output.append("  call void @seen_arr_push_str(ptr " + arrayPtrReg + ", %SeenString " + argReg + ")\n")
                    return "0"  // void return
                }
                if pushElemType == "Int" or pushElemType == "Char" or receiverType == "Array<Int>" {
                    // Inline fast-path push: check len < cap, store directly
                    // Slow path falls back to runtime for capacity growth
                    let lenPtrReg = getNextReg()
                    let lenReg = getNextReg()
                    let capPtrReg = getNextReg()
                    let capReg = getNextReg()
                    let needsGrowReg = getNextReg()
                    let slowLabel = getNextBlockLabel()
                    let fastLabel = getNextBlockLabel()
                    let doneLabel = getNextBlockLabel()

                    // Load len (field 0) and cap (field 1)
                    output.append("  " + lenPtrReg + " = getelementptr inbounds %SeenArray, ptr " + arrayPtrReg + ", i32 0, i32 0\n")
                    output.append("  " + lenReg + " = load i64, ptr " + lenPtrReg + ", !tbaa !108, !range !188\n")
                    output.append("  " + capPtrReg + " = getelementptr inbounds %SeenArray, ptr " + arrayPtrReg + ", i32 0, i32 1\n")
                    output.append("  " + capReg + " = load i64, ptr " + capPtrReg + ", !tbaa !108, !range !188\n")

                    // Branch: len >= cap -> slow path (grow), else -> fast path (direct store)
                    // Branch weights: fast path (no grow) is much more likely
                    output.append("  " + needsGrowReg + " = icmp sge i64 " + lenReg + ", " + capReg + "\n")
                    output.append("  br i1 " + needsGrowReg + ", label %" + slowLabel + ", label %" + fastLabel + ", !prof !197\n")

                    // Slow path: fully inlined grow + push (enables SROA when struct is on stack)
                    output.append(slowLabel + ":\n")
                    // new_cap = cap * 2
                    let newCapReg = getNextReg()
                    output.append("  " + newCapReg + " = shl i64 " + capReg + ", 1\n")
                    // Store new cap
                    output.append("  store i64 " + newCapReg + ", ptr " + capPtrReg + ", !tbaa !108\n")
                    // new byte size = new_cap * 8
                    let newByteSizeReg = getNextReg()
                    output.append("  " + newByteSizeReg + " = shl i64 " + newCapReg + ", 3\n")
                    // Load data ptr
                    let slowDataPtrPtrReg = getNextReg()
                    output.append("  " + slowDataPtrPtrReg + " = getelementptr inbounds %SeenArray, ptr " + arrayPtrReg + ", i32 0, i32 3\n")
                    let slowOldDataReg = getNextReg()
                    output.append("  " + slowOldDataReg + " = load ptr, ptr " + slowDataPtrPtrReg + ", !tbaa !104\n")
                    // Realloc
                    let slowNewDataReg = getNextReg()
                    output.append("  " + slowNewDataReg + " = call ptr @realloc(ptr " + slowOldDataReg + ", i64 " + newByteSizeReg + ")\n")
                    // Store new data ptr
                    output.append("  store ptr " + slowNewDataReg + ", ptr " + slowDataPtrPtrReg + ", !tbaa !104\n")
                    // Store element at data[len]
                    let slowElemPtrReg = getNextReg()
                    output.append("  " + slowElemPtrReg + " = getelementptr inbounds i64, ptr " + slowNewDataReg + ", i64 " + lenReg + "\n")
                    output.append("  store i64 " + argReg + ", ptr " + slowElemPtrReg + ", !tbaa !105\n")
                    // Increment len
                    let slowNewLenReg = getNextReg()
                    output.append("  " + slowNewLenReg + " = add nsw i64 " + lenReg + ", 1\n")
                    output.append("  store i64 " + slowNewLenReg + ", ptr " + lenPtrReg + ", !tbaa !108\n")
                    output.append("  br label %" + doneLabel + "\n")

                    // Fast path: direct store at data[len], then increment len
                    output.append(fastLabel + ":\n")
                    let dataPtrPtrReg = getNextReg()
                    let dataPtrReg = getNextReg()
                    let elemPtrReg = getNextReg()
                    let newLenReg = getNextReg()
                    output.append("  " + dataPtrPtrReg + " = getelementptr inbounds %SeenArray, ptr " + arrayPtrReg + ", i32 0, i32 3\n")
                    output.append("  " + dataPtrReg + " = load ptr, ptr " + dataPtrPtrReg + ", !tbaa !104\n")
                    output.append("  " + elemPtrReg + " = getelementptr inbounds i64, ptr " + dataPtrReg + ", i64 " + lenReg + "\n")
                    output.append("  store i64 " + argReg + ", ptr " + elemPtrReg + ", !tbaa !105\n")
                    output.append("  " + newLenReg + " = add nsw i64 " + lenReg + ", 1\n")
                    output.append("  store i64 " + newLenReg + ", ptr " + lenPtrReg + ", !tbaa !108\n")
                    output.append("  br label %" + doneLabel + "\n")

                    // Done
                    output.append(doneLabel + ":\n")
                    return "0"  // void return
                }
                if pushElemType == "Float" or receiverType == "Array<Float>" {
                    // For Float arrays, bitcast double to i64 and use seen_arr_push_i64
                    // Both are 8 bytes so this is safe
                    let castReg = getNextReg()
                    output.append("  " + castReg + " = bitcast double " + argReg + " to i64\n")
                    output.append("  call void @seen_arr_push_i64(ptr " + arrayPtrReg + ", i64 " + castReg + ")\n")
                    return "0"  // void return
                }
                if pushElemType != "String" and pushElemType != "Int" and pushElemType != "Float" and receiverType != "Array<Int>" and receiverType != "Array<Float>" {
                    // Inline data types use Array_push (copies element_size bytes).
                    if isDataType(pushElemType) {
                        var ptrArgReg = argReg
                        if isClassType(pushElemType) {
                            let tmpReg = getNextReg()
                            output.append("  " + tmpReg + " = alloca i64\n")
                            output.append("  store i64 " + argReg + ", ptr " + tmpReg + "\n")
                            ptrArgReg = tmpReg
                        }
                        if not argIsStructLiteral {
                            let tmpReg = getNextReg()
                            output.append("  " + tmpReg + " = alloca %" + pushElemType + "\n")
                            output.append("  store %" + pushElemType + " " + argReg + ", ptr " + tmpReg + "\n")
                            ptrArgReg = tmpReg
                        }
                        let resultReg = getNextReg()
                        output.append("  " + resultReg + " = call i64 @Array_push(ptr " + arrayPtrReg + ", ptr " + ptrArgReg + ")\n")
                        return resultReg
                    }
                    // Pointer arrays (class types and raw pointers) use seen_arr_push_ptr.
                    var ptrArgReg = argReg
                    if isClassType(pushElemType) {
                        let ptrReg = getNextReg()
                        output.append("  " + ptrReg + " = inttoptr i64 " + argReg + " to ptr\n")
                        ptrArgReg = ptrReg
                    }
                    if ptrArgReg == "0" {
                        ptrArgReg = "null"
                    }
                    output.append("  call void @seen_arr_push_ptr(ptr " + arrayPtrReg + ", ptr " + ptrArgReg + ")\n")
                    return "0"
                }
            }
        }

        // Array.pop() — remove and return the last element
        if methodName == "pop" {
            var arrayPtrReg = ""
            let popVarName = expr.literalValue
            if popVarName != "" {
                let popVarIdx = findVar(popVarName)
                if popVarIdx >= 0 {
                    let loadReg = getNextReg()
                    output.append("  " + loadReg + " = load ptr, ptr " + varRegs[popVarIdx] + "\n")
                    arrayPtrReg = loadReg
                }
            }
            if arrayPtrReg == "" { arrayPtrReg = receiverReg }
            if arrayPtrReg != "" {
                var elemType = ""
                if receiverType.startsWith("Array<") and receiverType.endsWith(">") {
                    elemType = receiverType.substring(6, receiverType.length() - 1)
                }
                let popResultReg = getNextReg()
                if elemType == "Float" {
                    output.append("  " + popResultReg + " = call double @seen_arr_pop_f64(ptr " + arrayPtrReg + ")\n")
                    return popResultReg
                }
                if elemType == "String" {
                    output.append("  " + popResultReg + " = call %SeenString @seen_arr_pop_str(ptr " + arrayPtrReg + ")\n")
                    return popResultReg
                }
                output.append("  " + popResultReg + " = call i64 @seen_arr_pop_i64(ptr " + arrayPtrReg + ")\n")
                return popResultReg
            }
        }

        // Inline Array.swap(i, j): swap two elements in an Array<Int> or Array<Float>
        if methodName == "swap" {
            let isArraySwap = receiverType.startsWith("Array<") or receiverType == "Array"
            if isArraySwap and expr.arguments.length() == 2 {
                let idxAReg = generateExpression(expr.arguments[0])
                let idxBReg = generateExpression(expr.arguments[1])
                // Resolve array pointer from variable
                var arrayPtrReg = receiverReg
                if arrayPtrReg == "" and expr.literalValue != "" {
                    let swapVarIdx = findVar(expr.literalValue)
                    if swapVarIdx >= 0 {
                        arrayPtrReg = getNextReg()
                        output.append("  " + arrayPtrReg + " = load ptr, ptr " + varRegs[swapVarIdx] + "\n")
                    }
                }
                if arrayPtrReg != "" {
                    // GEP to data pointer (field 3 of SeenArray)
                    let dataPPReg = getNextReg()
                    output.append("  " + dataPPReg + " = getelementptr inbounds %SeenArray, ptr " + arrayPtrReg + ", i32 0, i32 3\n")
                    let dataPReg = getNextReg()
                    output.append("  " + dataPReg + " = load ptr, ptr " + dataPPReg + ", !tbaa !104\n")
                    // GEP to element[i] and element[j]
                    let elemAPtrReg = getNextReg()
                    output.append("  " + elemAPtrReg + " = getelementptr inbounds i64, ptr " + dataPReg + ", i64 " + idxAReg + "\n")
                    let elemBPtrReg = getNextReg()
                    output.append("  " + elemBPtrReg + " = getelementptr inbounds i64, ptr " + dataPReg + ", i64 " + idxBReg + "\n")
                    // Load both elements
                    let valAReg = getNextReg()
                    output.append("  " + valAReg + " = load i64, ptr " + elemAPtrReg + ", align 8, !tbaa !105\n")
                    let valBReg = getNextReg()
                    output.append("  " + valBReg + " = load i64, ptr " + elemBPtrReg + ", align 8, !tbaa !105\n")
                    // Store crosswise
                    output.append("  store i64 " + valBReg + ", ptr " + elemAPtrReg + ", align 8, !tbaa !105\n")
                    output.append("  store i64 " + valAReg + ", ptr " + elemBPtrReg + ", align 8, !tbaa !105\n")
                    return "0"
                }
            }
        }

        // Check if this is a static method call (receiver is a class name, not a variable)
        // BUT if we already set receiverReg from field access, this is NOT a static call
        let isStatic = findVar(expr.literalValue) < 0 and receiverReg == ""

        if isStatic {
            // Static method call: LLVMIRGenerator.new() -> @LLVMIRGenerator_new()
            let className = expr.literalValue
            let funcName = className + "_" + methodName

            // Generate arguments
            var argRegs = Array<String>()
            var argTypeStrs = Array<String>()
            prepareCallArguments(funcName, expr.arguments, argRegs, argTypeStrs, false, true, false, "")

            let registeredStaticReturnType = getMethodReturnType(className, methodName)
            var staticReturnType = registeredStaticReturnType
            if staticReturnType == "" or staticReturnType == "Unknown" {
                staticReturnType = inferExpressionType(expr)
            }
            let staticLlvmReturnType = mapType(staticReturnType)

            // Fallback generic static call — delegated to ir_call_dispatch.seen
            var isClassRecvFB = 0
            if isClassType(className) { isClassRecvFB = 1 }
            var isDataRecvFB = 0
            if isDataType(className) { isDataRecvFB = 1 }
            // Fallback static calls share the same receiver-free ABI as the main
            // static-call path.
            let hasImplicitThisFB = 0
            fillDefaultParamsLocal(funcName, argRegs, argTypeStrs)
            argRegs = g_defaultFillArgRegs
            argTypeStrs = g_defaultFillArgTypeStrs
            recordLateUserDeclare(funcName, staticLlvmReturnType, argTypeStrs, hasImplicitThisFB)
            return emitGenericStaticCallImpl(output, g_regBox, quoteIdentIfNeeded(funcName), staticLlvmReturnType, className, argRegs, argTypeStrs, isClassRecvFB, isDataRecvFB, hasImplicitThisFB)
        }

        // Instance method call: generator.generate(arg) -> @LLVMIRGenerator_generate(receiver, arg)
        // Get the receiver's type to construct the function name
        var instanceTypeName = receiverType

        // Special handling for toJson on unwrapped types
        // When calling .toJson() on the result of .unwrap(), we need to trace back to the actual type
        // because inferExpressionType may return "ptr" for unwrap results
        if instanceTypeName == "ptr" and methodName == "toJson" and expr.operands.length() > 0 {
            let receiverExpr = expr.operands[0]
            if receiverExpr.kind == "MethodCall" and receiverExpr.callee == "unwrap" {
                // Trace back to find the type being unwrapped
                if receiverExpr.operands.length() > 0 {
                    let unwrapReceiverType = inferExpressionType(receiverExpr.operands[0])
                    // If it's a nullable type (T?), the unwrap returns T
                    if unwrapReceiverType.endsWith("?") {
                        instanceTypeName = unwrapReceiverType.substring(0, unwrapReceiverType.length() - 1)
                    }
                }
            }
        }
        // Clean up type name - remove optional ? suffix if present
        // This handles cases like IRFunction? -> IRFunction
        if instanceTypeName.length() > 0 and instanceTypeName.charAt(instanceTypeName.length() - 1) == '?' {
            instanceTypeName = instanceTypeName.substring(0, instanceTypeName.length() - 1)
        }
        // NOTE: Do NOT strip Optional<T> or Option<T> wrapper here!
        // Option is a class with methods like unwrap(), isSome(), etc.
        // Stripping would cause Option<Bool>.unwrap() to call Bool_unwrap instead of Option_unwrap.
        // Clean up type name - remove generic parameters if present
        // Avoid String.contains/substring here to reduce heap churn during codegen.
        var ltIdx = -1
        var scanIdx = 0
        while scanIdx < instanceTypeName.length() {
            if instanceTypeName.charAt(scanIdx) == '<' {
                ltIdx = scanIdx
                scanIdx = instanceTypeName.length()
            }
            scanIdx = scanIdx + 1
        }
        if ltIdx > 0 {
            var prefix = ""
            var i = 0
            while i < ltIdx {
                prefix = prefix + instanceTypeName.charAt(i).toString()
                i = i + 1
            }
            instanceTypeName = prefix
        }

        var funcName = instanceTypeName + "_" + methodName

        // Intercept @hot_reload synthesized methods (not in class definition, need explicit dispatch)
        if methodName == "__seen_hot_get_size" or methodName == "__seen_hot_get_version" or methodName == "__seen_hot_get_state" {
            var hrRecvReg = receiverReg
            if isClassType(receiverType) {
                let hrPtrReg = getNextReg()
                output.append("  " + hrPtrReg + " = inttoptr i64 " + receiverReg + " to ptr\n")
                hrRecvReg = hrPtrReg
            }
            let hrRes = getNextReg()
            output.append("  " + hrRes + " = call i64 @" + quoteIdentIfNeeded(funcName) + "(ptr " + hrRecvReg + ")\n")
            return hrRes
        }
        if methodName == "__seen_hot_set_state" {
            var hrRecvReg2 = receiverReg
            if isClassType(receiverType) {
                let hrPtrReg2 = getNextReg()
                output.append("  " + hrPtrReg2 + " = inttoptr i64 " + receiverReg + " to ptr\n")
                hrRecvReg2 = hrPtrReg2
            }
            var hrStateArg = "0"
            if expr.arguments.length() > 0 {
                hrStateArg = generateExpression(expr.arguments[0])
            }
            output.append("  call void @" + quoteIdentIfNeeded(funcName) + "(ptr " + hrRecvReg2 + ", i64 " + hrStateArg + ")\n")
            return "0"
        }

        // Generate arguments
        var argRegs = Array<String>()
        var argTypeStrs = Array<String>()
        prepareCallArguments(funcName, expr.arguments, argRegs, argTypeStrs, false, true, false, "")

        // Infer return type from method name
        var returnTypeStr = inferExpressionType(expr)
        if returnTypeStr == "" or returnTypeStr == "Unknown" {
            let regRetType = getMethodReturnType(instanceTypeName, methodName)
            if regRetType != "" { returnTypeStr = regRetType }
        }
        if returnTypeStr == "" or returnTypeStr == "Unknown" { returnTypeStr = "Int" }
        let llvmReturnType = mapType(returnTypeStr)

        // Determine the receiver type for the call
        // For primitive types (Int, Char, Bool), use their LLVM type directly
        // For class/struct types, use ptr
        var receiverLlvmType = "ptr"
        var receiverLlvmResolved = false
        if instanceTypeName == "Char" or instanceTypeName == "Int" or instanceTypeName == "Integer" or instanceTypeName == "SeenTokenType" {
            receiverLlvmType = "i64"
            receiverLlvmResolved = true
        }
        if not receiverLlvmResolved and (instanceTypeName == "Bool" or instanceTypeName == "Boolean") {
            receiverLlvmType = "i1"
            receiverLlvmResolved = true
        }
        if not receiverLlvmResolved and instanceTypeName == "Float" {
            receiverLlvmType = "double"
            receiverLlvmResolved = true
        }
        if not receiverLlvmResolved and instanceTypeName == "String" {
            receiverLlvmType = "%SeenString"
            receiverLlvmResolved = true
        }
        // For class types (not primitives or String), receiver is stored as i64
        // Convert from i64 to ptr before calling the method
        // But non-class struct types (like StringBuilder) are stored as ptr, no conversion needed
        if not receiverLlvmResolved and isClassType(receiverType) {
            // receiverLlvmType is "ptr" by default (set above)
            // But receiverReg holds an i64 value, so convert it
            let ptrReceiverReg = getNextReg()
            output.append("  " + ptrReceiverReg + " = inttoptr i64 " + receiverReg + " to ptr\n")
            receiverReg = ptrReceiverReg
        }
        // For data types (inline structs like AnnotationNode), receiver is a struct value
        // Store to temp alloca and pass pointer - same pattern as data type arguments
        if not receiverLlvmResolved and isDataType(receiverType) {
            let llvmType = mapType(receiverType)
            let allocaReg = getNextReg()
            output.append("  " + allocaReg + " = alloca " + llvmType + "\n")
            output.append("  store " + llvmType + " " + receiverReg + ", ptr " + allocaReg + "\n")
            receiverReg = allocaReg
        }
        // String?.unwrap() - identity operation
        // String? maps to %SeenString (same as String); unwrap is a no-op
        if methodName == "unwrap" and instanceTypeName == "String" {
            return receiverReg
        }

        // Option<T>.unwrap() type-specialized — delegated to ir_call_dispatch.seen
        if methodName == "unwrap" and instanceTypeName == "Option" {
            // Extract the inner type from Option<T> using receiverType (before generic stripping)
            var innerType = ""
            var ltPos = -1
            var gtPos = -1
            var scanPos = 0
            while scanPos < receiverType.length() {
                if receiverType.charAt(scanPos) == '<' and ltPos < 0 {
                    ltPos = scanPos
                }
                if receiverType.charAt(scanPos) == '>' {
                    gtPos = scanPos
                }
                scanPos = scanPos + 1
            }
            if ltPos >= 0 and gtPos > ltPos {
                innerType = receiverType.substring(ltPos + 1, gtPos)
            }
            if innerType == "" {
                innerType = returnTypeStr
            }
            var isClassInner = 0
            let baseInnerType = getBaseTypeName(innerType)
            if isClassType(baseInnerType) or baseInnerType == "Vec" or baseInnerType == "Map" or baseInnerType == "HashMap" or baseInnerType == "Result" {
                isClassInner = 1
            }
            let optUnwrapResult = emitOptionUnwrapSpecializedImpl(output, g_regBox, innerType, receiverLlvmType, receiverReg, isClassInner)
            if optUnwrapResult != "" { return optUnwrapResult }
            // Fall through to generic Option_unwrap for other types
        }

        // Final instance method call — delegated to ir_call_dispatch.seen
        fillDefaultParamsLocal(funcName, argRegs, argTypeStrs)
        argRegs = g_defaultFillArgRegs
        argTypeStrs = g_defaultFillArgTypeStrs
        return emitUserMethodCallImpl(output, g_regBox, quoteIdentIfNeeded(funcName), llvmReturnType, receiverLlvmType, receiverReg, argRegs, argTypeStrs)
    }

    // Generate IR for an await expression. Calls the async function to get
    // a coroutine handle (ptr), then emits a poll loop: coro.done? -> yes:
    // extract promise value, no: coro.resume and loop. Uses LLVM coroutine
    // intrinsics (coro.done, coro.resume, coro.destroy) directly — C wrapper
    // functions CRASH due to calling convention mismatch (fastcc vs ccc).
    fun generateAwaitExpression(expr: ParserExpressionNode) r: String {
        // Poll-based await: call async function, poll until done, extract result from promise
        let futureExpr = expr.operands[0]

        // Generate the inner expression (call to async function -> returns ptr handle)
        let hdlReg = generateExpression(futureExpr)

        // Determine result type from the called function's declared return type
        var resultLlvmType = "i64"
        if futureExpr.kind == "Call" {
            let declType = getAsyncDeclaredRetType(futureExpr.callee)
            if declType != "" {
                resultLlvmType = mapType(declType)
            }
        }

        // Poll loop: resume coroutine until done
        let pollLabel = getNextBlockLabel()
        let resumeLabel = getNextBlockLabel()
        let readyLabel = getNextBlockLabel()

        output.append("  br label %" + pollLabel + "\n")

        // Poll: check if coroutine completed
        output.append("\n" + pollLabel + ":\n")
        let doneReg = getNextReg()
        output.append("  " + doneReg + " = call i1 @llvm.coro.done(ptr " + hdlReg + ")\n")
        output.append("  br i1 " + doneReg + ", label %" + readyLabel + ", label %" + resumeLabel + "\n")

        // Not done: resume the inner coroutine and poll again
        output.append("\n" + resumeLabel + ":\n")
        output.append("  call void @llvm.coro.resume(ptr " + hdlReg + ")\n")
        output.append("  br label %" + pollLabel + "\n")

        // Done: extract result from promise and destroy frame
        output.append("\n" + readyLabel + ":\n")

        if resultLlvmType == "void" {
            output.append("  call void @llvm.coro.destroy(ptr " + hdlReg + ")\n")
            return "0"
        }

        let promisePtrReg = getNextReg()
        output.append("  " + promisePtrReg + " = call ptr @llvm.coro.promise(ptr " + hdlReg + ", i32 8, i1 false)\n")
        let resultReg = getNextReg()
        output.append("  " + resultReg + " = load " + resultLlvmType + ", ptr " + promisePtrReg + "\n")
        output.append("  call void @llvm.coro.destroy(ptr " + hdlReg + ")\n")

        return resultReg
    }

    // Generate IR for a unary expression: negation (-x), logical not (!x),
    // bitwise not (~x), address-of (&x), dereference (*x).
    fun generateUnary(expr: ParserExpressionNode) r: String {
        // Operator overloading: check for operator_neg / operator_not methods
        if expr.operands.length() > 0 {
            let unaryOpType = inferExpressionType(expr.operands[0])
            var unaryOpMethod = ""
            if expr.operator == "-" { unaryOpMethod = "operator_neg" }
            if expr.operator == "not" or expr.operator == "!" { unaryOpMethod = "operator_not" }
            if unaryOpMethod != "" and unaryOpType != "Int" and unaryOpType != "Float" and unaryOpType != "Bool" and unaryOpType != "String" {
                let unaryOpFuncName = unaryOpType + "_" + unaryOpMethod
                let unaryOpRetType = getFunctionReturnType(unaryOpFuncName)
                if unaryOpRetType != "" {
                    let unaryValReg = generateExpression(expr.operands[0])
                    let unaryThisReg = getNextReg()
                    output.append("  " + unaryThisReg + " = inttoptr i64 " + unaryValReg + " to ptr\n")
                    let unaryRetLlvm = mapType(unaryOpRetType)
                    let unaryResReg = getNextReg()
                    output.append("  " + unaryResReg + " = call " + unaryRetLlvm + " @" + quoteIdentIfNeeded(unaryOpFuncName) + "(ptr " + unaryThisReg + ")\n")
                    return unaryResReg
                }
            }
        }

        if expr.operator == "-" {
            let operandReg = generateExpression(expr.operands[0])
            let resultReg = getNextReg()
            // Check if operand is Float for fneg
            let operandType = inferExpressionType(expr.operands[0])
            if operandType == "Float" {
                output.append("  " + resultReg + " = fneg fast double " + operandReg + "\n")
            } else {
                output.append("  " + resultReg + " = sub nsw i64 0, " + operandReg + "\n")
            }
            return resultReg
        }
        if expr.operator == "not" or expr.operator == "!" {
            // Negation simplification: not (a == b) → a != b, etc.
            let innerExpr = expr.operands[0]
            if innerExpr.kind == "Binary" {
                let innerOp = innerExpr.operator
                var flippedOp = ""
                if innerOp == "==" { flippedOp = "ne" }
                if innerOp == "!=" { flippedOp = "eq" }
                if innerOp == "<" { flippedOp = "sge" }
                if innerOp == ">" { flippedOp = "sle" }
                if innerOp == "<=" { flippedOp = "sgt" }
                if innerOp == ">=" { flippedOp = "slt" }
                if flippedOp != "" {
                    let innerLeftType = inferExpressionType(innerExpr.operands[0])
                    let innerRightType = inferExpressionType(innerExpr.operands[1])
                    if innerLeftType == "Int" or innerRightType == "Int" or innerLeftType == "Char" or innerRightType == "Char" {
                        let aReg = generateExpression(innerExpr.operands[0])
                        let bReg = generateExpression(innerExpr.operands[1])
                        let resultReg = getNextReg()
                        output.append("  " + resultReg + " = icmp " + flippedOp + " i64 " + aReg + ", " + bReg + " ; negated comparison\n")
                        return resultReg
                    }
                }
            }
            let operandReg = generateExpression(expr.operands[0])
            var boolReg = operandReg
            // If operand is not already i1 (Bool), convert from i64 first
            let operandType = inferExpressionType(expr.operands[0])
            if operandType != "Bool" {
                if operandType != "Boolean" {
                    boolReg = getNextReg()
                    output.append("  " + boolReg + " = icmp ne i64 " + operandReg + ", 0\n")
                }
            }
            let resultReg = getNextReg()
            output.append("  " + resultReg + " = xor i1 " + boolReg + ", 1\n")
            return resultReg
        }
        // Address-of: &x — returns pointer to variable as i64
        if expr.operator == "&" {
            if g_insideUnsafe == 0 {
                output.append("  ; WARNING: address-of (&) requires unsafe block\n")
            }
            let addrOperand = expr.operands[0]
            let addrType = inferExpressionType(addrOperand)
            if addrOperand.kind == "Variable" or addrOperand.kind == "VarExpr" {
                var addrVarName = addrOperand.variableName
                if addrVarName == "" { addrVarName = addrOperand.literalValue }
                let addrIdx = findVar(addrVarName)
                if addrIdx >= 0 {
                    let addrVarReg = varRegs[addrIdx]
                    if isClassType(addrType) {
                        // Class type: handle IS already a pointer, just load and return it
                        let addrLoadReg = getNextReg()
                        output.append("  " + addrLoadReg + " = load i64, ptr " + addrVarReg + " ; &class — handle is pointer\n")
                        return addrLoadReg
                    }
                    // Primitive or @repr(C): return pointer to alloca
                    let addrResultReg = getNextReg()
                    output.append("  " + addrResultReg + " = ptrtoint ptr " + addrVarReg + " to i64 ; &var — address of alloca\n")
                    return addrResultReg
                }
            }
            // Fallback: generate expression and return it (can't take address of rvalue)
            let addrFallback = generateExpression(addrOperand)
            return addrFallback
        }
        // Pointer dereference: *ptr — loads value from pointer
        if expr.operator == "*" {
            if g_insideUnsafe == 0 {
                output.append("  ; WARNING: pointer dereference (*) requires unsafe block\n")
            }
            let derefValReg = generateExpression(expr.operands[0])
            let derefPtrReg = getNextReg()
            output.append("  " + derefPtrReg + " = inttoptr i64 " + derefValReg + " to ptr\n")
            let derefResultReg = getNextReg()
            output.append("  " + derefResultReg + " = load i64, ptr " + derefPtrReg + " ; *ptr dereference\n")
            return derefResultReg
        }
        // Bitwise NOT: ~x = x xor -1
        // Avoid "~" string literal (miscompiled by bootstrap — use char code 126 check)
        var opIsBitwiseNot = 0
        if expr.operator.length() == 1 {
            if expr.operator.charAt(0).toInt() == 126 {
                opIsBitwiseNot = 1
            }
        }
        if opIsBitwiseNot == 1 {
            let operandReg = generateExpression(expr.operands[0])
            let resultReg = getNextReg()
            output.append("  " + resultReg + " = xor i64 " + operandReg + ", -1\n")
            return resultReg
        }
        let operandReg = generateExpression(expr.operands[0])
        let resultReg = getNextReg()
        return resultReg
    }

    // Helper functions

    // Allocate the next SSA register (%1, %2, %3, ...). Registers are
    // strictly ascending within a function — using a pre-allocated register
    // for the FIRST instruction of a sequence is required to maintain order.
    // The counter is stored in g_regBox[0] (a boxed Array<Int>) so that
    // extracted free functions can mutate it by reference.
    fun getNextReg() r: String {
        let reg = "%" + g_regBox[0].toString()
        g_regBox[0] = g_regBox[0] + 1
        return reg
    }

    // Allocate the next block label (block0, block1, ...). Unlike registers,
    // block labels accumulate across functions within a module to ensure
    // unique loop metadata IDs (loopMetaId = blockCount + 202).
    fun getNextBlockLabel() r: String {
        let label = "bb" + g_blockBox[0].toString()
        g_blockBox[0] = g_blockBox[0] + 1
        return label
    }

    // SIMD type helpers — delegated to ir_type_info.seen
    fun isSimdVectorType(t: String) r: Int { return isSimdVectorTypeImpl(t) }
    fun simdScalarType(t: String) r: String { return simdScalarTypeImpl(t) }
    fun simdLaneCount(t: String) r: Int { return simdLaneCountImpl(t) }
    fun isSwizzlePattern(s: String, lanes: Int) r: Int { return isSwizzlePatternImpl(s, lanes) }
    fun swizzleLaneIndex(c: String) r: Int { return swizzleLaneIndexImpl(c) }
    fun simdLlvmSuffix(t: String) r: String { return simdLlvmSuffixImpl(t) }

    // Map a Seen type name to its LLVM IR type representation.
    // Core mappings: Int->i64, Float->double, Bool->i1, String->%SeenString,
    // Char->i64, Void->void, Array<T>/Vec<T>->ptr, HashMap/BTreeMap->ptr.
    // Class types map to i64 (they are heap pointers stored as integers —
    // inttoptr converts when field access is needed). Simple enums map to
    // i64 (tag value). Data enums and Option map to ptr (heap-allocated).
    // SIMD vector types (i32x4, f32x4, etc.) map to LLVM vector types.
    // Buffer<T>/Uniform<T>/Image<T> (GPU) map to i64 (opaque handles).
    // Delegates to mapTypeImpl in ir_type_mapping.seen.
    fun mapType(seenType: String) r: String {
        // dyn Trait: fat pointer stored as i64 (ptr to { ptr data, ptr vtable })
        if seenType.startsWith("dyn ") {
            return "i64"
        }
        // Pointer types: *T → i64 (pointer stored as integer)
        if seenType.startsWith("*") {
            return "i64"
        }
        // @repr(C) classes are value types (stack-allocated struct), not heap handles
        if g_reprCClassNames != "" {
            let baseT = getBaseTypeName(seenType)
            if g_reprCClassNames.contains(baseT + "|") {
                return "%" + baseT
            }
        }
        return mapTypeImpl(seenType, structNames, g_typeAliasNames, g_typeAliasTargets, g_typeAliasCount, g_enumTypeNames)
    }

    // Check whether a Seen type is a heap-allocated class (as opposed to a
    // value type or data struct). Class types are stored as i64 handles
    // (heap pointers cast to integer) and need inttoptr for field access.
    fun isClassType(seenType: String) r: Bool {
        return isClassTypeReg(seenType, structNames)
    }


    // Convert a method receiver register to a pointer. Class types are stored
    // as i64 (heap pointer cast to integer), so method calls need inttoptr
    // before dereferencing. Returns a new register with the ptr value if
    // conversion was needed, or the original register unchanged for non-class types.
    fun convertReceiverToPtr(receiverReg: String, receiverType: String) r: String {
        // @repr(C) value types are NOT heap-allocated — no inttoptr
        if g_reprCClassNames != "" {
            if g_reprCClassNames.contains(receiverType + "|") {
                return receiverReg
            }
        }
        if isClassType(receiverType) {
            let ptrConvReg = getNextReg()
            output.append("  " + ptrConvReg + " = inttoptr i64 " + receiverReg + " to ptr\n")
            return ptrConvReg
        }
        return receiverReg
    }

    // Check whether a Seen type is a data type (value semantics, passed by
    // pointer in function calls). Data types differ from class types: they
    // are stack-allocated or embedded inline in parent structs, not heap-
    // allocated with an i64 handle.
    fun isDataType(seenType: String) r: Bool {
        if isDataTypeImpl(seenType) == 1 { return true }
        return false
    }

    // Get the byte size of a data type, used for Array<T> element_size.
    // First checks the struct registry (structSizes), then falls back to
    // hardcoded sizes for known AST types (TypeNode=24, ParamNode=48, etc.).
    // These sizes MUST match the LLVM struct layouts — a mismatch causes
    // array element access to read/write at wrong offsets.
    fun getDataTypeSize(seenType: String) r: Int {
        return getDataTypeSizeReg(seenType, structNames, structSizes)
    }


    // Map a Seen type to its LLVM IR type for use as a function parameter.
    // Data types (value-semantic structs) are passed as "ptr noalias nonnull"
    // for ABI compatibility — Rust and C both pass structs by pointer.
    // The noalias attribute enables LLVM's alias analysis optimizations.
    // Strips the "comptime:" qualifier prefix from compile-time parameters.
    fun mapTypeForParameter(seenType: String) r: String {
        var cleanType = seenType
        // Strip comptime: qualifier
        if cleanType.startsWith("comptime:") {
            cleanType = cleanType.substring(9, cleanType.length())
        }
        // Strip default value suffix
        if cleanType.contains("~default~") {
            let mtpDefPos = cleanType.indexOf("~default~", 0)
            cleanType = cleanType.substring(0, mtpDefPos)
        }
        // Data types passed as pointers for ABI compatibility with Rust backend
        if isDataType(cleanType) {
            return "ptr noalias nonnull"
        }
        let mapped = mapType(cleanType)
        if mapped == "ptr" {
            return "ptr noalias nonnull"
        }
        return mapped
    }

    fun mapStorageTypeForParameter(seenType: String) r: String {
        let mapped = mapTypeForParameter(seenType)
        if mapped == "ptr noalias nonnull" {
            return "ptr"
        }
        return mapped
    }

    fun normalizeSeenTypeName(seenType: String) r: String {
        var normalized = seenType
        if normalized.startsWith("move:") {
            normalized = normalized.substring(5, normalized.length())
        }
        if normalized.startsWith("borrow:") {
            normalized = normalized.substring(7, normalized.length())
        }
        if normalized.startsWith("comptime:") {
            normalized = normalized.substring(9, normalized.length())
        }
        if normalized.contains("~default~") {
            let defPos = normalized.indexOf("~default~", 0)
            normalized = normalized.substring(0, defPos)
        }
        if normalized == "i1" {
            return "Bool"
        }
        if normalized == "i64" {
            return "Int"
        }
        if normalized == "%SeenString" {
            return "String"
        }
        return normalized
    }

    fun normalizeDeclaredTypeNode(typeNode: TypeNode) r: String {
        let normalized = normalizeSeenTypeName(typeNode.typeName)
        if typeNode.isNullable {
            if normalized == "Option<String>" or normalized == "Optional<String>" {
                return "String?"
            }
        }
        return normalized
    }

    fun prepareCallArguments(funcName: String, arguments: Array<ParserExpressionNode>,
        argRegs: Array<String>, argTypeStrs: Array<String>, enableDynBoxing: Bool,
        enableFloatPromotion: Bool, nullifyMovedSources: Bool, moveContext: String) r: Void {

        var argIdx = 0
        while argIdx < arguments.length() {
            let argExpr = arguments[argIdx]
            let argReg = generateExpression(argExpr)
            let argType = inferExpressionType(argExpr)
            if enableFloatPromotion and argType == "Int" and currentClassName == "LLVMIRGenerator" {
                println("[irgen float lookup] class=" + currentClassName + " target=" + funcName + " arg=" + argIdx.toString())
            }
            let argLlvmType = mapType(argType)
            appendPreparedCallArgImpl(output, g_regBox, funcName, argReg, argType, argLlvmType, argIdx, argRegs, argTypeStrs, g_dynParamFuncs, enableDynBoxing, enableFloatPromotion, g_floatParamFuncNames, g_floatParamParamIdxs)

            if nullifyMovedSources and g_moveOnlyClasses != "" and g_moveOnlyClasses.contains(argType + "|") {
                if argExpr.kind == "Variable" or argExpr.kind == "VarExpr" {
                    var moveVarName = argExpr.variableName
                    if moveVarName == "" { moveVarName = argExpr.literalValue }
                    if moveVarName != "" {
                        let moveVarIdx = findVar(moveVarName)
                        if moveVarIdx >= 0 {
                            let moveSrcReg = varRegs[moveVarIdx]
                            output.append("  store i64 0, ptr " + moveSrcReg + " ; @move: nullify source (" + moveContext + ")\n")
                            g_movedVarNames = g_movedVarNames + moveVarName + "|"
                            g_movedVarCount = g_movedVarCount + 1
                        }
                    }
                }
            }
            argIdx = argIdx + 1
        }
    }

    fun fillDefaultParamsLocal(funcName: String, argRegs: Array<String>, argTypeStrs: Array<String>) r: Void {
        g_defaultFillArgRegs = argRegs
        g_defaultFillArgTypeStrs = argTypeStrs
        if g_funcDefaultsArr == "" or g_funcParamCountArr == "" {
            return
        }
        let funcLookup = funcName + ":"
        let paramCountPos = g_funcParamCountArr.indexOf(funcLookup, 0)
        if paramCountPos < 0 {
            return
        }
        let paramCountStart = paramCountPos + funcLookup.length()
        var paramCountEnd = g_funcParamCountArr.indexOf("|", paramCountStart)
        if paramCountEnd < 0 {
            paramCountEnd = g_funcParamCountArr.length()
        }
        let expectedCount = parseIntManual(g_funcParamCountArr.substring(paramCountStart, paramCountEnd))
        var fillIdx = g_defaultFillArgRegs.length()
        while fillIdx < expectedCount {
            let defaultLookup = funcName + ":" + fillIdx.toString() + ":"
            let defaultPos = g_funcDefaultsArr.indexOf(defaultLookup, 0)
            if defaultPos >= 0 {
                let defaultStart = defaultPos + defaultLookup.length()
                var defaultEnd = g_funcDefaultsArr.indexOf("|", defaultStart)
                if defaultEnd < 0 {
                    defaultEnd = g_funcDefaultsArr.length()
                }
                let defaultEntry = g_funcDefaultsArr.substring(defaultStart, defaultEnd)
                let typeSep = defaultEntry.indexOf(":", 0)
                if typeSep > 0 {
                    let defaultValue = defaultEntry.substring(0, typeSep)
                    let defaultType = defaultEntry.substring(typeSep + 1, defaultEntry.length())
                    if defaultType == "String" {
                        var strIdx = -1
                        var sci = 0
                        while sci < stringConstants.length() {
                            if stringConstants[sci] == defaultValue {
                                strIdx = sci
                                sci = stringConstants.length()
                            }
                            sci = sci + 1
                        }
                        if strIdx >= 0 {
                            let strLen = defaultValue.length()
                            let gepReg = getNextReg()
                            output.append("  " + gepReg + " = getelementptr [" + (strLen + 1).toString() + " x i8], ptr @.str." + stringConstantPrefix + strIdx.toString() + ", i64 0, i64 0\n")
                            let insertLenReg = getNextReg()
                            output.append("  " + insertLenReg + " = insertvalue %SeenString undef, i64 " + strLen.toString() + ", 0\n")
                            let strReg = getNextReg()
                            output.append("  " + strReg + " = insertvalue %SeenString " + insertLenReg + ", ptr " + gepReg + ", 1\n")
                            g_defaultFillArgRegs.push(strReg)
                            g_defaultFillArgTypeStrs.push("%SeenString")
                        }
                    } else if defaultType == "Float" {
                        g_defaultFillArgRegs.push(defaultValue)
                        g_defaultFillArgTypeStrs.push("double")
                    } else if defaultType == "Bool" {
                        if defaultValue == "true" {
                            g_defaultFillArgRegs.push("1")
                        } else {
                            g_defaultFillArgRegs.push("0")
                        }
                        g_defaultFillArgTypeStrs.push("i64")
                    } else {
                        g_defaultFillArgRegs.push(defaultValue)
                        g_defaultFillArgTypeStrs.push("i64")
                    }
                }
            }
            fillIdx = fillIdx + 1
        }
    }

    fun collectDefaultParamStringConstantsFromFunction(fn: FunctionNode) r: Void {
        var paramIdx = 0
        while paramIdx < fn.params.length() {
            let paramTypeName = fn.params[paramIdx].paramType.typeName
            if paramTypeName.contains("~default~") {
                let defaultPos = paramTypeName.indexOf("~default~", 0)
                let defaultValue = paramTypeName.substring(defaultPos + 9, paramTypeName.length())
                if normalizeSeenTypeName(paramTypeName) == "String" {
                    var exists = false
                    var sci = 0
                    while sci < stringConstants.length() {
                        if stringConstants[sci] == defaultValue {
                            exists = true
                            sci = stringConstants.length()
                        }
                        sci = sci + 1
                    }
                    if not exists {
                        stringConstants.push(defaultValue)
                    }
                }
            }
            paramIdx = paramIdx + 1
        }
    }

    fun collectDefaultParamStringConstants(program: ProgramNode) r: Void {
        var itemIdx = 0
        while itemIdx < program.items.length() {
            let item = program.items[itemIdx]
            if item.itemType == "Function" {
                collectDefaultParamStringConstantsFromFunction(item.function)
            } else if item.itemType == "Class" {
                var methodIdx = 0
                while methodIdx < item.classNode.methods.length() {
                    collectDefaultParamStringConstantsFromFunction(item.classNode.methods[methodIdx])
                    methodIdx = methodIdx + 1
                }
            }
            itemIdx = itemIdx + 1
        }
    }

    fun inferReturnExprType(className: String, expr: ParserExpressionNode) r: String {
        if expr.kind == "None" {
            return "Void"
        }
        if expr.kind == "StructLiteral" {
            if expr.literalType != "" and expr.literalType != "Unknown" {
                return expr.literalType
            }
            return className
        }
        if expr.kind == "MethodCall" and expr.callee == "new" {
            if expr.literalValue != "" {
                return expr.literalValue
            }
            return className
        }
        let inferred = inferExpressionType(expr)
        if inferred != "" and inferred != "Unknown" {
            return inferred
        }
        return ""
    }

    fun inferBlockReturnType(className: String, block: BlockNode) r: String {
        var stmtIdx = 0
        var sawReturn = false
        while stmtIdx < block.statements.length() {
            let stmt = block.statements[stmtIdx]
            if stmt.kind == "Return" {
                sawReturn = true
                let retType = inferReturnExprType(className, stmt.returnValue)
                if retType != "" {
                    return retType
                }
            }
            if stmt.kind == "If" {
                let thenType = inferBlockReturnType(className, stmt.thenBranch)
                let elseType = inferBlockReturnType(className, stmt.elseBranch)
                if thenType != "" and elseType != "" and thenType == elseType {
                    return thenType
                }
            }
            stmtIdx = stmtIdx + 1
        }
        if not sawReturn {
            return "Void"
        }
        return ""
    }

    fun resolveMethodReturnType(className: String, method: FunctionNode) r: String {
        let declaredType = normalizeDeclaredTypeNode(method.returnType)
        if declaredType != "" and declaredType != "Unknown" {
            return declaredType
        }
        if method.name == "new" {
            return className
        }
        let inferredType = inferBlockReturnType(className, method.body)
        if inferredType != "" and inferredType != "Unknown" {
            return inferredType
        }
        return declaredType
    }

    fun resolveMethodReturnTypeFromList(className: String, methods: Array<FunctionNode>, methodIdx: Int) r: String {
        let declaredType = normalizeDeclaredTypeNode(methods[methodIdx].returnType)
        if declaredType != "" and declaredType != "Unknown" {
            return declaredType
        }
        if methods[methodIdx].name == "new" {
            return className
        }
        let inferredType = inferBlockReturnType(className, methods[methodIdx].body)
        if inferredType != "" and inferredType != "Unknown" {
            return inferredType
        }
        return declaredType
    }

    fun resolveMethodReturnTypeByIndex(classNode: ClassNode, methodIdx: Int) r: String {
        return resolveMethodReturnTypeFromList(classNode.name, classNode.methods, methodIdx)
    }

    fun resolveFunctionReturnType(fn: FunctionNode) r: String {
        let declaredType = normalizeDeclaredTypeNode(fn.returnType)
        if declaredType != "" and declaredType != "Unknown" {
            return declaredType
        }
        let inferredType = inferBlockReturnType("", fn.body)
        if inferredType != "" and inferredType != "Unknown" {
            return inferredType
        }
        return declaredType
    }

    // Infer the Seen type of an expression for codegen decisions (operator
    // selection, ABI, field access type, etc.). This is NOT the typechecker —
    // it operates during codegen and uses the variable/function/struct registries
    // built during Pass 1. Handles: literals (by literalType), variables (via
    // findVarType + module constants), calls (via getFunctionReturnType +
    // special cases for constructors and builtins), method calls (via
    // inferMethodCallTypeTable), binary ops (type promotion rules), member
    // access (struct field type lookup), index access (element type inference),
    // array literals, struct literals, casts, string interpolation, etc.
    // Returns the Seen type name (e.g., "Int", "String", "MyClass") or ""
    // if inference fails.
    fun inferExpressionType(expr: ParserExpressionNode) r: String {
        if expr.kind == "Literal" {
            if expr.literalType == "Int" or expr.literalType == "Integer" {
                return "Int"
            }
            if expr.literalType == "String" {
                return "String"
            }
            if expr.literalType == "Char" {
                return "Char"
            }
            if expr.literalType == "Bool" or expr.literalType == "Boolean" {
                return "Bool"
            }
            if expr.literalType == "Float" {
                return "Float"
            }
            // If literalType is set but not one of the known types, return it
            if expr.literalType != "" {
                return expr.literalType
            }
            // Fallback: try to infer from literal value
            if expr.literalValue.startsWith("\"") or expr.literalValue.startsWith("'") {
                return "String"
            }
            if expr.literalValue.contains(".") {
                return "Float"
            }
            return "Int"  // Default for numeric literals
        }
        if expr.kind == "Variable" or expr.kind == "VarExpr" {
            // Use findVarType to check both varTypes and preAllocatedTypes
            let varName = getExprVariableName(expr)
            let varType = findVarType(varName)
            if varType != "" {
                return varType
            }
            // Check if it's a module constant
            let constIdx = findModuleConstant(varName)
        if constIdx >= 0 {
            let constType = moduleConstantTypes[constIdx]
            let seenType = getModuleConstSeenType(constIdx)
            if seenType != "" {
                return seenType
            }
            // Map LLVM types to Seen types
            if constType == "i64" {
                return "Int"
            }
            if constType == "double" {
                    return "Float"
                }
                if constType == "i1" {
                    return "Bool"
                }
            if constType == "%SeenString" {
                return "String"
            }
            return "Int"  // Default
        }
            // Variable not found - check if it's a field on 'this'
            let thisIdx = findVar("this")
            if thisIdx >= 0 {
                let thisType = varTypes[thisIdx]
                if thisType == "LLVMIRGenerator" {
                    let idxCheck = getLLVMIRGeneratorFieldIndex(varName)
                    if idxCheck >= 0 {
                        return getSeenFieldType(thisType, varName)
                    }
                }
                let structIdx = findStruct(thisType)
                if structIdx >= 0 {
                    let fieldIdx = getFieldInfo(thisType, varName)
                    if fieldIdx >= 0 {
                        return getSeenFieldType(thisType, varName)
                    }
                }
            }
            // Recognize bare type names (used in sizeof/alignof expressions)
            let vn = varName
            if vn == "Int8" or vn == "UInt8" or vn == "Int16" or vn == "UInt16" or vn == "Int32" or vn == "UInt32" or vn == "Int64" or vn == "UInt64" or vn == "Float32" {
                return vn
            }
        }
        if expr.kind == "Binary" {
            // SIMD vector type propagation
            if expr.operands.length() >= 2 {
                let binLeftType = inferExpressionType(expr.operands[0])
                if isSimdVectorType(binLeftType) == 1 {
                    return binLeftType
                }
            }
            if expr.operator == "==" or expr.operator == "!=" or expr.operator == "<" or expr.operator == ">" or expr.operator == "<=" or expr.operator == ">=" or expr.operator == "and" or expr.operator == "or" {
                return "Bool"
            }
            if expr.operator == "+" {
                // Check if string concat - check both operands
                if expr.operands.length() >= 2 {
                    let leftExpr = expr.operands[0]
                    let rightExpr = expr.operands[1]
                    // Fast path for deep string-concat trees: avoid recursively
                    // inferring the whole left spine when either direct operand
                    // is already obviously string-like.
                    if leftExpr.kind == "Literal" and leftExpr.literalType == "String" {
                        return "String"
                    }
                    if rightExpr.kind == "Literal" and rightExpr.literalType == "String" {
                        return "String"
                    }
                    let leftType = inferExpressionType(expr.operands[0])
                    if leftType == "String" {
                        return "String"
                    }
                    let rightType = inferExpressionType(expr.operands[1])
                    if rightType == "String" {
                        return "String"
                    }
                    if leftType == "Float" or rightType == "Float" {
                        return "Float"
                    }
                }
            }
            // For arithmetic operators (-, *, /, %), check if either operand is Float
            if expr.operator == "-" or expr.operator == "*" or expr.operator == "/" or expr.operator == "%" {
                if expr.operands.length() >= 2 {
                    let leftType = inferExpressionType(expr.operands[0])
                    let rightType = inferExpressionType(expr.operands[1])
                    if leftType == "Float" or rightType == "Float" {
                        return "Float"
                    }
                }
            }
            // Check for operator overloading return type
            var opSuffix = ""
            if expr.operator == "+" { opSuffix = "operator_add" }
            if opSuffix == "" and expr.operator == "-" { opSuffix = "operator_sub" }
            if opSuffix == "" and expr.operator == "*" { opSuffix = "operator_mul" }
            if opSuffix == "" and expr.operator == "/" { opSuffix = "operator_div" }
            if opSuffix == "" and expr.operator == "%" { opSuffix = "operator_mod" }
            if opSuffix == "" and expr.operator == "==" { opSuffix = "operator_eq" }
            if opSuffix == "" and expr.operator == "!=" { opSuffix = "operator_neq" }
            if opSuffix == "" and expr.operator == "<" { opSuffix = "operator_lt" }
            if opSuffix == "" and expr.operator == ">" { opSuffix = "operator_gt" }
            if opSuffix == "" and expr.operator == "<=" { opSuffix = "operator_lte" }
            if opSuffix == "" and expr.operator == ">=" { opSuffix = "operator_gte" }
            if opSuffix != "" {
                if expr.operands.length() >= 1 {
                    let leftOpType = inferExpressionType(expr.operands[0])
                    let opFuncN = leftOpType + "_" + opSuffix
                    let opRetT = getFunctionReturnType(opFuncN)
                    if opRetT != "" {
                        return opRetT
                    }
                }
            }
            return "Int"
        }
        if expr.kind == "MethodCall" {
            // First, try to look up method return type from registry based on receiver type
            // Handle "this" receiver
            if currentClassName != "" and expr.literalValue == "this" {
                let registryRetType = getMethodReturnType(currentClassName, expr.callee)
                if registryRetType != "" {
                    return registryRetType
                }
            }
            // Some parser paths still produce a zero-receiver MethodCall for what is
            // semantically either an implicit current-class call or a plain free
            // function call. Mirror generateCall() so both paths infer the same type.
            if expr.literalValue == "" and expr.operands.length() == 0 {
                if currentClassName != "" {
                    let implicitMethodRetType = getMethodReturnType(currentClassName, expr.callee)
                    if implicitMethodRetType != "" {
                        return implicitMethodRetType
                    }
                }
                let freeFuncRetType = getFunctionReturnType(expr.callee)
                if freeFuncRetType != "" {
                    if isAsyncFunction(expr.callee) {
                        return "ptr"
                    }
                    return freeFuncRetType
                }
            }
            // Handle variable receiver (obj.method())
            if expr.literalValue != "" and expr.literalValue != "this" {
                let recVarType = findVarType(expr.literalValue)
                if recVarType != "" {
                    let registryRetType = getMethodReturnType(recVarType, expr.callee)
                    if registryRetType != "" {
                        return registryRetType
                    }
                }
                // Check for static method calls - literalValue is the class name (e.g., LspResponse::success)
                if recVarType == "" {
                    let staticOwnerType = getBaseTypeName(expr.literalValue)
                    var staticRetType = getMethodReturnType(expr.literalValue, expr.callee)
                    if staticRetType == "" and staticOwnerType != expr.literalValue {
                        staticRetType = getMethodReturnType(staticOwnerType, expr.callee)
                    }
                    if staticRetType != "" {
                        return staticRetType
                    }
                }
            }
            // Handle expression receiver (chained calls like obj.method1().method2())
            if expr.operands.length() > 0 {
                let recExprType = inferExpressionType(expr.operands[0])
                // Debug: Trace Vec/BTreeMap get() calls
                if expr.callee == "get" and (recExprType.startsWith("Vec<") or recExprType.startsWith("BTreeMap<")) {
                    let debugRetType = getMethodReturnType(recExprType, expr.callee)
                    traceGen("inferExpressionType: MethodCall get() receiver type=" + recExprType + " -> " + debugRetType)
                }
                if recExprType != "" {
                    let registryRetType = getMethodReturnType(recExprType, expr.callee)
                    if registryRetType != "" {
                        return registryRetType
                    }
                }
            }
            // Check for static method calls - literalValue is the class name
            if expr.callee == "new" {
                // Static constructor - returns the class type
                return expr.literalValue
            }
            if expr.callee == "withCapacity" {
                let capacityOwnerType = getBaseTypeName(expr.literalValue)
                if capacityOwnerType == "Vec" or capacityOwnerType == "HashMap" or capacityOwnerType == "BTreeMap" or capacityOwnerType == "LinkedList" or capacityOwnerType == "StringHashMap" {
                    return expr.literalValue
                }
            }
            // Array<T>.withLength(n) / Array<T>.withCapacity(n) returns Array<T>
            if (expr.callee == "withLength" or expr.callee == "withCapacity") and expr.literalValue.startsWith("Array") {
                return expr.literalValue
            }
            // Receiver-sensitive method return types (toUpperCase, abs, floor, Vec first/last/remove)
            // Resolve receiver type, then delegate to inferReceiverMethodTypeImpl
            if expr.callee == "toUpperCase" or expr.callee == "toLowerCase" or expr.callee == "abs" or expr.callee == "min" or expr.callee == "max" or expr.callee == "clamp" or expr.callee == "floor" or expr.callee == "ceil" or expr.callee == "round" or expr.callee == "sqrt" or expr.callee == "first" or expr.callee == "last" or expr.callee == "remove" {
                var recTypeForImpl = ""
                if expr.operands.length() > 0 {
                    recTypeForImpl = inferExpressionType(expr.operands[0])
                }
                if recTypeForImpl == "" and expr.literalValue != "" {
                    recTypeForImpl = findVarType(expr.literalValue)
                }
                let implResult = inferReceiverMethodTypeImpl(expr.callee, recTypeForImpl)
                if implResult != "" {
                    return implResult
                }
            }
            let mcTable = inferMethodCallTypeTable(expr.callee)
            if mcTable != "" { return mcTable }
            if expr.callee == "fromJson" {
                // fromJson returns nullable types - try to infer from receiver/class
                // Check if literalValue contains the class name (for static calls like LspPosition::fromJson)
                if expr.literalValue != "" and expr.literalValue != "this" {
                    let staticRetType = getMethodReturnType(expr.literalValue, "fromJson")
                    if staticRetType != "" {
                        return staticRetType
                    }
                }
                // Fallback - return ptr for unknown nullable types
                return "ptr"
            }
            // Map/Vec/BTreeMap.get() - resolve receiver type to determine return type
            if expr.callee == "get" {
                var recType = ""
                if expr.operands.length() > 0 {
                    recType = inferExpressionType(expr.operands[0])
                }
                if recType == "" and expr.literalValue != "" {
                    // First check if it's a chained path like "div.children"
                    if expr.literalValue.contains(".") {
                        recType = resolveChainedPathType(expr.literalValue)
                    }
                    // Then check if it's a simple variable
                    if recType == "" {
                        recType = findVarType(expr.literalValue)
                    }
                    // Also check if it's a field on 'this'
                    if recType == "" {
                        let thisIdx = findVar("this")
                        if thisIdx >= 0 {
                            let thisType = varTypes[thisIdx]
                            recType = getSemanticFieldType(thisType, expr.literalValue)
                            if recType == "" {
                                recType = getSeenFieldType(thisType, expr.literalValue)
                            }
                        }
                    }
                }
                // Debug: Trace get() method type inference
                traceGen("inferExpressionType: get() recType=" + recType + " literalValue=" + expr.literalValue + " operands=" + expr.operands.length().toString())
                // Only use hardcoded collection dispatch for known collection types
                let isCollectionGet = recType.startsWith("Array<") or recType.startsWith("Vec<") or recType.startsWith("HashMap<") or recType.startsWith("StringHashMap<") or recType.startsWith("BTreeMap<") or recType.startsWith("Map<") or recType == ""
                if isCollectionGet {
                    let collGetType = resolveCollectionGetTypeImpl(recType)
                    if collGetType != "" {
                        return collGetType
                    }
                    return "Option<Int>"  // Fallback for unrecognized collection type
                }
                // Non-collection .get() — fall through to general method dispatch
            }
            // Array<T>.pop() returns T
            if expr.callee == "pop" {
                var popRecType = ""
                if expr.operands.length() > 0 {
                    popRecType = inferExpressionType(expr.operands[0])
                }
                if popRecType == "" and expr.literalValue != "" {
                    popRecType = findVarType(expr.literalValue)
                }
                let popResult = resolvePopElementTypeImpl(popRecType)
                if popResult != "" {
                    return popResult
                }
                return "Int"
            }
            if expr.callee == "unwrap" {
                // Check receiver type to determine return type
                // Receiver can be in operands (for chained calls) or literalValue (for simple variable calls)
                var recType = ""
                if expr.operands.length() > 0 {
                    recType = inferExpressionType(expr.operands[0])
                }
                if recType == "" and expr.literalValue != "" {
                    recType = findVarType(expr.literalValue)
                    if recType == "" and expr.literalValue.contains(".") {
                        recType = resolveChainedPathType(expr.literalValue)
                    }
                }
                var isClassInner = 0
                if isClassType(recType) { isClassInner = 1 }
                let unwrapResult = resolveUnwrapTypeImpl(recType, isClassInner)
                if unwrapResult != "" {
                    return unwrapResult
                }
                return "ptr"
            }
            // Try to look up method return type from receiver's class
            var receiverType = ""
            var receiverTypeResolved = false
            if expr.operands.length() > 0 {
                receiverType = inferExpressionType(expr.operands[0])
                receiverTypeResolved = true
            }
            if not receiverTypeResolved {
                // Check if literalValue is a known variable
                let varIdx = findVar(expr.literalValue)
                var varIdxHandled = false
                if varIdx >= 0 {
                    receiverType = varTypes[varIdx]
                    varIdxHandled = true
                }
                if not varIdxHandled {
                    // Check if literalValue is a field on 'this'
                    let thisIdx = findVar("this")
                    if thisIdx >= 0 {
                        let thisType = varTypes[thisIdx]
                            var fieldType = getSemanticFieldType(thisType, expr.literalValue)
                            if fieldType == "" {
                                fieldType = getSeenFieldType(thisType, expr.literalValue)
                            }
                        if fieldType != "Int" or expr.literalValue == "length" {
                            receiverType = fieldType
                        }
                    }
                    // Try resolving as a chained path (e.g., "this.differ" -> VDOMDiffer)
                    if receiverType == "" and expr.literalValue.contains(".") {
                        receiverType = resolveChainedPathType(expr.literalValue)
                    }
                }
            }

            if receiverType != "" {
                // SIMD method return type inference
                if isSimdVectorType(receiverType) == 1 {
                    if expr.callee == "reduce_add" or expr.callee == "reduce_min" or expr.callee == "reduce_max" {
                        if receiverType.startsWith("f32") or receiverType.startsWith("f64") {
                            return "Float"
                        }
                        return "Int"
                    }
                }
                let methodRetType = getMethodReturnType(receiverType, expr.callee)
                if methodRetType != "" {
                    return methodRetType
                }
            }
            // Some parser paths leave unresolved MethodCall nodes even though the
            // callee should lower exactly like a plain Call node. Only fall back
            // here after receiver-based resolution has already failed.
            if currentClassName != "" {
                let implicitMethodRetType = getMethodReturnType(currentClassName, expr.callee)
                if implicitMethodRetType != "" {
                    return implicitMethodRetType
                }
            }
            let freeFuncRetType = getFunctionReturnType(expr.callee)
            if freeFuncRetType != "" {
                if isAsyncFunction(expr.callee) {
                    return "ptr"
                }
                return freeFuncRetType
            }
            // Last-resort Bool detection: scan funcRetTypes for any method with this name returning Bool
            let boolSuffix = "_" + expr.callee
            var boolScanIdx = funcNames.length() - 1
            while boolScanIdx >= 0 {
                if funcNames[boolScanIdx].endsWith(boolSuffix) {
                    if funcRetTypes[boolScanIdx] == "Bool" {
                        return "Bool"
                    }
                    boolScanIdx = 0 - 1
                }
                boolScanIdx = boolScanIdx - 1
            }
        }
        if expr.kind == "Call" {
            // SIMD vector constructor type inference
            if isSimdVectorType(expr.callee) == 1 {
                return expr.callee
            }
            // Free-function forms of former static methods in lsp/types and
            // similar modules: Foo_new(...) and Foo_fromJson(...).
            if expr.callee.endsWith("_new") {
                let baseType = expr.callee.substring(0, expr.callee.length() - 4)
                if isClassType(baseType) or isDataType(baseType) or findStruct(baseType) >= 0 {
                    return baseType
                }
            }
            if expr.callee.endsWith("_fromJson") {
                let baseType = expr.callee.substring(0, expr.callee.length() - 9)
                let fromJsonRet = getMethodReturnType(baseType, "fromJson")
                if fromJsonRet != "" {
                    return fromJsonRet
                }
                if isClassType(baseType) or isDataType(baseType) or findStruct(baseType) >= 0 {
                    return baseType + "?"
                }
            }
            // SIMD select/shuffle return type = type of vector arg
            if expr.callee == "simd_select" or expr.callee == "simd_shuffle" {
                if expr.arguments.length() >= 2 {
                    return inferExpressionType(expr.arguments[1])
                }
            }
            // Pure callee-name lookups (SIMD gather, includeStr, ptr_deref, cstr, constructors)
            let callExprType = inferCallExprTypeImpl(expr.callee)
            if callExprType != "" {
                return callExprType
            }
            // Enum variant constructors: Circle(3.14) -> parent enum type
            if g_enumVariantCount > 0 {
                if isEnumVariant(expr.callee) {
                    let enumParent = lookupEnumParent(expr.callee)
                    if enumParent != "" {
                        return enumParent
                    }
                }
            }
            // First check user-defined functions
            let userRetType = getFunctionReturnType(expr.callee)
            if userRetType != "" {
                // Async functions return ptr (coroutine handle) when called directly
                // without await. The await handler uses getAsyncDeclaredRetType separately.
                if isAsyncFunction(expr.callee) {
                    return "ptr"
                }
                return userRetType
            }
            let callTable = inferCallTypeTable(expr.callee)
            if callTable != "" { return callTable }
            // Check if callee is a class constructor (e.g., Expr() -> "Expr")
            if isClassType(expr.callee) {
                return expr.callee
            }
            // Generic fallback: check if callee is a method on the current class (implicit this)
            if currentClassName != "" {
                let implicitRetType = getMethodReturnType(currentClassName, expr.callee)
                if implicitRetType != "" {
                    return implicitRetType
                }
            }
        }
        if expr.kind == "MemberAccess" {
            // SIMD swizzle type inference
            if expr.literalValue != "" {
                let swzRecType = findVarType(expr.literalValue)
                if isSimdVectorType(swzRecType) == 1 {
                    let swzLanes = simdLaneCount(swzRecType)
                    if isSwizzlePattern(expr.variableName, swzLanes) == 1 {
                        if expr.variableName.length() == 1 {
                            if swzRecType.startsWith("f32") or swzRecType.startsWith("f64") { return "Float" }
                            return "Int"
                        }
                        return swzRecType
                    }
                }
            }
            // Enum variant access: Color.Red -> enum type
            if g_enumVariantCount > 0 {
                if isEnumVariant(expr.variableName) {
                    let enumParent = lookupEnumParent(expr.variableName)
                    if enumParent != "" and enumParent == expr.literalValue {
                        return enumParent
                    }
                }
            }

            // Field access - infer type from known fields
            var fieldName = expr.variableName

            // Handle chained field names like "program.items" - use the last part
            if fieldName.contains(".") {
                var lastDot = 0
                var fi = 0
                while fi < fieldName.length() {
                    if fieldName.byteAt(fi) == 46 {
                        lastDot = fi
                    }
                    fi = fi + 1
                }
                fieldName = fieldName.substring(lastDot + 1, fieldName.length())
            }

            // For fields that are type-dependent (like 'kind'), do receiver-based lookup first
            // This is important because 'kind' is Int in JsonValue but String in AST nodes
            if fieldName == "kind" or fieldName == "boolValue" or fieldName == "numberValue" or fieldName == "stringValue" or fieldName == "arrayValue" or fieldName == "objectKeys" or fieldName == "objectValues" {
                // Try receiver-based lookup first for these ambiguous fields
                if expr.operands.length() > 0 {
                    let recvType = inferExpressionType(expr.operands[0])
                    if recvType == "JsonValue" {
                        let fieldType = getSeenFieldType("JsonValue", fieldName)
                        return fieldType
                    }
                }
                if expr.literalValue == "this" and currentClassName == "JsonValue" {
                    let fieldType = getSeenFieldType("JsonValue", fieldName)
                    return fieldType
                }
                if expr.literalValue != "" and expr.literalValue != "this" {
                    let recvVarType = findVarType(expr.literalValue)
                    if recvVarType == "JsonValue" {
                        let fieldType = getSeenFieldType("JsonValue", fieldName)
                        return fieldType
                    }
                }
            }

            // CRITICAL: For this.field expressions, do context-aware lookup BEFORE generic fallbacks
            // This fixes type inference for fields like "severity" which are Int in Diagnostic but
            // would incorrectly return String from the generic fallback below
            if expr.literalValue == "this" and currentClassName != "" {
                let semanticFieldType = getSemanticFieldType(currentClassName, fieldName)
                if semanticFieldType != "" {
                    return semanticFieldType
                }
                let contextFieldType = getSeenFieldType(currentClassName, fieldName)
                if contextFieldType != "" {
                    return contextFieldType
                }
            }

            // CRITICAL: Try receiver-based lookup BEFORE generic fallbacks
            // This ensures msg.params returns JsonValue? (not Array<ParamNode> from generic fallback)
            if expr.operands.length() > 0 {
                let recvType = inferExpressionType(expr.operands[0])
                if recvType != "" {
                    let semanticFieldType = getSemanticFieldType(recvType, fieldName)
                    if semanticFieldType != "" {
                        return semanticFieldType
                    }
                    let fieldType = getSeenFieldType(recvType, fieldName)
                    if fieldType != "" {
                        return fieldType
                    }
                }
            }
            if expr.literalValue != "" and expr.literalValue != "this" {
                // Receiver is a variable name in literalValue
                // Handle chained paths like "item.function.returnType"
                if expr.literalValue.contains(".") {
                    // Recursively resolve the type of the chained path
                    let chainedType = resolveChainedPathType(expr.literalValue)
                    if chainedType != "" {
                        let semanticFieldType = getSemanticFieldType(chainedType, fieldName)
                        if semanticFieldType != "" {
                            return semanticFieldType
                        }
                        let fieldType = getSeenFieldType(chainedType, fieldName)
                        if fieldType != "" {
                            return fieldType
                        }
                    }
                }
                let recvVarType = findVarType(expr.literalValue)
                if recvVarType != "" {
                    let semanticFieldType = getSemanticFieldType(recvVarType, fieldName)
                    if semanticFieldType != "" {
                        return semanticFieldType
                    }
                    let fieldType = getSeenFieldType(recvVarType, fieldName)
                    if fieldType != "" {
                        return fieldType
                    }
                }
                let thisIdx = findVar("this")
                if thisIdx >= 0 {
                    let thisType = varTypes[thisIdx]
                    let receiverFieldType = getSemanticFieldType(thisType, expr.literalValue)
                    if receiverFieldType != "" {
                        let semanticFieldType = getSemanticFieldType(receiverFieldType, fieldName)
                        if semanticFieldType != "" {
                            return semanticFieldType
                        }
                    }
                }
            }

            // FALLBACK: Generic field name to type mappings (used when receiver type is unknown)
            let fieldFallback = inferFieldTypeFallback(fieldName)
            if fieldFallback != "" { return fieldFallback }
            // NOTE: Receiver-based lookup is done earlier
            // Generic fallbacks above are only used when receiver type is unknown
        }
        if expr.kind == "StructLiteral" {
            // Struct literal - return the struct type name
            return expr.literalType
        }
        if expr.kind == "IndexAccess" {
            // Array indexing - return element type
            let arrayType = inferExpressionType(expr.operands[0])
            let elemType = inferIndexElementType(arrayType)
            if elemType != "" { return elemType }
            // Generic fallback: parse Array<T> to extract T
            if arrayType.startsWith("Array<") and arrayType.endsWith(">") {
                let elementType = arrayType.substring(6, arrayType.length() - 1)
                return elementType
            }
            return "ptr"  // Default for unknown array types
        }
        if expr.kind == "ArrayLiteral" {
            // Infer element type from first element if available
            if expr.arguments.length() > 0 {
                let firstElemType = inferExpressionType(expr.arguments[0])
                if firstElemType == "String" {
                    return "Array<String>"
                }
                if firstElemType == "Float" {
                    return "Array<Float>"
                }
                if firstElemType == "Bool" {
                    return "Array<Bool>"
                }
                return "Array<Int>"
            }
            return "Array"
        }
        if expr.kind == "StringInterpolation" {
            var i = 0
            while i < expr.arguments.length() {
                collectStringConstantsFromExpr(expr.arguments[i])
                i = i + 1
            }
            i = 0
            while i < expr.operands.length() {
                collectStringConstantsFromExpr(expr.operands[i])
                i = i + 1
            }
            return "String"
        }
        if expr.kind == "StructLiteral" {
            if expr.literalType != "" {
                return expr.literalType
            }
            return "ptr"
        }
        if expr.kind == "Unary" {
            // Unary operators
            if expr.operator == "!" or expr.operator == "not" {
                return "Bool"
            }
            // Address-of: &T → *T (pointer type)
            if expr.operator == "&" and expr.operands.length() > 0 {
                let innerType = inferExpressionType(expr.operands[0])
                return "*" + innerType
            }
            // Pointer dereference: *T → remove one pointer level
            if expr.operator == "*" and expr.operands.length() > 0 {
                let ptrType = inferExpressionType(expr.operands[0])
                if ptrType.startsWith("*") {
                    return ptrType.substring(1, ptrType.length())
                }
                return "Int"
            }
            if expr.operands.length() > 0 {
                return inferExpressionType(expr.operands[0])
            }
            return "Int"
        }
        if expr.kind == "Await" {
            if expr.operands.length() > 0 {
                let inner = expr.operands[0]
                if inner.kind == "Call" {
                    let asyncRet = getAsyncDeclaredRetType(inner.callee)
                    if asyncRet != "" { return asyncRet }
                    return getFunctionReturnType(inner.callee)
                }
                return inferExpressionType(inner)
            }
            return "Void"
        }
        if expr.kind == "Elvis" or expr.kind == "NullCoalesce" {
            // Elvis/NullCoalesce returns the type of the left operand
            if expr.operands.length() > 0 {
                return inferExpressionType(expr.operands[0])
            }
        }
        if expr.kind == "SafeNavigation" {
            // Safe navigation returns the member type (nullable, but we use default)
            return "Int"
        }
        if expr.kind == "WhenExpression" {
            // When expression returns the type of the first arm's result
            if expr.arguments.length() > 0 {
                let firstArm = expr.arguments[0]
                if firstArm.operands.length() > 1 {
                    return inferExpressionType(firstArm.operands[1])
                }
            }
        }
        if expr.kind == "Range" {
            return "Range"
        }
        if expr.kind == "IfExpression" {
            // If expression returns the type of the then branch
            if expr.operands.length() > 1 {
                return inferExpressionType(expr.operands[1])
            }
        }
        if expr.kind == "IsExpression" {
            return "Bool"
        }
        if expr.kind == "Closure" {
            return "Int"
        }
        if expr.kind == "TryPropagate" {
            if expr.operands.length() > 0 {
                let tryInnerType = inferExpressionType(expr.operands[0])
                let tryResult = resolveTryPropagateTypeImpl(tryInnerType)
                if tryResult != "" {
                    return tryResult
                }
                return tryInnerType
            }
        }
        if expr.kind == "Cast" {
            return expr.literalValue
        }
        return "Int"
    }

    // Escape string for LLVM IR. Uses byteAt() to avoid per-char substring allocation.
    // ASCII: 92='\', 34='"', 10='\n', 9='\t', 13='\r'
    // Escape a string for embedding in LLVM IR constant data. Replaces
    // backslash, double-quote, newline, tab, and carriage-return with their
    // LLVM hex escape sequences (\5C, \22, \0A, \09, \0D). Uses a fast
    // path (byteAt scan) to skip allocation when no escaping is needed.
    fun escapeString(str: String) r: String {
        // Fast path: check if any escaping is needed at all
        var needsEscape = 0
        var scanIdx = 0
        while scanIdx < str.length() {
            let sb = str.byteAt(scanIdx)
            if sb == 92 or sb == 34 or sb == 10 or sb == 9 or sb == 13 {
                needsEscape = 1
                scanIdx = str.length()
            }
            scanIdx = scanIdx + 1
        }
        if needsEscape == 0 { return str }
        // Slow path: build escaped string using byteAt
        var result = ""
        var i = 0
        while i < str.length() {
            let b = str.byteAt(i)
            var charHandled = false
            if b == 92 {
                result = result + "\\\\"
                charHandled = true
            }
            if not charHandled and b == 34 {
                result = result + "\\22"
                charHandled = true
            }
            if not charHandled and b == 10 {
                result = result + "\\0A"
                charHandled = true
            }
            if not charHandled and b == 9 {
                result = result + "\\09"
                charHandled = true
            }
            if not charHandled and b == 13 {
                result = result + "\\0D"
                charHandled = true
            }
            if not charHandled {
                result = result + str.substring(i, i + 1)
            }
            i = i + 1
        }
        return result
    }

    // Pre-scan all expressions in a program to collect string literal constants.
    // These are emitted as LLVM global constants before any function bodies.
    // Also piggybacks call counting for ML inline decisions and self-call
    // detection (for the norecurse attribute). Delegates to
    // collectStringConstantsImpl in ir_string_collect.seen.
    fun collectStringConstants(program: ProgramNode) r: Void {
        initCollectionBoxes()
        collectStringConstantsImpl(program, stringConstants, g_selfCallBox, g_selfCallCountBox, g_callCountNamesBox, g_callCountEntriesBox)
        syncCollectionBoxes()
        collectDefaultParamStringConstants(program)
    }

    // Thin wrapper for collectStringConstantsFromExpr (called from inferExpressionType)
    fun collectStringConstantsFromExpr(expr: ParserExpressionNode) r: Void {
        initCollectionBoxes()
        collectStringConstantsFromExprImpl(expr, stringConstants, g_callCountNamesBox, g_callCountEntriesBox)
        syncCollectionBoxes()
    }
    // Generate IR for string interpolation: "Hello {name}!"
    // Emits a chain of seen_str_concat_ss calls, converting each interpolated
    // expression to a string (via toString, seen_int_to_string, etc.).
    fun generateStringInterpolation(expr: ParserExpressionNode) r: String {
        var resultReg = ""
        let numParts = expr.arguments.length()
        let numExprs = expr.operands.length()
        var i = 0
        while i < numParts {
            let strPart = expr.arguments[i]
            let partReg = generateLiteral(strPart)
            if resultReg == "" {
                resultReg = partReg
            } else {
                // Fix default "0" values to proper SeenString zeroinitializer
                var resultStrReg = resultReg
                var partStrReg = partReg
                if resultReg == "0" {
                    resultStrReg = "zeroinitializer"
                }
                if partReg == "0" {
                    partStrReg = "zeroinitializer"
                }
                let concatReg = getNextReg()
                output.append("  " + concatReg + " = call %SeenString @seen_str_concat_ss(%SeenString " + resultStrReg + ", %SeenString " + partStrReg + ")\n")
                resultReg = concatReg
            }
            if i < numExprs {
                let exprNode = expr.operands[i]
                let exprType = inferExpressionType(exprNode)
                let exprReg = generateExpression(exprNode)
                // Convert expression to string based on its type
                // Use a single strExprReg variable that's assigned in each branch
                var strExprReg = exprReg
                if exprType == "String" {
                    // Fix default "0" value to proper SeenString zeroinitializer
                    if exprReg == "0" {
                        strExprReg = "zeroinitializer"
                    } else {
                        strExprReg = exprReg
                    }
                } else if exprType == "Int" {
                    strExprReg = getNextReg()
                    output.append("  " + strExprReg + " = call %SeenString @seen_int_to_string(i64 " + exprReg + ")\n")
                } else if exprType == "Float" {
                    strExprReg = getNextReg()
                    output.append("  " + strExprReg + " = call %SeenString @seen_float_to_string(double " + exprReg + ")\n")
                } else if exprType == "Bool" {
                    strExprReg = getNextReg()
                    output.append("  " + strExprReg + " = call %SeenString @seen_bool_to_string(i1 " + exprReg + ")\n")
                } else if exprType == "Char" {
                    strExprReg = getNextReg()
                    output.append("  " + strExprReg + " = call %SeenString @seen_char_to_str(i64 " + exprReg + ")\n")
                }
                // Fix default "0" values to proper SeenString zeroinitializer
                var resultStrReg2 = resultReg
                var strExprStrReg = strExprReg
                if resultReg == "0" {
                    resultStrReg2 = "zeroinitializer"
                }
                if strExprReg == "0" {
                    strExprStrReg = "zeroinitializer"
                }
                let concatReg = getNextReg()
                output.append("  " + concatReg + " = call %SeenString @seen_str_concat_ss(%SeenString " + resultStrReg2 + ", %SeenString " + strExprStrReg + ")\n")
                resultReg = concatReg
            }
            i = i + 1
        }
        return resultReg
    }

    // Elvis operator: a ?: b — returns a if non-zero/non-null, otherwise b
    // Generate IR for the elvis/null-coalesce operator (a ?? b).
    // Evaluates 'a', checks if null (icmp eq ptr, null), and returns 'b'
    // if null, otherwise 'a'. Uses a phi node to merge the two paths.
    fun generateElvis(expr: ParserExpressionNode) r: String {
        let leftReg = generateExpression(expr.operands[0])
        let leftType = inferExpressionType(expr.operands[0])
        let llvmType = mapType(leftType)

        let thenLabel = getNextBlockLabel()
        let elseLabel = getNextBlockLabel()
        let endLabel = getNextBlockLabel()

        // Check if left is "null" / zero / empty
        let cmpReg = getNextReg()
        if llvmType == "%SeenString" {
            // For strings, check if length is 0
            let lenReg = getNextReg()
            output.append("  " + lenReg + " = extractvalue %SeenString " + leftReg + ", 0\n")
            output.append("  " + cmpReg + " = icmp eq i64 " + lenReg + ", 0\n")
        } else if llvmType == "i1" {
            output.append("  " + cmpReg + " = icmp eq i1 " + leftReg + ", 0\n")
        } else if llvmType == "double" {
            output.append("  " + cmpReg + " = fcmp oeq double " + leftReg + ", 0.0\n")
        } else {
            // i64 or ptr: check == 0
            output.append("  " + cmpReg + " = icmp eq i64 " + leftReg + ", 0\n")
        }

        output.append("  br i1 " + cmpReg + ", label %" + elseLabel + ", label %" + thenLabel + "\n")

        // Then: left is non-null, use left
        output.append(thenLabel + ":\n")
        output.append("  br label %" + endLabel + "\n")

        // Else: left is null, compute right
        output.append(elseLabel + ":\n")
        let rightReg = generateExpression(expr.operands[1])
        output.append("  br label %" + endLabel + "\n")

        // Merge with phi
        output.append(endLabel + ":\n")
        let resultReg = getNextReg()
        output.append("  " + resultReg + " = phi " + llvmType + " [ " + leftReg + ", %" + thenLabel + " ], [ " + rightReg + ", %" + elseLabel + " ]\n")
        return resultReg
    }

    // Safe navigation: obj?.member — returns member if obj is non-null, else default
    // Generate IR for the safe navigation operator (a?.b).
    // Checks if 'a' is null — if so, short-circuits to null/0 without
    // accessing the field. Otherwise, proceeds with normal field access.
    fun generateSafeNavigation(expr: ParserExpressionNode) r: String {
        let recvReg = generateExpression(expr.operands[0])
        let recvType = inferExpressionType(expr.operands[0])
        let memberName = expr.variableName

        let thenLabel = getNextBlockLabel()
        let elseLabel = getNextBlockLabel()
        let endLabel = getNextBlockLabel()

        // Check if receiver is null (pointer == 0)
        let cmpReg = getNextReg()
        if mapType(recvType) == "%SeenString" {
            let lenReg = getNextReg()
            output.append("  " + lenReg + " = extractvalue %SeenString " + recvReg + ", 0\n")
            output.append("  " + cmpReg + " = icmp eq i64 " + lenReg + ", 0\n")
        } else {
            output.append("  " + cmpReg + " = icmp eq i64 " + recvReg + ", 0\n")
        }

        output.append("  br i1 " + cmpReg + ", label %" + elseLabel + ", label %" + thenLabel + "\n")

        // Then: non-null, access member
        output.append(thenLabel + ":\n")
        // Build a MemberAccess expression to reuse existing codegen
        let memberExpr = ParserExpressionNode.new()
        memberExpr.kind = "MemberAccess"
        memberExpr.variableName = memberName
        memberExpr.operands.push(expr.operands[0])
        let memberReg = generateMemberAccess(memberExpr)
        let memberType = inferExpressionType(memberExpr)
        let memberLlvm = mapType(memberType)
        output.append("  br label %" + endLabel + "\n")

        // Else: null, use default
        output.append(elseLabel + ":\n")
        var defaultVal = "0"
        if memberLlvm == "%SeenString" {
            defaultVal = "zeroinitializer"
        }
        if memberLlvm == "double" {
            defaultVal = "0.0"
        }
        if memberLlvm == "i1" {
            defaultVal = "false"
        }
        output.append("  br label %" + endLabel + "\n")

        // Merge
        output.append(endLabel + ":\n")
        let resultReg = getNextReg()
        output.append("  " + resultReg + " = phi " + memberLlvm + " [ " + memberReg + ", %" + thenLabel + " ], [ " + defaultVal + ", %" + elseLabel + " ]\n")
        return resultReg
    }

    // When expression (pattern matching)
    // Generate IR for a when (match) expression. Evaluates the subject once,
    // then emits a chain of comparisons against each arm's pattern value.
    // Each arm branches to its body block or falls through to the next
    // comparison. All arms merge into a phi node that produces the result.
    // Supports integer, string, and enum variant patterns.
    fun generateWhenExpression(expr: ParserExpressionNode) r: String {
        // Subject expression (if present)
        var subjectReg = "0"
        var subjectType = "Int"
        if expr.operands.length() > 0 {
            subjectReg = generateExpression(expr.operands[0])
            subjectType = inferExpressionType(expr.operands[0])
        }
        let subjectLlvm = mapType(subjectType)

        let endLabel = getNextBlockLabel()
        // Result alloca — use i64 as universal result storage
        let resultAlloca = getNextReg()
        output.append("  " + resultAlloca + " = alloca i64, align 8\n")
        output.append("  store i64 0, ptr " + resultAlloca + "\n")

        // Generate each arm
        var armIdx = 0
        while armIdx < expr.arguments.length() {
            let arm = expr.arguments[armIdx]
            // arm.variableName = pattern kind ("Is", "Literal", "Wildcard", "Variable")
            // arm.literalValue = type/constructor name or literal value
            // arm.operands[0] = Pattern expression
            // arm.operands[1] = arm result expression
            let patternExpr = arm.operands[0]
            let patternKind = patternExpr.variableName

            let armBodyLabel = getNextBlockLabel()
            let nextCheckLabel = getNextBlockLabel()

            var armGenerated = false
            if patternKind == "Literal" {
                // Literal pattern: compare subject with literal value
                let litVal = patternExpr.literalValue
                let litType = patternExpr.literalType
                let cmpReg = getNextReg()
                if litType == "Bool" {
                    var boolVal = "0"
                    if litVal == "true" { boolVal = "1" }
                    output.append("  " + cmpReg + " = icmp eq i1 " + subjectReg + ", " + boolVal + "\n")
                }
                if litType == "String" {
                    let litStrIdx = getStringConstantIndex(litVal)
                    let litStrReg = getNextReg()
                    output.append("  " + litStrReg + " = load %SeenString, ptr @.str." + litStrIdx.toString() + "\n")
                    let eqReg = getNextReg()
                    // Fix default "0" values to proper SeenString zeroinitializer
                    var subjectStrReg = subjectReg
                    if subjectReg == "0" {
                        subjectStrReg = "zeroinitializer"
                    }
                    output.append("  " + eqReg + " = call i1 @seen_str_eq(%SeenString " + subjectStrReg + ", %SeenString " + litStrReg + ")\n")
                    output.append("  " + cmpReg + " = icmp eq i1 " + eqReg + ", 1\n")
                }
                if litType != "Bool" and litType != "String" {
                    output.append("  " + cmpReg + " = icmp eq i64 " + subjectReg + ", " + litVal + "\n")
                }
                output.append("  br i1 " + cmpReg + ", label %" + armBodyLabel + ", label %" + nextCheckLabel + "\n")
                armGenerated = true
            }
            if not armGenerated and patternKind == "Is" {
                let variantName = patternExpr.literalValue
                let tagIdx = lookupEnumVariantTag(variantName)
                if subjectLlvm == "i64" {
                    // Simple enum: subject IS the tag value (i64), compare directly
                    let cmpReg = getNextReg()
                    output.append("  " + cmpReg + " = icmp eq i64 " + subjectReg + ", " + tagIdx.toString() + "\n")
                    output.append("  br i1 " + cmpReg + ", label %" + armBodyLabel + ", label %" + nextCheckLabel + "\n")
                } else {
                    // Data enum: subject is ptr to heap object, load tag from offset 0
                    let tagLoadReg = getNextReg()
                    output.append("  " + tagLoadReg + " = load i64, ptr " + subjectReg + "\n")
                    let cmpReg = getNextReg()
                    output.append("  " + cmpReg + " = icmp eq i64 " + tagLoadReg + ", " + tagIdx.toString() + "\n")
                    output.append("  br i1 " + cmpReg + ", label %" + armBodyLabel + ", label %" + nextCheckLabel + "\n")
                }
                armGenerated = true
            }
            if not armGenerated and (patternKind == "Wildcard" or patternKind == "Variable") {
                // Wildcard/else pattern: always matches
                output.append("  br label %" + armBodyLabel + "\n")
                armGenerated = true
            }
            if not armGenerated {
                // Unknown pattern kind, skip
                output.append("  br label %" + nextCheckLabel + "\n")
            }

            // Arm body
            output.append(armBodyLabel + ":\n")
            cseClear()

            // Guard clause: if arm has 3 operands, evaluate guard condition
            if arm.operands.length() > 2 {
                let guardReg = generateExpression(arm.operands[2])
                let guardType = inferExpressionType(arm.operands[2])
                var guardCond = guardReg
                // Convert non-i1 guard to i1
                if guardType != "Bool" {
                    guardCond = getNextReg()
                    output.append("  " + guardCond + " = icmp ne i64 " + guardReg + ", 0\n")
                }
                output.append("  br i1 " + guardCond + ", label %" + armBodyLabel + ".guarded, label %" + nextCheckLabel + "\n")
                output.append(armBodyLabel + ".guarded:\n")
                cseClear()
            }

            // For Is patterns with destructuring, bind fields
            if patternKind == "Is" and patternExpr.operands.length() > 0 {
                // Get ptr to subject for field access
                var destructPtrReg = subjectReg
                if subjectLlvm != "ptr" {
                    destructPtrReg = getNextReg()
                    output.append("  " + destructPtrReg + " = inttoptr i64 " + subjectReg + " to ptr\n")
                }
                var fieldIdx = 0
                while fieldIdx < patternExpr.operands.length() {
                    let fieldBind = patternExpr.operands[fieldIdx]
                    if fieldBind.kind == "PatternField" {
                        let bindingName = fieldBind.literalValue
                        if bindingName == "" {
                            fieldIdx = fieldIdx + 1
                            continue
                        }
                        // Load field from enum object: offset = 8 + fieldIdx * 8
                        let fieldOffset = 8 + fieldIdx * 8
                        let fieldPtrReg = getNextReg()
                        output.append("  " + fieldPtrReg + " = getelementptr i8, ptr " + destructPtrReg + ", i64 " + fieldOffset.toString() + "\n")
                        // Look up the field type from enum info
                        let variantName = patternExpr.literalValue
                        let fType = lookupEnumFieldType(variantName, fieldIdx)
                        let fLlvm = mapType(fType)
                        let fLoadReg = getNextReg()
                        output.append("  " + fLoadReg + " = load " + fLlvm + ", ptr " + fieldPtrReg + "\n")
                        // Store into binding variable
                        let bindIdx = findVar(bindingName)
                        if bindIdx >= 0 {
                            output.append("  store " + fLlvm + " " + fLoadReg + ", ptr " + varRegs[bindIdx] + "\n")
                        }
                    }
                    fieldIdx = fieldIdx + 1
                }
            }

            // Generate arm result expression
            if arm.operands.length() > 1 {
                let armResult = arm.operands[1]
                if armResult.kind == "ReturnExpr" {
                    // Return from enclosing function inside when/match arm
                    if armResult.operands.length() > 0 {
                        let retValReg = generateExpression(armResult.operands[0])
                        let retType = mapType(currentFunctionReturnType)
                        output.append("  ret " + retType + " " + retValReg + "\n")
                    } else {
                        let retType = mapType(currentFunctionReturnType)
                        if retType == "void" {
                            output.append("  ret void\n")
                        } else {
                            output.append("  ret " + retType + " 0\n")
                        }
                    }
                    blockTerminated = true
                } else {
                    let armResultReg = generateExpression(armResult)
                    if not blockTerminated {
                        let armResultType = inferExpressionType(armResult)
                        var armStoreReg = armResultReg
                        if armResultType == "Bool" or armResultType == "Boolean" {
                            armStoreReg = getNextReg()
                            output.append("  " + armStoreReg + " = zext i1 " + armResultReg + " to i64\n")
                        }
                        output.append("  store i64 " + armStoreReg + ", ptr " + resultAlloca + "\n")
                    }
                }
            }
            if not blockTerminated {
                output.append("  br label %" + endLabel + "\n")
            }
            blockTerminated = false

            // Next check
            output.append(nextCheckLabel + ":\n")
            cseClear()
            armIdx = armIdx + 1
        }

        // After all arms, branch to end (fallthrough if no match)
        output.append("  br label %" + endLabel + "\n")

        // End block
        output.append(endLabel + ":\n")
        cseClear()
        let resultReg = getNextReg()
        output.append("  " + resultReg + " = load i64, ptr " + resultAlloca + "\n")
        return resultReg
    }

    // Look up enum variant tag index by variant name
    fun lookupEnumVariantTag(variantName: String) r: Int {
        return lookupEnumVariantTagImpl(variantName, g_enumVariantNames, g_enumVariantTags, g_enumVariantCount)
    }

    // Look up parent enum type for a variant name
    fun lookupEnumParent(variantName: String) r: String {
        return lookupEnumParentImpl(variantName, g_enumVariantNames, g_enumVariantParent, g_enumVariantCount)
    }

    // Look up enum field type by variant name and field index
    fun lookupEnumFieldType(variantName: String, fieldIdx: Int) r: String {
        return lookupEnumFieldTypeImpl(variantName, fieldIdx, g_enumVariantNames, g_enumVariantFieldTypes, g_enumVariantCount)
    }

    // Look up field count for a variant
    fun lookupEnumFieldCount(variantName: String) r: Int {
        return lookupEnumFieldCountImpl(variantName, g_enumVariantNames, g_enumVariantFieldCounts, g_enumVariantCount)
    }

    // Check if a name is a registered enum variant
    fun isEnumVariant(name: String) r: Bool {
        return isEnumVariantImpl(name, g_enumVariantNames, g_enumVariantCount)
    }

    // Generate enum variant constructor call
    // Simple enums (no fields): return tag as i64
    // Data enums (with fields): allocate tagged heap object [i64 tag, field1, field2, ...]
    // Generate IR for an enum variant constructor call. Simple enums
    // (no fields) return the tag as an i64 integer value directly.
    // Data enums (with fields) allocate a heap object: 8 bytes for the
    // tag at offset 0, then 8 bytes per field at offsets 8, 16, 24, etc.
    // Returns the malloc'd pointer (data enums map to "ptr" in mapType).
    fun generateEnumConstructor(variantName: String, expr: ParserExpressionNode) r: String {
        let tag = lookupEnumVariantTag(variantName)
        let fieldCount = lookupEnumFieldCount(variantName)

        // Simple enum: just return the tag as an integer value
        if fieldCount == 0 {
            return tag.toString()
        }

        // Data enum: allocate heap object
        // Total size: 8 bytes for tag + 8 bytes per field
        let totalSize = 8 + fieldCount * 8
        let objReg = getNextReg()
        output.append("  " + objReg + " = call ptr @malloc(i64 " + totalSize.toString() + ")\n")
        // Store tag at offset 0
        output.append("  store i64 " + tag.toString() + ", ptr " + objReg + "\n")
        // Store each field
        var fi = 0
        while fi < fieldCount and fi < expr.arguments.length() {
            let fieldReg = generateExpression(expr.arguments[fi])
            let fieldType = lookupEnumFieldType(variantName, fi)
            let fieldLlvm = mapType(fieldType)
            let fieldOffset = 8 + fi * 8
            let fieldPtrReg = getNextReg()
            output.append("  " + fieldPtrReg + " = getelementptr i8, ptr " + objReg + ", i64 " + fieldOffset.toString() + "\n")
            output.append("  store " + fieldLlvm + " " + fieldReg + ", ptr " + fieldPtrReg + "\n")
            fi = fi + 1
        }
        // Return as ptr (enum types map to "ptr" in mapType)
        return objReg
    }
