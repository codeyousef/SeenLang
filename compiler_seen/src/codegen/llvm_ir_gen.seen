var g_irgenFieldInfoCacheKeys: Array<String> = Array<String>()
var g_irgenFieldInfoCacheIdxs: Array<Int> = Array<Int>()

fun findCachedIrgenFieldIndex(key: String) r: Int {
    var i = g_irgenFieldInfoCacheKeys.length() - 1
    while i >= 0 {
        if g_irgenFieldInfoCacheKeys[i] == key {
            return g_irgenFieldInfoCacheIdxs[i]
        }
        i = i - 1
    }
    return -1
}

fun cacheIrgenFieldIndex(key: String, idx: Int) r: Void {
    if idx < 0 { return }
    g_irgenFieldInfoCacheKeys.push(key)
    g_irgenFieldInfoCacheIdxs.push(idx)
}

