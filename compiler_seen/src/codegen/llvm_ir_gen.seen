// LLVM IR Generator - Generates LLVM IR text from ProgramNode
// This replaces the C generator for Stage1 compilation

import parser.real_parser.{ProgramNode, ItemNode, FunctionNode, ClassNode, BlockNode, StatementNode, ParserExpressionNode, ParamNode, TypeNode}
import str.string.{StringBuilder}
import io.file.{readText, exists}
import trace.{traceGen}

class LLVMIRGenerator {
    var output: StringBuilder
    var stringConstants: Array<String>
    var nextReg: Int
    var nextBlock: Int
    // Using parallel arrays as workaround for Map.get() bug
    var varNames: Array<String>
    var varRegs: Array<String>
    var varTypes: Array<String>
    var indent: Int
    // Struct layout registry - parallel arrays for struct info
    var structNames: Array<String>        // Struct/class names
    var structLayouts: Array<String>      // LLVM struct layout strings
    var structFieldNames: Array<String>   // Comma-separated field names
    var structFieldTypes: Array<String>   // Comma-separated field type names
    var structLlvmFieldTypes: Array<String> // Pipe-separated LLVM field type names (from header)
    var structSizes: Array<Int>           // Struct sizes in bytes
    var structMethodNames: Array<String>  // Comma-separated method names
    var structMethodRetTypes: Array<String> // Comma-separated method return types
    // Function registry - track user-defined function return types
    var funcNames: Array<String>           // Function names
    var funcRetTypes: Array<String>        // Function return types
    // Current function context
    var currentFunctionReturnType: String
    var currentClassName: String  // Track current class for method type inference
    var blockTerminated: Bool  // Track if current block has a terminator
    // Loop context for break/continue
    var currentLoopCondLabel: String  // Label to jump to for continue
    var currentLoopEndLabel: String   // Label to jump to for break
    // Pre-allocated variable names and types (for hoisting allocas to entry block)
    var preAllocatedVars: Array<String>
    var preAllocatedTypes: Array<String>
    // Module prefix for per-module compilation (empty for multi-module)
    var stringConstantPrefix: String
    // Track which functions have been emitted in current module (reset per-module)
    var generatedFunctions: Array<String>
    // Track which class types have been emitted in current module (reset per-module)
    var generatedClasses: Array<String>
    // Track if types were loaded from header file (skip emitting class types)
    var typesLoadedFromHeader: Bool
    // Track if runtime declarations were loaded from header file (skip emitting core runtime decls)
    var runtimeDeclsLoaded: Bool
    // Path to type header file (generated by Rust bootstrap compiler with --emit-type-header)
    // If set and file exists, type declarations are read from this file instead of hardcoded
    var typeHeaderPath: String
    // Expected array literal type (used to derive element type for [])
    var pendingArrayLiteralType: String
    // Generic class method base names - populated during registerStructLayout
    // Used to skip standalone functions that are actually class methods
    var classMethodBaseNames: Array<String>

    static fun new() r: LLVMIRGenerator {
        return LLVMIRGenerator{
            output: StringBuilder.new(),
            stringConstants: Array<String>(),
            nextReg: 1,
            nextBlock: 0,
            varNames: Array<String>(),
            varRegs: Array<String>(),
            varTypes: Array<String>(),
            indent: 0,
            structNames: Array<String>(),
            structLayouts: Array<String>(),
            structFieldNames: Array<String>(),
            structFieldTypes: Array<String>(),
            structLlvmFieldTypes: Array<String>(),
            structSizes: Array<Int>(),
            structMethodNames: Array<String>(),
            structMethodRetTypes: Array<String>(),
            funcNames: Array<String>(),
            funcRetTypes: Array<String>(),
            currentFunctionReturnType: "",
            currentClassName: "",
            blockTerminated: false,
            currentLoopCondLabel: "",
            currentLoopEndLabel: "",
            preAllocatedVars: Array<String>(),
            preAllocatedTypes: Array<String>(),
            stringConstantPrefix: "",
            generatedFunctions: Array<String>(),
            generatedClasses: Array<String>(),
            typesLoadedFromHeader: false,
            runtimeDeclsLoaded: false,
            typeHeaderPath: "",
            pendingArrayLiteralType: "",
            classMethodBaseNames: Array<String>()
        }
    }

    // Set the path to the type header file (generated by --emit-type-header)
    fun setTypeHeaderPath(path: String) r: Void {
        typeHeaderPath = path
    }

    // Reset generator state for per-module compilation (keeps struct/func registries)
    fun reset() r: Void {
        output = StringBuilder.new()
        stringConstants = Array<String>()
        varNames = Array<String>()
        varRegs = Array<String>()
        varTypes = Array<String>()
        nextReg = 1
        nextBlock = 0
        currentFunctionReturnType = ""
        currentClassName = ""
        blockTerminated = false
        currentLoopCondLabel = ""
        currentLoopEndLabel = ""
        preAllocatedVars = Array<String>()
        preAllocatedTypes = Array<String>()
        stringConstantPrefix = ""
        generatedFunctions = Array<String>()
        generatedClasses = Array<String>()
        typesLoadedFromHeader = false
        pendingArrayLiteralType = ""
        // Keep struct/func registries for cross-module references
    }

    // Register known data types from the parser that are used as value types
    // These need to be manually registered because 'data' definitions aren't
    // captured as program items like 'class' definitions
    fun registerKnownDataTypes() r: Void {
        traceGen("registerKnownDataTypes: start structNames len=" + structNames.length().toString())
        if structNames.length() > 0 {
            traceGen("registerKnownDataTypes: end structNames len=" + structNames.length().toString())
            return
        }
        // ItemNode { itemType: String, name: String, visibility: String, importPath: Array<String>, importSymbols: Array<ImportSymbolNode>, function: FunctionNode, classNode: ClassNode, enumNode: EnumNode }
        // Arrays are stored as ptr (8 bytes each, pointer to heap-allocated SeenArray), class types stored as i64
        structNames.push("ItemNode")
        traceGen("registerKnownDataTypes: pushed ItemNode")
        structLayouts.push("{ %SeenString, %SeenString, %SeenString, ptr, ptr, i64, i64, i64 }")
        structFieldNames.push("itemType,name,visibility,importPath,importSymbols,function,classNode,enumNode")
        // Use Seen types (not LLVM types) for getSeenFieldType to work correctly
        // Field types are pipe-separated per getSeenFieldType parsing
        structFieldTypes.push("String|String|String|Array<String>|Array<ImportSymbolNode>|FunctionNode|ClassNode|EnumNode")
        structLlvmFieldTypes.push("")
        structSizes.push(88)  // 16+16+16+8+8+8+8+8 = 88 bytes (matches Rust backend)
        structMethodNames.push("")
        structMethodRetTypes.push("")
        // ImportSymbolNode { name: String, alias: String }
        structNames.push("ImportSymbolNode")
        structLayouts.push("{ %SeenString, %SeenString }")
        structFieldNames.push("name,alias")
        structFieldTypes.push("String|String")
        structLlvmFieldTypes.push("")
        structSizes.push(32)
        structMethodNames.push("")
        structMethodRetTypes.push("")
        // ParamNode { name: String, paramType: TypeNode (inline), isMutable: i1 }
        structNames.push("ParamNode")
        structLayouts.push("{ %SeenString, %TypeNode, i1 }")
        structFieldNames.push("name,paramType,isMutable")
        structFieldTypes.push("String|TypeNode|Bool")
        structLlvmFieldTypes.push("")
        // %SeenString(16) + %TypeNode(24) + i1(1) + padding = 48
        structSizes.push(48)
        structMethodNames.push("")
        structMethodRetTypes.push("")
        // TypeNode { typeName: String, isNullable: i1 }
        structNames.push("TypeNode")
        structLayouts.push("{ %SeenString, i1 }")
        structFieldNames.push("typeName,isNullable")
        structFieldTypes.push("String|Bool")
        structLlvmFieldTypes.push("")
        // %SeenString(16) + i1(1) + padding = 24
        structSizes.push(24)
        structMethodNames.push("")
        structMethodRetTypes.push("")
        // ImportPathInfo { text: String, segments: ptr }
        structNames.push("ImportPathInfo")
        structLayouts.push("{ %SeenString, ptr }")
        structFieldNames.push("text,segments")
        structFieldTypes.push("String|Array<String>")
        structLlvmFieldTypes.push("")
        structSizes.push(24)
        structMethodNames.push("")
        structMethodRetTypes.push("")
        // FunctionNode { name: String, params: Array<ParamNode>, returnType: TypeNode (inline data), body: BlockNode (class, i64), isAsync: Bool, isInline: Bool, isStatic: Bool }
        // Actual layout from Rust: { { i64, ptr }, ptr, %TypeNode, i64, i1, i1, i1 }
        // Where %TypeNode = { { i64, ptr }, i1 } = { %SeenString, i1 }
        structNames.push("FunctionNode")
        // Note: TypeNode is inline (data type), BlockNode is i64 (class type)
        structLayouts.push("{ %SeenString, ptr, %TypeNode, i64, i1, i1, i1 }")
        structFieldNames.push("name,params,returnType,body,isAsync,isInline,isStatic")
        structFieldTypes.push("String|Array<ParamNode>|TypeNode|BlockNode|Bool|Bool|Bool")
        structLlvmFieldTypes.push("")
        // %SeenString(16) + ptr(8) + %TypeNode(24) + i64(8) + i1+i1+i1 + padding = 64
        structSizes.push(64)
        structMethodNames.push("")
        structMethodRetTypes.push("")
        // ClassNode { name: String, fields: Array<ParamNode>, methods: Array<FunctionNode> }
        structNames.push("ClassNode")
        structLayouts.push("{ %SeenString, ptr, ptr }")
        structFieldNames.push("name,fields,methods")
        structFieldTypes.push("String|Array<ParamNode>|Array<FunctionNode>")
        structLlvmFieldTypes.push("")
        structSizes.push(32)
        structMethodNames.push("")
        structMethodRetTypes.push("")
        // BlockNode { statements: Array<StatementNode> }
        structNames.push("BlockNode")
        structLayouts.push("{ ptr }")
        structFieldNames.push("statements")
        structFieldTypes.push("Array<StatementNode>")
        structLlvmFieldTypes.push("")
        structSizes.push(8)
        structMethodNames.push("")
        structMethodRetTypes.push("")
        // StatementNode { kind, variableName, variableType (TypeNode inline), initializer, returnValue, expression, condition, thenBranch, elseBranch, loopCondition, loopBody }
        structNames.push("StatementNode")
        structLayouts.push("{ %SeenString, %SeenString, %TypeNode, i64, i64, i64, i64, i64, i64, i64, i64 }")
        structFieldNames.push("kind,variableName,variableType,initializer,returnValue,expression,condition,thenBranch,elseBranch,loopCondition,loopBody")
        structFieldTypes.push("String|String|TypeNode|ParserExpressionNode|ParserExpressionNode|ParserExpressionNode|ParserExpressionNode|BlockNode|BlockNode|ParserExpressionNode|BlockNode")
        structLlvmFieldTypes.push("")
        // 16 + 16 + 24 + 8*8 = 120 (aligned)
        structSizes.push(120)
        structMethodNames.push("")
        structMethodRetTypes.push("")
        // ParserExpressionNode { kind, operands, operator, literalValue, literalType, variableName, callee, arguments }
        structNames.push("ParserExpressionNode")
        structLayouts.push("{ %SeenString, ptr, %SeenString, %SeenString, %SeenString, %SeenString, %SeenString, ptr }")
        structFieldNames.push("kind,operands,operator,literalValue,literalType,variableName,callee,arguments")
        structFieldTypes.push("String|Array<ParserExpressionNode>|String|String|String|String|String|Array<ParserExpressionNode>")
        structLlvmFieldTypes.push("")
        // 16 + 8 + 16*5 + 8 = 112 (aligned)
        structSizes.push(112)
        structMethodNames.push("")
        structMethodRetTypes.push("")
        // StringBuilder { parts: Array<String>, totalLength: Int }
        structNames.push("StringBuilder")
        structLayouts.push("{ ptr, i64 }")
        structFieldNames.push("parts,totalLength")
        structFieldTypes.push("Array<String>|Int")
        structLlvmFieldTypes.push("")
        structSizes.push(16)
        structMethodNames.push("")
        structMethodRetTypes.push("")
        // LLVMIRGenerator state (needed for accurate field typing during self-hosted codegen)
        structNames.push("LLVMIRGenerator")
        structLayouts.push("{ i64, ptr, i64, i64, ptr, ptr, ptr, i64, ptr, ptr, ptr, ptr, ptr, ptr, ptr, ptr, ptr, ptr, %SeenString, %SeenString, i1, %SeenString, %SeenString, ptr, ptr, %SeenString, ptr, ptr, i1, i1, %SeenString, %SeenString, ptr }")
        structFieldNames.push("output,stringConstants,nextReg,nextBlock,varNames,varRegs,varTypes,indent,structNames,structLayouts,structFieldNames,structFieldTypes,structLlvmFieldTypes,structSizes,structMethodNames,structMethodRetTypes,funcNames,funcRetTypes,currentFunctionReturnType,currentClassName,blockTerminated,currentLoopCondLabel,currentLoopEndLabel,preAllocatedVars,preAllocatedTypes,stringConstantPrefix,generatedFunctions,generatedClasses,typesLoadedFromHeader,runtimeDeclsLoaded,typeHeaderPath,pendingArrayLiteralType,classMethodBaseNames")
        structFieldTypes.push("StringBuilder|Array<String>|Int|Int|Array<String>|Array<String>|Array<String>|Int|Array<String>|Array<String>|Array<String>|Array<String>|Array<String>|Array<Int>|Array<String>|Array<String>|Array<String>|Array<String>|String|String|Bool|String|String|Array<String>|Array<String>|String|Array<String>|Array<String>|Bool|Bool|String|String|Array<String>")
        structLlvmFieldTypes.push("")
        structSizes.push(304)
        structMethodNames.push("")
        structMethodRetTypes.push("")
        // Token { tokenType: SeenTokenType (i64), value: String, line: Int, column: Int, length: Int, fileId: Int }
        structNames.push("Token")
        structLayouts.push("{ i64, %SeenString, i64, i64, i64, i64 }")
        structFieldNames.push("tokenType,value,line,column,length,fileId")
        structFieldTypes.push("SeenTokenType|String|Int|Int|Int|Int")
        structLlvmFieldTypes.push("")
        structSizes.push(56)
        structMethodNames.push("")
        structMethodRetTypes.push("")
        // Position { line: Int, column: Int, fileId: Int }
        structNames.push("Position")
        structLayouts.push("{ i64, i64, i64 }")
        structFieldNames.push("line,column,fileId")
        structFieldTypes.push("Int|Int|Int")
        structLlvmFieldTypes.push("")
        structSizes.push(24)
        structMethodNames.push("")
        structMethodRetTypes.push("")
        // RealParser { tokens: Array<Token>, current: Int, currentProgram: ProgramNode, currentBlock: BlockNode, lastStatement: StatementNode, lastFunction: FunctionNode }
        structNames.push("RealParser")
        structLayouts.push("{ ptr, i64, i64, i64, i64, i64 }")
        structFieldNames.push("tokens,current,currentProgram,currentBlock,lastStatement,lastFunction")
        structFieldTypes.push("Array<Token>|Int|ProgramNode|BlockNode|StatementNode|FunctionNode")
        structLlvmFieldTypes.push("")
        structSizes.push(48)
        structMethodNames.push("")
        structMethodRetTypes.push("")
        // SeenLexer { source: String, fileId: Int, language: String, errorRecoveryMode: Bool, keywordManager: KeywordManager, position: Int, line: Int, column: Int, tokens: Array<Token> }
        structNames.push("SeenLexer")
        structLayouts.push("{ %SeenString, i64, %SeenString, i1, i64, i64, i64, i64, ptr }")
        structFieldNames.push("source,fileId,language,errorRecoveryMode,keywordManager,position,line,column,tokens")
        structFieldTypes.push("String|Int|String|Bool|KeywordManager|Int|Int|Int|Array<Token>")
        structLlvmFieldTypes.push("")
        structSizes.push(88)
        structMethodNames.push("")
        structMethodRetTypes.push("")
        // KeywordManager { language: String, keywords: Map, tokenNameMap: Map, sources: Array<String> }
        structNames.push("KeywordManager")
        structLayouts.push("{ %SeenString, i64, i64, ptr }")
        structFieldNames.push("language,keywords,tokenNameMap,sources")
        structFieldTypes.push("String|Map|Map|Array<String>")
        structLlvmFieldTypes.push("")
        structSizes.push(40)
        structMethodNames.push("")
        structMethodRetTypes.push("")
        // ProgramNode { items: Array<ItemNode> }
        structNames.push("ProgramNode")
        structLayouts.push("{ ptr }")
        structFieldNames.push("items")
        structFieldTypes.push("Array<ItemNode>")
        structLlvmFieldTypes.push("")
        structSizes.push(8)
        structMethodNames.push("")
        structMethodRetTypes.push("")
        // EnumNode { name: String, variants: Array<String> }
        structNames.push("EnumNode")
        structLayouts.push("{ %SeenString, ptr }")
        structFieldNames.push("name,variants")
        structFieldTypes.push("String|Array<String>")
        structLlvmFieldTypes.push("")
        structSizes.push(24)
        structMethodNames.push("")
        structMethodRetTypes.push("")
        // FrontendResult { success: Bool, diagnostics: Array<FrontendDiagnostic>, program: ProgramNode }
        // Rust backend stores arrays as ptr, class types as i64 (pointer-as-int)
        structNames.push("FrontendResult")
        structLayouts.push("{ i1, ptr, i64 }")
        structFieldNames.push("success,diagnostics,program")
        structFieldTypes.push("Bool|Array<FrontendDiagnostic>|ProgramNode")
        structLlvmFieldTypes.push("")
        structSizes.push(24)
        structMethodNames.push("")
        structMethodRetTypes.push("")
        // FrontendDiagnostic { file: String, line: Int, column: Int, severity: String, message: String }
        structNames.push("FrontendDiagnostic")
        structLayouts.push("{ %SeenString, i64, i64, %SeenString, %SeenString }")
        structFieldNames.push("file,line,column,severity,message")
        structFieldTypes.push("String|Int|Int|String|String")
        structLlvmFieldTypes.push("")
        structSizes.push(72)
        structMethodNames.push("")
        structMethodRetTypes.push("")
        // TypeInferenceResult { success: Bool, type: Type, errors: Array<TypeError>, warnings: Array<String>, environment: Environment }
        structNames.push("TypeInferenceResult")
        structLayouts.push("{ i1, i64, ptr, ptr, i64 }")
        structFieldNames.push("success,type,errors,warnings,environment")
        structFieldTypes.push("Bool|Type|Array<TypeError>|Array<String>|Environment")
        structLlvmFieldTypes.push("")
        structSizes.push(40)
        structMethodNames.push("")
        structMethodRetTypes.push("")
        // CommandResult { success: Bool, output: String }
        structNames.push("CommandResult")
        structLayouts.push("{ i1, %SeenString }")
        structFieldNames.push("success,output")
        structFieldTypes.push("Bool|String")
        structLlvmFieldTypes.push("")
        structSizes.push(24)
        structMethodNames.push("")
        structMethodRetTypes.push("")
        if structNames.length() > 0 {
            traceGen("registerKnownDataTypes: structNames[0]=" + structNames[0])
        }
        if structNames.length() > 1 {
            traceGen("registerKnownDataTypes: structNames[1]=" + structNames[1])
        }
        traceGen("registerKnownDataTypes: end structNames len=" + structNames.length().toString())
    }

    // Register all declarations from a program without keeping the AST
    // Used in Pass 1 to populate registries for cross-module references
    fun registerDeclarations(program: ProgramNode) r: Void {
        // First, register known data types
        this.registerKnownDataTypes()

        // Pre-register class names so field types resolve during layout
        var preIdx = 0
        while preIdx < program.items.length() {
            let preItem = program.items[preIdx]
            if preItem.itemType == "Class" {
                this.ensureStructEntry(preItem.classNode.name)
            }
            preIdx = preIdx + 1
        }

        var i = 0
        while i < program.items.length() {
            let item = program.items[i]

            if item.itemType == "Class" {
                // Register struct layout (fields)
                this.registerStructLayout(item.classNode)

                // Also register class methods as functions
                var mi = 0
                while mi < item.classNode.methods.length() {
                    let method = item.classNode.methods[mi]
                    let mangledName = item.classNode.name + "_" + method.name
                    this.registerFunction(mangledName, method.returnType.typeName)
                    mi = mi + 1
                }
            }

            // Data types use the same ClassNode structure for their fields
            if item.itemType == "Data" {
                // Register data type layout (fields)
                this.registerStructLayout(item.classNode)
            }

            if item.itemType == "Function" {
                // Register function signature
                this.registerFunction(item.function.name, item.function.returnType.typeName)
            }

            i = i + 1
        }
    }

    // Register a user-defined function's return type
    fun registerFunction(name: String, retType: String) r: Void {
        funcNames.push(name)
        funcRetTypes.push(retType)
    }

    // Look up a user-defined function's return type
    fun getFunctionReturnType(name: String) r: String {
        let len = funcNames.length()
        var i = 0
        while i < len {
            let current = funcNames[i]
            if current == name {
                return funcRetTypes[i]
            }
            i = i + 1
        }
        return ""  // Not found
    }

    // Convert a hex string value (like "0x00C0") to decimal string
    fun hexToDecimal(value: String) r: String {
        let len = value.length()
        if len < 3 {
            return value  // Too short to be hex
        }
        // Check for 0x or 0X prefix
        let firstChar = value.substring(0, 1)
        let secondChar = value.substring(1, 2)
        if firstChar != "0" {
            return value  // Not hex
        }
        if secondChar != "x" and secondChar != "X" {
            return value  // Not hex
        }

        // Parse hex digits
        var result = 0
        var i = 2
        while i < len {
            let c = value.substring(i, i + 1)
            var digit = 0
            if c == "0" { digit = 0 }
            if c == "1" { digit = 1 }
            if c == "2" { digit = 2 }
            if c == "3" { digit = 3 }
            if c == "4" { digit = 4 }
            if c == "5" { digit = 5 }
            if c == "6" { digit = 6 }
            if c == "7" { digit = 7 }
            if c == "8" { digit = 8 }
            if c == "9" { digit = 9 }
            if c == "a" or c == "A" { digit = 10 }
            if c == "b" or c == "B" { digit = 11 }
            if c == "c" or c == "C" { digit = 12 }
            if c == "d" or c == "D" { digit = 13 }
            if c == "e" or c == "E" { digit = 14 }
            if c == "f" or c == "F" { digit = 15 }
            result = result * 16 + digit
            i = i + 1
        }
        return result.toString()
    }

    // Trim leading/trailing whitespace (space, tab, CR)
    fun trimSpaces(value: String) r: String {
        var start = 0
        var end = value.length()
        while start < end {
            let c = value.substring(start, start + 1)
            if c == " " or c == "\t" or c == "\r" {
                start = start + 1
            }
            if c != " " and c != "\t" and c != "\r" {
                break
            }
        }
        while end > start {
            let c = value.substring(end - 1, end)
            if c == " " or c == "\t" or c == "\r" {
                end = end - 1
            }
            if c != " " and c != "\t" and c != "\r" {
                break
            }
        }
        return value.substring(start, end)
    }

    fun removeSpaces(value: String) r: String {
        var result = ""
        var i = 0
        while i < value.length() {
            let c = value.substring(i, i + 1)
            if c != " " and c != "\t" and c != "\r" {
                result = result + c
            }
            i = i + 1
        }
        return result
    }

    fun getBaseTypeName(typeName: String) r: String {
        let trimmed = this.trimSpaces(typeName)
        if trimmed == "" {
            return ""
        }
        var end = trimmed.length()
        var ltIdx = -1
        var i = 0
        while i < trimmed.length() {
            if trimmed.substring(i, i + 1) == "<" {
                ltIdx = i
                i = trimmed.length()
            }
            i = i + 1
        }
        if ltIdx >= 0 {
            end = ltIdx
        }
        var lastSep = -1
        i = 0
        while i < end {
            let c = trimmed.substring(i, i + 1)
            if c == "." or c == ":" {
                lastSep = i
            }
            i = i + 1
        }
        if lastSep >= 0 and lastSep + 1 < end {
            return trimmed.substring(lastSep + 1, end)
        }
        return trimmed.substring(0, end)
    }

    fun normalizeHeaderType(typeName: String) r: String {
        let trimmed = this.trimSpaces(typeName)
        let compact = this.removeSpaces(trimmed)
        if compact.startsWith("{") {
            let fields = this.extractStructFieldTypes(trimmed)
            if fields.length() == 2 {
                let f0 = this.removeSpaces(fields[0])
                let f1 = this.removeSpaces(fields[1])
                if (f0 == "i64" and f1 == "ptr") or (f0 == "ptr" and f1 == "i64") {
                    return "%SeenString"
                }
            }
            if fields.length() == 4 {
                let f0 = this.removeSpaces(fields[0])
                let f1 = this.removeSpaces(fields[1])
                let f2 = this.removeSpaces(fields[2])
                let f3 = this.removeSpaces(fields[3])
                if f0 == "i64" and f1 == "i64" and f2 == "i64" and f3 == "ptr" {
                    return "%SeenArray"
                }
            }
        }
        return trimmed
    }

    fun alignUp(value: Int, align: Int) r: Int {
        if align <= 1 {
            return value
        }
        let rem = value % align
        if rem == 0 {
            return value
        }
        return value + (align - rem)
    }

    // Extract field type strings from a struct layout like "{ i64, ptr }"
    fun extractStructFieldTypes(layout: String) r: Array<String> {
        let result = Array<String>()
        let trimmed = this.trimSpaces(layout)
        var startIdx = 0
        var endIdx = trimmed.length()

        // Find first '{'
        var i = 0
        while i < trimmed.length() {
            if trimmed.substring(i, i + 1) == "{" {
                startIdx = i + 1
                i = trimmed.length()
            }
            i = i + 1
        }

        // Find last '}'
        i = trimmed.length() - 1
        var foundEnd = false
        while i >= 0 and not foundEnd {
            if trimmed.substring(i, i + 1) == "}" {
                endIdx = i
                foundEnd = true
            }
            i = i - 1
        }

        if endIdx <= startIdx {
            return result
        }

        let inner = trimmed.substring(startIdx, endIdx)
        var entryStart = 0
        var pos = 0
        var nesting = 0
        while pos <= inner.length() {
            var c = ""
            if pos < inner.length() {
                c = inner.substring(pos, pos + 1)
            }
            if c == "{" or c == "[" or c == "<" {
                nesting = nesting + 1
            }
            if c == "}" or c == "]" or c == ">" {
                if nesting > 0 {
                    nesting = nesting - 1
                }
            }
            if pos == inner.length() or (c == "," and nesting == 0) {
                let entry = this.trimSpaces(inner.substring(entryStart, pos))
                if entry != "" {
                    result.push(entry)
                }
                entryStart = pos + 1
            }
            pos = pos + 1
        }
        return result
    }

    fun parseArrayLength(typeName: String) r: Int {
        let trimmed = this.trimSpaces(typeName)
        if not trimmed.startsWith("[") {
            return -1
        }
        var xIdx = -1
        var i = 0
        while i < trimmed.length() {
            if trimmed.substring(i, i + 1) == "x" {
                xIdx = i
                i = trimmed.length()
            }
            i = i + 1
        }
        if xIdx < 0 {
            return -1
        }
        let lenStr = this.trimSpaces(trimmed.substring(1, xIdx))
        return this.parseDecimalInt(lenStr)
    }

    fun parseArrayElementType(typeName: String) r: String {
        let trimmed = this.trimSpaces(typeName)
        if not trimmed.startsWith("[") {
            return ""
        }
        var xIdx = -1
        var i = 0
        while i < trimmed.length() {
            if trimmed.substring(i, i + 1) == "x" {
                xIdx = i
                i = trimmed.length()
            }
            i = i + 1
        }
        if xIdx < 0 {
            return ""
        }
        // Trim trailing ']'
        let endIdx = trimmed.length() - 1
        return this.trimSpaces(trimmed.substring(xIdx + 1, endIdx))
    }

    fun extractArrayLiteralElementType(arrayType: String) r: String {
        let trimmed = this.trimSpaces(arrayType)
        if trimmed.startsWith("Array<") and trimmed.endsWith(">") {
            return this.trimSpaces(trimmed.substring(6, trimmed.length() - 1))
        }
        if trimmed.startsWith("List<") and trimmed.endsWith(">") {
            return this.trimSpaces(trimmed.substring(5, trimmed.length() - 1))
        }
        return ""
    }

    fun getLlvmTypeAlign(typeName: String) r: Int {
        let trimmed = this.trimSpaces(typeName)
        let compact = this.removeSpaces(trimmed)
        if compact == "i1" or compact == "i8" {
            return 1
        }
        if compact == "i16" {
            return 2
        }
        if compact == "i32" or compact == "float" {
            return 4
        }
        if compact == "i64" or compact == "double" or compact == "ptr" {
            return 8
        }
        if compact == "%SeenString" or compact == "{{i64,ptr}}" {
            return 8
        }
        if compact == "%SeenArray" or compact == "{{i64,i64,i64,ptr}}" {
            return 8
        }
        if compact.startsWith("%") {
            let name = trimmed.substring(1, trimmed.length())
            let idx = this.findStruct(name)
            if idx >= 0 {
                let layout = structLayouts[idx]
                if layout != "" {
                    let fields = this.extractStructFieldTypes(layout)
                    var maxAlign = 1
                    var i = 0
                    while i < fields.length() {
                        let a = this.getLlvmTypeAlign(fields[i])
                        if a > maxAlign {
                            maxAlign = a
                        }
                        i = i + 1
                    }
                    return maxAlign
                }
            }
            return 8
        }
        if compact.startsWith("{") {
            let fields = this.extractStructFieldTypes(trimmed)
            var maxAlign = 1
            var i = 0
            while i < fields.length() {
                let a = this.getLlvmTypeAlign(fields[i])
                if a > maxAlign {
                    maxAlign = a
                }
                i = i + 1
            }
            return maxAlign
        }
        if compact.startsWith("[") {
            let elemType = this.parseArrayElementType(trimmed)
            if elemType != "" {
                return this.getLlvmTypeAlign(elemType)
            }
        }
        return 8
    }

    fun getLlvmTypeSize(typeName: String) r: Int {
        let trimmed = this.trimSpaces(typeName)
        let compact = this.removeSpaces(trimmed)
        if compact == "i1" or compact == "i8" {
            return 1
        }
        if compact == "i16" {
            return 2
        }
        if compact == "i32" or compact == "float" {
            return 4
        }
        if compact == "i64" or compact == "double" {
            return 8
        }
        if compact == "ptr" {
            return 8
        }
        if compact == "%SeenString" or compact == "{{i64,ptr}}" {
            return 16
        }
        if compact == "%SeenArray" or compact == "{{i64,i64,i64,ptr}}" {
            return 32
        }
        if compact.startsWith("%") {
            let name = trimmed.substring(1, trimmed.length())
            let idx = this.findStruct(name)
            if idx >= 0 {
                let sizeVal = structSizes[idx]
                if sizeVal > 0 {
                    return sizeVal
                }
                let layout = structLayouts[idx]
                if layout != "" {
                    return this.computeStructSizeFromLayout(layout)
                }
            }
            return 0
        }
        if compact.startsWith("{") {
            return this.computeStructSizeFromLayout(trimmed)
        }
        if compact.startsWith("[") {
            let len = this.parseArrayLength(trimmed)
            let elemType = this.parseArrayElementType(trimmed)
            if len >= 0 and elemType != "" {
                let elemSize = this.getLlvmTypeSize(elemType)
                if elemSize > 0 {
                    return len * elemSize
                }
            }
        }
        return 0
    }

    fun computeStructSizeFromLayout(layout: String) r: Int {
        let fields = this.extractStructFieldTypes(layout)
        var offset = 0
        var maxAlign = 1
        var i = 0
        while i < fields.length() {
            let fieldType = fields[i]
            let align = this.getLlvmTypeAlign(fieldType)
            let size = this.getLlvmTypeSize(fieldType)
            if size <= 0 or align <= 0 {
                return 0
            }
            offset = this.alignUp(offset, align)
            offset = offset + size
            if align > maxAlign {
                maxAlign = align
            }
            i = i + 1
        }
        return this.alignUp(offset, maxAlign)
    }

    fun computeMissingStructSizes() r: Void {
        var changed = true
        var pass = 0
        while changed and pass < 8 {
            changed = false
            var i = 0
            while i < structNames.length() {
                if structSizes[i] == 0 {
                    let structName = structNames[i]
                    if not this.isDataType(structName) {
                        i = i + 1
                        continue
                    }
                    traceGen("computeMissingStructSizes: " + structName)
                    let layout = structLayouts[i]
                    if layout != "" {
                        let sizeVal = this.computeStructSizeFromLayout(layout)
                        if sizeVal > 0 {
                            structSizes[i] = sizeVal
                            changed = true
                        }
                    }
                }
                i = i + 1
            }
            pass = pass + 1
        }
    }

    // Parse a decimal integer from a string (ignores non-digit characters)
    fun parseDecimalInt(value: String) r: Int {
        var result = 0
        var i = 0
        while i < value.length() {
            let c = value.substring(i, i + 1)
            var digit = -1
            if c == "0" { digit = 0 }
            if c == "1" { digit = 1 }
            if c == "2" { digit = 2 }
            if c == "3" { digit = 3 }
            if c == "4" { digit = 4 }
            if c == "5" { digit = 5 }
            if c == "6" { digit = 6 }
            if c == "7" { digit = 7 }
            if c == "8" { digit = 8 }
            if c == "9" { digit = 9 }
            if digit >= 0 {
                result = result * 10 + digit
            }
            i = i + 1
        }
        return result
    }

    fun findSubstring(value: String, needle: String) r: Int {
        let vlen = value.length()
        let nlen = needle.length()
        if needle == " = type " and value.contains("FrontendDiagnostic") {
            println("[DEBUG findSubstring] searching for ' = type ' in FrontendDiagnostic line")
            println("[DEBUG findSubstring] vlen=" + vlen.toString() + " nlen=" + nlen.toString())
        }
        if nlen == 0 {
            return 0
        }
        if nlen > vlen {
            return -1
        }
        var i = 0
        while i <= vlen - nlen {
            var matched = true
            var j = 0
            // Debug for i=19
            if needle == " = type " and value.contains("FrontendDiagnostic") and i == 19 {
                println("[DEBUG findSubstring] Starting char-by-char at i=19")
            }
            while j < nlen {
                let vc = value.substring(i + j, i + j + 1)
                let nc = needle.substring(j, j + 1)
                // Debug for i=19
                if needle == " = type " and value.contains("FrontendDiagnostic") and i == 19 {
                    let vcLen = vc.length()
                    let ncLen = nc.length()
                    let idx1 = i + j
                    let idx2 = i + j + 1
                    println("[DEBUG findSubstring] j=" + j.toString() + " idx1=" + idx1.toString() + " idx2=" + idx2.toString())
                    println("[DEBUG findSubstring] vc='" + vc + "' nc='" + nc + "' eq=" + (vc == nc).toString() + " vcLen=" + vcLen.toString() + " ncLen=" + ncLen.toString())
                }
                if vc != nc {
                    matched = false
                    j = nlen
                }
                j = j + 1
            }
            // Debug for i=19
            if needle == " = type " and value.contains("FrontendDiagnostic") and i == 19 {
                println("[DEBUG findSubstring] After loop at i=19: matched=" + matched.toString())
            }
            if matched {
                if needle == " = type " and value.contains("FrontendDiagnostic") {
                    println("[DEBUG findSubstring] FOUND ' = type ' at i=" + i.toString())
                }
                return i
            }
            i = i + 1
        }
        if needle == " = type " and value.contains("FrontendDiagnostic") {
            println("[DEBUG findSubstring] NOT FOUND ' = type ' in FrontendDiagnostic line")
        }
        return -1
    }

    // Find a field's Seen type from parallel name/type lists
    fun getFieldTypeFromLists(fieldNamesStr: String, fieldTypesStr: String, fieldName: String) r: String {
        var fieldIdx = 0
        var nameStart = 0
        var pos = 0
        var foundField = false
        while pos <= fieldNamesStr.length() and not foundField {
            if pos == fieldNamesStr.length() or fieldNamesStr.substring(pos, pos + 1) == "," {
                let name = fieldNamesStr.substring(nameStart, pos)
                if name == fieldName {
                    foundField = true
                }
                if name != fieldName {
                    fieldIdx = fieldIdx + 1
                    nameStart = pos + 1
                }
            }
            pos = pos + 1
        }

        if not foundField {
            return ""
        }

        var typeIdx = 0
        var typeStart = 0
        pos = 0
        while pos <= fieldTypesStr.length() {
            if pos == fieldTypesStr.length() or fieldTypesStr.substring(pos, pos + 1) == "|" {
                if typeIdx == fieldIdx {
                    return fieldTypesStr.substring(typeStart, pos)
                }
                typeIdx = typeIdx + 1
                typeStart = pos + 1
            }
            pos = pos + 1
        }
        return ""
    }

    fun reorderFieldTypes(existingNames: String, existingTypes: String, newNames: String) r: String {
        var result = ""
        var start = 0
        var pos = 0
        while pos <= newNames.length() {
            var c = ""
            if pos < newNames.length() {
                c = newNames.substring(pos, pos + 1)
            }
            if c == "," or pos == newNames.length() {
                let name = newNames.substring(start, pos)
                var mappedType = this.getFieldTypeFromLists(existingNames, existingTypes, name)
                if mappedType == "" {
                    mappedType = "Int"
                }
                if result != "" {
                    result = result + "|"
                }
                result = result + mappedType
                start = pos + 1
            }
            pos = pos + 1
        }
        return result
    }

    fun updateStructLayoutFromHeader(structName: String, structLayout: String) r: Void {
        var idx = this.findStruct(structName)
        if idx < 0 {
            idx = this.ensureStructEntry(structName)
        }
        if structName == "FrontendDiagnostic" {
            println("[DEBUG updateStructLayoutFromHeader] FrontendDiagnostic before: idx=" + idx.toString() + " layout='" + structLayouts[idx] + "'")
            println("[DEBUG updateStructLayoutFromHeader] FrontendDiagnostic setting to: '" + structLayout + "'")
        }
        if structLayout != "" {
            structLayouts[idx] = structLayout + ""
            // Force size recomputation from the authoritative header layout.
            structSizes[idx] = 0
        }
        if structName == "FrontendDiagnostic" {
            println("[DEBUG updateStructLayoutFromHeader] FrontendDiagnostic after: layout='" + structLayouts[idx] + "'")
        }
    }

    fun updateStructFieldsFromHeader(structName: String, fieldsStr: String) r: Void {
        var idx = this.findStruct(structName)
        if idx < 0 {
            idx = this.ensureStructEntry(structName)
        }
        let existingNames = structFieldNames[idx]
        let existingTypes = structFieldTypes[idx]
        let trimmedFields = this.trimSpaces(fieldsStr)
        if trimmedFields == "" {
            return
        }

        var namesOut = ""
        var llvmTypesOut = ""
        var entryStart = 0
        var pos = 0
        var nesting = 0
        while pos <= trimmedFields.length() {
            var c = ""
            if pos < trimmedFields.length() {
                c = trimmedFields.substring(pos, pos + 1)
            }
            if c == "{" or c == "[" or c == "<" {
                nesting = nesting + 1
            }
            if c == "}" or c == "]" or c == ">" {
                if nesting > 0 {
                    nesting = nesting - 1
                }
            }
            if pos == trimmedFields.length() or (c == "," and nesting == 0) {
                let entry = trimmedFields.substring(entryStart, pos)
                var colonIdx = -1
                var scan = 0
                while scan < entry.length() {
                    if entry.substring(scan, scan + 1) == ":" {
                        colonIdx = scan
                        scan = entry.length()
                    }
                    scan = scan + 1
                }
                if colonIdx >= 0 {
                    let rawName = this.trimSpaces(entry.substring(0, colonIdx))
                    let rawType = this.trimSpaces(entry.substring(colonIdx + 1, entry.length()))
                    let normalizedType = this.normalizeHeaderType(rawType)
                    if structName == "FrontendResult" {
                        println("[DEBUG updateStructFieldsFromHeader] entry='" + entry + "' rawName='" + rawName + "' rawType='" + rawType + "' normalizedType='" + normalizedType + "'")
                    }
                    if rawName != "" {
                        if namesOut != "" {
                            namesOut = namesOut + ","
                            llvmTypesOut = llvmTypesOut + "|"
                        }
                        namesOut = namesOut + rawName
                        llvmTypesOut = llvmTypesOut + normalizedType
                        if structName == "FrontendResult" {
                            println("[DEBUG updateStructFieldsFromHeader] after append: llvmTypesOut='" + llvmTypesOut + "'")
                        }
                    }
                }
                entryStart = pos + 1
            }
            pos = pos + 1
        }

        if namesOut == "" {
            return
        }

        if structName == "FrontendResult" {
            println("[DEBUG updateStructFieldsFromHeader] FrontendResult namesOut='" + namesOut + "' llvmTypesOut='" + llvmTypesOut + "'")
        }
        structFieldNames[idx] = namesOut
        structLlvmFieldTypes[idx] = llvmTypesOut

        if existingNames != "" and existingTypes != "" {
            let reordered = this.reorderFieldTypes(existingNames, existingTypes, namesOut)
            if reordered != "" {
                structFieldTypes[idx] = reordered
            }
        }
    }

    fun updateStructSizeFromHeader(structName: String, sizeStr: String) r: Void {
        var idx = this.findStruct(structName)
        if idx < 0 {
            idx = this.ensureStructEntry(structName)
        }
        let trimmed = this.trimSpaces(sizeStr)
        if trimmed == "" {
            return
        }
        let sizeVal = this.parseDecimalInt(trimmed)
        if sizeVal > 0 {
            structSizes[idx] = sizeVal
        }
    }

    fun applyTypeHeader(headerContent: String) r: Void {
        println("[DEBUG applyTypeHeader] START, headerContent.length=" + headerContent.length().toString())
        var currentStruct = ""
        var lineStart = 0
        var pos = 0
        var lineCount = 0
        while pos <= headerContent.length() {
            var isEnd = false
            var c = ""
            if pos == headerContent.length() {
                isEnd = true
            }
            if not isEnd {
                c = headerContent.substring(pos, pos + 1)
            }
            if isEnd or c == "\n" {
                let line = headerContent.substring(lineStart, pos)
                let trimmedLine = this.trimSpaces(line)
                lineCount = lineCount + 1
                if trimmedLine.startsWith("; Runtime Function Declarations") or trimmedLine.startsWith("; End of auto-generated type declarations") {
                    println("[DEBUG applyTypeHeader] END at line " + lineCount.toString() + ", returning")
                    return
                }
                if trimmedLine.startsWith("%") and trimmedLine.contains("= type") {
                    // Parse "%NAME = type LAYOUT" by finding " = type " position
                    // Since findSubstring is broken, find "=" and verify context
                    var parseIdx = 1 // start after %
                    var foundName = ""
                    var foundLayout = ""
                    while parseIdx < trimmedLine.length() - 7 {
                        // Look for " = type {"
                        if trimmedLine.substring(parseIdx, parseIdx + 9) == " = type {" {
                            foundName = trimmedLine.substring(1, parseIdx)
                            foundLayout = trimmedLine.substring(parseIdx + 8, trimmedLine.length())
                            parseIdx = trimmedLine.length() // break
                        }
                        parseIdx = parseIdx + 1
                    }
                    if foundName != "" {
                        if foundName == "FrontendDiagnostic" {
                            println("[DEBUG applyTypeHeader] Parsed FrontendDiagnostic, layout='" + foundLayout + "'")
                        }
                        currentStruct = foundName
                        this.updateStructLayoutFromHeader(foundName, foundLayout)
                    }
                }
                if trimmedLine.startsWith("; Size:") and currentStruct != "" {
                    let sizePart = trimmedLine.substring(7, trimmedLine.length())
                    this.updateStructSizeFromHeader(currentStruct, sizePart)
                }
                if trimmedLine.startsWith("; Fields:") and currentStruct != "" {
                    let fieldsPart = trimmedLine.substring(9, trimmedLine.length())
                    this.updateStructFieldsFromHeader(currentStruct, fieldsPart)
                }
                lineStart = pos + 1
            }
            pos = pos + 1
        }
    }

    // Helper to store variable
    fun storeVar(name: String, reg: String, varType: String) r: Void {
        varNames.push(name)
        varRegs.push(reg)
        varTypes.push(varType)
    }

    // Helper to find variable
    fun findVar(name: String) r: Int {
        let len = varNames.length()
        var i = 0
        while i < len {
            let current = varNames[i]
            if current == name {
                return i
            }
            i = i + 1
        }
        return -1
    }

    // Helper to find variable type (checks both varTypes and preAllocatedTypes)
    // Used during type inference where we need to know variable types
    fun findVarType(name: String) r: String {
        // First check active variables
        let idx = this.findVar(name)
        if idx >= 0 {
            return varTypes[idx]
        }
        // Then check pre-allocated variables (during collection phase)
        var i = 0
        while i < preAllocatedVars.length() {
            if preAllocatedVars[i] == name {
                return preAllocatedTypes[i]
            }
            i = i + 1
        }
        return ""  // Not found
    }

    // Helper to find struct layout index
    fun findStruct(name: String) r: Int {
        let len = structNames.length()
        var i = 0
        while i < len {
            if name == "FrontendDiagnostic" and i < 3 {
                traceGen("findStruct: " + name + " check[" + i.toString() + "]=" + structNames[i])
            }
            if structNames[i] == name {
                return i
            }
            i = i + 1
        }
        return -1
    }

    fun ensureStructEntry(name: String) r: Int {
        let existing = this.findStruct(name)
        if existing >= 0 {
            return existing
        }
        structNames.push(name)
        structLayouts.push("")
        structFieldNames.push("")
        structFieldTypes.push("")
        structLlvmFieldTypes.push("")
        structSizes.push(0)
        structMethodNames.push("")
        structMethodRetTypes.push("")
        return structNames.length() - 1
    }

    // Collect all variable declarations from a block (recursively)
    // Stores names and types in preAllocatedVars/preAllocatedTypes
    // NOTE: Simplified to avoid method merging bug - no nested if/else chains
    fun collectVariableDeclarations(block: BlockNode) r: Void {
        var i = 0
        while i < block.statements.length() {
            let stmt = block.statements[i]
            collectStmtVars(stmt)
            i = i + 1
        }
    }

    // Helper to collect variables from a single statement - separate method to avoid merging
    fun collectStmtVars(stmt: StatementNode) r: Void {
        // Handle Let/Var declarations
        if stmt.kind == "Let" or stmt.kind == "Var" {
            var varType = stmt.variableType.typeName
            if varType == "" or varType == "Unknown" {
                varType = this.inferExpressionType(stmt.initializer)
            }
            if varType == "" or varType == "Unknown" {
                varType = "Int"
            }
            preAllocatedVars.push(stmt.variableName)
            preAllocatedTypes.push(varType)
        }
        // Handle If statements
        if stmt.kind == "If" {
            this.collectVariableDeclarations(stmt.thenBranch)
        }
        // Handle While statements
        if stmt.kind == "While" {
            this.collectVariableDeclarations(stmt.loopBody)
        }
        // Handle For statements
        if stmt.kind == "For" {
            this.collectVariableDeclarations(stmt.loopBody)
        }
        return
    }

    // Check if a variable has been pre-allocated, return its index or -1
    fun findPreAllocated(name: String) r: Int {
        var i = 0
        while i < this.preAllocatedVars.length() {
            if this.preAllocatedVars[i] == name {
                return i
            }
            i = i + 1
        }
        return -1
    }

    // Emit allocas for all pre-allocated variables at function entry
    // This ensures all allocas are in the entry block, avoiding domination errors
    fun emitPreAllocatedAllocas() r: Void {
        var i = 0
        while i < preAllocatedVars.length() {
            let varName = preAllocatedVars[i]
            let varType = preAllocatedTypes[i]
            let llvmType = this.mapType(varType)
            let reg = this.getNextReg()
            output.append("  " + reg + " = alloca " + llvmType + "\n")
            // Store the mapping for later use
            this.storeVar(varName, reg, varType)
            i = i + 1
        }
    }

    // Get size of a Seen type in bytes when stored in a class/struct field
    // This is the STORAGE size, not the full object size
    // - Primitives: their natural size (aligned to 8)
    // - String: 16 bytes (inline %SeenString struct)
    // - Array: 8 bytes (ptr to heap-allocated SeenArray)
    // - Classes: 8 bytes (i64 pointer-as-int)
    // - Data types: their full inline size
    fun getTypeSize(typeName: String) r: Int {
        if typeName == "Int" {
            return 8
        }
        if typeName == "Bool" or typeName == "Boolean" {
            // Bool is i1 but takes 8 bytes in struct layout due to alignment
            // (next field will be aligned to 8 bytes anyway)
            return 8
        }
        if typeName == "Float" {
            return 8
        }
        if typeName == "String" {
            return 16  // %SeenString = { i64, ptr } = 8 + 8 (stored inline)
        }
        if typeName.startsWith("Array<") or typeName.startsWith("List<") {
            // Arrays are stored as ptr to heap-allocated SeenArray (NOT inline!)
            return 8
        }
        // Check if this is a data type (stored inline)
        if this.isDataType(typeName) {
            return this.getDataTypeSize(typeName)
        }
        // All other types (classes) are stored as i64 (pointer-as-int) = 8 bytes
        return 8
    }

    // Register a struct layout from a ClassNode
    fun registerStructLayout(classNode: ClassNode) r: Void {
        // Ensure entry exists (supports self-references during layout)
        let structIdx = this.ensureStructEntry(classNode.name)
        let hasLayout = structLayouts[structIdx] != ""
        traceGen("registerStructLayout: " + classNode.name + " structIdx=" + structIdx.toString() + " namesLen=" + structNames.length().toString() + " fieldNamesLen=" + structFieldNames.length().toString())
        traceGen("registerStructLayout: " + classNode.name + " fields=" + classNode.fields.length().toString())

        // Build the layout from fields
        var layout = "{ "
        var fieldNames = ""
        var fieldTypes = ""
        var totalSize = 0

        var i = 0
        while i < classNode.fields.length() {
            traceGen("registerStructLayout: " + classNode.name + " field idx=" + i.toString())
            if i > 0 {
                layout = layout + ", "
                fieldNames = fieldNames + ","
                fieldTypes = fieldTypes + "|"  // Use | as separator for types (not comma, due to generics)
            }
            let field = classNode.fields[i]
            let fieldType = field.paramType.typeName
            let llvmType = this.mapType(fieldType)

            layout = layout + llvmType
            fieldNames = fieldNames + field.name
            fieldTypes = fieldTypes + fieldType
            totalSize = totalSize + getTypeSize(fieldType)

            i = i + 1
        }

        layout = layout + " }"
        traceGen("registerStructLayout: " + classNode.name + " layout built")

        // Collect method signatures
        var methodNames = ""
        var methodRetTypes = ""
        var mi = 0
        traceGen("registerStructLayout: " + classNode.name + " methods len=" + classNode.methods.length().toString())
        while mi < classNode.methods.length() {
            if mi > 0 {
                methodNames = methodNames + ","
                methodRetTypes = methodRetTypes + "|"
            }
            let method = classNode.methods[mi]
            methodNames = methodNames + method.name
            methodRetTypes = methodRetTypes + method.returnType.typeName
            // Register base method name for generic class method skip detection
            // Check if already registered to avoid duplicates
            var alreadyRegistered = false
            var cri = 0
            while cri < classMethodBaseNames.length() {
                if classMethodBaseNames[cri] == method.name {
                    alreadyRegistered = true
                }
                cri = cri + 1
            }
            if not alreadyRegistered {
                classMethodBaseNames.push(method.name)
            }
            mi = mi + 1
        }

        // Store in registry
        traceGen("registerStructLayout: " + classNode.name + " updating registry")
        if not hasLayout {
            structLayouts[structIdx] = layout
        }
        traceGen("registerStructLayout: " + classNode.name + " updating field types")
        traceGen("registerStructLayout: " + classNode.name + " fieldNamesLen(before)=" + structFieldNames.length().toString())
        structFieldNames[structIdx] = fieldNames
        structFieldTypes[structIdx] = fieldTypes
        // Only update size if not already set (preserve hardcoded sizes for data types)
        // Class types always compute size from fields since their layout can vary
        if structSizes[structIdx] == 0 or not this.isDataType(classNode.name) {
            structSizes[structIdx] = totalSize
        }
        structMethodNames[structIdx] = methodNames
        structMethodRetTypes[structIdx] = methodRetTypes
    }

    // Get field index and type from registered struct
    fun getFieldInfo(structName: String, fieldName: String) r: Int {
        traceGen("getFieldInfo: " + structName + "." + fieldName)
        if structName == "FrontendResult" {
            let idxCheck = this.findStruct(structName)
            if idxCheck >= 0 {
                traceGen("FrontendResult fields=" + structFieldNames[idxCheck])
            }
        }

        // CRITICAL: Check hardcoded field indices FIRST for known AST types
        // This ensures correct indices even when registry is partially populated
        // (e.g., when type header is loaded but source hasn't been fully parsed)
        if structName == "FunctionNode" {
            if fieldName == "name" { return 0 }
            if fieldName == "params" { return 1 }
            if fieldName == "returnType" { return 2 }
            if fieldName == "body" { return 3 }
            if fieldName == "isAsync" { return 4 }
            if fieldName == "isInline" { return 5 }
            if fieldName == "isStatic" { return 6 }
        }
        if structName == "ClassNode" {
            if fieldName == "name" { return 0 }
            if fieldName == "fields" { return 1 }
            if fieldName == "methods" { return 2 }
        }
        if structName == "TypeNode" {
            if fieldName == "typeName" { return 0 }
            if fieldName == "isNullable" { return 1 }
        }
        if structName == "ParamNode" {
            if fieldName == "name" { return 0 }
            if fieldName == "paramType" { return 1 }
            if fieldName == "isMutable" { return 2 }
        }
        if structName == "ItemNode" {
            if fieldName == "itemType" { return 0 }
            if fieldName == "name" { return 1 }
            if fieldName == "visibility" { return 2 }
            if fieldName == "importPath" { return 3 }
            if fieldName == "importSymbols" { return 4 }
            if fieldName == "function" { return 5 }
            if fieldName == "classNode" { return 6 }
            if fieldName == "enumNode" { return 7 }
        }
        if structName == "ProgramNode" {
            if fieldName == "items" { return 0 }
        }
        if structName == "BlockNode" {
            if fieldName == "statements" { return 0 }
        }
        if structName == "FrontendResult" {
            if fieldName == "success" { return 0 }
            if fieldName == "diagnostics" { return 1 }
            if fieldName == "program" { return 2 }
        }
        if structName == "StatementNode" {
            if fieldName == "kind" { return 0 }
            if fieldName == "variableName" { return 1 }
            if fieldName == "variableType" { return 2 }
            if fieldName == "initializer" { return 3 }
            if fieldName == "expression" { return 4 }
            if fieldName == "condition" { return 5 }
            if fieldName == "thenBranch" { return 6 }
            if fieldName == "elseBranch" { return 7 }
            if fieldName == "loopCondition" { return 8 }
            if fieldName == "loopBody" { return 9 }
            if fieldName == "returnValue" { return 10 }
        }
        if structName == "ParserExpressionNode" {
            if fieldName == "kind" { return 0 }
            if fieldName == "operands" { return 1 }
            if fieldName == "operator" { return 2 }
            if fieldName == "literalValue" { return 3 }
            if fieldName == "literalType" { return 4 }
            if fieldName == "variableName" { return 5 }
            if fieldName == "callee" { return 6 }
            if fieldName == "arguments" { return 7 }
        }

        let idx = this.findStruct(structName)
        if idx < 0 {
            return -1  // Struct not found
        }

        let fieldNamesStr = structFieldNames[idx]
        // Parse comma-separated field names to find index
        var fieldIdx = 0
        var start = 0
        var pos = 0
        while pos <= fieldNamesStr.length() {
            var c = ""
            if pos < fieldNamesStr.length() {
                c = fieldNamesStr.substring(pos, pos + 1)
            }
            if c == "," or pos == fieldNamesStr.length() {
                let name = fieldNamesStr.substring(start, pos)
                if name == fieldName {
                    return fieldIdx
                }
                fieldIdx = fieldIdx + 1
                start = pos + 1
            }
            pos = pos + 1
        }

        // Fallback hardcoded field indices for less common types (not covered above)
        if structName == "FrontendDiagnostic" {
            if fieldName == "file" { return 0 }
            if fieldName == "line" { return 1 }
            if fieldName == "column" { return 2 }
            if fieldName == "severity" { return 3 }
            if fieldName == "message" { return 4 }
        }
        if structName == "Token" {
            if fieldName == "tokenType" { return 0 }
            if fieldName == "value" { return 1 }
            if fieldName == "line" { return 2 }
            if fieldName == "column" { return 3 }
        }
        if structName == "FieldNode" {
            if fieldName == "name" { return 0 }
            if fieldName == "fieldType" { return 1 }
            if fieldName == "isMutable" { return 2 }
            if fieldName == "defaultValue" { return 3 }
            if fieldName == "visibility" { return 4 }
        }
        return -1  // Field not found
    }

    // Get field type from registered struct
    // Note: fieldTypes uses | as separator (not comma) to handle generic types like Map<K,V>
    fun getFieldType(structName: String, fieldName: String) r: String {
        let idx = this.findStruct(structName)
        if idx < 0 {
            return "i64"  // Default
        }

        let fieldNamesStr = structFieldNames[idx]
        let fieldTypesStr = structFieldTypes[idx]
        let llvmFieldTypesStr = structLlvmFieldTypes[idx]

        // If struct was loaded from header with empty field names, use hardcoded fallbacks
        if fieldNamesStr == "" {
            if structName == "FunctionNode" {
                if fieldName == "name" { return "%SeenString" }
                if fieldName == "params" { return "ptr" }
                if fieldName == "returnType" { return "%TypeNode" }
                if fieldName == "body" { return "i64" }
                if fieldName == "isAsync" { return "i1" }
                if fieldName == "isInline" { return "i1" }
                if fieldName == "isStatic" { return "i1" }
            }
            if structName == "ClassNode" {
                if fieldName == "name" { return "%SeenString" }
                if fieldName == "fields" { return "ptr" }
                if fieldName == "methods" { return "ptr" }
            }
            if structName == "TypeNode" {
                if fieldName == "typeName" { return "%SeenString" }
                if fieldName == "isNullable" { return "i1" }
            }
            if structName == "ParamNode" {
                if fieldName == "name" { return "%SeenString" }
                if fieldName == "paramType" { return "%TypeNode" }
                if fieldName == "defaultValue" { return "i64" }
            }
            if structName == "ItemNode" {
                if fieldName == "itemType" { return "%SeenString" }
                if fieldName == "name" { return "%SeenString" }
                if fieldName == "visibility" { return "%SeenString" }
                if fieldName == "importPath" { return "ptr" }
                if fieldName == "importSymbols" { return "ptr" }
                if fieldName == "function" { return "i64" }
                if fieldName == "classNode" { return "i64" }
                if fieldName == "enumNode" { return "i64" }
            }
            if structName == "ProgramNode" {
                if fieldName == "items" { return "ptr" }
            }
            if structName == "BlockNode" {
                if fieldName == "statements" { return "ptr" }
            }
            if structName == "FrontendResult" {
                if fieldName == "success" { return "i1" }
                if fieldName == "diagnostics" { return "ptr" }
                if fieldName == "program" { return "i64" }
            }
            if structName == "FrontendDiagnostic" {
                if fieldName == "file" { return "%SeenString" }
                if fieldName == "line" { return "i64" }
                if fieldName == "column" { return "i64" }
                if fieldName == "severity" { return "%SeenString" }
                if fieldName == "message" { return "%SeenString" }
            }
            if structName == "Token" {
                if fieldName == "tokenType" { return "i64" }
                if fieldName == "value" { return "%SeenString" }
                if fieldName == "line" { return "i64" }
                if fieldName == "column" { return "i64" }
            }
            if structName == "StatementNode" {
                if fieldName == "kind" { return "%SeenString" }
                if fieldName == "variableName" { return "%SeenString" }
                if fieldName == "variableType" { return "%TypeNode" }
                if fieldName == "initializer" { return "i64" }
                if fieldName == "condition" { return "i64" }
                if fieldName == "thenBranch" { return "i64" }
                if fieldName == "elseBranch" { return "i64" }
                if fieldName == "loopBody" { return "i64" }
                if fieldName == "loopVariable" { return "%SeenString" }
                if fieldName == "loopIterable" { return "i64" }
                if fieldName == "returnValue" { return "i64" }
                if fieldName == "expression" { return "i64" }
            }
            if structName == "ParserExpressionNode" {
                if fieldName == "kind" { return "%SeenString" }
                if fieldName == "variableName" { return "%SeenString" }
                if fieldName == "literalValue" { return "%SeenString" }
                if fieldName == "literalType" { return "%SeenString" }
                if fieldName == "operator" { return "%SeenString" }
                if fieldName == "operands" { return "ptr" }
                if fieldName == "arguments" { return "ptr" }
                if fieldName == "callee" { return "%SeenString" }
            }
        }

        // Parse to find matching field by index
        var fieldIdx = 0
        var nameStart = 0
        var nameEnd = 0

        // Find field index from names string (comma-separated)
        // Refactored: avoid else clause to prevent method merging bug
        var foundField = false
        var pos = 0
        while pos <= fieldNamesStr.length() and not foundField {
            if pos == fieldNamesStr.length() or fieldNamesStr.substring(pos, pos + 1) == "," {
                let name = fieldNamesStr.substring(nameStart, pos)
                if name == fieldName {
                    foundField = true
                }
                if name != fieldName {
                    fieldIdx = fieldIdx + 1
                    nameStart = pos + 1
                }
            }
            pos = pos + 1
        }

        // Hardcoded fallbacks for known structs (avoid string parsing bugs)
        // Use %SeenString instead of { i64, ptr } for type compatibility
        // NOTE: Check these BEFORE returning default i64 for unknown fields
        if structName == "FrontendResult" {
            if fieldName == "success" { return "i1" }
            if fieldName == "diagnostics" { return "ptr" }
            if fieldName == "program" { return "i64" }
        }
        if structName == "FrontendDiagnostic" {
            if fieldName == "file" { return "%SeenString" }
            if fieldName == "line" { return "i64" }
            if fieldName == "column" { return "i64" }
            if fieldName == "severity" { return "%SeenString" }
            if fieldName == "message" { return "%SeenString" }
        }
        if structName == "CommandResult" {
            if fieldName == "success" { return "i1" }
            if fieldName == "output" { return "%SeenString" }
        }
        if structName == "FsFileResult" {
            if fieldName == "isOk" { return "i1" }
            if fieldName == "file" { return "i64" }
            if fieldName == "error" { return "%SeenString" }
        }
        if structName == "ProgramNode" {
            if fieldName == "items" { return "ptr" }
        }
        if structName == "ItemNode" {
            if fieldName == "itemType" { return "%SeenString" }
            if fieldName == "name" { return "%SeenString" }
            if fieldName == "visibility" { return "%SeenString" }
            if fieldName == "importPath" { return "ptr" }
            if fieldName == "importSymbols" { return "ptr" }
            if fieldName == "function" { return "i64" }
            if fieldName == "classNode" { return "i64" }
            if fieldName == "enumNode" { return "i64" }
        }
        if structName == "FunctionNode" {
            if fieldName == "name" { return "%SeenString" }
            if fieldName == "params" { return "ptr" }
            if fieldName == "returnType" { return "%TypeNode" }
            if fieldName == "body" { return "i64" }
            if fieldName == "isPublic" { return "i1" }
            if fieldName == "genericParams" { return "ptr" }
            if fieldName == "isAsync" { return "i1" }
            if fieldName == "isExtern" { return "i1" }
            if fieldName == "isStatic" { return "i1" }
            if fieldName == "isInline" { return "i1" }
        }
        if structName == "ClassNode" {
            if fieldName == "name" { return "%SeenString" }
            if fieldName == "fields" { return "ptr" }
            if fieldName == "methods" { return "ptr" }
        }
        if structName == "TypeInferenceResult" {
            if fieldName == "success" { return "i1" }
            if fieldName == "type" { return "i64" }
            if fieldName == "program" { return "i64" }
            if fieldName == "errors" { return "ptr" }
            if fieldName == "warnings" { return "ptr" }
            if fieldName == "environment" { return "i64" }
            if fieldName == "typeTable" { return "i64" }
        }
        if structName == "Token" {
            if fieldName == "kind" { return "%SeenString" }
            if fieldName == "tokenType" { return "i64" }
            if fieldName == "value" { return "%SeenString" }
            if fieldName == "line" { return "i64" }
            if fieldName == "column" { return "i64" }
            if fieldName == "offset" { return "i64" }
            if fieldName == "endOffset" { return "i64" }
            if fieldName == "length" { return "i64" }
            if fieldName == "fileId" { return "i64" }
            if fieldName == "pos" { return "%Position" }
        }
        if structName == "Position" {
            if fieldName == "line" { return "i64" }
            if fieldName == "column" { return "i64" }
            if fieldName == "offset" { return "i64" }
            if fieldName == "fileId" { return "i64" }
        }
        if structName == "StatementNode" {
            if fieldName == "kind" { return "%SeenString" }
            if fieldName == "expression" { return "i64" }
            if fieldName == "condition" { return "i64" }
            if fieldName == "thenBlock" { return "i64" }
            if fieldName == "thenBranch" { return "i64" }
            if fieldName == "elseBlock" { return "i64" }
            if fieldName == "elseBranch" { return "i64" }
            if fieldName == "varName" { return "%SeenString" }
            if fieldName == "varType" { return "%TypeNode" }
            if fieldName == "isMutable" { return "i1" }
            if fieldName == "initializer" { return "i64" }
            if fieldName == "loopVar" { return "%SeenString" }
            if fieldName == "iterableExpr" { return "i64" }
            if fieldName == "loopBody" { return "i64" }
            if fieldName == "whileCondition" { return "i64" }
            if fieldName == "whileBody" { return "i64" }
            if fieldName == "loopCondition" { return "i64" }
            if fieldName == "matchExpr" { return "i64" }
            if fieldName == "matchArms" { return "ptr" }
            if fieldName == "returnExpr" { return "i64" }
            if fieldName == "returnValue" { return "i64" }
            if fieldName == "value" { return "i64" }
            if fieldName == "target" { return "i64" }
        }
        if structName == "ParserExpressionNode" {
            if fieldName == "kind" { return "%SeenString" }
            if fieldName == "callee" { return "%SeenString" }
            if fieldName == "literalValue" { return "%SeenString" }
            if fieldName == "literalType" { return "%SeenString" }
            if fieldName == "operands" { return "ptr" }
            if fieldName == "operator" { return "%SeenString" }
            if fieldName == "arguments" { return "ptr" }
            if fieldName == "typeArgs" { return "ptr" }
            if fieldName == "isNullable" { return "i1" }
            if fieldName == "isSafeAccess" { return "i1" }
            if fieldName == "receiverType" { return "%SeenString" }
            if fieldName == "fieldName" { return "%SeenString" }
            if fieldName == "inferredType" { return "%TypeNode" }
            if fieldName == "lambdaParams" { return "ptr" }
            if fieldName == "lambdaBody" { return "i64" }
            if fieldName == "lambdaReturnType" { return "%TypeNode" }
        }
        if structName == "TypeNode" {
            if fieldName == "typeName" { return "%SeenString" }
            if fieldName == "isNullable" { return "i1" }
        }
        if structName == "ParamNode" {
            if fieldName == "name" { return "%SeenString" }
            if fieldName == "paramType" { return "%TypeNode" }
            if fieldName == "isMutable" { return "i1" }
        }
        if structName == "FieldNode" {
            if fieldName == "name" { return "%SeenString" }
            if fieldName == "fieldType" { return "%TypeNode" }
            if fieldName == "isMutable" { return "i1" }
            if fieldName == "defaultValue" { return "i64" }
        }
        if structName == "MatchArm" {
            if fieldName == "pattern" { return "i64" }
            if fieldName == "body" { return "i64" }
        }
        if structName == "BlockNode" {
            if fieldName == "statements" { return "ptr" }
        }
        if structName == "EnumNode" {
            if fieldName == "name" { return "%SeenString" }
            if fieldName == "variants" { return "ptr" }
        }
        if structName == "EnumVariant" {
            if fieldName == "name" { return "%SeenString" }
            if fieldName == "associatedTypes" { return "ptr" }
        }
        if structName == "Location" {
            if fieldName == "line" { return "i64" }
            if fieldName == "column" { return "i64" }
            if fieldName == "file" { return "%SeenString" }
        }
        if structName == "TypeError" {
            if fieldName == "message" { return "%SeenString" }
            if fieldName == "location" { return "i64" }  // class type
            if fieldName == "severity" { return "%SeenString" }
        }
        if structName == "LexerError" {
            if fieldName == "message" { return "%SeenString" }
            if fieldName == "line" { return "i64" }
            if fieldName == "column" { return "i64" }
        }
        if structName == "ParseError" {
            if fieldName == "message" { return "%SeenString" }
            if fieldName == "line" { return "i64" }
            if fieldName == "column" { return "i64" }
        }
        if structName == "SeenLexer" {
            if fieldName == "source" { return "%SeenString" }
            if fieldName == "fileId" { return "i64" }
            if fieldName == "language" { return "%SeenString" }
            if fieldName == "errorRecoveryMode" { return "i1" }
            if fieldName == "keywordManager" { return "i64" }
            if fieldName == "position" { return "i64" }
            if fieldName == "line" { return "i64" }
            if fieldName == "column" { return "i64" }
            if fieldName == "tokens" { return "ptr" }
            if fieldName == "pos" { return "i64" }
            if fieldName == "errors" { return "ptr" }
        }
        if structName == "TypeChecker" {
            if fieldName == "environment" { return "i64" }
            if fieldName == "env" { return "i64" }
            if fieldName == "errors" { return "ptr" }
            if fieldName == "warnings" { return "ptr" }
            if fieldName == "strictMode" { return "i1" }
            if fieldName == "currentFunction" { return "i64" }
            if fieldName == "currentClass" { return "i64" }
            if fieldName == "classTypes" { return "ptr" }
            if fieldName == "functionTypes" { return "ptr" }
            if fieldName == "typeTable" { return "i64" }
        }
        if structName == "SeenTypeChecker" {
            if fieldName == "smartCastContext" { return "i64" }
            if fieldName == "strictMode" { return "i1" }
            if fieldName == "environment" { return "i64" }
            if fieldName == "errors" { return "ptr" }
            if fieldName == "warnings" { return "ptr" }
        }
        if structName == "RealParser" {
            if fieldName == "tokens" { return "ptr" }
            if fieldName == "pos" { return "i64" }
            if fieldName == "current" { return "i64" }
            if fieldName == "currentProgram" { return "i64" }
            if fieldName == "currentBlock" { return "i64" }
            if fieldName == "lastStatement" { return "i64" }
            if fieldName == "lastFunction" { return "i64" }
            if fieldName == "errors" { return "ptr" }
            if fieldName == "currentFile" { return "%SeenString" }
        }
        if structName == "ImportPathInfo" {
            if fieldName == "isRelative" { return "i1" }
            if fieldName == "segments" { return "ptr" }
        }
        if structName == "ImportSymbolNode" {
            if fieldName == "name" { return "%SeenString" }
            if fieldName == "alias" { return "%SeenString" }
        }
        if structName == "FsFile" {
            if fieldName == "fd" { return "i64" }
            if fieldName == "path" { return "%SeenString" }
        }
        if structName == "StringHashMap" {
            if fieldName == "entries" { return "ptr" }
            if fieldName == "count" { return "i64" }
            if fieldName == "capacity" { return "i64" }
        }
        if structName == "HashEntry" {
            if fieldName == "key" { return "%SeenString" }
            if fieldName == "value" { return "i64" }
        }
        if structName == "KeywordManager" {
            if fieldName == "language" { return "%SeenString" }
            if fieldName == "keywords" { return "i64" }  // StringHashMap (class)
            if fieldName == "tokenNameMap" { return "i64" }
            if fieldName == "sources" { return "ptr" }
            if fieldName == "operators" { return "i64" }
            if fieldName == "literalKeywords" { return "i64" }
        }
        if structName == "Environment" {
            if fieldName == "parent" { return "i64" }
            if fieldName == "variables" { return "i64" }
            if fieldName == "types" { return "i64" }
        }
        if structName == "TypeTable" {
            if fieldName == "types" { return "i64" }
            if fieldName == "parent" { return "i64" }
        }
        if structName == "LLVMIRGenerator" {
            return this.getLLVMIRGeneratorFieldType(fieldName)
        }
        if structName == "Type" {
            if fieldName == "name" { return "%SeenString" }
            if fieldName == "isNullable" { return "i1" }
        }
        if structName == "FunctionType" {
            if fieldName == "parameters" { return "ptr" }
            if fieldName == "returnType" { return "i64" }
            if fieldName == "isAsync" { return "i1" }
        }
        if structName == "ClassType" {
            if fieldName == "name" { return "%SeenString" }
            if fieldName == "fields" { return "ptr" }
            if fieldName == "methods" { return "ptr" }
        }
        if structName == "InterfaceType" {
            if fieldName == "name" { return "%SeenString" }
            if fieldName == "methods" { return "ptr" }
        }
        if structName == "StringBuilder" {
            if fieldName == "data" { return "ptr" }
            if fieldName == "length" { return "i64" }
            if fieldName == "capacity" { return "i64" }
        }
        if structName == "SeenArray" {
            if fieldName == "len" { return "i64" }
            if fieldName == "cap" { return "i64" }
            if fieldName == "element_size" { return "i64" }
            if fieldName == "data" { return "ptr" }
        }

        // If field wasn't found in the field names list, return default
        // (can't use fieldIdx if foundField is false)
        if not foundField {
            return "i64"
        }

        // Prefer LLVM field types from header if available
        if llvmFieldTypesStr != "" {
            if structName == "FrontendResult" and fieldName == "success" {
                println("[DEBUG getFieldType] FrontendResult.success: llvmFieldTypesStr='" + llvmFieldTypesStr + "' len=" + llvmFieldTypesStr.length().toString())
            }
            var llvmTypeIdx = 0
            var llvmTypeStart = 0
            pos = 0
            while pos <= llvmFieldTypesStr.length() {
                if pos == llvmFieldTypesStr.length() or llvmFieldTypesStr.substring(pos, pos + 1) == "|" {
                    if llvmTypeIdx == fieldIdx {
                        let result = llvmFieldTypesStr.substring(llvmTypeStart, pos)
                        if structName == "FrontendResult" and fieldName == "success" {
                            println("[DEBUG getFieldType] returning: '" + result + "' len=" + result.length().toString())
                        }
                        return result
                    }
                    llvmTypeIdx = llvmTypeIdx + 1
                    llvmTypeStart = pos + 1
                }
                pos = pos + 1
            }
        }

        // Now find the type at fieldIdx (pipe-separated)
        var typeIdx = 0
        var typeStart = 0
        pos = 0
        while pos <= fieldTypesStr.length() {
            if pos == fieldTypesStr.length() or fieldTypesStr.substring(pos, pos + 1) == "|" {
                if typeIdx == fieldIdx {
                    let typeName = fieldTypesStr.substring(typeStart, pos)
                    return this.mapType(typeName)
                }
                typeIdx = typeIdx + 1
                typeStart = pos + 1
            }
            pos = pos + 1
        }

        return "i64"  // Default
    }

