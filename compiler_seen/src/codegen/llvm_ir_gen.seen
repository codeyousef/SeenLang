    // Generate IR for a single class method. The method name is mangled as
    // ClassName_methodName. Non-static methods receive an implicit `ptr %this`
    // first parameter pointing to the heap-allocated struct.
    //
    // Option class methods (isSome, isNone) are inlined against the direct-value
    // option object layout used by runtime unwrap helpers.
    // rather than delegated to the C runtime.
    //
    // CRITICAL: cseClear() is called at method entry to prevent the cross-method
    // CSE bug. Without it, a CSE key like "%4*%7->%8" cached from method A
    // could match the same register numbers in method B (since each method
    // resets nextReg to 1), producing self-referential IR that causes LLVM
    // verification failures.
    fun shouldTraceClassMethodStart(className: String) r: Bool {
        return className == "JsonParseResult" or className == "JsonParser" or className == "LLVMIRGenerator"
    }

    fun resetClassMethodGenerationState(className: String, parentName: String, methods: Array<FunctionNode>, methodIdx: Int) r: Void {
        g_regBox[0] = 1
        varNames = Array<String>()
        varRegs = Array<String>()
        varTypes = Array<String>()
        preAllocatedVars = Array<String>()
        preAllocatedTypes = Array<String>()
        preAllocatedRegs = Array<String>()
        activeVarCount = 0
        declOrdinalNames = Array<String>()
        declOrdinalCounts = Array<Int>()
        currentFunctionReturnType = resolveMethodReturnTypeFromList(className, methods, methodIdx)
        currentClassName = className
        g_currentClassParentName = parentName
        blockTerminated = false
        resetFunctionLoweringOptionsState()
        cseClear()
    }

    fun collectClassMethodParameterInfo(methods: Array<FunctionNode>, methodIdx: Int,
        normalizedMethodParamTypes: Array<String>, mappedMethodParamTypes: Array<String>,
        quotedMethodArgNames: Array<String>) r: Void {

        var paramInfoIdx = 0
        while paramInfoIdx < methods[methodIdx].params.length() {
            let methodParam = methods[methodIdx].params[paramInfoIdx]
            let normalizedParamType = normalizeDeclaredTypeNode(methodParam.paramType)
            normalizedMethodParamTypes.push(normalizedParamType)
            mappedMethodParamTypes.push(mapTypeForParameter(normalizedParamType))
            quotedMethodArgNames.push(quoteIdentIfNeeded(methodParam.name + ".arg"))
            paramInfoIdx = paramInfoIdx + 1
        }
    }

    fun prepareClassMethodVariableCollection(className: String, methods: Array<FunctionNode>, methodIdx: Int,
        normalizedMethodParamTypes: Array<String>) r: Void {

        if not methods[methodIdx].isStatic {
            storeVar("this", "", className)
        }
        var paramIdx = 0
        while paramIdx < methods[methodIdx].params.length() {
            let param = methods[methodIdx].params[paramIdx]
            storeVar(param.name, "", normalizedMethodParamTypes[paramIdx])
            paramIdx = paramIdx + 1
        }
        collectVariableDeclarations(methods[methodIdx].body)
        varNames = Array<String>()
        varRegs = Array<String>()
        varTypes = Array<String>()
        activeVarCount = 0
    }

    fun emitClassMethodSignature(className: String, methodName: String, methods: Array<FunctionNode>,
        methodIdx: Int, isStatic: Bool, returnType: String, mappedMethodParamTypes: Array<String>,
        quotedMethodArgNames: Array<String>) r: String {

        let methodAttrs = buildMethodAttrsImpl(methods, methodIdx, className, methodName,
            g_selfCallFuncs, g_selfCallNames, g_selfCallCount)
        var methodRetPrefix = "define "
        if returnType == "i64" or returnType == "double" or returnType == "i1" {
            methodRetPrefix = "define noundef "
        }
        output.append(methodRetPrefix + returnType + " @" + quoteIdentIfNeeded(className + "_" + methodName) + "(")

        var hasThis = false
        if not isStatic {
            output.append("ptr %this")
            hasThis = true
        }

        var isStaticInt = 0
        if isStatic {
            isStaticInt = 1
        }
        let explicitReceiverName = detectExplicitReceiverNameImpl(className, isStaticInt, methods, methodIdx)
        var hasThisInt = 0
        if hasThis {
            hasThisInt = 1
        }
        emitMethodSignatureParamsImpl(output, methods, methodIdx, explicitReceiverName,
            hasThisInt, mappedMethodParamTypes, quotedMethodArgNames)

        output.append(")" + methodAttrs + " #0 {\n")
        output.append("entry:\n")
        return explicitReceiverName
    }

    fun emitClassMethodReceiverBinding(className: String, isStatic: Bool, explicitReceiverName: String) r: Void {
        if isStatic {
            return
        }
        let thisReg = getNextReg()
        output.append("  " + thisReg + " = alloca ptr\n")
        output.append("  store ptr %this, ptr " + thisReg + "\n")
        storeVar("this", thisReg, className)
        if explicitReceiverName != "this" {
            if explicitReceiverName != "" {
                storeVar(explicitReceiverName, thisReg, className)
            }
        }
    }

    fun emitClassMethodParameterBindings(methods: Array<FunctionNode>, methodIdx: Int, explicitReceiverName: String,
        normalizedMethodParamTypes: Array<String>, quotedMethodArgNames: Array<String>) r: Void {

        var paramIdx = 0
        while paramIdx < methods[methodIdx].params.length() {
            let param = methods[methodIdx].params[paramIdx]
            var isExplicitReceiver = 0
            if param.name == explicitReceiverName {
                if explicitReceiverName != "" {
                    isExplicitReceiver = 1
                }
            }
            if isExplicitReceiver == 0 {
                let seenTypeName = normalizedMethodParamTypes[paramIdx]
                let semanticSeenTypeName = normalizeSeenTypeName(seenTypeName)
                if isDataType(semanticSeenTypeName) {
                    storeVar(param.name, "%" + quotedMethodArgNames[paramIdx], semanticSeenTypeName)
                } else {
                    let paramType = mapStorageTypeForParameter(seenTypeName)
                    let reg = getNextReg()
                    output.append("  " + reg + " = alloca " + paramType + "\n")
                    output.append("  store " + paramType + " %" + quotedMethodArgNames[paramIdx] + ", ptr " + reg + "\n")
                    storeVar(param.name, reg, semanticSeenTypeName)
                }
            }
            paramIdx = paramIdx + 1
        }
    }

    fun emitClassMethodConstructorSetup(className: String, methodName: String) r: Void {
        if methodName != "new" {
            return
        }
        let thisReg = emitConstructorAllocationImpl(output, g_regBox, className,
            structNames, structSizes, structFieldNames, structFieldTypes)
        storeVar("this", thisReg, className)
    }

    fun tryEmitClassMethodConstructorReturn(methodName: String) r: Bool {
        if blockTerminated {
            return false
        }
        if methodName != "new" {
            return false
        }
        let thisVarIdx = findVar("this")
        if thisVarIdx < 0 {
            return false
        }
        emitConstructorReturnImpl(output, g_regBox, varRegs[thisVarIdx])
        blockTerminated = true
        return true
    }

    fun emitClassMethodDefaultReturn(returnType: String) r: Void {
        if blockTerminated {
            return
        }
        emitDefaultReturnValueImpl(output, returnType)
    }

    fun generateClassMethodFromList(className: String, parentName: String, methods: Array<FunctionNode>, methodIdx: Int) r: Void {
        let methodName = methods[methodIdx].name
        if shouldTraceClassMethodStart(className) {
            println("[irgen class method start] " + className + "." + methodName)
        }
        if tryEmitOptionClassMethodShimImpl(output, className, methodName) == 1 {
            return
        }

        resetClassMethodGenerationState(className, parentName, methods, methodIdx)

        let normalizedMethodParamTypes = Array<String>()
        let mappedMethodParamTypes = Array<String>()
        let quotedMethodArgNames = Array<String>()
        collectClassMethodParameterInfo(methods, methodIdx, normalizedMethodParamTypes, mappedMethodParamTypes, quotedMethodArgNames)
        prepareClassMethodVariableCollection(className, methods, methodIdx, normalizedMethodParamTypes)

        let returnType = mapType(currentFunctionReturnType)
        let isStatic = methods[methodIdx].isStatic or methodName == "new"
        let explicitReceiverName = emitClassMethodSignature(className, methodName, methods, methodIdx,
            isStatic, returnType, mappedMethodParamTypes, quotedMethodArgNames)
        emitClassMethodReceiverBinding(className, isStatic, explicitReceiverName)
        emitClassMethodParameterBindings(methods, methodIdx, explicitReceiverName,
            normalizedMethodParamTypes, quotedMethodArgNames)
        emitPreAllocatedAllocas()
        emitClassMethodConstructorSetup(className, methodName)

        generateBlock(methods[methodIdx].body)
        tryEmitClassMethodConstructorReturn(methodName)
        emitClassMethodDefaultReturn(returnType)
        output.append("}\n\n")
    }

    fun generateClassMethodByIndex(classNode: ClassNode, methodIdx: Int) r: Void {
        generateClassMethodFromList(classNode.name, classNode.parentName, classNode.methods, methodIdx)
    }

    fun emitStringConstants() r: Void {
        var i = 0
        while i < stringConstants.length() {
            let str = stringConstants[i]
            let escaped = escapeString(str)
            let len = str.length() + 1  // +1 for null terminator
            output.append("@.str." + i.toString() + " = private unnamed_addr constant [" + len.toString() + " x i8] c\"" + escaped + "\\00\"\n")
            i = i + 1
        }
        if stringConstants.length() > 0 {
            output.append("\n")
        }
    }

    // Emit string constants with module prefix to avoid collisions in per-module compilation
    fun emitStringConstantsWithPrefix(moduleIndex: Int) r: Void {
        var i = 0
        while i < stringConstants.length() {
            let str = stringConstants[i]
            let escaped = escapeString(str)
            let len = str.length() + 1  // +1 for null terminator
            // Module-prefixed name: @.str.M0.0, @.str.M1.0, etc.
            output.append("@.str.M" + moduleIndex.toString() + "." + i.toString() + " = private unnamed_addr constant [" + len.toString() + " x i8] c\"" + escaped + "\\00\"\n")
            i = i + 1
        }
        if stringConstants.length() > 0 {
            output.append("\n")
        }
    }

    // Delegates to free functions in ir_decl_runtime/parser/features.seen
    // Emit `declare` statements for all runtime C functions (seen_runtime.c)
    // and standard library functions that might be called from user code.
    // Skips functions that are defined in this module (definedFuncs) to
    // avoid "invalid redefinition" LLVM errors. Delegates to specialized
    // emitters in ir_decl_runtime, ir_decl_parser, ir_decl_features.
    fun emitRuntimeDeclarations(definedFuncs: Array<String>) r: Void {
        emitCoreRuntimeDecls(output, runtimeDeclsLoaded, definedFuncs)
        runtimeDeclsLoaded = true
        emitStringAndIODecls(output, definedFuncs)
        emitParserDecls(output, definedFuncs)
        emitTypecheckerDecls(output, runtimeDeclsLoaded, definedFuncs)
        emitMacroAndLspDecls(output, definedFuncs)
        emitFeatureDecls(output, definedFuncs)
    }

    fun emitProgramGlobalVariables(program: ProgramNode) r: Void {
        let moduleConstMutableBox = Array<String>()
        moduleConstMutableBox.push(g_moduleConstMutable)
        let moduleConstSeenTypesBox = Array<String>()
        moduleConstSeenTypesBox.push(g_moduleConstSeenTypes)
        emitGlobalVariablesImpl(output, program, moduleConstantNames, moduleConstantTypes, moduleConstantValues, moduleConstMutableBox, moduleConstSeenTypesBox)
        g_moduleConstMutable = moduleConstMutableBox[0]
        g_moduleConstSeenTypes = moduleConstSeenTypesBox[0]
    }

    fun emitCrossModuleConstantDeclares() r: Void {
        emitCrossModuleConstantDeclaresImpl(output, moduleConstantNames, g_xmConstNames, g_xmConstTypes, g_xmConstCount)
    }

    fun emitTraitVtableConstants() r: Void {
        emitTraitVtableConstantsImpl(output, g_traitImplRegistry, g_traitImplCount, g_dynTraitNames)
    }

    fun registerDynTraitName(name: String) r: Void {
        let namesBox = Array<String>()
        namesBox.push(g_dynTraitNames)
        appendDynTraitNameImpl(name, namesBox)
        g_dynTraitNames = namesBox[0]
    }

    fun appendTraitImplEntry(entry: String) r: Void {
        let registryBox = Array<String>()
        registryBox.push(g_traitImplRegistry)
        let countBox = Array<Int>()
        countBox.push(g_traitImplCount)
        appendTraitImplEntryImpl(entry, registryBox, countBox)
        g_traitImplRegistry = registryBox[0]
        g_traitImplCount = countBox[0]
    }

    fun autoRegisterTraitImpls(methodName: String, receiverType: String, implFuncName: String) r: Void {
        let registryBox = Array<String>()
        registryBox.push(g_traitImplRegistry)
        let countBox = Array<Int>()
        countBox.push(g_traitImplCount)
        autoRegisterTraitImplsImpl(methodName, receiverType, implFuncName, g_dynTraitNames, structNames, structMethodNames, structMethodRetTypes, registryBox, countBox)
        g_traitImplRegistry = registryBox[0]
        g_traitImplCount = countBox[0]
    }

    fun emitGlobalConstructors() r: Void {
        emitGlobalConstructorsImpl(output, g_initFuncCount, g_initFuncNames)
    }

    // Helper to check if a function has a specific decorator
    fun hasDecorator(fn: FunctionNode, decoratorName: String) r: Bool {
        var i = 0
        while i < fn.decorators.length() {
            if fn.decorators[i].name == decoratorName {
                return true
            }
            i = i + 1
        }
        return false
    }

    // : Generate CPU dispatch wrapper for a GPU shader function
    // The wrapper takes the same parameters and calls seen_gpu_dispatch with buffer handles
    // NOTE: Simplified to avoid stage1_frozen "store %SeenString 0" bug in loop bodies
    fun generateGpuDispatchWrapper(fn: FunctionNode, stage: Int, bindingCount: Int, wgX: Int, wgY: Int, wgZ: Int) r: Void {
        // Generate a simple void dispatch wrapper that takes group counts + buffer handles
        // Avoids iterating fn.params with string let bindings (triggers stage1 codegen bug)
        output.append("define void @" + quoteIdentIfNeeded(fn.name + "_gpu_dispatch") + "(i64 %gpu_gx, i64 %gpu_gy, i64 %gpu_gz, ptr %gpu_bufs, i64 %gpu_nbufs) nounwind {\n")
        output.append("entry:\n")
        let dr = getNextReg()
        output.append("  " + dr + " = call i64 @seen_gpu_dispatch(i64 0, i64 %gpu_gx, i64 %gpu_gy, i64 %gpu_gz, ptr %gpu_bufs, i64 %gpu_nbufs)\n")
        output.append("  ret void\n")
        output.append("}\n\n")
    }

    // Add a string constant to the string constant table (deduplicating).
    // Returns the index, used to reference the global @.str.PREFIX.INDEX.
    fun addStringConstant(str: String) r: Int {
        // Check if already exists
        var idx = 0
        while idx < stringConstants.length() {
            if stringConstants[idx] == str {
                return idx
            }
            idx = idx + 1
        }
        // Add new string constant
        stringConstants.push(str)
        return stringConstants.length() - 1
    }

    // Get the index of an existing string constant
    fun getStringConstantIndex(str: String) r: Int {
        var idx = 0
        while idx < stringConstants.length() {
            if stringConstants[idx] == str {
                return idx
            }
            idx = idx + 1
        }
        // Not found - add it
        return addStringConstant(str)
    }

    // Generate IR for a top-level (free) function. Handles decorators:
    //   @cfg — conditional compilation (skip if predicate doesn't match)
    //   @intrinsic — emit thin wrapper calling an LLVM intrinsic
    //   @inline/@noinline — LLVM inlining hints (alwaysinline/noinline)
    //   @compute — GPU shader (skip IR, handled by GLSL codegen)
    //   @async — LLVM coroutine-based async function
    //   @profile — instrumentation profiling (call enter/exit hooks)
    //   @vectorize/@no_vectorize/@unroll/@prefetch — loop optimization hints
    //
    // Extern functions (body has no statements, name starts with "__") are
    // skipped — they must have explicit `declare` in ir_declarations.seen.
    //
    // Function bodies are wrapped in: entry block -> alloca hoisting ->
    // parameter stores -> body generation -> implicit void return.
    // ML-guided inlining decisions are logged when g_mlLogEnabled is set.
    fun shouldSkipFunctionByCfg(fn: FunctionNode) r: Bool {
        if not hasDecorator(fn, "cfg") {
            return false
        }
        var cfgMatch = false
        var cfgIdx = 0
        while cfgIdx < fn.decorators.length() {
            if fn.decorators[cfgIdx].name == "cfg" {
                if fn.decorators[cfgIdx].arguments.length() > 0 {
                    let cfgPred = fn.decorators[cfgIdx].arguments[0]
                    if cfgPred == "linux" or cfgPred == "target_os_linux" {
                        cfgMatch = true
                    }
                    if cfgPred == "unix" {
                        cfgMatch = true
                    }
                    if cfgPred == "x86_64" or cfgPred == "target_arch_x86_64" {
                        cfgMatch = true
                    }
                    if cfgPred == "debug" {
                        cfgMatch = false
                    }
                    if cfgPred == "release" {
                        cfgMatch = true
                    }
                    if cfgPred.startsWith("feature:") {
                        let featureName = cfgPred.substring(8, cfgPred.length())
                        let featureNameTrimmed = trimSpaces(featureName)
                        var featureClean = featureNameTrimmed
                        if featureClean.startsWith("\"") {
                            featureClean = featureClean.substring(1, featureClean.length())
                        }
                        if featureClean.endsWith("\"") {
                            featureClean = featureClean.substring(0, featureClean.length() - 1)
                        }
                        if g_enabledFeatures.contains(featureClean + "|") {
                            cfgMatch = true
                        }
                    }
                }
            }
            cfgIdx = cfgIdx + 1
        }
        if not cfgMatch {
            output.append("; SKIPPED: " + fn.name + " (@cfg predicate not met)\n")
            return true
        }
        return false
    }

    fun emitFunctionDecoratorMetadataComments(fn: FunctionNode) r: Void {
        if hasDecorator(fn, "where_constraint") and g_traitImplCount > 0 {
            var wcIdx = 0
            while wcIdx < fn.decorators.length() {
                if fn.decorators[wcIdx].name == "where_constraint" {
                    if fn.decorators[wcIdx].arguments.length() > 0 {
                        let wcText = fn.decorators[wcIdx].arguments[0]
                        output.append("; where clause: " + wcText + "\n")
                    }
                }
                wcIdx = wcIdx + 1
            }
        }
        if hasDecorator(fn, "region_bound") {
            output.append("; @region_bound function: " + fn.name + "\n")
        }
    }

    fun tryHandleIntrinsicFunctionGeneration(fn: FunctionNode) r: Bool {
        if not hasDecorator(fn, "intrinsic") {
            return false
        }
        var intrLlvmName = ""
        var intrDecIdx = 0
        while intrDecIdx < fn.decorators.length() {
            if fn.decorators[intrDecIdx].name == "intrinsic" {
                if fn.decorators[intrDecIdx].arguments.length() > 0 {
                    intrLlvmName = fn.decorators[intrDecIdx].arguments[0]
                }
            }
            intrDecIdx = intrDecIdx + 1
        }
        if intrLlvmName == "" {
            return false
        }
        let intrParamTypes = Array<String>()
        var intrPIdx = 0
        while intrPIdx < fn.params.length() {
            let intrParam = fn.params[intrPIdx]
            let intrPType = intrParam.paramType
            let intrPTName = intrPType.typeName
            intrParamTypes.push(mapType(intrPTName))
            intrPIdx = intrPIdx + 1
        }
        let intrRetTN = fn.returnType
        let intrRetTName = intrRetTN.typeName
        let intrRetType = mapType(intrRetTName)
        let intrLines = Array<String>()
        if emitIntrinsicWrapperImpl(intrLines, g_regBox, fn.name, intrLlvmName, intrParamTypes, intrParamTypes.length(), intrRetType, quoteIdentIfNeeded(fn.name)) {
            var intrOutIdx = 0
            while intrOutIdx < intrLines.length() {
                output.append(intrLines[intrOutIdx])
                intrOutIdx = intrOutIdx + 1
            }
        }
        if g_intrinsicCount > 0 {
            g_intrinsicFuncNames = g_intrinsicFuncNames + "|"
            g_intrinsicLlvmNames = g_intrinsicLlvmNames + "|"
        }
        g_intrinsicFuncNames = g_intrinsicFuncNames + fn.name
        g_intrinsicLlvmNames = g_intrinsicLlvmNames + intrLlvmName
        g_intrinsicCount = g_intrinsicCount + 1
        return true
    }

    fun registerFunctionTraitImplDecorators(fn: FunctionNode) r: Void {
        if not hasDecorator(fn, "impl_trait") {
            return
        }
        var itDecIdx = 0
        while itDecIdx < fn.decorators.length() {
            if fn.decorators[itDecIdx].name == "impl_trait" {
                if fn.decorators[itDecIdx].arguments.length() > 0 {
                    let itInfo = fn.decorators[itDecIdx].arguments[0]
                    appendTraitImplEntry(itInfo + ":" + fn.name)
                }
            }
            itDecIdx = itDecIdx + 1
        }
    }

    fun tryHandleGpuShaderFunctionGeneration(fn: FunctionNode) r: Bool {
        if not (hasDecorator(fn, "compute") or hasDecorator(fn, "vertex") or hasDecorator(fn, "fragment")) {
            return false
        }
        var gpuStage = 0
        if hasDecorator(fn, "vertex") {
            gpuStage = 1
        }
        if hasDecorator(fn, "fragment") {
            gpuStage = 2
        }
        var gpuWgX = 64
        var gpuWgY = 1
        var gpuWgZ = 1
        var gpuBindCount = fn.params.length()
        if g_gpuShaderCount > 0 {
            g_gpuShaderNames = g_gpuShaderNames + "|"
            g_gpuShaderStages = g_gpuShaderStages + "|"
            g_gpuShaderWorkgroups = g_gpuShaderWorkgroups + "|"
            g_gpuShaderBindings = g_gpuShaderBindings + "|"
        }
        g_gpuShaderNames = g_gpuShaderNames + fn.name
        g_gpuShaderStages = g_gpuShaderStages + gpuStage.toString()
        g_gpuShaderWorkgroups = g_gpuShaderWorkgroups + gpuWgX.toString() + "," + gpuWgY.toString() + "," + gpuWgZ.toString()
        g_gpuShaderBindings = g_gpuShaderBindings + gpuBindCount.toString()
        g_gpuShaderCount = g_gpuShaderCount + 1
        output.append("; GPU shader function: " + fn.name + " (stage=" + gpuStage.toString() + ", bindings=" + gpuBindCount.toString() + ")\n")
        generateGpuDispatchWrapper(fn, gpuStage, gpuBindCount, gpuWgX, gpuWgY, gpuWgZ)
        return true
    }

    fun shouldSkipSpecialFunctionBody(fn: FunctionNode) r: Bool {
        if fn.name == "new" {
            output.append("; SKIPPED: new (class constructor)\n")
            return true
        }
        if fn.name.startsWith("__") and fn.body.statements.length() == 0 and not fn.isExtern {
            output.append("; SKIPPED: " + fn.name + " (extern C function - declared by runtime)\n")
            return true
        }
        return false
    }

    fun tryHandleExternFunctionGeneration(fn: FunctionNode) r: Bool {
        if not fn.isExtern {
            return false
        }
        if fn.name.startsWith("__") {
            output.append("; SKIPPED: " + fn.name + " (extern runtime function - declared by ir_declarations)\n")
            registerFunction(fn.name, normalizeDeclaredTypeNode(fn.returnType))
            return true
        }
        var externSymbol = fn.name
        if externSymbol.startsWith("llvm_coro_") {
            let suffix = externSymbol.substring(10, externSymbol.length())
            externSymbol = "llvm.coro." + suffix
        }
        var mappedPTypes = Array<String>()
        var mpIdx = 0
        while mpIdx < fn.params.length() {
            let param = fn.params[mpIdx]
            let ptn = param.paramType
            let ptName = normalizeDeclaredTypeNode(ptn)
            mappedPTypes.push(mapTypeForParameter(ptName))
            mpIdx = mpIdx + 1
        }
        let externRetType = mapType(normalizeDeclaredTypeNode(fn.returnType))
        var isVariadic = 0
        if hasDecorator(fn, "variadic") { isVariadic = 1 }
        emitExternDeclImpl(output, fn.name, externSymbol, mappedPTypes, fn.params.length(), externRetType, isVariadic)
        registerFunction(fn.name, normalizeDeclaredTypeNode(fn.returnType))
        return true
    }

    fun resolveImplementationFunctionName(fn: FunctionNode) r: String {
        var implFuncName = fn.name
        let implFnParams = fn.params
        if implFnParams.length() > 0 {
            let implFirstP = implFnParams[0]
            let implFirstPName = implFirstP.name
            if implFirstPName == "this" {
                let implFirstPType = implFirstP.paramType
                let implFirstPTN = implFirstPType.typeName
                if isClassType(implFirstPTN) {
                    let implExpectedPrefix = implFirstPTN + "_"
                    if not implFuncName.startsWith(implExpectedPrefix) {
                        implFuncName = implExpectedPrefix + implFuncName
                    }
                    autoRegisterTraitImpls(fn.name, implFirstPTN, implFuncName)
                }
            }
        }
        return implFuncName
    }

    fun resetFunctionGenerationState(resolvedFunctionReturnType: String) r: Void {
        g_regBox[0] = 1
        varNames = Array<String>()
        varRegs = Array<String>()
        varTypes = Array<String>()
        preAllocatedVars = Array<String>()
        preAllocatedTypes = Array<String>()
        preAllocatedRegs = Array<String>()
        activeVarCount = 0
        declOrdinalNames = Array<String>()
        declOrdinalCounts = Array<Int>()
        currentFunctionReturnType = resolvedFunctionReturnType
        currentClassName = ""
        g_currentClassParentName = ""
        blockTerminated = false
        resetFunctionLoweringOptionsState()
        g_movedVarNames = ""
        g_movedVarCount = 0
    }

    fun preRegisterFunctionParameters(fn: FunctionNode, implFuncName: String) r: Void {
        var preParamIdx = 0
        while preParamIdx < fn.params.length() {
            let param = fn.params[preParamIdx]
            let rawPreTypeName = param.paramType.typeName
            var preTypeName = normalizeDeclaredTypeNode(param.paramType)
            if preTypeName.startsWith("move:") {
                preTypeName = preTypeName.substring(5, preTypeName.length())
            }
            if preTypeName.startsWith("borrow:") {
                preTypeName = preTypeName.substring(7, preTypeName.length())
            }
            if preTypeName.startsWith("comptime:") {
                preTypeName = preTypeName.substring(9, preTypeName.length())
                if g_comptimeParamCount == 0 or not g_comptimeParamFuncNames.contains(fn.name + "|") {
                    g_comptimeParamFuncNames = g_comptimeParamFuncNames + fn.name + ":" + preParamIdx.toString() + ":" + param.name + "|"
                    g_comptimeParamCount = g_comptimeParamCount + 1
                }
            }
            var defaultTypeName = rawPreTypeName
            if defaultTypeName.startsWith("move:") {
                defaultTypeName = defaultTypeName.substring(5, defaultTypeName.length())
            }
            if defaultTypeName.startsWith("borrow:") {
                defaultTypeName = defaultTypeName.substring(7, defaultTypeName.length())
            }
            if defaultTypeName.startsWith("comptime:") {
                defaultTypeName = defaultTypeName.substring(9, defaultTypeName.length())
            }
            if defaultTypeName.contains("~default~") {
                let defSepPos = defaultTypeName.indexOf("~default~", 0)
                let defValue = defaultTypeName.substring(defSepPos + 9, defaultTypeName.length())
                let defTypeName = normalizeSeenTypeName(defaultTypeName.substring(0, defSepPos))
                g_funcDefaultsArr = g_funcDefaultsArr + implFuncName + ":" + preParamIdx.toString() + ":" + defValue + ":" + defTypeName + "|"
            }
            if preTypeName.startsWith("dyn ") {
                let dynTraitParam = preTypeName.substring(4, preTypeName.length())
                g_dynParamFuncs = g_dynParamFuncs + implFuncName + ":" + preParamIdx.toString() + ":" + dynTraitParam + "|"
            }
            storeVar(param.name, "", normalizeSeenTypeName(preTypeName))
            preParamIdx = preParamIdx + 1
        }

        if fn.params.length() > 0 {
            g_funcParamCountArr = g_funcParamCountArr + implFuncName + ":" + fn.params.length().toString() + "|"
        }
    }

    fun tryEmitMainFunction(fn: FunctionNode, fnName: String, returnType: String) r: Bool {
        if not llvmIrGenIsMainFunctionName(fnName) {
            return false
        }
        g_isMainFunc = 1
        var mainReturnType = returnType
        if mainReturnType == "void" {
            mainReturnType = "i32"
        }
        var mainRetPrefix = "define "
        if mainReturnType == "i64" or mainReturnType == "double" or mainReturnType == "i1" {
            mainRetPrefix = "define noundef "
        }
        output.append(mainRetPrefix + mainReturnType + " @main(i32 %argc, ptr %argv) #0 {\n")
        output.append("entry:\n")
        output.append("  call void @seen_runtime_init(i32 %argc, ptr %argv)\n")
        emitPreAllocatedAllocas()
        println("[irgen function] block start: " + fnName)
        generateBlock(fn.body)
        println("[irgen function] block done: " + fnName)
        if not blockTerminated {
            emitDefaultReturnValueImpl(output, mainReturnType)
        }
        output.append("}\n\n")
        g_isMainFunc = 0
        return true
    }

    fun emitFunctionParameterAllocas(fn: FunctionNode) r: Void {
        var paramIdx = 0
        while paramIdx < fn.params.length() {
            let param = fn.params[paramIdx]
            var seenTypeName = normalizeDeclaredTypeNode(param.paramType)
            var paramOwnership = ""
            if seenTypeName.startsWith("move:") {
                paramOwnership = "move"
                seenTypeName = seenTypeName.substring(5, seenTypeName.length())
            }
            if seenTypeName.startsWith("borrow:") {
                paramOwnership = "borrow"
                seenTypeName = seenTypeName.substring(7, seenTypeName.length())
            }
            if seenTypeName.contains("~default~") {
                let allocDefPos = seenTypeName.indexOf("~default~", 0)
                seenTypeName = seenTypeName.substring(0, allocDefPos)
            }
            let semanticSeenTypeName = normalizeSeenTypeName(seenTypeName)
            if isDataType(semanticSeenTypeName) {
                storeVar(param.name, "%" + quoteIdentIfNeeded(param.name + ".arg"), semanticSeenTypeName)
            } else {
                let paramType = mapStorageTypeForParameter(seenTypeName)
                let reg = getNextReg()
                output.append("  " + reg + " = alloca " + paramType + "\n")
                output.append("  store " + paramType + " %" + quoteIdentIfNeeded(param.name + ".arg") + ", ptr " + reg + "\n")
                storeVar(param.name, reg, semanticSeenTypeName)
            }
            if paramOwnership == "borrow" {
                let currentRegion = getNextReg()
                output.append("  " + currentRegion + " = call ptr @__seen_region_current()\n")
                let handleReg = getNextReg()
                output.append("  " + handleReg + " = call i64 @__seen_region_alloc_handle(ptr " + currentRegion + ", ptr %" + quoteIdentIfNeeded(param.name + ".arg") + ")\n")
                output.append("  ; borrow handle for " + param.name + " = " + handleReg + "\n")
            }
            paramIdx = paramIdx + 1
        }
    }

    fun generateFunction(fn: FunctionNode) r: Void {
        if shouldSkipFunctionByCfg(fn) {
            return
        }

        emitFunctionDecoratorMetadataComments(fn)

        if tryHandleIntrinsicFunctionGeneration(fn) {
            return
        }

        registerFunctionTraitImplDecorators(fn)

        if tryHandleGpuShaderFunctionGeneration(fn) {
            return
        }

        if shouldSkipSpecialFunctionBody(fn) {
            return
        }

        if tryHandleExternFunctionGeneration(fn) {
            return
        }

        let implFuncName = resolveImplementationFunctionName(fn)

        // Check if this function was already emitted in this module (duplicate detection)
        var alreadyGenerated = false
        var gi = 0
        while gi < generatedFunctions.length() {
            if generatedFunctions[gi] == implFuncName {
                alreadyGenerated = true
                gi = generatedFunctions.length()  // break
            }
            gi = gi + 1
        }
        if alreadyGenerated {
            return
        }
        // Skip user stubs that redefine runtime builtins (e.g. fun println(...) {})
        // The runtime already provides these — user stubs shadow them with no-ops
        if fn.body.statements.length() == 0 and implFuncName != "main" {
            if implFuncName == "println" or implFuncName == "print" or implFuncName == "eprintln" {
                output.append("; skipped user stub for runtime builtin: " + implFuncName + "\n")
                return
            }
        }
        generatedFunctions.push(implFuncName)

        // Register this function's return type for later call site inference
        // (may already be registered from registerDeclarations, but that's OK)
        let resolvedFunctionReturnType = resolveFunctionReturnType(fn)
        registerFunction(implFuncName, resolvedFunctionReturnType)

        resetFunctionGenerationState(resolvedFunctionReturnType)
        preRegisterFunctionParameters(fn, implFuncName)

        // Clear CSE cache at function boundaries
        cseClear()

        // Collect all variable declarations for hoisting allocas to entry block
        println("[irgen function] collect vars start: " + implFuncName)
        collectVariableDeclarations(fn.body)
        println("[irgen function] collect vars done: " + implFuncName)

        // Clear pre-registered parameters (will be re-added with proper registers)
        varNames = Array<String>()
        varRegs = Array<String>()
        varTypes = Array<String>()
        activeVarCount = 0

        let fnTypeName = currentFunctionReturnType
        println("[irgen function] return-type map start: " + implFuncName)
        let returnType = mapType(fnTypeName)
        let fnName = implFuncName
        println("[irgen function] return-type map done: " + fnName)

        if tryEmitMainFunction(fn, fnName, returnType) {
            return
        }

        // Build function attributes
        println("[irgen function] attrs start: " + fnName)
        var funcAttrs = ""
        if fn.isInline {
            funcAttrs = " alwaysinline"
        }
        if hasDecorator(fn, "noinline") {
            funcAttrs = " noinline"
        }
        if hasDecorator(fn, "cold") {
            funcAttrs = funcAttrs + " cold"
        }
        if hasDecorator(fn, "always_inline") {
            funcAttrs = " alwaysinline"
        }
        if hasDecorator(fn, "hot") {
            funcAttrs = funcAttrs + " hot"
        }
        if hasDecorator(fn, "pure") {
            funcAttrs = funcAttrs + " readonly nounwind"
        }
        if hasDecorator(fn, "likely") {
            funcAttrs = funcAttrs + " hot"
        }
        if hasDecorator(fn, "unlikely") {
            funcAttrs = funcAttrs + " cold"
        }
        // @init: register as module initializer for @llvm.global_ctors
        if hasDecorator(fn, "init") {
            g_initFuncNames = g_initFuncNames + fn.name + "|"
            g_initFuncCount = g_initFuncCount + 1
        }
        // : @trusted — suppress bounds/overflow checks inside this function
        if hasDecorator(fn, "trusted") {
            g_trustedFuncNames = g_trustedFuncNames + fn.name + "|"
            output.append("; @trusted function: " + fn.name + "\n")
        }
        // P2 : Sanitizer function attributes
        if g_sanitizerMode != "" {
            if g_sanitizerMode == "address" {
                funcAttrs = funcAttrs + " sanitize_address"
            }
            if g_sanitizerMode == "thread" {
                funcAttrs = funcAttrs + " sanitize_thread"
            }
            if g_sanitizerMode == "memory" {
                funcAttrs = funcAttrs + " sanitize_memory"
            }
        }
        // P2 : Generic specialization — @specialize(T=Int) etc.
        if hasDecorator(fn, "specialize") {
            var specIdx = 0
            while specIdx < fn.decorators.length() {
                if fn.decorators[specIdx].name == "specialize" {
                    if fn.decorators[specIdx].arguments.length() > 0 {
                        var specArg = fn.decorators[specIdx].arguments[0]
                        g_specializationNames = g_specializationNames + fn.name + ":" + specArg + "|"
                        g_specializationCount = g_specializationCount + 1
                        output.append("; @specialize: " + fn.name + " with " + specArg + "\n")
                    }
                }
                specIdx = specIdx + 1
            }
        }
        if fn.isAsync {
            funcAttrs = funcAttrs + " presplitcoroutine"
        }
        println("[irgen function] attrs done: " + fnName)

        // ML-guided inline decision
        println("[irgen function] inline-analysis start: " + fnName)
        if not fn.isInline and not hasDecorator(fn, "noinline") {
            let bodySize = fn.body.statements.length()
            // Check for replay first
            let replayInline = mlReplayLookup("inline", fnName)
            if replayInline == "yes" {
                funcAttrs = funcAttrs + " alwaysinline"
                mlLogDecision("inline", "yes", fnName + ":replay")
            }
            if replayInline == "" {
                // Use mlShouldInline with call count from string-constants pre-pass
                let fnCallCount = callCountLookup(fnName)
                // Compute extra features for weighted model
                var hasLoopsFlag = 0
                var loopScanIdx = 0
                while loopScanIdx < fn.body.statements.length() {
                    let loopScanStmt = fn.body.statements[loopScanIdx]
                    if loopScanStmt.kind == "While" or loopScanStmt.kind == "ForIn" {
                        hasLoopsFlag = 1
                    }
                    loopScanIdx = loopScanIdx + 1
                }
                let nestDepth = fn.params.length()
                // Log features for ML training data
                mlLogFeatures("inline", fnName, bodySize, fnCallCount, hasLoopsFlag, nestDepth, 0)
                let inlineDecision = mlShouldInlineWeighted(bodySize, fnCallCount, hasLoopsFlag, nestDepth)
                if inlineDecision == "always" {
                    funcAttrs = funcAttrs + " alwaysinline"
                    mlLogDecision("inline", "yes", fnName + ":sz=" + bodySize.toString())
                }
                if inlineDecision == "hint" {
                    funcAttrs = funcAttrs + " inlinehint"
                    mlLogDecision("inline", "hint", fnName + ":sz=" + bodySize.toString())
                }
                if inlineDecision == "noinline" {
                    funcAttrs = funcAttrs + " noinline"
                    mlLogDecision("inline", "no", fnName + ":sz=" + bodySize.toString())
                }
            }
        }
        println("[irgen function] inline-analysis done: " + fnName)

        // norecurse / noinline for recursive functions
        println("[irgen function] recursion flags start: " + fnName)
        let isSelfRecursive = selfCallCheck(fnName, g_selfCallFuncs, g_selfCallNames, g_selfCallCount)
        if isSelfRecursive {
            // Prevent catastrophic code explosion from inlining recursive calls
            funcAttrs = funcAttrs.replace(" alwaysinline", "")
            funcAttrs = funcAttrs.replace(" inlinehint", "")
            funcAttrs = funcAttrs + " noinline"
        }
        if not isSelfRecursive {
            funcAttrs = funcAttrs + " norecurse"
        }
        println("[irgen function] recursion flags done: " + fnName)

        // ML register pressure estimation (9.7): count unique variables
        println("[irgen function] reg-pressure start: " + fnName)
        var regPressureCount = fn.params.length()
        var rpIdx = 0
        while rpIdx < fn.body.statements.length() {
            let rpStmt = fn.body.statements[rpIdx]
            if rpStmt.kind == "Let" or rpStmt.kind == "Var" {
                regPressureCount = regPressureCount + 1
            }
            rpIdx = rpIdx + 1
        }
        if regPressureCount > 14 {
            output.append("; register pressure high: " + regPressureCount.toString() + " vars — capping unroll/vectorize\n")
            g_currentFunctionHighPressure = true
            getCurrentFunctionOptions().highPressure = true
            mlLogDecision("reg-pressure", "high", fnName + ":" + regPressureCount.toString())
        }
        println("[irgen function] reg-pressure done: " + fnName)

        // Function signature
        // Add noundef on primitive return types for stronger optimization
        var fnRetPrefix = "define "
        if returnType == "i64" or returnType == "double" or returnType == "i1" {
            fnRetPrefix = "define noundef "
        }
        // Async functions return ptr (coroutine handle) instead of declared type
        var actualLlvmReturnType = returnType
        if fn.isAsync {
            actualLlvmReturnType = "ptr"
            fnRetPrefix = "define "
        }
        if hasDecorator(fn, "init") and fn.name == "__seen_internal_module_init__" {
            fnRetPrefix = "define internal "
        }
        // @export("C"): add dso_local for C-compatible export
        if hasDecorator(fn, "export") {
            fnRetPrefix = fnRetPrefix + "dso_local "
        }
        println("[irgen function] signature start: " + fnName)
        let quotedFnName = quoteIdentIfNeeded(fnName)
        let signaturePrefix = fnRetPrefix + actualLlvmReturnType + " @" + quotedFnName + "("

        // Parameters
        var paramDecls = Array<String>()
        var paramIdx = 0
        while paramIdx < fn.params.length() {
            let param = fn.params[paramIdx]
            var sigTypeName = normalizeDeclaredTypeNode(param.paramType)
            // Strip ownership qualifiers for IR type
            if sigTypeName.startsWith("move:") {
                sigTypeName = sigTypeName.substring(5, sigTypeName.length())
            }
            if sigTypeName.startsWith("borrow:") {
                sigTypeName = sigTypeName.substring(7, sigTypeName.length())
            }
            // Strip default value suffix for IR type
            if sigTypeName.contains("~default~") {
                let sigDefPos = sigTypeName.indexOf("~default~", 0)
                sigTypeName = sigTypeName.substring(0, sigDefPos)
            }
            let paramType = mapTypeForParameter(sigTypeName)
            // @no_alias decorator: add noalias on pointer params
            var paramAttr = ""
            if paramType == "ptr" and hasDecorator(fn, "no_alias") {
                paramAttr = "noalias "
            }
            paramDecls.push(paramAttr + paramType + " %" + quoteIdentIfNeeded(param.name + ".arg"))
            paramIdx = paramIdx + 1
        }

        emitFunctionSignatureImpl(output, signaturePrefix, paramDecls, funcAttrs)
        println("[irgen function] signature done: " + fnName)

        // Coroutine preamble for async functions
        if fn.isAsync {
            let promiseType = mapType(currentFunctionReturnType)
            let promiseBox = Array<String>()
            let coroIdBox = Array<String>()
            let coroHdlBox = Array<String>()
            let finalLabelBox = Array<String>()
            let cleanupLabelBox = Array<String>()
            emitAsyncCoroutinePreambleImpl(output, g_regBox, g_blockBox, promiseType, promiseBox, coroIdBox, coroHdlBox, finalLabelBox, cleanupLabelBox)
            g_asyncFunctionPromise = promiseBox[0]
            g_asyncFunctionCoroId = coroIdBox[0]
            g_asyncFunctionCoroHdl = coroHdlBox[0]
            g_asyncFinalLabel = finalLabelBox[0]
            g_asyncCleanupLabel = cleanupLabelBox[0]
        }

        emitFunctionParameterAllocas(fn)
        println("[irgen function] params done: " + fnName)

        // Emit allocas for all local variables at entry (avoids domination errors)
        emitPreAllocatedAllocas()
        println("[irgen function] allocas done: " + fnName)

        // Clear CSE cache at function boundary (safe to re-enable within function scope)
        cseClear()

        // Dead argument detection (9.10e): warn about unused parameters
        println("[irgen function] dead-arg scan start: " + fnName)
        let unusedParams = scanUnusedParametersImpl(fn)
        var unusedIdx = 0
        while unusedIdx < unusedParams.length() {
            output.append("  ; WARNING: unused parameter: " + unusedParams[unusedIdx] + " in " + fnName + "\n")
            mlLogDecision("dead-arg", "unused", unusedParams[unusedIdx] + ":" + fnName)
            unusedIdx = unusedIdx + 1
        }
        println("[irgen function] dead-arg scan done: " + fnName)

        // Check for @profile decorator and emit profile_enter
        g_currentFunctionIsProfiled = hasDecorator(fn, "profile")
        g_currentFunctionNameForProfile = fnName
        if g_currentFunctionIsProfiled {
            // Get string constant index for function name
            let strIdx = addStringConstant(fnName)
            output.append("  ; @profile instrumentation - enter\n")
            output.append("  call void @__seen_profile_enter(ptr @.str." + strIdx.toString() + ")\n")
        }

        configureFunctionLoweringOptions(fn)

        // Emit prefetch intrinsic calls for pointer parameters
        if currentFunctionPrefetchMode() > 0 {
            var prefetchRW = "0"
            if currentFunctionPrefetchMode() == 2 {
                prefetchRW = "1"
            }
            var prefetchModeStr = "read"
            if currentFunctionPrefetchMode() == 2 {
                prefetchModeStr = "write"
            }
            output.append("  ; @prefetch(" + prefetchModeStr + ") instrumentation\n")
            var pi = 0
            while pi < fn.params.length() {
                let param = fn.params[pi]
                let paramTypeName = param.paramType.typeName
                if paramTypeName == "Array<Int>" or paramTypeName == "Array<Float>" or contains(paramTypeName, "Array") {
                    let allocaName = "%" + quoteIdentIfNeeded(param.name)
                    let ptrReg = getNextReg()
                    output.append("  " + ptrReg + " = load ptr, ptr " + allocaName + "\n")
                    output.append("  call void @llvm.prefetch.p0(ptr " + ptrReg + ", i32 " + prefetchRW + ", i32 3, i32 1)\n")
                }
                pi = pi + 1
            }
        }

        if currentFunctionRegionSizeBytes() > 0 {
            output.append("  ; @preallocate region allocator - create\n")
            let regionReg = getNextReg()
            output.append("  " + regionReg + " = call ptr @__seen_region_create(i64 " + currentFunctionRegionSizeBytes().toString() + ", i32 1)\n")
            output.append("  %__region_ptr = alloca ptr\n")
            output.append("  store ptr " + regionReg + ", ptr %__region_ptr\n")
        }

        // Generate function body
        generateBlock(fn.body)

        // If no terminator was generated, add a default return
        if not blockTerminated {
            // Emit region destroy before default return if using @preallocate
            if currentFunctionRegionSizeBytes() > 0 {
                let regionDefReg = getNextReg()
                output.append("  " + regionDefReg + " = load ptr, ptr %__region_ptr\n")
                output.append("  call void @__seen_region_destroy(ptr " + regionDefReg + ") ; @preallocate cleanup\n")
            }
            // Emit profile_exit before default return if profiled
            if g_currentFunctionIsProfiled {
                let strIdx = getStringConstantIndex(g_currentFunctionNameForProfile)
                output.append("  ; @profile instrumentation - exit (default return)\n")
                output.append("  call void @__seen_profile_exit(ptr @.str." + strIdx.toString() + ")\n")
            }

            // For async functions, store default return value in promise and branch to final suspend
            if isCurrentFunctionAsyncLowering() {
                let promiseType = mapType(currentFunctionReturnType)
                if promiseType != "void" {
                    output.append("  store " + promiseType + " zeroinitializer, ptr " + g_asyncFunctionPromise + "\n")
                }
                output.append("  br label %" + g_asyncFinalLabel + "\n")
            }

            if not fn.isAsync {
                emitDefaultReturnValueImpl(output, returnType)
            }
        }

        // Emit coroutine final suspend and cleanup blocks for async functions
        if fn.isAsync {
            emitAsyncCoroutineEpilogueImpl(output, g_regBox, g_blockBox, g_asyncFunctionCoroId, g_asyncFunctionCoroHdl, g_asyncFinalLabel, g_asyncCleanupLabel)
        }

        // Reset profiling state (module-level vars - writes are no-ops but kept for clarity)
        g_currentFunctionIsProfiled = false
        g_currentFunctionNameForProfile = ""
        g_currentFunctionHighPressure = false
        // Reset async coroutine state
        g_asyncFunctionCoroId = ""
        g_asyncFunctionCoroHdl = ""
        g_asyncFunctionPromise = ""
        g_asyncFinalLabel = ""
        g_asyncCleanupLabel = ""
        clearTransientFunctionLoweringState()

        output.append("}\n\n")
    }

    // Generate IR for a block of statements. Manages the defer stack depth
    // (saves on entry, emits deferred expressions in LIFO order on exit).
    // Performs dead store elimination: scans for "var x = literal; x = expr"
    // patterns where x is not read between the two stores, and skips the
    // first literal initialization.
    fun isReadModifyWriteDeadStore(varName: String, rhsExpr: ParserExpressionNode) r: Bool {
        if rhsExpr.kind == "Variable" or rhsExpr.kind == "VarExpr" {
            var rhsName = rhsExpr.literalValue
            if rhsName == "" {
                rhsName = rhsExpr.variableName
            }
            return rhsName == varName
        }
        if rhsExpr.kind == "Binary" and rhsExpr.operands.length() > 0 {
            let lhsOp = rhsExpr.operands[0]
            var lhsName = lhsOp.literalValue
            if lhsName == "" {
                lhsName = lhsOp.variableName
            }
            return lhsName == varName
        }
        return false
    }

    fun tryMarkDeadStoreElimination(stmt: StatementNode, nextStmt: StatementNode) r: Void {
        if (stmt.kind != "Let" and stmt.kind != "Var") or nextStmt.kind != "Expression" {
            return
        }
        if nextStmt.expression.kind != "Assignment" or nextStmt.expression.variableName != stmt.variableName {
            return
        }

        var isReadModWrite = false
        if nextStmt.expression.operands.length() > 0 {
            isReadModWrite = isReadModifyWriteDeadStore(stmt.variableName, nextStmt.expression.operands[0])
        }
        if isReadModWrite {
            return
        }

        g_deadStoresEliminated = g_deadStoresEliminated + 1
        if stmt.initializer.kind == "Literal" {
            output.append("  ; dead store eliminated: " + stmt.variableName + " literal init skipped\n")
            if g_deadStoreSkipVars == "" {
                g_deadStoreSkipVars = stmt.variableName
            } else {
                g_deadStoreSkipVars = g_deadStoreSkipVars + "|" + stmt.variableName
            }
            mlLogDecision("dead-store", "skip-init", stmt.variableName)
            return
        }

        output.append("  ; dead store: " + stmt.variableName + " initialized then immediately overwritten\n")
        mlLogDecision("dead-store", "detected", stmt.variableName)
    }

    fun scanBlockDeadStorePatterns(block: BlockNode) r: Void {
        var dsIdx = 0
        while dsIdx < block.statements.length() - 1 {
            tryMarkDeadStoreElimination(block.statements[dsIdx], block.statements[dsIdx + 1])
            dsIdx = dsIdx + 1
        }
    }

    fun emitTrailingDeadCodeNotice(block: BlockNode, startIndex: Int) r: Void {
        let remaining = block.statements.length() - startIndex
        if remaining > 0 {
            g_deadStatementsEliminated = g_deadStatementsEliminated + remaining
            output.append("  ; dead code eliminated: " + remaining.toString() + " statements\n")
        }
    }

    fun emitBlockDeferredCleanup(savedDeferCount: Int) r: Void {
        if g_deferCount > savedDeferCount and not blockTerminated {
            output.append("  ; defer cleanup (LIFO)\n")
            var dIdx = g_deferCount - 1
            while dIdx >= savedDeferCount {
                generateExpression(g_deferExprs[dIdx])
                dIdx = dIdx - 1
            }
        }
    }

    fun generateBlock(block: BlockNode) r: Void {
        // Save defer stack depth for this block scope
        let savedDeferCount = g_deferCount
        // Dead store elimination (9.10b): scan for var x = literal; x = expr2 with no read of x
        // Only skip literal initializers (Int, Float, Bool, String) to preserve side effects
        let savedDeadStoreSkip = g_deadStoreSkipVars
        let savedActiveVarCount = activeVarCount

        scanBlockDeadStorePatterns(block)

        var i = 0
        while i < block.statements.length() {
            if blockTerminated {
                emitTrailingDeadCodeNotice(block, i)
                break
            }
            generateStatement(block.statements[i])
            i = i + 1
        }

        emitBlockDeferredCleanup(savedDeferCount)

        // Restore defer stack to saved depth
        g_deferCount = savedDeferCount
        // Restore dead store skip list (scoped to this block)
        g_deadStoreSkipVars = savedDeadStoreSkip
        activeVarCount = savedActiveVarCount
    }

    fun tryGenerateAssignmentLikeExpression(expr: ParserExpressionNode) r: Bool {
        if expr.kind == "Assignment" {
            generateAssignmentExpr(expr)
            return true
        }
        if expr.kind == "MemberAssignment" {
            generateMemberAssignment(expr)
            return true
        }
        if expr.kind == "IndexAssignment" {
            generateIndexAssignment(expr)
            return true
        }
        return false
    }

    fun warnUnusedResultCall(expr: ParserExpressionNode) r: Void {
        if g_warnUnusedResult != 1 or expr.kind != "Call" {
            return
        }
        let unusedCallName = expr.callee
        let unusedRetType = getFunctionReturnType(unusedCallName)
        if not unusedRetType.startsWith("Result<") and not unusedRetType.startsWith("Result ") {
            return
        }
        if g_tryCatchLabel == "" {
            output.append("; WARNING: unused Result from call to " + unusedCallName + "\n")
            println("[WARNING] unused error result from '" + unusedCallName + "'")
        }
    }

    fun generateExpressionStatement(stmt: StatementNode) r: Void {
        if tryGenerateAssignmentLikeExpression(stmt.expression) {
            return
        }
        warnUnusedResultCall(stmt.expression)
        generateExpression(stmt.expression)
    }

    fun emitContinueStatement() r: Void {
        if currentLoopCondLabel == "" {
            output.append("  ; ERROR: continue used outside of loop\n")
        }
        if currentLoopCondLabel != "" {
            let pipeIdx = currentLoopCondLabel.indexOf("|")
            if pipeIdx >= 0 {
                let actualLabel = currentLoopCondLabel.substring(0, pipeIdx)
                let metaIdStr = currentLoopCondLabel.substring(pipeIdx + 1, currentLoopCondLabel.length())
                output.append("  br label %" + actualLabel + ", !llvm.loop !" + metaIdStr + "\n")
            }
            if pipeIdx < 0 {
                output.append("  br label %" + currentLoopCondLabel + ", !llvm.loop !202\n")
            }
            blockTerminated = true
        }
    }

    fun emitBreakStatement() r: Void {
        if currentLoopEndLabel == "" {
            output.append("  ; ERROR: break used outside of loop\n")
        }
        if currentLoopEndLabel != "" {
            output.append("  br label %" + currentLoopEndLabel + "\n")
            blockTerminated = true
        }
    }

    fun generateDeferredStatement(stmt: StatementNode, isErrdefer: Bool) r: Void {
        if stmt.expression.kind != "" {
            if isErrdefer {
                g_errdeferExprs.push(stmt.expression)
                g_errdeferCount = g_errdeferCount + 1
            } else {
                g_deferExprs.push(stmt.expression)
                g_deferCount = g_deferCount + 1
            }
        }
    }

    fun generateInlineBlockStatement(stmt: StatementNode) r: Void {
        if stmt.thenBranch.statements.length() > 0 {
            generateBlock(stmt.thenBranch)
        }
    }

    fun generateUnsafeStatement(stmt: StatementNode) r: Void {
        output.append("  ; unsafe {\n")
        g_insideUnsafe = g_insideUnsafe + 1
        if stmt.thenBranch.statements.length() > 0 {
            generateBlock(stmt.thenBranch)
        }
        g_insideUnsafe = g_insideUnsafe - 1
        output.append("  ; } // end unsafe\n")
    }

    fun generateTryCatchStatement(stmt: StatementNode) r: Void {
        let tryCatchLabel = "catch." + g_blockBox[0].toString()
        g_blockBox[0] = g_blockBox[0] + 1
        let tryEndLabel = "try.end." + g_blockBox[0].toString()
        g_blockBox[0] = g_blockBox[0] + 1

        let savedTryCatchLabel = g_tryCatchLabel
        let savedTryCatchEndLabel = g_tryCatchEndLabel
        g_tryCatchLabel = tryCatchLabel
        g_tryCatchEndLabel = tryEndLabel

        output.append("  ; try {\n")
        if stmt.thenBranch.statements.length() > 0 {
            generateBlock(stmt.thenBranch)
        }
        if not blockTerminated {
            output.append("  br label %" + tryEndLabel + "\n")
        }
        blockTerminated = false

        output.append(tryCatchLabel + ":\n")
        output.append("  ; catch {\n")
        let savedCatchVarCount = activeVarCount
        if stmt.variableName != "" {
            let catchVarReg = getNextReg()
            storeVar(stmt.variableName, catchVarReg, "Int")
            output.append("  " + catchVarReg + " = add i64 0, 0 ; catch binding\n")
        }
        if stmt.elseBranch.statements.length() > 0 {
            generateBlock(stmt.elseBranch)
        }
        activeVarCount = savedCatchVarCount
        if not blockTerminated {
            output.append("  br label %" + tryEndLabel + "\n")
        }
        blockTerminated = false
        output.append(tryEndLabel + ":\n")
        output.append("  ; } // end try/catch\n")

        g_tryCatchLabel = savedTryCatchLabel
        g_tryCatchEndLabel = savedTryCatchEndLabel
    }

    fun tryGenerateBasicStatement(stmt: StatementNode) r: Bool {
        if stmt.kind == "Let" or stmt.kind == "Var" {
            generateLetStatement(stmt)
            return true
        }
        if stmt.kind == "Return" {
            generateReturnStatement(stmt)
            return true
        }
        if stmt.kind == "Expression" {
            generateExpressionStatement(stmt)
            return true
        }
        if stmt.kind == "If" {
            generateIfStatement(stmt)
            return true
        }
        if stmt.kind == "IfLet" {
            generateIfLetStatement(stmt)
            return true
        }
        if stmt.kind == "While" {
            generateWhileStatement(stmt)
            return true
        }
        if stmt.kind == "Assignment" {
            generateAssignment(stmt)
            return true
        }
        if stmt.kind == "ForIn" {
            generateForInStatement(stmt)
            return true
        }
        if stmt.kind == "Region" {
            generateRegionStatement(stmt)
            return true
        }
        return false
    }

    fun tryGenerateLoopControlStatement(stmt: StatementNode) r: Bool {
        if stmt.kind == "Continue" {
            emitContinueStatement()
            return true
        }
        if stmt.kind == "Break" {
            emitBreakStatement()
            return true
        }
        return false
    }

    fun tryGenerateScopedStatement(stmt: StatementNode) r: Bool {
        if stmt.kind == "Defer" {
            generateDeferredStatement(stmt, false)
            return true
        }
        if stmt.kind == "Errdefer" {
            generateDeferredStatement(stmt, true)
            return true
        }
        if stmt.kind == "Block" {
            generateInlineBlockStatement(stmt)
            return true
        }
        if stmt.kind == "Unsafe" {
            generateUnsafeStatement(stmt)
            return true
        }
        if stmt.kind == "TryCatch" {
            generateTryCatchStatement(stmt)
            return true
        }
        return false
    }

    fun tryGenerateMetaStatement(stmt: StatementNode) r: Bool {
        if stmt.kind == "ParallelFor" {
            generateParallelForStatement(stmt)
            return true
        }
        if stmt.kind == "ComptimeBlock" {
            generateComptimeBlock(stmt)
            return true
        }
        if stmt.kind == "ComptimeAssert" {
            generateComptimeAssert(stmt)
            return true
        }
        if stmt.kind == "ComptimeIf" {
            generateComptimeIf(stmt)
            return true
        }
        return false
    }

    // Top-level statement dispatch. Routes each statement kind to its
    // specialized generator: Let/Var, Return, If, IfLet, While, ForIn,
    // Match, Expression (which may be Assignment, MemberAssignment,
    // IndexAssignment, or a general expression), Defer, Errdefer,
    // TryCatch, UnsafeBlock, Region, ComptimeIf/Block, ParallelFor.
    // Uses flag-based dispatch (not early returns) for stage1 compatibility.
    fun generateStatement(stmt: StatementNode) r: Void {
        var handled = false
        if not handled {
            handled = tryGenerateBasicStatement(stmt)
        }
        if not handled {
            handled = tryGenerateLoopControlStatement(stmt)
        }
        if not handled {
            handled = tryGenerateScopedStatement(stmt)
        }
        if not handled {
            handled = tryGenerateMetaStatement(stmt)
        }
    }

    fun generateRegionStatement(stmt: StatementNode) r: Void {
        // region [strategy] [name] { body }
        // Strategy: 0=auto, 1=bump, 2=stack, 3=cxl_near, 4=cxl_far, 5=gpu
        var strategyInt = "0"
        let strategy = normalizeDeclaredTypeNode(stmt.variableType)
        if strategy == "bump" { strategyInt = "1" }
        if strategy == "stack" { strategyInt = "2" }
        if strategy == "cxl_near" { strategyInt = "3" }
        if strategy == "cxl_far" { strategyInt = "4" }
        if strategy == "gpu" { strategyInt = "5" }
        let regionName = stmt.variableName
        output.append("  ; region block")
        if strategy != "" { output.append(" strategy=" + strategy) }
        if regionName != "" { output.append(" name=" + regionName) }
        output.append("\n")
        // Create region (64KB default)
        let regionReg = getNextReg()
        output.append("  " + regionReg + " = call ptr @__seen_region_create(i64 65536, i32 " + strategyInt + ")\n")
        // Push region onto stack
        output.append("  call void @__seen_region_push(ptr " + regionReg + ")\n")
        // Store region ptr for cleanup
        let regionSlot = getNextReg()
        output.append("  " + regionSlot + " = alloca ptr\n")
        output.append("  store ptr " + regionReg + ", ptr " + regionSlot + "\n")
        // Generate body
        generateBlock(stmt.thenBranch)
        // Pop and destroy region
        let popReg = getNextReg()
        output.append("  " + popReg + " = call ptr @__seen_region_pop()\n")
        let loadReg = getNextReg()
        output.append("  " + loadReg + " = load ptr, ptr " + regionSlot + "\n")
        output.append("  call void @__seen_region_destroy(ptr " + loadReg + ")\n")
    }

    // : Map C type string to LLVM IR type
    fun mapCTypeToLlvm(cType: String) r: String {
        let ct = cType.trim()
        if ct == "void" { return "void" }
        if ct == "int" or ct == "int32_t" or ct == "signed int" { return "i32" }
        if ct == "long" or ct == "int64_t" or ct == "long long" { return "i64" }
        if ct == "short" or ct == "int16_t" { return "i16" }
        if ct == "unsigned int" or ct == "uint32_t" { return "i32" }
        if ct == "unsigned long" or ct == "uint64_t" or ct == "size_t" { return "i64" }
        if ct == "char" or ct == "signed char" or ct == "unsigned char" { return "i8" }
        if ct == "bool" or ct == "_Bool" { return "i1" }
        if ct == "float" { return "float" }
        if ct == "double" { return "double" }
        if ct.endsWith("*") or ct.contains("*") { return "ptr" }
        return "i64"
    }

    // : Generate variadic generic expansion (arities 1-8)
    fun generateVariadicGenericExpansion(funcNode: FunctionNode) r: Void {
        // Extract pack name from @variadic_generic decorator
        var packName = "Ts"
        var vgDecIdx = 0
        while vgDecIdx < funcNode.decorators.length() {
            if funcNode.decorators[vgDecIdx].name == "variadic_generic" {
                if funcNode.decorators[vgDecIdx].arguments.length() > 0 {
                    packName = funcNode.decorators[vgDecIdx].arguments[0]
                }
            }
            vgDecIdx = vgDecIdx + 1
        }
        g_variadicGenericNames = g_variadicGenericNames + funcNode.name + "|"
        g_variadicGenericCount = g_variadicGenericCount + 1
        output.append("; : variadic generic expansion for " + funcNode.name + "<..." + packName + ">\n")
        // Generate arity-specific overloads (1 through 8)
        var arity = 1
        while arity <= 8 {
            let mangledName = funcNode.name + "_" + arity.toString()
            // Emit a stub function that takes arity i64 params and returns i64
            var paramList = ""
            var pi = 0
            while pi < arity {
                if pi > 0 { paramList = paramList + ", " }
                paramList = paramList + "i64 %t" + pi.toString()
                pi = pi + 1
            }
            output.append("define i64 @" + quoteIdentIfNeeded(mangledName) + "(" + paramList + ") nounwind {\n")
            output.append("entry:\n")
            // Allocate and store params into a tuple struct
            let tupleType = "%SeenTuple" + arity.toString()
            let tupleReg = "%tuple"
            output.append("  " + tupleReg + " = alloca " + tupleType + "\n")
            var si = 0
            while si < arity {
                let gepReg = "%gep" + si.toString()
                output.append("  " + gepReg + " = getelementptr " + tupleType + ", ptr " + tupleReg + ", i32 0, i32 " + si.toString() + "\n")
                output.append("  store i64 %t" + si.toString() + ", ptr " + gepReg + "\n")
                si = si + 1
            }
            // Return pointer to tuple as i64
            let retReg = "%ret"
            output.append("  " + retReg + " = ptrtoint ptr " + tupleReg + " to i64\n")
            output.append("  ret i64 " + retReg + "\n")
            output.append("}\n\n")
            arity = arity + 1
        }
    }

    // parallel_for i in start..end { body } → extract closure, call seen_parallel_for
    fun generateParallelForStatement(stmt: StatementNode) r: Void {
        // The expression should be a range: start..end (parsed as Binary with operator "..")
        let rangeExpr = stmt.expression
        var startReg = ""
        var endReg = ""
        if rangeExpr.kind == "Binary" and rangeExpr.operator == ".." {
            startReg = generateExpression(rangeExpr.operands[0])
            endReg = generateExpression(rangeExpr.operands[1])
        } else {
            // Fallback: treat expression as end, start = 0
            startReg = "0"
            endReg = generateExpression(rangeExpr)
        }

        // Generate the loop body as an anonymous function
        let pforIdx = g_pforCount
        g_pforCount = g_pforCount + 1
        let bodyFuncName = "@__seen_pfor_body_" + pforIdx.toString()

        // Save current state
        let savedOutput = output
        let savedVarNames = varNames
        let savedVarRegs = varRegs
        let savedVarTypes = varTypes
        let savedPreAllocatedVars = preAllocatedVars
        let savedPreAllocatedTypes = preAllocatedTypes
        let savedPreAllocatedRegs = preAllocatedRegs
        let savedDeclOrdinalNames = declOrdinalNames
        let savedDeclOrdinalCounts = declOrdinalCounts
        let savedActiveVarCount = activeVarCount
        let savedNextReg = g_regBox[0]
        let savedBlockTerm = blockTerminated

        // Generate body function in a new buffer
        output = StringBuilder.new()
        varNames = Array<String>()
        varRegs = Array<String>()
        varTypes = Array<String>()
        preAllocatedVars = Array<String>()
        preAllocatedTypes = Array<String>()
        preAllocatedRegs = Array<String>()
        declOrdinalNames = Array<String>()
        declOrdinalCounts = Array<Int>()
        activeVarCount = 0
        g_regBox[0] = 1
        blockTerminated = false

        output.append("define i64 " + bodyFuncName + "(i64 %0) nounwind {\n")
        output.append("entry:\n")
        // Bind loop variable to %0
        storeVar(stmt.variableName, "%0", "Int")
        // Generate body block
        generateBlock(stmt.loopBody)
        if not blockTerminated {
            output.append("  ret i64 0\n")
        }
        output.append("}\n\n")

        // Store generated body function in closures list
        let bodyFuncIR = output.toString()
        g_closureDefs = g_closureDefs + bodyFuncIR

        // Restore state
        output = savedOutput
        varNames = savedVarNames
        varRegs = savedVarRegs
        varTypes = savedVarTypes
        preAllocatedVars = savedPreAllocatedVars
        preAllocatedTypes = savedPreAllocatedTypes
        preAllocatedRegs = savedPreAllocatedRegs
        declOrdinalNames = savedDeclOrdinalNames
        declOrdinalCounts = savedDeclOrdinalCounts
        activeVarCount = savedActiveVarCount
        g_regBox[0] = savedNextReg
        blockTerminated = savedBlockTerm

        // Emit call to seen_parallel_for(start, end, body_fn_ptr, nthreads=0 for auto)
        output.append("  ; parallel_for " + stmt.variableName + "\n")
        output.append("  call void @seen_parallel_for(i64 " + startReg + ", i64 " + endReg + ", ptr " + bodyFuncName + ", i64 0)\n")
    }

    // comptime { block } — evaluate let bindings at compile time, store in comptime registry
    fun generateComptimeBlock(stmt: StatementNode) r: Void {
        output.append("  ; comptime block\n")
        processComptimeStatements(stmt.thenBranch)
    }

    // Process comptime block statements, supporting Let/Var, Assignment, While
    fun processComptimeStatements(block: BlockNode) r: Void {
        var ctIdx = 0
        while ctIdx < block.statements.length() {
            let ctStmt = block.statements[ctIdx]
            if ctStmt.kind == "Let" or ctStmt.kind == "Var" {
                // Try integer evaluation first
                let ctVal = evaluateConstExpr(ctStmt.initializer)
                if ctVal != -9999999 {
                    registerComptimeVar(ctStmt.variableName, ctVal)
                    output.append("  ; comptime let " + ctStmt.variableName + " = " + ctVal.toString() + "\n")
                } else {
                    // Try string evaluation
                    let ctStrVal = evaluateConstExprStr(ctStmt.initializer)
                    if ctStrVal != "__EVAL_FAIL__" {
                        registerComptimeStrVar(ctStmt.variableName, ctStrVal)
                        output.append("  ; comptime let " + ctStmt.variableName + " = \"" + ctStrVal + "\"\n")
                    }
                }
            }
            // comptime Assignment — update existing comptime variable
            if ctStmt.kind == "Assignment" or ctStmt.kind == "Expression" {
                if ctStmt.expression.kind == "Assignment" {
                    let ctAssignName = ctStmt.expression.variableName
                    if ctAssignName == "" {
                        let ctAssignName2 = ctStmt.expression.literalValue
                        if ctAssignName2 != "" {
                            let ctNewVal = evaluateConstExpr(ctStmt.expression.operands[0])
                            if ctNewVal != -9999999 {
                                updateComptimeVar(ctAssignName2, ctNewVal)
                                output.append("  ; comptime " + ctAssignName2 + " = " + ctNewVal.toString() + "\n")
                            }
                        }
                    } else {
                        let ctNewVal = evaluateConstExpr(ctStmt.expression.operands[0])
                        if ctNewVal != -9999999 {
                            updateComptimeVar(ctAssignName, ctNewVal)
                            output.append("  ; comptime " + ctAssignName + " = " + ctNewVal.toString() + "\n")
                        }
                    }
                }
            }
            // comptime While — unroll loop at compile time
            if ctStmt.kind == "While" {
                var ctWhileIter = 0
                while ctWhileIter < 1000 {
                    let ctWhileCond = evaluateConstExpr(ctStmt.expression)
                    if ctWhileCond == 0 or ctWhileCond == -9999999 { break }
                    // Process body: comptime statements update vars, runtime statements get emitted
                    processComptimeStatements(ctStmt.thenBranch)
                    ctWhileIter = ctWhileIter + 1
                }
                output.append("  ; comptime while unrolled " + ctWhileIter.toString() + " iterations\n")
            }
            // Other statement kinds: emit as runtime code (code generation use case)
            if ctStmt.kind != "Let" and ctStmt.kind != "Var" and ctStmt.kind != "Assignment" and ctStmt.kind != "Expression" and ctStmt.kind != "While" {
                generateStatement(ctStmt)
            }
            ctIdx = ctIdx + 1
        }
    }

    // Register a new comptime integer variable
    fun registerComptimeVar(name: String, value: Int) r: Void {
        // Check if already exists — update instead
        let existingVal = lookupComptimeVar(name)
        if existingVal != -9999999 {
            updateComptimeVar(name, value)
            return
        }
        if g_comptimeCount > 0 {
            g_comptimeNames = g_comptimeNames + "|"
            g_comptimeValues = g_comptimeValues + "|"
        }
        g_comptimeNames = g_comptimeNames + name
        g_comptimeValues = g_comptimeValues + value.toString()
        g_comptimeCount = g_comptimeCount + 1
    }

    // Update an existing comptime integer variable
    fun updateComptimeVar(name: String, value: Int) r: Void {
        if g_comptimeCount == 0 { return }
        // Rebuild the values string with updated value
        var newValues = ""
        var searchPos = 0
        var valPos = 0
        var idx = 0
        while idx < g_comptimeCount {
            var curName = ""
            var nextPipe = g_comptimeNames.indexOf("|", searchPos)
            if nextPipe < 0 {
                curName = g_comptimeNames.substring(searchPos, g_comptimeNames.length())
            } else {
                curName = g_comptimeNames.substring(searchPos, nextPipe)
                searchPos = nextPipe + 1
            }
            var curVal = ""
            var nextValPipe = g_comptimeValues.indexOf("|", valPos)
            if nextValPipe < 0 {
                curVal = g_comptimeValues.substring(valPos, g_comptimeValues.length())
            } else {
                curVal = g_comptimeValues.substring(valPos, nextValPipe)
                valPos = nextValPipe + 1
            }
            if idx > 0 { newValues = newValues + "|" }
            if curName == name {
                newValues = newValues + value.toString()
            } else {
                newValues = newValues + curVal
            }
            idx = idx + 1
        }
        g_comptimeValues = newValues
    }

    // Register a comptime string variable
    fun registerComptimeStrVar(name: String, value: String) r: Void {
        if g_comptimeStrCount > 0 {
            g_comptimeStrNames = g_comptimeStrNames + "|"
            g_comptimeStrValues = g_comptimeStrValues + "|"
        }
        g_comptimeStrNames = g_comptimeStrNames + name
        g_comptimeStrValues = g_comptimeStrValues + value
        g_comptimeStrCount = g_comptimeStrCount + 1
    }

    // Look up a comptime string variable
    fun lookupComptimeStrVar(name: String) r: String {
        return lookupComptimeStrVarImpl(name, g_comptimeStrNames, g_comptimeStrValues, g_comptimeStrCount)
    }

    // Evaluate a constant expression as a string at compile time
    fun evaluateConstExprStr(expr: ParserExpressionNode) r: String {
        return evaluateConstExprStrImpl(expr, g_comptimeNames, g_comptimeValues, g_comptimeCount, g_comptimeStrNames, g_comptimeStrValues, g_comptimeStrCount, structNames, structFieldNames, structFieldTypes)
    }

    // comptime assert(cond, "msg") — compile-time assertion
    fun generateComptimeAssert(stmt: StatementNode) r: Void {
        let condVal = evaluateConstExpr(stmt.expression)
        if condVal == 0 {
            // Assertion failed
            var msg = "comptime assertion failed"
            if stmt.condition.kind == "Literal" and stmt.condition.literalType == "String" {
                msg = stmt.condition.literalValue
            }
            output.append("  ; COMPTIME ASSERT FAILED: " + msg + "\n")
            // Emit compile error via runtime abort
            let msgReg = getNextReg()
            output.append("  " + msgReg + " = call %SeenString @seen_cstr_to_str(ptr @.str.comptime_assert)\n")
            output.append("  call void @println(%SeenString " + msgReg + ")\n")
            output.append("  call void @exit(i64 1)\n")
        } else {
            output.append("  ; comptime assert passed\n")
        }
    }

    // comptime if (cond) { then } else { else } — dead code elimination
    fun generateComptimeIf(stmt: StatementNode) r: Void {
        let condVal = evaluateConstExpr(stmt.expression)
        if condVal != 0 {
            // Condition is true — generate then branch only
            output.append("  ; comptime if: true branch\n")
            generateBlock(stmt.thenBranch)
        } else {
            // Condition is false — generate else branch only (if present)
            if stmt.elseBranch.statements.length() > 0 {
                output.append("  ; comptime if: false branch (else)\n")
                generateBlock(stmt.elseBranch)
            } else {
                output.append("  ; comptime if: false, no else branch — eliminated\n")
            }
        }
    }

    // Evaluate a constant expression at compile time
    fun evaluateConstExpr(expr: ParserExpressionNode) r: Int {
        return evaluateConstExprImpl(expr, g_comptimeNames, g_comptimeValues, g_comptimeCount, g_comptimeStrNames, g_comptimeStrValues, g_comptimeStrCount, structNames, structFieldNames, structFieldTypes)
    }

    // Look up a comptime variable value
    fun lookupComptimeVar(name: String) r: Int {
        return lookupComptimeVarImpl(name, g_comptimeNames, g_comptimeValues, g_comptimeCount)
    }

    // Comptime sizeof for common types
    fun comptimeSizeof(typeName: String) r: Int {
        return comptimeSizeofImpl(typeName)
    }

    // Comptime type field count — look up struct by name, count comma-separated fields
    fun comptimeTypeFieldCount(typeName: String) r: Int {
        return comptimeTypeFieldCountImpl(typeName, structNames, structFieldNames)
    }

    // Comptime type field name — get Nth field name from struct
    fun comptimeTypeFieldName(typeName: String, fieldIdx: Int) r: String {
        return comptimeTypeFieldNameImpl(typeName, fieldIdx, structNames, structFieldNames)
    }

    // Comptime type field type — get Nth field type from struct
    fun comptimeTypeFieldType(typeName: String, fieldIdx: Int) r: String {
        return comptimeTypeFieldTypeImpl(typeName, fieldIdx, structNames, structFieldTypes)
    }

    // Simple integer parser for comptime
    fun parseSimpleInt(s: String) r: Int {
        return parseSimpleIntImpl(s)
    }

    // Generate IR for a let/var declaration. Resolves the variable type from
    // the explicit annotation, falling back to inferExpressionType on the
    // initializer, then preAllocatedTypes, then "Int" as final fallback.
    // If the variable was pre-allocated at function entry (by
    // collectVariableDeclarations), reuses the existing alloca register.
    // Supports dead store elimination: skips literal initializers that are
    // immediately overwritten (tracked in g_deadStoreSkipVars).
    fun resolveLetStatementType(stmt: StatementNode, preIdx: Int) r: String {
        var varType = resolveDeclarationBaseType(stmt)
        if declarationTypeNeedsFallback(varType) and preIdx >= 0 {
            varType = preAllocatedTypes[preIdx]
        }
        if declarationTypeNeedsFallback(varType) {
            varType = "Int"
        }
        return varType
    }

    fun resolveLetStatementAlloca(preIdx: Int, llvmType: String) r: String {
        if preIdx >= 0 and preIdx < preAllocatedRegs.length() {
            let existingLlvmType = mapType(preAllocatedTypes[preIdx])
            if existingLlvmType == llvmType {
                return preAllocatedRegs[preIdx]
            }
        }
        let reg = getNextReg()
        output.append("  " + reg + " = alloca " + llvmType + "\n")
        return reg
    }

    fun shouldSkipDeadLiteralInitializer(stmt: StatementNode) r: Bool {
        if g_deadStoreSkipVars == "" or stmt.initializer.kind != "Literal" {
            return false
        }
        var dsScanIdx = 0
        while dsScanIdx < g_deadStoreSkipVars.length() {
            let dsEntry = pipeGet(g_deadStoreSkipVars, dsScanIdx)
            if dsEntry == "" {
                return false
            }
            if dsEntry == stmt.variableName {
                return true
            }
            dsScanIdx = dsScanIdx + 1
        }
        return false
    }

    fun emitLetStatementInitializer(stmt: StatementNode, reg: String, varType: String, llvmType: String) r: Void {
        if stmt.initializer.kind == "None" {
            return
        }
        if shouldSkipDeadLiteralInitializer(stmt) {
            output.append("  ; DSE: skipped dead literal init for " + stmt.variableName + "\n")
            return
        }
        let savedPendingType = pendingArrayLiteralType
        if stmt.initializer.kind == "ArrayLiteral" and (varType.startsWith("Array") or varType.startsWith("List")) {
            pendingArrayLiteralType = varType
        }
        let valueReg = generateExpression(stmt.initializer)
        pendingArrayLiteralType = savedPendingType
        output.append("  store " + llvmType + " " + valueReg + ", ptr " + reg + "\n")
    }

    fun generateLetStatement(stmt: StatementNode) r: Void {
        let declOrdinal = nextDeclarationOrdinal(stmt.variableName)
        let preIdx = findPreAllocatedOccurrence(stmt.variableName, declOrdinal)
        let varType = resolveLetStatementType(stmt, preIdx)
        let llvmType = mapType(varType)
        let reg = resolveLetStatementAlloca(preIdx, llvmType)
        storeVar(stmt.variableName, reg, varType)
        emitLetStatementInitializer(stmt, reg, varType, llvmType)
    }

    fun emitPendingReturnDefers() r: Void {
        if g_deferCount > 0 {
            output.append("  ; defer cleanup before return (LIFO)\n")
            var deferIdx = g_deferCount - 1
            while deferIdx >= 0 {
                generateExpression(g_deferExprs[deferIdx])
                deferIdx = deferIdx - 1
            }
        }
    }

    fun prepareErrdeferReturnStatement(stmt: StatementNode) r: Void {
        if g_errdeferCount == 0 {
            return
        }
        if stmt.returnValue.kind == "None" {
            output.append("  ; errdefer cleanup before void return (LIFO)\n")
            var voidErrdeferIdx = g_errdeferCount - 1
            while voidErrdeferIdx >= 0 {
                generateExpression(g_errdeferExprs[voidErrdeferIdx])
                voidErrdeferIdx = voidErrdeferIdx - 1
            }
            return
        }

        let tempAllocaReg = getNextReg()
        output.append("  " + tempAllocaReg + " = alloca i64\n")
        let returnValueReg = generateExpression(stmt.returnValue)
        output.append("  store i64 " + returnValueReg + ", ptr " + tempAllocaReg + "\n")
        let isErrReg = getNextReg()
        output.append("  " + isErrReg + " = icmp eq i64 " + returnValueReg + ", 0 ; errdefer: check if error\n")
        let errLabel = getNextBlockLabel()
        let okLabel = getNextBlockLabel()
        output.append("  br i1 " + isErrReg + ", label %" + errLabel + ", label %" + okLabel + "\n")
        output.append(errLabel + ":\n")
        output.append("  ; errdefer cleanup (error path, LIFO)\n")
        var errdeferIdx = g_errdeferCount - 1
        while errdeferIdx >= 0 {
            generateExpression(g_errdeferExprs[errdeferIdx])
            errdeferIdx = errdeferIdx - 1
        }
        output.append("  br label %" + okLabel + "\n")
        output.append(okLabel + ":\n")
        g_errdeferTempAlloca = tempAllocaReg
    }

    fun emitReturnRegionAndProfileCleanup() r: Void {
        if currentFunctionRegionSizeBytes() > 0 {
            let regionLoadReg = getNextReg()
            output.append("  " + regionLoadReg + " = load ptr, ptr %__region_ptr\n")
            output.append("  call void @__seen_region_destroy(ptr " + regionLoadReg + ") ; @preallocate cleanup\n")
        }
        if g_currentFunctionIsProfiled {
            let strIdx = getStringConstantIndex(g_currentFunctionNameForProfile)
            output.append("  ; @profile instrumentation - exit (explicit return)\n")
            output.append("  call void @__seen_profile_exit(ptr @.str." + strIdx.toString() + ")\n")
        }
    }

    fun tryEmitAsyncReturnStatement(stmt: StatementNode) r: Bool {
        if not isCurrentFunctionAsyncLowering() {
            return false
        }
        if stmt.returnValue.kind != "None" {
            let savedPendingType = pendingArrayLiteralType
            if stmt.returnValue.kind == "ArrayLiteral" and (currentFunctionReturnType.startsWith("Array") or currentFunctionReturnType.startsWith("List")) {
                pendingArrayLiteralType = currentFunctionReturnType
            }
            if stmt.returnValue.kind == "Call" {
                markTailCallPosition()
            }
            let valueReg = generateExpression(stmt.returnValue)
            pendingArrayLiteralType = savedPendingType
            let promiseType = mapType(currentFunctionReturnType)
            output.append("  store " + promiseType + " " + valueReg + ", ptr " + g_asyncFunctionPromise + "\n")
        }
        output.append("  br label %" + g_asyncFinalLabel + "\n")
        blockTerminated = true
        return true
    }

    fun emitDefaultEmptyReturnStatement() r: Void {
        let llvmType = mapType(currentFunctionReturnType)
        if llvmType == "void" or currentFunctionReturnType == "" or currentFunctionReturnType == "Void" {
            if g_isMainFunc == 1 {
                output.append("  ret i32 0\n")
                return
            }
        }
        emitDefaultReturnValueImpl(output, llvmType)
    }

    fun tryEmitCharLiteralReturnFastPath(stmt: StatementNode) r: Bool {
        if currentFunctionReturnType != "Char" {
            return false
        }
        if stmt.returnValue.kind != "Literal" or stmt.returnValue.literalType != "String" {
            return false
        }
        let charValue = stmt.returnValue.literalValue
        if charValue.length() != 1 {
            return false
        }
        let codeStr = charToCodeStr(charValue)
        output.append("  ret i64 " + codeStr + "\n")
        return true
    }

    fun resolveReturnStatementValueReg(stmt: StatementNode) r: String {
        if g_errdeferTempAlloca != "" {
            let loadReg = getNextReg()
            output.append("  " + loadReg + " = load i64, ptr " + g_errdeferTempAlloca + "\n")
            g_errdeferTempAlloca = ""
            return loadReg
        }

        let savedPendingType = pendingArrayLiteralType
        if stmt.returnValue.kind == "ArrayLiteral" and (currentFunctionReturnType.startsWith("Array") or currentFunctionReturnType.startsWith("List")) {
            pendingArrayLiteralType = currentFunctionReturnType
        }
        let valueReg = generateExpression(stmt.returnValue)
        pendingArrayLiteralType = savedPendingType
        return valueReg
    }

    fun normalizeReturnStatementValueReg(stmt: StatementNode, llvmType: String, valueReg: String) r: String {
        var normalizedValueReg = valueReg
        if isDataType(currentFunctionReturnType) and stmt.returnValue.kind == "StructLiteral" {
            let loadReg = getNextReg()
            output.append("  " + loadReg + " = load " + llvmType + ", ptr " + normalizedValueReg + "\n")
            normalizedValueReg = loadReg
        }
        if normalizedValueReg == "0" {
            var fixedValue = false
            if llvmType == "ptr" {
                normalizedValueReg = "null"
                fixedValue = true
            }
            if not fixedValue and llvmType == "%SeenString" {
                normalizedValueReg = "zeroinitializer"
                fixedValue = true
            }
            if not fixedValue and llvmType == "%SeenArray" {
                normalizedValueReg = "zeroinitializer"
                fixedValue = true
            }
            if not fixedValue and llvmType == "i1" {
                normalizedValueReg = "false"
            }
        }
        return normalizedValueReg
    }

    // Generate IR for a return statement. Emits pending defer expressions
    // in LIFO order before the return. For async functions, stores the return
    // value into the coroutine promise and branches to the async cleanup label.
    // Handles type coercion (int-to-float, class-to-ptr, data-type-to-ptr).
    // Sets blockTerminated=true to prevent unreachable instructions after ret.
    fun generateReturnStatement(stmt: StatementNode) r: Void {
        emitPendingReturnDefers()
        prepareErrdeferReturnStatement(stmt)
        emitReturnRegionAndProfileCleanup()

        if tryEmitAsyncReturnStatement(stmt) {
            return
        }

        if stmt.returnValue.kind == "None" {
            emitDefaultEmptyReturnStatement()
            blockTerminated = true
            return
        }

        if stmt.returnValue.kind == "Call" {
            markTailCallPosition()
        }
        if tryEmitCharLiteralReturnFastPath(stmt) {
            blockTerminated = true
            return
        }

        let llvmType = mapType(currentFunctionReturnType)
        let rawValueReg = resolveReturnStatementValueReg(stmt)
        let valueReg = normalizeReturnStatementValueReg(stmt, llvmType, rawValueReg)
        output.append("  ret " + llvmType + " " + valueReg + "\n")
        blockTerminated = true
    }

    fun tryEmitConstantIfStatement(stmt: StatementNode) r: Bool {
        if stmt.condition.kind != "BoolLiteral" {
            return false
        }
        if stmt.condition.literalValue == "true" {
            g_branchesEliminated = g_branchesEliminated + 1
            mlLogDecision("branch-elim", "folded", "if-true")
            output.append("  ; branch eliminated: if true\n")
            generateBlock(stmt.thenBranch)
            return true
        }
        if stmt.condition.literalValue == "false" {
            g_branchesEliminated = g_branchesEliminated + 1
            mlLogDecision("branch-elim", "folded", "if-false")
            output.append("  ; branch eliminated: if false\n")
            if stmt.elseBranch.statements.length() > 0 {
                generateBlock(stmt.elseBranch)
            }
            return true
        }
        return false
    }

    fun tryEmitPairedAssignmentSelectIfStatement(stmt: StatementNode) r: Bool {
        if stmt.thenBranch.statements.length() != 1 or stmt.elseBranch.statements.length() != 1 {
            return false
        }

        let thenStmt = stmt.thenBranch.statements[0]
        let elseStmt = stmt.elseBranch.statements[0]
        var thenAssignName = ""
        var elseAssignName = ""
        var thenIsExprAssign = false
        var elseIsExprAssign = false
        var thenIsStmtAssign = false
        var elseIsStmtAssign = false

        if thenStmt.kind == "Expression" and thenStmt.expression.kind == "Assignment" {
            thenAssignName = thenStmt.expression.variableName
            thenIsExprAssign = true
        }
        if thenStmt.kind == "Assignment" {
            thenAssignName = thenStmt.variableName
            thenIsStmtAssign = true
        }
        if elseStmt.kind == "Expression" and elseStmt.expression.kind == "Assignment" {
            elseAssignName = elseStmt.expression.variableName
            elseIsExprAssign = true
        }
        if elseStmt.kind == "Assignment" {
            elseAssignName = elseStmt.variableName
            elseIsStmtAssign = true
        }

        var thenHasRhs = false
        var elseHasRhs = false
        if thenIsExprAssign and thenStmt.expression.operands.length() > 0 { thenHasRhs = true }
        if thenIsStmtAssign { thenHasRhs = true }
        if elseIsExprAssign and elseStmt.expression.operands.length() > 0 { elseHasRhs = true }
        if elseIsStmtAssign { elseHasRhs = true }
        if thenAssignName == "" or thenAssignName != elseAssignName or not thenHasRhs or not elseHasRhs {
            return false
        }

        let varIdx = findVar(thenAssignName)
        if varIdx < 0 {
            return false
        }

        let varType = varTypes[varIdx]
        let llvmType = mapType(varType)
        if llvmType != "i64" and llvmType != "double" {
            return false
        }

        var thenRhs = thenStmt.initializer
        if thenIsExprAssign { thenRhs = thenStmt.expression.operands[0] }
        var elseRhs = elseStmt.initializer
        if elseIsExprAssign { elseRhs = elseStmt.expression.operands[0] }
        if exprCost(thenRhs) >= 8 or exprCost(elseRhs) >= 8 {
            return false
        }

        let condReg = generateExpression(stmt.condition)
        let thenReg = generateExpression(thenRhs)
        let elseReg = generateExpression(elseRhs)
        let resultReg = getNextReg()
        output.append("  " + resultReg + " = select i1 " + condReg + ", " + llvmType + " " + thenReg + ", " + llvmType + " " + elseReg + " ; branchless if/else\n")
        output.append("  store " + llvmType + " " + resultReg + ", ptr " + varRegs[varIdx] + "\n")
        g_branchesEliminated = g_branchesEliminated + 1
        mlLogDecision("select", "if-else", thenAssignName)
        return true
    }

    fun tryEmitSingleArmSelectIfStatement(stmt: StatementNode) r: Bool {
        if stmt.thenBranch.statements.length() != 1 or stmt.elseBranch.statements.length() != 0 {
            return false
        }

        let thenStmt = stmt.thenBranch.statements[0]
        var assignName = ""
        var isExprAssign = false
        var isStmtAssign = false
        if thenStmt.kind == "Expression" and thenStmt.expression.kind == "Assignment" {
            assignName = thenStmt.expression.variableName
            isExprAssign = true
        }
        if thenStmt.kind == "Assignment" {
            assignName = thenStmt.variableName
            isStmtAssign = true
        }
        if assignName == "" or stmt.condition.kind != "Binary" {
            return false
        }

        var isCompareOp = false
        if stmt.condition.operator == ">" or stmt.condition.operator == ">=" or stmt.condition.operator == "<" or stmt.condition.operator == "<=" {
            isCompareOp = true
        }
        var hasRhs = false
        if isExprAssign and thenStmt.expression.operands.length() > 0 { hasRhs = true }
        if isStmtAssign { hasRhs = true }
        if not isCompareOp or stmt.condition.operands.length() < 2 or not hasRhs {
            return false
        }

        var rhsExpr = thenStmt.initializer
        if isExprAssign { rhsExpr = thenStmt.expression.operands[0] }
        if exprCost(rhsExpr) >= 5 {
            return false
        }

        let varIdx = findVar(assignName)
        if varIdx < 0 {
            return false
        }

        let varType = varTypes[varIdx]
        let llvmType = mapType(varType)
        if llvmType != "i64" and llvmType != "double" {
            return false
        }

        let condReg = generateExpression(stmt.condition)
        let newValueReg = generateExpression(rhsExpr)
        let oldValueReg = getNextReg()
        output.append("  " + oldValueReg + " = load " + llvmType + ", ptr " + varRegs[varIdx] + "\n")
        let selectedValueReg = getNextReg()
        output.append("  " + selectedValueReg + " = select i1 " + condReg + ", " + llvmType + " " + newValueReg + ", " + llvmType + " " + oldValueReg + " ; branchless max/min\n")
        output.append("  store " + llvmType + " " + selectedValueReg + ", ptr " + varRegs[varIdx] + "\n")
        g_branchesEliminated = g_branchesEliminated + 1
        mlLogDecision("select", "max-min", assignName)
        return true
    }

    fun tryEmitSelectOptimizedIfStatement(stmt: StatementNode) r: Bool {
        if tryEmitPairedAssignmentSelectIfStatement(stmt) {
            return true
        }
        return tryEmitSingleArmSelectIfStatement(stmt)
    }

    fun inferIfConditionType(expr: ParserExpressionNode) r: String {
        var condType = inferExpressionType(expr)
        let condKind = expr.kind
        if condKind == "Binary" {
            let condOp = expr.operator
            if condOp == "==" or condOp == "!=" or condOp == "<" or condOp == ">" or condOp == "<=" or condOp == ">=" or condOp == "and" or condOp == "or" {
                condType = "Bool"
            }
        }
        if condKind == "Not" {
            condType = "Bool"
        }
        if condKind == "Literal" {
            let condLitVal = expr.literalValue
            if condLitVal == "true" or condLitVal == "false" {
                condType = "Bool"
            }
        }
        return condType
    }

    fun computeIfBranchWeightMetadata(stmt: StatementNode) r: String {
        if stmt.thenBranch.statements.length() > 0 and stmt.thenBranch.statements.length() <= 3 {
            let lastThenStmt = stmt.thenBranch.statements[stmt.thenBranch.statements.length() - 1]
            if lastThenStmt.kind == "Return" {
                return ", !prof !197"
            }
        }
        return ""
    }

    fun finalizeConditionalEndBlock(endLabel: String, thenTerminated: Bool, elseTerminated: Bool) r: Void {
        output.append(endLabel + ":\n")
        cseClear()
        if thenTerminated and elseTerminated {
            blockTerminated = true
            output.append("  unreachable\n")
            return
        }
        blockTerminated = false
    }

    // Generate IR for an if/else statement. Performs branch elimination at
    // compile time for constant conditions (BoolLiteral true/false).
    // Emits conditional branch (br i1 %cond, label %then, label %else),
    // generates then/else blocks, and emits a merge block if neither branch
    // terminates (both have a path to the merge point).
    fun generateIfStatement(stmt: StatementNode) r: Void {
        if tryEmitConstantIfStatement(stmt) {
            return
        }
        if tryEmitSelectOptimizedIfStatement(stmt) {
            return
        }

        let condReg = generateExpression(stmt.condition)
        let condType = inferIfConditionType(stmt.condition)
        let condBool = emitConditionToI1Impl(output, g_regBox, condReg, condType)
        let branchInfo = emitIfBranchingImpl(output, g_blockBox, condBool, computeIfBranchWeightMetadata(stmt))
        let branchLabels = splitPipe(branchInfo)
        let elseLabel = branchLabels[1]
        let endLabel = branchLabels[2]

        cseClear()
        blockTerminated = false
        generateBlock(stmt.thenBranch)
        let thenTerminated = blockTerminated
        if not thenTerminated {
            output.append("  br label %" + endLabel + "\n")
        }

        // Else block
        output.append(elseLabel + ":\n")
        cseClear()  // CSE cache invalid across basic block boundaries
        blockTerminated = false
        if stmt.elseBranch.statements.length() > 0 {
            generateBlock(stmt.elseBranch)
        }
        let elseTerminated = blockTerminated
        if not elseTerminated {
            output.append("  br label %" + endLabel + "\n")
        }

        finalizeConditionalEndBlock(endLabel, thenTerminated, elseTerminated)
    }

    fun emitIfLetBinding(bindName: String, exprReg: String) r: Int {
        let bindReg = getNextReg()
        output.append("  " + bindReg + " = alloca i64, align 8\n")
        output.append("  store i64 " + exprReg + ", ptr " + bindReg + "\n")
        let savedIfLetVarCount = activeVarCount
        storeVar(bindName, bindReg, "Int")
        return savedIfLetVarCount
    }

    // if let name = expr { ... } else { ... }
    // Evaluate expr, if non-null bind name to value and run then-block
    fun generateIfLetStatement(stmt: StatementNode) r: Void {
        let exprReg = generateExpression(stmt.condition)
        let cmpReg = emitConditionToI1Impl(output, g_regBox, exprReg, "Int")
        let branchInfo = emitIfBranchingImpl(output, g_blockBox, cmpReg, "")
        let branchLabels = splitPipe(branchInfo)
        let elseLabel = branchLabels[1]
        let endLabel = branchLabels[2]

        cseClear()
        blockTerminated = false
        let savedIfLetVarCount = emitIfLetBinding(stmt.variableName, exprReg)
        generateBlock(stmt.thenBranch)
        activeVarCount = savedIfLetVarCount
        let thenTerminated = blockTerminated
        if not thenTerminated {
            output.append("  br label %" + endLabel + "\n")
        }

        // Else block
        output.append(elseLabel + ":\n")
        cseClear()
        blockTerminated = false
        if stmt.elseBranch.statements.length() > 0 {
            generateBlock(stmt.elseBranch)
        }
        let elseTerminated = blockTerminated
        if not elseTerminated {
            output.append("  br label %" + endLabel + "\n")
        }

        finalizeConditionalEndBlock(endLabel, thenTerminated, elseTerminated)
    }

    fun blockHasTerminator(block: BlockNode) r: Bool {
        if block.statements.length() == 0 {
            return false
        }
        let lastStmt = block.statements[block.statements.length() - 1]
        return lastStmt.kind == "Return"
    }

    fun appendLoopTileHint(loopMetaId: Int, hintValue: Int) r: Void {
        let metaIdx = loopMetaId - 202
        let entry = metaIdx.toString() + ":" + hintValue.toString()
        if g_loopTileHints == "" {
            g_loopTileHints = entry
        } else {
            g_loopTileHints = g_loopTileHints + "|" + entry
        }
    }

    fun appendNestedLoopMetadataId(loopMetaId: Int) r: Void {
        let nestedMetaIdx = loopMetaId - 202
        if g_nestedLoopIds == "" {
            g_nestedLoopIds = nestedMetaIdx.toString()
        } else {
            g_nestedLoopIds = g_nestedLoopIds + "|" + nestedMetaIdx.toString()
        }
    }

    fun appendReductionLoopMetadataId(loopMetaId: Int) r: Void {
        let reductionMetaIdx = loopMetaId - 202
        if g_reductionLoopIds == "" {
            g_reductionLoopIds = reductionMetaIdx.toString()
        } else {
            g_reductionLoopIds = g_reductionLoopIds + "|" + reductionMetaIdx.toString()
        }
    }

    fun enterLoopContext(condLabel: String, endLabel: String, loopMetaIdStr: String,
        savedCondBox: Array<String>, savedEndBox: Array<String>) r: Void {
        savedCondBox.push(currentLoopCondLabel)
        savedEndBox.push(currentLoopEndLabel)
        currentLoopCondLabel = condLabel + "|" + loopMetaIdStr
        currentLoopEndLabel = endLabel
    }

    fun restoreLoopContext(savedCondLabel: String, savedEndLabel: String) r: Void {
        currentLoopCondLabel = savedCondLabel
        currentLoopEndLabel = savedEndLabel
    }

    fun emitLoopEndBlock(endLabel: String) r: Void {
        output.append(endLabel + ":\n")
        cseClear()
        blockTerminated = false
    }

    fun emitLiteralBoundWhileHints(stmt: StatementNode, loopMetaId: Int, loopBoundLiteral: Int) r: Void {
        let tileSize = computeLoopTileSizeImpl(loopBoundLiteral, g_mlUnrollThreshold)
        if tileSize > 0 {
            output.append("  ; loop tiling: bound=" + loopBoundLiteral.toString() + " → unroll.count=" + tileSize.toString() + "\n")
            g_loopsOptimized = g_loopsOptimized + 1
            appendLoopTileHint(loopMetaId, tileSize)
            mlLogDecision("loop-tile", "unroll", "bound:" + loopBoundLiteral.toString() + ",tile:" + tileSize.toString())
        }
        if loopBoundLiteral < g_mlVectorizeThreshold and loopBoundLiteral > 0 {
            output.append("  ; ML: loop bound " + loopBoundLiteral.toString() + " < vectorize threshold " + g_mlVectorizeThreshold.toString() + " → skip vectorize\n")
            appendLoopTileHint(loopMetaId, -1)
            mlLogDecision("ml-vec", "skip", "bound:" + loopBoundLiteral.toString() + "<threshold:" + g_mlVectorizeThreshold.toString())
        }
        if loopBoundLiteral > 0 and loopBoundLiteral <= 32 and not detectNestedLoopImpl(stmt.loopBody) and stmt.loopBody.statements.length() <= 8 {
            appendLoopTileHint(loopMetaId, -2)
            output.append("  ; small loop (bound=" + loopBoundLiteral.toString() + ", " + stmt.loopBody.statements.length().toString() + " stmts) → full unroll hint\n")
        }
    }

    fun emitWhileLoopInvariantAnnotations(stmt: StatementNode, loopMetaId: Int) r: Void {
        var licmIdx = 0
        while licmIdx < stmt.loopBody.statements.length() {
            let licmStmt = stmt.loopBody.statements[licmIdx]
            if licmStmt.kind == "Let" or licmStmt.kind == "Var" {
                if licmStmt.expression.kind == "Variable" or licmStmt.expression.kind == "VarExpr" {
                    var licmVarName = licmStmt.expression.literalValue
                    if licmVarName == "" { licmVarName = licmStmt.expression.variableName }
                    var mcIdx = 0
                    while mcIdx < moduleConstantNames.length() {
                        if moduleConstantNames[mcIdx] == licmVarName {
                            var licmImmutable = true
                            if isModuleConstMutable(mcIdx) { licmImmutable = false }
                            if licmImmutable {
                                output.append("  ; LICM: " + licmVarName + " is immutable module constant (!invariant.load applied)\n")
                                mlLogDecision("licm", "applied", licmVarName)
                            } else {
                                output.append("  ; LICM candidate: " + licmVarName + " is mutable (var), skipped\n")
                                mlLogDecision("licm", "skipped-mutable", licmVarName)
                            }
                            g_loopsOptimized = g_loopsOptimized + 1
                            mcIdx = moduleConstantNames.length()
                        }
                        mcIdx = mcIdx + 1
                    }
                }
            }
            licmIdx = licmIdx + 1
        }

        if detectNestedLoopImpl(stmt.loopBody) {
            output.append("  ; nested loop detected - interchange candidate\n")
            g_loopsOptimized = g_loopsOptimized + 1
            mlLogDecision("loop-interchange", "candidate", "nested-loop")
            appendNestedLoopMetadataId(loopMetaId)
        }
    }

    fun emitGcdPatternWhileHint(stmt: StatementNode, loopMetaId: Int) r: Void {
        if detectGcdPatternImpl(stmt.loopCondition, stmt.loopBody) {
            appendLoopTileHint(loopMetaId, 8)
            output.append("  ; GCD-pattern loop → unroll.count=8\n")
        }
    }

    fun emitWhileConditionBranch(condReg: String, breakFlagVar: String, bodyLabel: String, endLabel: String) r: Void {
        if breakFlagVar != "" {
            let bfVarIdx = findVar(breakFlagVar)
            if bfVarIdx >= 0 {
                let bfFlagReg = getNextReg()
                output.append("  " + bfFlagReg + " = load i64, ptr " + varRegs[bfVarIdx] + "\n")
                let bfNotFoundReg = getNextReg()
                output.append("  " + bfNotFoundReg + " = icmp eq i64 " + bfFlagReg + ", 0\n")
                let bfCombinedReg = getNextReg()
                output.append("  " + bfCombinedReg + " = and i1 " + condReg + ", " + bfNotFoundReg + " ; early exit when flag set\n")
                output.append("  br i1 " + bfCombinedReg + ", label %" + bodyLabel + ", label %" + endLabel + ", !prof !196\n")
                return
            }
        }
        output.append("  br i1 " + condReg + ", label %" + bodyLabel + ", label %" + endLabel + ", !prof !196\n")
    }

    fun tryEmitMemcpyOptimizedWhileLoop(stmt: StatementNode, condLabel: String, bodyLabel: String, endLabel: String, savedCondLabel: String, savedEndLabel: String) r: Bool {
        let memcpyInfo = Array<String>()
        let memcpyKind = detectMemcpyPatternImpl(stmt.loopCondition, stmt.loopBody, memcpyInfo)
        if memcpyKind == 0 or memcpyInfo.length() < 3 {
            return false
        }
        let mcLHSArrName = memcpyInfo[0]
        let mcRHSArrName = memcpyInfo[1]
        let mcIncrVarName = memcpyInfo[2]
        let mcBoundExpr = stmt.loopCondition.operands[1]
        let mcBoundReg = generateExpression(mcBoundExpr)

        if memcpyKind == 1 {
            let mcDstType = findVarType(mcLHSArrName)
            let mcSrcType = findVarType(mcRHSArrName)
            let mcDstIdx = findVar(mcLHSArrName)
            let mcSrcIdx = findVar(mcRHSArrName)
            if mcDstType != "Array<Int>" or mcSrcType != "Array<Int>" or mcDstIdx < 0 or mcSrcIdx < 0 {
                return false
            }
            let mcDstPtr = getNextReg()
            output.append("  " + mcDstPtr + " = load ptr, ptr " + varRegs[mcDstIdx] + "\n")
            let mcSrcPtr = getNextReg()
            output.append("  " + mcSrcPtr + " = load ptr, ptr " + varRegs[mcSrcIdx] + "\n")
            let mcDstPP = getNextReg()
            output.append("  " + mcDstPP + " = getelementptr inbounds %SeenArray, ptr " + mcDstPtr + ", i32 0, i32 3\n")
            let mcDstData = getNextReg()
            output.append("  " + mcDstData + " = load ptr, ptr " + mcDstPP + ", !tbaa !104\n")
            let mcSrcPP = getNextReg()
            output.append("  " + mcSrcPP + " = getelementptr inbounds %SeenArray, ptr " + mcSrcPtr + ", i32 0, i32 3\n")
            let mcSrcData = getNextReg()
            output.append("  " + mcSrcData + " = load ptr, ptr " + mcSrcPP + ", !tbaa !104\n")
            let mcByteCount = getNextReg()
            output.append("  " + mcByteCount + " = shl nsw i64 " + mcBoundReg + ", 3\n")
            output.append("  call void @llvm.memcpy.p0.p0.i64(ptr " + mcDstData + ", ptr " + mcSrcData + ", i64 " + mcByteCount + ", i1 false)\n")
            let mcLoopVarIdx = findVar(mcIncrVarName)
            if mcLoopVarIdx >= 0 {
                output.append("  store i64 " + mcBoundReg + ", ptr " + varRegs[mcLoopVarIdx] + "\n")
            }
            output.append("  ; memcpy optimization: " + mcLHSArrName + "[i] = " + mcRHSArrName + "[i] → llvm.memcpy\n")
            mlLogDecision("memcpy", "applied", mcLHSArrName + "<-" + mcRHSArrName)
            g_loopsOptimized = g_loopsOptimized + 1
        }
        if memcpyKind == 2 {
            let mcArrType = findVarType(mcLHSArrName)
            let mcArrIdx = findVar(mcLHSArrName)
            if mcArrType != "Array<Int>" or mcArrIdx < 0 {
                return false
            }
            let mcArrPtr = getNextReg()
            output.append("  " + mcArrPtr + " = load ptr, ptr " + varRegs[mcArrIdx] + "\n")
            let mcDataPtrPtr = getNextReg()
            output.append("  " + mcDataPtrPtr + " = getelementptr inbounds %SeenArray, ptr " + mcArrPtr + ", i32 0, i32 3\n")
            let mcData = getNextReg()
            output.append("  " + mcData + " = load ptr, ptr " + mcDataPtrPtr + ", !tbaa !104\n")
            let mcSrc = getNextReg()
            output.append("  " + mcSrc + " = getelementptr i64, ptr " + mcData + ", i64 1\n")
            let mcByteCount = getNextReg()
            output.append("  " + mcByteCount + " = shl nsw i64 " + mcBoundReg + ", 3\n")
            output.append("  call void @llvm.memmove.p0.p0.i64(ptr " + mcData + ", ptr " + mcSrc + ", i64 " + mcByteCount + ", i1 false)\n")
            let mcLoopVarIdx = findVar(mcIncrVarName)
            if mcLoopVarIdx >= 0 {
                output.append("  store i64 " + mcBoundReg + ", ptr " + varRegs[mcLoopVarIdx] + "\n")
            }
            output.append("  ; memmove optimization: " + mcLHSArrName + "[i] = " + mcLHSArrName + "[i+1] → llvm.memmove\n")
            mlLogDecision("memmove", "applied", mcLHSArrName + "[i]<-[i+1]")
            g_loopsOptimized = g_loopsOptimized + 1
        }
        output.append("  br label %" + endLabel + "\n")
        output.append(condLabel + ":\n")
        output.append("  br label %" + endLabel + "\n")
        output.append(bodyLabel + ":\n")
        output.append("  br label %" + endLabel + "\n")
        output.append(endLabel + ":\n")
        currentLoopCondLabel = savedCondLabel
        currentLoopEndLabel = savedEndLabel
        return true
    }

    fun emitWhileLoopAnalyses(stmt: StatementNode, loopMetaId: Int,
        breakFlagBox: Array<String>, savedInductionVarBox: Array<String>) r: Void {
        let loopBoundLiteral = detectLoopBoundImpl(stmt.loopCondition)
        if loopBoundLiteral >= 0 {
            emitLiteralBoundWhileHints(stmt, loopMetaId, loopBoundLiteral)
        }
        emitWhileLoopInvariantAnnotations(stmt, loopMetaId)
        emitGcdPatternWhileHint(stmt, loopMetaId)

        let reductionVar = detectReductionPatternImpl(stmt.loopBody)
        if reductionVar != "" {
            let reductionType = "sum"
            output.append("  ; reduction chain detected: " + reductionType + " on " + reductionVar + " → 2x vectorize width\n")
            g_reductionChainsDetected = g_reductionChainsDetected + 1
            appendReductionLoopMetadataId(loopMetaId)
            mlLogDecision("reduction", reductionType, reductionVar)
        }

        savedInductionVarBox.push(g_inductionVarName)
        let inductionVarName = detectInductionVarImpl(stmt.loopBody)
        if inductionVarName != "" {
            output.append("  ; induction variable: " + inductionVarName + " → nsw\n")
            g_inductionVarName = inductionVarName
        }

        let breakFlagVar = detectBreakOnFlagImpl(stmt.loopBody)
        breakFlagBox.push(breakFlagVar)
        if breakFlagVar != "" {
            output.append("  ; break-on-flag: " + breakFlagVar + " → early loop exit\n")
            mlLogDecision("break-flag", "early-exit", breakFlagVar)
        }
    }

    fun emitWhileLoopBody(stmt: StatementNode, condLabel: String, bodyLabel: String,
        endLabel: String, breakFlagVar: String, loopMetaIdStr: String) r: Void {
        output.append("  br label %" + condLabel + "\n")

        output.append(condLabel + ":\n")
        cseClear()
        let condReg = generateExpression(stmt.loopCondition)
        emitWhileConditionBranch(condReg, breakFlagVar, bodyLabel, endLabel)

        output.append(bodyLabel + ":\n")
        cseClear()
        blockTerminated = false
        generateBlock(stmt.loopBody)
        let bodyTerminated = blockTerminated
        if not bodyTerminated {
            output.append("  br label %" + condLabel + ", !llvm.loop !" + loopMetaIdStr + "\n")
        }
    }

    fun resolveForInLoopVariableStorage(loopVarName: String) r: String {
        var loopVarType = findVarType(loopVarName)
        if loopVarType == "" {
            loopVarType = "Int"
        }
        let loopVarOrdinal = nextDeclarationOrdinal(loopVarName)
        let loopVarPreIdx = findPreAllocatedOccurrence(loopVarName, loopVarOrdinal)
        var loopVarReg = ""
        if loopVarPreIdx >= 0 and loopVarPreIdx < preAllocatedRegs.length() {
            loopVarReg = preAllocatedRegs[loopVarPreIdx]
        }
        if loopVarReg == "" {
            let loopVarLlvmType = mapType(loopVarType)
            loopVarReg = getNextReg()
            if loopVarLlvmType == "i64" or loopVarLlvmType == "double" or loopVarLlvmType == "ptr" {
                output.append("  " + loopVarReg + " = alloca " + loopVarLlvmType + ", align 8\n")
            } else {
                output.append("  " + loopVarReg + " = alloca " + loopVarLlvmType + "\n")
            }
        }
        return loopVarType + "|" + loopVarReg
    }

    fun resolveForInIndexAlloca(idxName: String) r: String {
        var idxReg = ""
        let idxPreIdx = findPreAllocatedOccurrence(idxName, 1)
        if idxPreIdx >= 0 and idxPreIdx < preAllocatedRegs.length() {
            idxReg = preAllocatedRegs[idxPreIdx]
        }
        if idxReg == "" {
            idxReg = getNextReg()
            output.append("  " + idxReg + " = alloca i64, align 8\n")
        }
        return idxReg
    }

    fun emitRangeForInLoop(stmt: StatementNode, loopVarName: String, loopVarType: String, loopVarReg: String,
        forInIterable: ParserExpressionNode, condLabel: String, bodyLabel: String,
        endLabel: String, loopMetaIdStr: String) r: Void {
        let startReg = generateExpression(forInIterable.operands[0])
        let endReg = generateExpression(forInIterable.operands[1])
        let idxReg = resolveForInIndexAlloca("__forin_idx_" + loopVarName)
        storeVar(loopVarName, loopVarReg, loopVarType)
        cseClear()
        emitIndexedForLoopHeaderImpl(output, g_regBox, startReg, endReg, loopVarReg, idxReg, condLabel, bodyLabel, endLabel)
        cseClear()
        blockTerminated = false
        generateBlock(stmt.loopBody)
        let bodyTerminated = blockTerminated
        if not bodyTerminated {
            emitForInIncrementImpl(output, g_regBox, idxReg, condLabel, loopMetaIdStr)
        }
    }

    fun tryEmitIteratorProtocolForInLoop(stmt: StatementNode, loopVarName: String, loopVarType: String,
        loopVarReg: String, forInIterable: ParserExpressionNode, iterableType: String,
        condLabel: String, bodyLabel: String, endLabel: String) r: Bool {
        let iterFuncName = iterableType + "_iter"
        let iterFuncRet = getFunctionReturnType(iterFuncName)
        if iterFuncRet == "" {
            return false
        }

        let iterableReg = generateExpression(forInIterable)
        let iterThisReg = getNextReg()
        output.append("  " + iterThisReg + " = inttoptr i64 " + iterableReg + " to ptr\n")
        let iterObjReg = getNextReg()
        let iterRetLlvm = mapType(iterFuncRet)
        output.append("  " + iterObjReg + " = call " + iterRetLlvm + " @" + quoteIdentIfNeeded(iterFuncName) + "(ptr " + iterThisReg + ")\n")
        let iterStoreReg = getNextReg()
        output.append("  " + iterStoreReg + " = alloca i64, align 8\n")
        output.append("  store i64 " + iterObjReg + ", ptr " + iterStoreReg + "\n")
        storeVar(loopVarName, loopVarReg, loopVarType)

        output.append("  br label %" + condLabel + "\n")
        output.append(condLabel + ":\n")
        cseClear()
        let iterLoadReg = getNextReg()
        output.append("  " + iterLoadReg + " = load i64, ptr " + iterStoreReg + "\n")
        let iterPtrReg = getNextReg()
        output.append("  " + iterPtrReg + " = inttoptr i64 " + iterLoadReg + " to ptr\n")
        let hasNextFunc = iterFuncRet + "_hasNext"
        let hasNextReg = getNextReg()
        output.append("  " + hasNextReg + " = call i1 @" + quoteIdentIfNeeded(hasNextFunc) + "(ptr " + iterPtrReg + ")\n")
        output.append("  br i1 " + hasNextReg + ", label %" + bodyLabel + ", label %" + endLabel + "\n")

        output.append(bodyLabel + ":\n")
        cseClear()
        blockTerminated = false
        let nextFunc = iterFuncRet + "_next"
        let nextRetType = getFunctionReturnType(nextFunc)
        var nextRetLlvm = "i64"
        if nextRetType != "" {
            nextRetLlvm = mapType(nextRetType)
        }
        let nextReg = getNextReg()
        output.append("  " + nextReg + " = call " + nextRetLlvm + " @" + quoteIdentIfNeeded(nextFunc) + "(ptr " + iterPtrReg + ")\n")
        if loopVarReg != "" {
            output.append("  store " + nextRetLlvm + " " + nextReg + ", ptr " + loopVarReg + "\n")
        }
        generateBlock(stmt.loopBody)
        let bodyTerminated = blockTerminated
        if not bodyTerminated {
            output.append("  br label %" + condLabel + "\n")
        }
        return true
    }

    fun emitStringForInElement(arrReg: String, loadIdx: String, loopVarReg: String) r: Void {
        var arrStrReg = arrReg
        if arrReg == "0" {
            arrStrReg = "zeroinitializer"
        }
        let charReg = getNextReg()
        output.append("  " + charReg + " = call i64 @seen_char_at(%SeenString " + arrStrReg + ", i64 " + loadIdx + ")\n")
        output.append("  store i64 " + charReg + ", ptr " + loopVarReg + ", align 8\n")
    }

    fun emitArrayLikeForInLoop(stmt: StatementNode, loopVarName: String, loopVarType: String, loopVarReg: String,
        forInIterable: ParserExpressionNode, condLabel: String, bodyLabel: String,
        endLabel: String, loopMetaIdStr: String) r: Void {
        let arrReg = generateExpression(forInIterable)
        let iterType = inferExpressionType(forInIterable)
        var elementType = "Int"
        if iterType.startsWith("Array<") {
            elementType = iterType.substring(6, iterType.length() - 1)
        }

        var isStringIterable = 0
        if iterType == "String" {
            isStringIterable = 1
            elementType = "Char"
        }
        var lenReg = ""
        if isStringIterable == 1 {
            lenReg = getNextReg()
            var arrStrReg = arrReg
            if arrReg == "0" {
                arrStrReg = "zeroinitializer"
            }
            output.append("  " + lenReg + " = call i64 @seen_length(%SeenString " + arrStrReg + ")\n")
        } else {
            let lenPtrReg = getNextReg()
            lenReg = getNextReg()
            output.append("  " + lenPtrReg + " = getelementptr inbounds %SeenArray, ptr " + arrReg + ", i32 0, i32 0\n")
            output.append("  " + lenReg + " = load i64, ptr " + lenPtrReg + ", !tbaa !108, !range !188\n")
        }

        let idxReg = resolveForInIndexAlloca("__forin_idx_" + loopVarName)
        storeVar(loopVarName, loopVarReg, loopVarType)
        cseClear()
        let loadIdx = emitIndexedForLoopHeaderImpl(output, g_regBox, "0", lenReg, "", idxReg, condLabel, bodyLabel, endLabel)
        cseClear()
        blockTerminated = false

        if isStringIterable == 1 {
            emitStringForInElement(arrReg, loadIdx, loopVarReg)
        } else {
            var isString = 0
            var isFloat = 0
            if elementType == "String" { isString = 1 }
            if elementType == "Float" { isFloat = 1 }
            emitForInElementFetchImpl(output, g_regBox, arrReg, loadIdx, loopVarReg, elementType, isString, isFloat)
            emitForInPrefetchImpl(output, g_regBox, g_blockBox, arrReg, loadIdx, lenReg, elementType)
        }

        generateBlock(stmt.loopBody)
        let bodyTerminated = blockTerminated
        if not bodyTerminated {
            emitForInIncrementImpl(output, g_regBox, idxReg, condLabel, loopMetaIdStr)
        }
    }

    fun finalizeForInLoop(endLabel: String, savedForInVarCount: Int, savedCondLabel: String, savedEndLabel: String) r: Void {
        emitLoopEndBlock(endLabel)
        activeVarCount = savedForInVarCount
        restoreLoopContext(savedCondLabel, savedEndLabel)
    }

    // Generate IR for a while loop. Emits cond/body/end blocks with
    // back-edge from body to cond. Attaches LLVM loop metadata for:
    //   - !llvm.loop.vectorize.enable/width (from @vectorize decorator)
    //   - !llvm.loop.unroll.count (from @unroll decorator or tile hints)
    //   - !llvm.loop.distribute.enable (for nested loops)
    // Performs pattern detection for memcpy/memmove idioms and replaces
    // them with llvm.memcpy/memmove intrinsics.
    // Saves/restores outer loop context (currentLoopCondLabel/EndLabel)
    // for nested loop support. Break jumps to endLabel, continue to condLabel.
    fun generateWhileStatement(stmt: StatementNode) r: Void {
        let loopMetaId = g_blockBox[0] + 202
        let loopMetaIdStr = loopMetaId.toString()
        let condLabel = getNextBlockLabel()
        let bodyLabel = getNextBlockLabel()
        let endLabel = getNextBlockLabel()

        let savedCondBox = Array<String>()
        let savedEndBox = Array<String>()
        enterLoopContext(condLabel, endLabel, loopMetaIdStr, savedCondBox, savedEndBox)
        let savedCondLabel = savedCondBox[0]
        let savedEndLabel = savedEndBox[0]

        if tryEmitMemcpyOptimizedWhileLoop(stmt, condLabel, bodyLabel, endLabel, savedCondLabel, savedEndLabel) {
            return
        }

        let breakFlagBox = Array<String>()
        let savedInductionVarBox = Array<String>()
        emitWhileLoopAnalyses(stmt, loopMetaId, breakFlagBox, savedInductionVarBox)
        emitWhileLoopBody(stmt, condLabel, bodyLabel, endLabel, breakFlagBox[0], loopMetaIdStr)
        emitLoopEndBlock(endLabel)

        g_inductionVarName = savedInductionVarBox[0]
        restoreLoopContext(savedCondLabel, savedEndLabel)
    }

    // Generate IR for a for-in loop over a range or array.
    // Range loops (for i in 0..n) emit a simple counter-based loop.
    // Array loops (for item in arr) emit index-based iteration with
    // element load per iteration. Attaches the same loop metadata as
    // generateWhileStatement for vectorization/unrolling hints.
    fun generateForInStatement(stmt: StatementNode) r: Void {
        let loopMetaId = g_blockBox[0] + 202
        let loopMetaIdStr = loopMetaId.toString()
        let condLabel = getNextBlockLabel()
        let bodyLabel = getNextBlockLabel()
        let endLabel = getNextBlockLabel()

        let savedCondBox = Array<String>()
        let savedEndBox = Array<String>()
        enterLoopContext(condLabel, endLabel, loopMetaIdStr, savedCondBox, savedEndBox)
        let savedCondLabel = savedCondBox[0]
        let savedEndLabel = savedEndBox[0]
        let savedForInVarCount = activeVarCount

        let loopVarName = stmt.variableName
        let loopVarInfo = splitPipe(resolveForInLoopVariableStorage(loopVarName))
        let loopVarType = loopVarInfo[0]
        let loopVarReg = loopVarInfo[1]
        let forInIterable = stmt.expression
        if forInIterable.kind == "Range" {
            emitRangeForInLoop(stmt, loopVarName, loopVarType, loopVarReg, forInIterable,
                condLabel, bodyLabel, endLabel, loopMetaIdStr)
        } else {
            let iterableType = inferExpressionType(forInIterable)
            if not tryEmitIteratorProtocolForInLoop(stmt, loopVarName, loopVarType, loopVarReg,
                forInIterable, iterableType, condLabel, bodyLabel, endLabel) {
                emitArrayLikeForInLoop(stmt, loopVarName, loopVarType, loopVarReg, forInIterable,
                    condLabel, bodyLabel, endLabel, loopMetaIdStr)
            }
        }
        finalizeForInLoop(endLabel, savedForInVarCount, savedCondLabel, savedEndLabel)
    }

    fun generateAssignmentValuePreservingPendingType(valueExpr: ParserExpressionNode) r: String {
        let savedPendingType = pendingArrayLiteralType
        let valueReg = generateExpression(valueExpr)
        pendingArrayLiteralType = savedPendingType
        return valueReg
    }

    fun generateAssignmentValueForSeenType(valueExpr: ParserExpressionNode, targetSeenType: String) r: String {
        let savedPendingType = pendingArrayLiteralType
        if targetSeenType != "" and valueExpr.kind == "ArrayLiteral" {
            if targetSeenType.startsWith("Array") or targetSeenType.startsWith("List") {
                pendingArrayLiteralType = targetSeenType
            }
        }
        let valueReg = generateExpression(valueExpr)
        pendingArrayLiteralType = savedPendingType
        return valueReg
    }

    fun tryGenerateModuleConstantAssignment(varName: String, valueExpr: ParserExpressionNode) r: Int {
        let constIdx = findModuleConstant(varName)
        if constIdx < 0 {
            return 0
        }
        let constType = moduleConstantTypes[constIdx]
        let valueReg = generateAssignmentValuePreservingPendingType(valueExpr)
        emitStoreValueToPtrImpl(output, constType, valueReg, "@" + varName)
        return 1
    }

    fun tryGenerateImplicitThisFieldAssignment(varName: String, valueExpr: ParserExpressionNode) r: Int {
        let thisIdx = findVar("this")
        if thisIdx < 0 {
            return 0
        }

        let thisType = varTypes[thisIdx]
        let structIdx = findStruct(thisType)
        if structIdx < 0 {
            return 0
        }

        let fieldIdx = getFieldInfo(thisType, varName)
        if fieldIdx < 0 {
            return 0
        }

        let fieldSeenType = getSeenFieldType(thisType, varName)
        let valueReg = generateAssignmentValueForSeenType(valueExpr, fieldSeenType)
        let fieldType = getFieldType(thisType, varName)
        emitImplicitThisFieldStoreImpl(output, g_regBox,
            varRegs[thisIdx], structLayouts[structIdx], fieldIdx, fieldType, valueReg)
        return 1
    }

    fun tryGenerateFallbackAssignmentTarget(varName: String, valueExpr: ParserExpressionNode) r: Int {
        if tryGenerateModuleConstantAssignment(varName, valueExpr) == 1 {
            return 1
        }
        return tryGenerateImplicitThisFieldAssignment(varName, valueExpr)
    }

    fun emitDistinctAssignmentTypeWarning(varType: String, valueExpr: ParserExpressionNode) r: Void {
        if g_distinctTypeNames == "" or not g_distinctTypeNames.contains(varType + "|") {
            return
        }
        let rhsType = inferExpressionType(valueExpr)
        if rhsType != "" and rhsType != varType {
            emitDistinctTypeMismatchWarningImpl(output, rhsType, varType)
        }
    }

    fun emitLocalVariableAssignment(idx: Int, valueExpr: ParserExpressionNode) r: String {
        let varType = varTypes[idx]
        let valueReg = generateAssignmentValueForSeenType(valueExpr, varType)
        emitStoreValueToPtrImpl(output, mapType(varType), valueReg, varRegs[idx])
        return varType
    }

    fun applyMoveAssignmentSemantics(valueExpr: ParserExpressionNode) r: Void {
        if g_moveOnlyClasses == "" {
            return
        }
        if valueExpr.kind != "Variable" and valueExpr.kind != "VarExpr" {
            return
        }

        let rhsVarName = getExprVariableNameImpl(valueExpr.variableName, valueExpr.literalValue)
        if rhsVarName == "" {
            return
        }

        let rhsIdx = findVar(rhsVarName)
        if rhsIdx < 0 {
            return
        }

        let rhsType = varTypes[rhsIdx]
        if not g_moveOnlyClasses.contains(rhsType + "|") {
            return
        }

        emitMoveSourceNullifyImpl(output, varRegs[rhsIdx])
        g_movedVarNames = g_movedVarNames + rhsVarName + "|"
        g_movedVarCount = g_movedVarCount + 1
    }

    fun emitTriviallyCopyableAssignmentNote(varType: String) r: Void {
        if g_triviallyCopyableClasses != "" and g_triviallyCopyableClasses.contains(varType + "|") {
            emitTriviallyCopyableAssignmentNoteImpl(output, varType)
        }
    }

    // Handle assignment expression (from parser)
    fun generateAssignmentExpr(expr: ParserExpressionNode) r: Void {
        let varName = expr.variableName
        let idx = findVar(varName)

        if idx < 0 {
            tryGenerateFallbackAssignmentTarget(varName, expr.operands[0])
            return
        }

        emitLocalVariableAssignment(idx, expr.operands[0])
    }

    // Generate IR for a variable assignment statement (x = expr).
    // Finds the variable's alloca register via findVar and emits a store.
    // Handles compound assignments (+=, -=, *=, /=, %=, &=, |=, ^=, <<=, >>=)
    // by loading the current value, performing the operation, and storing back.
    fun generateAssignment(stmt: StatementNode) r: Void {
        let varName = stmt.variableName
        let idx = findVar(varName)

        if idx < 0 {
            tryGenerateFallbackAssignmentTarget(varName, stmt.initializer)
            return
        }

        let varType = varTypes[idx]
        emitDistinctAssignmentTypeWarning(varType, stmt.initializer)
        emitLocalVariableAssignment(idx, stmt.initializer)
        applyMoveAssignmentSemantics(stmt.initializer)
        emitTriviallyCopyableAssignmentNote(varType)
    }

    // Generate member assignment: a.b = value or a.b = value
    // Generate IR for a member assignment (obj.field = expr). Resolves the
    // receiver to a pointer, computes the GEP index for the field, generates
    // the value expression, and emits a store. For class-type receivers,
    // converts the i64 handle to ptr via inttoptr before GEP.
    fun emitResolvedMemberAssignment(receiverPtrReg: String, receiverType: String, fieldName: String,
        value: ParserExpressionNode, valueReg: String, allowBitfield: Int) r: Int {

        if receiverPtrReg == "" or receiverType == "" {
            return 0
        }

        let fieldTypes = resolveAssignmentFieldTypesImpl(receiverType, fieldName,
            structNames, structFieldNames, structFieldTypes, structLlvmFieldTypes,
            g_reprCClassNames, g_typeAliasNames, g_typeAliasTargets, g_typeAliasCount, g_enumTypeNames)
        if fieldTypes.length() < 2 or fieldTypes[1] == "" {
            return 0
        }

        if g_unionTypes != "" and g_unionTypes.contains(receiverType + "|") {
            emitUnionFieldStoreImpl(output, fieldTypes[0], valueReg, receiverPtrReg)
            return 1
        }

        let layoutInfo = resolveFieldAccessLayoutImpl(receiverType, fieldName, structNames, structLayouts, structFieldNames)
        let layoutParts = splitAssignmentLayoutInfoImpl(layoutInfo)
        let fieldIdx = parseSimpleInt(layoutParts[1])
        if fieldIdx < 0 {
            return 0
        }

        let fieldPtrReg = getNextReg()
        output.append("  " + fieldPtrReg + " = getelementptr inbounds " + layoutParts[0] + ", ptr " + receiverPtrReg + ", i32 0, i32 " + fieldIdx.toString() + "\n")

        if allowBitfield == 1 and g_bitfieldCount > 0 and fieldTypes[0] == "i64" {
            let bitfieldWidth = findBitfieldWidthImpl(receiverType + "." + fieldName, g_bitfieldKeys, g_bitfieldWidths)
            if bitfieldWidth > 0 {
                if tryEmitBitfieldAssignmentStoreImpl(output, g_regBox, fieldPtrReg, valueReg, bitfieldWidth) == 1 {
                    return 1
                }
            }
        }

        var valueIsStructLit = 0
        if value.kind == "StructLiteral" {
            valueIsStructLit = 1
        }
        var isDataField = 0
        if isDataType(fieldTypes[1]) {
            isDataField = 1
        }
        emitFieldStoreImpl(output, g_regBox, valueReg, fieldTypes[0], fieldPtrReg, valueIsStructLit, isDataField)
        return 1
    }

    fun tryGenerateExpressionReceiverMemberAssignment(receiverExpr: ParserExpressionNode,
        fieldName: String, value: ParserExpressionNode, valueReg: String) r: Int {

        let receiverReg = generateExpression(receiverExpr)
        let receiverType = inferExpressionType(receiverExpr)
        if receiverType == "" or receiverType == "Unknown" {
            return 0
        }

        let receiverPtrReg = prepareValueAssignmentReceiverPtrImpl(output, g_regBox,
            receiverReg, receiverType, g_reprCClassNames, structNames)
        return emitResolvedMemberAssignment(receiverPtrReg, receiverType, fieldName, value, valueReg, 0)
    }

    fun tryGenerateSimpleReceiverMemberAssignment(receiverName: String, fieldName: String,
        value: ParserExpressionNode, valueReg: String) r: Int {

        let varIdx = findVar(receiverName)
        output.append("; DEBUG generateMemberAssignment: varIdx=" + varIdx.toString() + "\n")
        if varIdx < 0 {
            return 0
        }

        let varReg = varRegs[varIdx]
        let varType = varTypes[varIdx]
        output.append("; DEBUG generateMemberAssignment: varType=" + varType + "\n")
        let receiverPtrReg = prepareVariableAssignmentReceiverPtrImpl(output, g_regBox, varReg, varType, structNames)
        return emitResolvedMemberAssignment(receiverPtrReg, varType, fieldName, value, valueReg, 1)
    }

    fun tryGenerateImplicitThisMemberAssignment(receiverName: String, fieldName: String,
        value: ParserExpressionNode, valueReg: String) r: Int {

        let thisIdx = findVar("this")
        if thisIdx < 0 {
            return 0
        }

        let thisReg = varRegs[thisIdx]
        let thisType = varTypes[thisIdx]
        let firstFieldType = getSeenFieldType(thisType, receiverName)
        if firstFieldType == "" {
            return 0
        }

        let thisPtrReg = getNextReg()
        output.append("  " + thisPtrReg + " = load ptr, ptr " + thisReg + "\n")

        var nestedPtrReg = ""
        if isClassType(firstFieldType) {
            let firstFieldValReg = generateFieldAccess(thisPtrReg, thisType, receiverName)
            let ptrConvReg = getNextReg()
            output.append("  " + ptrConvReg + " = inttoptr i64 " + firstFieldValReg + " to ptr\n")
            nestedPtrReg = ptrConvReg
        } else {
            nestedPtrReg = generateFieldAccessPtr(thisPtrReg, thisType, receiverName)
        }

        return emitResolvedMemberAssignment(nestedPtrReg, firstFieldType, fieldName, value, valueReg, 0)
    }

    fun generateMemberAssignment(expr: ParserExpressionNode) r: Void {
        let memberAccess = expr.operands[0]
        let value = expr.operands[1]
        let receiverName = memberAccess.literalValue
        let fieldName = memberAccess.variableName
        output.append("; DEBUG generateMemberAssignment: receiverName=" + receiverName + " fieldName=" + fieldName + "\n")

        let valueReg = generateExpression(value)

        if memberAccess.operands.length() > 0 and memberAccess.literalValue == "" {
            let receiverExpr = memberAccess.operands[0]
            if tryGenerateExpressionReceiverMemberAssignment(receiverExpr, fieldName, value, valueReg) == 1 {
                return
            }
            return
        }

        if receiverName.contains(".") {
            let receiverExpr = buildChainedPathExprImpl(receiverName)
            if receiverExpr.kind != "" {
                if tryGenerateExpressionReceiverMemberAssignment(receiverExpr, fieldName, value, valueReg) == 1 {
                    return
                }
            }
        }

        if tryGenerateSimpleReceiverMemberAssignment(receiverName, fieldName, value, valueReg) == 1 {
            return
        }
        tryGenerateImplicitThisMemberAssignment(receiverName, fieldName, value, valueReg)
    }

    // Generate index assignment: a[i] = value
    // Generate IR for an index assignment (arr[idx] = expr). Dispatches to
    // runtime helpers based on element type: seen_arr_set_str, seen_arr_set,
    // or type-specific variants. Also handles HashMap index assignment.
    fun generateIndexAssignment(expr: ParserExpressionNode) r: Void {
        let indexAccess = expr.operands[0]
        let value = expr.operands[1]
        let array = indexAccess.operands[0]
        let index = indexAccess.operands[1]

        let arrayReg = generateExpression(array)
        let indexReg = generateExpression(index)
        let valueReg = generateExpression(value)

        if g_boundsCheckEnabled == 1 {
            let labelSuffix = g_boundsCheckLabelCount.toString()
            g_boundsCheckLabelCount = g_boundsCheckLabelCount + 1
            emitIndexAssignmentBoundsCheckImpl(output, g_regBox, arrayReg, indexReg,
                "bounds_fail_" + labelSuffix, "bounds_ok_" + labelSuffix)
            cseClear()
        }

        let arrayType = inferExpressionType(array)
        var elementType = "ptr"
        if arrayType.startsWith("Array<") {
            elementType = arrayType.substring(6, arrayType.length() - 1)
        }
        let llvmElementType = mapType(elementType)

        if emitPrimitiveIndexAssignmentStoreImpl(output, g_regBox, arrayReg, indexReg, valueReg, elementType) == 1 {
            return
        }

        var valueIsStructLiteral = 0
        if value.kind == "StructLiteral" {
            valueIsStructLiteral = 1
        }
        emitGenericIndexAssignmentStoreImpl(output, g_regBox, arrayReg, indexReg, valueReg,
            elementType, llvmElementType, valueIsStructLiteral, structNames)
    }

    // Main expression codegen dispatcher. Returns the SSA register (or
    // immediate constant string) holding the expression's value.
    // Dispatches on expr.kind to specialized generators: Literal, Variable,
    // Binary, Call, MethodCall, Unary, Await, MemberAccess, IndexAccess,
    // StructLiteral, ArrayLiteral, StringInterpolation, Elvis/NullCoalesce,
    // SafeNavigation, WhenExpression, IfExpression, Cast, Closure, Lambda,
    // EnumVariant constructors, Result ? operator, etc.
    fun tryGenerateConstructionExpression(expr: ParserExpressionNode) r: String {
        if expr.kind == "StructLiteral" {
            return generateStructLiteral(expr)
        }
        if expr.kind == "ArrayLiteral" {
            return generateArrayLiteral(expr)
        }
        if expr.kind == "StringInterpolation" {
            return generateStringInterpolation(expr)
        }
        return ""
    }

    fun tryGenerateConditionalValueExpression(expr: ParserExpressionNode) r: String {
        if expr.kind == "Elvis" or expr.kind == "NullCoalesce" {
            return generateElvis(expr)
        }
        if expr.kind == "SafeNavigation" {
            return generateSafeNavigation(expr)
        }
        if expr.kind == "WhenExpression" {
            return generateWhenExpression(expr)
        }
        if expr.kind == "IfExpression" {
            return generateIfExpression(expr)
        }
        return ""
    }

    fun emitCastSpecialExpression(expr: ParserExpressionNode) r: String {
        let cSrcReg = generateExpression(expr.operands[0])
        let cSrcType = inferExpressionType(expr.operands[0])
        let cTgtType = expr.literalValue
        return emitCastExprImpl(output, g_regBox, cSrcReg, cSrcType, cTgtType)
    }

    fun emitIsExpressionTest(expr: ParserExpressionNode) r: String {
        let isSubjectReg = generateExpression(expr.operands[0])
        let isTypeName = expr.literalValue
        let isTagIdx = lookupEnumVariantTag(isTypeName)
        if isTagIdx >= 0 {
            let isTagLoad = getNextReg()
            output.append("  " + isTagLoad + " = load i64, ptr " + isSubjectReg + "\n")
            let isCmpReg = getNextReg()
            output.append("  " + isCmpReg + " = icmp eq i64 " + isTagLoad + ", " + isTagIdx.toString() + "\n")
            return isCmpReg
        }
        let isSubjectType = inferExpressionType(expr.operands[0])
        if isSubjectType == isTypeName {
            return "1"
        }
        return "0"
    }

    fun emitTryPropagateExpression(expr: ParserExpressionNode) r: String {
        let tryInnerReg = generateExpression(expr.operands[0])
        let tryInnerType = inferExpressionType(expr.operands[0])
        if tryInnerType.startsWith("Result") {
            let tryIsOkReg = getNextReg()
            output.append("  " + tryIsOkReg + " = icmp ne i64 " + tryInnerReg + ", 0\n")

            let tryLabelSuffix = g_regBox[0].toString()
            let tryOkLabel = "try.ok." + tryLabelSuffix
            let tryErrLabel = "try.err." + tryLabelSuffix

            output.append("  br i1 " + tryIsOkReg + ", label %" + tryOkLabel + ", label %" + tryErrLabel + "\n")

            output.append(tryErrLabel + ":\n")
            let tryRetType = mapType(currentFunctionReturnType)
            if tryRetType == "void" {
                output.append("  ret void\n")
            } else {
                output.append("  ret " + tryRetType + " 0\n")
            }

            output.append(tryOkLabel + ":\n")
            return tryInnerReg
        }
        return tryInnerReg
    }

    fun tryGenerateSpecialExpression(expr: ParserExpressionNode) r: String {
        if expr.kind == "Await" {
            return generateAwaitExpression(expr)
        }
        if expr.kind == "Unary" {
            return generateUnary(expr)
        }
        if expr.kind == "Cast" {
            return emitCastSpecialExpression(expr)
        }
        if expr.kind == "IsExpression" {
            return emitIsExpressionTest(expr)
        }
        if expr.kind == "Closure" {
            return generateClosure(expr)
        }
        if expr.kind == "TryPropagate" {
            return emitTryPropagateExpression(expr)
        }
        return ""
    }

    fun generateExpression(expr: ParserExpressionNode) r: String {
        if expr.kind == "Literal" {
            return generateLiteral(expr)
        }
        if expr.kind == "Variable" or expr.kind == "VarExpr" {
            return generateVariable(expr)
        }
        if expr.kind == "Binary" {
            return generateBinary(expr)
        }
        if expr.kind == "Call" {
            return generateCall(expr)
        }
        if expr.kind == "MethodCall" {
            return generateMethodCall(expr)
        }
        if expr.kind == "MemberAccess" {
            return generateMemberAccess(expr)
        }
        if expr.kind == "IndexAccess" {
            return generateIndexAccess(expr)
        }
        let constructionReg = tryGenerateConstructionExpression(expr)
        if constructionReg != "" {
            return constructionReg
        }
        let conditionalReg = tryGenerateConditionalValueExpression(expr)
        if conditionalReg != "" {
            return conditionalReg
        }
        let specialReg = tryGenerateSpecialExpression(expr)
        if specialReg != "" {
            return specialReg
        }
        return "0"
    }

    // Generate IR for an if-expression (if cond { a } else { b } used as a
    // value). Emits then/else blocks and a phi node to merge the result.
    // Supports multi-expression blocks separated by semicolons, where side
    // effects execute before the final expression provides the block value.
    fun emitIfExpressionSideEffects(expr: ParserExpressionNode, startIdx: Int, stopOnSentinel: Bool) r: Int {
        var sideIdx = startIdx
        while sideIdx < expr.arguments.length() {
            let sideExpr = expr.arguments[sideIdx]
            if stopOnSentinel and sideExpr.kind == "Sentinel" {
                return sideIdx + 1
            }
            generateExpression(sideExpr)
            sideIdx = sideIdx + 1
        }
        return sideIdx
    }

    fun emitIfExpressionBranchValue(branchExpr: ParserExpressionNode, branchLabelPrefix: String, mergeLabel: String) r: String {
        let branchReg = generateExpression(branchExpr)
        let phiLabel = branchLabelPrefix + ".end." + g_regBox[0].toString()
        output.append("  br label %" + phiLabel + "\n")
        output.append(phiLabel + ":\n")
        output.append("  br label %" + mergeLabel + "\n")
        return branchReg + "|" + phiLabel
    }

    fun emitPhiMergeValue(llvmType: String, thenReg: String, thenLabel: String, elseReg: String, elseLabel: String) r: String {
        let resultReg = getNextReg()
        output.append("  " + resultReg + " = phi " + llvmType + " [ " + thenReg + ", %" + thenLabel + " ], [ " + elseReg + ", %" + elseLabel + " ]\n")
        return resultReg
    }

    fun generateIfExpression(expr: ParserExpressionNode) r: String {
        // if-as-expression: if cond { thenExpr } else { elseExpr }
        // Generates SSA with phi node
        let condExpr = expr.operands[0]
        let thenExpr = expr.operands[1]
        let elseExpr = expr.operands[2]

        let condReg = generateExpression(condExpr)
        let condBool = emitConditionToI1Impl(output, g_regBox, condReg, inferIfConditionType(condExpr))

        let labelSuffix = g_regBox[0].toString()
        let thenLabel = "if.expr.then." + labelSuffix
        let elseLabel = "if.expr.else." + labelSuffix
        let mergeLabel = "if.expr.merge." + labelSuffix

        output.append("  br i1 " + condBool + ", label %" + thenLabel + ", label %" + elseLabel + "\n")

        // Generate then-branch side-effect expressions (before the value expression)
        output.append(thenLabel + ":\n")
        var ifSideIdx = emitIfExpressionSideEffects(expr, 0, true)
        let thenInfo = splitPipe(emitIfExpressionBranchValue(thenExpr, "if.expr.then", mergeLabel))
        let thenReg = thenInfo[0]
        let thenPhiLabel = thenInfo[1]

        // Generate else-branch side-effect expressions
        output.append(elseLabel + ":\n")
        emitIfExpressionSideEffects(expr, ifSideIdx, false)
        let elseInfo = splitPipe(emitIfExpressionBranchValue(elseExpr, "if.expr.else", mergeLabel))
        let elseReg = elseInfo[0]
        let elsePhiLabel = elseInfo[1]

        // Merge with phi
        output.append(mergeLabel + ":\n")
        let resultType = inferExpressionType(thenExpr)
        let irType = mapType(resultType)
        return emitPhiMergeValue(irType, thenReg, thenPhiLabel, elseReg, elsePhiLabel)
    }

    // Generate IR for a closure expression (|x| expr or |x, y| { ... }).
    // No-capture MVP: emits an anonymous `define` function, converts its
    // function pointer to i64 via ptrtoint, and returns the i64 handle.
    // Callers use inttoptr to convert back to a function pointer for indirect
    // calls. Closure definitions are accumulated in g_closureDefs and emitted
    // after all regular functions (to avoid forward-reference issues).
    fun generateClosure(expr: ParserExpressionNode) r: String {
        let closureId = g_closureCount
        g_closureCount = g_closureCount + 1
        let closureName = "__seen_closure_" + closureId.toString()

        // Build parameter list: all params are i64
        var paramList = ""
        var paramIdx = 0
        while paramIdx < expr.arguments.length() {
            if paramIdx > 0 { paramList = paramList + ", " }
            paramList = paramList + "i64 %__cp" + paramIdx.toString()
            paramIdx = paramIdx + 1
        }

        // Save codegen state
        let clSavedOutput = output
        let clSavedVarNames = varNames
        let clSavedVarRegs = varRegs
        let clSavedVarTypes = varTypes
        let clSavedPreAllocatedVars = preAllocatedVars
        let clSavedPreAllocatedTypes = preAllocatedTypes
        let clSavedPreAllocatedRegs = preAllocatedRegs
        let clSavedDeclOrdinalNames = declOrdinalNames
        let clSavedDeclOrdinalCounts = declOrdinalCounts
        let clSavedActiveVarCount = activeVarCount
        let clSavedNextReg = g_regBox[0]
        let clSavedBlockTerminated = blockTerminated
        let clSavedReturnType = currentFunctionReturnType

        // Generate closure function into a separate buffer
        output = StringBuilder.new()
        varNames = Array<String>()
        varRegs = Array<String>()
        varTypes = Array<String>()
        preAllocatedVars = Array<String>()
        preAllocatedTypes = Array<String>()
        preAllocatedRegs = Array<String>()
        declOrdinalNames = Array<String>()
        declOrdinalCounts = Array<Int>()
        activeVarCount = 0
        g_regBox[0] = 1
        blockTerminated = false
        currentFunctionReturnType = "Int"

        output.append("define i64 @" + quoteIdentIfNeeded(closureName) + "(" + paramList + ") {\n")
        output.append("entry:\n")

        // Bind params as local variables
        paramIdx = 0
        while paramIdx < expr.arguments.length() {
            let cpName = expr.arguments[paramIdx].literalValue
            let cpReg = "%__cp" + paramIdx.toString()
            let cpLocal = getNextReg()
            output.append("  " + cpLocal + " = alloca i64\n")
            output.append("  store i64 " + cpReg + ", ptr " + cpLocal + "\n")
            storeVar(cpName, cpLocal, "Int")
            paramIdx = paramIdx + 1
        }

        // Generate body expression
        let clBodyReg = generateExpression(expr.operands[0])
        if not blockTerminated {
            output.append("  ret i64 " + clBodyReg + "\n")
        }
        output.append("}\n\n")

        let closureDef = output.toString()
        g_closureDefs = g_closureDefs + closureDef

        // Restore codegen state
        output = clSavedOutput
        varNames = clSavedVarNames
        varRegs = clSavedVarRegs
        varTypes = clSavedVarTypes
        preAllocatedVars = clSavedPreAllocatedVars
        preAllocatedTypes = clSavedPreAllocatedTypes
        preAllocatedRegs = clSavedPreAllocatedRegs
        declOrdinalNames = clSavedDeclOrdinalNames
        declOrdinalCounts = clSavedDeclOrdinalCounts
        activeVarCount = clSavedActiveVarCount
        g_regBox[0] = clSavedNextReg
        blockTerminated = clSavedBlockTerminated
        currentFunctionReturnType = clSavedReturnType

        // Return function pointer as i64
        let clResultReg = getNextReg()
        output.append("  " + clResultReg + " = ptrtoint ptr @" + closureName + " to i64\n")
        return clResultReg
    }

    // Generate IR for an array literal [a, b, c]. Creates the array via
    // runtime helpers (seen_arr_new_str/int/float) to ensure element_size
    // is set correctly, then pushes each element. The element type is
    // resolved from pendingArrayLiteralType (set by the enclosing let/var
    // statement) or inferred from the first element.
    fun resolveArrayLiteralElementSeenType(elemExpr: ParserExpressionNode, defaultType: String) r: String {
        if defaultType != "" {
            return defaultType
        }
        if elemExpr.kind == "StructLiteral" and elemExpr.literalType != "" {
            return elemExpr.literalType
        }
        return inferExpressionType(elemExpr)
    }

    fun resolveArrayLiteralElementType(expr: ParserExpressionNode) r: String {
        if pendingArrayLiteralType != "" {
            let pendingElementType = extractArrayLiteralElementType(pendingArrayLiteralType)
            if pendingElementType != "" {
                return pendingElementType
            }
        }
        if expr.arguments.length() == 0 {
            return ""
        }
        return resolveArrayLiteralElementSeenType(expr.arguments[0], "")
    }

    fun emitArrayLiteralAllocation(elementType: String) r: String {
        let arrReg = getNextReg()
        if elementType == "String" {
            output.append("  " + arrReg + " = call ptr @seen_arr_new_str_ptr()\n")
        } else if isDataType(elementType) {
            let elementSize = getDataTypeSize(elementType)
            output.append("  " + arrReg + " = call ptr @seen_arr_new_with_size_ptr(i64 " + elementSize.toString() + ")\n")
        } else {
            output.append("  " + arrReg + " = call ptr @seen_arr_new_ptr_ptr()\n")
        }
        return arrReg
    }

    fun generateArrayLiteralElementValue(elemExpr: ParserExpressionNode, elementType: String) r: String {
        let savedElemPending = pendingArrayLiteralType
        pendingArrayLiteralType = ""
        if elemExpr.kind == "ArrayLiteral" and (elementType.startsWith("Array") or elementType.startsWith("List")) {
            pendingArrayLiteralType = elementType
        }
        let argReg = generateExpression(elemExpr)
        pendingArrayLiteralType = savedElemPending
        return argReg
    }

    fun emitArrayLiteralElementPush(arrReg: String, argReg: String, argType: String, argIsStructLiteral: Bool) r: Void {
        if argType == "String" {
            output.append("  call void @seen_arr_push_str(ptr " + arrReg + ", %SeenString " + argReg + ")\n")
            return
        }
        if argType == "Int" {
            output.append("  call void @seen_arr_push_i64(ptr " + arrReg + ", i64 " + argReg + ")\n")
            return
        }

        var ptrArgReg = argReg
        if ptrArgReg == "0" {
            ptrArgReg = "null"
        }
        if isClassType(argType) {
            let tmpClassReg = getNextReg()
            output.append("  " + tmpClassReg + " = alloca i64\n")
            output.append("  store i64 " + argReg + ", ptr " + tmpClassReg + "\n")
            ptrArgReg = tmpClassReg
        }
        if isDataType(argType) and not argIsStructLiteral {
            let tmpDataReg = getNextReg()
            output.append("  " + tmpDataReg + " = alloca %" + argType + "\n")
            output.append("  store %" + argType + " " + argReg + ", ptr " + tmpDataReg + "\n")
            ptrArgReg = tmpDataReg
        }
        let pushReg = getNextReg()
        output.append("  " + pushReg + " = call i64 @Array_push(ptr " + arrReg + ", ptr " + ptrArgReg + ")\n")
    }

    fun generateArrayLiteral(expr: ParserExpressionNode) r: String {
        let savedPendingType = pendingArrayLiteralType
        let elementType = resolveArrayLiteralElementType(expr)
        let arrReg = emitArrayLiteralAllocation(elementType)

        // Populate elements
        var elemIdx = 0
        while elemIdx < expr.arguments.length() {
            let elemExpr = expr.arguments[elemIdx]
            let argReg = generateArrayLiteralElementValue(elemExpr, elementType)
            let argType = resolveArrayLiteralElementSeenType(elemExpr, elementType)
            let argIsStructLiteral = elemExpr.kind == "StructLiteral"
            emitArrayLiteralElementPush(arrReg, argReg, argType, argIsStructLiteral)
            elemIdx = elemIdx + 1
        }

        pendingArrayLiteralType = savedPendingType
        return arrReg
    }

    // Generate IR for index access (arr[idx]). Dispatches to runtime helpers
    // based on element type: seen_arr_get_str for String arrays, seen_arr_get
    // for Int arrays (with bitcast i64->double for Float arrays). Supports
    // bounds checking when g_boundsCheckEnabled is set. Also handles HashMap
    // index access (hash_get_*) and String character access (seen_str_char_at).
    fun generateIndexAccess(expr: ParserExpressionNode) r: String {
        // operands[0] = array expression
        // operands[1] = index expression
        // Pointer index access: ptr[i] → load from (ptr + i*8)
        let idxBaseType = inferExpressionType(expr.operands[0])
        if idxBaseType.startsWith("*") {
            let piaBaseReg = generateExpression(expr.operands[0])
            let piaIdxReg = generateExpression(expr.operands[1])
            // Compute byte offset: index * 8 (i64 element size)
            let piaMulReg = getNextReg()
            output.append("  " + piaMulReg + " = mul i64 " + piaIdxReg + ", 8\n")
            let piaOffsetReg = getNextReg()
            output.append("  " + piaOffsetReg + " = call i64 @seen_ptr_add(i64 " + piaBaseReg + ", i64 " + piaMulReg + ", i64 1)\n")
            let piaPtrReg = getNextReg()
            output.append("  " + piaPtrReg + " = inttoptr i64 " + piaOffsetReg + " to ptr\n")
            let piaResultReg = getNextReg()
            output.append("  " + piaResultReg + " = load i64, ptr " + piaPtrReg + " ; ptr[i] access\n")
            return piaResultReg
        }
        // Operator overloading: check for operator_index method on non-array types
        if not idxBaseType.startsWith("Array<") and not idxBaseType.startsWith("List<") and not idxBaseType.startsWith("Vec<") and idxBaseType != "String" {
            let idxOpFunc = idxBaseType + "_operator_index"
            let idxOpRet = getFunctionReturnType(idxOpFunc)
            if idxOpRet != "" {
                let idxBaseReg = generateExpression(expr.operands[0])
                let idxIdxReg = generateExpression(expr.operands[1])
                let idxThisReg = getNextReg()
                output.append("  " + idxThisReg + " = inttoptr i64 " + idxBaseReg + " to ptr\n")
                let idxRetLlvm = mapType(idxOpRet)
                let idxResReg = getNextReg()
                output.append("  " + idxResReg + " = call " + idxRetLlvm + " @" + quoteIdentIfNeeded(idxOpFunc) + "(ptr " + idxThisReg + ", i64 " + idxIdxReg + ")\n")
                return idxResReg
            }
        }

        output.append("; DEBUG generateIndexAccess: operands[0].kind=" + expr.operands[0].kind + " variableName=" + expr.operands[0].variableName + " literalValue=" + expr.operands[0].literalValue + "\n")
        var arrayReg = generateExpression(expr.operands[0])
        output.append("; DEBUG arrayReg=" + arrayReg + "\n")
        let indexReg = generateExpression(expr.operands[1])

        // Workaround: if arrayReg is 0 and the variable name is 'statements',
        // try to find a BlockNode variable with that field
        if arrayReg == "0" and expr.operands[0].variableName == "statements" {
            output.append("; DEBUG trying to find BlockNode for statements\n")
            // Look for any local variable of type BlockNode
            var blockIdx = 0
            while blockIdx < varTypes.length() {
                if varTypes[blockIdx] == "BlockNode" {
                    let blockVarReg = varRegs[blockIdx]
                    // Load the block pointer
                    let blockPtrReg = getNextReg()
                    output.append("  " + blockPtrReg + " = load ptr, ptr " + blockVarReg + "\n")
                    // Access the statements field
                    arrayReg = generateFieldAccess(blockPtrReg, "BlockNode", "statements")
                    output.append("; DEBUG found BlockNode, arrayReg=" + arrayReg + "\n")
                    blockIdx = varTypes.length()  // break
                }
                blockIdx = blockIdx + 1
            }
        }

        // : Bounds checking on array access
        if g_boundsCheckEnabled == 1 {
            let bcFailLabel = "bounds_fail_" + g_boundsCheckLabelCount.toString()
            let bcOkLabel = "bounds_ok_" + g_boundsCheckLabelCount.toString()
            g_boundsCheckLabelCount = g_boundsCheckLabelCount + 1
            let lenPtrReg = getNextReg()
            output.append("  " + lenPtrReg + " = getelementptr inbounds %SeenArray, ptr " + arrayReg + ", i32 0, i32 0\n")
            let lenReg = getNextReg()
            output.append("  " + lenReg + " = load i64, ptr " + lenPtrReg + "\n")
            let oobReg = getNextReg()
            output.append("  " + oobReg + " = icmp uge i64 " + indexReg + ", " + lenReg + "\n")
            output.append("  br i1 " + oobReg + ", label %" + bcFailLabel + ", label %" + bcOkLabel + "\n")
            output.append(bcFailLabel + ":\n")
            output.append("  call void @seen_bounds_check(i64 " + indexReg + ", i64 " + lenReg + ")\n")
            output.append("  unreachable\n")
            output.append(bcOkLabel + ":\n")
            cseClear()
        }

        // Infer the element type from the array type
        let arrayType = inferExpressionType(expr.operands[0])
        output.append("; DEBUG arrayType=" + arrayType + "\n")

        // Both List<T> and Array<T> are ptr to SeenArray on heap - use pointer-based accessors
        // to avoid struct-by-value ABI issues between LLVM and C

        var resultReg = ""
        var handledArr = false

        // Use typed array get functions based on element type (pointer-based variants)
        if arrayType == "Array<String>" {
            resultReg = getNextReg()
            output.append("  " + resultReg + " = call %SeenString @seen_arr_get_str_ptr(ptr " + arrayReg + ", i64 " + indexReg + ")\n")
            handledArr = true
        }
        if not handledArr and arrayType == "Array<FrontendDiagnostic>" {
            let ptrResultReg = getNextReg()
            output.append("  " + ptrResultReg + " = call ptr @seen_arr_get_diag_ptr(ptr " + arrayReg + ", i64 " + indexReg + ")\n")
            // FrontendDiagnostic is a class type stored as i64, convert ptr to i64
            resultReg = getNextReg()
            output.append("  " + resultReg + " = ptrtoint ptr " + ptrResultReg + " to i64\n")
            handledArr = true
        }
        if not handledArr and arrayType == "Array<Int>" {
            // Inline array read: direct GEP to data pointer (field 3) then index
            // Eliminates function call overhead, enables vectorization and unrolling
            let dataPtrPtrReg = getNextReg()
            output.append("  " + dataPtrPtrReg + " = getelementptr inbounds %SeenArray, ptr " + arrayReg + ", i32 0, i32 3\n")
            let dataPtrReg = getNextReg()
            output.append("  " + dataPtrReg + " = load ptr, ptr " + dataPtrPtrReg + ", !tbaa !104\n")
            let elemPtrReg = getNextReg()
            output.append("  " + elemPtrReg + " = getelementptr inbounds nuw i64, ptr " + dataPtrReg + ", i64 " + indexReg + "\n")
            resultReg = getNextReg()
            output.append("  " + resultReg + " = load i64, ptr " + elemPtrReg + ", align 8, !tbaa !105\n")
            handledArr = true
        }
        if not handledArr and arrayType == "Array<Float>" {
            // Inline array read: direct GEP to data pointer (field 3) then index
            let dataPtrPtrReg = getNextReg()
            output.append("  " + dataPtrPtrReg + " = getelementptr inbounds %SeenArray, ptr " + arrayReg + ", i32 0, i32 3\n")
            let dataPtrReg = getNextReg()
            output.append("  " + dataPtrReg + " = load ptr, ptr " + dataPtrPtrReg + ", !tbaa !104\n")
            let elemPtrReg = getNextReg()
            output.append("  " + elemPtrReg + " = getelementptr inbounds nuw double, ptr " + dataPtrReg + ", i64 " + indexReg + "\n")
            resultReg = getNextReg()
            output.append("  " + resultReg + " = load double, ptr " + elemPtrReg + ", align 8, !tbaa !106\n")
            handledArr = true
        }
        if not handledArr and arrayType == "Array<ProgramNode>" {
            // ProgramNode is a class type, so convert ptr to i64
            let ptrResultReg = getNextReg()
            output.append("  " + ptrResultReg + " = call ptr @seen_arr_get_ptr_ptr(ptr " + arrayReg + ", i64 " + indexReg + ")\n")
            resultReg = getNextReg()
            output.append("  " + resultReg + " = ptrtoint ptr " + ptrResultReg + " to i64\n")
            handledArr = true
        }
        if not handledArr {
            // Extract element type from arrayType (e.g., "Array<TypeError>" -> "TypeError")
            var elementType = ""
            if arrayType.startsWith("Array<") and arrayType.endsWith(">") {
                elementType = arrayType.substring(6, arrayType.length() - 1)
            }

            // Choose the right getter based on element type (pointer-based variants)
            let ptrResultReg = getNextReg()
            if isDataType(elementType) {
                // Data types are stored inline - use seen_arr_get_element_ptr which uses element_size
                output.append("  " + ptrResultReg + " = call ptr @seen_arr_get_element_ptr(ptr " + arrayReg + ", i64 " + indexReg + ")\n")
                // Load the inline struct value
                resultReg = getNextReg()
                output.append("  " + resultReg + " = load %" + elementType + ", ptr " + ptrResultReg + "\n")
            } else if isClassType(elementType) {
                // Class types are stored as pointers - inline GEP for ptr-sized elements
                // Note: ptrResultReg already allocated above, but we can't use it out-of-order.
                // Instead, emit a dummy instruction and use new sequential registers.
                output.append("  " + ptrResultReg + " = getelementptr inbounds %SeenArray, ptr " + arrayReg + ", i32 0, i32 3\n")
                let clsDataPtr = getNextReg()
                output.append("  " + clsDataPtr + " = load ptr, ptr " + ptrResultReg + ", !tbaa !104\n")
                let clsElemPtr = getNextReg()
                output.append("  " + clsElemPtr + " = getelementptr inbounds ptr, ptr " + clsDataPtr + ", i64 " + indexReg + "\n")
                let clsLoadReg = getNextReg()
                output.append("  " + clsLoadReg + " = load ptr, ptr " + clsElemPtr + "\n")
                // Convert ptr to i64 for class types
                resultReg = getNextReg()
                output.append("  " + resultReg + " = ptrtoint ptr " + clsLoadReg + " to i64\n")
            } else {
                // Default: use element_ptr - SAFER because it works with any element_size
                // seen_arr_get_element_ptr uses the stored element_size for correct offset calculation
                output.append("  " + ptrResultReg + " = call ptr @seen_arr_get_element_ptr(ptr " + arrayReg + ", i64 " + indexReg + ")\n")
                resultReg = ptrResultReg
            }
        }

        return resultReg
    }

    fun shouldRebuildMemberAccessReceiver(receiverName: String) r: Int {
        if receiverName.contains("()") {
            return 1
        }
        if receiverName.contains(".") {
            let receiverSegments = splitChainedPathImpl(receiverName)
            if receiverSegments.length() > 0 and findVarType(receiverSegments[0]) != "" {
                return 1
            }
        }
        return 0
    }

    fun tryRebuildMemberAccessReceiver(expr: ParserExpressionNode, receiverName: String, fieldName: String) r: String {
        if expr.operands.length() > 0 or receiverName.contains("[") or shouldRebuildMemberAccessReceiver(receiverName) == 0 {
            return ""
        }
        let rebuiltReceiverExpr = buildChainedPathExprImpl(receiverName)
        if rebuiltReceiverExpr.kind == "None" {
            return ""
        }
        let rebuiltExpr = ParserExpressionNode.new()
        rebuiltExpr.kind = "MemberAccess"
        rebuiltExpr.variableName = fieldName
        rebuiltExpr.operands.push(rebuiltReceiverExpr)
        return generateMemberAccess(rebuiltExpr)
    }

    fun tryGenerateEnumMemberAccess(receiverName: String, fieldName: String) r: String {
        if g_enumVariantCount > 0 and isEnumVariant(fieldName) {
            let parentEnum = lookupEnumParent(fieldName)
            if parentEnum == receiverName {
                let varFieldCount = lookupEnumFieldCount(fieldName)
                if varFieldCount > 0 {
                    let enumExpr = ParserExpressionNode.new()
                    return generateEnumConstructor(fieldName, enumExpr)
                }
                return lookupEnumVariantTag(fieldName).toString()
            }
        }
        if receiverName == "SeenTokenType" {
            return getSeenTokenTypeValue(fieldName).toString()
        }
        return ""
    }

    fun tryGenerateSimdSwizzleMemberAccess(receiverName: String, fieldName: String) r: String {
        if receiverName == "" {
            return ""
        }
        let swzVarType = findVarType(receiverName)
        let swizzleType = inferSimdSwizzleMemberTypeImpl(swzVarType, fieldName)
        if swizzleType == "" {
            return ""
        }
        let swzIdx = findVar(receiverName)
        if swzIdx < 0 {
            return ""
        }
        return emitSimdSwizzleMemberAccessImpl(output, g_regBox, fieldName, mapType(swzVarType), varRegs[swzIdx])
    }

    fun tryGenerateExpressionReceiverMemberAccess(receiverExpr: ParserExpressionNode, fieldName: String) r: String {
        let receiverReg = generateExpression(receiverExpr)
        let receiverType = inferExpressionType(receiverExpr)
        var exprIsClass = 0
        if isClassType(receiverType) { exprIsClass = 1 }
        var exprIsData = 0
        if isDataType(receiverType) { exprIsData = 1 }
        let actualReceiverReg = prepareExpressionMemberReceiverImpl(output, g_regBox,
            receiverReg, receiverType, g_reprCClassNames, exprIsClass, exprIsData)
        return generateFieldAccess(actualReceiverReg, receiverType, fieldName)
    }

    fun tryGenerateVariableReceiverMemberAccess(receiverName: String, fieldName: String) r: String {
        let idx = findVar(receiverName)
        if idx < 0 {
            return ""
        }
        let varType = varTypes[idx]
        var varIsClass = 0
        if isClassType(varType) { varIsClass = 1 }
        var varIsData = 0
        if isDataType(varType) { varIsData = 1 }
        let actualVarReg = prepareVariableMemberReceiverImpl(output, g_regBox,
            varRegs[idx], varType, g_reprCClassNames, varIsClass, varIsData)
        return generateFieldAccess(actualVarReg, varType, fieldName)
    }

    fun tryGenerateModuleConstReceiverMemberAccess(receiverName: String, fieldName: String) r: String {
        let constIdx = findModuleConstant(receiverName)
        if constIdx < 0 {
            return ""
        }
        let constType = moduleConstantTypes[constIdx]
        var constSeenType = getModuleConstSeenType(constIdx)
        if constSeenType == "" {
            constSeenType = findVarType(receiverName)
        }
        var invSuffix = ""
        if not isModuleConstMutable(constIdx) {
            invSuffix = ", !invariant.load !190"
        }
        var constIsClass = 0
        if constSeenType != "" and isClassType(constSeenType) { constIsClass = 1 }
        var constIsData = 0
        if constSeenType != "" and isDataType(constSeenType) { constIsData = 1 }
        let actualConstReg = prepareModuleConstMemberReceiverImpl(output, g_regBox,
            "@" + quoteIdentIfNeeded(receiverName), constType, constSeenType, invSuffix, constIsClass, constIsData)
        if actualConstReg == "" {
            return ""
        }
        return generateFieldAccess(actualConstReg, constSeenType, fieldName)
    }

    fun tryGenerateBracketPathMemberAccess(receiverName: String, fieldName: String) r: String {
        if not receiverName.contains("[") {
            return ""
        }
        output.append("; DEBUG generateMemberAccess: handling array path=" + receiverName + " fieldName=" + fieldName + "\n")
        let bracketParts = splitBracketPathImpl(receiverName)
        if bracketParts.length() < 2 {
            return ""
        }
        let pathBeforeBracket = bracketParts[0]
        let indexStr = bracketParts[1]
        output.append("; DEBUG array path: pathBeforeBracket=" + pathBeforeBracket + " indexStr=" + indexStr + "\n")
        if not pathBeforeBracket.contains(".") {
            return ""
        }

        let pathParts = splitFirstPathDotImpl(pathBeforeBracket)
        let baseVar = pathParts[0]
        let arrayField = pathParts[1]
        output.append("; DEBUG array path split: baseVar=" + baseVar + " arrayField=" + arrayField + "\n")

        let baseIdx = findVar(baseVar)
        if baseIdx < 0 {
            return ""
        }

        let baseType = varTypes[baseIdx]
        var baseIsClass = 0
        if isClassType(baseType) { baseIsClass = 1 }
        var baseIsData = 0
        if isDataType(baseType) { baseIsData = 1 }
        let basePtrReg = prepareVariableMemberReceiverImpl(output, g_regBox,
            varRegs[baseIdx], baseType, g_reprCClassNames, baseIsClass, baseIsData)
        let arrayReg = generateFieldAccess(basePtrReg, baseType, arrayField)
        let arrayType = getSeenFieldType(baseType, arrayField)
        output.append("; DEBUG array access: arrayReg=" + arrayReg + " arrayType=" + arrayType + "\n")

        var elementType = parseArrayElementType(arrayType)
        if elementType == "" and arrayType.startsWith("Array<") and arrayType.endsWith(">") {
            elementType = arrayType.substring(6, arrayType.length() - 1)
        }

        let elementPtrReg = emitMemberArrayElementPtrImpl(output, g_regBox, arrayReg, indexStr)
        output.append("; DEBUG element access: elementPtrReg=" + elementPtrReg + " elementType=" + elementType + "\n")
        return generateFieldAccess(elementPtrReg, elementType, fieldName)
    }

    fun walkMemberAccessChainPointer(startPtrReg: String, startType: String, path: String) r: String {
        if path == "" {
            return startPtrReg
        }
        var chainPtr = startPtrReg
        var chainType = startType
        let pathSegments = splitChainedPathImpl(path)
        var chainIdx = 0
        while chainIdx < pathSegments.length() {
            let chainField = pathSegments[chainIdx]
            let chainFieldType = getSeenFieldType(chainType, chainField)
            output.append("; DEBUG chained ptr access: chainType=" + chainType + " chainField=" + chainField + " chainFieldType=" + chainFieldType + "\n")
            if isClassType(chainFieldType) {
                let loadedVal = generateFieldAccess(chainPtr, chainType, chainField)
                let convPtr = getNextReg()
                output.append("  " + convPtr + " = inttoptr i64 " + loadedVal + " to ptr\n")
                chainPtr = convPtr
            } else {
                chainPtr = generateFieldAccessPtr(chainPtr, chainType, chainField)
            }
            chainType = chainFieldType
            chainIdx = chainIdx + 1
        }
        return chainPtr
    }

    fun tryGenerateChainedReceiverMemberAccess(receiverName: String, fieldName: String) r: String {
        if not receiverName.contains(".") {
            return ""
        }
        let receiverParts = splitFirstPathDotImpl(receiverName)
        let baseVarName = receiverParts[0]
        let restPath = receiverParts[1]
        if restPath == "" {
            return ""
        }

        let baseIdx = findVar(baseVarName)
        if baseIdx < 0 {
            return ""
        }
        let baseType = varTypes[baseIdx]
        var baseIsClass = 0
        if isClassType(baseType) { baseIsClass = 1 }
        var baseIsData = 0
        if isDataType(baseType) { baseIsData = 1 }
        let basePtrReg = prepareVariableMemberReceiverImpl(output, g_regBox,
            varRegs[baseIdx], baseType, g_reprCClassNames, baseIsClass, baseIsData)

        output.append("; DEBUG generateMemberAccess: baseType=" + baseType + " restPath=" + restPath + " fieldName=" + fieldName + "\n")
        var intermediateType = resolveChainedPathSuffixTypeImpl(baseType, restPath,
            structNames, structFieldNames, structFieldTypes, structMethodNames, structMethodRetTypes)
        output.append("; DEBUG chained type final: intermediateType=" + intermediateType + "\n")
        if intermediateType == "" {
            intermediateType = "ProgramNode"
        }

        var actualIntermediateReg = ""
        if isClassType(intermediateType) {
            let intermediateReg = generateFieldAccess(basePtrReg, baseType, restPath)
            let ptrConvReg = getNextReg()
            output.append("  " + ptrConvReg + " = inttoptr i64 " + intermediateReg + " to ptr\n")
            actualIntermediateReg = ptrConvReg
        } else if restPath.contains(".") {
            actualIntermediateReg = walkMemberAccessChainPointer(basePtrReg, baseType, restPath)
        } else {
            actualIntermediateReg = generateFieldAccessPtr(basePtrReg, baseType, restPath)
        }

        return generateFieldAccess(actualIntermediateReg, intermediateType, fieldName)
    }

    fun tryGenerateImplicitThisReceiverMemberAccess(receiverName: String, fieldName: String) r: String {
        let thisIdx = findVar("this")
        if thisIdx < 0 {
            return ""
        }
        let thisType = varTypes[thisIdx]
        let fieldIdx = getFieldInfo(thisType, receiverName)
        if fieldIdx < 0 {
            return ""
        }

        let thisPtrReg = emitImplicitThisPointerLoadImpl(output, g_regBox, varRegs[thisIdx])
        let intermediateType = getSeenFieldType(thisType, receiverName)
        output.append("; DEBUG this field access: thisType=" + thisType + " receiverName=" + receiverName + " intermediateType=" + intermediateType + " fieldName=" + fieldName + "\n")

        var accessReg = ""
        if isClassType(intermediateType) {
            let intermediateReg = generateFieldAccess(thisPtrReg, thisType, receiverName)
            let ptrConvReg = getNextReg()
            output.append("  " + ptrConvReg + " = inttoptr i64 " + intermediateReg + " to ptr\n")
            accessReg = ptrConvReg
        } else {
            accessReg = generateFieldAccessPtr(thisPtrReg, thisType, receiverName)
        }

        return generateFieldAccess(accessReg, intermediateType, fieldName)
    }

    // Generate IR for member access (expr.field). Handles:
    //   - Array/String .length() — inline load from SeenArray.len field
    //   - Enum variant field access — load from heap offset (tag + fieldIdx*8)
    //   - Class field access — inttoptr receiver i64->ptr, then GEP + load
    //   - Data type field access — direct GEP on pointer
    //   - Chained access (a.b.c) — recursive resolution via generateFieldAccess
    fun generateMemberAccess(expr: ParserExpressionNode) r: String {
        let receiverName = expr.literalValue
        let fieldName = expr.variableName

        let rebuiltResult = tryRebuildMemberAccessReceiver(expr, receiverName, fieldName)
        if rebuiltResult != "" {
            return rebuiltResult
        }

        let enumResult = tryGenerateEnumMemberAccess(receiverName, fieldName)
        if enumResult != "" {
            return enumResult
        }

        let swizzleResult = tryGenerateSimdSwizzleMemberAccess(receiverName, fieldName)
        if swizzleResult != "" {
            return swizzleResult
        }

        if expr.operands.length() > 0 {
            return tryGenerateExpressionReceiverMemberAccess(expr.operands[0], fieldName)
        }

        let varResult = tryGenerateVariableReceiverMemberAccess(receiverName, fieldName)
        if varResult != "" {
            return varResult
        }

        let constResult = tryGenerateModuleConstReceiverMemberAccess(receiverName, fieldName)
        if constResult != "" {
            return constResult
        }

        let bracketResult = tryGenerateBracketPathMemberAccess(receiverName, fieldName)
        if bracketResult != "" {
            return bracketResult
        }

        let chainedResult = tryGenerateChainedReceiverMemberAccess(receiverName, fieldName)
        if chainedResult != "" {
            return chainedResult
        }

        let thisResult = tryGenerateImplicitThisReceiverMemberAccess(receiverName, fieldName)
        if thisResult != "" {
            return thisResult
        }

        return "0"
    }

    fun tryGenerateReprCFieldAccess(ptrReg: String, structType: String, fieldName: String) r: String {
        if g_reprCClassNames != "" and g_reprCClassNames.contains(structType + "|") {
            let structIdx = findStruct(structType)
            if structIdx >= 0 {
                let regFieldIdx = getFieldInfo(structType, fieldName)
                if regFieldIdx >= 0 {
                    let evReg = getNextReg()
                    output.append("  " + evReg + " = extractvalue %" + structType + " " + ptrReg + ", " + regFieldIdx.toString() + "\n")
                    return evReg
                }
            }
        }
        return ""
    }

    fun tryGenerateSpecialFieldAccessChain(ptrReg: String, structType: String, fieldName: String) r: String {
        if fieldName == "program.items" {
            let progReg = generateFieldAccess(ptrReg, structType, "program")
            let progPtrReg = getNextReg()
            output.append("  " + progPtrReg + " = inttoptr i64 " + progReg + " to ptr\n")
            return generateFieldAccess(progPtrReg, "ProgramNode", "items")
        }
        if fieldName == "program.items.length" {
            let progReg = generateFieldAccess(ptrReg, structType, "program")
            let progPtrReg = getNextReg()
            output.append("  " + progPtrReg + " = inttoptr i64 " + progReg + " to ptr\n")
            let itemsReg = generateFieldAccess(progPtrReg, "ProgramNode", "items")
            let lenPtrReg = emitFieldAccessPtrImpl(output, g_regBox, itemsReg, "%SeenArray", 0)
            return emitFieldAccessLoadImpl(output, g_regBox, "i64", lenPtrReg)
        }
        return ""
    }

    fun tryGenerateChainedFieldAccess(ptrReg: String, structType: String, fieldName: String) r: String {
        if not fieldName.contains(".") {
            return ""
        }
        let fieldParts = splitFirstPathDotImpl(fieldName)
        let firstField = fieldParts[0]
        let restFields = fieldParts[1]
        if restFields == "" {
            output.append("; ERROR: Unknown chained field access: " + fieldName + "\n")
            return "0"
        }

        let firstType = getSeenFieldType(structType, firstField)
        output.append("; DEBUG chained access: structType=" + structType + " firstField=" + firstField + " firstType=" + firstType + " restFields=" + restFields + "\n")

        var actualFirstReg = ""
        if isClassType(firstType) {
            let firstReg = generateFieldAccess(ptrReg, structType, firstField)
            let ptrConvReg = getNextReg()
            output.append("  " + ptrConvReg + " = inttoptr i64 " + firstReg + " to ptr\n")
            actualFirstReg = ptrConvReg
        } else {
            actualFirstReg = generateFieldAccessPtr(ptrReg, structType, firstField)
        }
        return generateFieldAccess(actualFirstReg, firstType, restFields)
    }

    fun tryGenerateUnionFieldAccess(ptrReg: String, structType: String, fieldName: String) r: String {
        if g_unionTypes != "" and g_unionTypes.contains(structType + "|") {
            return emitFieldAccessLoadImpl(output, g_regBox, getFieldType(structType, fieldName), ptrReg)
        }
        return ""
    }

    fun resolveFieldAccessLayoutInfo(structType: String, fieldName: String) r: String {
        let lb = "{"
        let rb = "}"
        if structType == "LLVMIRGenerator" {
            var idx = getLLVMIRGeneratorFieldIndex(fieldName)
            if idx < 0 {
                idx = 0
            }
            return lb + " i64, ptr, i64, i64, ptr, ptr, ptr, i64, i64, %SeenString, %SeenString, i1, %SeenString, %SeenString, ptr, ptr, %SeenString, ptr, ptr, i1, i1, %SeenString, ptr, ptr, ptr " + rb + "|" + idx.toString()
        }
        return resolveFieldAccessLayoutImpl(structType, fieldName, structNames, structLayouts, structFieldNames)
    }

    fun emitResolvedFieldAccessLoad(ptrReg: String, structType: String, fieldName: String) r: String {
        let layoutParts = splitPipe(resolveFieldAccessLayoutInfo(structType, fieldName))
        var structLayout = "{ i64 }"
        var fieldIndex = 0
        if layoutParts.length() >= 2 {
            structLayout = layoutParts[0]
            fieldIndex = parseIntManual(layoutParts[1])
        }
        let fieldPtrReg = emitFieldAccessPtrImpl(output, g_regBox, ptrReg, structLayout, fieldIndex)
        var resultReg = emitFieldAccessLoadImpl(output, g_regBox, getFieldType(structType, fieldName), fieldPtrReg)
        if g_bitfieldCount > 0 {
            let bitfieldWidth = findBitfieldWidthImpl(structType + "." + fieldName, g_bitfieldKeys, g_bitfieldWidths)
            if bitfieldWidth > 0 and bitfieldWidth < 64 {
                resultReg = emitBitfieldMaskLoadImpl(output, g_regBox, resultReg, bitfieldWidth)
            }
        }
        return resultReg
    }

    // Generate a struct field load via GEP (getelementptr). For simple fields,
    // emits: getelementptr %StructType, ptr %ptrReg, i32 0, i32 <fieldIdx>
    // followed by a load. For chained field access (e.g., "a.b.c"), recursively
    // resolves each segment, converting class-type intermediates from i64 to
    // ptr via inttoptr. For inline data types, uses generateFieldAccessPtr to
    // get a pointer without loading (avoids copying the entire struct).
    // WARNING: DO NOT use `!invariant.load` on array data pointers — array
    // data changes on push/resize, so the invariant annotation would be
    // incorrect and could cause LLVM to cache stale pointers.
    fun generateFieldAccess(ptrReg: String, structType: String, fieldName: String) r: String {
        let reprCResult = tryGenerateReprCFieldAccess(ptrReg, structType, fieldName)
        if reprCResult != "" {
            return reprCResult
        }

        let specialChainResult = tryGenerateSpecialFieldAccessChain(ptrReg, structType, fieldName)
        if specialChainResult != "" {
            return specialChainResult
        }

        let chainedResult = tryGenerateChainedFieldAccess(ptrReg, structType, fieldName)
        if chainedResult != "" {
            return chainedResult
        }

        let unionResult = tryGenerateUnionFieldAccess(ptrReg, structType, fieldName)
        if unionResult != "" {
            return unionResult
        }

        return emitResolvedFieldAccessLoad(ptrReg, structType, fieldName)
    }

    fun resolveFieldAccessPtrLayoutInfo(structType: String, fieldName: String) r: String {
        return resolveFieldAccessLayoutInfo(structType, fieldName)
    }

    // Same as generateFieldAccess but returns the GEP pointer without loading
    // Used for methods like push that need to modify the field in place
    fun generateFieldAccessPtr(ptrReg: String, structType: String, fieldName: String) r: String {
        if g_unionTypes != "" and g_unionTypes.contains(structType + "|") {
            return ptrReg
        }

        let layoutParts = splitPipe(resolveFieldAccessPtrLayoutInfo(structType, fieldName))
        var structLayout = "{ i64 }"
        var fieldIndex = 0
        if layoutParts.length() >= 2 {
            structLayout = layoutParts[0]
            fieldIndex = parseIntManual(layoutParts[1])
        }
        return emitFieldAccessPtrImpl(output, g_regBox, ptrReg, structLayout, fieldIndex)
    }

    // Generate IR for a struct literal expression (StructName { field: val, ... }).
    // Allocates the struct on the heap via malloc, memsets to zero, then stores
    // each field at its GEP offset. Data types use value semantics and return
    // the allocated pointer directly. Class values follow the current ABI and
    // are represented as pointer-as-i64 in expression results.
    fun inferStructLiteralFieldTypeFromValueExpr(valueExpr: ParserExpressionNode, sizeOut: Array<Int>) r: String {
        if valueExpr.kind == "StructLiteral" and valueExpr.literalType != "" {
            sizeOut[0] = 24
            return "%" + quoteIdentIfNeeded(valueExpr.literalType)
        }
        var fieldType = inferStructFieldTypeFromExpr(valueExpr, sizeOut)
        if valueExpr.kind == "MethodCall" {
            let calleeType = inferExpressionType(valueExpr)
            if isDataType(calleeType) {
                fieldType = "%" + quoteIdentIfNeeded(calleeType)
            }
        }
        return fieldType
    }

    fun buildInferredStructLiteralLayoutInfo(expr: ParserExpressionNode) r: String {
        let lb = "{"
        let rb = "}"
        var structSize = 0
        var layoutFields = ""
        var fieldI = 0
        while fieldI < expr.arguments.length() {
            if fieldI > 0 {
                layoutFields = layoutFields + ", "
            }
            var inferredFieldType = "i64"
            var fieldSize = 8
            let fieldExpr = expr.arguments[fieldI]
            if fieldExpr.operands.length() > 0 {
                let fieldSizeOut = Array<Int>()
                fieldSizeOut.push(8)
                inferredFieldType = inferStructLiteralFieldTypeFromValueExpr(fieldExpr.operands[0], fieldSizeOut)
                fieldSize = fieldSizeOut[0]
            }
            structSize = structSize + fieldSize
            layoutFields = layoutFields + inferredFieldType
            fieldI = fieldI + 1
        }
        return structSize.toString() + "|" + lb + " " + layoutFields + " " + rb
    }

    fun resolveStructLiteralLayoutInfo(expr: ParserExpressionNode, structName: String, structIdx: Int) r: String {
        if structIdx >= 0 {
            var structSize = structSizes[structIdx]
            if structSize < 8 {
                structSize = 8
            }
            return structSize.toString() + "|" + structLayouts[structIdx]
        }
        let knownLitLayout = resolveKnownStructFieldImpl(structName, "")
        if knownLitLayout != "" {
            var knownStructSize = getLlvmTypeSize(knownLitLayout)
            if knownStructSize < 8 {
                knownStructSize = 8
            }
            return knownStructSize.toString() + "|" + knownLitLayout
        }
        let inferredInfo = splitPipe(buildInferredStructLiteralLayoutInfo(expr))
        var inferredSize = inferredInfo[0].toInt()
        if inferredSize < 8 {
            inferredSize = 8
        }
        let inferredLayout = inferredInfo[1]
        println("[WARN] Unknown struct type '" + structName + "' - using inferred layout: " + inferredLayout + " size=" + inferredSize.toString())
        return inferredSize.toString() + "|" + inferredLayout
    }

    fun allocateStructLiteralStorage(structSize: Int) r: String {
        let mallocReg = getNextReg()
        if structSize <= 80 {
            output.append("  " + mallocReg + " = call ptr @seen_pool_alloc(i64 " + structSize.toString() + ")\n")
        }
        if structSize > 80 {
            output.append("  " + mallocReg + " = call ptr @malloc(i64 " + structSize.toString() + ")\n")
        }
        output.append("  ; escape-analysis: heap-to-stack candidate (" + structSize.toString() + " bytes)\n")
        return mallocReg
    }

    fun resolveStructLiteralFieldValue(structName: String, structIdx: Int, fieldName: String, fieldExpr: ParserExpressionNode) r: String {
        if fieldExpr.operands.length() == 0 {
            return "0"
        }
        let savedPendingType = pendingArrayLiteralType
        var fieldSeenType = ""
        if structIdx >= 0 {
            fieldSeenType = getSeenFieldType(structName, fieldName)
        }
        if fieldExpr.operands[0].kind == "ArrayLiteral" and (fieldSeenType.startsWith("Array") or fieldSeenType.startsWith("List")) {
            pendingArrayLiteralType = fieldSeenType
        }
        let valueReg = generateExpression(fieldExpr.operands[0])
        pendingArrayLiteralType = savedPendingType
        return valueReg
    }

    fun resolveStructLiteralFieldInfo(structName: String, structIdx: Int, fieldName: String, fieldExpr: ParserExpressionNode, defaultGepIndex: Int) r: String {
        var gepIndex = defaultGepIndex
        var fieldType = "i64"
        if structIdx >= 0 {
            let regFieldIdx = getFieldInfo(structName, fieldName)
            if regFieldIdx >= 0 {
                gepIndex = regFieldIdx
                fieldType = getFieldType(structName, fieldName)
                output.append("; DEBUG fieldType for " + structName + "." + fieldName + " = " + fieldType + "\n")
            }
            return fieldType + "|" + gepIndex.toString()
        }
        let knownFieldLayout = resolveKnownStructFieldImpl(structName, fieldName)
        if knownFieldLayout != "" {
            gepIndex = g_resolvedFieldIndex
            fieldType = decodeFieldTypeCode(g_resolvedFieldTypeCode)
            return fieldType + "|" + gepIndex.toString()
        }
        let fbGepBox = Array<Int>()
        fbGepBox.push(defaultGepIndex)
        let fbType = resolveStructLiteralFieldFallback(structName, fieldName, fbGepBox)
        if fbType != "" {
            gepIndex = fbGepBox[0]
            fieldType = fbType
            return fieldType + "|" + gepIndex.toString()
        }
        if fieldExpr.operands.length() > 0 {
            let fieldSizeOut = Array<Int>()
            fieldSizeOut.push(8)
            fieldType = inferStructLiteralFieldTypeFromValueExpr(fieldExpr.operands[0], fieldSizeOut)
        }
        return fieldType + "|" + gepIndex.toString()
    }

    fun generateStructLiteral(expr: ParserExpressionNode) r: String {
        let structName = expr.literalType
        let structIdx = findStruct(structName)
        let layoutInfo = splitPipe(resolveStructLiteralLayoutInfo(expr, structName, structIdx))
        let structSize = layoutInfo[0].toInt()
        let structLayout = layoutInfo[1]
        let mallocReg = allocateStructLiteralStorage(structSize)

        var slFieldRegs = Array<String>()
        var slFieldTypes = Array<String>()
        var slGepIndices = Array<Int>()
        var fieldIdx = 0
        while fieldIdx < expr.arguments.length() {
            let fieldExpr = expr.arguments[fieldIdx]
            let fieldName = fieldExpr.variableName
            slFieldRegs.push(resolveStructLiteralFieldValue(structName, structIdx, fieldName, fieldExpr))
            let fieldInfo = splitPipe(resolveStructLiteralFieldInfo(structName, structIdx, fieldName, fieldExpr, fieldIdx))
            let fieldType = fieldInfo[0]
            let gepIndex = fieldInfo[1].toInt()
            slFieldTypes.push(fieldType)
            slGepIndices.push(gepIndex)
            fieldIdx = fieldIdx + 1
        }

        emitStructFieldStoresImpl(output, g_regBox, structLayout, mallocReg, slFieldRegs, slFieldTypes, slGepIndices)

        if isClassType(structName) {
            let i64Reg = getNextReg()
            output.append("  " + i64Reg + " = ptrtoint ptr " + mallocReg + " to i64\n")
            return i64Reg
        }

        return mallocReg
    }

    // Thin wrapper: delegates to generateLiteralFree in ir_function_gen.seen,
    // then updates stats counters that aren't accessible from satellite modules.
    fun generateLiteral(expr: ParserExpressionNode) r: String {
        syncState()
        let litState = getSharedCodegenState()
        let litResult = generateLiteralFree(litState, expr)
        writeBackState()
        // Update stats counter (module-level, not accessible from satellite)
        if expr.literalType == "String" {
            if expr.literalValue.length() <= 15 {
                g_stringsDeduped = g_stringsDeduped + 1
                mlLogDecision("sso", "inlined", "len:" + expr.literalValue.length().toString())
            }
        }
        return litResult
    }

    // Generate IR for a variable reference. Looks up the variable in
    // varNames[] (via findVar, searching backwards for shadowing), then
    // emits a load from the alloca register. Falls back to module constants
    // (@global_name), enum variant tags (i64 constants), and 'this' field
    // access if the bare name matches a struct field on the current class.
    fun getExprVariableName(expr: ParserExpressionNode) r: String {
        return getExprVariableNameImpl(expr.variableName, expr.literalValue)
    }

    fun tryEmitMovedVariableRead(varName: String) r: Int {
        if g_movedVarCount > 0 and g_movedVarNames.contains(varName + "|") {
            emitMovedVariableUseTrapImpl(output, varName)
            return 1
        }
        return 0
    }

    fun tryGenerateComptimeVariable(varName: String) r: String {
        if g_comptimeCount > 0 {
            let ctVal = lookupComptimeVar(varName)
            if ctVal != -9999999 {
                return emitComptimeVariableLoadImpl(output, g_regBox, ctVal)
            }
        }
        return ""
    }

    fun tryGenerateImplicitThisVariable(varName: String) r: String {
        let thisIdx = findVar("this")
        if thisIdx < 0 {
            return ""
        }

        let thisReg = varRegs[thisIdx]
        let thisType = varTypes[thisIdx]
        if thisType == "LLVMIRGenerator" {
            let idxCheck = getLLVMIRGeneratorFieldIndex(varName)
            if idxCheck >= 0 {
                let thisPtrReg = emitImplicitThisPointerLoadImpl(output, g_regBox, thisReg)
                return generateFieldAccess(thisPtrReg, thisType, varName)
            }
        }

        let structIdx = findStruct(thisType)
        if structIdx < 0 {
            return ""
        }

        let fieldIdx = getFieldInfo(thisType, varName)
        if fieldIdx < 0 {
            return ""
        }

        let thisPtrReg = emitImplicitThisPointerLoadImpl(output, g_regBox, thisReg)
        return generateFieldAccess(thisPtrReg, thisType, varName)
    }

    fun tryGenerateFallbackVariable(varName: String) r: String {
        let constIdx = findModuleConstant(varName)
        if constIdx >= 0 {
            var invSuffix = ""
            if not isModuleConstMutable(constIdx) {
                invSuffix = ", !invariant.load !190"
            }
            return emitModuleConstantLoadImpl(output, g_regBox,
                "@" + varName, moduleConstantTypes[constIdx], invSuffix)
        }

        let implicitThisReg = tryGenerateImplicitThisVariable(varName)
        if implicitThisReg != "" {
            return implicitThisReg
        }

        let fpRetType = getFunctionReturnType(varName)
        if fpRetType != "" {
            return emitFunctionPointerInteropLoadImpl(output, g_regBox,
                "@" + quoteIdentIfNeeded(varName))
        }
        return ""
    }

    fun generateVariable(expr: ParserExpressionNode) r: String {
        let varName = getExprVariableName(expr)
        if varName == "" {
            return "0"
        }

        if tryEmitMovedVariableRead(varName) == 1 {
            return "0"
        }

        let ctReg = tryGenerateComptimeVariable(varName)
        if ctReg != "" {
            return ctReg
        }

        let idx = findVar(varName)
        if idx < 0 {
            let fallbackReg = tryGenerateFallbackVariable(varName)
            if fallbackReg != "" {
                return fallbackReg
            }
            return "0"
        }

        return emitLocalVariableLoadImpl(output, g_regBox,
            mapType(varTypes[idx]), varRegs[idx])
    }

    // Generate IR for a binary expression (+, -, *, /, %, ==, !=, <, >, etc.).
    // Type-dispatches: SIMD vector arithmetic, float operations (fadd/fsub/...),
    // string concatenation (seen_str_concat_ss), integer arithmetic, comparison
    // operators, bitwise ops, and short-circuit &&/||.
    // Includes constant folding for integer-literal operands via foldIntConstants.
    // Supports overflow-checked arithmetic when g_panicOnOverflow is set
    // (uses llvm.sadd.with.overflow intrinsics). Delegates to emitBinaryOpImpl
    // for the core LLVM instruction emission.
    fun generateBinary(expr: ParserExpressionNode) r: String {
        let leftExpr = expr.operands[0]
        let rightExpr = expr.operands[1]

        let leftType = inferExpressionType(leftExpr)
        let rightType = inferExpressionType(rightExpr)

        // --- Pointer arithmetic ---
        if leftType.startsWith("*") and (expr.operator == "+" or expr.operator == "-") {
            let paLeftReg = generateExpression(leftExpr)
            let paRightReg = generateExpression(rightExpr)
            let paResult = emitPointerArithmeticBinaryImpl(output, g_regBox,
                expr.operator, leftType, rightType, paLeftReg, paRightReg)
            if paResult != "" {
                return paResult
            }
        }

        // --- SIMD vector arithmetic ---
        let simdBinaryOp = expr.operator == "+" or expr.operator == "-" or expr.operator == "*" or expr.operator == "/" or
            expr.operator == "==" or expr.operator == "!=" or expr.operator == "<" or expr.operator == ">" or
            expr.operator == "<=" or expr.operator == ">="
        if isSimdVectorType(leftType) == 1 and simdBinaryOp {
            let simdLlvmType = mapType(leftType)
            let simdLeftReg = generateExpression(leftExpr)
            let simdRightReg = generateExpression(rightExpr)
            let simdResult = emitSimdBinaryExprImpl(output, g_regBox,
                expr.operator, leftType, simdLlvmType, simdLeftReg, simdRightReg)
            if simdResult != "" {
                return simdResult
            }
        }

        // --- E-graph peephole optimizations (consolidated via egraph lookup) ---
        // Integer peephole rules
        if leftType == "Int" and rightType == "Int" {
            let leftIsIntLit = leftExpr.kind == "Literal" and leftExpr.literalType == "Int"
            let rightIsIntLit = rightExpr.kind == "Literal" and rightExpr.literalType == "Int"
            let leftLitVal = leftExpr.literalValue
            let rightLitVal = rightExpr.literalValue

            // Self-comparison: both sides are the same variable (not a call)
            if leftExpr.kind == "Variable" and rightExpr.kind == "Variable" {
                if leftExpr.literalValue == rightExpr.literalValue {
                    let selfAction = egraphSelfComparison(expr.operator)
                    if selfAction == "const:0" {
                        g_constantsFolded = g_constantsFolded + 1
                        mlLogDecision("e-graph", "self-opt", leftExpr.literalValue + expr.operator + leftExpr.literalValue + "=0")
                        let selfReg = getNextReg()
                        output.append("  " + selfReg + " = add i64 0, 0 ; e-graph: x " + expr.operator + " x -> 0\n")
                        return selfReg
                    }
                    if selfAction == "const:1" {
                        g_constantsFolded = g_constantsFolded + 1
                        mlLogDecision("e-graph", "self-opt", leftExpr.literalValue + expr.operator + leftExpr.literalValue + "=1")
                        let selfReg = getNextReg()
                        output.append("  " + selfReg + " = add i64 1, 0 ; e-graph: x " + expr.operator + " x -> 1\n")
                        return selfReg
                    }
                    if selfAction == "identity_left" {
                        return generateExpression(leftExpr)
                    }
                    if selfAction == "const_true" {
                        g_constantsFolded = g_constantsFolded + 1
                        let selfReg = getNextReg()
                        output.append("  " + selfReg + " = add i1 1, 0 ; e-graph: x " + expr.operator + " x -> true\n")
                        return selfReg
                    }
                    if selfAction == "const_false" {
                        g_constantsFolded = g_constantsFolded + 1
                        let selfReg = getNextReg()
                        output.append("  " + selfReg + " = add i1 0, 0 ; e-graph: x " + expr.operator + " x -> false\n")
                        return selfReg
                    }
                }
            }

            // E-graph lookup for literal-based rules — delegated to ir_optimization.seen
            let action = egraphLookup(expr.operator, leftLitVal, rightLitVal, leftIsIntLit, rightIsIntLit)
            if action == "identity_left" {
                return generateExpression(leftExpr)
            }
            if action == "identity_right" {
                return generateExpression(rightExpr)
            }
            if action != "" {
                if action.startsWith("const:") {
                    g_constantsFolded = g_constantsFolded + 1
                    mlLogDecision("e-graph", "folded", expr.operator + "=" + action)
                }
                // For non-const actions, generate left operand (all remaining actions use leftReg)
                var egLeftReg = ""
                if not action.startsWith("const:") {
                    egLeftReg = generateExpression(leftExpr)
                }
                let egResult = emitEgraphPeepholeImpl(output, g_regBox, action, egLeftReg, "", expr.operator)
                if egResult != "" {
                    return egResult
                }
            }

            // Associative rewrite: (a + CONST1) + CONST2 → a + (CONST1+CONST2)
            if expr.operator == "+" and rightIsIntLit {
                if leftExpr.kind == "Binary" and leftExpr.operator == "+" {
                    if leftExpr.operands.length() >= 2 {
                        let innerRight = leftExpr.operands[1]
                        if innerRight.kind == "Literal" and innerRight.literalType == "Int" {
                            let combinedVal = foldIntConstants(innerRight.literalValue, rightLitVal, "+")
                            if combinedVal != "" {
                                let origCost = exprCost(expr) + exprCost(leftExpr)
                                let rewriteCost = exprCost(leftExpr.operands[0]) + 3 + 1
                                if rewriteCost <= origCost {
                                    g_constantsFolded = g_constantsFolded + 1
                                    mlLogDecision("e-graph", "assoc-fold", innerRight.literalValue + "+" + rightLitVal + "=" + combinedVal)
                                    let innerLeftReg = generateExpression(leftExpr.operands[0])
                                    let assocResultReg = getNextReg()
                                    output.append("  " + assocResultReg + " = add i64 " + innerLeftReg + ", " + combinedVal + " ; e-graph: (a+C1)+C2 -> a+(C1+C2)\n")
                                    return assocResultReg
                                }
                            }
                        }
                    }
                }
            }
            // Associative rewrite: (a * CONST1) * CONST2 → a * (CONST1*CONST2)
            if expr.operator == "*" and rightIsIntLit {
                if leftExpr.kind == "Binary" and leftExpr.operator == "*" {
                    if leftExpr.operands.length() >= 2 {
                        let innerRightMul = leftExpr.operands[1]
                        if innerRightMul.kind == "Literal" and innerRightMul.literalType == "Int" {
                            let combinedMulVal = foldIntConstants(innerRightMul.literalValue, rightLitVal, "*")
                            if combinedMulVal != "" {
                                let origMulCost = exprCost(expr) + exprCost(leftExpr)
                                let rewriteMulCost = exprCost(leftExpr.operands[0]) + 5 + 1
                                if rewriteMulCost <= origMulCost {
                                    g_constantsFolded = g_constantsFolded + 1
                                    mlLogDecision("e-graph", "assoc-fold", innerRightMul.literalValue + "*" + rightLitVal + "=" + combinedMulVal)
                                    let innerLeftMulReg = generateExpression(leftExpr.operands[0])
                                    let assocMulResultReg = getNextReg()
                                    output.append("  " + assocMulResultReg + " = mul nsw i64 " + innerLeftMulReg + ", " + combinedMulVal + " ; e-graph: (a*C1)*C2 -> a*(C1*C2)\n")
                                    return assocMulResultReg
                                }
                            }
                        }
                    }
                }
            }
            // Comparison of two integer literals: fold at compile time
            if leftIsIntLit and rightIsIntLit {
                let cmpResult = foldIntComparison(leftLitVal, rightLitVal, expr.operator)
                if cmpResult != "" {
                    g_constantsFolded = g_constantsFolded + 1
                    g_branchesEliminated = g_branchesEliminated + 1
                    mlLogDecision("const-fold", "cmp-folded", leftLitVal + expr.operator + rightLitVal + "=" + cmpResult)
                    let cmpFoldReg = getNextReg()
                    if cmpResult == "true" {
                        output.append("  " + cmpFoldReg + " = add i1 1, 0 ; constant-folded comparison\n")
                    } else {
                        output.append("  " + cmpFoldReg + " = add i1 0, 0 ; constant-folded comparison\n")
                    }
                    return cmpFoldReg
                }
            }
            // Constant folding: both operands are IntLiteral → compute at compile time
            if leftIsIntLit and rightIsIntLit {
                let folded = foldIntConstants(leftLitVal, rightLitVal, expr.operator)
                if folded != "" {
                    g_constantsFolded = g_constantsFolded + 1
                    mlLogDecision("const-fold", "folded", leftLitVal + expr.operator + rightLitVal + "=" + folded)
                    let foldResultReg = getNextReg()
                    output.append("  " + foldResultReg + " = add i64 " + folded + ", 0 ; constant-folded\n")
                    return foldResultReg
                }
            }
        }
        // Float peephole optimizations — delegated to ir_optimization.seen
        if leftType == "Float" and rightType == "Float" {
            let fLeftIsLit = leftExpr.kind == "Literal" and leftExpr.literalType == "Float"
            let fRightIsLit = rightExpr.kind == "Literal" and rightExpr.literalType == "Float"
            let fLeftLitVal = leftExpr.literalValue
            let fRightLitVal = rightExpr.literalValue
            let fAction = egraphLookupFloat(expr.operator, fLeftLitVal, fRightLitVal, fLeftIsLit, fRightIsLit)
            if fAction == "identity_left" {
                return generateExpression(leftExpr)
            }
            if fAction == "identity_right" {
                return generateExpression(rightExpr)
            }
            if fAction != "" {
                if fAction.startsWith("fconst:") {
                    g_constantsFolded = g_constantsFolded + 1
                }
                // Generate left/right operands as needed by the action
                var fgLeftReg = ""
                var fgRightReg = ""
                if fAction == "fneg" or fAction == "fneg_right" {
                    fgRightReg = generateExpression(rightExpr)
                }
                if fAction != "fneg" and fAction != "fneg_right" and not fAction.startsWith("fconst:") {
                    fgLeftReg = generateExpression(leftExpr)
                }
                let fResult = emitEgraphFloatPeepholeImpl(output, g_regBox, fAction, fgLeftReg, fgRightReg, expr.operator)
                if fResult != "" {
                    return fResult
                }
            }
        }
        // FMA detection: a + (b * c) or (a * b) + c → llvm.fmuladd.f64
        // NOTE: Int operands must be promoted to double via sitofp before use.
        if expr.operator == "+" and (leftType == "Float" or rightType == "Float") {
            // Check if right operand is a float multiply
            if rightExpr.kind == "Binary" and rightExpr.operator == "*" {
                let rLeftType = inferExpressionType(rightExpr.operands[0])
                let rRightType = inferExpressionType(rightExpr.operands[1])
                if rLeftType == "Float" or rRightType == "Float" {
                    var fmaAReg = generateExpression(rightExpr.operands[0])
                    if rLeftType != "Float" {
                        let cvtA = getNextReg()
                        output.append("  " + cvtA + " = sitofp i64 " + fmaAReg + " to double\n")
                        fmaAReg = cvtA
                    }
                    var fmaBReg = generateExpression(rightExpr.operands[1])
                    if rRightType != "Float" {
                        let cvtB = getNextReg()
                        output.append("  " + cvtB + " = sitofp i64 " + fmaBReg + " to double\n")
                        fmaBReg = cvtB
                    }
                    var fmaCReg = generateExpression(leftExpr)
                    if leftType != "Float" {
                        let cvtC = getNextReg()
                        output.append("  " + cvtC + " = sitofp i64 " + fmaCReg + " to double\n")
                        fmaCReg = cvtC
                    }
                    let fmaResultReg = getNextReg()
                    output.append("  " + fmaResultReg + " = call double @llvm.fmuladd.f64(double " + fmaAReg + ", double " + fmaBReg + ", double " + fmaCReg + ") ; FMA: c + a*b\n")
                    return fmaResultReg
                }
            }
            // Check if left operand is a float multiply
            if leftExpr.kind == "Binary" and leftExpr.operator == "*" {
                let lLeftType = inferExpressionType(leftExpr.operands[0])
                let lRightType = inferExpressionType(leftExpr.operands[1])
                if lLeftType == "Float" or lRightType == "Float" {
                    var fmaAReg = generateExpression(leftExpr.operands[0])
                    if lLeftType != "Float" {
                        let cvtA = getNextReg()
                        output.append("  " + cvtA + " = sitofp i64 " + fmaAReg + " to double\n")
                        fmaAReg = cvtA
                    }
                    var fmaBReg = generateExpression(leftExpr.operands[1])
                    if lRightType != "Float" {
                        let cvtB = getNextReg()
                        output.append("  " + cvtB + " = sitofp i64 " + fmaBReg + " to double\n")
                        fmaBReg = cvtB
                    }
                    var fmaCReg = generateExpression(rightExpr)
                    if rightType != "Float" {
                        let cvtC = getNextReg()
                        output.append("  " + cvtC + " = sitofp i64 " + fmaCReg + " to double\n")
                        fmaCReg = cvtC
                    }
                    let fmaResultReg = getNextReg()
                    output.append("  " + fmaResultReg + " = call double @llvm.fmuladd.f64(double " + fmaAReg + ", double " + fmaBReg + ", double " + fmaCReg + ") ; FMA: a*b + c\n")
                    return fmaResultReg
                }
            }
        }
        // --- End peephole optimizations ---

        // Short-circuit logical operators (must evaluate before eager left/right eval)
        if expr.operator == "and" {
            return generateShortCircuitAnd(expr)
        }
        if expr.operator == "or" {
            return generateShortCircuitOr(expr)
        }

        let leftReg = generateExpression(leftExpr)
        let rightReg = generateExpression(rightExpr)

        // CSE within function scope: re-enabled for pure int/float binary ops.
        // Cache is cleared at function entry and block boundaries (safe with dominance).
        if (leftType == "Int" or leftType == "Float") and (rightType == "Int" or rightType == "Float") {
            let isPureBinOp = expr.operator == "+" or expr.operator == "-" or expr.operator == "*" or expr.operator == "/"
            if isPureBinOp {
                let cseKey = leftReg + expr.operator + rightReg
                let cseCached = cseLookup(cseKey)
                if cseCached != "" {
                    mlLogDecision("cse", "hit", cseKey)
                    return cseCached
                }
            }
        }

        // Note: resultReg must be allocated AFTER any intermediate conversion registers
        // to maintain SSA sequential numbering

        // --- Operator overloading dispatch ---
        let opMethodSuffix = binaryOperatorMethodSuffixImpl(expr.operator)
        if opMethodSuffix != "" {
            let opFuncName = leftType + "_" + opMethodSuffix
            let opRetType = getFunctionReturnType(opFuncName)
            if opRetType != "" {
                let opRetLlvm = mapType(opRetType)
                return emitOverloadedBinaryCallImpl(output, g_regBox,
                    quoteIdentIfNeeded(opFuncName), opRetLlvm, leftReg, rightReg)
            }
        }
        // --- End operator overloading ---

        // Delegate to extracted binary op impl
        var boundsBox = Array<Int>()
        boundsBox.push(g_boundsCheckLabelCount)
        var cseSig = Array<Int>()
        cseSig.push(0)
        var panicFlag = 0
        if g_panicOnOverflow { panicFlag = 1 }
        let leftMT = mapType(leftType)
        let resultReg = emitBinaryOpImpl(output, g_regBox, boundsBox, cseSig,
            expr.operator, leftReg, rightReg, leftType, rightType,
            leftExpr.kind, leftExpr.literalValue, leftExpr.variableName,
            rightExpr.kind, rightExpr.literalValue,
            panicFlag, g_inductionVarName, leftMT)
        g_boundsCheckLabelCount = boundsBox[0]
        if cseSig[0] == 1 { cseClear() }

        // CSE recording for pure int/float binary ops (within function scope only)
        if (leftType == "Int" or leftType == "Float") and (rightType == "Int" or rightType == "Float") {
            let isPureBinOp2 = expr.operator == "+" or expr.operator == "-" or expr.operator == "*" or expr.operator == "/"
            if isPureBinOp2 {
                let cseKey2 = leftReg + expr.operator + rightReg
                cseRecord(cseKey2, resultReg)
            }
        }

        return resultReg
    }

    // Helper: check if an expression produces i1 (bool) rather than i64
    fun isExprBool(e: ParserExpressionNode, eType: String) r: Int {
        return exprProducesBoolImpl(eType, e.operator)
    }

    // Short-circuit AND: left ? right : false
    // Uses bridge blocks so phi predecessors are always correct even with nested and/or
    // Generate short-circuit evaluation for logical AND (&&).
    // If the left operand is false, skips evaluating the right operand
    // entirely. Uses a phi node to merge the boolean result from both paths.
    fun generateShortCircuitAnd(expr: ParserExpressionNode) r: String {
        let leftExpr = expr.operands[0]
        let rightExpr = expr.operands[1]
        let leftType = inferExpressionType(leftExpr)
        let rightType = inferExpressionType(rightExpr)

        let checkLabel = getNextBlockLabel()
        let rightLabel = getNextBlockLabel()
        let doneLabel = getNextBlockLabel()
        let mergeLabel = getNextBlockLabel()

        // Evaluate left side (may emit multiple blocks for nested and/or)
        let leftReg = generateExpression(leftExpr)

        // Bridge to known block for phi correctness
        output.append("  br label %" + checkLabel + "\n")
        output.append(checkLabel + ":\n")
        cseClear()

        // Convert left to i1 if needed
        let leftBool = emitBoolCoercionImpl(output, g_regBox, leftReg, leftType, leftExpr.operator)

        // If left is true, evaluate right; otherwise skip to merge with false
        output.append("  br i1 " + leftBool + ", label %" + rightLabel + ", label %" + mergeLabel + "\n")

        // Right side block
        output.append(rightLabel + ":\n")
        cseClear()
        let rightReg = generateExpression(rightExpr)

        // Bridge to known block after right evaluation
        output.append("  br label %" + doneLabel + "\n")
        output.append(doneLabel + ":\n")
        cseClear()

        // Convert right to i1 if needed
        let rightBool = emitBoolCoercionImpl(output, g_regBox, rightReg, rightType, rightExpr.operator)

        output.append("  br label %" + mergeLabel + "\n")

        // Merge block with phi
        cseClear()
        return emitShortCircuitPhiImpl(output, g_regBox, mergeLabel, "false", checkLabel, rightBool, doneLabel)
    }

    // Short-circuit OR: left ? true : right
    // Uses bridge blocks so phi predecessors are always correct even with nested and/or
    // Generate short-circuit evaluation for logical OR (||).
    // If the left operand is true, skips evaluating the right operand.
    fun generateShortCircuitOr(expr: ParserExpressionNode) r: String {
        let leftExpr = expr.operands[0]
        let rightExpr = expr.operands[1]
        let leftType = inferExpressionType(leftExpr)
        let rightType = inferExpressionType(rightExpr)

        let checkLabel = getNextBlockLabel()
        let rightLabel = getNextBlockLabel()
        let doneLabel = getNextBlockLabel()
        let mergeLabel = getNextBlockLabel()

        // Evaluate left side (may emit multiple blocks for nested and/or)
        let leftReg = generateExpression(leftExpr)

        // Bridge to known block for phi correctness
        output.append("  br label %" + checkLabel + "\n")
        output.append(checkLabel + ":\n")
        cseClear()

        // Convert left to i1 if needed
        let leftBool = emitBoolCoercionImpl(output, g_regBox, leftReg, leftType, leftExpr.operator)

        // If left is true, skip to merge with true; otherwise evaluate right
        output.append("  br i1 " + leftBool + ", label %" + mergeLabel + ", label %" + rightLabel + "\n")

        // Right side block
        output.append(rightLabel + ":\n")
        cseClear()
        let rightReg = generateExpression(rightExpr)

        // Bridge to known block after right evaluation
        output.append("  br label %" + doneLabel + "\n")
        output.append(doneLabel + ":\n")
        cseClear()

        // Convert right to i1 if needed
        let rightBool = emitBoolCoercionImpl(output, g_regBox, rightReg, rightType, rightExpr.operator)

        output.append("  br label %" + mergeLabel + "\n")

        // Merge block with phi
        cseClear()
        return emitShortCircuitPhiImpl(output, g_regBox, mergeLabel, "true", checkLabel, rightBool, doneLabel)
    }

    fun applyComptimeParamSpecialization(funcName: String, expr: ParserExpressionNode) r: Void {
        if g_comptimeParamCount <= 0 {
            return
        }

        // Check if this function has comptime params
        var ctpSearchPos = 0
        while ctpSearchPos < g_comptimeParamFuncNames.length() {
            var ctpNextPipe = g_comptimeParamFuncNames.indexOf("|", ctpSearchPos)
            if ctpNextPipe < 0 { ctpNextPipe = g_comptimeParamFuncNames.length() }
            let ctpEntry = g_comptimeParamFuncNames.substring(ctpSearchPos, ctpNextPipe)
            // Entry format: "funcName:paramIdx:paramName"
            let ctpColon1 = ctpEntry.indexOf(":", 0)
            if ctpColon1 > 0 {
                let ctpFuncName = ctpEntry.substring(0, ctpColon1)
                if ctpFuncName == funcName {
                    let ctpColon2 = ctpEntry.indexOf(":", ctpColon1 + 1)
                    if ctpColon2 > ctpColon1 {
                        let ctpIdxStr = ctpEntry.substring(ctpColon1 + 1, ctpColon2)
                        let ctpParamName = ctpEntry.substring(ctpColon2 + 1, ctpEntry.length())
                        let ctpParamIdx = parseSimpleInt(ctpIdxStr)
                        if ctpParamIdx >= 0 and ctpParamIdx < expr.arguments.length() {
                            let ctpVal = evaluateConstExpr(expr.arguments[ctpParamIdx])
                            if ctpVal != -9999999 {
                                registerComptimeVar(ctpParamName, ctpVal)
                                output.append("  ; comptime param " + ctpParamName + " = " + ctpVal.toString() + "\n")
                            }
                        }
                    }
                }
            }
            ctpSearchPos = ctpNextPipe + 1
        }
    }

    fun tryGenerateMetaBuiltinCall(expr: ParserExpressionNode, funcName: String) r: String {
        // sizeof(Type) — compile-time type size in bytes
        // NOTE: Use inferExpressionType instead of field access on arguments[0]
        // to avoid stage1_frozen cross-module GEP bug with ParserExpressionNode fields
        if funcName == "sizeof" {
            if expr.arguments.length() > 0 {
                // Try comptime evaluator first (handles bare type names like Int32)
                let ctSize = evaluateConstExpr(expr)
                if ctSize > 0 {
                    return ctSize.toString()
                }
                let sizeTypeName = inferExpressionType(expr.arguments[0])
                if sizeTypeName != "" {
                    let llvmT = mapType(sizeTypeName)
                    let sz = getLlvmTypeSize(llvmT)
                    if sz > 0 {
                        return sz.toString()
                    }
                }
            }
            return "0"
        }

        // alignof(Type) — compile-time type alignment in bytes
        if funcName == "alignof" {
            if expr.arguments.length() > 0 {
                let alignTypeName = inferExpressionType(expr.arguments[0])
                if alignTypeName != "" {
                    let llvmT = mapType(alignTypeName)
                    let al = getLlvmTypeAlign(llvmT)
                    if al > 0 {
                        return al.toString()
                    }
                }
            }
            return "0"
        }

        // offsetof(Type, field) — field walk delegated to ir_call_dispatch.seen
        if funcName == "offsetof" {
            if expr.arguments.length() >= 2 {
                let offTypeName = inferExpressionType(expr.arguments[0])
                let offFieldName = inferExpressionType(expr.arguments[1])
                if offTypeName != "" and offFieldName != "" {
                    let sIdx = findStruct(offTypeName)
                    if sIdx >= 0 {
                        let fNamesCsv = structFieldNames[sIdx]
                        let fTypesCsv = structFieldTypes[sIdx]
                        var offFieldNamesArr = Array<String>()
                        var offFieldAlignsArr = Array<Int>()
                        var offFieldSizesArr = Array<Int>()
                        var offPos = 0
                        var offTPos = 0
                        while offPos < fNamesCsv.length() {
                            var offComma = fNamesCsv.indexOf(",", offPos)
                            if offComma < 0 { offComma = fNamesCsv.length() }
                            let offFn = fNamesCsv.substring(offPos, offComma)
                            var offTComma = fTypesCsv.indexOf(",", offTPos)
                            if offTComma < 0 { offTComma = fTypesCsv.length() }
                            let offFt = fTypesCsv.substring(offTPos, offTComma)
                            offFieldNamesArr.push(offFn)
                            offFieldAlignsArr.push(getLlvmTypeAlign(offFt))
                            offFieldSizesArr.push(getLlvmTypeSize(offFt))
                            offPos = offComma + 1
                            offTPos = offTComma + 1
                        }
                        let offResult = emitOffsetofImpl(offFieldNamesArr, offFieldAlignsArr, offFieldSizesArr, offFieldName)
                        if offResult >= 0 {
                            return offResult.toString()
                        }
                    }
                }
            }
            return "0"
        }

        // transmute<TargetType>(value) — delegated to ir_method_gen.seen
        if funcName.startsWith("transmute<") {
            if g_insideUnsafe == 0 {
                output.append("  ; ERROR: transmute requires unsafe block\n")
                return "0"
            }
            if expr.arguments.length() > 0 {
                let tmSrcReg = generateExpression(expr.arguments[0])
                let tmSrcType = inferExpressionType(expr.arguments[0])
                let tmLt = funcName.indexOf("<", 0)
                let tmGt = funcName.indexOf(">", 0)
                var tmTargetTypeName = "Int"
                if tmLt >= 0 and tmGt > tmLt {
                    tmTargetTypeName = funcName.substring(tmLt + 1, tmGt)
                }
                return emitTransmuteImpl(output, g_regBox, tmSrcReg, mapType(tmSrcType), mapType(tmTargetTypeName))
            }
            return "0"
        }

        // comptime includeStr("path") — delegated to ir_call_dispatch.seen
        if funcName == "includeStr" {
            if expr.arguments.length() > 0 {
                let inclPath = expr.arguments[0].literalValue
                if inclPath != "" and exists(inclPath) {
                    let inclContent = readText(inclPath)
                    stringConstants.push(inclContent)
                    let inclIdx = stringConstants.length() - 1
                    let inclEscaped = escapeString(inclContent)
                    return emitIncludeStrImpl(output, g_regBox, inclContent, inclEscaped, stringConstantPrefix, inclIdx)
                }
                output.append("  ; WARNING: includeStr file not found: " + inclPath + "\n")
            }
            let inclEmptyReg = getNextReg()
            output.append("  " + inclEmptyReg + " = insertvalue %SeenString undef, i64 0, 0\n")
            return inclEmptyReg
        }

        // comptime includeBytes("path") — delegated to ir_call_dispatch.seen
        if funcName == "includeBytes" {
            if expr.arguments.length() > 0 {
                let inclBPath = expr.arguments[0].literalValue
                if inclBPath != "" and exists(inclBPath) {
                    let inclBContent = readText(inclBPath)
                    stringConstants.push(inclBContent)
                    let inclBIdx = stringConstants.length() - 1
                    let inclBEscaped = escapeString(inclBContent)
                    return emitIncludeBytesImpl(output, g_regBox, inclBContent, inclBEscaped, stringConstantPrefix, inclBIdx)
                }
            }
            return "0"
        }

        return ""
    }

    fun tryGenerateLowLevelBuiltinCall(expr: ParserExpressionNode, funcName: String) r: String {
        // ptr operations — delegated to ir_method_gen.seen emitPtrOpsImpl
        if funcName == "ptr_deref" or funcName == "ptr_deref_f64" or funcName == "ptr_store" or funcName == "ptr_store_f64" or funcName == "ptr_is_null" or funcName == "ptr_add" or funcName == "ptr_deref_i32" or funcName == "ptr_store_i32" or funcName == "ptr_deref_i16" or funcName == "ptr_store_i16" or funcName == "ptr_deref_i8" or funcName == "ptr_store_i8" or funcName == "ptr_deref_f32" or funcName == "ptr_store_f32" or funcName == "ptr_alloc_i32" or funcName == "ptr_alloc_i16" or funcName == "ptr_alloc_i8" {
            if g_insideUnsafe == 0 {
                if funcName.startsWith("ptr_deref") or funcName.startsWith("ptr_store") {
                    output.append("  ; WARNING: " + funcName + " requires unsafe block\n")
                }
            }
            var ptArg0 = ""
            var ptArg1 = ""
            var ptArg2 = ""
            if expr.arguments.length() > 0 { ptArg0 = generateExpression(expr.arguments[0]) }
            if expr.arguments.length() > 1 { ptArg1 = generateExpression(expr.arguments[1]) }
            if expr.arguments.length() > 2 { ptArg2 = generateExpression(expr.arguments[2]) }
            let ptResult = emitPtrOpsImpl(output, g_regBox, funcName, ptArg0, ptArg1, ptArg2)
            if ptResult != "" { return ptResult }
            if funcName == "ptr_is_null" { return "1" }
            return "0"
        }

        if funcName == "barrier" {
            output.append("  call void @seen_barrier()\n")
            return "0"
        }

        if funcName == "stackAlloc" or funcName.startsWith("stackAlloc<") {
            var allocCount = "1"
            if expr.arguments.length() > 0 {
                allocCount = generateExpression(expr.arguments[0])
            }
            return emitStackAllocImpl(output, g_regBox, allocCount)
        }

        if funcName == "constructAt" {
            if expr.arguments.length() >= 1 {
                let caPtr = generateExpression(expr.arguments[0])
                return emitConstructAtImpl(output, g_regBox, caPtr)
            }
            return "0"
        }

        if funcName == "debug_assert" {
            if g_boundsCheckEnabled == 1 {
                if expr.arguments.length() > 0 {
                    let condVal = generateExpression(expr.arguments[0])
                    var boundsCountBox = Array<Int>()
                    boundsCountBox.push(g_boundsCheckLabelCount)
                    emitDebugAssertCallImpl(output, g_regBox, boundsCountBox, condVal)
                    g_boundsCheckLabelCount = boundsCountBox[0]
                    cseClear()
                }
            }
            return "0"
        }

        if funcName == "str_to_cstr" {
            if expr.arguments.length() > 0 {
                let strArg = generateExpression(expr.arguments[0])
                return emitCStrConversionImpl(output, g_regBox, "str_to_cstr", strArg)
            }
            return "0"
        }
        if funcName == "split" {
            if expr.arguments.length() >= 2 {
                let textArg = generateExpression(expr.arguments[0])
                let delimArg = generateExpression(expr.arguments[1])
                let splitReg = getNextReg()
                output.append("  " + splitReg + " = call ptr @String_split(%SeenString " + textArg + ", %SeenString " + delimArg + ")\n")
                return splitReg
            }
        }
        if funcName == "cstr_to_str" {
            if expr.arguments.length() > 0 {
                let ptrArg = generateExpression(expr.arguments[0])
                return emitCStrConversionImpl(output, g_regBox, "cstr_to_str", ptrArg)
            }
            return "0"
        }

        if funcName == "__default" or funcName.startsWith("__default<") {
            return "0"
        }

        if funcName == "async_yield" {
            var isInsideAsync = 0
            if g_asyncFunctionCoroHdl != "" {
                isInsideAsync = 1
            }
            if isInsideAsync == 1 {
                var yieldCounterBox = Array<Int>()
                yieldCounterBox.push(g_yieldCounter)
                emitAsyncYieldCallImpl(output, g_regBox, yieldCounterBox, g_asyncCleanupLabel)
                g_yieldCounter = yieldCounterBox[0]
            }
            return "0"
        }

        let isSimdBuiltin = isSimdVectorType(funcName) == 1 or funcName.startsWith("simd_load_") or funcName.startsWith("simd_store_") or funcName == "simd_select" or funcName == "simd_shuffle" or funcName.startsWith("simd_gather_") or funcName.startsWith("simd_scatter_")
        if isSimdBuiltin {
            var simdArgs = Array<String>()
            var simdArgTypes = Array<String>()
            var simdConstIndices = Array<Int>()
            var simdPreArgIdx = 0
            let isShuf = funcName == "simd_shuffle"
            while simdPreArgIdx < expr.arguments.length() {
                if isShuf and simdPreArgIdx >= 2 {
                    let shufConstIdx = evaluateConstExpr(expr.arguments[simdPreArgIdx])
                    simdConstIndices.push(shufConstIdx)
                } else {
                    let simdArgReg = generateExpression(expr.arguments[simdPreArgIdx])
                    simdArgs.push(simdArgReg)
                    let simdArgType = inferExpressionType(expr.arguments[simdPreArgIdx])
                    simdArgTypes.push(simdArgType)
                }
                simdPreArgIdx = simdPreArgIdx + 1
            }
            let simdResult = emitSimdBuiltinImpl(output, g_regBox, funcName, simdArgs, simdArgs.length(), simdArgTypes, simdConstIndices, simdConstIndices.length())
            if simdResult != "" {
                return simdResult
            }
        }

        var icVarIdx = 0
        var icIsIndirect = false
        while icVarIdx < activeVarCount {
            if varNames[icVarIdx] == funcName {
                icIsIndirect = true
                break
            }
            icVarIdx = icVarIdx + 1
        }
        if icIsIndirect {
            let icFnPtrReg = getNextReg()
            output.append("  " + icFnPtrReg + " = load i64, ptr " + varRegs[icVarIdx] + "\n")
            let icFnPtrCast = getNextReg()
            output.append("  " + icFnPtrCast + " = inttoptr i64 " + icFnPtrReg + " to ptr\n")
            var icCallArgs = ""
            var icArgIdx = 0
            while icArgIdx < expr.arguments.length() {
                let icArgReg = generateExpression(expr.arguments[icArgIdx])
                if icArgIdx > 0 { icCallArgs = icCallArgs + ", " }
                icCallArgs = icCallArgs + "i64 " + icArgReg
                icArgIdx = icArgIdx + 1
            }
            let icResultReg = getNextReg()
            output.append("  " + icResultReg + " = call i64 " + icFnPtrCast + "(" + icCallArgs + ")\n")
            return icResultReg
        }

        if g_enumVariantCount > 0 {
            if isEnumVariant(funcName) {
                let varFieldCount = lookupEnumFieldCount(funcName)
                if varFieldCount > 0 {
                    return generateEnumConstructor(funcName, expr)
                }
            }
        }

        return ""
    }

    fun resolveArrayConstructorElementType(funcName: String) r: String {
        if funcName.startsWith("Array<") and funcName.endsWith(">") {
            return funcName.substring(6, funcName.length() - 1)
        }
        return ""
    }

    fun tryGenerateArrayConstructorCall(expr: ParserExpressionNode, funcName: String) r: String {
        if not (funcName.startsWith("Array<") or funcName == "Array") {
            return ""
        }

        let elementType = resolveArrayConstructorElementType(funcName)
        if expr.arguments.length() == 2 {
            let countReg = generateExpression(expr.arguments[0])
            let valueReg = generateExpression(expr.arguments[1])
            var isZeroFill = 0
            let fillValNode = expr.arguments[1]
            if fillValNode.kind == "Literal" and fillValNode.literalValue == "0" {
                isZeroFill = 1
            }
            return emitArrayBulkInitImpl(output, g_regBox, g_blockBox, countReg, valueReg,
                elementType, isZeroFill, currentFunctionAlignTo())
        }

        if expr.arguments.length() == 1 {
            let capReg = generateExpression(expr.arguments[0])
            var elemSz = 8
            if elementType == "String" { elemSz = 16 }
            if isDataType(elementType) { elemSz = getDataTypeSize(elementType) }
            return emitArrayPreallocImpl(output, g_regBox, capReg, elemSz)
        }

        var elemSize = 8
        if funcName == "Array<String>" or funcName.startsWith("Array<String") {
            elemSize = 16
        }
        if isDataType(elementType) {
            elemSize = getDataTypeSize(elementType)
        }
        return emitArrayInlineImpl(output, g_regBox, elemSize, currentFunctionAlignTo())
    }

    fun tryGenerateSmallVecConstructorCall(expr: ParserExpressionNode, funcName: String) r: String {
        if not (funcName.startsWith("SmallVec<") or funcName.startsWith("SmallVec[") or funcName == "SmallVec") {
            return ""
        }
        var svCapArgReg = ""
        if expr.arguments.length() > 0 {
            svCapArgReg = generateExpression(expr.arguments[0])
        }
        return emitSmallVecConstructorImpl(output, g_regBox, funcName, svCapArgReg)
    }

    fun tryGenerateCollectionConstructorCall(expr: ParserExpressionNode, funcName: String) r: String {
        let isCollectionCtor = funcName == "Vec" or funcName.startsWith("Vec<") or
            funcName == "BTreeMap" or funcName.startsWith("BTreeMap<") or
            funcName == "HashMap" or funcName.startsWith("HashMap<") or
            funcName == "LinkedList" or funcName.startsWith("LinkedList<")
        if not isCollectionCtor {
            return ""
        }
        var colCapArg = ""
        if expr.arguments.length() > 0 {
            colCapArg = generateExpression(expr.arguments[0])
        }
        return emitCollectionConstructorImpl(output, g_regBox, funcName, colCapArg, expr.arguments.length())
    }

    fun isReprCConstructorType(funcName: String) r: Bool {
        return g_reprCClassNames != "" and g_reprCClassNames.contains(funcName + "|")
    }

    fun tryGenerateReprCClassConstructorCall(expr: ParserExpressionNode, funcName: String, structIdx: Int) r: String {
        if not isReprCConstructorType(funcName) {
            return ""
        }
        if expr.arguments.length() == 0 or structIdx < 0 {
            return "zeroinitializer"
        }

        var reprCArgRegs = Array<String>()
        var reprCFieldTypes = Array<String>()
        let fieldTypesStr = structFieldTypes[structIdx]
        let argCount = expr.arguments.length()
        var reprCArgIdx = 0
        var typePos = 0
        while reprCArgIdx < argCount {
            reprCArgRegs.push(generateExpression(expr.arguments[reprCArgIdx]))
            var typeEnd = typePos
            while typeEnd < fieldTypesStr.length() and fieldTypesStr.byteAt(typeEnd) != 124 {
                typeEnd = typeEnd + 1
            }
            reprCFieldTypes.push(mapType(fieldTypesStr.substring(typePos, typeEnd)))
            reprCArgIdx = reprCArgIdx + 1
            if typeEnd < fieldTypesStr.length() {
                typePos = typeEnd + 1
            } else {
                typePos = fieldTypesStr.length()
            }
        }
        return emitReprCConstructorImpl(output, g_regBox, funcName, reprCArgRegs, reprCFieldTypes)
    }

    fun allocateClassConstructorStorage(structIdx: Int) r: String {
        let ptrReg = getNextReg()
        var structSize = 8
        if structIdx >= 0 {
            structSize = structSizes[structIdx]
            if structSize == 0 {
                structSize = 16
            }
        }

        if structSize <= 80 {
            output.append("  " + ptrReg + " = call ptr @seen_pool_alloc(i64 " + structSize.toString() + ")\n")
        } else {
            output.append("  " + ptrReg + " = call ptr @malloc(i64 " + structSize.toString() + ")\n")
        }
        output.append("  call void @llvm.memset.p0.i64(ptr " + ptrReg + ", i8 0, i64 " + structSize.toString() + ", i1 false)\n")
        return ptrReg
    }

    fun emitClassConstructorArrayFieldInitializers(ptrReg: String, structIdx: Int) r: Void {
        if structIdx < 0 {
            return
        }

        let fieldNamesStr = structFieldNames[structIdx]
        let fieldTypesStr = structFieldTypes[structIdx]
        var byteOffset = 0
        var namePos = 0
        var typePos = 0
        var iterDone = 0
        while iterDone == 0 {
            var nameEnd = namePos
            while nameEnd < fieldNamesStr.length() and fieldNamesStr.byteAt(nameEnd) != 44 {
                nameEnd = nameEnd + 1
            }
            var typeEnd = typePos
            while typeEnd < fieldTypesStr.length() and fieldTypesStr.byteAt(typeEnd) != 124 {
                typeEnd = typeEnd + 1
            }
            let fieldSeenType = fieldTypesStr.substring(typePos, typeEnd)
            let isArrayField = fieldSeenType.startsWith("Array<") or fieldSeenType.startsWith("List<")
            if isArrayField {
                let fieldPtrReg = getNextReg()
                output.append("  " + fieldPtrReg + " = getelementptr inbounds i8, ptr " + ptrReg + ", i64 " + byteOffset.toString() + "\n")
                var elemType = ""
                if fieldSeenType.startsWith("Array<") {
                    elemType = fieldSeenType.substring(6, fieldSeenType.length() - 1)
                }
                if fieldSeenType.startsWith("List<") {
                    elemType = fieldSeenType.substring(5, fieldSeenType.length() - 1)
                }
                let arrInitReg = getNextReg()
                if elemType == "String" {
                    output.append("  " + arrInitReg + " = call ptr @seen_arr_new_str_ptr()\n")
                } else {
                    if isDataType(elemType) {
                        let elemSize = getDataTypeSize(elemType)
                        output.append("  " + arrInitReg + " = call ptr @seen_arr_new_with_size_ptr(i64 " + elemSize.toString() + ")\n")
                    } else {
                        output.append("  " + arrInitReg + " = call ptr @seen_arr_new_ptr_ptr()\n")
                    }
                }
                output.append("  store ptr " + arrInitReg + ", ptr " + fieldPtrReg + "\n")
            }
            byteOffset = byteOffset + getTypeSize(fieldSeenType)
            if nameEnd < fieldNamesStr.length() {
                namePos = nameEnd + 1
                typePos = typeEnd + 1
            }
            if nameEnd >= fieldNamesStr.length() {
                iterDone = 1
            }
        }
    }

    fun emitClassConstructorArgumentStores(expr: ParserExpressionNode, ptrReg: String, structIdx: Int) r: Void {
        if structIdx < 0 or expr.arguments.length() == 0 {
            return
        }

        let ctorFieldTypesStr = structFieldTypes[structIdx]
        var ctorByteOffset = 0
        var ctorTypePos = 0
        var ctorArgIdx = 0
        while ctorArgIdx < expr.arguments.length() and ctorTypePos < ctorFieldTypesStr.length() {
            var ctorTypeEnd = ctorTypePos
            while ctorTypeEnd < ctorFieldTypesStr.length() and ctorFieldTypesStr.byteAt(ctorTypeEnd) != 124 {
                ctorTypeEnd = ctorTypeEnd + 1
            }
            let ctorFieldSeenType = ctorFieldTypesStr.substring(ctorTypePos, ctorTypeEnd)
            let ctorArgExpr = expr.arguments[ctorArgIdx]
            let ctorArgReg = generateExpression(ctorArgExpr)
            let ctorFieldPtrReg = getNextReg()
            output.append("  " + ctorFieldPtrReg + " = getelementptr inbounds i8, ptr " + ptrReg + ", i64 " + ctorByteOffset.toString() + "\n")
            if isDataType(ctorFieldSeenType) {
                if ctorArgExpr.kind == "StructLiteral" {
                    let ctorFieldSize = getDataTypeSize(ctorFieldSeenType)
                    output.append("  call void @llvm.memcpy.p0.p0.i64(ptr " + ctorFieldPtrReg + ", ptr " + ctorArgReg + ", i64 " + ctorFieldSize.toString() + ", i1 false)\n")
                } else {
                    output.append("  store %" + ctorFieldSeenType + " " + ctorArgReg + ", ptr " + ctorFieldPtrReg + "\n")
                }
            } else {
                let ctorFieldLlvmType = mapType(ctorFieldSeenType)
                var ctorStoreReg = ctorArgReg
                if ctorFieldLlvmType == "ptr" and ctorStoreReg == "0" {
                    ctorStoreReg = "null"
                }
                output.append("  store " + ctorFieldLlvmType + " " + ctorStoreReg + ", ptr " + ctorFieldPtrReg + "\n")
            }
            ctorByteOffset = ctorByteOffset + getTypeSize(ctorFieldSeenType)
            ctorArgIdx = ctorArgIdx + 1
            if ctorTypeEnd < ctorFieldTypesStr.length() {
                ctorTypePos = ctorTypeEnd + 1
            } else {
                ctorTypePos = ctorFieldTypesStr.length()
            }
        }
    }

    fun tryGenerateHeapClassConstructorCall(expr: ParserExpressionNode, funcName: String, structIdx: Int) r: String {
        if not isClassType(funcName) {
            return ""
        }

        let ptrReg = allocateClassConstructorStorage(structIdx)
        emitClassConstructorArrayFieldInitializers(ptrReg, structIdx)
        emitClassConstructorArgumentStores(expr, ptrReg, structIdx)
        let intReg = getNextReg()
        output.append("  " + intReg + " = ptrtoint ptr " + ptrReg + " to i64\n")
        return intReg
    }

    fun tryGenerateClassConstructorCall(expr: ParserExpressionNode, funcName: String) r: String {
        if not isClassType(funcName) {
            return ""
        }

        let structIdx = findStruct(funcName)
        let reprCResult = tryGenerateReprCClassConstructorCall(expr, funcName, structIdx)
        if reprCResult != "" {
            return reprCResult
        }
        return tryGenerateHeapClassConstructorCall(expr, funcName, structIdx)
    }

    fun tryGenerateConstructorLikeCall(expr: ParserExpressionNode, funcName: String) r: String {
        let arrayCtorResult = tryGenerateArrayConstructorCall(expr, funcName)
        if arrayCtorResult != "" {
            return arrayCtorResult
        }

        let smallVecCtorResult = tryGenerateSmallVecConstructorCall(expr, funcName)
        if smallVecCtorResult != "" {
            return smallVecCtorResult
        }

        let collectionCtorResult = tryGenerateCollectionConstructorCall(expr, funcName)
        if collectionCtorResult != "" {
            return collectionCtorResult
        }

        return tryGenerateClassConstructorCall(expr, funcName)
    }

    fun stripGenericCalleeName(funcName: String) r: String {
        if funcName.contains("<") {
            var ltIdx = 0
            var scanIdx = 0
            while scanIdx < funcName.length() {
                if funcName.byteAt(scanIdx) == 60 {
                    ltIdx = scanIdx
                    scanIdx = funcName.length()
                }
                scanIdx = scanIdx + 1
            }
            if ltIdx > 0 {
                return funcName.substring(0, ltIdx)
            }
        }
        return funcName
    }

    fun emitPrintLikeCall(printName: String, argExpr: ParserExpressionNode) r: String {
        let argType = inferExpressionType(argExpr)
        let argReg = generateExpression(argExpr)
        var strReg = argReg
        if argType == "Int" {
            strReg = getNextReg()
            output.append("  " + strReg + " = call %SeenString @seen_int_to_string(i64 " + argReg + ")\n")
        } else {
            if argType == "Float" {
                strReg = getNextReg()
                output.append("  " + strReg + " = call %SeenString @seen_float_to_string(double " + argReg + ")\n")
            } else {
                if argType == "Bool" {
                    strReg = getNextReg()
                    output.append("  " + strReg + " = call %SeenString @seen_bool_to_string(i1 " + argReg + ")\n")
                } else {
                    if argType == "Char" {
                        strReg = getNextReg()
                        output.append("  " + strReg + " = call %SeenString @seen_char_to_str(i64 " + argReg + ")\n")
                    }
                }
            }
        }
        output.append("  call void @" + printName + "(%SeenString " + strReg + ")\n")
        return "0"
    }

    fun tryGenerateOptionRuntimeBuiltinCall(expr: ParserExpressionNode, funcName: String) r: String {
        if funcName == "Some" {
            var argReg = "0"
            var argType = "Int"
            if expr.arguments.length() > 0 {
                argReg = generateExpression(expr.arguments[0])
                argType = inferExpressionType(expr.arguments[0])
            }
            var isClassArg = 0
            if isClassType(argType) { isClassArg = 1 }
            return emitSomeConstructorImpl(output, g_regBox, argReg, argType, isClassArg)
        }
        if funcName == "None" {
            return emitNoneConstructorImpl(output, g_regBox)
        }
        return ""
    }

    fun tryGenerateSuperRuntimeBuiltinCall(funcName: String) r: String {
        if funcName == "super" {
            if g_currentClassParentName != "" {
                let thisIdx = findVar("this")
                if thisIdx >= 0 {
                    let thisAlloca = varRegs[thisIdx]
                    let thisVal = getNextReg()
                    output.append("  " + thisVal + " = load ptr, ptr " + thisAlloca + "\n")
                    output.append("  call void @" + quoteIdentIfNeeded(g_currentClassParentName + "_init") + "(ptr " + thisVal + ")\n")
                }
            }
            return "0"
        }
        return ""
    }

    fun tryGenerateEmptyRuntimeBuiltinCall(expr: ParserExpressionNode, funcName: String) r: String {
        if funcName == "" {
            var i = 0
            while i < expr.arguments.length() {
                generateExpression(expr.arguments[i])
                i = i + 1
            }
            return "0"
        }
        return ""
    }

    fun tryGeneratePrintRuntimeBuiltinCall(expr: ParserExpressionNode, funcName: String) r: String {
        if funcName == "println" {
            if expr.arguments.length() > 0 {
                return emitPrintLikeCall("println", expr.arguments[0])
            }
            return "0"
        }
        if funcName == "print" {
            if expr.arguments.length() > 0 {
                return emitPrintLikeCall("print", expr.arguments[0])
            }
            return "0"
        }
        return ""
    }

    fun tryGenerateIoRuntimeBuiltinCall(expr: ParserExpressionNode, funcName: String) r: String {

        if funcName == "readText" {
            if expr.arguments.length() > 0 {
                let argReg = generateExpression(expr.arguments[0])
                let resultReg = getNextReg()
                output.append("  " + resultReg + " = call %SeenString @readText(%SeenString " + argReg + ")\n")
                return resultReg
            }
            return "0"
        }

        if funcName == "writeText" {
            if expr.arguments.length() >= 2 {
                let pathReg = generateExpression(expr.arguments[0])
                let contentReg = generateExpression(expr.arguments[1])
                let resultReg = getNextReg()
                output.append("  " + resultReg + " = call i1 @writeText(%SeenString " + pathReg + ", %SeenString " + contentReg + ")\n")
                return resultReg
            }
            return "0"
        }

        if funcName == "args" {
            let resultReg = getNextReg()
            output.append("  " + resultReg + " = call ptr @args()\n")
            return resultReg
        }
        return ""
    }

    fun tryGeneratePanicRuntimeBuiltinCall(expr: ParserExpressionNode, funcName: String) r: String {
        if funcName == "panic" {
            if expr.arguments.length() > 0 {
                let argReg = generateExpression(expr.arguments[0])
                let lenReg = getNextReg()
                let dataReg = getNextReg()
                output.append("  " + lenReg + " = extractvalue %SeenString " + argReg + ", 0\n")
                output.append("  " + dataReg + " = extractvalue %SeenString " + argReg + ", 1\n")
                output.append("  call void @__panic(i64 " + lenReg + ", ptr " + dataReg + ") noreturn\n")
                output.append("  unreachable\n")
            }
            return "0"
        }
        return ""
    }

    fun tryGenerateRuntimeBuiltinCall(expr: ParserExpressionNode, funcName: String) r: String {
        let optionResult = tryGenerateOptionRuntimeBuiltinCall(expr, funcName)
        if optionResult != "" {
            return optionResult
        }

        let superResult = tryGenerateSuperRuntimeBuiltinCall(funcName)
        if superResult != "" {
            return superResult
        }

        let emptyCallResult = tryGenerateEmptyRuntimeBuiltinCall(expr, funcName)
        if emptyCallResult != "" {
            return emptyCallResult
        }

        let printResult = tryGeneratePrintRuntimeBuiltinCall(expr, funcName)
        if printResult != "" {
            return printResult
        }

        let ioResult = tryGenerateIoRuntimeBuiltinCall(expr, funcName)
        if ioResult != "" {
            return ioResult
        }

        return tryGeneratePanicRuntimeBuiltinCall(expr, funcName)
    }

    fun tryGenerateImplicitThisCall(expr: ParserExpressionNode, funcName: String) r: String {
        let thisIdx = findVar("this")
        if thisIdx < 0 {
            return ""
        }

        let thisType = varTypes[thisIdx]
        let misplacedRetType = resolveRealParserMisplacedMethodReturnTypeImpl(funcName)
        if misplacedRetType != "" and thisType == "RealParser" {
            let thisReg = varRegs[thisIdx]
            let methodFuncName = thisType + "_" + funcName
            prepareCallArgumentsWithDefaults(methodFuncName, expr.arguments,
                false, false, false, "")
            let argRegs = g_defaultFillArgRegs
            let argTypeStrs = g_defaultFillArgTypeStrs

            let thisPtrReg = getNextReg()
            output.append("  " + thisPtrReg + " = load ptr, ptr " + thisReg + "\n")
            var mpTailCall = 0
            if takeTailCallPosition() {
                mpTailCall = 1
            }
            return emitUserMethodCallImpl(output, g_regBox, quoteIdentIfNeeded(methodFuncName), misplacedRetType, "ptr", thisPtrReg, argRegs, argTypeStrs, mpTailCall)
        }

        let methodRetType = getMethodReturnType(thisType, funcName)
        if methodRetType == "" {
            return ""
        }

        let thisReg = varRegs[thisIdx]
        let methodFuncName = thisType + "_" + funcName
        prepareCallArgumentsWithDefaults(methodFuncName, expr.arguments, false,
            true, false, "")
        let argRegs = g_defaultFillArgRegs
        let argTypeStrs = g_defaultFillArgTypeStrs

        if thisType == "StringBuilder" and (funcName == "append" or funcName == "appendInt" or funcName == "appendFloat" or funcName == "appendChar" or funcName == "clear" or funcName == "length" or funcName == "toString") {
            let thisPtrReg = getNextReg()
            output.append("  " + thisPtrReg + " = load ptr, ptr " + thisReg + "\n")
            var sbArg0 = ""
            if argRegs.length() > 0 {
                sbArg0 = argRegs[0]
            }
            return emitStringBuilderMethodImpl(output, g_regBox, funcName, thisPtrReg, sbArg0, 0)
        }

        let llvmReturnType = mapType(methodRetType)

        let thisPtrReg = getNextReg()
        output.append("  " + thisPtrReg + " = load ptr, ptr " + thisReg + "\n")
        var selfTailCall = 0
        if takeTailCallPosition() {
            selfTailCall = 1
        }
        return emitUserMethodCallImpl(output, g_regBox, quoteIdentIfNeeded(methodFuncName), llvmReturnType, "ptr", thisPtrReg, argRegs, argTypeStrs, selfTailCall)
    }

    fun tryGenerateMathBuiltinCall(expr: ParserExpressionNode, funcName: String) r: String {
        if funcName == "__Sqrt" or funcName == "__Sin" or funcName == "__Cos" or funcName == "__Exp" or funcName == "__Log" or funcName == "__Log10" or funcName == "__Fabs" or funcName == "__Pow" or funcName == "__Asin" or funcName == "__Acos" or funcName == "__Atan" or funcName == "__Sinh" or funcName == "__Cosh" or funcName == "__Tanh" or funcName == "__Tan" or funcName == "__Atan2" or funcName == "__ExecuteCommand" or funcName == "absFloat" or funcName == "absInt" or funcName == "minInt" or funcName == "maxInt" {
            var mArg0 = ""
            var mArg1 = ""
            if expr.arguments.length() > 0 { mArg0 = generateExpression(expr.arguments[0]) }
            if expr.arguments.length() > 1 { mArg1 = generateExpression(expr.arguments[1]) }
            let mResult = emitMathBuiltinImpl(output, g_regBox, funcName, mArg0, mArg1)
            if mResult != "" { return mResult }
        }
        return ""
    }

    // Generate IR for a function call expression. Handles a wide variety of
    // call types in priority order:
    //   1. Comptime parameter specialization (evaluate compile-time args)
    //   2. Builtins: sizeof/alignof/offsetof (compile-time constants)
    //   3. Print/println (variadic, type-dispatched formatting)
    //   4. Type constructors: Array/Vec/HashMap/BTreeMap/LinkedList/Option/etc.
    //   5. Enum variant constructors (checked via isEnumVariant)
    //   6. Closure/indirect calls (varNames match before enum/array check)
    //   7. Class constructors (malloc + memset + field init)
    //   8. Async function calls (return coroutine handle ptr)
    //   9. Regular function calls with ABI-correct parameter passing
    // Data types are passed as pointers (ptr) for ABI compatibility.
    // Collection constructors (HashMap_new_str_int, etc.) dispatch to
    // type-specialized runtime functions.
    fun generateCall(expr: ParserExpressionNode) r: String {
        var funcName = expr.callee

        applyComptimeParamSpecialization(funcName, expr)

        let metaBuiltinResult = tryGenerateMetaBuiltinCall(expr, funcName)
        if metaBuiltinResult != "" {
            return metaBuiltinResult
        }

        let lowLevelBuiltinResult = tryGenerateLowLevelBuiltinCall(expr, funcName)
        if lowLevelBuiltinResult != "" {
            return lowLevelBuiltinResult
        }

        let constructorResult = tryGenerateConstructorLikeCall(expr, funcName)
        if constructorResult != "" {
            return constructorResult
        }

        funcName = stripGenericCalleeName(funcName)

        let runtimeBuiltinResult = tryGenerateRuntimeBuiltinCall(expr, funcName)
        if runtimeBuiltinResult != "" {
            return runtimeBuiltinResult
        }

        let implicitThisResult = tryGenerateImplicitThisCall(expr, funcName)
        if implicitThisResult != "" {
            return implicitThisResult
        }

        let mathBuiltinResult = tryGenerateMathBuiltinCall(expr, funcName)
        if mathBuiltinResult != "" {
            return mathBuiltinResult
        }

        prepareCallArgumentsWithDefaults(funcName, expr.arguments, true, false,
            true, "fn call")
        var argRegs = g_defaultFillArgRegs
        var argTypeStrs = g_defaultFillArgTypeStrs

        if currentClassName == "JsonParseResult" or currentClassName == "JsonParser" or currentClassName == "LLVMIRGenerator" {
            println("[irgen call pre-promote] class=" + currentClassName + " func=" + funcName + " regs=" + argRegs.length().toString() + " types=" + argTypeStrs.length().toString())
        }

        if argRegs.length() == argTypeStrs.length() and g_floatParamFuncNames.length() > 0 and g_floatParamParamIdxs.length() > 0 {
            promoteFloatArgsImpl(output, g_regBox, funcName, argRegs, argTypeStrs, g_floatParamFuncNames, g_floatParamParamIdxs)
        }

        let returnType = inferExpressionType(expr)
        var llvmReturnType = mapType(returnType)
        if isAsyncFunction(funcName) {
            llvmReturnType = "ptr"
        }

        recordLateUserDeclare(funcName, llvmReturnType, argTypeStrs, 0)
        var freeCallTail = 0
        if takeTailCallPosition() {
            freeCallTail = 1
        }
        return emitUserFunctionCallImpl(output, g_regBox, quoteIdentIfNeeded(funcName), llvmReturnType, argRegs, argTypeStrs, freeCallTail)
    }

    fun tryGenerateResolvedReceiverFastPathMethodCall(expr: ParserExpressionNode,
        methodName: String, receiverReg: String, receiverType: String) r: String {

        let isOptionTypeSimple = receiverType == "Option" or
            receiverType.startsWith("Option<")
        if isOptionTypeSimple and receiverReg != "" {
            var optDefaultRegS = "0"
            if (methodName == "unwrapOr" or methodName == "UnwrapOr") and
                expr.arguments.length() > 0 {
                optDefaultRegS = generateExpression(expr.arguments[0])
            }
            return emitOptionMethodImpl(output, g_regBox, g_blockLabelBox,
                methodName, receiverReg, optDefaultRegS)
        }

        let isSmallVecSimple = receiverType == "SmallVec" or
            receiverType.startsWith("SmallVec<") or
            receiverType.startsWith("SmallVec[")
        if isSmallVecSimple and receiverReg != "" {
            var svArgReg = ""
            if (methodName == "push" or methodName == "get") and
                expr.arguments.length() > 0 {
                svArgReg = generateExpression(expr.arguments[0])
            }
            return emitSmallVecMethodImpl(output, g_regBox, methodName,
                receiverReg, receiverType, svArgReg)
        }

        let isCollectionTypeSimple = receiverType.startsWith("Vec<") or
            receiverType == "Vec" or
            receiverType.startsWith("BTreeMap<") or
            receiverType == "BTreeMap" or
            receiverType.startsWith("HashMap<") or
            receiverType == "HashMap" or
            receiverType.startsWith("StringHashMap<") or
            receiverType == "StringHashMap" or
            receiverType.startsWith("LinkedList<") or
            receiverType == "LinkedList"
        if isCollectionTypeSimple and receiverReg != "" {
            var collArg0s = "0"
            var collArg1s = "0"
            if expr.arguments.length() > 0 {
                collArg0s = generateExpression(expr.arguments[0])
            }
            if expr.arguments.length() > 1 {
                collArg1s = generateExpression(expr.arguments[1])
            }
            return dispatchCollectionMethodImpl(output, g_regBox, methodName,
                receiverReg, receiverType, collArg0s, collArg1s)
        }

        if receiverType.startsWith("Array<") and receiverReg != "" {
            var arrArg0 = ""
            var arrArg1 = ""
            if expr.arguments.length() > 0 {
                arrArg0 = generateExpression(expr.arguments[0])
            }
            if expr.arguments.length() > 1 {
                arrArg1 = generateExpression(expr.arguments[1])
            }
            return emitArrayBasicMethodImpl(output, g_regBox, methodName,
                receiverReg, receiverType, arrArg0, arrArg1)
        }

        return ""
    }

    fun tryGenerateStaticMethodCall(expr: ParserExpressionNode, methodName: String,
        receiverReg: String) r: String {

        if receiverReg != "" or expr.literalValue == "" {
            return ""
        }

        let classNames = splitPipe(resolveStaticMethodClassNamesImpl(expr.literalValue))
        let potentialClassName = classNames[0]
        let fullClassName = classNames[1]
        if not isStaticMethodReceiverReferenceImpl(findVar(expr.literalValue),
            findVar(potentialClassName)) {
            return ""
        }

        let firstChar = potentialClassName.substring(0, 1)
        let isUppercase = firstChar >= "A" and firstChar <= "Z"
        if isUppercase and methodName == "new" {
            let staticFactoryResult: String = tryGenerateStaticFactoryMethodCallImpl(
                output, g_regBox, methodName, potentialClassName,
                fullClassName, "", 0)
            if staticFactoryResult != "" {
                return staticFactoryResult
            }
        }
        if isUppercase and expr.arguments.length() > 0 {
            let needsStaticFactoryArg = (methodName == "withCapacity" and
                (potentialClassName == "HashMap" or
                    potentialClassName == "StringHashMap")) or
                (potentialClassName == "Array" and methodName == "withLength")
            if needsStaticFactoryArg {
                let staticFactoryArg0 = generateExpression(expr.arguments[0])
                let staticFactoryResult: String = tryGenerateStaticFactoryMethodCallImpl(
                    output, g_regBox, methodName, potentialClassName,
                    fullClassName, staticFactoryArg0,
                    expr.arguments.length())
                if staticFactoryResult != "" {
                    return staticFactoryResult
                }
            }
        }

        var staticClassName = expr.literalValue
        if isUppercase {
            staticClassName = potentialClassName
        }
        let funcName = staticClassName + "_" + methodName

        var enableFloatPromotion = true
        if isUppercase {
            enableFloatPromotion = false
        }
        prepareCallArgumentsWithDefaults(funcName, expr.arguments, false,
            enableFloatPromotion, false, "")
        let argRegs = g_defaultFillArgRegs
        let argTypeStrs = g_defaultFillArgTypeStrs

        let staticReturnType = resolveStaticMethodReturnTypeImpl(
            getMethodReturnType(staticClassName, methodName),
            inferExpressionType(expr))
        let staticLlvmReturnType = mapType(staticReturnType)
        var isClassRecv = 0
        if isClassType(staticClassName) { isClassRecv = 1 }
        var isDataRecv = 0
        if isDataType(staticClassName) { isDataRecv = 1 }
        return emitPreparedStaticMethodCallImpl(output, g_regBox, methodName,
            potentialClassName, staticClassName, funcName,
            staticLlvmReturnType, isClassRecv, isDataRecv,
            argRegs, argTypeStrs)
    }

    fun tryResolveArrayMutatorPointerFromLiteral(varName: String) r: String {
        if varName == "" {
            return ""
        }

        if varName.contains(".") {
            let fieldName = extractLastMemberFieldSegmentImpl(varName)
            let receiverName = varName.substring(0,
                varName.length() - fieldName.length() - 1)

            if receiverName.contains(".") {
                let chainedArrayPtr = tryGenerateChainedReceiverMemberAccess(
                    receiverName, fieldName)
                if chainedArrayPtr != "" {
                    return chainedArrayPtr
                }
            } else {
                let varArrayPtr = tryGenerateVariableReceiverMemberAccess(
                    receiverName, fieldName)
                if varArrayPtr != "" {
                    return varArrayPtr
                }

                let constArrayPtr = tryGenerateModuleConstReceiverMemberAccess(
                    receiverName, fieldName)
                if constArrayPtr != "" {
                    return constArrayPtr
                }

                let implicitThisArrayPtr =
                    tryGenerateImplicitThisReceiverMemberAccess(receiverName,
                        fieldName)
                if implicitThisArrayPtr != "" {
                    return implicitThisArrayPtr
                }
            }
            return ""
        }

        let varIdx = findVar(varName)
        if varIdx >= 0 {
            return emitLocalVariableLoadImpl(output, g_regBox, "ptr",
                varRegs[varIdx])
        }

        let implicitThisArrayPtr = tryGenerateImplicitThisVariable(varName)
        if implicitThisArrayPtr != "" {
            return implicitThisArrayPtr
        }

        let loadReg = getNextReg()
        output.append("  " + loadReg + " = load ptr, ptr @" + varName +
            "\n")
        return loadReg
    }

    fun tryGenerateArrayMutatorMethodCall(expr: ParserExpressionNode, methodName: String,
        receiverReg: String, receiverType: String) r: String {

        if methodName == "free" {
            var freeReceiverType = receiverType
            if (freeReceiverType == "String" or freeReceiverType == "") and expr.literalValue != "" {
                let freeTypeIdx = findVar(expr.literalValue)
                if freeTypeIdx >= 0 {
                    freeReceiverType = varTypes[freeTypeIdx]
                }
            }
            let isArrayType = freeReceiverType.startsWith("Array<") or freeReceiverType == "Array"
            if isArrayType {
                var freePtrReg = receiverReg
                if freePtrReg == "" and expr.literalValue != "" {
                    freePtrReg = tryResolveArrayMutatorPointerFromLiteral(
                        expr.literalValue)
                }
                if freePtrReg != "" {
                    return emitArrayFreeMutationImpl(output, g_regBox,
                        freePtrReg)
                }
            }
            if not isArrayType and isClassType(freeReceiverType) {
                var freeVarName = expr.literalValue
                if freeVarName == "" {
                    freeVarName = expr.variableName
                }
                let freeVarIdx = findVar(freeVarName)
                if freeVarIdx >= 0 {
                    let baseType = getBaseTypeName(freeReceiverType)
                    let sIdx = findStruct(baseType)
                    var sSize = 0
                    if sIdx >= 0 {
                        sSize = structSizes[sIdx]
                    }
                    return emitClassFreeMutationImpl(output, g_regBox,
                        varRegs[freeVarIdx], sSize)
                }
            }
        }

        if methodName == "push" and (receiverType.startsWith("Array<") or receiverType == "Array") {
            let argExpr = expr.arguments[0]
            let argReg = generateExpression(argExpr)
            let argType = inferExpressionType(argExpr)
            let argIsStructLiteral = argExpr.kind == "StructLiteral"
            var elemType = ""
            if receiverType.startsWith("Array<") and receiverType.endsWith(">") {
                elemType = receiverType.substring(6, receiverType.length() - 1)
            }
            var pushElemType = argType
            if pushElemType == "" {
                pushElemType = elemType
            }

            let varName = expr.literalValue
            var arrayPtrReg = tryResolveArrayMutatorPointerFromLiteral(varName)

            if arrayPtrReg == "" and (receiverType.startsWith("Array<") or receiverType == "Array") {
                arrayPtrReg = receiverReg
            }

            if arrayPtrReg != "" {
                let pushResult = emitArrayPushMutationImpl(output, g_regBox,
                    g_blockLabelBox, arrayPtrReg, argReg, pushElemType,
                    receiverType, argIsStructLiteral, structNames)
                if pushResult != "" {
                    return pushResult
                }
            }
        }

        if methodName == "pop" {
            var arrayPtrReg =
                tryResolveArrayMutatorPointerFromLiteral(expr.literalValue)
            if arrayPtrReg == "" { arrayPtrReg = receiverReg }
            if arrayPtrReg != "" {
                return emitArrayPopMutationImpl(output, g_regBox,
                    arrayPtrReg, resolvePopElementTypeImpl(receiverType))
            }
        }

        if methodName == "swap" {
            let isArraySwap = receiverType.startsWith("Array<") or receiverType == "Array"
            if isArraySwap and expr.arguments.length() == 2 {
                let idxAReg = generateExpression(expr.arguments[0])
                let idxBReg = generateExpression(expr.arguments[1])
                var arrayPtrReg =
                    tryResolveArrayMutatorPointerFromLiteral(expr.literalValue)
                if arrayPtrReg == "" {
                    arrayPtrReg = receiverReg
                }
                if arrayPtrReg != "" {
                    return emitArraySwapMutationImpl(output, g_regBox,
                        arrayPtrReg, idxAReg, idxBReg)
                }
            }
        }

        return ""
    }

    fun resolveLiteralMethodReceiverType(literalValue: String) r: String {
        if literalValue == "" {
            return ""
        }
        if literalValue.startsWith("SeenTokenType.") {
            return "Int"
        }

        if literalValue.contains(".") {
            let chainedType = resolveChainedPathType(literalValue)
            if chainedType != "" {
                return chainedType
            }
        }

        let directVarType = findVarType(literalValue)
        if directVarType != "" {
            return directVarType
        }

        let thisIdx = findVar("this")
        if thisIdx < 0 {
            return ""
        }
        let thisType = varTypes[thisIdx]
        if literalValue.contains(".") {
            let pathParts = splitFirstPathDotImpl(literalValue)
            let firstFieldType = resolveMethodFieldPathTypeImpl(thisType,
                pathParts[0], structNames, structFieldNames,
                structFieldTypes, structMethodNames, structMethodRetTypes)
            return resolveMethodFieldPathTypeImpl(firstFieldType, pathParts[1],
                structNames, structFieldNames, structFieldTypes,
                structMethodNames, structMethodRetTypes)
        }
        return resolveMethodFieldPathTypeImpl(thisType, literalValue,
            structNames, structFieldNames, structFieldTypes,
            structMethodNames, structMethodRetTypes)
    }

    fun prepareMethodCallArgRegsAndTypes(args: Array<ParserExpressionNode>,
        argRegs: Array<String>, argTypes: Array<String>) r: Void {

        var argIdx = 0
        while argIdx < args.length() {
            let argReg = generateExpression(args[argIdx])
            let argType = inferExpressionType(args[argIdx])
            argRegs.push(argReg)
            argTypes.push(mapType(argType))
            argIdx = argIdx + 1
        }
    }

    // Generate IR for a method call (receiver.method(args)). The largest and
    // most complex dispatch in the codegen — handles:
    //   - SIMD horizontal reductions (reduce_add/min/max)
    //   - Option methods (isSome/isNone/unwrap — inlined as null checks)
    //   - Hot-reload synthesized methods (__seen_hot_get_size etc.)
    //   - Collection methods: Vec, HashMap, BTreeMap, LinkedList (dispatched
    //     to type-specialized runtime functions via dispatchCollectionMethodImpl)
    //   - String methods (length, contains, indexOf, split, trim, etc.)
    //   - StringBuilder methods (append, toString)
    //   - Array methods (push, get, set, length, pop, etc. with type dispatch
    //     for Int/String/Float/Bool/data-type element types)
    //   - SmallVec/JsonValue methods
    //   - Numeric methods (toString, toFloat, abs, etc.)
    //   - User-defined class methods (ClassName_methodName mangling)
    //   - Simple variable receivers (separate handling path when operands is
    //     empty but callee contains the receiver)
    // NOTE: HashMap/BTreeMap methods must be handled in TWO locations — inside
    // the "operands.length() > 0" path AND the "simple variable receivers"
    // fallback section.
    fun generateMethodCall(expr: ParserExpressionNode) r: String {
        let methodName = expr.callee
        var receiverReg = ""
        var receiverType = "String"

        if expr.operands.length() == 0 and expr.literalValue.contains(".") {
            let receiverSegments = splitChainedPathImpl(expr.literalValue)
            if receiverSegments.length() > 0 {
                let baseReceiverName = receiverSegments[0]
                if findVarType(baseReceiverName) != "" {
                    let rebuiltReceiverExpr = buildChainedPathExprImpl(
                        expr.literalValue)
                    if rebuiltReceiverExpr.kind != "None" {
                        receiverReg = generateExpression(rebuiltReceiverExpr)
                        receiverType = inferExpressionType(rebuiltReceiverExpr)
                    }
                }
            }
        }

        if expr.operands.length() > 0 {
            receiverReg = generateExpression(expr.operands[0])
            receiverType = inferExpressionType(expr.operands[0])

            let simdRedResult = emitSimdReductionImpl(output, g_regBox,
                methodName, receiverReg, receiverType)
            if simdRedResult != "" {
                return simdRedResult
            }

            var dynArgRegs = Array<String>()
            var dynArgTypes = Array<String>()
            prepareMethodCallArgRegsAndTypes(expr.arguments, dynArgRegs,
                dynArgTypes)
            let explicitReceiverTypeBox = Array<String>()
            explicitReceiverTypeBox.push(receiverType)
            let explicitFastPath =
                tryGeneratePreparedExplicitReceiverFastPathImpl(output,
                    g_regBox, g_blockLabelBox, methodName, receiverReg,
                    explicitReceiverTypeBox, structNames, structMethodNames,
                    structMethodRetTypes, dynArgRegs, dynArgTypes,
                    g_reprCClassNames)
            receiverType = explicitReceiverTypeBox[0]
            if explicitFastPath != "" {
                return explicitFastPath
            }
        }

        if expr.operands.length() == 0 and expr.literalValue.contains(".") {
            if receiverReg == "" {
                let enumReceiverRegBox = Array<String>()
                enumReceiverRegBox.push("")
                let enumReceiverTypeBox = Array<String>()
                enumReceiverTypeBox.push(receiverType)
                if tryResolveEnumLiteralMethodReceiverImpl(expr,
                    enumReceiverRegBox, enumReceiverTypeBox) == 1 {
                    receiverReg = enumReceiverRegBox[0]
                    receiverType = enumReceiverTypeBox[0]
                } else {
                    let pathParts = splitFirstPathDotImpl(expr.literalValue)
                    let thisIdx = findVar("this")
                    if thisIdx >= 0 {
                        let thisType = varTypes[thisIdx]
                        let firstFieldType = resolveMethodFieldPathTypeImpl(
                            thisType, pathParts[0], structNames,
                            structFieldNames, structFieldTypes,
                            structMethodNames, structMethodRetTypes)
                        if firstFieldType != "" {
                            let thisPtrReg = emitImplicitThisPointerLoadImpl(
                                output, g_regBox, varRegs[thisIdx])
                            var accessFieldReg = ""
                            if isClassType(firstFieldType) {
                                let firstFieldReg = generateFieldAccess(
                                    thisPtrReg, thisType, pathParts[0])
                                let ptrConvReg = getNextReg()
                                output.append("  " + ptrConvReg +
                                    " = inttoptr i64 " + firstFieldReg +
                                    " to ptr\n")
                                accessFieldReg = ptrConvReg
                            } else {
                                accessFieldReg = generateFieldAccessPtr(
                                    thisPtrReg, thisType, pathParts[0])
                            }
                            receiverReg = generateFieldAccess(accessFieldReg,
                                firstFieldType, pathParts[1])
                            receiverType = resolveMethodFieldPathTypeImpl(
                                firstFieldType, pathParts[1], structNames,
                                structFieldNames, structFieldTypes,
                                structMethodNames, structMethodRetTypes)
                        }
                    }
                }
            }
        } else {
            if expr.literalValue != "" {
                let varName = expr.literalValue
                let idx = findVar(varName)
                if idx >= 0 {
                    let varReg = varRegs[idx]
                    let varType = varTypes[idx]
                    let llvmType = mapType(varType)
                    receiverReg = emitLocalVariableLoadImpl(output, g_regBox,
                        llvmType, varReg)
                    receiverType = varType

                    var svDynArgRegs = Array<String>()
                    var svDynArgTypes = Array<String>()
                    prepareMethodCallArgRegsAndTypes(expr.arguments,
                        svDynArgRegs, svDynArgTypes)
                    let localVarFastPath =
                        tryGeneratePreparedLocalVariableReceiverFastPathImpl(
                            output, g_regBox, methodName, receiverReg,
                            varType, structNames, structMethodNames,
                            structMethodRetTypes, svDynArgRegs,
                            svDynArgTypes)
                    if localVarFastPath != "" {
                        return localVarFastPath
                    }
                } else {
                    let gvMcIdx = findModuleConstant(varName)
                    if gvMcIdx >= 0 {
                        let gvMcType = moduleConstantTypes[gvMcIdx]
                        var gvMcInvSuffix = ""
                        if not isModuleConstMutable(gvMcIdx) {
                            gvMcInvSuffix = ", !invariant.load !190"
                        }
                        let moduleConstReceiverRegBox = Array<String>()
                        moduleConstReceiverRegBox.push(receiverReg)
                        let moduleConstReceiverTypeBox = Array<String>()
                        moduleConstReceiverTypeBox.push(receiverType)
                        prepareModuleConstantMethodReceiverImpl(output,
                            g_regBox, "@" + varName, gvMcType, gvMcInvSuffix,
                            resolveLiteralMethodReceiverType(varName),
                            moduleConstReceiverRegBox,
                            moduleConstReceiverTypeBox)
                        receiverReg = moduleConstReceiverRegBox[0]
                        receiverType = moduleConstReceiverTypeBox[0]
                    }
                    if receiverReg == "" {
                        let thisIdx = findVar("this")
                        if thisIdx >= 0 {
                            let thisReg = varRegs[thisIdx]
                            let thisType = varTypes[thisIdx]
                            if thisType == "LLVMIRGenerator" {
                                let idxCheck =
                                    getLLVMIRGeneratorFieldIndex(varName)
                                if idxCheck >= 0 {
                                    let thisPtrReg =
                                        emitImplicitThisPointerLoadImpl(
                                            output, g_regBox, thisReg)
                                    receiverReg = generateFieldAccess(
                                        thisPtrReg, "LLVMIRGenerator",
                                        varName)
                                    receiverType =
                                        resolveLiteralMethodReceiverType(
                                            varName)
                                }
                            }
                            if receiverReg == "" {
                                let structIdx = findStruct(thisType)
                                output.append("; DEBUG methodCall: varName=" +
                                    varName + " thisType=" + thisType +
                                    " structIdx=" + structIdx.toString() +
                                    "\n")
                                if structIdx >= 0 {
                                    let fieldIdx = getFieldInfo(thisType,
                                        varName)
                                    output.append("; DEBUG fieldIdx=" +
                                        fieldIdx.toString() + "\n")
                                    if fieldIdx >= 0 {
                                        let thisPtrReg =
                                            emitImplicitThisPointerLoadImpl(
                                                output, g_regBox, thisReg)
                                        receiverReg = generateFieldAccess(
                                            thisPtrReg, thisType, varName)
                                        output.append(
                                            "; DEBUG after generateFieldAccess: receiverReg=" +
                                            receiverReg + "\n")
                                        receiverType =
                                            resolveLiteralMethodReceiverType(
                                                varName)
                                        output.append("; DEBUG receiverType=" +
                                            receiverType + "\n")
                                    }
                                } else {
                                    output.append("; DEBUG: thisType=" +
                                        thisType + " varName=" + varName +
                                        "\n")
                                    if thisType == "SeenLexer" and
                                        varName == "keywordManager" {
                                        output.append("; DEBUG: Matched SeenLexer.keywordManager!\n")
                                        let thisPtrReg =
                                            emitImplicitThisPointerLoadImpl(
                                                output, g_regBox, thisReg)
                                        let gepReg = getNextReg()
                                        output.append("  " + gepReg + " = getelementptr inbounds { %SeenString, i64, %SeenString, i1, ptr, i64, i64, i64, %SeenArray }, ptr " + thisPtrReg + ", i32 0, i32 4\n")
                                        receiverReg = getNextReg()
                                        output.append("  " + receiverReg +
                                            " = load ptr, ptr " + gepReg +
                                            "\n")
                                        receiverType = "KeywordManager"
                                        output.append("; DEBUG: receiverReg=" +
                                            receiverReg +
                                            " receiverType=" + receiverType +
                                            "\n")
                                    }
                                }
                            }
                        }
                    }
                }
            }
        }

        let resolvedReceiverFastPath = tryGenerateResolvedReceiverFastPathMethodCall(expr, methodName, receiverReg, receiverType)
        if resolvedReceiverFastPath != "" {
            return resolvedReceiverFastPath
        }

        // Check if this is a static method call BEFORE setting receiver fallback
        // Static method call: ClassName.method() where ClassName is not a variable
        // Class names use PascalCase (start with uppercase letter)
        let staticCallResult = tryGenerateStaticMethodCall(expr, methodName, receiverReg)
        if staticCallResult != "" {
            return staticCallResult
        }

        if receiverReg == "" {
            var implicitMethodRetType = ""
            if currentClassName != "" {
                implicitMethodRetType = getMethodReturnType(currentClassName,
                    methodName)
            }
            if shouldLowerUnresolvedMethodAsCallImpl(currentClassName,
                implicitMethodRetType, getFunctionReturnType(methodName)) {
                return generateCall(expr)
            }

            if isStandaloneParserWorkaroundImpl(methodName) {
                prepareCallArgumentsWithDefaults(methodName, expr.arguments,
                    false, false, false, "")
                return emitStandaloneParserWorkaroundCallImpl(output,
                    g_regBox, methodName, g_defaultFillArgRegs,
                    g_defaultFillArgTypeStrs)
            }

            output.append("; WARNING: receiver not resolved for " + methodName +
                ", receiverType='" + receiverType + "', currentClass='" +
                currentClassName + "', literal='" + expr.literalValue +
                "', operands=" + expr.operands.length().toString() +
                ", using default\n")
            let unresolvedFallback =
                tryGenerateUnresolvedReceiverFallbackMethodImpl(output,
                    g_regBox, methodName, receiverReg, receiverType)
            if unresolvedFallback != "" {
                return unresolvedFallback
            }
            let unresolvedReceiverRegBox = Array<String>()
            unresolvedReceiverRegBox.push(receiverReg)
            applyUnresolvedReceiverDefaultImpl(unresolvedReceiverRegBox,
                receiverType)
            receiverReg = unresolvedReceiverRegBox[0]
        }

        // Generate arguments BEFORE allocating result register to keep numbers in order
        let arrayMutatorResult = tryGenerateArrayMutatorMethodCall(expr, methodName, receiverReg, receiverType)
        if arrayMutatorResult != "" {
            return arrayMutatorResult
        }

        let lengthLikeResult = tryGenerateLengthLikeMethodCallImpl(output,
            g_regBox, methodName, receiverReg, receiverType,
            g_reprCClassNames, structNames)
        if lengthLikeResult != "" {
            return lengthLikeResult
        }

        if receiverType == "StringBuilder" {
            if methodName == "append" or methodName == "appendInt" or
                methodName == "appendFloat" or
                methodName == "appendChar" or methodName == "clear" or
                methodName == "length" or methodName == "toString" {
                var sbArg0 = ""
                var isFloatFused = 0
                if methodName == "append" and expr.arguments.length() > 0 {
                    let appendArgExpr = expr.arguments[0]
                    if appendArgExpr.kind == "Call" and
                        appendArgExpr.callee == "__FloatToString" and
                        appendArgExpr.arguments.length() > 0 {
                        sbArg0 = generateExpression(appendArgExpr.arguments[0])
                        isFloatFused = 1
                    } else {
                        sbArg0 = generateExpression(expr.arguments[0])
                    }
                } else {
                    if expr.arguments.length() > 0 {
                        sbArg0 = generateExpression(expr.arguments[0])
                    }
                }
                let stringBuilderResult =
                    emitStringBuilderReceiverMethodCallImpl(output, g_regBox,
                        methodName, receiverReg, receiverType, sbArg0,
                        isFloatFused, g_reprCClassNames, structNames)
                if stringBuilderResult != "" {
                    return stringBuilderResult
                }
            }
        }

        let conversionResult = tryGeneratePrimitiveConversionMethodCallImpl(
            output, g_regBox, methodName, receiverReg, receiverType,
            structNames)
        if conversionResult != "" {
            return conversionResult
        }

        if methodName == "abs" or methodName == "min" or methodName == "max" or
            methodName == "clamp" or methodName == "floor" or
            methodName == "ceil" or methodName == "round" or
            methodName == "sqrt" or methodName == "isNaN" or
            methodName == "isInfinite" {
            var numArg0 = ""
            var numArg1 = ""
            if expr.arguments.length() > 0 {
                numArg0 = generateExpression(expr.arguments[0])
            }
            if expr.arguments.length() > 1 {
                numArg1 = generateExpression(expr.arguments[1])
            }
            let numericResult = tryGenerateNumericReceiverMethodCallImpl(
                output, g_regBox, methodName, receiverReg, receiverType,
                numArg0, numArg1)
            if numericResult != "" {
                return numericResult
            }
        }

        var strArg0 = ""
        var strArg1 = ""
        let strArgCount = expr.arguments.length()
        if strArgCount > 0 {
            strArg0 = generateExpression(expr.arguments[0])
        }
        if strArgCount > 1 {
            strArg1 = generateExpression(expr.arguments[1])
        }
        let stringLikeResult = tryGenerateStringLikeReceiverMethodCallImpl(
            output, g_regBox, methodName, receiverReg, receiverType, strArg0,
            strArg1, strArgCount, g_reprCClassNames, structNames)
        if stringLikeResult != "" {
            return stringLikeResult
        }

        var tracedUnwrapSourceType = ""
        if receiverType == "ptr" and methodName == "toJson" and
            expr.operands.length() > 0 {
            let receiverExpr = expr.operands[0]
            if receiverExpr.kind == "MethodCall" and
                receiverExpr.callee == "unwrap" and
                receiverExpr.operands.length() > 0 {
                tracedUnwrapSourceType = inferExpressionType(
                    receiverExpr.operands[0])
            }
        }
        let instanceTypeName = resolveMethodCallInstanceTypeNameImpl(expr,
            methodName, receiverType, tracedUnwrapSourceType)
        let funcName = instanceTypeName + "_" + methodName

        var hotStateArg = ""
        if methodName == "__seen_hot_set_state" and expr.arguments.length() > 0 {
            hotStateArg = generateExpression(expr.arguments[0])
        }
        let hotReloadResult = tryGeneratePreparedHotReloadInstanceMethodCallImpl(
            output, g_regBox, methodName, quoteIdentIfNeeded(funcName),
            receiverReg, receiverType, hotStateArg, structNames)
        if hotReloadResult != "" {
            return hotReloadResult
        }

        prepareCallArgumentsWithDefaults(funcName, expr.arguments, false, true,
            false, "")
        let argRegs = g_defaultFillArgRegs
        let argTypeStrs = g_defaultFillArgTypeStrs

        let returnTypeStr = resolveMethodCallReturnTypeImpl(
            inferExpressionType(expr), getMethodReturnType(instanceTypeName,
                methodName))
        let llvmReturnType = mapType(returnTypeStr)

        let receiverRegBox = Array<String>()
        receiverRegBox.push(receiverReg)
        let receiverLlvmTypeBox = Array<String>()
        receiverLlvmTypeBox.push("ptr")
        prepareMethodCallReceiverAbiImpl(output, g_regBox, instanceTypeName,
            receiverRegBox, receiverType, receiverLlvmTypeBox, structNames,
            g_reprCClassNames, g_typeAliasNames, g_typeAliasTargets,
            g_typeAliasCount, g_enumTypeNames)

        let normalizedReceiverReg = receiverRegBox[0]
        let receiverLlvmType = receiverLlvmTypeBox[0]

        let specializedResult = tryGenerateSpecializedInstanceMethodCallImpl(
            output, g_regBox, methodName, instanceTypeName, receiverType,
            returnTypeStr, receiverLlvmType, normalizedReceiverReg,
            structNames)
        if specializedResult != "" {
            return specializedResult
        }

        return emitUserMethodCallImpl(output, g_regBox,
            quoteIdentIfNeeded(funcName), llvmReturnType, receiverLlvmType,
            normalizedReceiverReg, argRegs, argTypeStrs, 0)
    }

    // Generate IR for an await expression. Calls the async function to get
    // a coroutine handle (ptr), then emits a poll loop: coro.done? -> yes:
    // extract promise value, no: coro.resume and loop. Uses LLVM coroutine
    // intrinsics (coro.done, coro.resume, coro.destroy) directly — C wrapper
    // functions CRASH due to calling convention mismatch (fastcc vs ccc).
    fun resolveAwaitExpressionResultLlvmType(futureExpr: ParserExpressionNode) r: String {
        if futureExpr.kind == "Call" {
            let declType = getAsyncDeclaredRetType(futureExpr.callee)
            if declType != "" {
                return mapType(declType)
            }
        }
        return "i64"
    }

    fun emitAwaitPollLoop(hdlReg: String) r: Void {
        let pollLabel = getNextBlockLabel()
        let resumeLabel = getNextBlockLabel()
        let readyLabel = getNextBlockLabel()

        output.append("  br label %" + pollLabel + "\n")
        output.append("\n" + pollLabel + ":\n")
        let doneReg = getNextReg()
        output.append("  " + doneReg + " = call i1 @llvm.coro.done(ptr " + hdlReg + ")\n")
        output.append("  br i1 " + doneReg + ", label %" + readyLabel + ", label %" + resumeLabel + "\n")

        output.append("\n" + resumeLabel + ":\n")
        output.append("  call void @llvm.coro.resume(ptr " + hdlReg + ")\n")
        output.append("  br label %" + pollLabel + "\n")

        output.append("\n" + readyLabel + ":\n")
    }

    fun emitAwaitResultValue(hdlReg: String, resultLlvmType: String) r: String {
        if resultLlvmType == "void" {
            output.append("  call void @llvm.coro.destroy(ptr " + hdlReg + ")\n")
            return "0"
        }

        let promisePtrReg = getNextReg()
        output.append("  " + promisePtrReg + " = call ptr @llvm.coro.promise(ptr " + hdlReg + ", i32 8, i1 false)\n")
        let resultReg = getNextReg()
        output.append("  " + resultReg + " = load " + resultLlvmType + ", ptr " + promisePtrReg + "\n")
        output.append("  call void @llvm.coro.destroy(ptr " + hdlReg + ")\n")
        return resultReg
    }

    fun generateAwaitExpression(expr: ParserExpressionNode) r: String {
        let futureExpr = expr.operands[0]
        let hdlReg = generateExpression(futureExpr)
        let resultLlvmType = resolveAwaitExpressionResultLlvmType(futureExpr)
        emitAwaitPollLoop(hdlReg)
        return emitAwaitResultValue(hdlReg, resultLlvmType)
    }

    // Generate IR for a unary expression: negation (-x), logical not (!x),
    // bitwise not (~x), address-of (&x), dereference (*x).
    fun tryEmitOverloadedUnary(expr: ParserExpressionNode) r: String {
        if expr.operands.length() == 0 {
            return ""
        }
        let unaryOpType = inferExpressionType(expr.operands[0])
        var unaryOpMethod = ""
        if expr.operator == "-" { unaryOpMethod = "operator_neg" }
        if expr.operator == "not" or expr.operator == "!" { unaryOpMethod = "operator_not" }
        if unaryOpMethod == "" {
            return ""
        }
        if unaryOpType == "Int" or unaryOpType == "Float" or unaryOpType == "Bool" or unaryOpType == "String" {
            return ""
        }
        let unaryOpFuncName = unaryOpType + "_" + unaryOpMethod
        let unaryOpRetType = getFunctionReturnType(unaryOpFuncName)
        if unaryOpRetType == "" {
            return ""
        }
        let unaryValReg = generateExpression(expr.operands[0])
        let unaryThisReg = getNextReg()
        output.append("  " + unaryThisReg + " = inttoptr i64 " + unaryValReg + " to ptr\n")
        let unaryRetLlvm = mapType(unaryOpRetType)
        let unaryResReg = getNextReg()
        output.append("  " + unaryResReg + " = call " + unaryRetLlvm + " @" + quoteIdentIfNeeded(unaryOpFuncName) + "(ptr " + unaryThisReg + ")\n")
        return unaryResReg
    }

    fun emitUnaryNegation(expr: ParserExpressionNode) r: String {
        let operandReg = generateExpression(expr.operands[0])
        let resultReg = getNextReg()
        let operandType = inferExpressionType(expr.operands[0])
        if operandType == "Float" {
            output.append("  " + resultReg + " = fneg fast double " + operandReg + "\n")
        } else {
            output.append("  " + resultReg + " = sub nsw i64 0, " + operandReg + "\n")
        }
        return resultReg
    }

    fun tryEmitNegatedComparison(innerExpr: ParserExpressionNode) r: String {
        if innerExpr.kind != "Binary" {
            return ""
        }
        let innerOp = innerExpr.operator
        var flippedOp = ""
        if innerOp == "==" { flippedOp = "ne" }
        if innerOp == "!=" { flippedOp = "eq" }
        if innerOp == "<" { flippedOp = "sge" }
        if innerOp == ">" { flippedOp = "sle" }
        if innerOp == "<=" { flippedOp = "sgt" }
        if innerOp == ">=" { flippedOp = "slt" }
        if flippedOp == "" {
            return ""
        }
        let innerLeftType = inferExpressionType(innerExpr.operands[0])
        let innerRightType = inferExpressionType(innerExpr.operands[1])
        if innerLeftType != "Int" and innerRightType != "Int" and innerLeftType != "Char" and innerRightType != "Char" {
            return ""
        }
        let aReg = generateExpression(innerExpr.operands[0])
        let bReg = generateExpression(innerExpr.operands[1])
        let resultReg = getNextReg()
        output.append("  " + resultReg + " = icmp " + flippedOp + " i64 " + aReg + ", " + bReg + " ; negated comparison\n")
        return resultReg
    }

    fun emitUnaryLogicalNot(expr: ParserExpressionNode) r: String {
        let innerExpr = expr.operands[0]
        let negatedCmpReg = tryEmitNegatedComparison(innerExpr)
        if negatedCmpReg != "" {
            return negatedCmpReg
        }
        let operandReg = generateExpression(innerExpr)
        var boolReg = operandReg
        let operandType = inferExpressionType(innerExpr)
        if operandType != "Bool" and operandType != "Boolean" {
            boolReg = getNextReg()
            output.append("  " + boolReg + " = icmp ne i64 " + operandReg + ", 0\n")
        }
        let resultReg = getNextReg()
        output.append("  " + resultReg + " = xor i1 " + boolReg + ", 1\n")
        return resultReg
    }

    fun emitUnaryAddressOf(expr: ParserExpressionNode) r: String {
        if g_insideUnsafe == 0 {
            output.append("  ; WARNING: address-of (&) requires unsafe block\n")
        }
        let addrOperand = expr.operands[0]
        let addrType = inferExpressionType(addrOperand)
        if addrOperand.kind == "Variable" or addrOperand.kind == "VarExpr" {
            var addrVarName = addrOperand.variableName
            if addrVarName == "" { addrVarName = addrOperand.literalValue }
            let addrIdx = findVar(addrVarName)
            if addrIdx >= 0 {
                let addrVarReg = varRegs[addrIdx]
                if isClassType(addrType) {
                    let addrLoadReg = getNextReg()
                    output.append("  " + addrLoadReg + " = load i64, ptr " + addrVarReg + " ; &class — handle is pointer\n")
                    return addrLoadReg
                }
                let addrResultReg = getNextReg()
                output.append("  " + addrResultReg + " = ptrtoint ptr " + addrVarReg + " to i64 ; &var — address of alloca\n")
                return addrResultReg
            }
        }
        return generateExpression(addrOperand)
    }

    fun emitUnaryDereference(expr: ParserExpressionNode) r: String {
        if g_insideUnsafe == 0 {
            output.append("  ; WARNING: pointer dereference (*) requires unsafe block\n")
        }
        let derefValReg = generateExpression(expr.operands[0])
        let derefPtrReg = getNextReg()
        output.append("  " + derefPtrReg + " = inttoptr i64 " + derefValReg + " to ptr\n")
        let derefResultReg = getNextReg()
        output.append("  " + derefResultReg + " = load i64, ptr " + derefPtrReg + " ; *ptr dereference\n")
        return derefResultReg
    }

    fun isUnaryBitwiseNotOperator(op: String) r: Bool {
        if op.length() != 1 {
            return false
        }
        return op.charAt(0).toInt() == 126
    }

    fun emitUnaryBitwiseNot(expr: ParserExpressionNode) r: String {
        let operandReg = generateExpression(expr.operands[0])
        let resultReg = getNextReg()
        output.append("  " + resultReg + " = xor i64 " + operandReg + ", -1\n")
        return resultReg
    }

    fun generateUnary(expr: ParserExpressionNode) r: String {
        let overloadedUnaryReg = tryEmitOverloadedUnary(expr)
        if overloadedUnaryReg != "" {
            return overloadedUnaryReg
        }

        if expr.operator == "-" {
            return emitUnaryNegation(expr)
        }
        if expr.operator == "not" or expr.operator == "!" {
            return emitUnaryLogicalNot(expr)
        }
        if expr.operator == "&" {
            return emitUnaryAddressOf(expr)
        }
        if expr.operator == "*" {
            return emitUnaryDereference(expr)
        }
        if isUnaryBitwiseNotOperator(expr.operator) {
            return emitUnaryBitwiseNot(expr)
        }
        let operandReg = generateExpression(expr.operands[0])
        let resultReg = getNextReg()
        return resultReg
    }

    // Helper functions

    // Allocate the next SSA register (%1, %2, %3, ...). Registers are
    // strictly ascending within a function — using a pre-allocated register
    // for the FIRST instruction of a sequence is required to maintain order.
    // The counter is stored in g_regBox[0] (a boxed Array<Int>) so that
    // extracted free functions can mutate it by reference.
    fun getNextReg() r: String {
        let reg = "%" + g_regBox[0].toString()
        g_regBox[0] = g_regBox[0] + 1
        return reg
    }

    // Allocate the next block label (block0, block1, ...). Unlike registers,
    // block labels accumulate across functions within a module to ensure
    // unique loop metadata IDs (loopMetaId = blockCount + 202).
    fun getNextBlockLabel() r: String {
        let label = "bb" + g_blockBox[0].toString()
        g_blockBox[0] = g_blockBox[0] + 1
        return label
    }

    // SIMD type helpers — delegated to ir_type_info.seen
    fun isSimdVectorType(t: String) r: Int { return isSimdVectorTypeImpl(t) }
    fun simdScalarType(t: String) r: String { return simdScalarTypeImpl(t) }
    fun simdLaneCount(t: String) r: Int { return simdLaneCountImpl(t) }
    fun isSwizzlePattern(s: String, lanes: Int) r: Int { return isSwizzlePatternImpl(s, lanes) }
    fun swizzleLaneIndex(c: String) r: Int { return swizzleLaneIndexImpl(c) }
    fun simdLlvmSuffix(t: String) r: String { return simdLlvmSuffixImpl(t) }

    // Map a Seen type name to its LLVM IR type representation.
    // Core mappings: Int->i64, Float->double, Bool->i1, String->%SeenString,
    // Char->i64, Void->void, Array<T>/Vec<T>->ptr, HashMap/BTreeMap->ptr.
    // Class types map to i64 (they are heap pointers stored as integers —
    // inttoptr converts when field access is needed). Simple enums map to
    // i64 (tag value). Data enums and Option map to ptr (heap-allocated).
    // SIMD vector types (i32x4, f32x4, etc.) map to LLVM vector types.
    // Buffer<T>/Uniform<T>/Image<T> (GPU) map to i64 (opaque handles).
    // Delegates to mapTypeImpl in ir_type_mapping.seen.
    fun mapType(seenType: String) r: String {
        // dyn Trait: fat pointer stored as i64 (ptr to { ptr data, ptr vtable })
        if seenType.startsWith("dyn ") {
            return "i64"
        }
        // Pointer types: *T → i64 (pointer stored as integer)
        if seenType.startsWith("*") {
            return "i64"
        }
        // @repr(C) classes are value types (stack-allocated struct), not heap handles
        if g_reprCClassNames != "" {
            let baseT = getBaseTypeName(seenType)
            if g_reprCClassNames.contains(baseT + "|") {
                return "%" + baseT
            }
        }
        return mapTypeImpl(seenType, structNames, g_typeAliasNames, g_typeAliasTargets, g_typeAliasCount, g_enumTypeNames)
    }

    // Check whether a Seen type is a heap-allocated class (as opposed to a
    // value type or data struct). Class types are stored as i64 handles
    // (heap pointers cast to integer) and need inttoptr for field access.
    fun isClassType(seenType: String) r: Bool {
        return isClassTypeReg(seenType, structNames)
    }


    // Convert a method receiver register to a pointer. Class types are stored
    // as i64 (heap pointer cast to integer), so method calls need inttoptr
    // before dereferencing. Returns a new register with the ptr value if
    // conversion was needed, or the original register unchanged for non-class types.
    fun convertReceiverToPtr(receiverReg: String, receiverType: String) r: String {
        return convertReceiverToPtrImpl(output, g_regBox, receiverReg,
            receiverType, g_reprCClassNames, structNames)
    }

    // Check whether a Seen type is a data type (value semantics, passed by
    // pointer in function calls). Data types differ from class types: they
    // are stack-allocated or embedded inline in parent structs, not heap-
    // allocated with an i64 handle.
    fun isDataType(seenType: String) r: Bool {
        if isDataTypeImpl(seenType) == 1 { return true }
        return false
    }

    // Get the byte size of a data type, used for Array<T> element_size.
    // First checks the struct registry (structSizes), then falls back to
    // hardcoded sizes for known AST types (TypeNode=24, ParamNode=48, etc.).
    // These sizes MUST match the LLVM struct layouts — a mismatch causes
    // array element access to read/write at wrong offsets.
    fun getDataTypeSize(seenType: String) r: Int {
        return getDataTypeSizeReg(seenType, structNames, structSizes)
    }


    // Map a Seen type to its LLVM IR type for use as a function parameter.
    // Data types (value-semantic structs) are passed as "ptr noalias nonnull"
    // for ABI compatibility — Rust and C both pass structs by pointer.
    // The noalias attribute enables LLVM's alias analysis optimizations.
    // Strips the "comptime:" qualifier prefix from compile-time parameters.
    fun mapTypeForParameter(seenType: String) r: String {
        var cleanType = seenType
        // Strip comptime: qualifier
        if cleanType.startsWith("comptime:") {
            cleanType = cleanType.substring(9, cleanType.length())
        }
        // Strip default value suffix
        if cleanType.contains("~default~") {
            let mtpDefPos = cleanType.indexOf("~default~", 0)
            cleanType = cleanType.substring(0, mtpDefPos)
        }
        // Data types passed as pointers for ABI compatibility with Rust backend
        if isDataType(cleanType) {
            return "ptr noalias nonnull"
        }
        let mapped = mapType(cleanType)
        if mapped == "ptr" {
            return "ptr noalias nonnull"
        }
        return mapped
    }

    fun mapStorageTypeForParameter(seenType: String) r: String {
        let mapped = mapTypeForParameter(seenType)
        if mapped == "ptr noalias nonnull" {
            return "ptr"
        }
        return mapped
    }

    fun normalizeSeenTypeName(seenType: String) r: String {
        var normalized = seenType
        if normalized.startsWith("move:") {
            normalized = normalized.substring(5, normalized.length())
        }
        if normalized.startsWith("borrow:") {
            normalized = normalized.substring(7, normalized.length())
        }
        if normalized.startsWith("comptime:") {
            normalized = normalized.substring(9, normalized.length())
        }
        if normalized.contains("~default~") {
            let defPos = normalized.indexOf("~default~", 0)
            normalized = normalized.substring(0, defPos)
        }
        if normalized == "i1" {
            return "Bool"
        }
        if normalized == "i64" {
            return "Int"
        }
        if normalized == "%SeenString" {
            return "String"
        }
        return normalized
    }

    fun normalizeDeclaredTypeNode(typeNode: TypeNode) r: String {
        let normalized = normalizeSeenTypeName(typeNode.typeName)
        if typeNode.isNullable {
            if normalized == "Option<String>" or normalized == "Optional<String>" {
                return "String?"
            }
        }
        return normalized
    }

    fun prepareCallArguments(funcName: String, arguments: Array<ParserExpressionNode>,
        argRegs: Array<String>, argTypeStrs: Array<String>, enableDynBoxing: Bool,
        enableFloatPromotion: Bool, nullifyMovedSources: Bool, moveContext: String) r: Void {

        var argIdx = 0
        while argIdx < arguments.length() {
            let argExpr = arguments[argIdx]
            let argReg = generateExpression(argExpr)
            let argType = inferExpressionType(argExpr)
            if enableFloatPromotion and argType == "Int" and currentClassName == "LLVMIRGenerator" {
                println("[irgen float lookup] class=" + currentClassName + " target=" + funcName + " arg=" + argIdx.toString())
            }
            let argLlvmType = mapType(argType)
            appendPreparedCallArgImpl(output, g_regBox, funcName, argReg, argType, argLlvmType, argIdx, argRegs, argTypeStrs, g_dynParamFuncs, enableDynBoxing, enableFloatPromotion, g_floatParamFuncNames, g_floatParamParamIdxs)

            if nullifyMovedSources and g_moveOnlyClasses != "" and g_moveOnlyClasses.contains(argType + "|") {
                if argExpr.kind == "Variable" or argExpr.kind == "VarExpr" {
                    var moveVarName = argExpr.variableName
                    if moveVarName == "" { moveVarName = argExpr.literalValue }
                    if moveVarName != "" {
                        let moveVarIdx = findVar(moveVarName)
                        if moveVarIdx >= 0 {
                            let moveSrcReg = varRegs[moveVarIdx]
                            output.append("  store i64 0, ptr " + moveSrcReg + " ; @move: nullify source (" + moveContext + ")\n")
                            g_movedVarNames = g_movedVarNames + moveVarName + "|"
                            g_movedVarCount = g_movedVarCount + 1
                        }
                    }
                }
            }
            argIdx = argIdx + 1
        }
    }

    fun prepareCallArgumentsWithDefaults(funcName: String,
        arguments: Array<ParserExpressionNode>, enableDynBoxing: Bool,
        enableFloatPromotion: Bool, nullifyMovedSources: Bool,
        moveContext: String) r: Void {

        let preparedArgRegs = Array<String>()
        let preparedArgTypeStrs = Array<String>()
        prepareCallArguments(funcName, arguments, preparedArgRegs,
            preparedArgTypeStrs, enableDynBoxing, enableFloatPromotion,
            nullifyMovedSources, moveContext)
        fillDefaultParamsLocal(funcName, preparedArgRegs, preparedArgTypeStrs)
    }

    fun fillDefaultParamsLocal(funcName: String, argRegs: Array<String>, argTypeStrs: Array<String>) r: Void {
        g_defaultFillArgRegs = argRegs
        g_defaultFillArgTypeStrs = argTypeStrs
        fillDefaultParamsImpl(output, g_regBox, funcName, g_defaultFillArgRegs,
            g_defaultFillArgTypeStrs, g_funcParamCountArr, g_funcDefaultsArr,
            stringConstantPrefix, stringConstants)
    }

    fun collectDefaultParamStringConstantsFromFunction(fn: FunctionNode) r: Void {
        var paramIdx = 0
        while paramIdx < fn.params.length() {
            let param = fn.params[paramIdx]
            let paramTypeName = param.paramType.typeName
            if paramTypeName.contains("~default~") {
                let defaultPos = paramTypeName.indexOf("~default~", 0)
                let defaultValue = paramTypeName.substring(defaultPos + 9, paramTypeName.length())
                if normalizeSeenTypeName(paramTypeName) == "String" {
                    var exists = false
                    var sci = 0
                    while sci < stringConstants.length() {
                        if stringConstants[sci] == defaultValue {
                            exists = true
                            sci = stringConstants.length()
                        }
                        sci = sci + 1
                    }
                    if not exists {
                        stringConstants.push(defaultValue)
                    }
                }
            }
            paramIdx = paramIdx + 1
        }
    }

    fun collectDefaultParamStringConstants(program: ProgramNode) r: Void {
        var itemIdx = 0
        while itemIdx < program.items.length() {
            let item = program.items[itemIdx]
            if item.itemType == "Function" {
                collectDefaultParamStringConstantsFromFunction(item.function)
            } else if item.itemType == "Class" {
                var methodIdx = 0
                while methodIdx < item.classNode.methods.length() {
                    collectDefaultParamStringConstantsFromFunction(item.classNode.methods[methodIdx])
                    methodIdx = methodIdx + 1
                }
            }
            itemIdx = itemIdx + 1
        }
    }

    fun inferReturnExprType(className: String, expr: ParserExpressionNode) r: String {
        if expr.kind == "None" {
            return "Void"
        }
        if expr.kind == "StructLiteral" {
            if expr.literalType != "" and expr.literalType != "Unknown" {
                return expr.literalType
            }
            return className
        }
        if expr.kind == "MethodCall" and expr.callee == "new" {
            if expr.literalValue != "" {
                return expr.literalValue
            }
            return className
        }
        let inferred = inferExpressionType(expr)
        if inferred != "" and inferred != "Unknown" {
            return inferred
        }
        return ""
    }

    fun inferBlockReturnType(className: String, block: BlockNode) r: String {
        var stmtIdx = 0
        var sawReturn = false
        while stmtIdx < block.statements.length() {
            let stmt = block.statements[stmtIdx]
            if stmt.kind == "Return" {
                sawReturn = true
                let retType = inferReturnExprType(className, stmt.returnValue)
                if retType != "" {
                    return retType
                }
            }
            if stmt.kind == "If" {
                let thenType = inferBlockReturnType(className, stmt.thenBranch)
                let elseType = inferBlockReturnType(className, stmt.elseBranch)
                if thenType != "" and elseType != "" and thenType == elseType {
                    return thenType
                }
            }
            stmtIdx = stmtIdx + 1
        }
        if not sawReturn {
            return "Void"
        }
        return ""
    }

    fun resolveMethodReturnType(className: String, method: FunctionNode) r: String {
        let declaredType = normalizeDeclaredTypeNode(method.returnType)
        if declaredType != "" and declaredType != "Unknown" {
            return declaredType
        }
        if method.name == "new" {
            return className
        }
        let inferredType = inferBlockReturnType(className, method.body)
        if inferredType != "" and inferredType != "Unknown" {
            return inferredType
        }
        return declaredType
    }

    fun resolveMethodReturnTypeFromList(className: String, methods: Array<FunctionNode>, methodIdx: Int) r: String {
        let method = methods[methodIdx]
        let declaredType = normalizeDeclaredTypeNode(method.returnType)
        if declaredType != "" and declaredType != "Unknown" {
            return declaredType
        }
        if method.name == "new" {
            return className
        }
        let inferredType = inferBlockReturnType(className, method.body)
        if inferredType != "" and inferredType != "Unknown" {
            return inferredType
        }
        return declaredType
    }

    fun resolveMethodReturnTypeByIndex(classNode: ClassNode, methodIdx: Int) r: String {
        return resolveMethodReturnTypeFromList(classNode.name, classNode.methods, methodIdx)
    }

    fun resolveFunctionReturnType(fn: FunctionNode) r: String {
        let declaredType = normalizeDeclaredTypeNode(fn.returnType)
        if declaredType != "" and declaredType != "Unknown" {
            return declaredType
        }
        let inferredType = inferBlockReturnType("", fn.body)
        if inferredType != "" and inferredType != "Unknown" {
            return inferredType
        }
        return declaredType
    }

    fun mapSimpleLlvmTypeToSeenType(llvmType: String) r: String {
        if llvmType == "i64" {
            return "Int"
        }
        if llvmType == "double" {
            return "Float"
        }
        if llvmType == "i1" {
            return "Bool"
        }
        if llvmType == "%SeenString" {
            return "String"
        }
        return "Int"
    }

    fun tryInferModuleConstantVariableType(varName: String) r: String {
        let constIdx = findModuleConstant(varName)
        if constIdx < 0 {
            return ""
        }
        let seenType = getModuleConstSeenType(constIdx)
        if seenType != "" {
            return seenType
        }
        return mapSimpleLlvmTypeToSeenType(moduleConstantTypes[constIdx])
    }

    fun tryInferLLVMIRGeneratorThisFieldType(thisType: String, varName: String) r: String {
        if thisType != "LLVMIRGenerator" {
            return ""
        }
        let idxCheck = getLLVMIRGeneratorFieldIndex(varName)
        if idxCheck >= 0 {
            return getSeenFieldType(thisType, varName)
        }
        return ""
    }

    fun tryInferStructThisFieldType(thisType: String, varName: String) r: String {
        let structIdx = findStruct(thisType)
        if structIdx < 0 {
            return ""
        }
        let fieldIdx = getFieldInfo(thisType, varName)
        if fieldIdx >= 0 {
            return getSeenFieldType(thisType, varName)
        }
        return ""
    }

    fun tryInferImplicitThisVariableType(varName: String) r: String {
        let thisIdx = findVar("this")
        if thisIdx < 0 {
            return ""
        }
        let thisType = varTypes[thisIdx]
        let generatorFieldType = tryInferLLVMIRGeneratorThisFieldType(thisType,
            varName)
        if generatorFieldType != "" {
            return generatorFieldType
        }
        return tryInferStructThisFieldType(thisType, varName)
    }

    fun tryInferNamedPrimitiveVariableType(varName: String) r: String {
        if varName == "Int8" or varName == "UInt8" or varName == "Int16" or
            varName == "UInt16" or varName == "Int32" or varName == "UInt32" or
            varName == "Int64" or varName == "UInt64" or varName == "Float32" {
            return varName
        }
        return ""
    }

    fun inferVariableExprTypeLocal(expr: ParserExpressionNode) r: String {
        let varName = getExprVariableName(expr)
        let varType = findVarType(varName)
        if varType != "" {
            return varType
        }
        let moduleConstType = tryInferModuleConstantVariableType(varName)
        if moduleConstType != "" {
            return moduleConstType
        }
        let implicitThisType = tryInferImplicitThisVariableType(varName)
        if implicitThisType != "" {
            return implicitThisType
        }
        return tryInferNamedPrimitiveVariableType(varName)
    }

    fun tryInferSimdBinaryExprType(expr: ParserExpressionNode) r: String {
        if expr.operands.length() >= 2 {
            let binLeftType = inferExpressionType(expr.operands[0])
            if isSimdVectorType(binLeftType) == 1 {
                return binLeftType
            }
        }
        return ""
    }

    fun isBoolBinaryOperator(operatorName: String) r: Int {
        if operatorName == "==" or operatorName == "!=" or operatorName == "<" or
            operatorName == ">" or operatorName == "<=" or operatorName == ">=" or
            operatorName == "and" or operatorName == "or" {
            return 1
        }
        return 0
    }

    fun tryInferArithmeticBinaryExprType(expr: ParserExpressionNode) r: String {
        if expr.operator == "+" {
            if expr.operands.length() < 2 {
                return ""
            }
            let leftExpr = expr.operands[0]
            let rightExpr = expr.operands[1]
            if leftExpr.kind == "Literal" and leftExpr.literalType == "String" {
                return "String"
            }
            if rightExpr.kind == "Literal" and rightExpr.literalType == "String" {
                return "String"
            }
            let leftType = inferExpressionType(expr.operands[0])
            if leftType == "String" {
                return "String"
            }
            let rightType = inferExpressionType(expr.operands[1])
            if rightType == "String" {
                return "String"
            }
            if leftType == "Float" or rightType == "Float" {
                return "Float"
            }
            return ""
        }
        if expr.operator == "-" or expr.operator == "*" or expr.operator == "/" or
            expr.operator == "%" {
            if expr.operands.length() >= 2 {
                let leftType = inferExpressionType(expr.operands[0])
                let rightType = inferExpressionType(expr.operands[1])
                if leftType == "Float" or rightType == "Float" {
                    return "Float"
                }
            }
        }
        return ""
    }

    fun resolveBinaryOperatorOverloadSuffix(operatorName: String) r: String {
        if operatorName == "+" { return "operator_add" }
        if operatorName == "-" { return "operator_sub" }
        if operatorName == "*" { return "operator_mul" }
        if operatorName == "/" { return "operator_div" }
        if operatorName == "%" { return "operator_mod" }
        if operatorName == "==" { return "operator_eq" }
        if operatorName == "!=" { return "operator_neq" }
        if operatorName == "<" { return "operator_lt" }
        if operatorName == ">" { return "operator_gt" }
        if operatorName == "<=" { return "operator_lte" }
        if operatorName == ">=" { return "operator_gte" }
        return ""
    }

    fun tryInferOverloadedBinaryExprType(expr: ParserExpressionNode) r: String {
        let opSuffix = resolveBinaryOperatorOverloadSuffix(expr.operator)
        if opSuffix == "" or expr.operands.length() < 1 {
            return ""
        }
        let leftOpType = inferExpressionType(expr.operands[0])
        let opFuncN = leftOpType + "_" + opSuffix
        return getFunctionReturnType(opFuncN)
    }

    fun inferBinaryExprTypeLocal(expr: ParserExpressionNode) r: String {
        let simdType = tryInferSimdBinaryExprType(expr)
        if simdType != "" {
            return simdType
        }
        if isBoolBinaryOperator(expr.operator) == 1 {
            return "Bool"
        }
        let arithmeticType = tryInferArithmeticBinaryExprType(expr)
        if arithmeticType != "" {
            return arithmeticType
        }
        let overloadType = tryInferOverloadedBinaryExprType(expr)
        if overloadType != "" {
            return overloadType
        }
        return "Int"
    }

    fun resolveMethodCallReceiverType(expr: ParserExpressionNode) r: String {
        if expr.operands.length() > 0 {
            return inferExpressionType(expr.operands[0])
        }
        return resolveLiteralMethodReceiverType(expr.literalValue)
    }

    fun tryInferExplicitThisMethodCallType(expr: ParserExpressionNode) r: String {
        if currentClassName != "" and expr.literalValue == "this" {
            return getMethodReturnType(currentClassName, expr.callee)
        }
        return ""
    }

    fun tryInferBareMethodOrFunctionCallType(expr: ParserExpressionNode) r: String {
        if expr.literalValue != "" or expr.operands.length() != 0 {
            return ""
        }
        if currentClassName != "" {
            let implicitMethodRetType = getMethodReturnType(currentClassName,
                expr.callee)
            if implicitMethodRetType != "" {
                return implicitMethodRetType
            }
        }
        let freeFuncRetType = getFunctionReturnType(expr.callee)
        if freeFuncRetType == "" {
            return ""
        }
        if isAsyncFunction(expr.callee) {
            return "ptr"
        }
        return freeFuncRetType
    }

    fun tryInferImplicitOrFreeMethodCallType(expr: ParserExpressionNode) r: String {
        let explicitThisType = tryInferExplicitThisMethodCallType(expr)
        if explicitThisType != "" {
            return explicitThisType
        }
        return tryInferBareMethodOrFunctionCallType(expr)
    }

    fun tryInferDeclaredStaticMethodCallType(expr: ParserExpressionNode) r: String {
        if expr.literalValue != "" and expr.literalValue != "this" {
            let recVarType = findVarType(expr.literalValue)
            if recVarType == "" {
                let staticOwnerType = getBaseTypeName(expr.literalValue)
                var staticRetType = getMethodReturnType(expr.literalValue, expr.callee)
                if staticRetType == "" and staticOwnerType != expr.literalValue {
                    staticRetType = getMethodReturnType(staticOwnerType, expr.callee)
                }
                if staticRetType != "" {
                    return staticRetType
                }
            }
        }
        return ""
    }

    fun tryInferStaticFactoryMethodType(expr: ParserExpressionNode) r: String {
        if expr.callee == "new" {
            return expr.literalValue
        }
        if expr.callee == "withCapacity" {
            let capacityOwnerType = getBaseTypeName(expr.literalValue)
            if capacityOwnerType == "Vec" or capacityOwnerType == "HashMap" or capacityOwnerType == "BTreeMap" or capacityOwnerType == "LinkedList" or capacityOwnerType == "StringHashMap" {
                return expr.literalValue
            }
        }
        if (expr.callee == "withLength" or expr.callee == "withCapacity") and expr.literalValue.startsWith("Array") {
            return expr.literalValue
        }
        return ""
    }

    fun tryInferStaticFromJsonMethodType(expr: ParserExpressionNode) r: String {
        if expr.callee == "fromJson" {
            if expr.literalValue != "" and expr.literalValue != "this" {
                let staticRetType = getMethodReturnType(expr.literalValue, "fromJson")
                if staticRetType != "" {
                    return staticRetType
                }
            }
            return "ptr"
        }
        return ""
    }

    fun tryInferStaticMethodCallType(expr: ParserExpressionNode) r: String {
        let declaredStaticType = tryInferDeclaredStaticMethodCallType(expr)
        if declaredStaticType != "" {
            return declaredStaticType
        }
        let staticFactoryType = tryInferStaticFactoryMethodType(expr)
        if staticFactoryType != "" {
            return staticFactoryType
        }
        return tryInferStaticFromJsonMethodType(expr)
    }

    fun tryInferSimpleBuiltinReceiverMethodType(methodName: String,
        receiverType: String) r: String {

        if methodName == "toUpperCase" or methodName == "toLowerCase" or
            methodName == "abs" or methodName == "min" or methodName == "max" or
            methodName == "clamp" or methodName == "floor" or
            methodName == "ceil" or methodName == "round" or
            methodName == "sqrt" or methodName == "first" or
            methodName == "last" or methodName == "remove" {
            return inferReceiverMethodTypeImpl(methodName, receiverType)
        }
        return ""
    }

    fun tryInferCollectionGetMethodType(expr: ParserExpressionNode,
        receiverType: String) r: String {

        if expr.callee == "get" {
            traceGen("inferExpressionType: get() recType=" + receiverType + " literalValue=" + expr.literalValue + " operands=" + expr.operands.length().toString())
            let isCollectionGet = receiverType.startsWith("Array<") or receiverType.startsWith("Vec<") or
                receiverType.startsWith("HashMap<") or receiverType.startsWith("StringHashMap<") or
                receiverType.startsWith("BTreeMap<") or receiverType.startsWith("Map<") or receiverType == ""
            if isCollectionGet {
                let collGetType = resolveCollectionGetTypeImpl(receiverType)
                if collGetType != "" {
                    return collGetType
                }
                return "Option<Int>"
            }
        }
        return ""
    }

    fun tryInferPopMethodType(methodName: String, receiverType: String) r: String {
        if methodName != "pop" {
            return ""
        }
        let popResult = resolvePopElementTypeImpl(receiverType)
        if popResult != "" {
            return popResult
        }
        return "Int"
    }

    fun tryInferUnwrapMethodType(methodName: String, receiverType: String) r: String {
        if methodName != "unwrap" {
            return ""
        }
        var isClassInner = 0
        if isClassType(receiverType) {
            isClassInner = 1
        }
        let unwrapResult = resolveUnwrapTypeImpl(receiverType, isClassInner)
        if unwrapResult != "" {
            return unwrapResult
        }
        return "ptr"
    }

    fun tryInferBuiltinReceiverMethodCallType(expr: ParserExpressionNode, receiverType: String) r: String {
        let simpleBuiltinType = tryInferSimpleBuiltinReceiverMethodType(
            expr.callee, receiverType)
        if simpleBuiltinType != "" {
            return simpleBuiltinType
        }
        let collectionGetType = tryInferCollectionGetMethodType(expr,
            receiverType)
        if collectionGetType != "" {
            return collectionGetType
        }
        let popType = tryInferPopMethodType(expr.callee, receiverType)
        if popType != "" {
            return popType
        }
        let unwrapType = tryInferUnwrapMethodType(expr.callee, receiverType)
        if unwrapType != "" {
            return unwrapType
        }
        return ""
    }

    fun tryInferSimdReduceMethodType(methodName: String, receiverType: String) r: String {
        if isSimdVectorType(receiverType) != 1 {
            return ""
        }
        if methodName == "reduce_add" or methodName == "reduce_min" or
            methodName == "reduce_max" {
            if receiverType.startsWith("f32") or receiverType.startsWith("f64") {
                return "Float"
            }
            return "Int"
        }
        return ""
    }

    fun tryInferReceiverRegistryMethodCallType(expr: ParserExpressionNode, receiverType: String) r: String {
        if receiverType == "" {
            return ""
        }
        let simdReduceType = tryInferSimdReduceMethodType(expr.callee,
            receiverType)
        if simdReduceType != "" {
            return simdReduceType
        }
        return getMethodReturnType(receiverType, expr.callee)
    }

    fun tryInferMethodCallBoolSuffix(expr: ParserExpressionNode) r: String {
        let boolSuffix = "_" + expr.callee
        var boolScanIdx = funcNames.length() - 1
        while boolScanIdx >= 0 {
            if funcNames[boolScanIdx].endsWith(boolSuffix) {
                if funcRetTypes[boolScanIdx] == "Bool" {
                    return "Bool"
                }
                boolScanIdx = -1
            }
            boolScanIdx = boolScanIdx - 1
        }
        return ""
    }

    fun tryInferLateMethodCallFallbackType(expr: ParserExpressionNode) r: String {
        let mcTable = inferMethodCallTypeTable(expr.callee)
        if mcTable != "" {
            return mcTable
        }
        if currentClassName != "" {
            let implicitMethodRetType = getMethodReturnType(currentClassName,
                expr.callee)
            if implicitMethodRetType != "" {
                return implicitMethodRetType
            }
        }
        let freeFuncRetType = getFunctionReturnType(expr.callee)
        if freeFuncRetType != "" {
            if isAsyncFunction(expr.callee) {
                return "ptr"
            }
            return freeFuncRetType
        }
        return tryInferMethodCallBoolSuffix(expr)
    }

    fun inferMethodCallExprTypeLocal(expr: ParserExpressionNode) r: String {
        let implicitOrFreeResult = tryInferImplicitOrFreeMethodCallType(expr)
        if implicitOrFreeResult != "" {
            return implicitOrFreeResult
        }

        let receiverType = resolveMethodCallReceiverType(expr)
        let receiverRegistryType = tryInferReceiverRegistryMethodCallType(expr, receiverType)
        if receiverRegistryType != "" {
            return receiverRegistryType
        }

        let staticResult = tryInferStaticMethodCallType(expr)
        if staticResult != "" {
            return staticResult
        }

        let builtinReceiverResult = tryInferBuiltinReceiverMethodCallType(expr, receiverType)
        if builtinReceiverResult != "" {
            return builtinReceiverResult
        }
        return tryInferLateMethodCallFallbackType(expr)
    }

    fun tryInferGeneratedCallType(expr: ParserExpressionNode) r: String {
        if isSimdVectorType(expr.callee) == 1 {
            return expr.callee
        }
        if expr.callee.endsWith("_new") {
            let baseType = expr.callee.substring(0, expr.callee.length() - 4)
            if isClassType(baseType) or isDataType(baseType) or
                findStruct(baseType) >= 0 {
                return baseType
            }
        }
        if expr.callee.endsWith("_fromJson") {
            let baseType = expr.callee.substring(0, expr.callee.length() - 9)
            let fromJsonRet = getMethodReturnType(baseType, "fromJson")
            if fromJsonRet != "" {
                return fromJsonRet
            }
            if isClassType(baseType) or isDataType(baseType) or
                findStruct(baseType) >= 0 {
                return baseType + "?"
            }
        }
        return ""
    }

    fun tryInferBuiltinCallExprType(expr: ParserExpressionNode) r: String {
        if expr.callee == "simd_select" or expr.callee == "simd_shuffle" {
            if expr.arguments.length() >= 2 {
                return inferExpressionType(expr.arguments[1])
            }
        }
        let builtinType = inferCallExprTypeImpl(expr.callee)
        if builtinType != "" {
            return builtinType
        }
        if g_enumVariantCount > 0 and isEnumVariant(expr.callee) {
            return lookupEnumParent(expr.callee)
        }
        return ""
    }

    fun tryInferResolvedCallExprType(expr: ParserExpressionNode) r: String {
        let userRetType = getFunctionReturnType(expr.callee)
        if userRetType != "" {
            if isAsyncFunction(expr.callee) {
                return "ptr"
            }
            return userRetType
        }
        let callTable = inferCallTypeTable(expr.callee)
        if callTable != "" {
            return callTable
        }
        if isClassType(expr.callee) {
            return expr.callee
        }
        if currentClassName != "" {
            return getMethodReturnType(currentClassName, expr.callee)
        }
        return ""
    }

    fun inferCallExprTypeLocal(expr: ParserExpressionNode) r: String {
        let generatedCallType = tryInferGeneratedCallType(expr)
        if generatedCallType != "" {
            return generatedCallType
        }
        let builtinCallType = tryInferBuiltinCallExprType(expr)
        if builtinCallType != "" {
            return builtinCallType
        }
        return tryInferResolvedCallExprType(expr)
    }

    fun tryInferJsonValueMemberAccessType(expr: ParserExpressionNode, fieldName: String) r: String {
        if fieldName != "kind" and fieldName != "boolValue" and fieldName != "numberValue" and
            fieldName != "stringValue" and fieldName != "arrayValue" and
            fieldName != "objectKeys" and fieldName != "objectValues" {
            return ""
        }

        if expr.operands.length() > 0 {
            if inferExpressionType(expr.operands[0]) == "JsonValue" {
                return getSeenFieldType("JsonValue", fieldName)
            }
        }
        if expr.literalValue == "this" and currentClassName == "JsonValue" {
            return getSeenFieldType("JsonValue", fieldName)
        }
        if expr.literalValue != "" and expr.literalValue != "this" {
            if findVarType(expr.literalValue) == "JsonValue" {
                return getSeenFieldType("JsonValue", fieldName)
            }
        }
        return ""
    }

    fun tryInferMemberFieldType(receiverType: String, fieldName: String) r: String {
        if receiverType == "" {
            return ""
        }
        let semanticFieldType = getSemanticFieldType(receiverType, fieldName)
        if semanticFieldType != "" {
            return semanticFieldType
        }
        return getSeenFieldType(receiverType, fieldName)
    }

    fun tryInferLiteralReceiverMemberAccessType(receiverName: String, fieldName: String) r: String {
        if receiverName == "" or receiverName == "this" {
            return ""
        }

        if receiverName.contains(".") {
            let chainedFieldType = tryInferMemberFieldType(resolveChainedPathType(receiverName), fieldName)
            if chainedFieldType != "" {
                return chainedFieldType
            }
        }

        let receiverVarType = findVarType(receiverName)
        let directFieldType = tryInferMemberFieldType(receiverVarType, fieldName)
        if directFieldType != "" {
            return directFieldType
        }

        let thisIdx = findVar("this")
        if thisIdx >= 0 {
            let receiverFieldType = getSemanticFieldType(varTypes[thisIdx], receiverName)
            let nestedFieldType = tryInferMemberFieldType(receiverFieldType, fieldName)
            if nestedFieldType != "" {
                return nestedFieldType
            }
        }
        return ""
    }

    fun tryInferDirectMemberAccessType(expr: ParserExpressionNode,
        fieldName: String) r: String {

        if expr.literalValue == "this" and currentClassName != "" {
            let implicitThisFieldType = tryInferMemberFieldType(currentClassName,
                fieldName)
            if implicitThisFieldType != "" {
                return implicitThisFieldType
            }
        }
        if expr.operands.length() > 0 {
            let receiverFieldType = tryInferMemberFieldType(
                inferExpressionType(expr.operands[0]), fieldName)
            if receiverFieldType != "" {
                return receiverFieldType
            }
        }
        if expr.literalValue != "" and expr.literalValue != "this" {
            let literalReceiverFieldType =
                tryInferLiteralReceiverMemberAccessType(expr.literalValue,
                    fieldName)
            if literalReceiverFieldType != "" {
                return literalReceiverFieldType
            }
        }
        return ""
    }

    fun inferMemberAccessExprTypeLocal(expr: ParserExpressionNode) r: String {
        if expr.literalValue != "" {
            let swizzleType = inferSimdSwizzleMemberTypeImpl(
                findVarType(expr.literalValue), expr.variableName)
            if swizzleType != "" {
                return swizzleType
            }
        }
        if g_enumVariantCount > 0 {
            if isEnumVariant(expr.variableName) {
                let enumParent = lookupEnumParent(expr.variableName)
                if enumParent != "" and enumParent == expr.literalValue {
                    return enumParent
                }
            }
        }
        let fieldName = extractLastMemberFieldSegmentImpl(expr.variableName)

        let jsonFieldType = tryInferJsonValueMemberAccessType(expr, fieldName)
        if jsonFieldType != "" {
            return jsonFieldType
        }
        let directFieldType = tryInferDirectMemberAccessType(expr, fieldName)
        if directFieldType != "" {
            return directFieldType
        }
        let fieldFallback = inferFieldTypeFallback(fieldName)
        if fieldFallback != "" { return fieldFallback }
        return ""
    }

    fun tryInferDeclaredLiteralType(expr: ParserExpressionNode) r: String {
        if expr.literalType == "Int" or expr.literalType == "Integer" {
            return "Int"
        }
        if expr.literalType == "String" {
            return "String"
        }
        if expr.literalType == "Char" {
            return "Char"
        }
        if expr.literalType == "Bool" or expr.literalType == "Boolean" {
            return "Bool"
        }
        if expr.literalType == "Float" {
            return "Float"
        }
        if expr.literalType != "" {
            return expr.literalType
        }
        return ""
    }

    fun inferLiteralValueFallbackType(expr: ParserExpressionNode) r: String {
        if expr.literalValue.startsWith("\"") or expr.literalValue.startsWith("'") {
            return "String"
        }
        if expr.literalValue.contains(".") {
            return "Float"
        }
        return "Int"
    }

    fun inferLiteralExprTypeLocal(expr: ParserExpressionNode) r: String {
        let declaredLiteralType = tryInferDeclaredLiteralType(expr)
        if declaredLiteralType != "" {
            return declaredLiteralType
        }
        return inferLiteralValueFallbackType(expr)
    }

    fun tryInferIndexedElementType(arrayType: String) r: String {
        let elemType = inferIndexElementType(arrayType)
        if elemType != "" {
            return elemType
        }
        if arrayType.startsWith("Array<") and arrayType.endsWith(">") {
            return arrayType.substring(6, arrayType.length() - 1)
        }
        return ""
    }

    fun inferIndexAccessExprTypeLocal(expr: ParserExpressionNode) r: String {
        let arrayType = inferExpressionType(expr.operands[0])
        let elemType = tryInferIndexedElementType(arrayType)
        if elemType != "" {
            return elemType
        }
        return "ptr"
    }

    fun tryInferKnownArrayLiteralType(firstElemType: String) r: String {
        if firstElemType == "String" {
            return "Array<String>"
        }
        if firstElemType == "Float" {
            return "Array<Float>"
        }
        if firstElemType == "Bool" {
            return "Array<Bool>"
        }
        return ""
    }

    fun inferArrayLiteralExprTypeLocal(expr: ParserExpressionNode) r: String {
        if expr.arguments.length() == 0 {
            return "Array"
        }
        let firstElemType = inferExpressionType(expr.arguments[0])
        let knownArrayType = tryInferKnownArrayLiteralType(firstElemType)
        if knownArrayType != "" {
            return knownArrayType
        }
        return "Array<Int>"
    }

    fun collectStringConstantsFromExprList(exprs: Array<ParserExpressionNode>) r: Void {
        var i = 0
        while i < exprs.length() {
            collectStringConstantsFromExpr(exprs[i])
            i = i + 1
        }
    }

    fun inferStringInterpolationExprTypeLocal(expr: ParserExpressionNode) r: String {
        collectStringConstantsFromExprList(expr.arguments)
        collectStringConstantsFromExprList(expr.operands)
        return "String"
    }

    fun tryInferAddressUnaryType(expr: ParserExpressionNode) r: String {
        if expr.operator != "&" or expr.operands.length() == 0 {
            return ""
        }
        return "*" + inferExpressionType(expr.operands[0])
    }

    fun tryInferDereferenceUnaryType(expr: ParserExpressionNode) r: String {
        if expr.operator != "*" or expr.operands.length() == 0 {
            return ""
        }
        let ptrType = inferExpressionType(expr.operands[0])
        if ptrType.startsWith("*") {
            return ptrType.substring(1, ptrType.length())
        }
        return "Int"
    }

    fun inferUnaryExprTypeLocal(expr: ParserExpressionNode) r: String {
        if expr.operator == "!" or expr.operator == "not" {
            return "Bool"
        }
        let addressType = tryInferAddressUnaryType(expr)
        if addressType != "" {
            return addressType
        }
        let dereferenceType = tryInferDereferenceUnaryType(expr)
        if dereferenceType != "" {
            return dereferenceType
        }
        if expr.operands.length() > 0 {
            return inferExpressionType(expr.operands[0])
        }
        return "Int"
    }

    fun tryInferAwaitedCallType(inner: ParserExpressionNode) r: String {
        if inner.kind != "Call" {
            return ""
        }
        let asyncRet = getAsyncDeclaredRetType(inner.callee)
        if asyncRet != "" {
            return asyncRet
        }
        return getFunctionReturnType(inner.callee)
    }

    fun inferAwaitExprTypeLocal(expr: ParserExpressionNode) r: String {
        if expr.operands.length() == 0 {
            return "Void"
        }
        let inner = expr.operands[0]
        let awaitedCallType = tryInferAwaitedCallType(inner)
        if awaitedCallType != "" {
            return awaitedCallType
        }
        return inferExpressionType(inner)
    }

    fun inferTryPropagateExprTypeLocal(expr: ParserExpressionNode) r: String {
        if expr.operands.length() == 0 {
            return ""
        }
        let tryInnerType = inferExpressionType(expr.operands[0])
        let tryResult = resolveTryPropagateTypeImpl(tryInnerType)
        if tryResult != "" {
            return tryResult
        }
        return tryInnerType
    }

    fun tryInferNullishSpecialExprType(expr: ParserExpressionNode) r: String {
        if expr.kind == "Elvis" or expr.kind == "NullCoalesce" {
            if expr.operands.length() > 0 {
                return inferExpressionType(expr.operands[0])
            }
            return ""
        }
        if expr.kind == "SafeNavigation" {
            return "Int"
        }
        return ""
    }

    fun tryInferBranchingSpecialExprType(expr: ParserExpressionNode) r: String {
        if expr.kind == "WhenExpression" {
            if expr.arguments.length() > 0 {
                let firstArm = expr.arguments[0]
                if firstArm.operands.length() > 1 {
                    return inferExpressionType(firstArm.operands[1])
                }
            }
            return ""
        }
        if expr.kind == "IfExpression" {
            if expr.operands.length() > 1 {
                return inferExpressionType(expr.operands[1])
            }
            return ""
        }
        return ""
    }

    fun tryInferFixedSpecialExprType(expr: ParserExpressionNode) r: String {
        if expr.kind == "Range" {
            return "Range"
        }
        if expr.kind == "IsExpression" {
            return "Bool"
        }
        if expr.kind == "Closure" {
            return "Int"
        }
        if expr.kind == "TryPropagate" {
            return inferTryPropagateExprTypeLocal(expr)
        }
        if expr.kind == "Cast" {
            return expr.literalValue
        }
        return ""
    }

    fun inferSpecialExprTypeLocal(expr: ParserExpressionNode) r: String {
        if expr.kind == "StructLiteral" {
            return expr.literalType
        }
        if expr.kind == "IndexAccess" {
            return inferIndexAccessExprTypeLocal(expr)
        }
        if expr.kind == "ArrayLiteral" {
            return inferArrayLiteralExprTypeLocal(expr)
        }
        if expr.kind == "StringInterpolation" {
            return inferStringInterpolationExprTypeLocal(expr)
        }
        if expr.kind == "Unary" {
            return inferUnaryExprTypeLocal(expr)
        }
        if expr.kind == "Await" {
            return inferAwaitExprTypeLocal(expr)
        }
        let nullishSpecialType = tryInferNullishSpecialExprType(expr)
        if nullishSpecialType != "" or expr.kind == "SafeNavigation" {
            return nullishSpecialType
        }
        let branchingSpecialType = tryInferBranchingSpecialExprType(expr)
        if branchingSpecialType != "" or expr.kind == "WhenExpression" or expr.kind == "IfExpression" {
            return branchingSpecialType
        }
        let fixedSpecialType = tryInferFixedSpecialExprType(expr)
        if fixedSpecialType != "" or expr.kind == "Cast" {
            return fixedSpecialType
        }
        return ""
    }

    // Infer the Seen type of an expression for codegen decisions (operator
    // selection, ABI, field access type, etc.). This is NOT the typechecker —
    // it operates during codegen and uses the variable/function/struct registries
    // built during Pass 1. Handles: literals (by literalType), variables (via
    // findVarType + module constants), calls (via getFunctionReturnType +
    // special cases for constructors and builtins), method calls (via
    // inferMethodCallTypeTable), binary ops (type promotion rules), member
    // access (struct field type lookup), index access (element type inference),
    // array literals, struct literals, casts, string interpolation, etc.
    // Returns the Seen type name (e.g., "Int", "String", "MyClass") or ""
    // if inference fails.
    fun inferExpressionType(expr: ParserExpressionNode) r: String {
        if expr.kind == "Literal" {
            return inferLiteralExprTypeLocal(expr)
        }
        if expr.kind == "Variable" or expr.kind == "VarExpr" {
            let variableResult = inferVariableExprTypeLocal(expr)
            if variableResult != "" {
                return variableResult
            }
        }
        if expr.kind == "Binary" {
            return inferBinaryExprTypeLocal(expr)
        }
        if expr.kind == "MethodCall" {
            let methodCallResult = inferMethodCallExprTypeLocal(expr)
            if methodCallResult != "" {
                return methodCallResult
            }
        }
        if expr.kind == "Call" {
            let callResult = inferCallExprTypeLocal(expr)
            if callResult != "" {
                return callResult
            }
        }
        if expr.kind == "MemberAccess" {
            let memberAccessResult = inferMemberAccessExprTypeLocal(expr)
            if memberAccessResult != "" {
                return memberAccessResult
            }
        }
        let specialExprResult = inferSpecialExprTypeLocal(expr)
        if specialExprResult != "" {
            return specialExprResult
        }
        return "Int"
    }

    // Escape string for LLVM IR. Uses byteAt() to avoid per-char substring allocation.
    // ASCII: 92='\', 34='"', 10='\n', 9='\t', 13='\r'
    // Escape a string for embedding in LLVM IR constant data. Replaces
    // backslash, double-quote, newline, tab, and carriage-return with their
    // LLVM hex escape sequences (\5C, \22, \0A, \09, \0D). Uses a fast
    // path (byteAt scan) to skip allocation when no escaping is needed.
    fun escapeString(str: String) r: String {
        // Fast path: check if any escaping is needed at all
        var needsEscape = 0
        var scanIdx = 0
        while scanIdx < str.length() {
            let sb = str.byteAt(scanIdx)
            if sb == 92 or sb == 34 or sb == 10 or sb == 9 or sb == 13 {
                needsEscape = 1
                scanIdx = str.length()
            }
            scanIdx = scanIdx + 1
        }
        if needsEscape == 0 { return str }
        // Slow path: build escaped string using byteAt
        var result = ""
        var i = 0
        while i < str.length() {
            let b = str.byteAt(i)
            var charHandled = false
            if b == 92 {
                result = result + "\\\\"
                charHandled = true
            }
            if not charHandled and b == 34 {
                result = result + "\\22"
                charHandled = true
            }
            if not charHandled and b == 10 {
                result = result + "\\0A"
                charHandled = true
            }
            if not charHandled and b == 9 {
                result = result + "\\09"
                charHandled = true
            }
            if not charHandled and b == 13 {
                result = result + "\\0D"
                charHandled = true
            }
            if not charHandled {
                result = result + str.substring(i, i + 1)
            }
            i = i + 1
        }
        return result
    }

    // Pre-scan all expressions in a program to collect string literal constants.
    // These are emitted as LLVM global constants before any function bodies.
    // Also piggybacks call counting for ML inline decisions and self-call
    // detection (for the norecurse attribute). Delegates to
    // collectStringConstantsImpl in ir_string_collect.seen.
    fun collectStringConstants(program: ProgramNode) r: Void {
        initCollectionBoxes()
        collectStringConstantsImpl(program, stringConstants, g_selfCallBox, g_selfCallCountBox, g_callCountNamesBox, g_callCountEntriesBox)
        syncCollectionBoxes()
        collectDefaultParamStringConstants(program)
    }

    // Thin wrapper for collectStringConstantsFromExpr (called from inferExpressionType)
    fun collectStringConstantsFromExpr(expr: ParserExpressionNode) r: Void {
        initCollectionBoxes()
        collectStringConstantsFromExprImpl(expr, stringConstants, g_callCountNamesBox, g_callCountEntriesBox)
        syncCollectionBoxes()
    }
    fun normalizeSeenStringValueReg(valueReg: String) r: String {
        if valueReg == "0" {
            return "zeroinitializer"
        }
        return valueReg
    }

    fun emitSeenStringConcat(leftReg: String, rightReg: String) r: String {
        let concatReg = getNextReg()
        output.append("  " + concatReg + " = call %SeenString @seen_str_concat_ss(%SeenString " + normalizeSeenStringValueReg(leftReg) + ", %SeenString " + normalizeSeenStringValueReg(rightReg) + ")\n")
        return concatReg
    }

    fun convertInterpolatedExprToString(exprNode: ParserExpressionNode) r: String {
        let exprType = inferExpressionType(exprNode)
        let exprReg = generateExpression(exprNode)
        if exprType == "String" {
            return normalizeSeenStringValueReg(exprReg)
        }
        if exprType == "Int" {
            let strExprReg = getNextReg()
            output.append("  " + strExprReg + " = call %SeenString @seen_int_to_string(i64 " + exprReg + ")\n")
            return strExprReg
        }
        if exprType == "Float" {
            let strExprReg = getNextReg()
            output.append("  " + strExprReg + " = call %SeenString @seen_float_to_string(double " + exprReg + ")\n")
            return strExprReg
        }
        if exprType == "Bool" {
            let strExprReg = getNextReg()
            output.append("  " + strExprReg + " = call %SeenString @seen_bool_to_string(i1 " + exprReg + ")\n")
            return strExprReg
        }
        if exprType == "Char" {
            let strExprReg = getNextReg()
            output.append("  " + strExprReg + " = call %SeenString @seen_char_to_str(i64 " + exprReg + ")\n")
            return strExprReg
        }
        return exprReg
    }

    fun generateStringInterpolation(expr: ParserExpressionNode) r: String {
        var resultReg = ""
        let numParts = expr.arguments.length()
        let numExprs = expr.operands.length()
        var i = 0
        while i < numParts {
            let strPart = expr.arguments[i]
            let partReg = generateLiteral(strPart)
            if resultReg == "" {
                resultReg = partReg
            } else {
                resultReg = emitSeenStringConcat(resultReg, partReg)
            }
            if i < numExprs {
                resultReg = emitSeenStringConcat(resultReg, convertInterpolatedExprToString(expr.operands[i]))
            }
            i = i + 1
        }
        return resultReg
    }

    // Elvis operator: a ?: b — returns a if non-zero/non-null, otherwise b
    // Generate IR for the elvis/null-coalesce operator (a ?? b).
    // Evaluates 'a', checks if null (icmp eq ptr, null), and returns 'b'
    // if null, otherwise 'a'. Uses a phi node to merge the two paths.
    fun emitNullishCheckComparison(valueReg: String, llvmType: String) r: String {
        let cmpReg = getNextReg()
        if llvmType == "%SeenString" {
            let lenReg = getNextReg()
            output.append("  " + lenReg + " = extractvalue %SeenString " + valueReg + ", 0\n")
            output.append("  " + cmpReg + " = icmp eq i64 " + lenReg + ", 0\n")
            return cmpReg
        }
        if llvmType == "i1" {
            output.append("  " + cmpReg + " = icmp eq i1 " + valueReg + ", 0\n")
            return cmpReg
        }
        if llvmType == "double" {
            output.append("  " + cmpReg + " = fcmp oeq double " + valueReg + ", 0.0\n")
            return cmpReg
        }
        output.append("  " + cmpReg + " = icmp eq i64 " + valueReg + ", 0\n")
        return cmpReg
    }

    fun defaultValueForLlvmType(llvmType: String) r: String {
        if llvmType == "%SeenString" {
            return "zeroinitializer"
        }
        if llvmType == "double" {
            return "0.0"
        }
        if llvmType == "i1" {
            return "false"
        }
        return "0"
    }

    fun generateElvis(expr: ParserExpressionNode) r: String {
        let leftReg = generateExpression(expr.operands[0])
        let leftType = inferExpressionType(expr.operands[0])
        let llvmType = mapType(leftType)

        let thenLabel = getNextBlockLabel()
        let elseLabel = getNextBlockLabel()
        let endLabel = getNextBlockLabel()

        let cmpReg = emitNullishCheckComparison(leftReg, llvmType)

        output.append("  br i1 " + cmpReg + ", label %" + elseLabel + ", label %" + thenLabel + "\n")

        // Then: left is non-null, use left
        output.append(thenLabel + ":\n")
        output.append("  br label %" + endLabel + "\n")

        // Else: left is null, compute right
        output.append(elseLabel + ":\n")
        let rightReg = generateExpression(expr.operands[1])
        output.append("  br label %" + endLabel + "\n")

        // Merge with phi
        output.append(endLabel + ":\n")
        return emitPhiMergeValue(llvmType, leftReg, thenLabel, rightReg, elseLabel)
    }

    // Safe navigation: obj?.member — returns member if obj is non-null, else default
    // Generate IR for the safe navigation operator (a?.b).
    // Checks if 'a' is null — if so, short-circuits to null/0 without
    // accessing the field. Otherwise, proceeds with normal field access.
    fun buildSafeNavigationMemberExpr(expr: ParserExpressionNode) r: ParserExpressionNode {
        let memberExpr = ParserExpressionNode.new()
        memberExpr.kind = "MemberAccess"
        memberExpr.variableName = expr.variableName
        memberExpr.operands.push(expr.operands[0])
        return memberExpr
    }

    fun generateSafeNavigation(expr: ParserExpressionNode) r: String {
        let recvReg = generateExpression(expr.operands[0])
        let recvType = inferExpressionType(expr.operands[0])

        let thenLabel = getNextBlockLabel()
        let elseLabel = getNextBlockLabel()
        let endLabel = getNextBlockLabel()

        let cmpReg = emitNullishCheckComparison(recvReg, mapType(recvType))

        output.append("  br i1 " + cmpReg + ", label %" + elseLabel + ", label %" + thenLabel + "\n")

        // Then: non-null, access member
        output.append(thenLabel + ":\n")
        let memberExpr = buildSafeNavigationMemberExpr(expr)
        let memberReg = generateMemberAccess(memberExpr)
        let memberType = inferExpressionType(memberExpr)
        let memberLlvm = mapType(memberType)
        output.append("  br label %" + endLabel + "\n")

        // Else: null, use default
        output.append(elseLabel + ":\n")
        let defaultVal = defaultValueForLlvmType(memberLlvm)
        output.append("  br label %" + endLabel + "\n")

        // Merge
        output.append(endLabel + ":\n")
        return emitPhiMergeValue(memberLlvm, memberReg, thenLabel, defaultVal, elseLabel)
    }

    // When expression (pattern matching)
    // Generate IR for a when (match) expression. Evaluates the subject once,
    // then emits a chain of comparisons against each arm's pattern value.
    // Each arm branches to its body block or falls through to the next
    // comparison. All arms merge into a phi node that produces the result.
    // Supports integer, string, and enum variant patterns.
    fun emitWhenLiteralPatternBranch(subjectReg: String, patternExpr: ParserExpressionNode, armBodyLabel: String, nextCheckLabel: String) r: Void {
        let litVal = patternExpr.literalValue
        let litType = patternExpr.literalType
        let cmpReg = getNextReg()
        if litType == "Bool" {
            var boolVal = "0"
            if litVal == "true" { boolVal = "1" }
            output.append("  " + cmpReg + " = icmp eq i1 " + subjectReg + ", " + boolVal + "\n")
        }
        if litType == "String" {
            let litStrIdx = getStringConstantIndex(litVal)
            let litStrReg = getNextReg()
            output.append("  " + litStrReg + " = load %SeenString, ptr @.str." + litStrIdx.toString() + "\n")
            let eqReg = getNextReg()
            var subjectStrReg = subjectReg
            if subjectReg == "0" {
                subjectStrReg = "zeroinitializer"
            }
            output.append("  " + eqReg + " = call i1 @seen_str_eq(%SeenString " + subjectStrReg + ", %SeenString " + litStrReg + ")\n")
            output.append("  " + cmpReg + " = icmp eq i1 " + eqReg + ", 1\n")
        }
        if litType != "Bool" and litType != "String" {
            output.append("  " + cmpReg + " = icmp eq i64 " + subjectReg + ", " + litVal + "\n")
        }
        output.append("  br i1 " + cmpReg + ", label %" + armBodyLabel + ", label %" + nextCheckLabel + "\n")
    }

    fun emitWhenIsPatternBranch(subjectReg: String, subjectLlvm: String, patternExpr: ParserExpressionNode, armBodyLabel: String, nextCheckLabel: String) r: Void {
        let variantName = patternExpr.literalValue
        let tagIdx = lookupEnumVariantTag(variantName)
        if subjectLlvm == "i64" {
            let cmpReg = getNextReg()
            output.append("  " + cmpReg + " = icmp eq i64 " + subjectReg + ", " + tagIdx.toString() + "\n")
            output.append("  br i1 " + cmpReg + ", label %" + armBodyLabel + ", label %" + nextCheckLabel + "\n")
            return
        }
        let tagLoadReg = getNextReg()
        output.append("  " + tagLoadReg + " = load i64, ptr " + subjectReg + "\n")
        let cmpReg = getNextReg()
        output.append("  " + cmpReg + " = icmp eq i64 " + tagLoadReg + ", " + tagIdx.toString() + "\n")
        output.append("  br i1 " + cmpReg + ", label %" + armBodyLabel + ", label %" + nextCheckLabel + "\n")
    }

    fun emitWhenPatternBranch(subjectReg: String, subjectLlvm: String, patternExpr: ParserExpressionNode, armBodyLabel: String, nextCheckLabel: String) r: Void {
        let patternKind = patternExpr.variableName
        if patternKind == "Literal" {
            emitWhenLiteralPatternBranch(subjectReg, patternExpr, armBodyLabel, nextCheckLabel)
            return
        }
        if patternKind == "Is" {
            emitWhenIsPatternBranch(subjectReg, subjectLlvm, patternExpr, armBodyLabel, nextCheckLabel)
            return
        }
        if patternKind == "Wildcard" or patternKind == "Variable" {
            output.append("  br label %" + armBodyLabel + "\n")
            return
        }
        output.append("  br label %" + nextCheckLabel + "\n")
    }

    fun emitWhenArmGuard(arm: ParserExpressionNode, armBodyLabel: String, nextCheckLabel: String) r: Void {
        if arm.operands.length() <= 2 {
            return
        }
        let guardReg = generateExpression(arm.operands[2])
        let guardType = inferExpressionType(arm.operands[2])
        var guardCond = guardReg
        if guardType != "Bool" {
            guardCond = getNextReg()
            output.append("  " + guardCond + " = icmp ne i64 " + guardReg + ", 0\n")
        }
        let guardedLabel = armBodyLabel + ".guarded"
        output.append("  br i1 " + guardCond + ", label %" + guardedLabel + ", label %" + nextCheckLabel + "\n")
        output.append(guardedLabel + ":\n")
        cseClear()
    }

    fun emitWhenPatternBindings(subjectReg: String, subjectLlvm: String, patternExpr: ParserExpressionNode) r: Void {
        if patternExpr.variableName != "Is" or patternExpr.operands.length() == 0 {
            return
        }
        var destructPtrReg = subjectReg
        if subjectLlvm != "ptr" {
            destructPtrReg = getNextReg()
            output.append("  " + destructPtrReg + " = inttoptr i64 " + subjectReg + " to ptr\n")
        }
        var fieldIdx = 0
        while fieldIdx < patternExpr.operands.length() {
            let fieldBind = patternExpr.operands[fieldIdx]
            if fieldBind.kind == "PatternField" {
                let bindingName = fieldBind.literalValue
                if bindingName == "" {
                    fieldIdx = fieldIdx + 1
                    continue
                }
                let fieldOffset = 8 + fieldIdx * 8
                let fieldPtrReg = getNextReg()
                output.append("  " + fieldPtrReg + " = getelementptr i8, ptr " + destructPtrReg + ", i64 " + fieldOffset.toString() + "\n")
                let variantName = patternExpr.literalValue
                let fType = lookupEnumFieldType(variantName, fieldIdx)
                let fLlvm = mapType(fType)
                let fLoadReg = getNextReg()
                output.append("  " + fLoadReg + " = load " + fLlvm + ", ptr " + fieldPtrReg + "\n")
                let bindIdx = findVar(bindingName)
                if bindIdx >= 0 {
                    output.append("  store " + fLlvm + " " + fLoadReg + ", ptr " + varRegs[bindIdx] + "\n")
                }
            }
            fieldIdx = fieldIdx + 1
        }
    }

    fun normalizeWhenArmStoreValue(valueReg: String, valueType: String) r: String {
        if valueType == "Bool" or valueType == "Boolean" {
            let widenedReg = getNextReg()
            output.append("  " + widenedReg + " = zext i1 " + valueReg + " to i64\n")
            return widenedReg
        }
        return valueReg
    }

    fun emitWhenArmResult(arm: ParserExpressionNode, resultAlloca: String) r: Void {
        if arm.operands.length() <= 1 {
            return
        }
        let armResult = arm.operands[1]
        if armResult.kind == "ReturnExpr" {
            if armResult.operands.length() > 0 {
                let retValReg = generateExpression(armResult.operands[0])
                let retType = mapType(currentFunctionReturnType)
                output.append("  ret " + retType + " " + retValReg + "\n")
            } else {
                let retType = mapType(currentFunctionReturnType)
                if retType == "void" {
                    output.append("  ret void\n")
                } else {
                    output.append("  ret " + retType + " 0\n")
                }
            }
            blockTerminated = true
            return
        }
        let armResultReg = generateExpression(armResult)
        if not blockTerminated {
            let armResultType = inferExpressionType(armResult)
            let armStoreReg = normalizeWhenArmStoreValue(armResultReg, armResultType)
            output.append("  store i64 " + armStoreReg + ", ptr " + resultAlloca + "\n")
        }
    }

    fun generateWhenExpression(expr: ParserExpressionNode) r: String {
        // Subject expression (if present)
        var subjectReg = "0"
        var subjectType = "Int"
        if expr.operands.length() > 0 {
            subjectReg = generateExpression(expr.operands[0])
            subjectType = inferExpressionType(expr.operands[0])
        }
        let subjectLlvm = mapType(subjectType)

        let endLabel = getNextBlockLabel()
        // Result alloca — use i64 as universal result storage
        let resultAlloca = getNextReg()
        output.append("  " + resultAlloca + " = alloca i64, align 8\n")
        output.append("  store i64 0, ptr " + resultAlloca + "\n")

        // Generate each arm
        var armIdx = 0
        while armIdx < expr.arguments.length() {
            let arm = expr.arguments[armIdx]
            // arm.variableName = pattern kind ("Is", "Literal", "Wildcard", "Variable")
            // arm.literalValue = type/constructor name or literal value
            // arm.operands[0] = Pattern expression
            // arm.operands[1] = arm result expression
            let patternExpr = arm.operands[0]

            let armBodyLabel = getNextBlockLabel()
            let nextCheckLabel = getNextBlockLabel()

            emitWhenPatternBranch(subjectReg, subjectLlvm, patternExpr, armBodyLabel, nextCheckLabel)

            // Arm body
            output.append(armBodyLabel + ":\n")
            cseClear()

            emitWhenArmGuard(arm, armBodyLabel, nextCheckLabel)
            emitWhenPatternBindings(subjectReg, subjectLlvm, patternExpr)
            emitWhenArmResult(arm, resultAlloca)
            if not blockTerminated {
                output.append("  br label %" + endLabel + "\n")
            }
            blockTerminated = false

            // Next check
            output.append(nextCheckLabel + ":\n")
            cseClear()
            armIdx = armIdx + 1
        }

        // After all arms, branch to end (fallthrough if no match)
        output.append("  br label %" + endLabel + "\n")

        // End block
        output.append(endLabel + ":\n")
        cseClear()
        let resultReg = getNextReg()
        output.append("  " + resultReg + " = load i64, ptr " + resultAlloca + "\n")
        return resultReg
    }

    // Look up enum variant tag index by variant name
    fun lookupEnumVariantTag(variantName: String) r: Int {
        return lookupEnumVariantTagImpl(variantName, g_enumVariantNames, g_enumVariantTags, g_enumVariantCount)
    }

    // Look up parent enum type for a variant name
    fun lookupEnumParent(variantName: String) r: String {
        return lookupEnumParentImpl(variantName, g_enumVariantNames, g_enumVariantParent, g_enumVariantCount)
    }

    // Look up enum field type by variant name and field index
    fun lookupEnumFieldType(variantName: String, fieldIdx: Int) r: String {
        return lookupEnumFieldTypeImpl(variantName, fieldIdx, g_enumVariantNames, g_enumVariantFieldTypes, g_enumVariantCount)
    }

    // Look up field count for a variant
    fun lookupEnumFieldCount(variantName: String) r: Int {
        return lookupEnumFieldCountImpl(variantName, g_enumVariantNames, g_enumVariantFieldCounts, g_enumVariantCount)
    }

    // Check if a name is a registered enum variant
    fun isEnumVariant(name: String) r: Bool {
        return isEnumVariantImpl(name, g_enumVariantNames, g_enumVariantCount)
    }

    // Generate enum variant constructor call
    // Simple enums (no fields): return tag as i64
    // Data enums (with fields): allocate tagged heap object [i64 tag, field1, field2, ...]
    // Generate IR for an enum variant constructor call. Simple enums
    // (no fields) return the tag as an i64 integer value directly.
    // Data enums (with fields) allocate a heap object: 8 bytes for the
    // tag at offset 0, then 8 bytes per field at offsets 8, 16, 24, etc.
    // Returns the malloc'd pointer (data enums map to "ptr" in mapType).
    fun allocateEnumConstructorObject(tag: Int, fieldCount: Int) r: String {
        let totalSize = 8 + fieldCount * 8
        let objReg = getNextReg()
        output.append("  " + objReg + " = call ptr @malloc(i64 " + totalSize.toString() + ")\n")
        output.append("  store i64 " + tag.toString() + ", ptr " + objReg + "\n")
        return objReg
    }

    fun emitEnumConstructorFieldStores(variantName: String, expr: ParserExpressionNode, objReg: String, fieldCount: Int) r: Void {
        var fi = 0
        while fi < fieldCount and fi < expr.arguments.length() {
            let fieldReg = generateExpression(expr.arguments[fi])
            let fieldType = lookupEnumFieldType(variantName, fi)
            let fieldLlvm = mapType(fieldType)
            let fieldOffset = 8 + fi * 8
            let fieldPtrReg = getNextReg()
            output.append("  " + fieldPtrReg + " = getelementptr i8, ptr " + objReg + ", i64 " + fieldOffset.toString() + "\n")
            output.append("  store " + fieldLlvm + " " + fieldReg + ", ptr " + fieldPtrReg + "\n")
            fi = fi + 1
        }
    }

    fun generateEnumConstructor(variantName: String, expr: ParserExpressionNode) r: String {
        let tag = lookupEnumVariantTag(variantName)
        let fieldCount = lookupEnumFieldCount(variantName)
        if fieldCount == 0 {
            return tag.toString()
        }
        let objReg = allocateEnumConstructorObject(tag, fieldCount)
        emitEnumConstructorFieldStores(variantName, expr, objReg, fieldCount)
        return objReg
    }
