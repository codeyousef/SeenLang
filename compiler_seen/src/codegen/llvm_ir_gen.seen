        }
        if not this.isFuncDefinedInModule("Environment_lookupFunction", definedFuncs) {
            output.append("declare i64 @Environment_lookupFunction(ptr, %SeenString)\n")
        }
        if not this.isFuncDefinedInModule("Environment_defineClass", definedFuncs) {
            output.append("declare i64 @Environment_defineClass(ptr, %SeenString, ptr)\n")
        }
        if not this.isFuncDefinedInModule("Environment_lookupClass", definedFuncs) {
            output.append("declare i64 @Environment_lookupClass(ptr, %SeenString)\n")
        }
        // Type-related functions (Type is class type stored as i64)
        if not this.isFuncDefinedInModule("Type_new", definedFuncs) {
            output.append("declare i64 @Type_new(%SeenString, i1)\n")
        }
        if not this.isFuncDefinedInModule("typeInt", definedFuncs) {
            output.append("declare i64 @typeInt()\n")
        }
        if not this.isFuncDefinedInModule("typeFloat", definedFuncs) {
            output.append("declare i64 @typeFloat()\n")
        }
        if not this.isFuncDefinedInModule("typeString", definedFuncs) {
            output.append("declare i64 @typeString()\n")
        }
        if not this.isFuncDefinedInModule("typeBool", definedFuncs) {
            output.append("declare i64 @typeBool()\n")
        }
        if not this.isFuncDefinedInModule("typeVoid", definedFuncs) {
            output.append("declare i64 @typeVoid()\n")
        }
        if not this.isFuncDefinedInModule("typeUnit", definedFuncs) {
            output.append("declare i64 @typeUnit()\n")
        }
        if not this.isFuncDefinedInModule("typeAny", definedFuncs) {
            output.append("declare i64 @typeAny()\n")
        }
        if not this.isFuncDefinedInModule("typeNever", definedFuncs) {
            output.append("declare i64 @typeNever()\n")
        }
        if not this.isFuncDefinedInModule("typeUnknown", definedFuncs) {
            output.append("declare i64 @typeUnknown()\n")
        }
        // Typechecker class constructors (class types stored as i64)
        if not this.isFuncDefinedInModule("ClassType", definedFuncs) {
            output.append("declare i64 @ClassType()\n")
        }
        if not this.isFuncDefinedInModule("FunctionType", definedFuncs) {
            output.append("declare i64 @FunctionType()\n")
        }
        if not this.isFuncDefinedInModule("InterfaceType", definedFuncs) {
            output.append("declare ptr @InterfaceType()\n")
        }
        if not this.isFuncDefinedInModule("Location", definedFuncs) {
            output.append("declare i64 @Location()\n")
        }
        if not this.isFuncDefinedInModule("TypeError", definedFuncs) {
            output.append("declare i64 @TypeError()\n")
        }
        if not this.isFuncDefinedInModule("Environment", definedFuncs) {
            output.append("declare i64 @Environment()\n")
        }

        // AST node constructors
        // Class types (heap-allocated, stored as i64)
        if not this.isFuncDefinedInModule("FunctionNode_new", definedFuncs) {
            output.append("declare i64 @FunctionNode_new()\n")
        }
        if not this.isFuncDefinedInModule("ClassNode_new", definedFuncs) {
            output.append("declare i64 @ClassNode_new()\n")
        }
        if not this.isFuncDefinedInModule("EnumNode_new", definedFuncs) {
            output.append("declare i64 @EnumNode_new()\n")
        }
        if not this.isFuncDefinedInModule("BlockNode_new", definedFuncs) {
            output.append("declare i64 @BlockNode_new()\n")
        }
        if not this.isFuncDefinedInModule("StatementNode_new", definedFuncs) {
            output.append("declare i64 @StatementNode_new()\n")
        }
        if not this.isFuncDefinedInModule("ParserExpressionNode_new", definedFuncs) {
            output.append("declare i64 @ParserExpressionNode_new()\n")
        }
        // Data types (inline structs, returned by value)
        if not this.isFuncDefinedInModule("ImportSymbolNode_new", definedFuncs) {
            output.append("declare %ImportSymbolNode @ImportSymbolNode_new()\n")
        }
        if not this.isFuncDefinedInModule("ItemNode_new", definedFuncs) {
            output.append("declare %ItemNode @ItemNode_new()\n")
        }
        if not this.isFuncDefinedInModule("ParamNode_new", definedFuncs) {
            output.append("declare %ParamNode @ParamNode_new()\n")
        }
        if not this.isFuncDefinedInModule("TypeNode_new", definedFuncs) {
            output.append("declare %TypeNode @TypeNode_new()\n")
        }

        // TypeError, Location, Type, and Result methods - also included in runtime header
        if not runtimeDeclsLoaded {
            // TypeError method declarations
            output.append("declare %SeenString @TypeError_getMessage(ptr)\n")
            output.append("declare %SeenString @TypeError_getContext(ptr)\n")
            output.append("declare ptr @TypeError_getLocation(ptr)\n")
            output.append("declare ptr @TypeError_getExpected(ptr)\n")
            output.append("declare ptr @TypeError_getActual(ptr)\n")

            // Location/Type field accessors
            output.append("declare i64 @Location_line(ptr)\n")
            output.append("declare i64 @Location_column(ptr)\n")
            output.append("declare %SeenString @Type_name(ptr)\n")

            // Result methods
            output.append("declare i1 @Result_isOkay(ptr)\n")
            output.append("declare i1 @Result_isErr(ptr)\n")
            output.append("declare ptr @Result_unwrap(ptr)\n")
            output.append("declare %SeenString @Result_unwrapErr(ptr)\n")
            // Ok and Err return Result which is a class type (stored as i64)
            output.append("declare i64 @Err(%SeenString)\n")
            output.append("declare i64 @Ok(i64)\n")
        }

        // FsFile methods (conditionally declared, return FsFileResult/Result class types as i64)
        if not this.isFuncDefinedInModule("FsFile_open", definedFuncs) {
            output.append("declare i64 @FsFile_open(%SeenString)\n")
        }
        if not this.isFuncDefinedInModule("FsFile_create", definedFuncs) {
            output.append("declare i64 @FsFile_create(%SeenString)\n")
        }
        if not this.isFuncDefinedInModule("FsFile_readContent", definedFuncs) {
            output.append("declare i64 @FsFile_readContent(ptr)\n")
        }
        if not this.isFuncDefinedInModule("FsFile_writeContent", definedFuncs) {
            output.append("declare i64 @FsFile_writeContent(ptr, %SeenString)\n")
        }
        if not this.isFuncDefinedInModule("FsFile_closeFile", definedFuncs) {
            output.append("declare i64 @FsFile_closeFile(ptr)\n")
        }
        // FsFileResult_unwrap returns FsFile (class type as i64)
        if not this.isFuncDefinedInModule("FsFileResult_unwrap", definedFuncs) {
            output.append("declare i64 @FsFileResult_unwrap(ptr)\n")
        }
        if not this.isFuncDefinedInModule("FsFileResult_unwrapErr", definedFuncs) {
            output.append("declare %SeenString @FsFileResult_unwrapErr(ptr)\n")
        }

        output.append("\n")
    }

    fun generateFunction(fn: FunctionNode) r: Void {
        // Skip functions that are registered class methods (generated via generateClass instead)
        var isClassMethodGen = false
        var cmig = 0
        while cmig < classMethodBaseNames.length() {
            if classMethodBaseNames[cmig] == fn.name {
                isClassMethodGen = true
            }
            cmig = cmig + 1
        }
        if isClassMethodGen {
            output.append("; SKIPPED: " + fn.name + " (class method, generated via generateClass)\n")
            return
        }
        // Skip 'new' - always a class method
        if fn.name == "new" {
            output.append("; SKIPPED: new (class constructor)\n")
            return
        }

        // Skip extern functions (C runtime primitives) - they have empty bodies and names starting with __
        // These should be declared, not defined - the C runtime provides the implementation
        if fn.name.startsWith("__") and fn.body.statements.length() == 0 {
            output.append("; SKIPPED: " + fn.name + " (extern C function - declared by runtime)\n")
            return
        }

        // Check if this function was already emitted in this module (duplicate detection)
        var alreadyGenerated = false
        var gi = 0
        while gi < generatedFunctions.length() {
            if generatedFunctions[gi] == fn.name {
                alreadyGenerated = true
                gi = generatedFunctions.length()  // break
            }
            gi = gi + 1
        }
        if alreadyGenerated {
            return
        }
        generatedFunctions.push(fn.name)

        // Register this function's return type for later call site inference
        // (may already be registered from registerDeclarations, but that's OK)
        this.registerFunction(fn.name, fn.returnType.typeName)

        // Reset per-function state
        nextReg = 1
        nextBlock = 0
        varNames = Array<String>()
        varRegs = Array<String>()
        varTypes = Array<String>()
        preAllocatedVars = Array<String>()
        preAllocatedTypes = Array<String>()
        currentFunctionReturnType = fn.returnType.typeName
        blockTerminated = false

        // Pre-register parameter types for use during variable collection
        // (needed so inferExpressionType can find parameter types)
        var preParamIdx = 0
        while preParamIdx < fn.params.length() {
            let param = fn.params[preParamIdx]
            varNames.push(param.name)
            varRegs.push("")  // Placeholder - will be cleared
            varTypes.push(param.paramType.typeName)
            preParamIdx = preParamIdx + 1
        }

        // Collect all variable declarations for hoisting allocas to entry block
        this.collectVariableDeclarations(fn.body)

        // Clear pre-registered parameters (will be re-added with proper registers)
        varNames = Array<String>()
        varRegs = Array<String>()
        varTypes = Array<String>()

        let fnTypeName = fn.returnType.typeName
        println("[DEBUG generateFunction] fn.returnType.typeName = '" + fnTypeName + "'")
        let returnType = this.mapType(fnTypeName)

        let fnName = fn.name
        println("[DEBUG generateFunction] fn.name = '" + fnName + "'")
        println("[DEBUG generateFunction] returnType = '" + returnType + "'")

        // Special handling for main function - needs to accept argc/argv from OS
        if fnName == "main" {
            output.append("define " + returnType + " @main(i32 %argc, ptr %argv) {\n")
            output.append("entry:\n")
            output.append("  call void @seen_runtime_init(i32 %argc, ptr %argv)\n")
            // Emit allocas for all local variables at entry (avoids domination errors)
            this.emitPreAllocatedAllocas()
            this.generateBlock(fn.body)
            // Add default return if no terminator generated
            if not blockTerminated {
                var emittedMainRet = false
                if returnType == "void" {
                    output.append("  ret void\n")
                    emittedMainRet = true
                }
                if not emittedMainRet and returnType == "i64" {
                    output.append("  ret i64 0\n")
                    emittedMainRet = true
                }
                if not emittedMainRet and returnType == "ptr" {
                    output.append("  ret ptr null\n")
                    emittedMainRet = true
                }
                if not emittedMainRet and returnType == "i32" {
                    output.append("  ret i32 0\n")
                    emittedMainRet = true
                }
                if not emittedMainRet {
                    // Default for other types (e.g., structs)
                    output.append("  ret " + returnType + " zeroinitializer\n")
                }
            }
            output.append("}\n\n")
            return
        }

        // Function signature
        output.append("define " + returnType + " @" + fnName + "(")

        // Parameters
        var paramIdx = 0
        while paramIdx < fn.params.length() {
            if paramIdx > 0 {
                output.append(", ")
            }
            let param = fn.params[paramIdx]
            let paramType = this.mapTypeForParameter(param.paramType.typeName)
            output.append(paramType + " %" + param.name + ".arg")
            paramIdx = paramIdx + 1
        }

        output.append(") {\n")
        output.append("entry:\n")

        // Allocate space for parameters and store them
        paramIdx = 0
        while paramIdx < fn.params.length() {
            let param = fn.params[paramIdx]
            let seenTypeName = param.paramType.typeName
            // Data type params come in as ptr (ABI compat with Rust backend)
            // Use the incoming ptr directly as the variable location
            if this.isDataType(seenTypeName) {
                this.storeVar(param.name, "%" + param.name + ".arg", seenTypeName)
            } else {
                let paramType = this.mapType(seenTypeName)
                let reg = this.getNextReg()
                output.append("  " + reg + " = alloca " + paramType + "\n")
                output.append("  store " + paramType + " %" + param.name + ".arg, ptr " + reg + "\n")
                this.storeVar(param.name, reg, seenTypeName)
            }
            paramIdx = paramIdx + 1
        }

        // Emit allocas for all local variables at entry (avoids domination errors)
        this.emitPreAllocatedAllocas()

        // Generate function body
        this.generateBlock(fn.body)

        // If no terminator was generated, add a default return
        if not blockTerminated {
            var emittedRet = false
            if returnType == "void" {
                output.append("  ret void\n")
                emittedRet = true
            }
            if not emittedRet and returnType == "i1" {
                output.append("  ret i1 false\n")
                emittedRet = true
            }
            if not emittedRet and returnType == "i64" {
                output.append("  ret i64 0\n")
                emittedRet = true
            }
            if not emittedRet and returnType == "ptr" {
                output.append("  ret ptr null\n")
                emittedRet = true
            }
            if not emittedRet and returnType == "%SeenString" {
                output.append("  ret %SeenString zeroinitializer\n")
                emittedRet = true
            }
            if not emittedRet and returnType == "%SeenArray" {
                output.append("  ret %SeenArray zeroinitializer\n")
                emittedRet = true
            }
            if not emittedRet {
                // Default for other types
                output.append("  ret " + returnType + " zeroinitializer\n")
            }
        }

        output.append("}\n\n")
    }

    fun generateBlock(block: BlockNode) r: Void {
        var i = 0
        while i < block.statements.length() {
            // Skip statements after a terminator (ret, br unconditional)
            if blockTerminated {
                break
            }
            this.generateStatement(block.statements[i])
            i = i + 1
        }
    }

    fun generateStatement(stmt: StatementNode) r: Void {
        var handled = false
        if stmt.kind == "Let" or stmt.kind == "Var" {
            this.generateLetStatement(stmt)
            handled = true
        }
        if not handled and stmt.kind == "Return" {
            this.generateReturnStatement(stmt)
            handled = true
        }
        if not handled and stmt.kind == "Expression" {
            // Check if the expression is actually an assignment
            var exprHandled = false
            output.append("; DEBUG stmt Expression kind=" + stmt.expression.kind + " literalValue=" + stmt.expression.literalValue + "\n")
            if stmt.expression.kind == "Assignment" {
                this.generateAssignmentExpr(stmt.expression)
                exprHandled = true
            }
            if not exprHandled and stmt.expression.kind == "MemberAssignment" {
                this.generateMemberAssignment(stmt.expression)
                exprHandled = true
            }
            if not exprHandled and stmt.expression.kind == "IndexAssignment" {
                this.generateIndexAssignment(stmt.expression)
                exprHandled = true
            }
            if not exprHandled {
                this.generateExpression(stmt.expression)
            }
            handled = true
        }
        if not handled and stmt.kind == "If" {
            this.generateIfStatement(stmt)
            handled = true
        }
        if not handled and stmt.kind == "While" {
            this.generateWhileStatement(stmt)
            handled = true
        }
        if not handled and stmt.kind == "Assignment" {
            this.generateAssignment(stmt)
            handled = true
        }
        if not handled and stmt.kind == "Continue" {
            // Jump to loop condition
            if currentLoopCondLabel != "" {
                output.append("  br label %" + currentLoopCondLabel + "\n")
                blockTerminated = true
            }
            handled = true
        }
        if not handled and stmt.kind == "Break" {
            // Jump to loop end
            if currentLoopEndLabel != "" {
                output.append("  br label %" + currentLoopEndLabel + "\n")
                blockTerminated = true
            }
        }
    }

    fun generateLetStatement(stmt: StatementNode) r: Void {
        // Get variable type - prefer explicit type, fall back to inference
        var varType = stmt.variableType.typeName
        if varType == "" or varType == "Unknown" {
            // Infer type from initializer
            if stmt.initializer.kind != "None" {
                varType = this.inferExpressionType(stmt.initializer)
            }
        }
        let llvmType = this.mapType(varType)

        // Check if this variable was pre-allocated at function entry
        let existingIdx = this.findVar(stmt.variableName)
        var reg = ""
        if existingIdx >= 0 {
            // Variable was pre-allocated, use existing register
            reg = varRegs[existingIdx]
        }
        if existingIdx < 0 {
            // Fallback: allocate here (shouldn't happen with proper collection)
            reg = this.getNextReg()
            output.append("  " + reg + " = alloca " + llvmType + "\n")
            this.storeVar(stmt.variableName, reg, varType)
        }

        // Initialize if there's an initializer
        if stmt.initializer.kind != "None" {
            let savedPendingType = pendingArrayLiteralType
            if stmt.initializer.kind == "ArrayLiteral" and (varType.startsWith("Array") or varType.startsWith("List")) {
                pendingArrayLiteralType = varType
            }
            let valueReg = this.generateExpression(stmt.initializer)
            pendingArrayLiteralType = savedPendingType
            output.append("  store " + llvmType + " " + valueReg + ", ptr " + reg + "\n")
        }
    }

    fun generateReturnStatement(stmt: StatementNode) r: Void {
        if stmt.returnValue.kind == "None" {
            // Check if function has non-void return type - use default value
            let llvmType = this.mapType(currentFunctionReturnType)
            var emittedDefRet = false
            if llvmType == "void" or currentFunctionReturnType == "" or currentFunctionReturnType == "Void" {
                output.append("  ret void\n")
                emittedDefRet = true
            }
            if not emittedDefRet and llvmType == "i1" {
                output.append("  ret i1 false\n")
                emittedDefRet = true
            }
            if not emittedDefRet and llvmType == "i64" {
                output.append("  ret i64 0\n")
                emittedDefRet = true
            }
            if not emittedDefRet and llvmType == "ptr" {
                output.append("  ret ptr null\n")
                emittedDefRet = true
            }
            if not emittedDefRet and llvmType == "%SeenString" {
                output.append("  ret %SeenString zeroinitializer\n")
                emittedDefRet = true
            }
            if not emittedDefRet and llvmType == "%SeenArray" {
                output.append("  ret %SeenArray zeroinitializer\n")
                emittedDefRet = true
            }
            if not emittedDefRet {
                // Generic struct type - return zeroinitializer
                output.append("  ret " + llvmType + " zeroinitializer\n")
            }
        }
        if stmt.returnValue.kind != "None" {
            // Special handling for Char return type with string literals
            if currentFunctionReturnType == "Char" and stmt.returnValue.kind == "Literal" and stmt.returnValue.literalType == "String" {
                // Convert single-char string to its code point
                let charValue = stmt.returnValue.literalValue
                if charValue.length() == 1 {
                    // Get first character's code point
                    let codeStr = this.charToCodeStr(charValue)
                    output.append("  ret i64 " + codeStr + "\n")
                    blockTerminated = true
                    return
                }
            }

            let savedPendingType = pendingArrayLiteralType
            if stmt.returnValue.kind == "ArrayLiteral" and (currentFunctionReturnType.startsWith("Array") or currentFunctionReturnType.startsWith("List")) {
                pendingArrayLiteralType = currentFunctionReturnType
            }
            var valueReg = this.generateExpression(stmt.returnValue)
            pendingArrayLiteralType = savedPendingType
            // Use the function's declared return type, not inferred type
            let llvmType = this.mapType(currentFunctionReturnType)
            // If returning a data type from a struct literal, we need to load the struct
            // (struct literals return ptr, but data type functions should return inline struct)
            if this.isDataType(currentFunctionReturnType) and stmt.returnValue.kind == "StructLiteral" {
                let loadReg = this.getNextReg()
                output.append("  " + loadReg + " = load " + llvmType + ", ptr " + valueReg + "\n")
                valueReg = loadReg
            }
            // Handle default return values when expression generation fails
            if valueReg == "0" {
                var fixedValReg = false
                if llvmType == "ptr" {
                    valueReg = "null"
                    fixedValReg = true
                }
                if not fixedValReg and llvmType == "%SeenString" {
                    // Return empty string { 0, null }
                    valueReg = "zeroinitializer"
                    fixedValReg = true
                }
                if not fixedValReg and llvmType == "%SeenArray" {
                    // Return empty array { 0, 0, null }
                    valueReg = "zeroinitializer"
                    fixedValReg = true
                }
                if not fixedValReg and llvmType == "i1" {
                    valueReg = "false"
                }
            }
            // NOTE: generateStructLiteral now handles ptrtoint conversion for class types,
            // so we don't need to add it here.
            output.append("  ret " + llvmType + " " + valueReg + "\n")
        }
        blockTerminated = true
    }

    fun generateIfStatement(stmt: StatementNode) r: Void {
        let condReg = this.generateExpression(stmt.condition)

        let thenLabel = this.getNextBlockLabel()
        let elseLabel = this.getNextBlockLabel()
        let endLabel = this.getNextBlockLabel()

        // Branch on condition
        output.append("  br i1 " + condReg + ", label %" + thenLabel + ", label %" + elseLabel + "\n")

        // Then block
        output.append(thenLabel + ":\n")
        blockTerminated = false
        this.generateBlock(stmt.thenBranch)
        let thenTerminated = blockTerminated
        if not thenTerminated {
            output.append("  br label %" + endLabel + "\n")
        }

        // Else block
        output.append(elseLabel + ":\n")
        blockTerminated = false
        if stmt.elseBranch.statements.length() > 0 {
            this.generateBlock(stmt.elseBranch)
        }
        let elseTerminated = blockTerminated
        if not elseTerminated {
            output.append("  br label %" + endLabel + "\n")
        }

        // End block
        output.append(endLabel + ":\n")
        // Only set blockTerminated if BOTH branches terminate
        if thenTerminated and elseTerminated {
            blockTerminated = true
            output.append("  unreachable\n")
        }
        if not (thenTerminated and elseTerminated) {
            blockTerminated = false
        }
    }

    fun blockHasTerminator(block: BlockNode) r: Bool {
        if block.statements.length() == 0 {
            return false
        }
        let lastStmt = block.statements[block.statements.length() - 1]
        return lastStmt.kind == "Return"
    }

    fun generateWhileStatement(stmt: StatementNode) r: Void {
        let condLabel = this.getNextBlockLabel()
        let bodyLabel = this.getNextBlockLabel()
        let endLabel = this.getNextBlockLabel()

        // Save outer loop context (for nested loops)
        let savedCondLabel = currentLoopCondLabel
        let savedEndLabel = currentLoopEndLabel
        // Set current loop context for break/continue
        currentLoopCondLabel = condLabel
        currentLoopEndLabel = endLabel

        // Jump to condition check
        output.append("  br label %" + condLabel + "\n")

        // Condition block
        output.append(condLabel + ":\n")
        let condReg = this.generateExpression(stmt.loopCondition)
        output.append("  br i1 " + condReg + ", label %" + bodyLabel + ", label %" + endLabel + "\n")

        // Body block
        output.append(bodyLabel + ":\n")
        blockTerminated = false  // Reset for body
        this.generateBlock(stmt.loopBody)
        let bodyTerminated = blockTerminated
        // Only add loop branch if body didn't terminate (return/break/continue)
        if not bodyTerminated {
            output.append("  br label %" + condLabel + "\n")
        }

        // End block - reached when condition is false
        output.append(endLabel + ":\n")
        // While loop end is always reachable (condition can be false)
        blockTerminated = false

        // Restore outer loop context
        currentLoopCondLabel = savedCondLabel
        currentLoopEndLabel = savedEndLabel
    }

    // Handle assignment expression (from parser)
    fun generateAssignmentExpr(expr: ParserExpressionNode) r: Void {
        let varName = expr.variableName
        let idx = this.findVar(varName)

        if idx < 0 {
            // Variable not found - check if 'this' exists and varName is a field
            let thisIdx = this.findVar("this")
            if thisIdx >= 0 {
                let thisReg = varRegs[thisIdx]
                let thisType = varTypes[thisIdx]

                // Check if this type has the field
                let structIdx = this.findStruct(thisType)
                if structIdx >= 0 {
                    let fieldIdx = this.getFieldInfo(thisType, varName)
                    if fieldIdx >= 0 {
                        // Generate field assignment to this.fieldName
                        let savedPendingType = pendingArrayLiteralType
                        let fieldSeenType = this.getSeenFieldType(thisType, varName)
                        if expr.operands[0].kind == "ArrayLiteral" and (fieldSeenType.startsWith("Array") or fieldSeenType.startsWith("List")) {
                            pendingArrayLiteralType = fieldSeenType
                        }
                        let valueReg = this.generateExpression(expr.operands[0])
                        pendingArrayLiteralType = savedPendingType

                        // Load 'this' pointer
                        let thisPtrReg = this.getNextReg()
                        output.append("  " + thisPtrReg + " = load ptr, ptr " + thisReg + "\n")

                        // Get struct layout and field type
                        let structLayout = structLayouts[structIdx]
                        let fieldType = this.getFieldType(thisType, varName)

                        // Generate GEP to field
                        let fieldPtrReg = this.getNextReg()
                        output.append("  " + fieldPtrReg + " = getelementptr inbounds " + structLayout + ", ptr " + thisPtrReg + ", i32 0, i32 " + fieldIdx.toString() + "\n")

                        // Store the value
                        output.append("  store " + fieldType + " " + valueReg + ", ptr " + fieldPtrReg + "\n")
                        return
                    }
                }
            }
            return
        }

        let savedPendingType = pendingArrayLiteralType
        let varType = varTypes[idx]
        if expr.operands[0].kind == "ArrayLiteral" and (varType.startsWith("Array") or varType.startsWith("List")) {
            pendingArrayLiteralType = varType
        }
        let valueReg = this.generateExpression(expr.operands[0])
        pendingArrayLiteralType = savedPendingType
        let varReg = varRegs[idx]
        let llvmType = this.mapType(varType)
        output.append("  store " + llvmType + " " + valueReg + ", ptr " + varReg + "\n")
    }

    fun generateAssignment(stmt: StatementNode) r: Void {
        let varName = stmt.variableName
        let idx = this.findVar(varName)

        if idx < 0 {
            // Variable not found - check if 'this' exists and varName is a field
            let thisIdx = this.findVar("this")
            if thisIdx >= 0 {
                let thisReg = varRegs[thisIdx]
                let thisType = varTypes[thisIdx]

                // Check if this type has the field
                let structIdx = this.findStruct(thisType)
                if structIdx >= 0 {
                    let fieldIdx = this.getFieldInfo(thisType, varName)
                    if fieldIdx >= 0 {
                        // Generate field assignment to this.fieldName
                        let savedPendingType = pendingArrayLiteralType
                        let fieldSeenType = this.getSeenFieldType(thisType, varName)
                        if stmt.initializer.kind == "ArrayLiteral" and (fieldSeenType.startsWith("Array") or fieldSeenType.startsWith("List")) {
                            pendingArrayLiteralType = fieldSeenType
                        }
                        let valueReg = this.generateExpression(stmt.initializer)
                        pendingArrayLiteralType = savedPendingType

                        // Load 'this' pointer
                        let thisPtrReg = this.getNextReg()
                        output.append("  " + thisPtrReg + " = load ptr, ptr " + thisReg + "\n")

                        // Get struct layout and field type
                        let structLayout = structLayouts[structIdx]
                        let fieldType = this.getFieldType(thisType, varName)

                        // Generate GEP to field
                        let fieldPtrReg = this.getNextReg()
                        output.append("  " + fieldPtrReg + " = getelementptr inbounds " + structLayout + ", ptr " + thisPtrReg + ", i32 0, i32 " + fieldIdx.toString() + "\n")

                        // Store the value
                        output.append("  store " + fieldType + " " + valueReg + ", ptr " + fieldPtrReg + "\n")
                        return
                    }
                }
            }
            return
        }

        let savedPendingType = pendingArrayLiteralType
        let varType = varTypes[idx]
        if stmt.initializer.kind == "ArrayLiteral" and (varType.startsWith("Array") or varType.startsWith("List")) {
            pendingArrayLiteralType = varType
        }
        let valueReg = this.generateExpression(stmt.initializer)
        pendingArrayLiteralType = savedPendingType
        let varReg = varRegs[idx]
        let llvmType = this.mapType(varType)
        output.append("  store " + llvmType + " " + valueReg + ", ptr " + varReg + "\n")
    }

    // Generate member assignment: a.b = value or this.a.b = value
    fun generateMemberAssignment(expr: ParserExpressionNode) r: Void {
        // expr.operands[0] = lhs MemberAccess, expr.operands[1] = rhs value
        let memberAccess = expr.operands[0]
        let value = expr.operands[1]

        // Get the receiver and field name from MemberAccess
        // memberAccess.literalValue = receiver (e.g., "this" or variable name)
        // memberAccess.variableName = field name
        let receiverName = memberAccess.literalValue
        let fieldName = memberAccess.variableName
        output.append("; DEBUG generateMemberAssignment: receiverName=" + receiverName + " fieldName=" + fieldName + "\n")

        // Generate the value first
        let valueReg = this.generateExpression(value)

        // Resolve the receiver chain
        // If receiver is another MemberAccess (e.g., this.lastFunction.name), handle recursively
        if memberAccess.operands.length() > 0 and memberAccess.literalValue == "" {
            // Receiver is an expression (chained access like this.a.b where a is stored in operands[0])
            let receiverExpr = memberAccess.operands[0]
            let receiverReg = this.generateExpression(receiverExpr)

            // Infer receiver type to get struct layout
            let receiverType = this.inferExpressionType(receiverExpr)
            let structIdx = this.findStruct(receiverType)
            if structIdx >= 0 {
                let fieldIdx = this.getFieldInfo(receiverType, fieldName)
                if fieldIdx >= 0 {
                    let structLayout = structLayouts[structIdx]
                    // Note: getFieldType already returns LLVM type (it calls mapType internally)
                    let llvmFieldType = this.getFieldType(receiverType, fieldName)

                    // Ensure we have a pointer to the receiver struct
                    var receiverPtrReg = receiverReg
                    if this.isClassType(receiverType) {
                        let ptrConvReg = this.getNextReg()
                        output.append("  " + ptrConvReg + " = inttoptr i64 " + receiverReg + " to ptr\n")
                        receiverPtrReg = ptrConvReg
                    }
                    if this.isDataType(receiverType) {
                        let tmpReg = this.getNextReg()
                        output.append("  " + tmpReg + " = alloca %" + receiverType + "\n")
                        output.append("  store %" + receiverType + " " + receiverReg + ", ptr " + tmpReg + "\n")
                        receiverPtrReg = tmpReg
                    }

                    // GEP to field
                    let fieldPtrReg = this.getNextReg()
                    output.append("  " + fieldPtrReg + " = getelementptr inbounds " + structLayout + ", ptr " + receiverPtrReg + ", i32 0, i32 " + fieldIdx.toString() + "\n")

                    // Store
                    output.append("  store " + llvmFieldType + " " + valueReg + ", ptr " + fieldPtrReg + "\n")
                    return
                }
            }
            return
        }

        // Handle chained receiver like "fn.returnType" with fieldName "typeName"
        if receiverName.contains(".") {
            // Split into base variable and remaining path
            var dotIdx = 0
            var di = 0
            while di < receiverName.length() {
                if receiverName.substring(di, di + 1) == "." {
                    dotIdx = di
                    di = receiverName.length()  // break
                }
                di = di + 1
            }
            if dotIdx > 0 {
                let baseVarName = receiverName.substring(0, dotIdx)
                let restPath = receiverName.substring(dotIdx + 1, receiverName.length())
                let baseIdx = this.findVar(baseVarName)
                if baseIdx >= 0 {
                    let baseReg = varRegs[baseIdx]
                    let baseType = varTypes[baseIdx]
                    var basePtrReg = ""
                    if this.isClassType(baseType) {
                        let loadReg = this.getNextReg()
                        output.append("  " + loadReg + " = load i64, ptr " + baseReg + "\n")
                        basePtrReg = this.getNextReg()
                        output.append("  " + basePtrReg + " = inttoptr i64 " + loadReg + " to ptr\n")
                    } else if this.isDataType(baseType) {
                        basePtrReg = baseReg
                    } else {
                        basePtrReg = this.getNextReg()
                        output.append("  " + basePtrReg + " = load ptr, ptr " + baseReg + "\n")
                    }

                    // Walk the restPath to find the intermediate type
                    var intermediateType = ""
                    if restPath.contains(".") {
                        var pathSegments = Array<String>()
                        var segStart = 0
                        var segIdx = 0
                        while segIdx <= restPath.length() {
                            if segIdx == restPath.length() or restPath.substring(segIdx, segIdx + 1) == "." {
                                if segIdx > segStart {
                                    pathSegments.push(restPath.substring(segStart, segIdx))
                                }
                                segStart = segIdx + 1
                            }
                            segIdx = segIdx + 1
                        }
                        var currentType = baseType
                        var pi = 0
                        while pi < pathSegments.length() and currentType != "" {
                            let currField = pathSegments[pi]
                            currentType = this.getSeenFieldType(currentType, currField)
                            pi = pi + 1
                        }
                        intermediateType = currentType
                    }
                    if not restPath.contains(".") {
                        intermediateType = this.getSeenFieldType(baseType, restPath)
                    }

                    if intermediateType != "" {
                        var intermediatePtrReg = ""
                        if this.isClassType(intermediateType) {
                            let intermediateValReg = this.generateFieldAccess(basePtrReg, baseType, restPath)
                            let ptrConvReg = this.getNextReg()
                            output.append("  " + ptrConvReg + " = inttoptr i64 " + intermediateValReg + " to ptr\n")
                            intermediatePtrReg = ptrConvReg
                        } else {
                            // Handle chained paths like "function.returnType" by walking through each segment
                            if restPath.contains(".") {
                                var chainPtr = basePtrReg
                                var chainType = baseType
                                var chainSegStart = 0
                                var chainSegIdx = 0
                                while chainSegIdx <= restPath.length() {
                                    if chainSegIdx == restPath.length() or restPath.substring(chainSegIdx, chainSegIdx + 1) == "." {
                                        if chainSegIdx > chainSegStart {
                                            let chainField = restPath.substring(chainSegStart, chainSegIdx)
                                            let chainFieldType = this.getSeenFieldType(chainType, chainField)
                                            if this.isClassType(chainFieldType) {
                                                let loadedVal = this.generateFieldAccess(chainPtr, chainType, chainField)
                                                let convPtr = this.getNextReg()
                                                output.append("  " + convPtr + " = inttoptr i64 " + loadedVal + " to ptr\n")
                                                chainPtr = convPtr
                                            } else if this.isDataType(chainFieldType) {
                                                chainPtr = this.generateFieldAccessPtr(chainPtr, chainType, chainField)
                                            } else {
                                                chainPtr = this.generateFieldAccessPtr(chainPtr, chainType, chainField)
                                            }
                                            chainType = chainFieldType
                                        }
                                        chainSegStart = chainSegIdx + 1
                                    }
                                    chainSegIdx = chainSegIdx + 1
                                }
                                intermediatePtrReg = chainPtr
                            } else {
                                intermediatePtrReg = this.generateFieldAccessPtr(basePtrReg, baseType, restPath)
                            }
                        }

                        let structIdx = this.findStruct(intermediateType)
                        if structIdx >= 0 {
                            let fieldIdx = this.getFieldInfo(intermediateType, fieldName)
                            if fieldIdx >= 0 {
                                let structLayout = structLayouts[structIdx]
                                let llvmFieldType = this.getFieldType(intermediateType, fieldName)
                                let fieldPtrReg = this.getNextReg()
                                output.append("  " + fieldPtrReg + " = getelementptr inbounds " + structLayout + ", ptr " + intermediatePtrReg + ", i32 0, i32 " + fieldIdx.toString() + "\n")
                                output.append("  store " + llvmFieldType + " " + valueReg + ", ptr " + fieldPtrReg + "\n")
                                return
                            }
                        }
                    }
                }
            }
        }

        // Simple case: receiver is a variable name like "this" or "someVar"
        let varIdx = this.findVar(receiverName)
        output.append("; DEBUG generateMemberAssignment: varIdx=" + varIdx.toString() + "\n")
        if varIdx >= 0 {
            let varReg = varRegs[varIdx]
            let varType = varTypes[varIdx]
            output.append("; DEBUG generateMemberAssignment: varType=" + varType + "\n")

            // Load the receiver - class types are stored as i64, data types are inline
            var receiverPtrReg = ""
            if this.isClassType(varType) {
                let loadReg = this.getNextReg()
                output.append("  " + loadReg + " = load i64, ptr " + varReg + "\n")
                receiverPtrReg = this.getNextReg()
                output.append("  " + receiverPtrReg + " = inttoptr i64 " + loadReg + " to ptr\n")
            } else if this.isDataType(varType) {
                // Data types are stored inline - use the alloca pointer directly
                receiverPtrReg = varReg
            } else {
                receiverPtrReg = this.getNextReg()
                output.append("  " + receiverPtrReg + " = load ptr, ptr " + varReg + "\n")
            }

            // Find struct and field
            let structIdx = this.findStruct(varType)
            output.append("; DEBUG generateMemberAssignment: structIdx=" + structIdx.toString() + " fieldName=" + fieldName + "\n")
            if structIdx >= 0 {
                let fieldIdx = this.getFieldInfo(varType, fieldName)
                if fieldIdx >= 0 {
                    let structLayout = structLayouts[structIdx]
                    // Note: getFieldType already returns LLVM type
                    let llvmFieldType = this.getFieldType(varType, fieldName)
                    let seenFieldType = this.getSeenFieldType(varType, fieldName)

                    // GEP to field
                    let fieldPtrReg = this.getNextReg()
                    output.append("  " + fieldPtrReg + " = getelementptr inbounds " + structLayout + ", ptr " + receiverPtrReg + ", i32 0, i32 " + fieldIdx.toString() + "\n")

                    // For inline data types from struct literals, valueReg is a ptr - need to load value first
                    // But for method calls/function calls, valueReg is already the struct value
                    var actualValueReg = valueReg
                    if this.isDataType(seenFieldType) and value.kind == "StructLiteral" {
                        let loadedVal = this.getNextReg()
                        output.append("  " + loadedVal + " = load " + llvmFieldType + ", ptr " + valueReg + "\n")
                        actualValueReg = loadedVal
                    }

                    // Store
                    output.append("  store " + llvmFieldType + " " + actualValueReg + ", ptr " + fieldPtrReg + "\n")
                    return
                }
            }
        }

        // Check if it's a field of 'this'
        let thisIdx = this.findVar("this")
        if thisIdx >= 0 {
            let thisReg = varRegs[thisIdx]
            let thisType = varTypes[thisIdx]

            // Check if receiverName is a field of 'this'
            let thisStructIdx = this.findStruct(thisType)
            if thisStructIdx >= 0 {
                let firstFieldIdx = this.getFieldInfo(thisType, receiverName)
                if firstFieldIdx >= 0 {
                    // Load 'this' pointer
                    let thisPtrReg = this.getNextReg()
                    output.append("  " + thisPtrReg + " = load ptr, ptr " + thisReg + "\n")

                    // Resolve the Seen type for the first field
                    let firstFieldType = this.getSeenFieldType(thisType, receiverName)
                    if firstFieldType == "" {
                        return
                    }

                    // Obtain a pointer to the nested struct
                    var nestedPtrReg = ""
                    if this.isClassType(firstFieldType) {
                        // Class fields are stored as i64 pointer-as-int
                        let firstFieldValReg = this.generateFieldAccess(thisPtrReg, thisType, receiverName)
                        let ptrConvReg = this.getNextReg()
                        output.append("  " + ptrConvReg + " = inttoptr i64 " + firstFieldValReg + " to ptr\n")
                        nestedPtrReg = ptrConvReg
                    } else {
                        // Inline data types (or non-class structs) are stored by value
                        nestedPtrReg = this.generateFieldAccessPtr(thisPtrReg, thisType, receiverName)
                    }

                    let nestedStructIdx = this.findStruct(firstFieldType)
                    if nestedStructIdx >= 0 {
                        let finalFieldIdx = this.getFieldInfo(firstFieldType, fieldName)
                        if finalFieldIdx >= 0 {
                            let nestedStructLayout = structLayouts[nestedStructIdx]
                            // Note: getFieldType already returns LLVM type
                            let llvmFinalFieldType = this.getFieldType(firstFieldType, fieldName)

                            // GEP to final field
                            let finalFieldPtrReg = this.getNextReg()
                            output.append("  " + finalFieldPtrReg + " = getelementptr inbounds " + nestedStructLayout + ", ptr " + nestedPtrReg + ", i32 0, i32 " + finalFieldIdx.toString() + "\n")

                            // Store
                            output.append("  store " + llvmFinalFieldType + " " + valueReg + ", ptr " + finalFieldPtrReg + "\n")
                            return
                        }
                    }
                }
            }
        }
    }

    // Generate index assignment: a[i] = value
    fun generateIndexAssignment(expr: ParserExpressionNode) r: Void {
        // expr.operands[0] = lhs IndexAccess, expr.operands[1] = rhs value
        let indexAccess = expr.operands[0]
        let value = expr.operands[1]

        // indexAccess.operands[0] = array, indexAccess.operands[1] = index
        let array = indexAccess.operands[0]
        let index = indexAccess.operands[1]

        // Generate the array, index, and value
        let arrayReg = this.generateExpression(array)
        let indexReg = this.generateExpression(index)
        let valueReg = this.generateExpression(value)

        // Infer the array element type
        let arrayType = this.inferExpressionType(array)
        var elementType = "ptr"
        if arrayType.startsWith("Array<") {
            elementType = arrayType.substring(6, arrayType.length() - 1)
        }
        let llvmElementType = this.mapType(elementType)

        // Call array set function (pass pointer to element value)
        let valueIsStructLiteral = value.kind == "StructLiteral"
        var valuePtrReg = ""
        if this.isClassType(elementType) {
            // Class types are stored as i64 (pointer-as-int) - store to temp and pass pointer
            let tmpReg = this.getNextReg()
            output.append("  " + tmpReg + " = alloca i64\n")
            output.append("  store i64 " + valueReg + ", ptr " + tmpReg + "\n")
            valuePtrReg = tmpReg
        } else if this.isDataType(elementType) {
            // Data types are inline structs - pass pointer to value
            if valueIsStructLiteral {
                valuePtrReg = valueReg
            } else {
                let tmpReg = this.getNextReg()
                output.append("  " + tmpReg + " = alloca %" + elementType + "\n")
                output.append("  store %" + elementType + " " + valueReg + ", ptr " + tmpReg + "\n")
                valuePtrReg = tmpReg
            }
        } else if llvmElementType == "ptr" {
            // Pointer element - store pointer to temp so we copy the pointer value
            let tmpReg = this.getNextReg()
            var storedValue = valueReg
            if storedValue == "0" {
                storedValue = "null"
            }
            output.append("  " + tmpReg + " = alloca ptr\n")
            output.append("  store ptr " + storedValue + ", ptr " + tmpReg + "\n")
            valuePtrReg = tmpReg
        } else {
            // Primitive or struct value (String, Int, Bool, Float, etc.)
            let tmpReg = this.getNextReg()
            output.append("  " + tmpReg + " = alloca " + llvmElementType + "\n")
            output.append("  store " + llvmElementType + " " + valueReg + ", ptr " + tmpReg + "\n")
            valuePtrReg = tmpReg
        }

        output.append("  call void @Array_set(ptr " + arrayReg + ", i64 " + indexReg + ", ptr " + valuePtrReg + ")\n")
    }

    fun generateExpression(expr: ParserExpressionNode) r: String {
        // Debug: log all expressions related to LLVMIRGenerator
        if expr.callee.contains("LLVMIRGenerator") or expr.literalValue.contains("LLVMIRGenerator") or (expr.callee == "new" and expr.literalValue != "") {
            println("[DEBUG EXPR] kind=" + expr.kind + " callee=" + expr.callee + " literalValue=" + expr.literalValue)
        }
        if expr.kind == "Literal" {
            return generateLiteral(expr)
        }
        if expr.kind == "Variable" or expr.kind == "VarExpr" {
            return generateVariable(expr)
        }
        if expr.kind == "Binary" {
            return generateBinary(expr)
        }
        if expr.kind == "Call" {
            return generateCall(expr)
        }
        if expr.kind == "MethodCall" {
            return generateMethodCall(expr)
        }
        if expr.kind == "Unary" {
            return generateUnary(expr)
        }
        if expr.kind == "MemberAccess" {
            return generateMemberAccess(expr)
        }
        if expr.kind == "IndexAccess" {
            return generateIndexAccess(expr)
        }
        if expr.kind == "StructLiteral" {
            return generateStructLiteral(expr)
        }
        if expr.kind == "ArrayLiteral" {
            return generateArrayLiteral(expr)
        }
        return "0"
    }

    fun generateArrayLiteral(expr: ParserExpressionNode) r: String {
        let savedPendingType = pendingArrayLiteralType

        // Resolve element type from expected array type or first element
        var elementType = ""
        if pendingArrayLiteralType != "" {
            elementType = this.extractArrayLiteralElementType(pendingArrayLiteralType)
        }
        if elementType == "" and expr.arguments.length() > 0 {
            let firstExpr = expr.arguments[0]
            if firstExpr.kind == "StructLiteral" and firstExpr.literalType != "" {
                elementType = firstExpr.literalType
            } else {
                elementType = this.inferExpressionType(firstExpr)
            }
        }

        // Create array using runtime helpers so element_size stays consistent
        let arrReg = this.getNextReg()
        if elementType == "String" {
            output.append("  " + arrReg + " = call ptr @seen_arr_new_str_ptr()\n")
        } else if this.isDataType(elementType) {
            let elementSize = this.getDataTypeSize(elementType)
            output.append("  " + arrReg + " = call ptr @seen_arr_new_with_size_ptr(i64 " + elementSize.toString() + ")\n")
        } else {
            output.append("  " + arrReg + " = call ptr @seen_arr_new_ptr_ptr()\n")
        }

        // Populate elements
        var elemIdx = 0
        while elemIdx < expr.arguments.length() {
            let elemExpr = expr.arguments[elemIdx]
            let savedElemPending = pendingArrayLiteralType
            pendingArrayLiteralType = ""
            if elemExpr.kind == "ArrayLiteral" and (elementType.startsWith("Array") or elementType.startsWith("List")) {
                pendingArrayLiteralType = elementType
            }
            let argReg = this.generateExpression(elemExpr)
            pendingArrayLiteralType = savedElemPending

            var argType = elementType
            if argType == "" {
                if elemExpr.kind == "StructLiteral" and elemExpr.literalType != "" {
                    argType = elemExpr.literalType
                } else {
                    argType = this.inferExpressionType(elemExpr)
                }
            }
            let argIsStructLiteral = elemExpr.kind == "StructLiteral"

            if argType == "String" {
                output.append("  call void @seen_arr_push_str(ptr " + arrReg + ", %SeenString " + argReg + ")\n")
            } else if argType == "Int" {
                output.append("  call void @seen_arr_push_i64(ptr " + arrReg + ", i64 " + argReg + ")\n")
            } else {
                var ptrArgReg = argReg
                if ptrArgReg == "0" {
                    ptrArgReg = "null"
                }
                if this.isClassType(argType) {
                    let tmpClassReg = this.getNextReg()
                    output.append("  " + tmpClassReg + " = alloca i64\n")
                    output.append("  store i64 " + argReg + ", ptr " + tmpClassReg + "\n")
                    ptrArgReg = tmpClassReg
                }
                if this.isDataType(argType) and not argIsStructLiteral {
                    let tmpDataReg = this.getNextReg()
                    output.append("  " + tmpDataReg + " = alloca %" + argType + "\n")
                    output.append("  store %" + argType + " " + argReg + ", ptr " + tmpDataReg + "\n")
                    ptrArgReg = tmpDataReg
                }
                let pushReg = this.getNextReg()
                output.append("  " + pushReg + " = call i64 @Array_push(ptr " + arrReg + ", ptr " + ptrArgReg + ")\n")
            }
            elemIdx = elemIdx + 1
        }

        pendingArrayLiteralType = savedPendingType
        return arrReg
    }

    fun generateIndexAccess(expr: ParserExpressionNode) r: String {
        // operands[0] = array expression
        // operands[1] = index expression
        output.append("; DEBUG generateIndexAccess: operands[0].kind=" + expr.operands[0].kind + " variableName=" + expr.operands[0].variableName + " literalValue=" + expr.operands[0].literalValue + "\n")
        var arrayReg = this.generateExpression(expr.operands[0])
        output.append("; DEBUG arrayReg=" + arrayReg + "\n")
        let indexReg = this.generateExpression(expr.operands[1])

        // Workaround: if arrayReg is 0 and the variable name is 'statements',
        // try to find a BlockNode variable with that field
        if arrayReg == "0" and expr.operands[0].variableName == "statements" {
            output.append("; DEBUG trying to find BlockNode for statements\n")
            // Look for any local variable of type BlockNode
            var blockIdx = 0
            while blockIdx < varTypes.length() {
                if varTypes[blockIdx] == "BlockNode" {
                    let blockVarReg = varRegs[blockIdx]
                    // Load the block pointer
                    let blockPtrReg = this.getNextReg()
                    output.append("  " + blockPtrReg + " = load ptr, ptr " + blockVarReg + "\n")
                    // Access the statements field
                    arrayReg = this.generateFieldAccess(blockPtrReg, "BlockNode", "statements")
                    output.append("; DEBUG found BlockNode, arrayReg=" + arrayReg + "\n")
                    blockIdx = varTypes.length()  // break
                }
                blockIdx = blockIdx + 1
            }
        }

        // Infer the element type from the array type
        let arrayType = this.inferExpressionType(expr.operands[0])
        output.append("; DEBUG arrayType=" + arrayType + "\n")

        // For List<T> types, arrayReg is already a ptr - use it directly
        var arrayPtrReg = ""
        if arrayType.startsWith("List<") {
            // List types are ptr - use directly
            arrayPtrReg = arrayReg
        }
        if not arrayType.startsWith("List<") {
            // For byval arrays, we need to store the array in an alloca and pass the pointer
            // arrayReg is a ptr to SeenArray (heap-allocated), so we need to:
            // 1. Allocate local storage
            // 2. Load the SeenArray from the ptr
            // 3. Store it in the alloca for byval passing
            arrayPtrReg = this.getNextReg()
            output.append("  " + arrayPtrReg + " = alloca %SeenArray, align 8\n")
            let seenArrReg = this.getNextReg()
            output.append("  " + seenArrReg + " = load %SeenArray, ptr " + arrayReg + "\n")
            output.append("  store %SeenArray " + seenArrReg + ", ptr " + arrayPtrReg + ", align 8\n")
        }

        var resultReg = ""
        var handledArr = false

        // Use typed array get functions based on element type
        if arrayType == "Array<String>" {
            resultReg = this.getNextReg()
            output.append("  " + resultReg + " = call %SeenString @seen_arr_get_str(ptr byval(%SeenArray) align 8 " + arrayPtrReg + ", i64 " + indexReg + ")\n")
            handledArr = true
        }
        if not handledArr and arrayType == "Array<FrontendDiagnostic>" {
            let ptrResultReg = this.getNextReg()
            output.append("  " + ptrResultReg + " = call ptr @seen_arr_get_diag(ptr byval(%SeenArray) align 8 " + arrayPtrReg + ", i64 " + indexReg + ")\n")
            // FrontendDiagnostic is a class type stored as i64, convert ptr to i64
            resultReg = this.getNextReg()
            output.append("  " + resultReg + " = ptrtoint ptr " + ptrResultReg + " to i64\n")
            handledArr = true
        }
        if not handledArr and arrayType == "Array<Int>" {
            // Get pointer to int element slot and load the i64 value
            // Use seen_arr_get_element (returns ptr to element slot) not seen_arr_get_ptr (returns stored pointer value)
            let ptrReg = this.getNextReg()
            output.append("  " + ptrReg + " = call ptr @seen_arr_get_element(ptr byval(%SeenArray) align 8 " + arrayPtrReg + ", i64 " + indexReg + ")\n")
            resultReg = this.getNextReg()
            output.append("  " + resultReg + " = load i64, ptr " + ptrReg + "\n")
            handledArr = true
        }
        if not handledArr and arrayType == "Array<ItemNode>" {
            // ItemNode is a data type (inline struct), use seen_arr_get_element which uses element_size for correct offset
            let ptrReg = this.getNextReg()
            output.append("  " + ptrReg + " = call ptr @seen_arr_get_element(ptr byval(%SeenArray) align 8 " + arrayPtrReg + ", i64 " + indexReg + ")\n")
            resultReg = this.getNextReg()
            output.append("  " + resultReg + " = load %ItemNode, ptr " + ptrReg + "\n")
            handledArr = true
        }
        if not handledArr and arrayType == "Array<ProgramNode>" {
            // ProgramNode is a class type, so convert ptr to i64
            let ptrResultReg = this.getNextReg()
            output.append("  " + ptrResultReg + " = call ptr @seen_arr_get_ptr(ptr byval(%SeenArray) align 8 " + arrayPtrReg + ", i64 " + indexReg + ")\n")
            resultReg = this.getNextReg()
            output.append("  " + resultReg + " = ptrtoint ptr " + ptrResultReg + " to i64\n")
            handledArr = true
        }
        if not handledArr {
            // Extract element type from arrayType (e.g., "Array<TypeError>" -> "TypeError")
            var elementType = ""
            if arrayType.startsWith("Array<") and arrayType.endsWith(">") {
                elementType = arrayType.substring(6, arrayType.length() - 1)
            }

            // Choose the right getter based on element type
            let ptrResultReg = this.getNextReg()
            if this.isDataType(elementType) {
                // Data types are stored inline - use seen_arr_get_element which uses element_size
                output.append("  " + ptrResultReg + " = call ptr @seen_arr_get_element(ptr byval(%SeenArray) align 8 " + arrayPtrReg + ", i64 " + indexReg + ")\n")
                // Load the inline struct value
                resultReg = this.getNextReg()
                output.append("  " + resultReg + " = load %" + elementType + ", ptr " + ptrResultReg + "\n")
            } else if this.isClassType(elementType) {
                // Class types are stored as pointers - use seen_arr_get_ptr
                output.append("  " + ptrResultReg + " = call ptr @seen_arr_get_ptr(ptr byval(%SeenArray) align 8 " + arrayPtrReg + ", i64 " + indexReg + ")\n")
                // Convert ptr to i64 for class types
                resultReg = this.getNextReg()
                output.append("  " + resultReg + " = ptrtoint ptr " + ptrResultReg + " to i64\n")
            } else {
                // Default: use pointer get
                output.append("  " + ptrResultReg + " = call ptr @seen_arr_get_ptr(ptr byval(%SeenArray) align 8 " + arrayPtrReg + ", i64 " + indexReg + ")\n")
                resultReg = ptrResultReg
            }
        }

        return resultReg
    }

    fun generateMemberAccess(expr: ParserExpressionNode) r: String {
        // literalValue = receiver variable name (or chained path)
        // variableName = field/member name
        let receiverName = expr.literalValue
        let fieldName = expr.variableName

        // Handle enum member access: SeenTokenType.KeywordImport -> integer value
        if receiverName == "SeenTokenType" {
            let enumValue = this.getSeenTokenTypeValue(fieldName)
            return enumValue.toString()
        }

        // Check if receiver has an operand (chained expression like func().field)
        if expr.operands.length() > 0 {
            // Receiver is an expression result - get its type and generate field access
            let receiverReg = this.generateExpression(expr.operands[0])
            let receiverType = this.inferExpressionType(expr.operands[0])
            // If receiver type is a class type, it's stored as i64, so convert to ptr
            var actualReceiverReg = receiverReg
            if this.isClassType(receiverType) {
                let ptrConvReg = this.getNextReg()
                output.append("  " + ptrConvReg + " = inttoptr i64 " + receiverReg + " to ptr\n")
                actualReceiverReg = ptrConvReg
            }
            // If receiver type is a data type, store to temp memory and use that ptr
            if this.isDataType(receiverType) {
                let tmpReg = this.getNextReg()
                output.append("  " + tmpReg + " = alloca %" + receiverType + "\n")
                output.append("  store %" + receiverType + " " + receiverReg + ", ptr " + tmpReg + "\n")
                actualReceiverReg = tmpReg
            }
            return generateFieldAccess(actualReceiverReg, receiverType, fieldName)
        }

        // Simple variable field access like frontend.success or frontend.program
        let idx = this.findVar(receiverName)
        if idx >= 0 {
            let varReg = varRegs[idx]
            let varType = varTypes[idx]

            // Load the variable value - class types are stored as i64, data types are inline
            if this.isClassType(varType) {
                let loadReg = this.getNextReg()
                output.append("  " + loadReg + " = load i64, ptr " + varReg + "\n")
                // Convert to ptr for field access
                let ptrReg = this.getNextReg()
                output.append("  " + ptrReg + " = inttoptr i64 " + loadReg + " to ptr\n")
                return generateFieldAccess(ptrReg, varType, fieldName)
            } else if this.isDataType(varType) {
                // Data types are stored inline - use the alloca pointer directly
                return generateFieldAccess(varReg, varType, fieldName)
            } else {
                // Non-class types stored as ptr
                let ptrReg = this.getNextReg()
                output.append("  " + ptrReg + " = load ptr, ptr " + varReg + "\n")
                return generateFieldAccess(ptrReg, varType, fieldName)
            }
        }

        // Handle path with array indexing like "expr.operands[0]" for ".kind"
        if receiverName.contains("[") {
            output.append("; DEBUG generateMemberAccess: handling array path=" + receiverName + " fieldName=" + fieldName + "\n")
            // Find the bracket position
            var bracketIdx = 0
            var bi = 0
            while bi < receiverName.length() {
                if receiverName.substring(bi, bi + 1) == "[" {
                    bracketIdx = bi
                    bi = receiverName.length()  // break
                }
                bi = bi + 1
            }

            // Parse the path before the bracket
            let pathBeforeBracket = receiverName.substring(0, bracketIdx)
            // Parse the index inside brackets
            var closeBracket = bracketIdx + 1
            while closeBracket < receiverName.length() {
                if receiverName.substring(closeBracket, closeBracket + 1) == "]" {
                    closeBracket = closeBracket  // found
                    closeBracket = receiverName.length() + 1  // break
                }
                closeBracket = closeBracket + 1
            }
            closeBracket = closeBracket - 1  // adjust back to the ]

            // Find the actual close bracket
            var actualClose = bracketIdx + 1
            while actualClose < receiverName.length() and receiverName.substring(actualClose, actualClose + 1) != "]" {
                actualClose = actualClose + 1
            }
            let indexStr = receiverName.substring(bracketIdx + 1, actualClose)

            output.append("; DEBUG array path: pathBeforeBracket=" + pathBeforeBracket + " indexStr=" + indexStr + "\n")

            // Generate the array access
            // First, generate the path before bracket (e.g., "expr.operands")
            if pathBeforeBracket.contains(".") {
                // Split into base variable and field
                var dotIdx = 0
                var di = 0
                while di < pathBeforeBracket.length() {
                    if pathBeforeBracket.substring(di, di + 1) == "." {
                        dotIdx = di
                        di = pathBeforeBracket.length()  // break
                    }
                    di = di + 1
                }
                let baseVar = pathBeforeBracket.substring(0, dotIdx)
                let arrayField = pathBeforeBracket.substring(dotIdx + 1, pathBeforeBracket.length())

                output.append("; DEBUG array path split: baseVar=" + baseVar + " arrayField=" + arrayField + "\n")

                let baseIdx = this.findVar(baseVar)
                if baseIdx >= 0 {
                    let baseReg = varRegs[baseIdx]
                    let baseType = varTypes[baseIdx]

                    // Load the base pointer
                    let ptrReg = this.getNextReg()
                    output.append("  " + ptrReg + " = load ptr, ptr " + baseReg + "\n")

                    // Access the array field
                    let arrayReg = this.generateFieldAccess(ptrReg, baseType, arrayField)
                    let arrayType = this.getSeenFieldType(baseType, arrayField)

                    output.append("; DEBUG array access: arrayReg=" + arrayReg + " arrayType=" + arrayType + "\n")

                    // Infer the element type BEFORE making the array access call
                    var elementType = "ptr"
                    if arrayType.startsWith("Array<") and arrayType.endsWith(">") {
                        elementType = arrayType.substring(6, arrayType.length() - 1)
                    }

                    // Now perform index access
                    let tempReg = this.getNextReg()
                    output.append("  " + tempReg + " = alloca %SeenArray, align 8\n")
                    output.append("  store %SeenArray " + arrayReg + ", ptr " + tempReg + ", align 8\n")

                    let elementPtrReg = this.getNextReg()
                    // Use seen_arr_get_element for data types (inline structs), seen_arr_get_ptr for class types (pointers)
                    if this.isDataType(elementType) {
                        output.append("  " + elementPtrReg + " = call ptr @seen_arr_get_element(ptr byval(%SeenArray) align 8 " + tempReg + ", i64 " + indexStr + ")\n")
                    } else {
                        output.append("  " + elementPtrReg + " = call ptr @seen_arr_get_ptr(ptr byval(%SeenArray) align 8 " + tempReg + ", i64 " + indexStr + ")\n")
                    }

                    output.append("; DEBUG element access: elementPtrReg=" + elementPtrReg + " elementType=" + elementType + "\n")

                    // Finally, access the field on the element
                    return generateFieldAccess(elementPtrReg, elementType, fieldName)
                }
            }
        }

        // Handle chained receiver like "frontend.program" with fieldName "items"
        // Need to find base variable and chain through fields
        if receiverName.contains(".") {
            // Parse the chain: split by first dot to get base variable and remaining path
            var dotIdx = 0
            var i = 0
            while i < receiverName.length() {
                if receiverName.substring(i, i + 1) == "." {
                    dotIdx = i
                    i = receiverName.length()  // break
                }
                i = i + 1
            }

            if dotIdx > 0 {
                let baseVarName = receiverName.substring(0, dotIdx)
                let restPath = receiverName.substring(dotIdx + 1, receiverName.length())

                let baseIdx = this.findVar(baseVarName)
                if baseIdx >= 0 {
                    let baseReg = varRegs[baseIdx]
                    let baseType = varTypes[baseIdx]
                    // Load base - class types are stored as i64, data types are inline
                    var ptrReg = ""
                    if this.isClassType(baseType) {
                        let loadReg = this.getNextReg()
                        output.append("  " + loadReg + " = load i64, ptr " + baseReg + "\n")
                        ptrReg = this.getNextReg()
                        output.append("  " + ptrReg + " = inttoptr i64 " + loadReg + " to ptr\n")
                    } else if this.isDataType(baseType) {
                        // Data types are stored inline - use the alloca pointer directly
                        ptrReg = baseReg
                    } else {
                        ptrReg = this.getNextReg()
                        output.append("  " + ptrReg + " = load ptr, ptr " + baseReg + "\n")
                    }
                    // First, determine the intermediate type so we know how to access it
                    // Handle chained restPath (e.g., "function.returnType") by walking through types
                    var intermediateType = ""
                    output.append("; DEBUG generateMemberAccess: baseType=" + baseType + " restPath=" + restPath + " fieldName=" + fieldName + "\n")
                    if restPath.contains(".") {
                        // Walk through the chained path to find final type
                        // Parse the path into segments first
                        var pathSegments = Array<String>()
                        var segStart = 0
                        var segIdx = 0
                        while segIdx <= restPath.length() {
                            if segIdx == restPath.length() or restPath.substring(segIdx, segIdx + 1) == "." {
                                if segIdx > segStart {
                                    pathSegments.push(restPath.substring(segStart, segIdx))
                                }
                                segStart = segIdx + 1
                            }
                            segIdx = segIdx + 1
                        }

                        var currentType = baseType
                        var pi = 0
                        while pi < pathSegments.length() and currentType != "" and currentType != "Int" {
                            let currField = pathSegments[pi]
                            output.append("; DEBUG chained type walk: currentType=" + currentType + " currField=" + currField + "\n")
                            currentType = this.getSeenFieldType(currentType, currField)
                            output.append("; DEBUG chained type walk: newType=" + currentType + "\n")
                            pi = pi + 1
                        }
                        intermediateType = currentType
                        output.append("; DEBUG chained type final: intermediateType=" + intermediateType + "\n")
                    }
                    if not restPath.contains(".") {
                        intermediateType = this.getSeenFieldType(baseType, restPath)
                    }
                    if intermediateType == "" {
                        intermediateType = "ProgramNode"  // Default for .program access
                    }

                    // Access intermediate field (e.g., "program")
                    // For class types: load value (i64) and convert to ptr
                    // For inline data types: get pointer to field directly
                    var actualIntermediateReg = ""
                    if this.isClassType(intermediateType) {
                        let intermediateReg = this.generateFieldAccess(ptrReg, baseType, restPath)
                        let ptrConvReg = this.getNextReg()
                        output.append("  " + ptrConvReg + " = inttoptr i64 " + intermediateReg + " to ptr\n")
                        actualIntermediateReg = ptrConvReg
                    } else {
                        // Inline data types: get pointer to the field (don't load the value)
                        // Handle chained paths like "function.returnType" by walking through each segment
                        if restPath.contains(".") {
                            // Walk through the chain, accessing each field in turn
                            var chainPtr = ptrReg
                            var chainType = baseType
                            var chainSegStart = 0
                            var chainSegIdx = 0
                            while chainSegIdx <= restPath.length() {
                                if chainSegIdx == restPath.length() or restPath.substring(chainSegIdx, chainSegIdx + 1) == "." {
                                    if chainSegIdx > chainSegStart {
                                        let chainField = restPath.substring(chainSegStart, chainSegIdx)
                                        let chainFieldType = this.getSeenFieldType(chainType, chainField)
                                        output.append("; DEBUG chained ptr access: chainType=" + chainType + " chainField=" + chainField + " chainFieldType=" + chainFieldType + "\n")
                                        if this.isClassType(chainFieldType) {
                                            // Class field: load i64 and convert to ptr
                                            let loadedVal = this.generateFieldAccess(chainPtr, chainType, chainField)
                                            let convPtr = this.getNextReg()
                                            output.append("  " + convPtr + " = inttoptr i64 " + loadedVal + " to ptr\n")
                                            chainPtr = convPtr
                                        } else if this.isDataType(chainFieldType) {
                                            // Data type field: get pointer to inline struct
                                            chainPtr = this.generateFieldAccessPtr(chainPtr, chainType, chainField)
                                        } else {
                                            // Primitive or other: load value for intermediate, get ptr for final
                                            chainPtr = this.generateFieldAccessPtr(chainPtr, chainType, chainField)
                                        }
                                        chainType = chainFieldType
                                    }
                                    chainSegStart = chainSegIdx + 1
                                }
                                chainSegIdx = chainSegIdx + 1
                            }
                            actualIntermediateReg = chainPtr
                        } else {
                            // Simple single field access
                            actualIntermediateReg = this.generateFieldAccessPtr(ptrReg, baseType, restPath)
                        }
                    }
                    return generateFieldAccess(actualIntermediateReg, intermediateType, fieldName)
                }
            }
        }

        // Handle field of 'this' - if receiverName isn't a local variable, check if it's a field on 'this'
        let thisIdx = this.findVar("this")
        if thisIdx >= 0 {
            let thisReg = varRegs[thisIdx]
            let thisType = varTypes[thisIdx]

            // Check if receiverName is a field of thisType
            let fieldIdx = this.getFieldInfo(thisType, receiverName)
            if fieldIdx >= 0 {
                // Load 'this' pointer and access the field chain
                let ptrReg = this.getNextReg()
                output.append("  " + ptrReg + " = load ptr, ptr " + thisReg + "\n")

                let intermediateType = this.getSeenFieldType(thisType, receiverName)

                output.append("; DEBUG this field access: thisType=" + thisType + " receiverName=" + receiverName + " intermediateType=" + intermediateType + " fieldName=" + fieldName + "\n")

                // Resolve pointer to intermediate field (class -> i64 to ptr, data -> field pointer)
                var accessReg = ""
                if this.isClassType(intermediateType) {
                    let intermediateReg = this.generateFieldAccess(ptrReg, thisType, receiverName)
                    let ptrConvReg = this.getNextReg()
                    output.append("  " + ptrConvReg + " = inttoptr i64 " + intermediateReg + " to ptr\n")
                    accessReg = ptrConvReg
                } else {
                    accessReg = this.generateFieldAccessPtr(ptrReg, thisType, receiverName)
                }

                // Now access the final field (e.g., 'statements')
                return generateFieldAccess(accessReg, intermediateType, fieldName)
            }
        }

        return "0"
    }

    fun generateFieldAccess(ptrReg: String, structType: String, fieldName: String) r: String {
        output.append("; DEBUG generateFieldAccess: structType=" + structType + " fieldName=" + fieldName + "\n")
        if structType == "TypeNode" and fieldName == "typeName" {
            println("[DEBUG TypeNode.typeName] ptrReg=" + ptrReg)
        }
        // Handle known chained field access patterns directly (avoid substring for reliability)
        if fieldName == "program.items" {
            // FrontendResult.program -> ProgramNode, then ProgramNode.items
            let progReg = this.generateFieldAccess(ptrReg, structType, "program")
            // program is a class type (i64), convert to ptr for next field access
            let progPtrReg = this.getNextReg()
            output.append("  " + progPtrReg + " = inttoptr i64 " + progReg + " to ptr\n")
            return generateFieldAccess(progPtrReg, "ProgramNode", "items")
        }
        if fieldName == "program.items.length" {
            // Access through chain
            let progReg = this.generateFieldAccess(ptrReg, structType, "program")
            // program is a class type (i64), convert to ptr for next field access
            let progPtrReg = this.getNextReg()
            output.append("  " + progPtrReg + " = inttoptr i64 " + progReg + " to ptr\n")
            let itemsReg = this.generateFieldAccess(progPtrReg, "ProgramNode", "items")
            // Return length field of array
            let lenPtrReg = this.getNextReg()
            output.append("  " + lenPtrReg + " = getelementptr inbounds %SeenArray, ptr " + itemsReg + ", i32 0, i32 0\n")
            let lenReg = this.getNextReg()
            output.append("  " + lenReg + " = load i64, ptr " + lenPtrReg + "\n")
            return lenReg
        }
        if fieldName.contains(".") {
            // Generic chained access - split and resolve sequentially
            // Find the first dot
            var dotIdx = 0
            var searchIdx = 0
            while searchIdx < fieldName.length() {
                if fieldName.substring(searchIdx, searchIdx + 1) == "." {
                    dotIdx = searchIdx
                    searchIdx = fieldName.length()
                }
                searchIdx = searchIdx + 1
            }
            if dotIdx > 0 {
                let firstField = fieldName.substring(0, dotIdx)
                let restFields = fieldName.substring(dotIdx + 1, fieldName.length())

                // Get type of first field for next access
                let firstType = this.getSeenFieldType(structType, firstField)

                output.append("; DEBUG chained access: structType=" + structType + " firstField=" + firstField + " firstType=" + firstType + " restFields=" + restFields + "\n")

                // For class types (stored as i64), load and convert to ptr
                // For inline data types (stored by value), get pointer to field
                var actualFirstReg = ""
                if this.isClassType(firstType) {
                    // Class types are stored as i64 - load and convert to ptr
                    let firstReg = this.generateFieldAccess(ptrReg, structType, firstField)
                    let ptrConvReg = this.getNextReg()
                    output.append("  " + ptrConvReg + " = inttoptr i64 " + firstReg + " to ptr\n")
                    actualFirstReg = ptrConvReg
                } else {
                    // Inline data types - get pointer to the field directly (don't load)
                    let fieldPtrReg = this.generateFieldAccessPtr(ptrReg, structType, firstField)
                    actualFirstReg = fieldPtrReg
                }

                // Recursively access remaining fields
                return generateFieldAccess(actualFirstReg, firstType, restFields)
            }
            output.append("; ERROR: Unknown chained field access: " + fieldName + "\n")
            return "0"
        }

        var fieldIndex = 0
        var fieldType = "i64"
        // Note: structLayout initialization deferred to avoid brace parsing issue
        var structLayout = "default"
        // Helper vars for building layout strings with braces (avoid parser issues with literal braces in strings)
        let lb = "{"
        let rb = "}"
        let seenArr = lb + " i64, i64, i64, ptr " + rb  // %SeenArray: { len, cap, element_size, data }

        // Prefer registry layouts when available (type header is authoritative)
        let structIdx = this.findStruct(structType)
        var registryHasLayout = false
        if structIdx >= 0 {
            let registeredLayout = structLayouts[structIdx]
            // Check if the registered layout is not empty (has fields)
            // Use length check to avoid brace literal comparison issues
            if registeredLayout.length() > 5 {
                structLayout = registeredLayout
                let regFieldIdx = this.getFieldInfo(structType, fieldName)
                if structType == "TypeNode" and fieldName == "typeName" {
                    println("[DEBUG TypeNode.typeName] structIdx=" + structIdx.toString() + " regFieldIdx=" + regFieldIdx.toString() + " registeredLayout='" + registeredLayout + "'")
                }
                if regFieldIdx >= 0 {
                    fieldIndex = regFieldIdx
                    fieldType = this.getFieldType(structType, fieldName)
                    registryHasLayout = true
                    if structType == "TypeNode" and fieldName == "typeName" {
                        println("[DEBUG TypeNode.typeName] fieldIndex=" + fieldIndex.toString() + " fieldType='" + fieldType + "'")
                    }
                }
            }
        }
        if not registryHasLayout {
            // Use hardcoded layouts for well-known types
            if structType == "LLVMIRGenerator" {
                structLayout = lb + " i64, ptr, i64, i64, ptr, ptr, ptr, i64, ptr, ptr, ptr, ptr, ptr, ptr, ptr, ptr, ptr, ptr, %SeenString, %SeenString, i1, %SeenString, %SeenString, ptr, ptr, %SeenString, ptr, ptr, i1, i1, %SeenString, %SeenString, ptr " + rb
                let llvmType = this.getLLVMIRGeneratorFieldType(fieldName)
                let idx = this.getLLVMIRGeneratorFieldIndex(fieldName)
                if idx >= 0 {
                    fieldIndex = idx
                }
                if llvmType != "" {
                    fieldType = llvmType
                }
            }
            if structType == "FrontendResult" {
                // FrontendResult { success: Bool, diagnostics: ptr (to SeenArray), program: i64 (class) }
                // Rust backend: arrays as ptr (8 bytes), class types as i64 (pointer-as-int)
                structLayout = lb + " i1, ptr, i64 " + rb
                if fieldName == "success" { fieldIndex = 0; fieldType = "i1" }
                if fieldName == "diagnostics" { fieldIndex = 1; fieldType = "ptr" }
                if fieldName == "program" { fieldIndex = 2; fieldType = "i64" }
            }
            if structType == "FrontendDiagnostic" {
                // FrontendDiagnostic { file: String, line: Int, column: Int, severity: String, message: String }
                structLayout = lb + " %SeenString, i64, i64, %SeenString, %SeenString " + rb
                if fieldName == "file" { fieldIndex = 0; fieldType = "%SeenString" }
                if fieldName == "line" { fieldIndex = 1; fieldType = "i64" }
                if fieldName == "column" { fieldIndex = 2; fieldType = "i64" }
                if fieldName == "severity" { fieldIndex = 3; fieldType = "%SeenString" }
                if fieldName == "message" { fieldIndex = 4; fieldType = "%SeenString" }
            }
            if structType == "CommandResult" {
                // CommandResult { success: Bool, output: SeenString }
                structLayout = lb + " i1, %SeenString " + rb
                if fieldName == "success" { fieldIndex = 0; fieldType = "i1" }
                if fieldName == "output" { fieldIndex = 1; fieldType = "%SeenString" }
            }
            if structType == "Point" {
                // Point { x: Int, y: Int }
                structLayout = lb + " i64, i64 " + rb
                if fieldName == "x" { fieldIndex = 0; fieldType = "i64" }
                if fieldName == "y" { fieldIndex = 1; fieldType = "i64" }
            }
            if structType == "Counter" {
                // Counter { value: Int }
                structLayout = lb + " i64 " + rb
                if fieldName == "value" { fieldIndex = 0; fieldType = "i64" }
            }
            if structType == "ImportPathInfo" {
                // ImportPathInfo { text: String, segments: ptr (to Array<String>) }
                // Rust backend stores arrays as ptr (8 bytes)
                structLayout = lb + " %SeenString, ptr " + rb
                if fieldName == "text" { fieldIndex = 0; fieldType = "%SeenString" }
                if fieldName == "segments" { fieldIndex = 1; fieldType = "ptr" }
            }
            if structType == "ProgramNode" {
                // ProgramNode { items: ptr (to SeenArray) }
                // Rust backend stores arrays as ptr (8 bytes)
                structLayout = lb + " ptr " + rb
                if fieldName == "items" { fieldIndex = 0; fieldType = "ptr" }
            }
            if structType == "ItemNode" {
                // ItemNode { itemType: String, name: String, visibility: String, importPath: Array<String>, importSymbols: Array<ImportSymbolNode>, function: FunctionNode, classNode: ClassNode, enumNode: EnumNode }
                // Arrays are ptr (8 bytes each, pointer to heap-allocated SeenArray), class fields are i64 (pointer-as-int)
                // Total: 16 + 16 + 16 + 8 + 8 + 8 + 8 + 8 = 88 bytes
                structLayout = lb + " %SeenString, %SeenString, %SeenString, ptr, ptr, i64, i64, i64 " + rb
                if fieldName == "itemType" { fieldIndex = 0; fieldType = "%SeenString" }
                if fieldName == "name" { fieldIndex = 1; fieldType = "%SeenString" }
                if fieldName == "visibility" { fieldIndex = 2; fieldType = "%SeenString" }
                if fieldName == "importPath" { fieldIndex = 3; fieldType = "ptr" }
                if fieldName == "importSymbols" { fieldIndex = 4; fieldType = "ptr" }
                if fieldName == "function" { fieldIndex = 5; fieldType = "i64" }
                if fieldName == "classNode" { fieldIndex = 6; fieldType = "i64" }
                if fieldName == "enumNode" { fieldIndex = 7; fieldType = "i64" }
            }
            if structType == "TypeInferenceResult" {
                // TypeInferenceResult { success: Bool, type: i64 (class), errors: ptr (array), warnings: ptr (array), environment: i64 (class) }
                // Rust backend: class fields as i64 (pointer-as-int), arrays as ptr
                structLayout = lb + " i1, i64, ptr, ptr, i64 " + rb
                if fieldName == "success" { fieldIndex = 0; fieldType = "i1" }
                if fieldName == "type" { fieldIndex = 1; fieldType = "i64" }
                if fieldName == "errors" { fieldIndex = 2; fieldType = "ptr" }
                if fieldName == "warnings" { fieldIndex = 3; fieldType = "ptr" }
                if fieldName == "environment" { fieldIndex = 4; fieldType = "i64" }
            }
            if structType == "FsFileResult" {
                // FsFileResult { isOk: Bool, file: FsFile, error: String }
                structLayout = lb + " i1, i64, %SeenString " + rb
                if fieldName == "isOk" { fieldIndex = 0; fieldType = "i1" }
                if fieldName == "file" { fieldIndex = 1; fieldType = "i64" }
                if fieldName == "error" { fieldIndex = 2; fieldType = "%SeenString" }
            }
            if structType == "FsFile" {
                // FsFile { fd: Int, path: String }
                structLayout = lb + " i64, %SeenString " + rb
                if fieldName == "fd" { fieldIndex = 0; fieldType = "i64" }
                if fieldName == "path" { fieldIndex = 1; fieldType = "%SeenString" }
            }
            if structType == "FunctionNode" {
                // FunctionNode { name: String, params: ptr (array), returnType: %TypeNode (inline data), body: i64 (class), isAsync: Bool, isInline: Bool, isStatic: Bool }
                // Rust backend: TypeNode is inline data type (not i64!), BlockNode is class type (i64)
                structLayout = lb + " %SeenString, ptr, %TypeNode, i64, i1, i1, i1 " + rb
                if fieldName == "name" { fieldIndex = 0; fieldType = "%SeenString" }
                if fieldName == "params" { fieldIndex = 1; fieldType = "ptr" }
                if fieldName == "returnType" { fieldIndex = 2; fieldType = "%TypeNode" }
                if fieldName == "body" { fieldIndex = 3; fieldType = "i64" }
                if fieldName == "isAsync" { fieldIndex = 4; fieldType = "i1" }
                if fieldName == "isInline" { fieldIndex = 5; fieldType = "i1" }
                if fieldName == "isStatic" { fieldIndex = 6; fieldType = "i1" }
            }
            if structType == "ClassNode" {
                // ClassNode { name: String, fields: ptr (array), methods: ptr (array) }
                // Rust backend: arrays as ptr (8 bytes each)
                structLayout = lb + " %SeenString, ptr, ptr " + rb
                if fieldName == "name" { fieldIndex = 0; fieldType = "%SeenString" }
                if fieldName == "fields" { fieldIndex = 1; fieldType = "ptr" }
                if fieldName == "methods" { fieldIndex = 2; fieldType = "ptr" }
            }
            if structType == "TypeNode" {
                // TypeNode { typeName: String, isNullable: Bool }
                structLayout = lb + " %SeenString, i1 " + rb
                if fieldName == "typeName" { fieldIndex = 0; fieldType = "%SeenString" }
                if fieldName == "isNullable" { fieldIndex = 1; fieldType = "i1" }
            }
            if structType == "FieldNode" {
                // FieldNode layout comes from registry when available
                structLayout = lb + " %SeenString, %TypeNode, i1, i64, %SeenString " + rb
                if fieldName == "name" { fieldIndex = 0; fieldType = "%SeenString" }
                if fieldName == "fieldType" { fieldIndex = 1; fieldType = "%TypeNode" }
                if fieldName == "isMutable" { fieldIndex = 2; fieldType = "i1" }
                if fieldName == "defaultValue" { fieldIndex = 3; fieldType = "i64" }
                if fieldName == "visibility" { fieldIndex = 4; fieldType = "%SeenString" }
            }
            if structType == "ParamNode" {
                // ParamNode { name: String, paramType: TypeNode, isMutable: Bool }
                structLayout = lb + " %SeenString, %TypeNode, i1 " + rb
                if fieldName == "name" { fieldIndex = 0; fieldType = "%SeenString" }
                if fieldName == "paramType" { fieldIndex = 1; fieldType = "%TypeNode" }
                if fieldName == "isMutable" { fieldIndex = 2; fieldType = "i1" }
            }
            if structType == "ParserExpressionNode" {
                // ParserExpressionNode { kind, operands: ptr (array), operator, literalValue, literalType, variableName, callee, arguments: ptr (array) }
                // Rust backend: arrays as ptr (8 bytes each)
                structLayout = lb + " %SeenString, ptr, %SeenString, %SeenString, %SeenString, %SeenString, %SeenString, ptr " + rb
                if fieldName == "kind" { fieldIndex = 0; fieldType = "%SeenString" }
                if fieldName == "operands" { fieldIndex = 1; fieldType = "ptr" }
                if fieldName == "operator" { fieldIndex = 2; fieldType = "%SeenString" }
                if fieldName == "literalValue" { fieldIndex = 3; fieldType = "%SeenString" }
                if fieldName == "literalType" { fieldIndex = 4; fieldType = "%SeenString" }
                if fieldName == "variableName" { fieldIndex = 5; fieldType = "%SeenString" }
                if fieldName == "callee" { fieldIndex = 6; fieldType = "%SeenString" }
                if fieldName == "arguments" { fieldIndex = 7; fieldType = "ptr" }
            }
            if structType == "Type" {
                // Type { name: String, isNullable: Bool }
                structLayout = lb + " %SeenString, i1 " + rb
                if fieldName == "name" { fieldIndex = 0; fieldType = "%SeenString" }
                if fieldName == "isNullable" { fieldIndex = 1; fieldType = "i1" }
            }
            if structType == "FunctionType" {
                // FunctionType { parameters: ptr (array), returnType: i64 (class), isAsync: Bool }
                // Rust backend: arrays as ptr, class fields as i64 (pointer-as-int)
                structLayout = lb + " ptr, i64, i1 " + rb
                if fieldName == "parameters" { fieldIndex = 0; fieldType = "ptr" }
                if fieldName == "returnType" { fieldIndex = 1; fieldType = "i64" }
                if fieldName == "isAsync" { fieldIndex = 2; fieldType = "i1" }
            }
            if structType == "ClassType" {
                // ClassType { name: String }
                structLayout = lb + " %SeenString " + rb
                if fieldName == "name" { fieldIndex = 0; fieldType = "%SeenString" }
            }
            if structType == "InterfaceType" {
                // InterfaceType { name: String }
                structLayout = lb + " %SeenString " + rb
                if fieldName == "name" { fieldIndex = 0; fieldType = "%SeenString" }
            }
            if structType == "Location" {
                // Location { line: Int, column: Int, file: String }
                structLayout = lb + " i64, i64, %SeenString " + rb
                if fieldName == "line" { fieldIndex = 0; fieldType = "i64" }
                if fieldName == "column" { fieldIndex = 1; fieldType = "i64" }
                if fieldName == "file" { fieldIndex = 2; fieldType = "%SeenString" }
            }
            if structType == "TypeError" {
                // TypeError { location: i64 (class), expected: i64 (class), actual: i64 (class), context: String }
                // Rust backend: class fields as i64 (pointer-as-int)
                structLayout = lb + " i64, i64, i64, %SeenString " + rb
                if fieldName == "location" { fieldIndex = 0; fieldType = "i64" }
                if fieldName == "expected" { fieldIndex = 1; fieldType = "i64" }
                if fieldName == "actual" { fieldIndex = 2; fieldType = "i64" }
                if fieldName == "context" { fieldIndex = 3; fieldType = "%SeenString" }
            }
            if structType == "Environment" {
                // Environment { parent: Environment? }
                structLayout = lb + " ptr " + rb
                if fieldName == "parent" {
                    fieldIndex = 0
                    fieldType = "ptr"
                }
            }
            if structType == "BlockNode" {
                // BlockNode { statements: ptr (to Array<StatementNode>) }
                // Arrays are stored as ptr
                structLayout = lb + " ptr " + rb
                if fieldName == "statements" { fieldIndex = 0; fieldType = "ptr" }
            }
            if structType == "StatementNode" {
                // StatementNode { kind, varName, variableType, initializer, expression, condition, thenBranch, elseBranch, loopCondition, loopBody, returnValue }
                // String fields: kind, varName
                // variableType is inline TypeNode, class fields stored as i64
                structLayout = lb + " %SeenString, %SeenString, %TypeNode, i64, i64, i64, i64, i64, i64, i64, i64 " + rb
                if fieldName == "kind" { fieldIndex = 0; fieldType = "%SeenString" }
                if fieldName == "variableName" { fieldIndex = 1; fieldType = "%SeenString" }
                if fieldName == "variableType" { fieldIndex = 2; fieldType = "%TypeNode" }
                if fieldName == "initializer" { fieldIndex = 3; fieldType = "i64" }
                if fieldName == "expression" { fieldIndex = 4; fieldType = "i64" }
                if fieldName == "condition" { fieldIndex = 5; fieldType = "i64" }
                if fieldName == "thenBranch" { fieldIndex = 6; fieldType = "i64" }
                if fieldName == "elseBranch" { fieldIndex = 7; fieldType = "i64" }
                if fieldName == "loopCondition" { fieldIndex = 8; fieldType = "i64" }
                if fieldName == "loopBody" { fieldIndex = 9; fieldType = "i64" }
                if fieldName == "returnValue" { fieldIndex = 10; fieldType = "i64" }
            }
        }

        // Default structLayout if none matched (use simple single-field layout)
        if structLayout == "default" {
            structLayout = lb + " i64 " + rb
        }

        // Generate GEP to field
        let fieldPtrReg = this.getNextReg()
        output.append("  " + fieldPtrReg + " = getelementptr inbounds " + structLayout + ", ptr " + ptrReg + ", i32 0, i32 " + fieldIndex.toString() + "\n")

        // Load the field value
        var resultReg = this.getNextReg()
        output.append("  " + resultReg + " = load " + fieldType + ", ptr " + fieldPtrReg + "\n")

        // NOTE: Array fields return ptr to heap SeenArray (NOT the SeenArray itself)
        // Callers that need the SeenArray value should load it themselves
        // This keeps the return value consistent with the storage type

        // NOTE: Class fields return i64 (pointer-as-int) directly
        // Callers that need to use the value as a pointer (e.g., for method calls)
        // should convert using inttoptr themselves
        // This keeps the return value consistent with the storage type

        return resultReg
    }

    // Helper function to identify array fields (stored as ptr, need dereference to get SeenArray)
    fun isArrayField(structType: String, fieldName: String) r: Bool {
        if structType == "ProgramNode" and fieldName == "items" { return true }
        if structType == "ItemNode" and (fieldName == "importPath" or fieldName == "importSymbols") { return true }
        if structType == "FrontendResult" and fieldName == "diagnostics" { return true }
        if structType == "ImportPathInfo" and fieldName == "segments" { return true }
        if structType == "TypeInferenceResult" and (fieldName == "errors" or fieldName == "warnings") { return true }
        if structType == "FunctionNode" and fieldName == "params" { return true }
        if structType == "ClassNode" and (fieldName == "fields" or fieldName == "methods") { return true }
        if structType == "ParserExpressionNode" and (fieldName == "operands" or fieldName == "arguments") { return true }
        if structType == "FunctionType" and fieldName == "parameters" { return true }
        if structType == "BlockNode" and fieldName == "statements" { return true }
        return false
    }

    // Helper function to identify class fields (stored as i64, need inttoptr conversion)
    fun isClassField(structType: String, fieldName: String) r: Bool {
        if structType == "FrontendResult" and fieldName == "program" { return true }
        if structType == "ItemNode" and (fieldName == "function" or fieldName == "classNode" or fieldName == "enumNode") { return true }
        if structType == "TypeInferenceResult" and (fieldName == "type" or fieldName == "environment") { return true }
        // Note: FunctionNode.returnType is inline data type (TypeNode), not a class
        if structType == "FunctionNode" and fieldName == "body" { return true }
        if structType == "FunctionType" and fieldName == "returnType" { return true }
        if structType == "TypeError" and (fieldName == "location" or fieldName == "expected" or fieldName == "actual") { return true }
        if structType == "StatementNode" and (fieldName == "variableType" or fieldName == "initializer" or fieldName == "expression" or fieldName == "condition" or fieldName == "thenBranch" or fieldName == "elseBranch" or fieldName == "loopCondition" or fieldName == "loopBody" or fieldName == "returnValue") { return true }
        if (structType == "FieldNode" or structType == "ParamNode") and fieldName == "paramType" { return true }
        return false
    }

    // Same as generateFieldAccess but returns the GEP pointer without loading
    // Used for methods like push that need to modify the field in place
    fun generateFieldAccessPtr(ptrReg: String, structType: String, fieldName: String) r: String {
        var fieldIndex = 0
        // Helper vars for building layout strings with braces
        let lb = "{"
        let rb = "}"
        var structLayout = lb + " i64 " + rb  // Default

        // Try registry first
        let structIdx = this.findStruct(structType)
        if structIdx >= 0 {
            structLayout = structLayouts[structIdx]
            let regFieldIdx = this.getFieldInfo(structType, fieldName)
            if regFieldIdx >= 0 {
                fieldIndex = regFieldIdx
            }
        }
        if structType == "LLVMIRGenerator" {
            structLayout = lb + " i64, ptr, i64, i64, ptr, ptr, ptr, i64, ptr, ptr, ptr, ptr, ptr, ptr, ptr, ptr, ptr, ptr, %SeenString, %SeenString, i1, %SeenString, %SeenString, ptr, ptr, %SeenString, ptr, ptr, i1, i1, %SeenString, %SeenString, ptr " + rb
            let idx = this.getLLVMIRGeneratorFieldIndex(fieldName)
            if idx >= 0 {
                fieldIndex = idx
            }
        }

        // Generate GEP to field (without loading)
        let fieldPtrReg = this.getNextReg()
        output.append("  " + fieldPtrReg + " = getelementptr inbounds " + structLayout + ", ptr " + ptrReg + ", i32 0, i32 " + fieldIndex.toString() + "\n")

        return fieldPtrReg
    }

    fun generateStructLiteral(expr: ParserExpressionNode) r: String {
        // Get struct name from literalType
        let structName = expr.literalType

        // Helper vars for building layout strings with braces
        let lb = "{"
        let rb = "}"

        // Try to get layout from registry first
        let structIdx = this.findStruct(structName)
        var structSize = 8  // Default size
        var structLayout = lb + " i64 " + rb  // Default layout

        if structIdx >= 0 {
            // Use registered layout
            structSize = structSizes[structIdx]
            structLayout = structLayouts[structIdx]
        }
        if structIdx < 0 {
            // Fallback to hardcoded layouts for well-known types
            var resolvedLayout = false
            if structName == "FrontendDiagnostic" {
                structSize = 64
                structLayout = lb + " %SeenString, i64, i64, %SeenString, %SeenString " + rb
                resolvedLayout = true
            }
            if not resolvedLayout and structName == "CommandResult" {
                structSize = 24
                structLayout = lb + " i1, %SeenString " + rb
                resolvedLayout = true
            }
            if not resolvedLayout and structName == "Point" {
                structSize = 16
                structLayout = lb + " i64, i64 " + rb
                resolvedLayout = true
            }
            if not resolvedLayout and structName == "Counter" {
                structSize = 8
                structLayout = lb + " i64 " + rb
                resolvedLayout = true
            }
            if not resolvedLayout and structName == "ItemNode" {
                // ItemNode { itemType: String, name: String, visibility: String, importPath: Array<String>, importSymbols: Array<ImportSymbolNode>, function: FunctionNode, classNode: ClassNode, enumNode: EnumNode }
                // Array fields are ptr (8 bytes, pointer to heap-allocated SeenArray), class fields are i64 (pointer-as-int)
                structSize = 88  // %SeenString(16) * 3 + ptr(8) * 2 + i64(8) * 3 = 48 + 16 + 24 = 88
                structLayout = lb + " %SeenString, %SeenString, %SeenString, ptr, ptr, i64, i64, i64 " + rb
                resolvedLayout = true
            }
            if not resolvedLayout and structName == "ImportPathInfo" {
                // ImportPathInfo { text: String, segments: ptr }
                // Array field is ptr to heap-allocated SeenArray
                structSize = 24  // %SeenString(16) + ptr(8) = 24
                structLayout = lb + " %SeenString, ptr " + rb
                resolvedLayout = true
            }
            if not resolvedLayout {
                // Generic struct: estimate based on field count and infer field types from expressions
                let fieldCount = expr.arguments.length()
                structSize = 0
                var layoutFields = ""
                var fieldI = 0
                while fieldI < fieldCount {
                    if fieldI > 0 {
                        layoutFields = layoutFields + ", "
                    }
                    // Infer field type from the expression
                    var inferredFieldType = "i64"
                    if fieldI < expr.arguments.length() {
                        let fieldExpr = expr.arguments[fieldI]
                        if fieldExpr.operands.length() > 0 {
                            let valueExpr = fieldExpr.operands[0]
                            if valueExpr.kind == "Literal" and valueExpr.literalType == "String" {
                                inferredFieldType = "%SeenString"
                                structSize = structSize + 16
                            } else if valueExpr.kind == "Call" and valueExpr.callee.startsWith("Array") {
                                inferredFieldType = "ptr"
                                structSize = structSize + 8
                            } else if valueExpr.kind == "Literal" and valueExpr.literalType == "Bool" {
                                inferredFieldType = "i1"
                                structSize = structSize + 8  // Aligned
                            } else if valueExpr.kind == "StructLiteral" {
                                // Inline data type - use %TypeName if available
                                if valueExpr.literalType != "" {
                                    inferredFieldType = "%" + valueExpr.literalType
                                    structSize = structSize + 24  // Estimate
                                } else {
                                    structSize = structSize + 8
                                }
                            } else {
                                structSize = structSize + 8
                            }
                        } else {
                            structSize = structSize + 8
                        }
                    } else {
                        structSize = structSize + 8
                    }
                    layoutFields = layoutFields + inferredFieldType
                    fieldI = fieldI + 1
                }
                structLayout = lb + " " + layoutFields + " " + rb
                println("[WARN] Unknown struct type '" + structName + "' - using inferred layout: " + structLayout + " size=" + structSize.toString())
            }
        }

        // Allocate memory for struct
        let mallocReg = this.getNextReg()
        // DEBUG: Print struct allocation details
        println("[DEBUG STRUCT] " + structName + " size=" + structSize.toString() + " registry=" + structIdx.toString())
        output.append("  " + mallocReg + " = call ptr @malloc(i64 " + structSize.toString() + ")\n")

        // Store each field
        var fieldIdx = 0
        while fieldIdx < expr.arguments.length() {
            let fieldExpr = expr.arguments[fieldIdx]
            let fieldName = fieldExpr.variableName

            // Generate the field value
            var valueReg = "0"
            if fieldExpr.operands.length() > 0 {
                let savedPendingType = pendingArrayLiteralType
                var fieldSeenType = ""
                if structIdx >= 0 {
                    fieldSeenType = this.getSeenFieldType(structName, fieldName)
                }
                if fieldExpr.operands[0].kind == "ArrayLiteral" and (fieldSeenType.startsWith("Array") or fieldSeenType.startsWith("List")) {
                    pendingArrayLiteralType = fieldSeenType
                }
                output.append("; DEBUG structlit field " + fieldName + " expr.kind=" + fieldExpr.operands[0].kind + " literalValue=" + fieldExpr.operands[0].literalValue + "\n")
                valueReg = this.generateExpression(fieldExpr.operands[0])
                pendingArrayLiteralType = savedPendingType
            }

            // Get field index and type - try registry first, then fallback
            var gepIndex = fieldIdx
            var fieldType = "i64"

            if structIdx >= 0 {
                // Use registry to get field info
                let regFieldIdx = this.getFieldInfo(structName, fieldName)
                if regFieldIdx >= 0 {
                    gepIndex = regFieldIdx
                    fieldType = this.getFieldType(structName, fieldName)
                    output.append("; DEBUG fieldType for " + structName + "." + fieldName + " = " + fieldType + "\n")
                }
            }
            if structIdx < 0 {
                // Fallback to hardcoded field mappings
                var fieldResolved = false
                if structName == "FrontendDiagnostic" and fieldName == "file" {
                    gepIndex = 0
                    fieldType = "%SeenString"
                    fieldResolved = true
                }
                if not fieldResolved and structName == "FrontendDiagnostic" and fieldName == "line" {
                    gepIndex = 1
                    fieldType = "i64"
                    fieldResolved = true
                }
                if not fieldResolved and structName == "FrontendDiagnostic" and fieldName == "column" {
                    gepIndex = 2
                    fieldType = "i64"
                    fieldResolved = true
                }
                if not fieldResolved and structName == "FrontendDiagnostic" and fieldName == "severity" {
                    gepIndex = 3
                    fieldType = "%SeenString"
                    fieldResolved = true
                }
                if not fieldResolved and structName == "FrontendDiagnostic" and fieldName == "message" {
                    gepIndex = 4
                    fieldType = "%SeenString"
                    fieldResolved = true
                }
                if not fieldResolved and structName == "CommandResult" and fieldName == "success" {
                    gepIndex = 0
                    fieldType = "i1"
                    fieldResolved = true
                }
                if not fieldResolved and structName == "CommandResult" and fieldName == "output" {
                    gepIndex = 1
                    fieldType = "%SeenString"
                    fieldResolved = true
                }
                if not fieldResolved and structName == "Point" and fieldName == "x" {
                    gepIndex = 0
                    fieldType = "i64"
                    fieldResolved = true
                }
                if not fieldResolved and structName == "Point" and fieldName == "y" {
                    gepIndex = 1
                    fieldType = "i64"
                    fieldResolved = true
                }
                if not fieldResolved and structName == "ItemNode" and fieldName == "itemType" {
                    gepIndex = 0
                    fieldType = "%SeenString"
                    fieldResolved = true
                }
                if not fieldResolved and structName == "ItemNode" and fieldName == "name" {
                    gepIndex = 1
                    fieldType = "%SeenString"
                    fieldResolved = true
                }
                if not fieldResolved and structName == "ItemNode" and fieldName == "visibility" {
                    gepIndex = 2
                    fieldType = "%SeenString"
                    fieldResolved = true
                }
                if not fieldResolved and structName == "ItemNode" and fieldName == "importPath" {
                    gepIndex = 3
                    fieldType = "ptr"  // Pointer to heap-allocated SeenArray
                    fieldResolved = true
                }
                if not fieldResolved and structName == "ItemNode" and fieldName == "importSymbols" {
                    gepIndex = 4
                    fieldType = "ptr"  // Pointer to heap-allocated SeenArray
                    fieldResolved = true
                }
                if not fieldResolved and structName == "ItemNode" and fieldName == "function" {
                    gepIndex = 5
                    fieldType = "i64"  // Class type stored as pointer-as-int
                    fieldResolved = true
                }
                if not fieldResolved and structName == "ItemNode" and fieldName == "classNode" {
                    gepIndex = 6
                    fieldType = "i64"  // Class type stored as pointer-as-int
                    fieldResolved = true
                }
                if not fieldResolved and structName == "ItemNode" and fieldName == "enumNode" {
                    gepIndex = 7
                    fieldType = "i64"  // Class type stored as pointer-as-int
                    fieldResolved = true
                }
                if not fieldResolved and structName == "ImportPathInfo" and fieldName == "text" {
                    gepIndex = 0
                    fieldType = "%SeenString"
                    fieldResolved = true
                }
                if not fieldResolved and structName == "ImportPathInfo" and fieldName == "segments" {
                    gepIndex = 1
                    fieldType = "ptr"  // Pointer to array, not inline array
                    fieldResolved = true
                }
                // Infer field type from expression if not resolved by hardcoded mappings
                if not fieldResolved and fieldExpr.operands.length() > 0 {
                    let valueExpr = fieldExpr.operands[0]
                    if valueExpr.kind == "Literal" and valueExpr.literalType == "String" {
                        fieldType = "%SeenString"
                        fieldResolved = true
                    }
                    if not fieldResolved and valueExpr.kind == "Literal" and valueExpr.literalType == "Bool" {
                        fieldType = "i1"
                        fieldResolved = true
                    }
                    if not fieldResolved and valueExpr.kind == "Call" and valueExpr.callee.startsWith("Array") {
                        fieldType = "ptr"
                        fieldResolved = true
                    }
                    if not fieldResolved and valueExpr.kind == "StructLiteral" and valueExpr.literalType != "" {
                        fieldType = "%" + valueExpr.literalType
                        fieldResolved = true
                    }
                    if not fieldResolved and valueExpr.kind == "MethodCall" {
                        // For method calls that return data types, infer the type
                        let calleeType = this.inferExpressionType(valueExpr)
                        if this.isDataType(calleeType) {
                            fieldType = "%" + calleeType
                            fieldResolved = true
                        }
                    }
                }
            }

            // Generate GEP to field
            let fieldPtrReg = this.getNextReg()
            output.append("  " + fieldPtrReg + " = getelementptr inbounds " + structLayout + ", ptr " + mallocReg + ", i32 0, i32 " + gepIndex.toString() + "\n")

            // Store the value
            output.append("  store " + fieldType + " " + valueReg + ", ptr " + fieldPtrReg + "\n")

            fieldIdx = fieldIdx + 1
        }

        // Class types are stored as i64 (pointer-as-int), so convert ptr to i64
        if this.isClassType(structName) {
            let i64Reg = this.getNextReg()
            output.append("  " + i64Reg + " = ptrtoint ptr " + mallocReg + " to i64\n")
            return i64Reg
        }

        return mallocReg
    }

    fun generateLiteral(expr: ParserExpressionNode) r: String {
        if expr.literalType == "Int" or expr.literalType == "Integer" {
            // Convert hex values to decimal (LLVM text format doesn't accept hex for integers)
            return this.hexToDecimal(expr.literalValue)
        }
        if expr.literalType == "Char" {
            // Character literal - return the code point as i64
            return this.charToCodeStr(expr.literalValue)
        }
        if expr.literalType == "Bool" or expr.literalType == "Boolean" {
            if expr.literalValue == "true" {
                return "1"
            }
            return "0"
        }
        if expr.literalType == "String" {
            // Find string constant index
            var idx = 0
            var found = false
            while idx < stringConstants.length() {
                if stringConstants[idx] == expr.literalValue {
                    found = true
                    break
                }
                idx = idx + 1
            }

            // Convert to SeenString
            let ptrReg = this.getNextReg()
            let strLen = expr.literalValue.length() + 1
            output.append("  " + ptrReg + " = getelementptr [" + strLen.toString() + " x i8], ptr @.str." + stringConstantPrefix + idx.toString() + ", i64 0, i64 0\n")

            let strReg = this.getNextReg()
            output.append("  " + strReg + " = call %SeenString @seen_cstr_to_str(ptr " + ptrReg + ")\n")
            return strReg
        }
        if expr.literalType == "Float" {
            return expr.literalValue
        }
        return "0"
    }

    fun generateVariable(expr: ParserExpressionNode) r: String {
        var varName = expr.variableName
        if varName == "" {
            // Try literalValue for method call receivers
            varName = expr.literalValue
        }
        if varName == "" {
            return "0"
        }

        let idx = this.findVar(varName)
        if idx < 0 {
            // Variable not found - check if 'this' exists and varName is a field
            let thisIdx = this.findVar("this")
            if thisIdx >= 0 {
                // Try to access as this.fieldName
                let thisReg = varRegs[thisIdx]
                let thisType = varTypes[thisIdx]

                if thisType == "LLVMIRGenerator" {
                    let idxCheck = this.getLLVMIRGeneratorFieldIndex(varName)
                    if idxCheck >= 0 {
                        let thisPtrReg = this.getNextReg()
                        output.append("  " + thisPtrReg + " = load ptr, ptr " + thisReg + "\n")
                        return generateFieldAccess(thisPtrReg, thisType, varName)
                    }
                }

                // Check if this type has the field
                let structIdx = this.findStruct(thisType)
                if structIdx >= 0 {
                    let fieldIdx = this.getFieldInfo(thisType, varName)
                    if fieldIdx >= 0 {
                        // Load 'this' pointer
                        let thisPtrReg = this.getNextReg()
                        output.append("  " + thisPtrReg + " = load ptr, ptr " + thisReg + "\n")
                        // Access the field
                        return generateFieldAccess(thisPtrReg, thisType, varName)
                    }
                }
            }
            return "0"
        }

        let varReg = varRegs[idx]
        let varType = varTypes[idx]
        let llvmType = this.mapType(varType)
        let loadReg = this.getNextReg()
        output.append("  " + loadReg + " = load " + llvmType + ", ptr " + varReg + "\n")
        return loadReg
    }

    fun generateBinary(expr: ParserExpressionNode) r: String {
        let leftExpr = expr.operands[0]
        let rightExpr = expr.operands[1]

        let leftType = this.inferExpressionType(leftExpr)
        let rightType = this.inferExpressionType(rightExpr)

        let leftReg = this.generateExpression(leftExpr)
        let rightReg = this.generateExpression(rightExpr)

        // Note: resultReg must be allocated AFTER any intermediate conversion registers
        // to maintain SSA sequential numbering

        if expr.operator == "+" {
            if leftType == "String" or rightType == "String" or leftType == "Char" or rightType == "Char" {
                // String/Char concatenation - need to convert non-strings to strings first
                var leftStrReg = leftReg
                var rightStrReg = rightReg

                if leftType == "Char" {
                    // Convert Char to String using runtime function
                    leftStrReg = this.getNextReg()
                    output.append("  " + leftStrReg + " = call %SeenString @seen_char_to_str(i64 " + leftReg + ")\n")
                }
                if leftType != "Char" and leftType == "Int" {
                    // Convert Int to String
                    leftStrReg = this.getNextReg()
                    output.append("  " + leftStrReg + " = call %SeenString @seen_int_to_string(i64 " + leftReg + ")\n")
                }

                if rightType == "Char" {
                    // Convert Char to String using runtime function
                    rightStrReg = this.getNextReg()
                    output.append("  " + rightStrReg + " = call %SeenString @seen_char_to_str(i64 " + rightReg + ")\n")
                }
                if rightType != "Char" and rightType == "Int" {
                    // Convert Int to String
                    rightStrReg = this.getNextReg()
                    output.append("  " + rightStrReg + " = call %SeenString @seen_int_to_string(i64 " + rightReg + ")\n")
                }

                let resultReg = this.getNextReg()
                output.append("  " + resultReg + " = call %SeenString @seen_str_concat_ss(%SeenString " + leftStrReg + ", %SeenString " + rightStrReg + ")\n")
                return resultReg
            }
            // Integer addition
            let resultReg = this.getNextReg()
            output.append("  " + resultReg + " = add i64 " + leftReg + ", " + rightReg + "\n")
            return resultReg
        }

        let resultReg = this.getNextReg()
        var opHandled = false
        if expr.operator == "-" {
            output.append("  " + resultReg + " = sub i64 " + leftReg + ", " + rightReg + "\n")
            opHandled = true
        }
        if not opHandled and expr.operator == "*" {
            output.append("  " + resultReg + " = mul i64 " + leftReg + ", " + rightReg + "\n")
            opHandled = true
        }
        if not opHandled and expr.operator == "/" {
            output.append("  " + resultReg + " = sdiv i64 " + leftReg + ", " + rightReg + "\n")
            opHandled = true
        }
        if not opHandled and expr.operator == "%" {
            output.append("  " + resultReg + " = srem i64 " + leftReg + ", " + rightReg + "\n")
            opHandled = true
        }
        if not opHandled and expr.operator == "==" {
            // Handle Char comparisons specially
            if leftType == "Char" or rightType == "Char" {
                // Char comparison - both sides should be i64
                // If comparing Char to single-char string literal, extract char code
                var leftVal = leftReg
                var rightVal = rightReg
                if leftType == "Char" and rightType == "String" and rightExpr.kind == "Literal" and rightExpr.literalValue.length() == 1 {
                    // Convert single-char string to its code point
                    rightVal = this.charToCodeStr(rightExpr.literalValue)
                }
                if rightType == "Char" and leftType == "String" and leftExpr.kind == "Literal" and leftExpr.literalValue.length() == 1 {
                    // Convert single-char string to its code point
                    leftVal = this.charToCodeStr(leftExpr.literalValue)
                }
                output.append("  " + resultReg + " = icmp eq i64 " + leftVal + ", " + rightVal + "\n")
            }
            var eqIsChar = leftType == "Char" or rightType == "Char"
            if not eqIsChar and (leftType == "String" or rightType == "String") {
                // String comparison - use runtime function
                output.append("  " + resultReg + " = call i1 @seen_str_eq_ss(%SeenString " + leftReg + ", %SeenString " + rightReg + ")\n")
            }
            if not eqIsChar and not (leftType == "String" or rightType == "String") {
                // Check if comparing pointer types (enums, classes, optionals)
                let llvmLeftType = this.mapType(leftType)
                if llvmLeftType == "ptr" {
                    // Pointer comparison - use ptr type with null
                    var rightNullVal = rightReg
                    if rightReg == "0" {
                        rightNullVal = "null"
                    }
                    output.append("  " + resultReg + " = icmp eq ptr " + leftReg + ", " + rightNullVal + "\n")
                }
                if llvmLeftType != "ptr" {
                    output.append("  " + resultReg + " = icmp eq i64 " + leftReg + ", " + rightReg + "\n")
                }
            }
            opHandled = true
        }
        if not opHandled and expr.operator == "!=" {
            // Handle Char comparisons specially
            if leftType == "Char" or rightType == "Char" {
                var leftVal = leftReg
                var rightVal = rightReg
                if leftType == "Char" and rightType == "String" and rightExpr.kind == "Literal" and rightExpr.literalValue.length() == 1 {
                    rightVal = this.charToCodeStr(rightExpr.literalValue)
                }
                if rightType == "Char" and leftType == "String" and leftExpr.kind == "Literal" and leftExpr.literalValue.length() == 1 {
                    leftVal = this.charToCodeStr(leftExpr.literalValue)
                }
                output.append("  " + resultReg + " = icmp ne i64 " + leftVal + ", " + rightVal + "\n")
            }
            var neIsChar = leftType == "Char" or rightType == "Char"
            if not neIsChar and (leftType == "String" or rightType == "String") {
                // String comparison - use runtime function
                output.append("  " + resultReg + " = call i1 @seen_str_ne_ss(%SeenString " + leftReg + ", %SeenString " + rightReg + ")\n")
            }
            if not neIsChar and not (leftType == "String" or rightType == "String") {
                // Check if comparing pointer types (enums, classes, optionals)
                let llvmLeftType = this.mapType(leftType)
                if llvmLeftType == "ptr" {
                    // Pointer comparison - use ptr type with null
                    var rightNullVal = rightReg
                    if rightReg == "0" {
                        rightNullVal = "null"
                    }
                    output.append("  " + resultReg + " = icmp ne ptr " + leftReg + ", " + rightNullVal + "\n")
                }
                if llvmLeftType != "ptr" {
                    output.append("  " + resultReg + " = icmp ne i64 " + leftReg + ", " + rightReg + "\n")
                }
            }
            opHandled = true
        }
        if not opHandled and expr.operator == "<" {
            // Handle Char comparisons - if comparing with single-char string, use char code
            var leftVal = leftReg
            var rightVal = rightReg
            if leftType == "Char" and rightType == "String" and rightExpr.kind == "Literal" and rightExpr.literalValue.length() == 1 {
                rightVal = this.charToCodeStr(rightExpr.literalValue)
            }
            if rightType == "Char" and leftType == "String" and leftExpr.kind == "Literal" and leftExpr.literalValue.length() == 1 {
                leftVal = this.charToCodeStr(leftExpr.literalValue)
            }
            // Handle String vs String comparison by extracting first character codes
            if leftType == "String" and rightType == "String" {
                let leftCharReg = this.getNextReg()
                output.append("  " + leftCharReg + " = call i64 @seen_char_at(%SeenString " + leftReg + ", i64 0)\n")
                let rightCharReg = this.getNextReg()
                output.append("  " + rightCharReg + " = call i64 @seen_char_at(%SeenString " + rightReg + ", i64 0)\n")
                let strCmpReg = this.getNextReg()
                output.append("  " + strCmpReg + " = icmp slt i64 " + leftCharReg + ", " + rightCharReg + "\n")
                return strCmpReg
            }
            output.append("  " + resultReg + " = icmp slt i64 " + leftVal + ", " + rightVal + "\n")
            opHandled = true
        }
        if not opHandled and expr.operator == "<=" {
            var leftVal = leftReg
            var rightVal = rightReg
            if leftType == "Char" and rightType == "String" and rightExpr.kind == "Literal" and rightExpr.literalValue.length() == 1 {
                rightVal = this.charToCodeStr(rightExpr.literalValue)
            }
            if rightType == "Char" and leftType == "String" and leftExpr.kind == "Literal" and leftExpr.literalValue.length() == 1 {
                leftVal = this.charToCodeStr(leftExpr.literalValue)
            }
            // Handle String vs String comparison by extracting first character codes
            if leftType == "String" and rightType == "String" {
                let leftCharReg = this.getNextReg()
                output.append("  " + leftCharReg + " = call i64 @seen_char_at(%SeenString " + leftReg + ", i64 0)\n")
                let rightCharReg = this.getNextReg()
                output.append("  " + rightCharReg + " = call i64 @seen_char_at(%SeenString " + rightReg + ", i64 0)\n")
                let strCmpReg = this.getNextReg()
                output.append("  " + strCmpReg + " = icmp sle i64 " + leftCharReg + ", " + rightCharReg + "\n")
                return strCmpReg
            }
            output.append("  " + resultReg + " = icmp sle i64 " + leftVal + ", " + rightVal + "\n")
            opHandled = true
        }
        if not opHandled and expr.operator == ">" {
            var leftVal = leftReg
            var rightVal = rightReg
            if leftType == "Char" and rightType == "String" and rightExpr.kind == "Literal" and rightExpr.literalValue.length() == 1 {
                rightVal = this.charToCodeStr(rightExpr.literalValue)
            }
            if rightType == "Char" and leftType == "String" and leftExpr.kind == "Literal" and leftExpr.literalValue.length() == 1 {
                leftVal = this.charToCodeStr(leftExpr.literalValue)
            }
            // Handle String vs String comparison by extracting first character codes
            if leftType == "String" and rightType == "String" {
                let leftCharReg = this.getNextReg()
                output.append("  " + leftCharReg + " = call i64 @seen_char_at(%SeenString " + leftReg + ", i64 0)\n")
                let rightCharReg = this.getNextReg()
                output.append("  " + rightCharReg + " = call i64 @seen_char_at(%SeenString " + rightReg + ", i64 0)\n")
                let strCmpReg = this.getNextReg()
                output.append("  " + strCmpReg + " = icmp sgt i64 " + leftCharReg + ", " + rightCharReg + "\n")
                return strCmpReg
            }
            output.append("  " + resultReg + " = icmp sgt i64 " + leftVal + ", " + rightVal + "\n")
            opHandled = true
        }
        if not opHandled and expr.operator == ">=" {
            var leftVal = leftReg
            var rightVal = rightReg
            if leftType == "Char" and rightType == "String" and rightExpr.kind == "Literal" and rightExpr.literalValue.length() == 1 {
                rightVal = this.charToCodeStr(rightExpr.literalValue)
            }
            if rightType == "Char" and leftType == "String" and leftExpr.kind == "Literal" and leftExpr.literalValue.length() == 1 {
                leftVal = this.charToCodeStr(leftExpr.literalValue)
            }
            // Handle String vs String comparison by extracting first character codes
            if leftType == "String" and rightType == "String" {
                let leftCharReg = this.getNextReg()
                output.append("  " + leftCharReg + " = call i64 @seen_char_at(%SeenString " + leftReg + ", i64 0)\n")
                let rightCharReg = this.getNextReg()
                output.append("  " + rightCharReg + " = call i64 @seen_char_at(%SeenString " + rightReg + ", i64 0)\n")
                let strCmpReg = this.getNextReg()
                output.append("  " + strCmpReg + " = icmp sge i64 " + leftCharReg + ", " + rightCharReg + "\n")
                return strCmpReg
            }
            output.append("  " + resultReg + " = icmp sge i64 " + leftVal + ", " + rightVal + "\n")
            opHandled = true
        }
        if not opHandled and expr.operator == "and" {
            output.append("  " + resultReg + " = and i1 " + leftReg + ", " + rightReg + "\n")
            opHandled = true
        }
        if not opHandled and expr.operator == "or" {
            output.append("  " + resultReg + " = or i1 " + leftReg + ", " + rightReg + "\n")
        }

        return resultReg
    }

    fun generateCall(expr: ParserExpressionNode) r: String {
        var funcName = expr.callee

        // Debug output for all calls to understand structure
        if funcName.contains(".") or funcName.contains("Generator") {
            println("[DEBUG CALL] callee=" + funcName + " literalValue=" + expr.literalValue + " args=" + expr.arguments.length().toString())
        }

        // Special case: Array<Type>() constructor - creates empty array
        // NOTE: Must check BEFORE stripping generic parameters
        if funcName.startsWith("Array<") or funcName == "Array" {
            // Use runtime functions that return ptr to heap-allocated SeenArray
            let arrReg = this.getNextReg()
            if funcName == "Array<String>" or funcName.startsWith("Array<String") {
                output.append("  " + arrReg + " = call ptr @seen_arr_new_str_ptr()\n")
            } else {
                // Extract element type from Array<ElementType>
                var elementType = ""
                if funcName.startsWith("Array<") and funcName.endsWith(">") {
                    elementType = funcName.substring(6, funcName.length() - 1)
                }
                // Check if element type is a data type (needs correct element_size)
                if this.isDataType(elementType) {
                    // Get the size of the data type
                    let elementSize = this.getDataTypeSize(elementType)
                    output.append("  " + arrReg + " = call ptr @seen_arr_new_with_size_ptr(i64 " + elementSize.toString() + ")\n")
                } else {
                    // Class types are stored as pointers (8 bytes)
                    output.append("  " + arrReg + " = call ptr @seen_arr_new_ptr_ptr()\n")
                }
            }
            return arrReg
        }

        // Check if this is a class constructor call (e.g., Expr() creates new Expr instance)
        if this.isClassType(funcName) {
            // Generate inline constructor: malloc + initialize fields + return pointer-as-int
            let structIdx = this.findStruct(funcName)
            let ptrReg = this.getNextReg()

            // Get struct size - use getDataTypeSize if we have field info, otherwise default
            var structSize = 8
            if structIdx >= 0 {
                // Use the registered struct size
                structSize = structSizes[structIdx]
                if structSize == 0 {
                    structSize = 16  // Default minimum for a class with at least one field
                }
            }

            // Allocate memory for the object
            output.append("  " + ptrReg + " = call ptr @malloc(i64 " + structSize.toString() + ")\n")

            // Initialize fields to default values
            if structIdx >= 0 {
                let fieldNamesStr = structFieldNames[structIdx]
                let fieldTypesStr = structFieldTypes[structIdx]

                // Parse field names and types
                var fieldIdx = 0
                var fieldStart = 0
                var typeStart = 0
                var charIdx = 0

                while charIdx <= fieldNamesStr.length() {
                    let atEnd = charIdx == fieldNamesStr.length()
                    let isSep = not atEnd and fieldNamesStr.substring(charIdx, charIdx + 1) == ","

                    if isSep or atEnd {
                        let fieldName = fieldNamesStr.substring(fieldStart, charIdx)

                        // Find corresponding type
                        var typeCharIdx = 0
                        var typeFieldIdx = 0
                        var typeFieldStart = 0
                        var fieldType = ""
                        while typeCharIdx <= fieldTypesStr.length() and fieldType == "" {
                            let typeAtEnd = typeCharIdx == fieldTypesStr.length()
                            let typeIsSep = not typeAtEnd and fieldTypesStr.substring(typeCharIdx, typeCharIdx + 1) == "|"

                            if typeIsSep or typeAtEnd {
                                if typeFieldIdx == fieldIdx {
                                    fieldType = fieldTypesStr.substring(typeFieldStart, typeCharIdx)
                                }
                                typeFieldIdx = typeFieldIdx + 1
                                typeFieldStart = typeCharIdx + 1
                            }
                            typeCharIdx = typeCharIdx + 1
                        }

                        // Initialize field based on type
                        if fieldType == "String" {
                            // String fields: store empty SeenString { 0, null }
                            let fieldPtrReg = this.getNextReg()
                            output.append("  " + fieldPtrReg + " = getelementptr inbounds %" + funcName + ", ptr " + ptrReg + ", i32 0, i32 " + fieldIdx.toString() + "\n")
                            output.append("  store %SeenString { i64 0, ptr null }, ptr " + fieldPtrReg + "\n")
                        } else if fieldType == "Int" or fieldType == "Char" {
                            // Int/Char fields: store 0
                            let fieldPtrReg = this.getNextReg()
                            output.append("  " + fieldPtrReg + " = getelementptr inbounds %" + funcName + ", ptr " + ptrReg + ", i32 0, i32 " + fieldIdx.toString() + "\n")
                            output.append("  store i64 0, ptr " + fieldPtrReg + "\n")
                        } else if fieldType == "Bool" {
                            // Bool fields: store false
                            let fieldPtrReg = this.getNextReg()
                            output.append("  " + fieldPtrReg + " = getelementptr inbounds %" + funcName + ", ptr " + ptrReg + ", i32 0, i32 " + fieldIdx.toString() + "\n")
                            output.append("  store i1 false, ptr " + fieldPtrReg + "\n")
                        } else if fieldType.startsWith("Array<") {
                            // Array fields: store null pointer (will be initialized separately)
                            let fieldPtrReg = this.getNextReg()
                            output.append("  " + fieldPtrReg + " = getelementptr inbounds %" + funcName + ", ptr " + ptrReg + ", i32 0, i32 " + fieldIdx.toString() + "\n")
                            output.append("  store ptr null, ptr " + fieldPtrReg + "\n")
                        } else {
                            // Other types (class pointers): store 0
                            let fieldPtrReg = this.getNextReg()
                            output.append("  " + fieldPtrReg + " = getelementptr inbounds %" + funcName + ", ptr " + ptrReg + ", i32 0, i32 " + fieldIdx.toString() + "\n")
                            output.append("  store i64 0, ptr " + fieldPtrReg + "\n")
                        }

                        fieldStart = charIdx + 1
                        fieldIdx = fieldIdx + 1
                    }
                    charIdx = charIdx + 1
                }
            }

            // Convert pointer to i64 (class types are stored as pointer-as-int)
            let intReg = this.getNextReg()
            output.append("  " + intReg + " = ptrtoint ptr " + ptrReg + " to i64\n")
            return intReg
        }

        // Strip generic parameters from function name (e.g., "Err<String, String>" -> "Err")
        if funcName.contains("<") {
            var ltIdx = 0
            var scanIdx = 0
            while scanIdx < funcName.length() {
                if funcName.substring(scanIdx, scanIdx + 1) == "<" {
                    ltIdx = scanIdx
                    scanIdx = funcName.length()
                }
                scanIdx = scanIdx + 1
            }
            if ltIdx > 0 {
                funcName = funcName.substring(0, ltIdx)
            }
        }

        // Special case: super() parent constructor call - no-op for now
        // (inheritance not fully supported in Stage1 IR generator)
        if funcName == "super" or funcName == "" {
            // Just evaluate arguments for side effects, but don't generate a call
            var i = 0
            while i < expr.arguments.length() {
                generateExpression(expr.arguments[i])
                i = i + 1
            }
            return "0"  // super() returns nothing meaningful
        }

        // Special case: println
        if funcName == "println" {
            if expr.arguments.length() > 0 {
                let argReg = this.generateExpression(expr.arguments[0])
                output.append("  call void @println(%SeenString " + argReg + ")\n")
            }
            return "0"
        }

        // Special case: readText
        if funcName == "readText" {
            if expr.arguments.length() > 0 {
                let argReg = this.generateExpression(expr.arguments[0])
                let resultReg = this.getNextReg()
                output.append("  " + resultReg + " = call %SeenString @readText(%SeenString " + argReg + ")\n")
                return resultReg
            }
            return "0"
        }

        // Special case: writeText
        if funcName == "writeText" {
            if expr.arguments.length() >= 2 {
                let pathReg = this.generateExpression(expr.arguments[0])
                let contentReg = this.generateExpression(expr.arguments[1])
                let resultReg = this.getNextReg()
                output.append("  " + resultReg + " = call i1 @writeText(%SeenString " + pathReg + ", %SeenString " + contentReg + ")\n")
                return resultReg
            }
            return "0"
        }

        // Special case: args() uses sret for struct > 16 bytes
        if funcName == "args" {
            let resultReg = this.getNextReg()
            output.append("  " + resultReg + " = alloca %SeenArray, align 8\n")
            output.append("  call void @args(ptr sret(%SeenArray) align 8 " + resultReg + ")\n")
            // Return pointer to the alloca (arrays are stored as ptr)
            return resultReg
        }

        // Check if this is a method call on the current class (implicit this)
        // This handles calls like foo(x) inside a class method when foo is a method of the same class
        let thisIdx = this.findVar("this")
        if thisIdx >= 0 {
            let thisType = varTypes[thisIdx]

            // Special handling for misplaced RealParser class methods
            // These methods were incorrectly parsed as standalone functions but should be class methods
            let isMisplacedMethod = funcName == "isAtEnd" or funcName == "peek" or funcName == "peekTokenType" or funcName == "peekTokenTypeStr" or funcName == "previous" or funcName == "advance" or funcName == "consume" or funcName == "checkToken" or funcName == "matchTokenStr" or funcName == "skipExpression" or funcName == "toArray" or funcName == "parseExpressionStatement" or funcName == "parseReturnStatement" or funcName == "parseIfStatement" or funcName == "parseWhileStatement" or funcName == "parseLetStatement" or funcName == "parseVarStatement" or funcName == "parseStatement" or funcName == "parseExpression" or funcName == "parseAssignment" or funcName == "parseOr" or funcName == "parseAnd" or funcName == "parseEquality" or funcName == "parseComparison" or funcName == "parseTerm" or funcName == "parseFactor" or funcName == "parseUnary" or funcName == "parseCall" or funcName == "parsePrimary" or funcName == "parseBlock" or funcName == "parseParam" or funcName == "parseTypeNode" or funcName == "parseOptionalTypeAnnotation" or funcName == "parseOptionalReturnType" or funcName == "parseImportPath" or funcName == "parseImportSymbols" or funcName == "parseParameterList" or funcName == "parseFunctionItem" or funcName == "parseClassItem" or funcName == "parseEnumItem" or funcName == "parseImportItem" or funcName == "makeImportSymbol" or funcName == "inferVisibility" or funcName == "joinSegments" or funcName == "parseExpressionStatementByIdx" or funcName == "parseReturnStatementByIdx" or funcName == "parseIfStatementByIdx" or funcName == "parseWhileStatementByIdx" or funcName == "parseLetStatementByIdx" or funcName == "parseVarStatementByIdx" or funcName == "parseStatementInto" or funcName == "parseExpressionStatementInto" or funcName == "parseReturnStatementInto" or funcName == "parseIfStatementInto" or funcName == "parseWhileStatementInto" or funcName == "parseLetStatementInto" or funcName == "parseVarStatementInto" or funcName == "parseExpressionInto" or funcName == "parseExpressionIntoField" or funcName == "parseLetStatementField" or funcName == "parseVarStatementField" or funcName == "parseReturnStatementField" or funcName == "parseIfStatementField" or funcName == "parseWhileStatementField" or funcName == "parseExpressionStatementField" or funcName == "parseParameterListField" or funcName == "parseFunctionItemInto" or funcName == "parseClassItemInto" or funcName == "parseEnumItemInto" or funcName == "parseImportItemInto"
            if isMisplacedMethod and thisType == "RealParser" {
                // Generate call to the class method version
                let thisReg = varRegs[thisIdx]
                var argRegs = Array<String>()
                var argTypeStrs = Array<String>()
                var argIdx = 0
                while argIdx < expr.arguments.length() {
                    let argReg = this.generateExpression(expr.arguments[argIdx])
                    let argType = this.inferExpressionType(expr.arguments[argIdx])
                    // Data type arguments: store to alloca and pass pointer (ABI compat)
                    if this.isDataType(argType) {
                        let llvmType = this.mapType(argType)
                        let allocaReg = this.getNextReg()
                        output.append("  " + allocaReg + " = alloca " + llvmType + "\n")
                        output.append("  store " + llvmType + " " + argReg + ", ptr " + allocaReg + "\n")
                        argRegs.push(allocaReg)
                        argTypeStrs.push("ptr")
                    } else {
                        argRegs.push(argReg)
                        argTypeStrs.push(this.mapType(argType))
                    }
                    argIdx = argIdx + 1
                }

                // Determine return type for misplaced methods
                var misplacedRetType = "ptr"
                var misplacedResolved = false
                if funcName == "isAtEnd" or funcName == "checkToken" or funcName == "matchTokenStr" {
                    misplacedRetType = "i1"
                    misplacedResolved = true
                }
                // Token-returning methods: consume, advance, peek, previous return Token (class type stored as i64)
                if not misplacedResolved and (funcName == "consume" or funcName == "advance" or funcName == "peek" or funcName == "previous") {
                    misplacedRetType = "i64"
                    misplacedResolved = true
                }
                if not misplacedResolved and funcName == "peekTokenType" {
                    misplacedRetType = "i64"
                    misplacedResolved = true
                }
                if not misplacedResolved and (funcName == "peekTokenTypeStr" or funcName == "inferVisibility" or funcName == "joinSegments") {
                    misplacedRetType = "%SeenString"
                    misplacedResolved = true
                }
                if not misplacedResolved and funcName == "parseParameterList" {
                    // parseParameterList returns Void (use i64 for void-like)
                    misplacedRetType = "i64"
                    misplacedResolved = true
                }
                if not misplacedResolved and funcName == "parseImportSymbols" {
                    misplacedRetType = "ptr"  // Array returned as pointer
                    misplacedResolved = true
                }
                // Parse methods returning class types (stored as i64)
                if not misplacedResolved and funcName == "parseBlock" {
                    misplacedRetType = "i64"  // BlockNode is a class type
                    misplacedResolved = true
                }
                // Parse methods returning data types (inline structs)
                if not misplacedResolved and (funcName == "parseOptionalReturnType" or funcName == "parseOptionalTypeAnnotation" or funcName == "parseTypeNode") {
                    misplacedRetType = "%TypeNode"  // TypeNode is a data type
                    misplacedResolved = true
                }
                if not misplacedResolved and funcName == "parseParam" {
                    misplacedRetType = "%ParamNode"  // ParamNode is a data type
                    misplacedResolved = true
                }
                if not misplacedResolved and (funcName == "parsePrimary" or funcName == "parseCall" or funcName == "parseUnary" or funcName == "parseFactor" or funcName == "parseTerm" or funcName == "parseComparison" or funcName == "parseEquality" or funcName == "parseAnd" or funcName == "parseOr" or funcName == "parseAssignment" or funcName == "parseExpression") {
                    misplacedRetType = "i64"  // ParserExpressionNode
                    misplacedResolved = true
                }
                if not misplacedResolved and (funcName == "parseStatement" or funcName == "parseIfStatement" or funcName == "parseWhileStatement" or funcName == "parseLetStatement" or funcName == "parseVarStatement" or funcName == "parseExpressionStatement" or funcName == "parseReturnStatement") {
                    misplacedRetType = "i64"  // StatementNode
                    misplacedResolved = true
                }
                if not misplacedResolved and (funcName == "parseFunctionItem" or funcName == "parseClassItem" or funcName == "parseEnumItem" or funcName == "parseImportItem") {
                    misplacedRetType = "%ItemNode"  // ItemNode is a data type
                    misplacedResolved = true
                }
                if not misplacedResolved and funcName == "makeImportSymbol" {
                    misplacedRetType = "%ImportSymbolNode"  // ImportSymbolNode is a data type
                    misplacedResolved = true
                }
                if not misplacedResolved and funcName == "parseImportPath" {
                    misplacedRetType = "%ImportPathInfo"  // ImportPathInfo is a data type
                    misplacedResolved = true
                }

                let methodFuncName = thisType + "_" + funcName

                // Load this pointer
                let thisPtrReg = this.getNextReg()
                output.append("  " + thisPtrReg + " = load ptr, ptr " + thisReg + "\n")

                if misplacedRetType == "void" {
                    output.append("  call void @" + methodFuncName + "(ptr " + thisPtrReg)
                    argIdx = 0
                    while argIdx < argRegs.length() {
                        output.append(", " + argTypeStrs[argIdx] + " " + argRegs[argIdx])
                        argIdx = argIdx + 1
                    }
                    output.append(")\n")
                    return "0"
                }
                if misplacedRetType != "void" {
                    let resultReg = this.getNextReg()
                    output.append("  " + resultReg + " = call " + misplacedRetType + " @" + methodFuncName + "(ptr " + thisPtrReg)
                    argIdx = 0
                    while argIdx < argRegs.length() {
                        output.append(", " + argTypeStrs[argIdx] + " " + argRegs[argIdx])
                        argIdx = argIdx + 1
                    }
                    output.append(")\n")
                    return resultReg
                }
            }

            // Check if the function is a method of the current class
            let methodRetType = this.getMethodReturnType(thisType, funcName)
            if methodRetType != "" {
                // This is an implicit this.method() call
                let thisReg = varRegs[thisIdx]
                var argRegs = Array<String>()
                var argTypeStrs = Array<String>()
                var argIdx = 0
                while argIdx < expr.arguments.length() {
                    let argReg = this.generateExpression(expr.arguments[argIdx])
                    let argType = this.inferExpressionType(expr.arguments[argIdx])
                    // Data type arguments: store to alloca and pass pointer (ABI compat)
                    if this.isDataType(argType) {
                        let llvmType = this.mapType(argType)
                        let allocaReg = this.getNextReg()
                        output.append("  " + allocaReg + " = alloca " + llvmType + "\n")
                        output.append("  store " + llvmType + " " + argReg + ", ptr " + allocaReg + "\n")
                        argRegs.push(allocaReg)
                        argTypeStrs.push("ptr")
                    } else {
                        argRegs.push(argReg)
                        argTypeStrs.push(this.mapType(argType))
                    }
                    argIdx = argIdx + 1
                }

                let methodFuncName = thisType + "_" + funcName
                let llvmReturnType = this.mapType(methodRetType)

                // Load this pointer
                let thisPtrReg = this.getNextReg()
                output.append("  " + thisPtrReg + " = load ptr, ptr " + thisReg + "\n")

                if llvmReturnType == "void" {
                    output.append("  call void @" + methodFuncName + "(ptr " + thisPtrReg)
                    argIdx = 0
                    while argIdx < argRegs.length() {
                        output.append(", " + argTypeStrs[argIdx] + " " + argRegs[argIdx])
                        argIdx = argIdx + 1
                    }
                    output.append(")\n")
                    return "0"
                }

                let resultReg = this.getNextReg()
                output.append("  " + resultReg + " = call " + llvmReturnType + " @" + methodFuncName + "(ptr " + thisPtrReg)
                argIdx = 0
                while argIdx < argRegs.length() {
                    output.append(", " + argTypeStrs[argIdx] + " " + argRegs[argIdx])
                    argIdx = argIdx + 1
                }
                output.append(")\n")
                return resultReg
            }
        }

        // Special handling for __ExecuteCommand - it returns ptr (pointer to CommandResult)
        // that must be dereferenced to get the actual struct
        if funcName == "__ExecuteCommand" {
            // Generate argument
            var argReg = ""
            if expr.arguments.length() > 0 {
                argReg = this.generateExpression(expr.arguments[0])
            }
            // Call __ExecuteCommand which returns ptr
            let ptrReg = this.getNextReg()
            output.append("  " + ptrReg + " = call ptr @__ExecuteCommand(%SeenString " + argReg + ")\n")
            // Load the CommandResult struct from the pointer
            let structReg = this.getNextReg()
            output.append("  " + structReg + " = load %CommandResult, ptr " + ptrReg + "\n")
            return structReg
        }

        // Generic function call - generate args first, then result reg
        var argRegs = Array<String>()
        var argTypeStrs = Array<String>()
        var argIdx = 0
        while argIdx < expr.arguments.length() {
            let argReg = this.generateExpression(expr.arguments[argIdx])
            let argType = this.inferExpressionType(expr.arguments[argIdx])
            // Data type arguments: store to alloca and pass pointer (ABI compat)
            if this.isDataType(argType) {
                let llvmType = this.mapType(argType)
                let allocaReg = this.getNextReg()
                output.append("  " + allocaReg + " = alloca " + llvmType + "\n")
                output.append("  store " + llvmType + " " + argReg + ", ptr " + allocaReg + "\n")
                argRegs.push(allocaReg)
                argTypeStrs.push("ptr")
            } else {
                argRegs.push(argReg)
                argTypeStrs.push(this.mapType(argType))
            }
            argIdx = argIdx + 1
        }

        // Infer return type from function name
        let returnType = this.inferExpressionType(expr)
        let llvmReturnType = this.mapType(returnType)

        // For void functions, don't assign result
        if llvmReturnType == "void" {
            output.append("  call void @" + funcName + "(")

            argIdx = 0
            while argIdx < argRegs.length() {
                if argIdx > 0 {
                    output.append(", ")
                }
                output.append(argTypeStrs[argIdx] + " " + argRegs[argIdx])
                argIdx = argIdx + 1
            }

            output.append(")\n")
            return "0"  // No result for void functions
        }

        let resultReg = this.getNextReg()
        output.append("  " + resultReg + " = call " + llvmReturnType + " @" + funcName + "(")

        argIdx = 0
        while argIdx < argRegs.length() {
            if argIdx > 0 {
                output.append(", ")
            }
            output.append(argTypeStrs[argIdx] + " " + argRegs[argIdx])
            argIdx = argIdx + 1
        }

        output.append(")\n")
        return resultReg
    }

    fun generateMethodCall(expr: ParserExpressionNode) r: String {
        let methodName = expr.callee
        if methodName == "unwrap" or methodName == "unwrapErr" or methodName == "isOk" or methodName == "isOkay" or methodName == "writeContent" or methodName == "closeFile" or methodName == "readContent" {
            println("[DEBUG METHOD] name=" + methodName + " literalValue=" + expr.literalValue + " operands=" + expr.operands.length().toString())
        }
        // Get receiver
        var receiverReg = ""
        var receiverType = "String"  // Default assumption for method calls

        if expr.operands.length() > 0 {
            // Complex receiver (e.g., chained method call or expression)
            receiverReg = this.generateExpression(expr.operands[0])
            receiverType = this.inferExpressionType(expr.operands[0])
        }
        if expr.operands.length() == 0 and expr.literalValue.contains(".") {
            // Check for enum method calls like SeenTokenType.RightBrace.toString()
            let path = expr.literalValue

            // Find the dot index manually
            var dotIdx = 0
            var searchIdx = 0
            while searchIdx < path.length() {
                if path.substring(searchIdx, searchIdx + 1) == "." {
                    dotIdx = searchIdx
                    searchIdx = path.length()  // Exit loop
                }
                searchIdx = searchIdx + 1
            }

            let varName = path.substring(0, dotIdx)
            let fieldName = path.substring(dotIdx + 1, path.length())

            // Handle enum method calls: SeenTokenType.RightBrace.toString()
            var handledEnumMethod = false
            if varName == "SeenTokenType" {
                // Get the enum value as an integer
                let enumValue = this.getSeenTokenTypeValue(fieldName)
                receiverReg = enumValue.toString()
                receiverType = "Int"  // Enum values are integers
                // Continue to method call generation below (skip field access code)
                handledEnumMethod = true
            }
            if not handledEnumMethod {
                // Chained field access like diag.line.toString()
                // literalValue = "diag.line", callee = "toString"
                // Need to parse and load the field
                let idx = this.findVar(varName)
                var varFoundInLocalScope = false
                if idx >= 0 {
                varFoundInLocalScope = true
                let varReg = varRegs[idx]
                let varType = varTypes[idx]

                // Load the struct - class types are stored as i64, data types are inline
                var ptrReg = ""
                if this.isClassType(varType) {
                    let loadReg = this.getNextReg()
                    output.append("  " + loadReg + " = load i64, ptr " + varReg + "\n")
                    ptrReg = this.getNextReg()
                    output.append("  " + ptrReg + " = inttoptr i64 " + loadReg + " to ptr\n")
                } else if this.isDataType(varType) {
                    // Data types are stored inline - use the alloca pointer directly
                    ptrReg = varReg
                } else {
                    ptrReg = this.getNextReg()
                    output.append("  " + ptrReg + " = load ptr, ptr " + varReg + "\n")
                }

                // Generate field access
                receiverReg = this.generateFieldAccess(ptrReg, varType, fieldName)

                // Infer receiver type from field - handle chained field names
                // Use endsWith checks to avoid substring memory corruption issues
                var fieldTypeResolved = false
                if fieldName.endsWith(".items") or fieldName == "items" {
                    receiverType = "Array<ItemNode>"
                    fieldTypeResolved = true
                }
                if not fieldTypeResolved and (fieldName.endsWith(".diagnostics") or fieldName == "diagnostics") {
                    receiverType = "Array<FrontendDiagnostic>"
                    fieldTypeResolved = true
                }
                if not fieldTypeResolved and (fieldName.endsWith(".importPath") or fieldName == "importPath") {
                    receiverType = "Array<String>"
                    fieldTypeResolved = true
                }
                if not fieldTypeResolved and (fieldName.endsWith(".line") or fieldName == "line" or fieldName.endsWith(".column") or fieldName == "column") {
                    receiverType = "Int"
                    fieldTypeResolved = true
                }
                if not fieldTypeResolved and (fieldName.endsWith(".severity") or fieldName == "severity" or fieldName.endsWith(".message") or fieldName == "message" or fieldName.endsWith(".file") or fieldName == "file" or fieldName.endsWith(".output") or fieldName == "output") {
                    receiverType = "String"
                    fieldTypeResolved = true
                }
                if not fieldTypeResolved and (fieldName.endsWith(".program") or fieldName == "program") {
                    receiverType = "ProgramNode"
                    fieldTypeResolved = true
                }
                if not fieldTypeResolved and (fieldName.endsWith(".function") or fieldName == "function") {
                    receiverType = "FunctionNode"
                    fieldTypeResolved = true
                }
                if not fieldTypeResolved and (fieldName.endsWith(".classNode") or fieldName == "classNode") {
                    receiverType = "ClassNode"
                    fieldTypeResolved = true
                }
                if not fieldTypeResolved and (fieldName.endsWith(".methods") or fieldName == "methods") {
                    receiverType = "Array<FunctionNode>"
                    fieldTypeResolved = true
                }
                if not fieldTypeResolved and (fieldName.endsWith(".params") or fieldName == "params") {
                    receiverType = "Array<ParamNode>"
                    fieldTypeResolved = true
                }
                if not fieldTypeResolved and (fieldName.endsWith(".fields") or fieldName == "fields") {
                    receiverType = "Array<ParamNode>"
                    fieldTypeResolved = true
                }
                if not fieldTypeResolved and (fieldName.endsWith(".itemType") or fieldName == "itemType") {
                    receiverType = "String"
                    fieldTypeResolved = true
                }
                if not fieldTypeResolved and (fieldName.endsWith(".statements") or fieldName == "statements") {
                    receiverType = "Array<StatementNode>"
                    fieldTypeResolved = true
                }
                if not fieldTypeResolved and (fieldName.endsWith(".operands") or fieldName == "operands" or fieldName.endsWith(".arguments") or fieldName == "arguments") {
                    receiverType = "Array<ParserExpressionNode>"
                    fieldTypeResolved = true
                }
                if not fieldTypeResolved and (fieldName.endsWith(".errors") or fieldName == "errors") {
                    receiverType = "Array<TypeError>"
                    fieldTypeResolved = true
                }
                if not fieldTypeResolved and (fieldName.endsWith(".warnings") or fieldName == "warnings") {
                    receiverType = "Array<String>"
                    fieldTypeResolved = true
                }
                if not fieldTypeResolved and fieldName.contains(".") {
                    // Handle chained field names by walking through types
                    var currentType = varType
                    var remainingPath = fieldName
                    while remainingPath.length() > 0 and currentType != "" and currentType != "Int" {
                        var nextDot = -1
                        var searchIdx = 0
                        while searchIdx < remainingPath.length() {
                            if remainingPath.substring(searchIdx, searchIdx + 1) == "." {
                                nextDot = searchIdx
                                searchIdx = remainingPath.length()
                            }
                            searchIdx = searchIdx + 1
                        }
                        var currField = ""
                        if nextDot < 0 {
                            currField = remainingPath
                            remainingPath = ""
                        }
                        if nextDot >= 0 {
                            currField = remainingPath.substring(0, nextDot)
                            remainingPath = remainingPath.substring(nextDot + 1, remainingPath.length())
                        }
                        currentType = this.getSeenFieldType(currentType, currField)
                    }
                    receiverType = currentType
                    fieldTypeResolved = true
                }
                if not fieldTypeResolved {
                    receiverType = this.getSeenFieldType(varType, fieldName)
                }
            }
            if not varFoundInLocalScope {
                // varName is not a local variable - check if it's a field on 'this'
                let thisIdx = this.findVar("this")
                if thisIdx >= 0 {
                    let thisReg = varRegs[thisIdx]
                    let thisType = varTypes[thisIdx]

                    // Check if this type has the field
                    let structIdx = this.findStruct(thisType)
                    output.append("; DEBUG chainedFieldAccess: varName=" + varName + " fieldName=" + fieldName + " thisType=" + thisType + " structIdx=" + structIdx.toString() + "\n")
                    if structIdx >= 0 {
                        let fieldIdx = this.getFieldInfo(thisType, varName)
                        output.append("; DEBUG chainedFieldAccess: fieldIdx=" + fieldIdx.toString() + "\n")
                        if fieldIdx >= 0 {
                            // Load 'this' pointer
                            let thisPtrReg = this.getNextReg()
                            output.append("  " + thisPtrReg + " = load ptr, ptr " + thisReg + "\n")

                            // Get the type of the first field (varName)
                            let firstFieldType = this.getSeenFieldType(thisType, varName)
                            output.append("; DEBUG chainedFieldAccess: firstFieldType=" + firstFieldType + "\n")

                            // Resolve pointer to the first field (class -> i64 to ptr, data -> field pointer)
                            var accessFieldReg = ""
                            if this.isClassType(firstFieldType) {
                                let firstFieldReg = this.generateFieldAccess(thisPtrReg, thisType, varName)
                                let ptrConvReg = this.getNextReg()
                                output.append("  " + ptrConvReg + " = inttoptr i64 " + firstFieldReg + " to ptr\n")
                                accessFieldReg = ptrConvReg
                            } else {
                                accessFieldReg = this.generateFieldAccessPtr(thisPtrReg, thisType, varName)
                            }

                            // Now access the chained field(s) from this first field (e.g., items from currentProgram)
                            receiverReg = this.generateFieldAccess(accessFieldReg, firstFieldType, fieldName)

                            // Infer receiver type from fieldName
                            var chainedFieldTypeResolved = false
                            if fieldName.endsWith(".items") or fieldName == "items" {
                                receiverType = "Array<ItemNode>"
                                chainedFieldTypeResolved = true
                            }
                            if not chainedFieldTypeResolved and (fieldName.endsWith(".diagnostics") or fieldName == "diagnostics") {
                                receiverType = "Array<FrontendDiagnostic>"
                                chainedFieldTypeResolved = true
                            }
                            if not chainedFieldTypeResolved and (fieldName.endsWith(".statements") or fieldName == "statements") {
                                receiverType = "Array<StatementNode>"
                                chainedFieldTypeResolved = true
                            }
                            if not chainedFieldTypeResolved and (fieldName.endsWith(".methods") or fieldName == "methods") {
                                receiverType = "Array<FunctionNode>"
                                chainedFieldTypeResolved = true
                            }
                            if not chainedFieldTypeResolved and (fieldName.endsWith(".params") or fieldName == "params") {
                                receiverType = "Array<ParamNode>"
                                chainedFieldTypeResolved = true
                            }
                            if not chainedFieldTypeResolved and (fieldName.endsWith(".fields") or fieldName == "fields") {
                                receiverType = "Array<ParamNode>"
                                chainedFieldTypeResolved = true
                            }
                            if not chainedFieldTypeResolved and (fieldName.endsWith(".operands") or fieldName == "operands" or fieldName.endsWith(".arguments") or fieldName == "arguments") {
                                receiverType = "Array<ParserExpressionNode>"
                                chainedFieldTypeResolved = true
                            }
                            if not chainedFieldTypeResolved {
                                receiverType = this.getSeenFieldType(firstFieldType, fieldName)
                            }
                            output.append("; DEBUG chainedFieldAccess: receiverType=" + receiverType + " receiverReg=" + receiverReg + "\n")
                        }
                    }
                }
                }
            }
        }
        if not (expr.operands.length() == 0 and expr.literalValue.contains(".")) and expr.literalValue != "" {
            // Simple variable receiver stored in literalValue
            let varName = expr.literalValue
            let idx = this.findVar(varName)
            var varFoundInMethodCall = false
            if idx >= 0 {
                varFoundInMethodCall = true
                let varReg = varRegs[idx]
                let varType = varTypes[idx]
                let llvmType = this.mapType(varType)
                receiverReg = this.getNextReg()
                receiverType = varType
                output.append("  " + receiverReg + " = load " + llvmType + ", ptr " + varReg + "\n")
            }
            if not varFoundInMethodCall {
                // Variable not found - check if 'this' exists and varName is a field
                let thisIdx = this.findVar("this")
                if thisIdx >= 0 {
                    let thisReg = varRegs[thisIdx]
                    let thisType = varTypes[thisIdx]

                    if thisType == "LLVMIRGenerator" {
                        let idxCheck = this.getLLVMIRGeneratorFieldIndex(varName)
                        if idxCheck >= 0 {
                            let thisPtrReg = this.getNextReg()
                            output.append("  " + thisPtrReg + " = load ptr, ptr " + thisReg + "\n")
                            receiverReg = this.generateFieldAccess(thisPtrReg, thisType, varName)
                            receiverType = this.getSeenFieldType(thisType, varName)
                        }
                    }

                    // Check if this type has the field
                    let structIdx = this.findStruct(thisType)
                    output.append("; DEBUG methodCall: varName=" + varName + " thisType=" + thisType + " structIdx=" + structIdx.toString() + "\n")
                    if structIdx >= 0 {
                        let fieldIdx = this.getFieldInfo(thisType, varName)
                        output.append("; DEBUG fieldIdx=" + fieldIdx.toString() + "\n")
                        if fieldIdx >= 0 {
                            // Load 'this' pointer
                            let thisPtrReg = this.getNextReg()
                            output.append("  " + thisPtrReg + " = load ptr, ptr " + thisReg + "\n")
                            // Access the field
                            receiverReg = this.generateFieldAccess(thisPtrReg, thisType, varName)
                            output.append("; DEBUG after generateFieldAccess: receiverReg=" + receiverReg + "\n")
                            // Infer receiver type from field
                            receiverType = this.getSeenFieldType(thisType, varName)
                            output.append("; DEBUG receiverType=" + receiverType + "\n")
                        }
                    }
                    if structIdx < 0 {
                        // Fallback: hardcoded field access for well-known fields
                        // SeenLexer.keywordManager is at index 4
                        output.append("; DEBUG: thisType=" + thisType + " varName=" + varName + "\n")
                        if thisType == "SeenLexer" and varName == "keywordManager" {
                            output.append("; DEBUG: Matched SeenLexer.keywordManager!\n")
                            let thisPtrReg = this.getNextReg()
                            output.append("  " + thisPtrReg + " = load ptr, ptr " + thisReg + "\n")
                            let gepReg = this.getNextReg()
                            output.append("  " + gepReg + " = getelementptr inbounds { %SeenString, i64, %SeenString, i1, ptr, i64, i64, i64, %SeenArray }, ptr " + thisPtrReg + ", i32 0, i32 4\n")
                            receiverReg = this.getNextReg()
                            output.append("  " + receiverReg + " = load ptr, ptr " + gepReg + "\n")
                            receiverType = "KeywordManager"
                            output.append("; DEBUG: receiverReg=" + receiverReg + " receiverType=" + receiverType + "\n")
                        }
                    }
                }
            }
        }

        // Check if this is a static method call BEFORE setting receiver fallback
        // Static method call: ClassName.method() where ClassName is not a variable
        // Class names use PascalCase (start with uppercase letter)
        if receiverReg == "" and expr.literalValue != "" {
            var potentialClassName = expr.literalValue
            // Strip generic type parameters: Map<K, V> -> Map
            var ltIdx = 0
            var i = 0
            while i < potentialClassName.length() {
                let ch = potentialClassName.substring(i, i + 1)
                if ch == "<" {
                    ltIdx = i
                    i = potentialClassName.length()  // break
                }
                i = i + 1
            }
            if ltIdx > 0 {
                potentialClassName = potentialClassName.substring(0, ltIdx)
            }
            let firstChar = potentialClassName.substring(0, 1)
            // Check if it starts with uppercase (A-Z) and is not a known variable
            let isUppercase = firstChar >= "A" and firstChar <= "Z"
            if isUppercase and findVar(potentialClassName) < 0 {
                // This is a static method call
                let funcName = potentialClassName + "_" + methodName

                // Generate arguments
                var staticArgRegs = Array<String>()
                var staticArgTypeStrs = Array<String>()
                var staticArgIdx = 0
                while staticArgIdx < expr.arguments.length() {
                    let argReg = this.generateExpression(expr.arguments[staticArgIdx])
                    let argType = this.inferExpressionType(expr.arguments[staticArgIdx])
                    // Data type arguments: store to alloca and pass pointer (ABI compat)
                    if this.isDataType(argType) {
                        let llvmType = this.mapType(argType)
                        let allocaReg = this.getNextReg()
                        output.append("  " + allocaReg + " = alloca " + llvmType + "\n")
                        output.append("  store " + llvmType + " " + argReg + ", ptr " + allocaReg + "\n")
                        staticArgRegs.push(allocaReg)
                        staticArgTypeStrs.push("ptr")
                    } else {
                        staticArgRegs.push(argReg)
                        staticArgTypeStrs.push(this.mapType(argType))
                    }
                    staticArgIdx = staticArgIdx + 1
                }

                // Runtime-provided StringBuilder.new returns ptr; convert to i64 class value.
                if potentialClassName == "StringBuilder" and methodName == "new" {
                    let rawReg = this.getNextReg()
                    output.append("  " + rawReg + " = call ptr @" + funcName + "(")

                    staticArgIdx = 0
                    while staticArgIdx < staticArgRegs.length() {
                        if staticArgIdx > 0 {
                            output.append(", ")
                        }
                        output.append(staticArgTypeStrs[staticArgIdx] + " " + staticArgRegs[staticArgIdx])
                        staticArgIdx = staticArgIdx + 1
                    }

                    output.append(")\n")
                    let resultReg = this.getNextReg()
                    output.append("  " + resultReg + " = ptrtoint ptr " + rawReg + " to i64\n")
                    return resultReg
                }

                let resultReg = this.getNextReg()
                // Class types return i64 directly, data types return inline struct, others return ptr
                if this.isClassType(potentialClassName) {
                    output.append("  " + resultReg + " = call i64 @" + funcName + "(")
                } else if this.isDataType(potentialClassName) {
                    output.append("  " + resultReg + " = call %" + potentialClassName + " @" + funcName + "(")
                } else {
                    output.append("  " + resultReg + " = call ptr @" + funcName + "(")
                }

                staticArgIdx = 0
                while staticArgIdx < staticArgRegs.length() {
                    if staticArgIdx > 0 {
                        output.append(", ")
                    }
                    output.append(staticArgTypeStrs[staticArgIdx] + " " + staticArgRegs[staticArgIdx])
                    staticArgIdx = staticArgIdx + 1
                }

                output.append(")\n")
                return resultReg
            }
        }

        // If receiver couldn't be resolved, check if this is a standalone function call
        // This handles cases where class methods were incorrectly parsed as standalone functions
        if receiverReg == "" {
            // Check if this method name matches a known standalone function
            // These are methods that should be on RealParser class but are parsed as standalone
            let isStandaloneFunc = methodName == "checkToken" or methodName == "advance" or methodName == "isAtEnd" or methodName == "peek" or methodName == "peekTokenType" or methodName == "peekTokenTypeStr" or methodName == "previous" or methodName == "consume" or methodName == "matchTokenStr" or methodName == "joinSegments" or methodName == "skipExpression" or methodName == "toArray"

            if isStandaloneFunc {
                output.append("; INFO: calling standalone function " + methodName + " (parser workaround)\n")

                // Generate arguments
                var standaloneArgRegs = Array<String>()
                var standaloneArgTypes = Array<String>()
                var argIdx = 0
                while argIdx < expr.arguments.length() {
                    let argReg = this.generateExpression(expr.arguments[argIdx])
                    let argType = this.inferExpressionType(expr.arguments[argIdx])
                    // Data type arguments: store to alloca and pass pointer (ABI compat)
                    if this.isDataType(argType) {
                        let llvmType = this.mapType(argType)
                        let allocaReg = this.getNextReg()
                        output.append("  " + allocaReg + " = alloca " + llvmType + "\n")
                        output.append("  store " + llvmType + " " + argReg + ", ptr " + allocaReg + "\n")
                        standaloneArgRegs.push(allocaReg)
                        standaloneArgTypes.push("ptr")
                    } else {
                        standaloneArgRegs.push(argReg)
                        standaloneArgTypes.push(this.mapType(argType))
                    }
                    argIdx = argIdx + 1
                }

                // Infer return type from method name
                var standaloneRetType = "ptr"  // Default
                var standaloneRetTypeResolved = false
                if methodName == "checkToken" or methodName == "matchTokenStr" or methodName == "isAtEnd" {
                    standaloneRetType = "i1"
                    standaloneRetTypeResolved = true
                }
                if not standaloneRetTypeResolved and methodName == "peekTokenType" {
                    standaloneRetType = "i64"
                    standaloneRetTypeResolved = true
                }
                if not standaloneRetTypeResolved and (methodName == "peekTokenTypeStr" or methodName == "joinSegments") {
                    standaloneRetType = "%SeenString"
                    standaloneRetTypeResolved = true
                }
                if not standaloneRetTypeResolved and methodName == "toArray" {
                    standaloneRetType = "%SeenArray"
                    standaloneRetTypeResolved = true
                }
                if not standaloneRetTypeResolved and methodName == "skipExpression" {
                    standaloneRetType = "void"
                }

                // Generate the call
                if standaloneRetType == "void" {
                    output.append("  call void @" + methodName + "(")
                    argIdx = 0
                    while argIdx < standaloneArgRegs.length() {
                        if argIdx > 0 {
                            output.append(", ")
                        }
                        output.append(standaloneArgTypes[argIdx] + " " + standaloneArgRegs[argIdx])
                        argIdx = argIdx + 1
                    }
                    output.append(")\n")
                    return "0"  // Void return
                }
                if standaloneRetType != "void" {
                    let standaloneResultReg = this.getNextReg()
                    output.append("  " + standaloneResultReg + " = call " + standaloneRetType + " @" + methodName + "(")
                    argIdx = 0
                    while argIdx < standaloneArgRegs.length() {
                        if argIdx > 0 {
                            output.append(", ")
                        }
                        output.append(standaloneArgTypes[argIdx] + " " + standaloneArgRegs[argIdx])
                        argIdx = argIdx + 1
                    }
                    output.append(")\n")
                    return standaloneResultReg
                }
            }

            // Fallback: use default value based on inferred type
            output.append("; WARNING: receiver not resolved for " + methodName + ", receiverType='" + receiverType + "', using default\n")

            // Special case: toString on unknown receiver type - return proper string
            if methodName == "toString" {
                // Always handle toString specially since we need a string result
                let toStrReg = this.getNextReg()
                if receiverType == "Int" or receiverType == "" or receiverType == "Char" {
                    output.append("  " + toStrReg + " = call %SeenString @seen_int_to_string(i64 " + receiverReg + ")\n")
                } else if receiverType == "Bool" {
                    output.append("  " + toStrReg + " = call %SeenString @seen_bool_to_string(i1 " + receiverReg + ")\n")
                } else {
                    output.append("  " + toStrReg + " = call %SeenString @seen_int_to_string(i64 0)\n")
                }
                return toStrReg
            }

            // Original fallback - only for non-toString methods
            if methodName == "toString_disabled" and receiverType == "" {
                let emptyStrReg = this.getNextReg()
                output.append("  " + emptyStrReg + " = call %SeenString @seen_int_to_string(i64 0)\n")
                return emptyStrReg
            }

            var receiverFallbackResolved = false
            if receiverType == "Int" or receiverType == "" or receiverType == "Char" {
                receiverReg = "0"
                receiverFallbackResolved = true
            }
            if not receiverFallbackResolved and receiverType == "Bool" {
                receiverReg = "false"
                receiverFallbackResolved = true
            }
            if not receiverFallbackResolved {
                receiverReg = "0"  // Generic fallback for i64 operations
            }
        }

        // Generate arguments BEFORE allocating result register to keep numbers in order
        if methodName == "length" or methodName == "len" {
            // Check if receiver is an array, list, vec, or string
            let isCollectionType = receiverType.startsWith("Array<") or receiverType == "Array" or receiverType.startsWith("List<") or receiverType == "List" or receiverType.startsWith("Vec<") or receiverType == "Vec"
            if isCollectionType {
                // For list/vec, receiver is ptr - call seen_arr_length_ptr
                if receiverType.startsWith("List<") or receiverType == "List" or receiverType.startsWith("Vec<") or receiverType == "Vec" {
                    let resultReg = this.getNextReg()
                    output.append("  " + resultReg + " = call i64 @seen_arr_length_ptr(ptr " + receiverReg + ")\n")
                    return resultReg
                }
                // For byval array, receiverReg is ptr to SeenArray on heap
                // Allocate, load SeenArray from ptr, store in alloca, pass pointer
                let arrayPtrReg = this.getNextReg()
                output.append("  " + arrayPtrReg + " = alloca %SeenArray, align 8\n")
                let seenArrReg = this.getNextReg()
                output.append("  " + seenArrReg + " = load %SeenArray, ptr " + receiverReg + "\n")
                output.append("  store %SeenArray " + seenArrReg + ", ptr " + arrayPtrReg + ", align 8\n")
                let resultReg = this.getNextReg()
                output.append("  " + resultReg + " = call i64 @seen_arr_length(ptr byval(%SeenArray) align 8 " + arrayPtrReg + ")\n")
                return resultReg
            }
            if not isCollectionType {
                let resultReg = this.getNextReg()
                output.append("  " + resultReg + " = call i64 @seen_length(%SeenString " + receiverReg + ")\n")
                return resultReg
            }
        }
        if methodName == "append" and receiverType == "StringBuilder" and expr.arguments.length() > 0 {
            let argReg = this.generateExpression(expr.arguments[0])
            var sbPtrReg = receiverReg
            if this.isClassType(receiverType) {
                let ptrConvReg = this.getNextReg()
                output.append("  " + ptrConvReg + " = inttoptr i64 " + receiverReg + " to ptr\n")
                sbPtrReg = ptrConvReg
            }
            let callReg = this.getNextReg()
            output.append("  " + callReg + " = call i64 @StringBuilder_append(ptr " + sbPtrReg + ", %SeenString " + argReg + ")\n")
            return "0"
        }
        if methodName == "appendChar" and receiverType == "StringBuilder" and expr.arguments.length() > 0 {
            let argReg = this.generateExpression(expr.arguments[0])
            var sbPtrReg = receiverReg
            if this.isClassType(receiverType) {
                let ptrConvReg = this.getNextReg()
                output.append("  " + ptrConvReg + " = inttoptr i64 " + receiverReg + " to ptr\n")
                sbPtrReg = ptrConvReg
            }
            let callReg = this.getNextReg()
            output.append("  " + callReg + " = call i64 @StringBuilder_appendChar(ptr " + sbPtrReg + ", i64 " + argReg + ")\n")
            return "0"
        }
        if methodName == "toString" {
            if receiverType == "StringBuilder" {
                var sbPtrReg = receiverReg
                if this.isClassType(receiverType) {
                    let ptrConvReg = this.getNextReg()
                    output.append("  " + ptrConvReg + " = inttoptr i64 " + receiverReg + " to ptr\n")
                    sbPtrReg = ptrConvReg
                }
                let resultReg = this.getNextReg()
                output.append("  " + resultReg + " = call %SeenString @StringBuilder_toString(ptr " + sbPtrReg + ")\n")
                return resultReg
            }
            if receiverType == "Bool" {
                // Bool.toString() - convert i1 to string
                let resultReg = this.getNextReg()
                output.append("  " + resultReg + " = call %SeenString @seen_bool_to_string(i1 " + receiverReg + ")\n")
                return resultReg
            }
            if receiverType == "Char" {
                let resultReg = this.getNextReg()
                output.append("  " + resultReg + " = call %SeenString @seen_char_to_str(i64 " + receiverReg + ")\n")
                return resultReg
            }
            if receiverType == "String" {
                // String.toString() - just return the string as-is
                return receiverReg
            }
            // Default: Int.toString()
            let resultReg = this.getNextReg()
            output.append("  " + resultReg + " = call %SeenString @seen_int_to_string(i64 " + receiverReg + ")\n")
            return resultReg
        }
        if methodName == "startsWith" {
            let argReg = this.generateExpression(expr.arguments[0])
            let resultReg = this.getNextReg()
            output.append("  " + resultReg + " = call i1 @startsWith(%SeenString " + receiverReg + ", %SeenString " + argReg + ")\n")
            return resultReg
        }
        if methodName == "endsWith" {
            let argReg = this.generateExpression(expr.arguments[0])
            let resultReg = this.getNextReg()
            output.append("  " + resultReg + " = call i1 @endsWith(%SeenString " + receiverReg + ", %SeenString " + argReg + ")\n")
            return resultReg
        }
        if methodName == "contains" {
            let argReg = this.generateExpression(expr.arguments[0])
            let resultReg = this.getNextReg()
            output.append("  " + resultReg + " = call i1 @contains(%SeenString " + receiverReg + ", %SeenString " + argReg + ")\n")
            return resultReg
        }
        if methodName == "trim" {
            // Check if this is a class method call (receiver is not a String)
            if receiverType != "String" and receiverType != "" {
                // This is a class method like KeywordManager.trim(s)
                let funcName = receiverType + "_trim"
                let argReg = this.generateExpression(expr.arguments[0])
                // If receiver is a class type (stored as i64), convert to ptr
                var trimReceiverReg = receiverReg
                if this.isClassType(receiverType) {
                    let ptrConvReg = this.getNextReg()
                    output.append("  " + ptrConvReg + " = inttoptr i64 " + receiverReg + " to ptr\n")
                    trimReceiverReg = ptrConvReg
                }
                let resultReg = this.getNextReg()
                output.append("  " + resultReg + " = call %SeenString @" + funcName + "(ptr " + trimReceiverReg + ", %SeenString " + argReg + ")\n")
                return resultReg
            }
            // String method - no arguments, trim whitespace from string itself
            let resultReg = this.getNextReg()
            output.append("  " + resultReg + " = call %SeenString @trim(%SeenString " + receiverReg + ")\n")
            return resultReg
        }
        if methodName == "substring" {
            let startReg = this.generateExpression(expr.arguments[0])
            let endReg = this.generateExpression(expr.arguments[1])
            let resultReg = this.getNextReg()
            output.append("  " + resultReg + " = call %SeenString @seen_substring(%SeenString " + receiverReg + ", i64 " + startReg + ", i64 " + endReg + ")\n")
            return resultReg
        }
        if methodName == "charAt" {
            let indexReg = this.generateExpression(expr.arguments[0])
            let resultReg = this.getNextReg()
            output.append("  " + resultReg + " = call i64 @seen_char_at(%SeenString " + receiverReg + ", i64 " + indexReg + ")\n")
            return resultReg
        }
        if methodName == "charCodeAt" {
            let indexReg = this.generateExpression(expr.arguments[0])
            let resultReg = this.getNextReg()
            output.append("  " + resultReg + " = call i64 @seen_char_at(%SeenString " + receiverReg + ", i64 " + indexReg + ")\n")
            return resultReg
        }
        if methodName == "indexOf" {
            // indexOf(text, needle, startIndex=0) - call as free function
            let needleReg = this.generateExpression(expr.arguments[0])
            var startIdxReg = "0"
            if expr.arguments.length() > 1 {
                startIdxReg = this.generateExpression(expr.arguments[1])
            }
            let resultReg = this.getNextReg()
            output.append("  " + resultReg + " = call i64 @indexOf(%SeenString " + receiverReg + ", %SeenString " + needleReg + ", i64 " + startIdxReg + ")\n")
            return resultReg
        }
        if methodName == "lastIndexOf" {
            // lastIndexOf(text, needle, startIndex) - call as free function
            let needleReg = this.generateExpression(expr.arguments[0])
            var startIdxReg = "-1"  // Default: start from end
            if expr.arguments.length() > 1 {
                startIdxReg = this.generateExpression(expr.arguments[1])
            }
            let resultReg = this.getNextReg()
            output.append("  " + resultReg + " = call i64 @lastIndexOf(%SeenString " + receiverReg + ", %SeenString " + needleReg + ", i64 " + startIdxReg + ")\n")
            return resultReg
        }
        if methodName == "push" {
            // push needs pointer to array to modify in place
            // Generate argument first
            let argExpr = expr.arguments[0]
            let argReg = this.generateExpression(argExpr)
            let argType = this.inferExpressionType(argExpr)
            // Track if arg is from a struct literal (returns ptr) vs method call (may return inline struct)
            let argIsStructLiteral = argExpr.kind == "StructLiteral"
            var elemType = ""
            if receiverType.startsWith("Array<") and receiverType.endsWith(">") {
                elemType = receiverType.substring(6, receiverType.length() - 1)
            }
            var pushElemType = argType
            if pushElemType == "" {
                pushElemType = elemType
            }

            // We need the field pointer, not the loaded value
            var arrayPtrReg = ""

            // First, check if receiver is a local variable - use its alloca directly
            let varName = expr.literalValue
            if varName != "" {
                // Check if this is a chained field access (contains .)
                if varName.contains(".") {
                    // Chained field access like currentProgram.items
                    // Parse the path and navigate through fields
                    var dotIdx = 0
                    var searchIdx = 0
                    while searchIdx < varName.length() {
                        if varName.substring(searchIdx, searchIdx + 1) == "." {
                            dotIdx = searchIdx
                            searchIdx = varName.length()  // Exit loop at first dot
                        }
                        searchIdx = searchIdx + 1
                    }
                    let firstPart = varName.substring(0, dotIdx)
                    let restPart = varName.substring(dotIdx + 1, varName.length())

                    output.append("; DEBUG push chained: firstPart=" + firstPart + " restPart=" + restPart + "\n")

                    // Check if first part is a local variable
                    let firstVarIdx = this.findVar(firstPart)
                    var firstPartHandled = false
                    if firstVarIdx >= 0 {
                        // First part is a local variable
                        let firstVarReg = varRegs[firstVarIdx]
                        let firstVarType = varTypes[firstVarIdx]
                        let firstPtrReg = this.getNextReg()
                        output.append("  " + firstPtrReg + " = load ptr, ptr " + firstVarReg + "\n")
                        // Get pointer to rest of the path (the array field)
                        let fieldPtrReg = this.generateFieldAccessPtr(firstPtrReg, firstVarType, restPart)
                        // Load the actual array pointer from the field (arrays are stored as ptr to heap SeenArray)
                        let loadedArrPtr = this.getNextReg()
                        output.append("  " + loadedArrPtr + " = load ptr, ptr " + fieldPtrReg + "\n")
                        arrayPtrReg = loadedArrPtr
                        firstPartHandled = true
                    }
                    if not firstPartHandled {
                        // First part might be a field on 'this'
                        let thisIdx = this.findVar("this")
                        if thisIdx >= 0 {
                            let thisReg = varRegs[thisIdx]
                            let thisType = varTypes[thisIdx]
                            let structIdx = this.findStruct(thisType)
                            if structIdx >= 0 {
                                let fieldIdx = this.getFieldInfo(thisType, firstPart)
                                output.append("; DEBUG push chained from this: thisType=" + thisType + " firstPart=" + firstPart + " fieldIdx=" + fieldIdx.toString() + "\n")
                                if fieldIdx >= 0 {
                                    // Load 'this' pointer
                                    let thisPtrReg = this.getNextReg()
                                    output.append("  " + thisPtrReg + " = load ptr, ptr " + thisReg + "\n")

                                    // Get the type and pointer of the first field
                                    let firstFieldType = this.getSeenFieldType(thisType, firstPart)
                                    let firstFieldReg = this.generateFieldAccess(thisPtrReg, thisType, firstPart)
                                    output.append("; DEBUG push chained: firstFieldType=" + firstFieldType + " firstFieldReg=" + firstFieldReg + "\n")

                                    // If firstFieldType is a class type, convert i64 to ptr
                                    var accessFieldReg = firstFieldReg
                                    if this.isClassType(firstFieldType) {
                                        let ptrConvReg = this.getNextReg()
                                        output.append("  " + ptrConvReg + " = inttoptr i64 " + firstFieldReg + " to ptr\n")
                                        accessFieldReg = ptrConvReg
                                    }

                                    // Now get pointer to the rest of the path (the array field)
                                    let fieldPtrReg = this.generateFieldAccessPtr(accessFieldReg, firstFieldType, restPart)
                                    // Load the actual array pointer from the field (arrays are stored as ptr to heap SeenArray)
                                    let loadedArrPtr = this.getNextReg()
                                    output.append("  " + loadedArrPtr + " = load ptr, ptr " + fieldPtrReg + "\n")
                                    arrayPtrReg = loadedArrPtr
                                    output.append("; DEBUG push chained: arrayPtrReg=" + arrayPtrReg + "\n")
                                }
                            }
                        }
                    }
                }
                if not varName.contains(".") {
                    // Simple variable name (no dots)
                    let varIdx = this.findVar(varName)
                    var pushVarHandled = false
                    if varIdx >= 0 {
                        // Local variable - load the array pointer from the alloca
                        // Arrays are stored as ptr to heap SeenArray
                        let loadReg = this.getNextReg()
                        output.append("  " + loadReg + " = load ptr, ptr " + varRegs[varIdx] + "\n")
                        arrayPtrReg = loadReg
                        pushVarHandled = true
                    }
                    if not pushVarHandled {
                        // Not a local variable - might be a field on 'this'
                        let thisIdx = this.findVar("this")
                        if thisIdx >= 0 {
                            let thisReg = varRegs[thisIdx]
                            let thisType = varTypes[thisIdx]
                            if thisType == "LLVMIRGenerator" {
                                let idxCheck = this.getLLVMIRGeneratorFieldIndex(varName)
                                if idxCheck >= 0 {
                                    let thisPtrReg = this.getNextReg()
                                    output.append("  " + thisPtrReg + " = load ptr, ptr " + thisReg + "\n")
                                    let fieldPtrReg = this.generateFieldAccessPtr(thisPtrReg, thisType, varName)
                                    let loadedArrPtr = this.getNextReg()
                                    output.append("  " + loadedArrPtr + " = load ptr, ptr " + fieldPtrReg + "\n")
                                    arrayPtrReg = loadedArrPtr
                                }
                            }
                            let structIdx = this.findStruct(thisType)
                            if structIdx >= 0 {
                                let fieldIdx = this.getFieldInfo(thisType, varName)
                                if fieldIdx >= 0 {
                                    // Load 'this' pointer and get field pointer
                                    let thisPtrReg = this.getNextReg()
                                    output.append("  " + thisPtrReg + " = load ptr, ptr " + thisReg + "\n")
                                    let fieldPtrReg = this.generateFieldAccessPtr(thisPtrReg, thisType, varName)
                                    // Load the actual array pointer from the field (arrays are stored as ptr to heap SeenArray)
                                    let loadedArrPtr = this.getNextReg()
                                    output.append("  " + loadedArrPtr + " = load ptr, ptr " + fieldPtrReg + "\n")
                                    arrayPtrReg = loadedArrPtr
                                }
                            }
                        }
                    }
                }
            }

            // Fall back: receiverReg is already a ptr to SeenArray on heap
            // (arrays are heap-allocated, so receiverReg from generateExpression is a ptr)
            if arrayPtrReg == "" and (receiverType.startsWith("Array<") or receiverType == "Array") {
                arrayPtrReg = receiverReg
            }

            if arrayPtrReg != "" {
                // Use type-specific push function for correct ABI
                var pushTypeHandled = false
                if pushElemType == "String" {
                    // For strings, use seen_arr_push_str which takes SeenString by value
                    output.append("  call void @seen_arr_push_str(ptr " + arrayPtrReg + ", %SeenString " + argReg + ")\n")
                    return "0"  // void return
                }
                if pushElemType == "Int" or pushElemType == "Char" or receiverType == "Array<Int>" {
                    // For Int arrays, pass the value directly (not a stack pointer)
                    // Using seen_arr_push_i64 which takes i64 by value
                    output.append("  call void @seen_arr_push_i64(ptr " + arrayPtrReg + ", i64 " + argReg + ")\n")
                    return "0"  // void return
                }
                if pushElemType != "String" and pushElemType != "Int" and receiverType != "Array<Int>" {
                    // Inline data types use Array_push (copies element_size bytes).
                    if this.isDataType(pushElemType) {
                        var ptrArgReg = argReg
                        if this.isClassType(pushElemType) {
                            let tmpReg = this.getNextReg()
                            output.append("  " + tmpReg + " = alloca i64\n")
                            output.append("  store i64 " + argReg + ", ptr " + tmpReg + "\n")
                            ptrArgReg = tmpReg
                        }
                        if not argIsStructLiteral {
                            let tmpReg = this.getNextReg()
                            output.append("  " + tmpReg + " = alloca %" + pushElemType + "\n")
                            output.append("  store %" + pushElemType + " " + argReg + ", ptr " + tmpReg + "\n")
                            ptrArgReg = tmpReg
                        }
                        let resultReg = this.getNextReg()
                        output.append("  " + resultReg + " = call i64 @Array_push(ptr " + arrayPtrReg + ", ptr " + ptrArgReg + ")\n")
                        return resultReg
                    }
                    // Pointer arrays (class types and raw pointers) use seen_arr_push_ptr.
                    var ptrArgReg = argReg
                    if this.isClassType(pushElemType) {
                        let ptrReg = this.getNextReg()
                        output.append("  " + ptrReg + " = inttoptr i64 " + argReg + " to ptr\n")
                        ptrArgReg = ptrReg
                    }
                    if ptrArgReg == "0" {
                        ptrArgReg = "null"
                    }
                    output.append("  call void @seen_arr_push_ptr(ptr " + arrayPtrReg + ", ptr " + ptrArgReg + ")\n")
                    return "0"
                }
            }
        }

        // Check if this is a static method call (receiver is a class name, not a variable)
        // BUT if we already set receiverReg from field access, this is NOT a static call
        let isStatic = this.findVar(expr.literalValue) < 0 and receiverReg == ""

        if isStatic {
            // Static method call: LLVMIRGenerator.new() -> @LLVMIRGenerator_new()
            let className = expr.literalValue
            let funcName = className + "_" + methodName
            let isClass = this.isClassType(className)
            println("[DEBUG STATIC CALL] " + className + "." + methodName + " isClass=" + isClass.toString())

            // Generate arguments
            var argRegs = Array<String>()
            var argTypeStrs = Array<String>()
            var argIdx = 0
            while argIdx < expr.arguments.length() {
                let argReg = this.generateExpression(expr.arguments[argIdx])
                let argType = this.inferExpressionType(expr.arguments[argIdx])
                // Data type arguments: store to alloca and pass pointer (ABI compat)
                if this.isDataType(argType) {
                    let llvmType = this.mapType(argType)
                    let allocaReg = this.getNextReg()
                    output.append("  " + allocaReg + " = alloca " + llvmType + "\n")
                    output.append("  store " + llvmType + " " + argReg + ", ptr " + allocaReg + "\n")
                    argRegs.push(allocaReg)
                    argTypeStrs.push("ptr")
                } else {
                    argRegs.push(argReg)
                    argTypeStrs.push(this.mapType(argType))
                }
                argIdx = argIdx + 1
            }

            let resultReg = this.getNextReg()
            // Class types return i64 (pointer-as-int), data types return inline struct, others return ptr
            if this.isClassType(className) {
                output.append("  " + resultReg + " = call i64 @" + funcName + "(")
            } else if this.isDataType(className) {
                output.append("  " + resultReg + " = call %" + className + " @" + funcName + "(")
            } else {
                output.append("  " + resultReg + " = call ptr @" + funcName + "(")
            }

            argIdx = 0
            while argIdx < argRegs.length() {
                if argIdx > 0 {
                    output.append(", ")
                }
                output.append(argTypeStrs[argIdx] + " " + argRegs[argIdx])
                argIdx = argIdx + 1
            }

            output.append(")\n")
            return resultReg
        }

        // Instance method call: generator.generate(arg) -> @LLVMIRGenerator_generate(receiver, arg)
        // Get the receiver's type to construct the function name
        if methodName == "isOkay" {
            println("[DEBUG METHOD STATE] receiverType=" + receiverType + " receiverReg=" + receiverReg)
        }
        var instanceTypeName = receiverType
        // Clean up type name - remove generic parameters if present
        // Avoid String.contains/substring here to reduce heap churn during codegen.
        var ltIdx = -1
        var scanIdx = 0
        while scanIdx < instanceTypeName.length() {
            if instanceTypeName.charAt(scanIdx) == '<' {
                ltIdx = scanIdx
                scanIdx = instanceTypeName.length()
            }
            scanIdx = scanIdx + 1
        }
        if ltIdx > 0 {
            var prefix = ""
            var i = 0
            while i < ltIdx {
                prefix = prefix + instanceTypeName.charAt(i).toString()
                i = i + 1
            }
            instanceTypeName = prefix
        }

        let funcName = instanceTypeName + "_" + methodName
        if methodName == "isOkay" {
            println("[DEBUG METHOD STEP] instanceTypeName=" + instanceTypeName + " funcName=" + funcName)
        }

        // Generate arguments
        var argRegs = Array<String>()
        var argTypeStrs = Array<String>()
        var argIdx = 0
        while argIdx < expr.arguments.length() {
            let argReg = this.generateExpression(expr.arguments[argIdx])
            let argType = this.inferExpressionType(expr.arguments[argIdx])
            // Data type arguments: store to alloca and pass pointer (ABI compat)
            if this.isDataType(argType) {
                let llvmType = this.mapType(argType)
                let allocaReg = this.getNextReg()
                output.append("  " + allocaReg + " = alloca " + llvmType + "\n")
                output.append("  store " + llvmType + " " + argReg + ", ptr " + allocaReg + "\n")
                argRegs.push(allocaReg)
                argTypeStrs.push("ptr")
            } else {
                argRegs.push(argReg)
                argTypeStrs.push(this.mapType(argType))
            }
            argIdx = argIdx + 1
        }

        // Infer return type from method name
        let returnTypeStr = this.inferExpressionType(expr)
        if methodName == "isOkay" {
            println("[DEBUG METHOD STEP] returnTypeStr=" + returnTypeStr)
        }
        let llvmReturnType = this.mapType(returnTypeStr)
        if methodName == "isOkay" {
            println("[DEBUG METHOD STEP] llvmReturnType=" + llvmReturnType)
        }

        // Determine the receiver type for the call
        // For primitive types (Int, Char, Bool), use their LLVM type directly
        // For class/struct types, use ptr
        var receiverLlvmType = "ptr"
        var receiverLlvmResolved = false
        if instanceTypeName == "Char" or instanceTypeName == "Int" or instanceTypeName == "Integer" or instanceTypeName == "SeenTokenType" {
            receiverLlvmType = "i64"
            receiverLlvmResolved = true
        }
        if not receiverLlvmResolved and (instanceTypeName == "Bool" or instanceTypeName == "Boolean") {
            receiverLlvmType = "i1"
            receiverLlvmResolved = true
        }
        if not receiverLlvmResolved and instanceTypeName == "Float" {
            receiverLlvmType = "double"
            receiverLlvmResolved = true
        }
        if not receiverLlvmResolved and instanceTypeName == "String" {
            receiverLlvmType = "%SeenString"
            receiverLlvmResolved = true
        }
        if methodName == "isOkay" {
            println("[DEBUG METHOD STEP] receiverLlvmType=" + receiverLlvmType + " receiverLlvmResolved=" + receiverLlvmResolved.toString())
        }

        // For class types (not primitives or String), receiver is stored as i64
        // Convert from i64 to ptr before calling the method
        // But non-class struct types (like StringBuilder) are stored as ptr, no conversion needed
        if not receiverLlvmResolved and this.isClassType(receiverType) {
            // receiverLlvmType is "ptr" by default (set above)
            // But receiverReg holds an i64 value, so convert it
            let ptrReceiverReg = this.getNextReg()
            output.append("  " + ptrReceiverReg + " = inttoptr i64 " + receiverReg + " to ptr\n")
            receiverReg = ptrReceiverReg
        }
        if methodName == "isOkay" {
            println("[DEBUG METHOD STEP] receiverReg(after)=" + receiverReg)
        }

        // Handle void return type - don't assign to a register
        if llvmReturnType == "void" {
            output.append("  call void @" + funcName + "(" + receiverLlvmType + " " + receiverReg)

            argIdx = 0
            while argIdx < argRegs.length() {
                output.append(", ")
                output.append(argTypeStrs[argIdx] + " " + argRegs[argIdx])
                argIdx = argIdx + 1
            }

            output.append(")\n")
            return "0"  // Void calls return nothing
        }

        // Call the method with the correct LLVM return type
        // Class types already return i64 from mapType(), no conversion needed
        let resultReg = this.getNextReg()
        output.append("  " + resultReg + " = call " + llvmReturnType + " @" + funcName + "(" + receiverLlvmType + " " + receiverReg)

        argIdx = 0
        while argIdx < argRegs.length() {
            output.append(", ")
            output.append(argTypeStrs[argIdx] + " " + argRegs[argIdx])
            argIdx = argIdx + 1
        }

        output.append(")\n")

        return resultReg
    }

    fun generateUnary(expr: ParserExpressionNode) r: String {
        let operandReg = this.generateExpression(expr.operands[0])
        let resultReg = this.getNextReg()

        if expr.operator == "-" {
            output.append("  " + resultReg + " = sub i64 0, " + operandReg + "\n")
        }
        if expr.operator != "-" and (expr.operator == "not" or expr.operator == "!") {
            output.append("  " + resultReg + " = xor i1 " + operandReg + ", 1\n")
        }

        return resultReg
    }

    // Helper functions

    fun getNextReg() r: String {
        let reg = "%" + nextReg.toString()
        nextReg = nextReg + 1
        return reg
    }

    fun getNextBlockLabel() r: String {
        let label = "bb" + nextBlock.toString()
        nextBlock = nextBlock + 1
        return label
    }

    fun mapType(seenType: String) r: String {
        let trimmed = this.trimSpaces(seenType)
        let baseType = this.getBaseTypeName(trimmed)
        if baseType == "Int" {
            return "i64"
        }
        if baseType == "Char" {
            // Char is represented as i64 (Unicode code point)
            return "i64"
        }
        if baseType == "Bool" or baseType == "Boolean" {
            return "i1"
        }
        if baseType == "String" {
            return "%SeenString"
        }
        if baseType == "Float" {
            return "double"
        }
        if baseType == "Void" or baseType == "" {
            return "void"
        }
        // Enums are represented as i64
        if baseType == "SeenTokenType" {
            return "i64"
        }
        // Array types - heap-allocated, stored as ptr (8 bytes)
        // This must come BEFORE class/struct checks to handle Array<T> correctly
        if trimmed.startsWith("Array<") or baseType == "Array" {
            return "ptr"
        }
        if trimmed.startsWith("List<") or baseType == "List" {
            return "ptr"
        }
        if this.isDataType(baseType) {
            return "%" + baseType
        }
        if this.isClassType(baseType) {
            return "i64"
        }
        // Any other type is likely a struct/class, which is a pointer
        // (primitive types Int, Bool, Float, String, Void are handled above)
        return "ptr"
    }

    // Check if a Seen type is a class type (stored as i64, pointer-as-int)
    // Returns true for heap-allocated reference types defined with 'class' keyword
    fun isClassType(seenType: String) r: Bool {
        let baseType = this.getBaseTypeName(seenType)
        if baseType == "" {
            return false
        }
        if baseType == "Int" or baseType == "Char" or baseType == "Bool" or baseType == "Boolean" or baseType == "Float" or baseType == "String" or baseType == "Void" {
            return false
        }
        if seenType.startsWith("Array<") or baseType == "Array" {
            return false
        }
        if seenType.startsWith("List<") or baseType == "List" {
            return false
        }
        if this.isDataType(baseType) {
            return false
        }
        if this.findStruct(baseType) >= 0 {
            return true
        }
        // Class types are stored as i64 (pointer-as-int for ABI compatibility)
        if baseType == "FrontendResult" or baseType == "LLVMIRGenerator" or baseType == "ProgramNode" or baseType == "FrontendDiagnostic" or baseType == "Point" or baseType == "TypeInferenceResult" or baseType == "TypeChecker" or baseType == "RealParser" or baseType == "SeenLexer" or baseType == "TypeError" or baseType == "Location" or baseType == "Type" or baseType == "FsFileResult" or baseType == "FsFile" or baseType == "Result" or baseType == "Unit" or baseType == "Optional" or baseType == "Option" or baseType == "FunctionNode" or baseType == "ClassNode" or baseType == "EnumNode" or baseType == "BlockNode" or baseType == "Environment" or baseType == "ImportNode" or baseType == "Token" or baseType == "StringBuilder" or baseType == "Map" or baseType == "Vec" or baseType == "VecChunk" or baseType == "VecSlot" {
            return true
        }
        // AST node types (heap-allocated class types only, NOT data types)
        // Note: TypeNode, ParamNode, ImportPathInfo, ImportSymbolNode are DATA types (inline, not heap)
        if baseType == "StatementNode" or baseType == "ParserExpressionNode" or baseType == "LexerError" or baseType == "KeywordManager" or baseType == "ClassType" or baseType == "FunctionType" or baseType == "InterfaceType" {
            return true
        }
        // Generic class types
        if seenType.startsWith("Result<") or seenType.startsWith("Optional<") or seenType.startsWith("Option<") {
            return true
        }
        return false
    }

    // Check if a Seen type is a data type (inline struct, not heap-allocated)
    // Data types are stored inline in arrays and need to be loaded
    fun isDataType(seenType: String) r: Bool {
        let baseType = this.getBaseTypeName(seenType)
        if baseType == "TypeNode" or baseType == "ParamNode" or baseType == "ItemNode" or baseType == "ImportPathInfo" or baseType == "ImportSymbolNode" or baseType == "CommandResult" or baseType == "RemovalResult" or baseType == "CompilerInfo" or baseType == "VerificationResult" or baseType == "StageArtifact" or baseType == "BinaryComparison" or baseType == "FunctionSummary" or baseType == "ModuleMetadata" {
            return true
        }
        return false
    }

    // Get the size in bytes of a data type for array element_size
    // These sizes must match the LLVM struct layouts
    fun getDataTypeSize(seenType: String) r: Int {
        let baseType = this.getBaseTypeName(seenType)
        let idx = this.findStruct(baseType)
        if idx >= 0 {
            let sizeVal = structSizes[idx]
            if sizeVal > 0 {
                return sizeVal
            }
        }
        // TypeNode = { %SeenString, i1 } = 16 + 1 + padding = 24 bytes
        if baseType == "TypeNode" {
            return 24
        }
        // ParamNode = { %SeenString, %TypeNode, i1 } = 16 + 24 + 1 + padding = 48 bytes
        if baseType == "ParamNode" {
            return 48
        }
        // CommandResult = { i1, %SeenString } = 1 + padding + 16 = 24 bytes
        if baseType == "CommandResult" {
            return 24
        }
        // ItemNode = { %SeenString, %SeenString, %SeenString, ptr, ptr, i64, i64, i64 }
        //          = 16 + 16 + 16 + 8 + 8 + 8 + 8 + 8 = 88 bytes
        if baseType == "ItemNode" {
            return 88
        }
        // ImportPathInfo = { %SeenString, ptr } = 16 + 8 = 24 bytes
        if baseType == "ImportPathInfo" {
            return 24
        }
        // ImportSymbolNode = { %SeenString, %SeenString } = 16 + 16 = 32 bytes
        if baseType == "ImportSymbolNode" {
            return 32
        }
        // Default: pointer size
        return 8
    }

    // Map type for function parameter - ABI compatibility with Rust backend
    // Data types are passed as pointers to match Rust's struct-to-ptr conversion
    fun mapTypeForParameter(seenType: String) r: String {
        // Data types passed as pointers for ABI compatibility with Rust backend
        if this.isDataType(seenType) {
            return "ptr"
        }
        return this.mapType(seenType)
    }

    fun inferExpressionType(expr: ParserExpressionNode) r: String {
        if expr.kind == "Literal" {
            println("[DEBUG inferType] Literal literalType=" + expr.literalType + " literalValue=" + expr.literalValue)
            if expr.literalType == "Int" or expr.literalType == "Integer" {
                return "Int"
            }
            if expr.literalType == "String" {
                return "String"
            }
            if expr.literalType == "Char" {
                return "Char"
            }
            if expr.literalType == "Bool" or expr.literalType == "Boolean" {
                return "Bool"
            }
            if expr.literalType == "Float" {
                return "Float"
            }
            // If literalType is set but not one of the known types, return it
            if expr.literalType != "" {
                return expr.literalType
            }
            // Fallback: try to infer from literal value
            if expr.literalValue.startsWith("\"") or expr.literalValue.startsWith("'") {
                return "String"
            }
            return "Int"  // Default for numeric literals
        }
        if expr.kind == "Variable" or expr.kind == "VarExpr" {
            // Use findVarType to check both varTypes and preAllocatedTypes
            let varType = this.findVarType(expr.variableName)
            if varType != "" {
                return varType
            }
            // Variable not found - check if it's a field on 'this'
            let thisIdx = this.findVar("this")
            if thisIdx >= 0 {
                let thisType = varTypes[thisIdx]
                if thisType == "LLVMIRGenerator" {
                    let idxCheck = this.getLLVMIRGeneratorFieldIndex(expr.variableName)
                    if idxCheck >= 0 {
                        return this.getSeenFieldType(thisType, expr.variableName)
                    }
                }
                let structIdx = this.findStruct(thisType)
                if structIdx >= 0 {
                    let fieldIdx = this.getFieldInfo(thisType, expr.variableName)
                    if fieldIdx >= 0 {
                        return this.getSeenFieldType(thisType, expr.variableName)
                    }
                }
            }
        }
        if expr.kind == "Binary" {
            if expr.operator == "==" or expr.operator == "!=" or expr.operator == "<" or expr.operator == ">" or expr.operator == "<=" or expr.operator == ">=" or expr.operator == "and" or expr.operator == "or" {
                return "Bool"
            }
            if expr.operator == "+" {
                // Check if string concat - check both operands
                if expr.operands.length() >= 2 {
                    let leftType = this.inferExpressionType(expr.operands[0])
                    if leftType == "String" {
                        return "String"
                    }
                    let rightType = this.inferExpressionType(expr.operands[1])
                    if rightType == "String" {
                        return "String"
                    }
                }
            }
            return "Int"
        }
        if expr.kind == "MethodCall" {
            // Debug: show callee for advance calls
            if expr.callee == "advance" or expr.callee == "this.advance" {
                println("[DEBUG inferType] MethodCall callee=" + expr.callee + " for advance className=" + currentClassName)
            }
            // First, try to look up method return type from registry based on receiver type
            // Handle "this" receiver
            if currentClassName != "" and expr.literalValue == "this" {
                let registryRetType = this.getMethodReturnType(currentClassName, expr.callee)
                if registryRetType != "" {
                    return registryRetType
                }
            }
            // Handle variable receiver (obj.method())
            if expr.literalValue != "" and expr.literalValue != "this" {
                let recVarType = this.findVarType(expr.literalValue)
                if recVarType != "" {
                    let registryRetType = this.getMethodReturnType(recVarType, expr.callee)
                    if registryRetType != "" {
                        return registryRetType
                    }
                }
            }
            // Handle expression receiver (chained calls like obj.method1().method2())
            if expr.operands.length() > 0 {
                let recExprType = this.inferExpressionType(expr.operands[0])
                if recExprType != "" {
                    let registryRetType = this.getMethodReturnType(recExprType, expr.callee)
                    if registryRetType != "" {
                        return registryRetType
                    }
                }
            }
            // Check for static method calls - literalValue is the class name
            if expr.callee == "new" {
                // Static constructor - returns the class type
                return expr.literalValue
            }
            if expr.callee == "length" or expr.callee == "size" {
                return "Int"
            }
            if expr.callee == "charAt" or expr.callee == "charCodeAt" {
                return "Char"
            }
            // Note: 'getValue' must be hardcoded because Token class methods aren't registered
            // before parser module methods are compiled (module load order issue)
            if expr.callee == "toString" or expr.callee == "substring" or expr.callee == "trim" or expr.callee == "generate" or expr.callee == "generateMultiple" or expr.callee == "generateSingle" or expr.callee == "mapType" or expr.callee == "getNextReg" or expr.callee == "getNextBlock" or expr.callee == "getFieldType" or expr.callee == "getSeenFieldType" or expr.callee == "getFunctionReturnType" or expr.callee == "getMethodReturnType" or expr.callee == "resolveChainedPathType" or expr.callee == "hexToDecimal" or expr.callee == "escapeString" or expr.callee == "findVarType" or expr.callee == "peekTokenTypeStr" or expr.callee == "joinSegments" or expr.callee == "getValue" {
                return "String"
            }
            if expr.callee == "startsWith" or expr.callee == "endsWith" or expr.callee == "contains" or expr.callee == "success" or expr.callee == "isDynamic" or expr.callee == "isKeyword" or expr.callee == "hasTranslation" or expr.callee == "containsKey" or expr.callee == "containsValue" or expr.callee == "isOkay" or expr.callee == "isErr" or expr.callee == "checkToken" or expr.callee == "matchTokenStr" or expr.callee == "isAtEnd" {
                return "Bool"
            }
            if expr.callee == "peek" or expr.callee == "previous" or expr.callee == "consume" or expr.callee == "advance" {
                return "Token"
            }
            if expr.callee == "handleWhitespace" or expr.callee == "handleSingleLineComment" or expr.callee == "handleMultiLineComment" or expr.callee == "handleStringLiteral" or expr.callee == "handleCharLiteral" or expr.callee == "handleNumericLiteral" or expr.callee == "handleIdentifierOrKeyword" or expr.callee == "emitToken" or expr.callee == "emitErrorToken" or expr.callee == "setErrorRecoveryMode" or expr.callee == "push" or expr.callee == "append" or expr.callee == "appendChar" or expr.callee == "clear" {
                return "Void"
            }
            if expr.callee == "peekTokenType" {
                return "Int"
            }
            if expr.callee == "parseTypeNode" {
                return "TypeNode"
            }
            if expr.callee == "toArray" {
                return "Array<Token>"
            }
            if expr.callee == "getDiagnostics" {
                return "Array<FrontendDiagnostic>"
            }
            if expr.callee == "getSources" or expr.callee == "getKeywordSources" or expr.callee == "keys" or expr.callee == "values" or expr.callee == "split" {
                return "Array<String>"
            }
            if expr.callee == "getKeywordCount" {
                return "Int"
            }
            if expr.callee == "check" {
                return "TypeInferenceResult"
            }
            if expr.callee == "parse" {
                return "ProgramNode"
            }
            if expr.callee == "tokenize" {
                return "Array<Token>"
            }
            if expr.callee == "getContext" or expr.callee == "getMessage" or expr.callee == "unwrapErr" {
                return "String"
            }
            if expr.callee == "getLocation" {
                return "Location"
            }
            if expr.callee == "getExpected" or expr.callee == "getActual" {
                return "Type"
            }
            if expr.callee == "open" or expr.callee == "create" {
                return "FsFileResult"
            }
            if expr.callee == "unwrap" {
                // Check receiver type to determine return type
                // Receiver can be in operands (for chained calls) or literalValue (for simple variable calls)
                var recType = ""
                if expr.operands.length() > 0 {
                    recType = this.inferExpressionType(expr.operands[0])
                }
                if recType == "" and expr.literalValue != "" {
                    // Check if literalValue is a local variable
                    let varIdx = this.findVar(expr.literalValue)
                    if varIdx >= 0 {
                        recType = varTypes[varIdx]
                    }
                }
                if recType == "FsFileResult" {
                    return "FsFile"
                }
                if recType == "Result" {
                    return "ptr"  // Generic Result.unwrap returns ptr
                }
                return "ptr"
            }
            if expr.callee == "readContent" or expr.callee == "writeContent" or expr.callee == "closeFile" {
                return "Result"
            }

            // Try to look up method return type from receiver's class
            var receiverType = ""
            var receiverTypeResolved = false
            if expr.operands.length() > 0 {
                receiverType = this.inferExpressionType(expr.operands[0])
                receiverTypeResolved = true
            }
            if not receiverTypeResolved {
                // Check if literalValue is a known variable
                let varIdx = this.findVar(expr.literalValue)
                var varIdxHandled = false
                if varIdx >= 0 {
                    receiverType = varTypes[varIdx]
                    varIdxHandled = true
                }
                if not varIdxHandled {
                    // Check if literalValue is a field on 'this'
                    let thisIdx = this.findVar("this")
                    if thisIdx >= 0 {
                        let thisType = varTypes[thisIdx]
                        let fieldType = this.getSeenFieldType(thisType, expr.literalValue)
                        if fieldType != "Int" or expr.literalValue == "length" {
                            receiverType = fieldType
                        }
                    }
                }
            }

            if receiverType != "" {
                let methodRetType = this.getMethodReturnType(receiverType, expr.callee)
                if methodRetType != "" {
                    return methodRetType
                }
            }
        }
        if expr.kind == "Call" {
            // Check for Array constructor - preserve generic parameter
            if expr.callee.startsWith("Array<") {
                return expr.callee  // Return full type like "Array<String>"
            }
            if expr.callee == "Array" {
                return "Array"
            }
            // First check user-defined functions
            let userRetType = this.getFunctionReturnType(expr.callee)
            if userRetType != "" {
                return userRetType
            }
            // Explicit class constructor detection (hardcoded for reliability)
            // AST node types
            if expr.callee == "FunctionNode" or expr.callee == "ClassNode" or expr.callee == "EnumNode" or expr.callee == "BlockNode" or expr.callee == "StatementNode" or expr.callee == "ParserExpressionNode" {
                return expr.callee
            }
            if expr.callee == "ProgramNode" or expr.callee == "ItemNode" or expr.callee == "ImportNode" {
                return expr.callee
            }
            // Compiler infrastructure types
            if expr.callee == "LLVMIRGenerator" or expr.callee == "RealParser" or expr.callee == "SeenLexer" or expr.callee == "TypeChecker" or expr.callee == "Environment" {
                return expr.callee
            }
            if expr.callee == "FrontendResult" or expr.callee == "FrontendDiagnostic" or expr.callee == "TypeInferenceResult" or expr.callee == "TypeError" {
                return expr.callee
            }
            // Data/utility types
            if expr.callee == "Token" or expr.callee == "StringBuilder" or expr.callee == "KeywordManager" {
                return expr.callee
            }
            if expr.callee == "Map" or expr.callee == "Vec" or expr.callee == "VecChunk" or expr.callee == "VecSlot" {
                return expr.callee
            }
            if expr.callee == "FsFile" or expr.callee == "FsFileResult" or expr.callee == "Result" or expr.callee == "Optional" or expr.callee == "Option" {
                return expr.callee
            }
            // Type system types
            if expr.callee == "Type" or expr.callee == "FunctionType" or expr.callee == "ClassType" or expr.callee == "InterfaceType" or expr.callee == "Location" {
                return expr.callee
            }
            // Check if callee is a class constructor (e.g., Expr() -> "Expr")
            if this.isClassType(expr.callee) {
                return expr.callee
            }
            // Result constructors (handle both "Err" and "Err<T, E>" forms)
            if expr.callee == "Err" or expr.callee == "Ok" or expr.callee.startsWith("Err<") or expr.callee.startsWith("Ok<") {
                return "Result"
            }
            // Optional constructors (handle both "Some" and "Some<T>" forms)
            if expr.callee == "Some" or expr.callee == "None" or expr.callee.startsWith("Some<") or expr.callee.startsWith("None<") {
                return "Optional"
            }
            // Then hardcoded runtime functions
            if expr.callee == "readText" {
                return "String"
            }
            if expr.callee == "writeText" {
                return "Bool"
            }
            if expr.callee == "run_frontend" {
                return "FrontendResult"
            }
            if expr.callee == "runCommand" {
                return "CommandResult"
            }
            if expr.callee == "commandWasSuccessful" {
                return "Bool"
            }
            if expr.callee == "args" {
                return "Array<String>"
            }
            if expr.callee == "printUsage" or expr.callee == "printFrontendDiagnostics" {
                return "Void"
            }
            // String utility functions from string.seen
            if expr.callee == "trim" or expr.callee == "trimStart" or expr.callee == "trimEnd" {
                return "String"
            }
            if expr.callee == "split" or expr.callee == "lines" or expr.callee == "words" {
                return "Array<String>"
            }
            if expr.callee == "isBlank" or expr.callee == "isWhitespace" or expr.callee == "startsWith" or expr.callee == "endsWith" or expr.callee == "contains" {
                return "Bool"
            }
            if expr.callee == "indexOf" or expr.callee == "lastIndexOf" {
                return "Int"
            }
            if expr.callee == "padStart" or expr.callee == "padEnd" or expr.callee == "repeat" or expr.callee == "join" {
                return "String"
            }
            if expr.callee == "replaceFirst" or expr.callee == "replaceAll" or expr.callee == "replace" {
                return "String"
            }
            if expr.callee == "removePrefix" or expr.callee == "removeSuffix" {
                return "String"
            }
            if expr.callee == "ensurePrefix" or expr.callee == "ensureSuffix" {
                return "String"
            }
            // LLVMIRGenerator methods called without explicit receiver
            if expr.callee == "mapType" or expr.callee == "getNextReg" or expr.callee == "getNextBlock" or expr.callee == "getNextBlockLabel" or expr.callee == "getFieldType" or expr.callee == "getSeenFieldType" or expr.callee == "getFunctionReturnType" or expr.callee == "getMethodReturnType" or expr.callee == "resolveChainedPathType" or expr.callee == "hexToDecimal" or expr.callee == "escapeString" or expr.callee == "findVarType" or expr.callee == "getMethodName" {
                return "String"
            }
            if expr.callee == "findVar" or expr.callee == "findStruct" or expr.callee == "getFieldInfo" or expr.callee == "findPreallocated" {
                return "Int"
            }
            if expr.callee == "generateExpression" or expr.callee == "generateBinary" or expr.callee == "generateUnary" or expr.callee == "generateMemberAccess" or expr.callee == "generateMethodCall" or expr.callee == "generateCall" or expr.callee == "generateFieldAccess" or expr.callee == "generateIndexAccess" or expr.callee == "generateStructLiteral" or expr.callee == "generateArrayLiteral" or expr.callee == "generateVarExpression" or expr.callee == "generateLiteral" {
                return "String"
            }
            if expr.callee == "isFuncDefinedInModule" {
                return "Bool"
            }
            if expr.callee == "inferExpressionType" {
                return "String"
            }
            // RealParser utility methods (when called without explicit this.)
            if expr.callee == "consume" or expr.callee == "advance" or expr.callee == "previous" or expr.callee == "peek" {
                return "Token"
            }
            if expr.callee == "checkToken" or expr.callee == "matchTokenStr" or expr.callee == "isAtEnd" {
                return "Bool"
            }
            if expr.callee == "peekTokenType" {
                return "Int"
            }
            if expr.callee == "peekTokenTypeStr" or expr.callee == "joinSegments" {
                return "String"
            }
            if expr.callee == "toArray" {
                return "Array<Token>"
            }
            if expr.callee == "parseTypeNode" {
                return "TypeNode"
            }
            if expr.callee == "parseFunctionItem" or expr.callee == "parseClassItem" or expr.callee == "parseEnumItem" or expr.callee == "parseImportItem" {
                return "ItemNode"
            }
            if expr.callee == "parseStatement" or expr.callee == "parseBlock" or expr.callee == "parseIfStatement" or expr.callee == "parseWhileStatement" or expr.callee == "parseForStatement" or expr.callee == "parseExpressionStatement" or expr.callee == "parseLetStatement" or expr.callee == "parseVarStatement" or expr.callee == "parseReturnStatement" or expr.callee == "parseBreakStatement" or expr.callee == "parseContinueStatement" {
                return "StatementNode"
            }
            if expr.callee == "parseExpression" or expr.callee == "parsePrimary" or expr.callee == "parseUnary" or expr.callee == "parseBinary" or expr.callee == "parseOr" or expr.callee == "parseAnd" or expr.callee == "parseEquality" or expr.callee == "parseComparison" or expr.callee == "parseTerm" or expr.callee == "parseFactor" or expr.callee == "parseCall" or expr.callee == "parsePostfix" or expr.callee == "parseAssignment" {
                return "ParserExpressionNode"
            }
            if expr.callee == "parseParam" {
                return "ParamNode"
            }
            if expr.callee == "parseImportPath" {
                return "ImportPathInfo"
            }
            if expr.callee == "parseImportSymbols" {
                return "Array<ImportSymbolNode>"
            }
            if expr.callee == "makeImportSymbol" {
                return "ImportSymbolNode"
            }
            if expr.callee == "TypeError" {
                return "TypeError"
            }
            if expr.callee == "FunctionType" {
                return "FunctionType"
            }
            if expr.callee == "ClassType" {
                return "ClassType"
            }
            if expr.callee == "InterfaceType" {
                return "InterfaceType"
            }
            if expr.callee == "Location" {
                return "Location"
            }
            if expr.callee == "Type" {
                return "Type"
            }
            if expr.callee == "Environment" {
                return "Environment"
            }
            if expr.callee == "lookup" or expr.callee == "typeInt" or expr.callee == "typeFloat" or expr.callee == "typeString" or expr.callee == "typeBool" or expr.callee == "typeVoid" or expr.callee == "typeUnit" or expr.callee == "typeAny" or expr.callee == "typeNever" or expr.callee == "typeUnknown" {
                return "Type"
            }
            if expr.callee == "lookupFunction" {
                return "FunctionType"
            }
            if expr.callee == "lookupClass" {
                return "ClassType"
            }
        }
        if expr.kind == "MemberAccess" {
            // Field access - infer type from known fields
            var fieldName = expr.variableName
            println("[DEBUG inferType] MemberAccess fieldName=" + fieldName + " literalValue=" + expr.literalValue + " operands.len=" + expr.operands.length().toString())

            // Handle chained field names like "program.items" - use the last part
            if fieldName.contains(".") {
                var lastDot = 0
                var fi = 0
                while fi < fieldName.length() {
                    if fieldName.substring(fi, fi + 1) == "." {
                        lastDot = fi
                    }
                    fi = fi + 1
                }
                fieldName = fieldName.substring(lastDot + 1, fieldName.length())
            }

            if fieldName == "success" {
                return "Bool"
            }
            if fieldName == "program" {
                return "ProgramNode"
            }
            if fieldName == "diagnostics" {
                return "Array<FrontendDiagnostic>"
            }
            if fieldName == "output" {
                return "String"
            }
            if fieldName == "severity" or fieldName == "message" or fieldName == "file" or fieldName == "name" or fieldName == "typeName" or fieldName == "variableName" or fieldName == "callee" or fieldName == "operator" or fieldName == "kind" or fieldName == "literalValue" or fieldName == "literalType" {
                return "String"
            }
            if fieldName == "line" or fieldName == "column" {
                return "Int"
            }
            if fieldName == "x" or fieldName == "y" {
                return "Int"
            }
            if fieldName == "items" {
                return "Array<ItemNode>"
            }
            if fieldName == "itemType" {
                return "String"
            }
            if fieldName == "function" {
                return "FunctionNode"
            }
            if fieldName == "classNode" {
                return "ClassNode"
            }
            if fieldName == "importPath" {
                return "Array<String>"
            }
            if fieldName == "methods" {
                return "Array<FunctionNode>"
            }
            if fieldName == "params" {
                return "Array<ParamNode>"
            }
            if fieldName == "fields" {
                return "Array<ParamNode>"
            }
            if fieldName == "statements" {
                return "Array<StatementNode>"
            }
            if fieldName == "operands" or fieldName == "arguments" {
                return "Array<ParserExpressionNode>"
            }
            if fieldName == "body" {
                return "BlockNode"
            }
            if fieldName == "returnType" or fieldName == "variableType" or fieldName == "paramType" {
                return "TypeNode"
            }
            if fieldName == "errors" {
                return "Array<TypeError>"
            }
            if fieldName == "warnings" {
                return "Array<String>"
            }
            if fieldName == "initializer" or fieldName == "returnValue" or fieldName == "condition" or fieldName == "loopVariable" or fieldName == "loopIterable" {
                return "ParserExpressionNode"
            }
            if fieldName == "loopBody" or fieldName == "elseBody" or fieldName == "thenBody" {
                return "BlockNode"
            }
            // Try to get type from receiver
            var memberAccessResolved = false
            if expr.operands.length() > 0 {
                let recvType = this.inferExpressionType(expr.operands[0])
                let fieldType = this.getSeenFieldType(recvType, fieldName)
                if fieldType != "Int" or fieldName == "length" or fieldName == "line" or fieldName == "column" {
                    return fieldType
                }
                memberAccessResolved = true
            }
            if not memberAccessResolved and expr.literalValue != "" {
                // Receiver is a variable name in literalValue
                // Handle chained paths like "item.function.returnType"
                if expr.literalValue.contains(".") {
                    // Recursively resolve the type of the chained path
                    let chainedType = this.resolveChainedPathType(expr.literalValue)
                    if chainedType != "" and chainedType != "Int" {
                        let fieldType = this.getSeenFieldType(chainedType, fieldName)
                        if fieldType != "Int" or fieldName == "length" or fieldName == "line" or fieldName == "column" {
                            return fieldType
                        }
                    }
                }
                let recvVarType = this.findVarType(expr.literalValue)
                if recvVarType != "" {
                    let fieldType = this.getSeenFieldType(recvVarType, fieldName)
                    if fieldType != "Int" or fieldName == "length" or fieldName == "line" or fieldName == "column" {
                        return fieldType
                    }
                }
            }
        }
        if expr.kind == "StructLiteral" {
            // Struct literal - return the struct type name
            return expr.literalType
        }
        if expr.kind == "IndexAccess" {
            // Array indexing - return element type
            let arrayType = this.inferExpressionType(expr.operands[0])
            if arrayType == "Array<FrontendDiagnostic>" {
                return "FrontendDiagnostic"
            }
            if arrayType == "Array<String>" {
                return "String"
            }
            if arrayType == "Array<Int>" {
                return "Int"
            }
            if arrayType == "Array<ItemNode>" {
                return "ItemNode"
            }
            if arrayType == "Array<ProgramNode>" {
                return "ProgramNode"
            }
            if arrayType == "Array<FunctionNode>" {
                return "FunctionNode"
            }
            if arrayType == "Array<ParamNode>" {
                return "ParamNode"
            }
            if arrayType == "Array<StatementNode>" {
                return "StatementNode"
            }
            if arrayType == "Array<ParserExpressionNode>" {
                return "ParserExpressionNode"
            }
            if arrayType == "Array<TypeError>" {
                return "TypeError"
            }
            if arrayType == "Array<ParamNode>" {
                return "ParamNode"
            }
            if arrayType == "Array<ClassNode>" {
                return "ClassNode"
            }
            if arrayType == "Array<BlockNode>" {
                return "BlockNode"
            }
            // Generic fallback: parse Array<T> to extract T
            if arrayType.startsWith("Array<") and arrayType.endsWith(">") {
                let elementType = arrayType.substring(6, arrayType.length() - 1)
                println("[DEBUG inferType] IndexAccess generic fallback: arrayType=" + arrayType + " elementType=" + elementType)
                return elementType
            }
            println("[DEBUG inferType] IndexAccess returning ptr for arrayType=" + arrayType)
            return "ptr"  // Default for unknown array types
        }
        if expr.kind == "ArrayLiteral" {
            // Array literal - return "Array" (parser strips generic params)
            return "Array"
        }
        if expr.kind == "StructLiteral" {
            if expr.literalType != "" {
                return expr.literalType
            }
            return "ptr"
        }
        if expr.kind == "Unary" {
            // Unary operators
            if expr.operator == "!" or expr.operator == "not" {
                return "Bool"
            }
            // Unary minus returns same type as operand (default Int)
            return "Int"
        }
        return "Int"
    }

    fun escapeString(str: String) r: String {
        var result = ""
        var i = 0
        while i < str.length() {
            let c = str.substring(i, i + 1)
            var charHandled = false
            if c == "\\" {
                result = result + "\\\\"
                charHandled = true
            }
            if not charHandled and c == "\"" {
                // LLVM IR uses hex escapes, not \" - quote is ASCII 34 = 0x22
                result = result + "\\22"
                charHandled = true
            }
            if not charHandled and c == "\n" {
                result = result + "\\0A"
                charHandled = true
            }
            if not charHandled and c == "\t" {
                result = result + "\\09"
                charHandled = true
            }
            if not charHandled and c == "\r" {
                result = result + "\\0D"
                charHandled = true
            }
            if not charHandled {
                result = result + c
            }
            i = i + 1
        }
        return result
    }

    fun charToCodeStr(val: String) r: String {
        if val.length() == 0 { return "0" }
        if val == " " { return "32" }
        if val == "\t" { return "9" }
        if val == "\n" { return "10" }
        if val == "\r" { return "13" }
        if val == "0" { return "48" }
        if val == "1" { return "49" }
        if val == "2" { return "50" }
        if val == "3" { return "51" }
        if val == "4" { return "52" }
        if val == "5" { return "53" }
        if val == "6" { return "54" }
        if val == "7" { return "55" }
        if val == "8" { return "56" }
        if val == "9" { return "57" }
        if val == "a" { return "97" }
        if val == "b" { return "98" }
        if val == "c" { return "99" }
        if val == "d" { return "100" }
        if val == "e" { return "101" }
        if val == "f" { return "102" }
        if val == "g" { return "103" }
        if val == "h" { return "104" }
        if val == "i" { return "105" }
        if val == "j" { return "106" }
        if val == "k" { return "107" }
        if val == "l" { return "108" }
        if val == "m" { return "109" }
        if val == "n" { return "110" }
        if val == "o" { return "111" }
        if val == "p" { return "112" }
        if val == "q" { return "113" }
        if val == "r" { return "114" }
        if val == "s" { return "115" }
        if val == "t" { return "116" }
        if val == "u" { return "117" }
        if val == "v" { return "118" }
        if val == "w" { return "119" }
        if val == "x" { return "120" }
        if val == "y" { return "121" }
        if val == "z" { return "122" }
        if val == "A" { return "65" }
        if val == "B" { return "66" }
        if val == "C" { return "67" }
        if val == "D" { return "68" }
        if val == "E" { return "69" }
        if val == "F" { return "70" }
        if val == "G" { return "71" }
        if val == "H" { return "72" }
        if val == "I" { return "73" }
        if val == "J" { return "74" }
        if val == "K" { return "75" }
        if val == "L" { return "76" }
        if val == "M" { return "77" }
        if val == "N" { return "78" }
        if val == "O" { return "79" }
        if val == "P" { return "80" }
        if val == "Q" { return "81" }
        if val == "R" { return "82" }
        if val == "S" { return "83" }
        if val == "T" { return "84" }
        if val == "U" { return "85" }
        if val == "V" { return "86" }
        if val == "W" { return "87" }
        if val == "X" { return "88" }
        if val == "Y" { return "89" }
        if val == "Z" { return "90" }
        if val == "'" { return "39" }
        if val == "\"" { return "34" }
        if val == "\\" { return "92" }
        if val == "/" { return "47" }
        if val == "." { return "46" }
        if val == "," { return "44" }
        if val == ":" { return "58" }
        if val == ";" { return "59" }
        if val == "!" { return "33" }
        if val == "?" { return "63" }
        if val == "@" { return "64" }
        if val == "#" { return "35" }
        if val == "$" { return "36" }
        if val == "%" { return "37" }
        if val == "^" { return "94" }
        if val == "&" { return "38" }
        if val == "*" { return "42" }
        if val == "(" { return "40" }
        if val == ")" { return "41" }
        if val == "[" { return "91" }
        if val == "]" { return "93" }
        if val == "{" { return "123" }
        if val == "}" { return "125" }
        if val == "<" { return "60" }
        if val == ">" { return "62" }
        if val == "=" { return "61" }
        if val == "+" { return "43" }
        if val == "-" { return "45" }
        if val == "_" { return "95" }
        if val == "|" { return "124" }
        if val == "~" { return "126" }
        if val == "`" { return "96" }
        return "0"
    }

    fun collectStringConstants(program: ProgramNode) r: Void {
        var i = 0
        while i < program.items.length() {
            let item = program.items[i]
            if item.itemType == "Function" {
                this.collectStringConstantsFromBlock(item.function.body)
            }
            if item.itemType == "Class" {
                // Collect strings from class method bodies
                var mi = 0
                while mi < item.classNode.methods.length() {
                    this.collectStringConstantsFromBlock(item.classNode.methods[mi].body)
                    mi = mi + 1
                }
            }
            i = i + 1
        }
    }

    fun collectStringConstantsFromBlock(block: BlockNode) r: Void {
        var i = 0
        while i < block.statements.length() {
            collectStringConstantsFromStatement(block.statements[i])
            i = i + 1
        }
    }

    fun collectStringConstantsFromStatement(stmt: StatementNode) r: Void {
        if stmt.kind == "Let" or stmt.kind == "Var" {
            this.collectStringConstantsFromExpr(stmt.initializer)
        }
        if stmt.kind == "Return" {
            this.collectStringConstantsFromExpr(stmt.returnValue)
        }
        if stmt.kind == "Expression" {
            this.collectStringConstantsFromExpr(stmt.expression)
        }
        if stmt.kind == "If" {
            this.collectStringConstantsFromExpr(stmt.condition)
            this.collectStringConstantsFromBlock(stmt.thenBranch)
            this.collectStringConstantsFromBlock(stmt.elseBranch)
        }
        if stmt.kind == "While" {
            this.collectStringConstantsFromExpr(stmt.loopCondition)
            this.collectStringConstantsFromBlock(stmt.loopBody)
        }
        if stmt.kind == "Assignment" {
            this.collectStringConstantsFromExpr(stmt.initializer)
        }
        // Also check the expression for MemberAssignment/IndexAssignment
        if stmt.expression.kind != "" {
            this.collectStringConstantsFromExpr(stmt.expression)
        }
    }

    fun collectStringConstantsFromExpr(expr: ParserExpressionNode) r: Void {
        if expr.kind == "Literal" and expr.literalType == "String" {
            // Check if already in constants
            var found = false
            var i = 0
            while i < stringConstants.length() {
                if stringConstants[i] == expr.literalValue {
                    found = true
                    break
                }
                i = i + 1
            }
            if not found {
                stringConstants.push(expr.literalValue)
            }
        }
        if expr.kind == "Binary" {
            var i = 0
            while i < expr.operands.length() {
                this.collectStringConstantsFromExpr(expr.operands[i])
                i = i + 1
            }
        }
        if expr.kind == "Call" or expr.kind == "MethodCall" {
            var i = 0
            while i < expr.arguments.length() {
                this.collectStringConstantsFromExpr(expr.arguments[i])
                i = i + 1
            }
            // Also check operands for chained method calls
            i = 0
            while i < expr.operands.length() {
                this.collectStringConstantsFromExpr(expr.operands[i])
                i = i + 1
            }
        }
        if expr.kind == "StructLiteral" {
            // Collect strings from struct field initializers
            var i = 0
            while i < expr.arguments.length() {
                let fieldExpr = expr.arguments[i]
                if fieldExpr.operands.length() > 0 {
                    this.collectStringConstantsFromExpr(fieldExpr.operands[0])
                }
                i = i + 1
            }
        }
        if expr.kind == "Unary" {
            if expr.operands.length() > 0 {
                this.collectStringConstantsFromExpr(expr.operands[0])
            }
        }
        if expr.kind == "Assignment" {
            // Handle assignment expressions - collect from the right-hand side value
            // Parser stores: variableName = target, operands[0] = value
            if expr.operands.length() > 0 {
                this.collectStringConstantsFromExpr(expr.operands[0])
            }
        }
        if expr.kind == "MemberAssignment" or expr.kind == "IndexAssignment" {
            // MemberAssignment: operands[0] = lhs (MemberAccess), operands[1] = rhs value
            // IndexAssignment: operands[0] = lhs (IndexAccess), operands[1] = rhs value
            var i = 0
            while i < expr.operands.length() {
                this.collectStringConstantsFromExpr(expr.operands[i])
                i = i + 1
            }
        }
        if expr.kind == "MemberAccess" or expr.kind == "IndexAccess" {
            // Recursively handle operands for chained access
            var i = 0
            while i < expr.operands.length() {
                this.collectStringConstantsFromExpr(expr.operands[i])
                i = i + 1
            }
        }
    }
}
