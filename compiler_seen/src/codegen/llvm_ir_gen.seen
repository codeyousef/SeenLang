        }
        if not isFuncDefinedInModule("typeBool", definedFuncs) {
            output.append("declare ptr @typeBool()\n")
        }
        if not isFuncDefinedInModule("typeVoid", definedFuncs) {
            output.append("declare ptr @typeVoid()\n")
        }
        if not isFuncDefinedInModule("typeUnit", definedFuncs) {
            output.append("declare ptr @typeUnit()\n")
        }
        if not isFuncDefinedInModule("typeAny", definedFuncs) {
            output.append("declare ptr @typeAny()\n")
        }
