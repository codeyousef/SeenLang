///
Public LLVM IR generator facade.

Most lowering work now lives in focused `ir_*` modules. This class stays as
the compatibility surface for older call sites and for bootstrap builds that
still pass the generator around as an object. Keep orchestration and state
bridging here; put new lowering rules in the extracted modules.
///
import parser.real_parser.{ProgramNode, FunctionNode, ClassNode, BlockNode, StatementNode, ParserExpressionNode}
import str.string.{StringBuilder}
import codegen.ir_module_driver.{generateMultipleState, generateSingleState, emitMultipleState, emitSingleState}
import codegen.ir_call_args_driver.{prepareCallArgumentsWithDefaultsState}
import codegen.ir_call_driver.{generateCallWithGlobalState}
import codegen.ir_enum_ctor_gen.{generateEnumConstructorState}
import codegen.ir_class_driver.{generateClassState}
import codegen.ir_program_driver.{emitProgramTopLevelFunctionsState}
import codegen.ir_stmt_var_collect_driver.{collectVariableDeclarationsState}
import codegen.ir_stmt_driver.{generateStatementWithGlobalState}
import codegen.ir_class_method_driver.{generateClassMethodFromListState}
import codegen.ir_codegen_state.{FunctionLoweringOptions, getSharedCodegenState}
import codegen.ir_function_driver.{generateFunctionState}
import codegen.ir_block_driver.{generateBlockWithGlobalState}
import codegen.ir_generator_config_driver.{setGeneratorTypeHeaderPathState}
import codegen.ir_codegen_state_bridge.{captureCodegenStateBridgeSnapshotImpl, resetSharedModuleGenerationScratchAndGlobalsImpl}
import codegen.ir_codegen_bootstrap_state.{initBootstrapFragileGlobalArrays}
import codegen.ir_codegen_reset_state.{resetLLVMIRGeneratorModuleStateImpl}
import codegen.ir_codegen_target_state.{overrideTargetTripleImpl}
import codegen.ir_codegen_global_state.{getBlockTerminatedWithGlobalStateImpl, setBlockTerminatedWithGlobalStateImpl, syncCodegenStateFromGlobalStateImpl, applyGlobalCodegenStateBridgeSnapshotImpl}
import codegen.ir_codegen_feature_state.{g_reprCClassNames, g_moveOnlyClasses, g_funcDefaultsArr, g_funcParamCountArr, g_dynParamFuncs, g_floatParamFuncNames, g_floatParamParamIdxs, g_binaryClassNames, g_binaryEndianness, g_binaryVersions, g_binaryClassCount, g_typeAliasNames, g_typeAliasTargets, g_typeAliasCount, g_enumTypeNames, g_enumVariantNames, g_enumVariantTags, g_enumVariantFieldTypes, g_enumVariantFieldCounts, g_enumVariantCount, setPanicOnOverflowStateImpl, setBoundsCheckEnabledStateImpl, setWarnUnusedResultStateImpl, setNullSafetyEnabledStateImpl, setUninitCheckEnabledStateImpl, setStackCheckEnabledStateImpl, setSanitizerModeStateImpl, setEnabledFeaturesStateImpl, getFeatureRegBoxImpl, getFeatureBlockBoxImpl}
import codegen.ir_decl_registration_driver.{registerDeclarationsState}
import codegen.ir_expr_driver.{generateExpressionWithGlobalState}
import codegen.ir_expr_type_driver.{inferExpressionTypeState}

fun overrideTargetTriple(triple: String, layout: String) r: Void { overrideTargetTripleImpl(triple, layout) }
fun getCurrentFunctionOptions() r: FunctionLoweringOptions { return getSharedCodegenState().functionOptions }

class LLVMIRGenerator {
    var output: StringBuilder
    var stringConstants: Array<String>
    var nextReg: Int
    var nextBlock: Int
    // Parallel arrays keep this bootstrap-fragile state layout stable.
    var varNames: Array<String>
    var varRegs: Array<String>
    var varTypes: Array<String>
    var indent: Int
    static fun new() r: LLVMIRGenerator {
        initBootstrapFragileGlobalArrays()
        let gen = LLVMIRGenerator{
            output: StringBuilder.new(),
            stringConstants: Array<String>(),
            nextReg: 1,
            nextBlock: 0,
            varNames: Array<String>(),
            varRegs: Array<String>(),
            varTypes: Array<String>(),
            indent: 0
        }
        gen.reset()
        return gen
    }

    fun setTypeHeaderPath(path: String) r: Void { setGeneratorTypeHeaderPathState(path) }
    fun setPanicOnOverflow(enabled: Bool) r: Void { setPanicOnOverflowStateImpl(enabled) }
    fun setBoundsCheckEnabled(enabled: Int) r: Void { setBoundsCheckEnabledStateImpl(enabled) }
    fun setWarnUnusedResult(enabled: Int) r: Void { setWarnUnusedResultStateImpl(enabled) }
    fun setNullSafetyEnabled(enabled: Int) r: Void { setNullSafetyEnabledStateImpl(enabled) }
    fun setUninitCheckEnabled(enabled: Int) r: Void { setUninitCheckEnabledStateImpl(enabled) }
    fun setStackCheckEnabled(enabled: Int) r: Void { setStackCheckEnabledStateImpl(enabled) }
    fun setSanitizerMode(mode: String) r: Void { setSanitizerModeStateImpl(mode) }
    fun setEnabledFeatures(features: String) r: Void { setEnabledFeaturesStateImpl(features) }

    fun reset() r: Void {
        let resetState = resetLLVMIRGeneratorModuleStateImpl(
            getCurrentFunctionOptions())
        this.output = resetState.output
        this.stringConstants = resetState.stringConstants
        this.varNames = resetState.varNames
        this.varRegs = resetState.varRegs
        this.varTypes = resetState.varTypes
        nextReg = resetState.nextReg
        nextBlock = resetState.nextBlock
        this.indent = resetState.indent
    }

    fun isBlockTerminated() r: Bool { return getBlockTerminatedWithGlobalStateImpl() }
    fun setBlockTerminated(value: Bool) r: Void { setBlockTerminatedWithGlobalStateImpl(value) }

    ///
    Push facade-owned buffers into the shared state used by extracted helpers.
    The bridge keeps the old object API alive while the implementation works
    through explicit state modules.
    ///
    fun syncState() r: Void {
        let state = getSharedCodegenState()
        // Legacy layout field only. FunctionLoweringOptions is the source of truth.
        this.indent = 0
        syncCodegenStateFromGlobalStateImpl(state, this.output,
            this.stringConstants, getFeatureRegBoxImpl(),
            getFeatureBlockBoxImpl(), this.varNames, this.varRegs,
            this.varTypes, getCurrentFunctionOptions())
    }

    ///
    Pull helper-owned buffers back into the facade after nested lowering.
    Any helper that calls through `CodegenLoweringContext` should leave the
    facade consistent before returning to legacy callers.
    ///
    fun writeBackState() r: Void {
        let state = getSharedCodegenState()
        let snapshot = captureCodegenStateBridgeSnapshotImpl(state)
        this.output = snapshot.output
        this.stringConstants = snapshot.stringConstants
        this.varNames = snapshot.varNames
        this.varRegs = snapshot.varRegs
        this.varTypes = snapshot.varTypes
        applyGlobalCodegenStateBridgeSnapshotImpl(snapshot)
        this.indent = 0
    }

    fun registerDeclarations(program: ProgramNode) r: Void { registerDeclarationsState(program, this.varNames, this.varTypes, this.stringConstants) }

    // Single-module entry point: wraps generateMultiple with one program.
    fun generate(program: ProgramNode) r: String {
        // Single module compilation
        let programs = Array<ProgramNode>()
        programs.push(program)
        return generateMultiple(programs)
    }

    fun resetSharedModuleGenerationScratchState() r: Void {
        let scratchState = resetSharedModuleGenerationScratchAndGlobalsImpl()
        this.output = scratchState.output
        this.stringConstants = scratchState.stringConstants
    }

    fun generateMultiple(programs: Array<ProgramNode>) r: String {
        resetSharedModuleGenerationScratchState()
        return generateMultipleState(this as Int, this.output,
            this.stringConstants, programs)
    }

    fun generateMultipleToFile(programs: Array<ProgramNode>, outputPath: String)
        r: Bool {

        resetSharedModuleGenerationScratchState()
        emitMultipleState(this as Int, this.output, this.stringConstants,
            programs)
        return this.output.writeToFile(outputPath)
    }

    fun generateSingle(program: ProgramNode, moduleIndex: Int) r: String {
        reset()
        resetSharedModuleGenerationScratchState()
        return generateSingleState(this as Int, this.output,
            this.stringConstants, program, moduleIndex)
    }

    fun generateSingleToFile(program: ProgramNode, moduleIndex: Int,
        outputPath: String) r: Bool {

        reset()
        resetSharedModuleGenerationScratchState()
        emitSingleState(this as Int, this.output, this.stringConstants,
            program, moduleIndex)
        return this.output.writeToFile(outputPath)
    }
    fun generateExpression(expr: ParserExpressionNode) r: String { return generateExpressionWithGlobalState(this as Int, this.output, expr, this.varNames, this.varRegs, this.varTypes, this.stringConstants) }
    ///
    Lower an expression into caller-owned scratch buffers. This is used by
    nested contexts such as constructor fields and short-circuit branches where
    emitting into the main function buffer too early would corrupt control flow.
    ///
    fun generateExpressionIntoCallback(outputOverride: StringBuilder,
        expr: ParserExpressionNode, varNamesOverride: Array<String>,
        varRegsOverride: Array<String>, varTypesOverride: Array<String>,
        stringConstantsOverride: Array<String>) r: String {

        this.output = outputOverride
        this.varNames = varNamesOverride
        this.varRegs = varRegsOverride
        this.varTypes = varTypesOverride
        this.stringConstants = stringConstantsOverride
        return generateExpressionWithGlobalState(this as Int, this.output,
            expr, this.varNames, this.varRegs, this.varTypes,
            this.stringConstants)
    }
    fun generateCall(expr: ParserExpressionNode) r: String { return generateCallWithGlobalState(this as Int, this.output, expr, this.varNames, this.varRegs, this.varTypes, this.stringConstants) }
    fun inferExpressionType(expr: ParserExpressionNode) r: String { return inferExpressionTypeState(expr, this.varNames, this.varTypes, this.stringConstants) }

    fun prepareLoweredCallArgumentsWithDefaultsCallback(funcName: String, arguments: Array<ParserExpressionNode>, enableDynBoxing: Bool, enableFloatPromotion: Bool, nullifyMovedSources: Bool, moveContext: String) r: Void {
        prepareCallArgumentsWithDefaultsState(this as Int, this.output, funcName, arguments, enableDynBoxing, enableFloatPromotion, nullifyMovedSources, moveContext, this.varNames, this.varRegs, this.varTypes, this.stringConstants)
    }
    fun lowerEnumConstructorCallback(variantName: String, expr: ParserExpressionNode) r: String { return generateEnumConstructorState(this as Int, this.output, variantName, expr, g_enumVariantNames, g_enumVariantTags, g_enumVariantFieldTypes, g_enumVariantFieldCounts, g_enumVariantCount) }
    fun lowerProgramTopLevelFunctionsCallback(program: ProgramNode, moduleIndex: Int, traceModule: Bool) r: Void { emitProgramTopLevelFunctionsState(this as Int, this.output, program, moduleIndex, traceModule) }
    fun lowerClassNodeCallback(classNode: ClassNode) r: Void { generateClassState(this as Int, this.output, classNode, this.varNames, this.varRegs, this.varTypes, this.stringConstants, g_reprCClassNames, g_typeAliasNames, g_typeAliasTargets, g_typeAliasCount, g_enumTypeNames, g_binaryClassNames, g_binaryVersions, g_binaryEndianness, g_binaryClassCount) }
    fun lowerFunctionNodeCallback(fn: FunctionNode) r: Void { generateFunctionState(this as Int, this.output, fn, this.varNames, this.varTypes, this.stringConstants) }
    fun lowerClassMethodFromListCallback(className: String, parentName: String, methods: Array<FunctionNode>, methodIdx: Int) r: Void { generateClassMethodFromListState(this as Int, this.output, className, parentName, methods, methodIdx, this.varNames, this.varRegs, this.varTypes, this.stringConstants) }
    fun collectLoweringVariableDeclarationsCallback(block: BlockNode) r: Void { collectVariableDeclarationsState(block, this.varNames, this.varTypes, this.stringConstants) }
    fun lowerBlockCallback(block: BlockNode) r: Void { generateBlockWithGlobalState(this as Int, this.output, block, this.varNames) }
    fun lowerStatementCallback(stmt: StatementNode) r: Void { generateStatementWithGlobalState(this as Int, this.output, stmt, this.varNames, this.varRegs, this.varTypes, this.stringConstants) }
}

fun newLLVMIRGenerator() r: LLVMIRGenerator {
    return LLVMIRGenerator.new()
}
