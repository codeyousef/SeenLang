// LLVM IR Generator - Generates LLVM IR text from ProgramNode
// This replaces the C generator for Stage1 compilation

import parser.real_parser.{ProgramNode, ItemNode, FunctionNode, ClassNode, BlockNode, StatementNode, ParserExpressionNode, ParamNode, TypeNode}
import str.string.{StringBuilder}

class LLVMIRGenerator {
    var output: StringBuilder
    var stringConstants: Array<String>
    var nextReg: Int
    var nextBlock: Int
    // Using parallel arrays as workaround for Map.get() bug
    var varNames: Array<String>
    var varRegs: Array<String>
    var varTypes: Array<String>
    var indent: Int
    // Struct layout registry - parallel arrays for struct info
    var structNames: Array<String>        // Struct/class names
    var structLayouts: Array<String>      // LLVM struct layout strings
    var structFieldNames: Array<String>   // Comma-separated field names
    var structFieldTypes: Array<String>   // Comma-separated field type names
    var structSizes: Array<Int>           // Struct sizes in bytes
    var structMethodNames: Array<String>  // Comma-separated method names
    var structMethodRetTypes: Array<String> // Comma-separated method return types
    // Function registry - track user-defined function return types
    var funcNames: Array<String>           // Function names
    var funcRetTypes: Array<String>        // Function return types
    // Current function context
    var currentFunctionReturnType: String
    var blockTerminated: Bool  // Track if current block has a terminator
    // Pre-allocated variable names and types (for hoisting allocas to entry block)
    var preAllocatedVars: Array<String>
    var preAllocatedTypes: Array<String>
    // Module prefix for per-module compilation (empty for multi-module)
    var stringConstantPrefix: String
    // Track which functions have been emitted in current module (reset per-module)
    var generatedFunctions: Array<String>

    static fun new() r: LLVMIRGenerator {
        return LLVMIRGenerator{
            output: StringBuilder.new(),
            stringConstants: Array<String>(),
            nextReg: 1,
            nextBlock: 0,
            varNames: Array<String>(),
            varRegs: Array<String>(),
            varTypes: Array<String>(),
            indent: 0,
            structNames: Array<String>(),
            structLayouts: Array<String>(),
            structFieldNames: Array<String>(),
            structFieldTypes: Array<String>(),
            structSizes: Array<Int>(),
            structMethodNames: Array<String>(),
            structMethodRetTypes: Array<String>(),
            funcNames: Array<String>(),
            funcRetTypes: Array<String>(),
            currentFunctionReturnType: "",
            blockTerminated: false,
            preAllocatedVars: Array<String>(),
            preAllocatedTypes: Array<String>(),
            stringConstantPrefix: "",
            generatedFunctions: Array<String>()
        }
    }

    // Reset generator state for per-module compilation (keeps struct/func registries)
    fun reset() r: Void {
        output = StringBuilder.new()
        stringConstants = Array<String>()
        varNames = Array<String>()
        varRegs = Array<String>()
        varTypes = Array<String>()
        nextReg = 1
        nextBlock = 0
        currentFunctionReturnType = ""
        blockTerminated = false
        preAllocatedVars = Array<String>()
        preAllocatedTypes = Array<String>()
        stringConstantPrefix = ""
        generatedFunctions = Array<String>()
        // Keep struct/func registries for cross-module references
    }

    // Register all declarations from a program without keeping the AST
    // Used in Pass 1 to populate registries for cross-module references
    fun registerDeclarations(program: ProgramNode) r: Void {
        var i = 0
        while i < program.items.length() {
            let item = program.items[i]

            if item.itemType == "Class" {
                // Register struct layout (fields)
                registerStructLayout(item.classNode)

                // Also register class methods as functions
                var mi = 0
                while mi < item.classNode.methods.length() {
                    let method = item.classNode.methods[mi]
                    let mangledName = item.classNode.name + "_" + method.name
                    registerFunction(mangledName, method.returnType.typeName)
                    mi = mi + 1
                }
            }

            if item.itemType == "Function" {
                // Register function signature
                registerFunction(item.function.name, item.function.returnType.typeName)
            }

            i = i + 1
        }
    }

    // Register a user-defined function's return type
    fun registerFunction(name: String, retType: String) r: Void {
        funcNames.push(name)
        funcRetTypes.push(retType)
    }

    // Look up a user-defined function's return type
    fun getFunctionReturnType(name: String) r: String {
        let len = funcNames.length()
        var i = 0
        while i < len {
            let current = funcNames[i]
            if current == name {
                return funcRetTypes[i]
            }
            i = i + 1
        }
        return ""  // Not found
    }

    // Convert a hex string value (like "0x00C0") to decimal string
    fun hexToDecimal(value: String) r: String {
        let len = value.length()
        if len < 3 {
            return value  // Too short to be hex
        }
        // Check for 0x or 0X prefix
        let firstChar = value.substring(0, 1)
        let secondChar = value.substring(1, 2)
        if firstChar != "0" {
            return value  // Not hex
        }
        if secondChar != "x" and secondChar != "X" {
            return value  // Not hex
        }

        // Parse hex digits
        var result = 0
        var i = 2
        while i < len {
            let c = value.substring(i, i + 1)
            var digit = 0
            if c == "0" { digit = 0 }
            else if c == "1" { digit = 1 }
            else if c == "2" { digit = 2 }
            else if c == "3" { digit = 3 }
            else if c == "4" { digit = 4 }
            else if c == "5" { digit = 5 }
            else if c == "6" { digit = 6 }
            else if c == "7" { digit = 7 }
            else if c == "8" { digit = 8 }
            else if c == "9" { digit = 9 }
            else if c == "a" or c == "A" { digit = 10 }
            else if c == "b" or c == "B" { digit = 11 }
            else if c == "c" or c == "C" { digit = 12 }
            else if c == "d" or c == "D" { digit = 13 }
            else if c == "e" or c == "E" { digit = 14 }
            else if c == "f" or c == "F" { digit = 15 }
            result = result * 16 + digit
            i = i + 1
        }
        return result.toString()
    }

    // Helper to store variable
    fun storeVar(name: String, reg: String, varType: String) r: Void {
        varNames.push(name)
        varRegs.push(reg)
        varTypes.push(varType)
    }

    // Helper to find variable
    fun findVar(name: String) r: Int {
        let len = varNames.length()
        var i = 0
        while i < len {
            let current = varNames[i]
            if current == name {
                return i
            }
            i = i + 1
        }
        return -1
    }

    // Helper to find variable type (checks both varTypes and preAllocatedTypes)
    // Used during type inference where we need to know variable types
    fun findVarType(name: String) r: String {
        // First check active variables
        let idx = findVar(name)
        if idx >= 0 {
            return varTypes[idx]
        }
        // Then check pre-allocated variables (during collection phase)
        var i = 0
        while i < preAllocatedVars.length() {
            if preAllocatedVars[i] == name {
                return preAllocatedTypes[i]
            }
            i = i + 1
        }
        return ""  // Not found
    }

    // Helper to find struct layout index
    fun findStruct(name: String) r: Int {
        let len = structNames.length()
        var i = 0
        while i < len {
            if structNames[i] == name {
                return i
            }
            i = i + 1
        }
        return -1
    }

    // Collect all variable declarations from a block (recursively)
    // Stores names and types in preAllocatedVars/preAllocatedTypes
    fun collectVariableDeclarations(block: BlockNode) r: Void {
        var i = 0
        while i < block.statements.length() {
            let stmt = block.statements[i]
            if stmt.kind == "Let" or stmt.kind == "Var" {
                // Determine type - explicit or inferred
                var varType = stmt.variableType.typeName
                println("[DEBUG collectVar] " + stmt.variableName + " explicit type=" + varType + " init.kind=" + stmt.initializer.kind + " init.litVal=" + stmt.initializer.literalValue)
                if varType == "" or varType == "Unknown" {
                    // Try to infer from initializer
                    if stmt.initializer.kind != "None" and stmt.initializer.kind != "" {
                        println("[DEBUG collectVar] " + stmt.variableName + " init.callee=" + stmt.initializer.callee + " literalType=" + stmt.initializer.literalType)
                        varType = inferExpressionType(stmt.initializer)
                        println("[DEBUG collectVar] " + stmt.variableName + " inferred=" + varType)
                    } else if stmt.initializer.kind == "None" and stmt.initializer.literalValue != "" {
                        // Fallback: check literalValue for string-like initialization
                        if stmt.initializer.literalValue.startsWith("\"") or stmt.initializer.literalValue.startsWith("'") {
                            varType = "String"
                            println("[DEBUG collectVar] " + stmt.variableName + " inferred from literalValue=String")
                        } else if stmt.initializer.literalValue == "true" or stmt.initializer.literalValue == "false" {
                            varType = "Bool"
                        }
                    }
                }
                // Default to i64 if still unknown
                if varType == "" or varType == "Unknown" {
                    // Workaround: infer type from known variable name patterns
                    if stmt.variableName == "layout" or stmt.variableName == "structLayout" or stmt.variableName == "fieldType" or stmt.variableName == "fieldName" or stmt.variableName == "funcName" or stmt.variableName == "className" or stmt.variableName == "methodName" or stmt.variableName == "paramName" or stmt.variableName == "llvmType" or stmt.variableName == "seenType" or stmt.variableName.endsWith("Names") or stmt.variableName.endsWith("Types") or stmt.variableName.endsWith("Name") or stmt.variableName.endsWith("Type") or stmt.variableName.endsWith("Str") {
                        varType = "String"
                        println("[DEBUG collectVar] " + stmt.variableName + " inferred from name pattern=String")
                    } else {
                        varType = "Int"
                    }
                }
                // Add to pre-allocated lists
                preAllocatedVars.push(stmt.variableName)
                preAllocatedTypes.push(varType)
            } else if stmt.kind == "If" {
                // Recurse into then/else branches
                collectVariableDeclarations(stmt.thenBranch)
                if stmt.elseBranch.statements.length() > 0 {
                    collectVariableDeclarations(stmt.elseBranch)
                }
            } else if stmt.kind == "While" {
                // Recurse into while body
                collectVariableDeclarations(stmt.loopBody)
            } else if stmt.kind == "For" {
                // For loop may have iterator variable and body
                collectVariableDeclarations(stmt.loopBody)
            }
            i = i + 1
        }
    }

    // Check if a variable has been pre-allocated, return its index or -1
    fun findPreAllocated(name: String) r: Int {
        var i = 0
        while i < preAllocatedVars.length() {
            if preAllocatedVars[i] == name {
                return i
            }
            i = i + 1
        }
        return -1
    }

    // Emit allocas for all pre-allocated variables at function entry
    // This ensures all allocas are in the entry block, avoiding domination errors
    fun emitPreAllocatedAllocas() r: Void {
        var i = 0
        while i < preAllocatedVars.length() {
            let varName = preAllocatedVars[i]
            let varType = preAllocatedTypes[i]
            let llvmType = mapType(varType)
            let reg = getNextReg()
            output.append("  " + reg + " = alloca " + llvmType + "\n")
            // Store the mapping for later use
            storeVar(varName, reg, varType)
            i = i + 1
        }
    }

    // Get size of a Seen type in bytes
    fun getTypeSize(typeName: String) r: Int {
        if typeName == "Int" {
            return 8
        } else if typeName == "Bool" or typeName == "Boolean" {
            return 1  // But aligned to 8 in structs typically
        } else if typeName == "Float" {
            return 8
        } else if typeName == "String" {
            return 16  // %SeenString = { i64, ptr } = 8 + 8
        } else if typeName.startsWith("Array<") {
            return 24  // %SeenArray = { i64, i64, ptr } = 8 + 8 + 8
        }
        // All other types (classes, structs) are pointers = 8 bytes
        return 8
    }

    // Register a struct layout from a ClassNode
    fun registerStructLayout(classNode: ClassNode) r: Void {
        // Check if already registered
        if findStruct(classNode.name) >= 0 {
            return
        }

        // Build the layout from fields
        var layout = "{ "
        var fieldNames = ""
        var fieldTypes = ""
        var totalSize = 0

        var i = 0
        while i < classNode.fields.length() {
            if i > 0 {
                layout = layout + ", "
                fieldNames = fieldNames + ","
                fieldTypes = fieldTypes + "|"  // Use | as separator for types (not comma, due to generics)
            }
            let field = classNode.fields[i]
            let fieldType = field.paramType.typeName
            let llvmType = mapType(fieldType)

            layout = layout + llvmType
            fieldNames = fieldNames + field.name
            fieldTypes = fieldTypes + fieldType
            totalSize = totalSize + getTypeSize(fieldType)

            i = i + 1
        }

        layout = layout + " }"

        // Collect method signatures
        var methodNames = ""
        var methodRetTypes = ""
        var mi = 0
        while mi < classNode.methods.length() {
            if mi > 0 {
                methodNames = methodNames + ","
                methodRetTypes = methodRetTypes + ","
            }
            let method = classNode.methods[mi]
            methodNames = methodNames + method.name
            methodRetTypes = methodRetTypes + method.returnType.typeName
            mi = mi + 1
        }

        // Store in registry
        structNames.push(classNode.name)
        structLayouts.push(layout)
        structFieldNames.push(fieldNames)
        structFieldTypes.push(fieldTypes)
        structSizes.push(totalSize)
        structMethodNames.push(methodNames)
        structMethodRetTypes.push(methodRetTypes)
    }

    // Get field index and type from registered struct
    fun getFieldInfo(structName: String, fieldName: String) r: Int {
        let idx = findStruct(structName)
        if idx < 0 {
            return -1  // Struct not found
        }

        let fieldNamesStr = structFieldNames[idx]
        // Parse comma-separated field names to find index
        var fieldIdx = 0
        var start = 0
        var pos = 0
        while pos <= fieldNamesStr.length() {
            var c = ""
            if pos < fieldNamesStr.length() {
                c = fieldNamesStr.substring(pos, pos + 1)
            }
            if c == "," or pos == fieldNamesStr.length() {
                let name = fieldNamesStr.substring(start, pos)
                if name == fieldName {
                    return fieldIdx
                }
                fieldIdx = fieldIdx + 1
                start = pos + 1
            }
            pos = pos + 1
        }
        return -1  // Field not found
    }

    // Get field type from registered struct
    // Note: fieldTypes uses | as separator (not comma) to handle generic types like Map<K,V>
    fun getFieldType(structName: String, fieldName: String) r: String {
        let idx = findStruct(structName)
        if idx < 0 {
            return "i64"  // Default
        }

        let fieldNamesStr = structFieldNames[idx]
        let fieldTypesStr = structFieldTypes[idx]

        // Parse to find matching field by index
        var fieldIdx = 0
        var nameStart = 0
        var nameEnd = 0

        // Find field index from names string (comma-separated)
        var foundField = false
        var pos = 0
        while pos <= fieldNamesStr.length() and not foundField {
            if pos == fieldNamesStr.length() or fieldNamesStr.substring(pos, pos + 1) == "," {
                let name = fieldNamesStr.substring(nameStart, pos)
                if name == fieldName {
                    foundField = true
                } else {
                    fieldIdx = fieldIdx + 1
                    nameStart = pos + 1
                }
            }
            pos = pos + 1
        }

        if not foundField {
            return "i64"
        }

        // Now find the type at fieldIdx (pipe-separated)
        var typeIdx = 0
        var typeStart = 0
        pos = 0
        while pos <= fieldTypesStr.length() {
            if pos == fieldTypesStr.length() or fieldTypesStr.substring(pos, pos + 1) == "|" {
                if typeIdx == fieldIdx {
                    let typeName = fieldTypesStr.substring(typeStart, pos)
                    return mapType(typeName)
                }
                typeIdx = typeIdx + 1
                typeStart = pos + 1
            }
            pos = pos + 1
        }

        return "i64"  // Default
    }

    // Get the ordinal value for SeenTokenType enum members
    // Enum values are 0-indexed based on declaration order in token_type.seen
    fun getSeenTokenTypeValue(memberName: String) r: Int {
        if memberName == "IntegerLiteral" { return 0 }
        if memberName == "FloatLiteral" { return 1 }
        if memberName == "StringLiteral" { return 2 }
        if memberName == "CharLiteral" { return 3 }
        if memberName == "BooleanLiteral" { return 4 }
        if memberName == "KeywordFalse" { return 5 }
        if memberName == "Identifier" { return 6 }
        if memberName == "KeywordFun" { return 7 }
        if memberName == "KeywordLet" { return 8 }
        if memberName == "KeywordVar" { return 9 }
        if memberName == "KeywordIf" { return 10 }
        if memberName == "KeywordElse" { return 11 }
        if memberName == "KeywordWhile" { return 12 }
        if memberName == "KeywordFor" { return 13 }
        if memberName == "KeywordIn" { return 14 }
        if memberName == "KeywordReturn" { return 15 }
        if memberName == "KeywordBreak" { return 16 }
        if memberName == "KeywordContinue" { return 17 }
        if memberName == "KeywordClass" { return 18 }
        if memberName == "KeywordInterface" { return 19 }
        if memberName == "KeywordEnum" { return 20 }
        if memberName == "KeywordExtends" { return 21 }
        if memberName == "KeywordImplements" { return 22 }
        if memberName == "KeywordAsync" { return 23 }
        if memberName == "KeywordAwait" { return 24 }
        if memberName == "KeywordSpawn" { return 25 }
        if memberName == "KeywordMatch" { return 26 }
        if memberName == "KeywordTry" { return 27 }
        if memberName == "KeywordCatch" { return 28 }
        if memberName == "KeywordFinally" { return 29 }
        if memberName == "KeywordThrow" { return 30 }
        if memberName == "KeywordImport" { return 31 }
        if memberName == "KeywordUse" { return 32 }
        if memberName == "KeywordExport" { return 33 }
        if memberName == "KeywordAs" { return 34 }
        if memberName == "KeywordIs" { return 35 }
        if memberName == "KeywordNull" { return 36 }
        if memberName == "KeywordTrue" { return 37 }
        if memberName == "KeywordThis" { return 38 }
        if memberName == "KeywordSuper" { return 39 }
        if memberName == "KeywordMove" { return 40 }
        if memberName == "KeywordBorrow" { return 41 }
        if memberName == "Plus" { return 42 }
        if memberName == "Minus" { return 43 }
        if memberName == "Multiply" { return 44 }
        if memberName == "Divide" { return 45 }
        if memberName == "Modulo" { return 46 }
        if memberName == "Equal" { return 47 }
        if memberName == "PlusEqual" { return 48 }
        if memberName == "MinusEqual" { return 49 }
        if memberName == "MultiplyEqual" { return 50 }
        if memberName == "DivideEqual" { return 51 }
        if memberName == "EqualEqual" { return 52 }
        if memberName == "NotEqual" { return 53 }
        if memberName == "LessThan" { return 54 }
        if memberName == "LessEqual" { return 55 }
        if memberName == "GreaterThan" { return 56 }
        if memberName == "GreaterEqual" { return 57 }
        if memberName == "LogicalAnd" { return 58 }
        if memberName == "LogicalOr" { return 59 }
        if memberName == "LogicalNot" { return 60 }
        if memberName == "SafeNavigation" { return 61 }
        if memberName == "Elvis" { return 62 }
        if memberName == "Question" { return 63 }
        if memberName == "LeftParen" { return 64 }
        if memberName == "RightParen" { return 65 }
        if memberName == "LeftBrace" { return 66 }
        if memberName == "RightBrace" { return 67 }
        if memberName == "LeftBracket" { return 68 }
        if memberName == "RightBracket" { return 69 }
        if memberName == "Comma" { return 70 }
        if memberName == "Semicolon" { return 71 }
        if memberName == "Colon" { return 72 }
        if memberName == "Dot" { return 73 }
        if memberName == "Arrow" { return 74 }
        if memberName == "InterpolatedStringStart" { return 75 }
        if memberName == "InterpolatedStringMiddle" { return 76 }
        if memberName == "InterpolatedStringEnd" { return 77 }
        if memberName == "Newline" { return 78 }
        if memberName == "Whitespace" { return 79 }
        if memberName == "Comment" { return 80 }
        if memberName == "Error" { return 81 }
        if memberName == "EndOfFile" { return 82 }
        if memberName == "None" { return 83 }
        return 0  // Unknown member - fallback
    }

    // Get field Seen type (not LLVM type) from registered struct
    fun getSeenFieldType(structName: String, fieldName: String) r: String {
        let idx = findStruct(structName)
        if structName == "FunctionNode" {
            println("[DEBUG getSeenFieldType] FunctionNode." + fieldName + " idx=" + idx.toString())
        }
        if idx < 0 {
            // Fallback for well-known types not in registry
            if structName == "FrontendResult" {
                if fieldName == "success" { return "Bool" }
                if fieldName == "diagnostics" { return "Array<FrontendDiagnostic>" }
                if fieldName == "program" { return "ProgramNode" }
            } else if structName == "ProgramNode" {
                if fieldName == "items" { return "Array<ItemNode>" }
            } else if structName == "ItemNode" {
                if fieldName == "itemType" { return "String" }
                if fieldName == "function" { return "FunctionNode" }
                if fieldName == "classNode" { return "ClassNode" }
                if fieldName == "importPath" { return "Array<String>" }
            } else if structName == "FrontendDiagnostic" {
                if fieldName == "severity" { return "String" }
                if fieldName == "file" { return "String" }
                if fieldName == "line" { return "Int" }
                if fieldName == "column" { return "Int" }
                if fieldName == "message" { return "String" }
            } else if structName == "CommandResult" {
                if fieldName == "success" { return "Bool" }
                if fieldName == "output" { return "String" }
                if fieldName == "exitCode" { return "Int" }
            } else if structName == "TypeInferenceResult" {
                if fieldName == "success" { return "Bool" }
                if fieldName == "type" { return "Type" }
                if fieldName == "errors" { return "Array<TypeError>" }
                if fieldName == "warnings" { return "Array<String>" }
                if fieldName == "environment" { return "Environment" }
            } else if structName == "FsFileResult" {
                if fieldName == "isOk" { return "Bool" }
                if fieldName == "file" { return "FsFile" }
                if fieldName == "error" { return "String" }
            } else if structName == "FsFile" {
                if fieldName == "fd" { return "Int" }
                if fieldName == "path" { return "String" }
            } else if structName == "FunctionNode" {
                if fieldName == "name" { return "String" }
                if fieldName == "params" { return "Array<ParamNode>" }
                if fieldName == "returnType" { return "TypeNode" }
                if fieldName == "body" { return "BlockNode" }
                if fieldName == "isAsync" { return "Bool" }
                if fieldName == "isInline" { return "Bool" }
                if fieldName == "isStatic" { return "Bool" }
            } else if structName == "ClassNode" {
                if fieldName == "name" { return "String" }
                if fieldName == "fields" { return "Array<FieldNode>" }
                if fieldName == "methods" { return "Array<FunctionNode>" }
            } else if structName == "TypeNode" {
                if fieldName == "typeName" { return "String" }
            } else if structName == "ParamNode" {
                if fieldName == "name" { return "String" }
                if fieldName == "paramType" { return "TypeNode" }
            } else if structName == "FieldNode" {
                if fieldName == "name" { return "String" }
                if fieldName == "paramType" { return "TypeNode" }
            } else if structName == "BlockNode" {
                if fieldName == "statements" { return "Array<StatementNode>" }
            } else if structName == "ImportPathInfo" {
                if fieldName == "text" { return "String" }
                if fieldName == "segments" { return "Array<String>" }
            } else if structName == "StatementNode" {
                if fieldName == "kind" { return "String" }
                if fieldName == "variableName" { return "String" }
                if fieldName == "variableType" { return "TypeNode" }
                if fieldName == "initializer" { return "ParserExpressionNode" }
                if fieldName == "returnValue" { return "ParserExpressionNode" }
                if fieldName == "condition" { return "ParserExpressionNode" }
                if fieldName == "thenBody" { return "BlockNode" }
                if fieldName == "elseBody" { return "BlockNode" }
                if fieldName == "loopBody" { return "BlockNode" }
            } else if structName == "ParserExpressionNode" {
                if fieldName == "kind" { return "String" }
                if fieldName == "variableName" { return "String" }
                if fieldName == "callee" { return "String" }
                if fieldName == "operator" { return "String" }
                if fieldName == "literalValue" { return "String" }
                if fieldName == "literalType" { return "String" }
                if fieldName == "operands" { return "Array<ParserExpressionNode>" }
                if fieldName == "arguments" { return "Array<ParserExpressionNode>" }
            } else if structName == "Type" {
                if fieldName == "name" { return "String" }
                if fieldName == "isNullable" { return "Bool" }
            } else if structName == "FunctionType" {
                if fieldName == "parameters" { return "Array<Type>" }
                if fieldName == "returnType" { return "Type" }
                if fieldName == "isAsync" { return "Bool" }
            } else if structName == "ClassType" {
                if fieldName == "name" { return "String" }
            } else if structName == "InterfaceType" {
                if fieldName == "name" { return "String" }
            } else if structName == "Location" {
                if fieldName == "line" { return "Int" }
                if fieldName == "column" { return "Int" }
                if fieldName == "file" { return "String" }
            } else if structName == "TypeError" {
                if fieldName == "location" { return "Location" }
                if fieldName == "expected" { return "Type" }
                if fieldName == "actual" { return "Type" }
                if fieldName == "context" { return "String" }
            } else if structName == "Environment" {
                if fieldName == "parent" { return "Environment" }
            }
            return "Int"  // Default
        }

        let fieldNamesStr = structFieldNames[idx]
        let fieldTypesStr = structFieldTypes[idx]

        if structName == "FunctionNode" and fieldName == "returnType" {
            println("[DEBUG getSeenFieldType] FunctionNode fieldNamesStr=" + fieldNamesStr)
            println("[DEBUG getSeenFieldType] FunctionNode fieldTypesStr=" + fieldTypesStr)
        }

        // Parse to find matching field by index
        var fieldIdx = 0
        var nameStart = 0

        // Find field index from names string (comma-separated)
        var foundField = false
        var pos = 0
        while pos <= fieldNamesStr.length() and not foundField {
            if pos == fieldNamesStr.length() or fieldNamesStr.substring(pos, pos + 1) == "," {
                let name = fieldNamesStr.substring(nameStart, pos)
                if name == fieldName {
                    foundField = true
                } else {
                    fieldIdx = fieldIdx + 1
                    nameStart = pos + 1
                }
            }
            pos = pos + 1
        }

        if not foundField {
            if structName == "FunctionNode" {
                println("[DEBUG getSeenFieldType] FunctionNode." + fieldName + " NOT FOUND in names, returning Int")
            }
            return "Int"
        }

        // Now find the type at fieldIdx (pipe-separated)
        var typeIdx = 0
        var typeStart = 0
        pos = 0
        while pos <= fieldTypesStr.length() {
            if pos == fieldTypesStr.length() or fieldTypesStr.substring(pos, pos + 1) == "|" {
                if typeIdx == fieldIdx {
                    let typeName = fieldTypesStr.substring(typeStart, pos)
                    if structName == "FunctionNode" {
                        println("[DEBUG getSeenFieldType] FunctionNode." + fieldName + " found at idx=" + fieldIdx.toString() + " type=" + typeName)
                    }
                    return typeName  // Return Seen type, not LLVM type
                }
                typeIdx = typeIdx + 1
                typeStart = pos + 1
            }
            pos = pos + 1
        }
        if structName == "FunctionNode" {
            println("[DEBUG getSeenFieldType] FunctionNode." + fieldName + " typeIdx mismatch, returning Int")
        }
        return "Int"  // Default
    }

    // Resolve the type of a chained path like "item.function.returnType"
    // Returns the type of the final field in the chain
    fun resolveChainedPathType(path: String) r: String {
        // Split the path at the first dot
        var firstDot = -1
        var idx = 0
        while idx < path.length() {
            if path.substring(idx, idx + 1) == "." {
                firstDot = idx
                idx = path.length()  // break
            }
            idx = idx + 1
        }

        if firstDot < 0 {
            // No dot - simple variable name
            return findVarType(path)
        }

        // Get base variable and rest of path
        let baseName = path.substring(0, firstDot)
        let restPath = path.substring(firstDot + 1, path.length())

        // Get base type
        var currentType = findVarType(baseName)
        if currentType == "" {
            return ""
        }

        // Walk through the rest of the path
        var remainingPath = restPath
        while remainingPath.length() > 0 {
            // Find next dot
            var nextDot = -1
            var searchIdx = 0
            while searchIdx < remainingPath.length() {
                if remainingPath.substring(searchIdx, searchIdx + 1) == "." {
                    nextDot = searchIdx
                    searchIdx = remainingPath.length()  // break
                }
                searchIdx = searchIdx + 1
            }

            var fieldName = ""
            if nextDot < 0 {
                // Last field in the chain
                fieldName = remainingPath
                remainingPath = ""
            } else {
                fieldName = remainingPath.substring(0, nextDot)
                remainingPath = remainingPath.substring(nextDot + 1, remainingPath.length())
            }

            // Get type of this field
            currentType = getSeenFieldType(currentType, fieldName)
            if currentType == "" or currentType == "Int" {
                // Can't resolve further
                return currentType
            }
        }

        return currentType
    }

    // Get method return type from registered struct
    fun getMethodReturnType(structName: String, methodName: String) r: String {
        // Fallback for well-known types that may not have methods registered
        if structName == "Environment" {
            if methodName == "lookup" { return "Type" }
            if methodName == "lookupFunction" { return "FunctionType" }
            if methodName == "lookupClass" { return "ClassType" }
            if methodName == "define" or methodName == "defineFunction" or methodName == "defineClass" { return "Void" }
        } else if structName == "Type" {
            if methodName == "getName" or methodName == "toString" { return "String" }
        } else if structName == "TypeInferenceResult" {
            if methodName == "getVariableType" { return "Type" }
        }

        let idx = findStruct(structName)
        if idx < 0 {
            return ""  // Not found
        }

        let methodNamesStr = structMethodNames[idx]
        let methodRetTypesStr = structMethodRetTypes[idx]

        // Parse to find matching method
        var nameStart = 0
        var typeStart = 0
        var namePos = 0
        var typePos = 0

        while namePos <= methodNamesStr.length() {
            var nc = ""
            if namePos < methodNamesStr.length() {
                nc = methodNamesStr.substring(namePos, namePos + 1)
            }

            // Find end of current type
            while typePos < methodRetTypesStr.length() {
                let tc = methodRetTypesStr.substring(typePos, typePos + 1)
                if tc == "," {
                    break
                }
                typePos = typePos + 1
            }

            if nc == "," or namePos == methodNamesStr.length() {
                let name = methodNamesStr.substring(nameStart, namePos)
                let typeName = methodRetTypesStr.substring(typeStart, typePos)
                if name == methodName {
                    return typeName
                }
                nameStart = namePos + 1
                typeStart = typePos + 1
                typePos = typePos + 1
            }
            namePos = namePos + 1
        }
        return ""  // Not found
    }

    fun generate(program: ProgramNode) r: String {
        // Single module compilation
        let programs = Array<ProgramNode>()
        programs.push(program)
        return generateMultiple(programs)
    }

    fun generateMultiple(programs: Array<ProgramNode>) r: String {
        output = StringBuilder.new()
        stringConstants = Array<String>()
        stringConstantPrefix = ""  // No prefix for multi-module

        // First pass: collect string constants from all programs
        var pi = 0
        while pi < programs.length() {
            collectStringConstants(programs[pi])
            pi = pi + 1
        }

        // Emit module header
        emitPrologue()

        // Emit class struct type definitions from all programs
        pi = 0
        while pi < programs.length() {
            let program = programs[pi]
            var i = 0
            while i < program.items.length() {
                let item = program.items[i]
                if item.itemType == "Class" {
                    emitClassType(item.classNode)
                }
                i = i + 1
            }
            pi = pi + 1
        }

        // Emit string constants
        emitStringConstants()

        // Emit runtime declarations
        emitRuntimeDeclarations()

        // Emit functions (top-level) from all programs
        pi = 0
        while pi < programs.length() {
            let program = programs[pi]
            var i = 0
            while i < program.items.length() {
                let item = program.items[i]
                if item.itemType == "Function" {
                    let fnName = item.function.name
                    // Skip StringBuilder methods that were incorrectly parsed as standalone
                    if fnName == "clear" or fnName == "isEmpty" or fnName == "length" or fnName == "buildAndClear" or fnName == "toString" or fnName == "reduceToString" or fnName == "append" or fnName == "appendChar" or fnName == "appendLine" or fnName == "appendAll" {
                        i = i + 1
                        continue
                    }
                    // Skip string utility functions that use unsupported features (break, for)
                    // These could be provided by the C runtime instead
                    if fnName == "trimStart" or fnName == "trimEnd" or fnName == "trim" or fnName == "split" or fnName == "lines" or fnName == "words" or fnName == "splitWhitespace" {
                        i = i + 1
                        continue
                    }
                    if fnName == "replaceFirst" or fnName == "replaceAll" or fnName == "replace" {
                        i = i + 1
                        continue
                    }
                    if fnName == "padStart" or fnName == "padEnd" or fnName == "repeat" or fnName == "join" or fnName == "mergeAdjacent" {
                        i = i + 1
                        continue
                    }
                    if fnName == "isBlank" or fnName == "isWhitespace" or fnName == "contains" or fnName == "startsWith" or fnName == "endsWith" {
                        // These might use features we don't support yet
                        i = i + 1
                        continue
                    }
                    if fnName == "removePrefix" or fnName == "removeSuffix" or fnName == "ensurePrefix" or fnName == "ensureSuffix" {
                        i = i + 1
                        continue
                    }
                    // Skip RealParser methods that were incorrectly parsed as standalone functions
                    if fnName == "isAtEnd" or fnName == "peek" or fnName == "peekTokenType" or fnName == "peekTokenTypeStr" or fnName == "previous" or fnName == "advance" or fnName == "consume" or fnName == "checkToken" or fnName == "matchTokenStr" or fnName == "skipExpression" or fnName == "toArray" {
                        i = i + 1
                        continue
                    }
                    // Skip 'new' - it's always a class method, never a standalone function
                    if fnName == "new" {
                        i = i + 1
                        continue
                    }
                    generateFunction(item.function)
                }
                i = i + 1
            }
            pi = pi + 1
        }

        // Emit class methods from all programs
        pi = 0
        while pi < programs.length() {
            let program = programs[pi]
            var i = 0
            while i < program.items.length() {
                let item = program.items[i]
                if item.itemType == "Class" {
                    generateClass(item.classNode)
                }
                i = i + 1
            }
            pi = pi + 1
        }

        return output.toString()
    }

    // Generate IR for a single module (for per-module compilation)
    fun generateSingle(program: ProgramNode, moduleIndex: Int) r: String {
        // Reset per-module state
        output = StringBuilder.new()
        stringConstants = Array<String>()
        varNames = Array<String>()
        varRegs = Array<String>()
        varTypes = Array<String>()
        nextReg = 1
        nextBlock = 0
        preAllocatedVars = Array<String>()
        preAllocatedTypes = Array<String>()
        // Set module prefix for string constants (e.g., "M0.", "M1.", etc.)
        stringConstantPrefix = "M" + moduleIndex.toString() + "."

        // Collect string constants for THIS module only
        collectStringConstants(program)

        // Emit module header
        emitPrologue()

        // Emit class struct type definitions for THIS module
        var i = 0
        while i < program.items.length() {
            let item = program.items[i]
            if item.itemType == "Class" {
                emitClassType(item.classNode)
            }
            i = i + 1
        }

        // Emit string constants with module prefix
        emitStringConstantsWithPrefix(moduleIndex)

        // Collect function names defined in this module (to skip their declarations)
        var definedFuncs = Array<String>()
        var collectIdx = 0
        while collectIdx < program.items.length() {
            let collectItem = program.items[collectIdx]
            if collectItem.itemType == "Function" {
                definedFuncs.push(collectItem.function.name)
            } else if collectItem.itemType == "Class" {
                // Also collect class method names (format: ClassName_methodName)
                let className = collectItem.classNode.name
                var methodIdx = 0
                while methodIdx < collectItem.classNode.methods.length() {
                    let method = collectItem.classNode.methods[methodIdx]
                    definedFuncs.push(className + "_" + method.name)
                    methodIdx = methodIdx + 1
                }
            }
            collectIdx = collectIdx + 1
        }

        // Emit runtime declarations (skip functions defined in this module)
        emitRuntimeDeclarations(definedFuncs)

        // Emit functions (top-level) for THIS module
        i = 0
        while i < program.items.length() {
            let item = program.items[i]
            if item.itemType == "Function" {
                let fnName = item.function.name
                // Skip StringBuilder methods that were incorrectly parsed as standalone
                if fnName == "clear" or fnName == "isEmpty" or fnName == "length" or fnName == "buildAndClear" or fnName == "toString" or fnName == "reduceToString" or fnName == "append" or fnName == "appendChar" or fnName == "appendLine" or fnName == "appendAll" {
                    i = i + 1
                    continue
                }
                // Skip string utility functions that use unsupported features
                if fnName == "trimStart" or fnName == "trimEnd" or fnName == "trim" or fnName == "split" or fnName == "lines" or fnName == "words" or fnName == "splitWhitespace" {
                    i = i + 1
                    continue
                }
                if fnName == "replaceFirst" or fnName == "replaceAll" or fnName == "replace" {
                    i = i + 1
                    continue
                }
                if fnName == "padStart" or fnName == "padEnd" or fnName == "repeat" or fnName == "join" or fnName == "mergeAdjacent" {
                    i = i + 1
                    continue
                }
                if fnName == "isBlank" or fnName == "isWhitespace" or fnName == "contains" or fnName == "startsWith" or fnName == "endsWith" {
                    i = i + 1
                    continue
                }
                if fnName == "removePrefix" or fnName == "removeSuffix" or fnName == "ensurePrefix" or fnName == "ensureSuffix" {
                    i = i + 1
                    continue
                }
                // Skip RealParser methods that were incorrectly parsed as standalone functions
                if fnName == "isAtEnd" or fnName == "peek" or fnName == "peekTokenType" or fnName == "peekTokenTypeStr" or fnName == "previous" or fnName == "advance" or fnName == "consume" or fnName == "checkToken" or fnName == "matchTokenStr" or fnName == "skipExpression" or fnName == "toArray" {
                    i = i + 1
                    continue
                }
                // Skip 'new' - it's always a class method, never a standalone function
                // (Parser may incorrectly extract it from classes with 'extends')
                if fnName == "new" {
                    i = i + 1
                    continue
                }
                generateFunction(item.function)
            }
            i = i + 1
        }

        // Emit class methods for THIS module
        i = 0
        while i < program.items.length() {
            let item = program.items[i]
            if item.itemType == "Class" {
                generateClass(item.classNode)
            }
            i = i + 1
        }

        return output.toString()
    }

    fun emitPrologue() r: Void {
        output.append("; Generated by Seen Stage1 Compiler (LLVM backend)\n")
        output.append("target datalayout = \"e-m:e-p270:32:32-p271:32:32-p272:64:64-i64:64-f80:128-n8:16:32:64-S128\"\n")
        output.append("target triple = \"x86_64-unknown-linux-gnu\"\n\n")

        // Type definitions
        output.append("%SeenString = type { i64, ptr }\n")
        // SeenArray: { len: i64, cap: i64, element_size: i64, data: ptr }
        output.append("%SeenArray = type { i64, i64, i64, ptr }\n\n")
    }

    fun emitClassType(classNode: ClassNode) r: Void {
        // Register struct layout for code generation
        registerStructLayout(classNode)

        // Emit struct type for class
        // %ClassName = type { field1Type, field2Type, ... }
        output.append("%" + classNode.name + " = type { ")

        var i = 0
        while i < classNode.fields.length() {
            if i > 0 {
                output.append(", ")
            }
            let field = classNode.fields[i]
            output.append(mapType(field.paramType.typeName))
            i = i + 1
        }

        output.append(" }\n")
    }

    fun generateClass(classNode: ClassNode) r: Void {
        // Skip classes that are provided by the runtime
        let className = classNode.name
        if className == "StringBuilder" or className == "" {
            // StringBuilder is provided by the C runtime
            // Empty class name means parsing issue - skip to avoid bad code
            return
        }

        // Generate all methods for this class
        var i = 0
        while i < classNode.methods.length() {
            let method = classNode.methods[i]
            generateClassMethod(classNode, method)
            i = i + 1
        }
    }

    fun generateClassMethod(classNode: ClassNode, method: FunctionNode) r: Void {
        // Reset per-function state
        nextReg = 1
        nextBlock = 0
        varNames = Array<String>()
        varRegs = Array<String>()
        varTypes = Array<String>()
        preAllocatedVars = Array<String>()
        preAllocatedTypes = Array<String>()
        currentFunctionReturnType = method.returnType.typeName
        blockTerminated = false

        // Pre-register parameter types for use during variable collection
        // (needed so inferExpressionType can find parameter types)
        // Also pre-register 'this' for instance methods (non-static)
        let isStaticMethod = method.isStatic or method.name == "new"
        if not isStaticMethod {
            varNames.push("this")
            varRegs.push("")  // Placeholder - will be cleared
            varTypes.push(classNode.name)
        }
        var preParamIdx = 0
        while preParamIdx < method.params.length() {
            let param = method.params[preParamIdx]
            varNames.push(param.name)
            varRegs.push("")  // Placeholder - will be cleared
            varTypes.push(param.paramType.typeName)
            preParamIdx = preParamIdx + 1
        }

        // Collect all variable declarations for hoisting allocas to entry block
        collectVariableDeclarations(method.body)

        // Clear pre-registered parameters (will be re-added with proper registers)
        varNames = Array<String>()
        varRegs = Array<String>()
        varTypes = Array<String>()

        let returnType = mapType(method.returnType.typeName)
        let className = classNode.name
        let methodName = method.name

        // Determine if this is a static method (name is "new" or has isStatic flag)
        let isStatic = method.isStatic or methodName == "new"

        // Function signature: ClassName_methodName or ClassName_new
        output.append("define " + returnType + " @" + className + "_" + methodName + "(")

        // For instance methods, first parameter is 'this' pointer
        var hasThis = false
        if not isStatic {
            output.append("ptr %this")
            hasThis = true
        }

        // Other parameters
        var paramIdx = 0
        while paramIdx < method.params.length() {
            if paramIdx > 0 or hasThis {
                output.append(", ")
            }
            let param = method.params[paramIdx]
            let paramType = mapType(param.paramType.typeName)
            output.append(paramType + " %" + param.name + ".arg")
            paramIdx = paramIdx + 1
        }

        output.append(") {\n")
        output.append("entry:\n")

        // For instance methods, store 'this' pointer
        if not isStatic {
            let thisReg = getNextReg()
            output.append("  " + thisReg + " = alloca ptr\n")
            output.append("  store ptr %this, ptr " + thisReg + "\n")
            storeVar("this", thisReg, className)
        }

        // Allocate space for parameters and store them
        paramIdx = 0
        while paramIdx < method.params.length() {
            let param = method.params[paramIdx]
            let paramType = mapType(param.paramType.typeName)
            let reg = getNextReg()
            output.append("  " + reg + " = alloca " + paramType + "\n")
            output.append("  store " + paramType + " %" + param.name + ".arg, ptr " + reg + "\n")
            storeVar(param.name, reg, param.paramType.typeName)
            paramIdx = paramIdx + 1
        }

        // Emit allocas for all local variables at entry (avoids domination errors)
        emitPreAllocatedAllocas()

        // Generate method body
        generateBlock(method.body)

        // If no terminator was generated, add a default return
        if not blockTerminated {
            if returnType == "void" {
                output.append("  ret void\n")
            } else if returnType == "i1" {
                output.append("  ret i1 false\n")
            } else if returnType == "i64" {
                output.append("  ret i64 0\n")
            } else if returnType == "ptr" {
                output.append("  ret ptr null\n")
            } else if returnType == "%SeenString" {
                output.append("  ret %SeenString zeroinitializer\n")
            } else if returnType == "%SeenArray" {
                output.append("  ret %SeenArray zeroinitializer\n")
            } else {
                // Default for other types
                output.append("  ret " + returnType + " zeroinitializer\n")
            }
        }

        output.append("}\n\n")
    }

    fun emitStringConstants() r: Void {
        var i = 0
        while i < stringConstants.length() {
            let str = stringConstants[i]
            let escaped = escapeString(str)
            let len = str.length() + 1  // +1 for null terminator
            output.append("@.str." + i.toString() + " = private unnamed_addr constant [" + len.toString() + " x i8] c\"" + escaped + "\\00\"\n")
            i = i + 1
        }
        if stringConstants.length() > 0 {
            output.append("\n")
        }
    }

    // Emit string constants with module prefix to avoid collisions in per-module compilation
    fun emitStringConstantsWithPrefix(moduleIndex: Int) r: Void {
        var i = 0
        while i < stringConstants.length() {
            let str = stringConstants[i]
            let escaped = escapeString(str)
            let len = str.length() + 1  // +1 for null terminator
            // Module-prefixed name: @.str.M0.0, @.str.M1.0, etc.
            output.append("@.str.M" + moduleIndex.toString() + "." + i.toString() + " = private unnamed_addr constant [" + len.toString() + " x i8] c\"" + escaped + "\\00\"\n")
            i = i + 1
        }
        if stringConstants.length() > 0 {
            output.append("\n")
        }
    }

    // Helper to check if a function name is defined in this module
    fun isFuncDefinedInModule(name: String, definedFuncs: Array<String>) r: Bool {
        var i = 0
        while i < definedFuncs.length() {
            if definedFuncs[i] == name {
                return true
            }
            i = i + 1
        }
        return false
    }

    fun emitRuntimeDeclarations(definedFuncs: Array<String>) r: Void {
        output.append("; Runtime function declarations\n")
        output.append("declare void @seen_runtime_init(i32, ptr)\n")
        output.append("declare void @println(%SeenString)\n")
        output.append("declare %SeenString @seen_cstr_to_str(ptr)\n")
        output.append("declare i64 @seen_length(%SeenString)\n")
        output.append("declare %SeenString @seen_substring(%SeenString, i64, i64)\n")
        output.append("declare i1 @startsWith(%SeenString, %SeenString)\n")
        output.append("declare i1 @endsWith(%SeenString, %SeenString)\n")
        output.append("declare i1 @contains(%SeenString, %SeenString)\n")
        // Note: trim is provided by string.seen, not the C runtime
        output.append("declare %SeenString @seen_str_concat_ss(%SeenString, %SeenString)\n")
        output.append("declare %SeenString @seen_int_to_string(i64)\n")
        output.append("declare %SeenString @seen_char_to_str(i64)\n")
        output.append("declare %SeenString @seen_bool_to_string(i1)\n")
        output.append("declare i64 @seen_char_at(%SeenString, i64)\n")

        // String search functions (conditionally declared)
        if not isFuncDefinedInModule("indexOf", definedFuncs) {
            output.append("declare i64 @indexOf(%SeenString, %SeenString, i64)\n")
        }
        if not isFuncDefinedInModule("lastIndexOf", definedFuncs) {
            output.append("declare i64 @lastIndexOf(%SeenString, %SeenString, i64)\n")
        }

        // StringBuilder functions
        output.append("declare ptr @StringBuilder_new()\n")
        output.append("declare i64 @StringBuilder_append(ptr, %SeenString)\n")
        output.append("declare i64 @StringBuilder_appendChar(ptr, i64)\n")
        output.append("declare %SeenString @StringBuilder_toString(ptr)\n")
        output.append("declare i64 @Char_toInt(i64)\n")
        output.append("declare i64 @Int_unwrap(i64)\n")
        output.append("declare ptr @Optional_unwrap(ptr)\n")
        output.append("declare i64 @SeenTokenType_unwrap(i64)\n")
        output.append("declare ptr @Some(ptr)\n")
        output.append("declare ptr @None()\n")
        output.append("declare i1 @seen_str_eq_ss(%SeenString, %SeenString)\n")
        output.append("declare i1 @seen_str_ne_ss(%SeenString, %SeenString)\n")
        if not isFuncDefinedInModule("readText", definedFuncs) {
            output.append("declare %SeenString @readText(%SeenString)\n")
        }
        if not isFuncDefinedInModule("writeText", definedFuncs) {
            output.append("declare i1 @writeText(%SeenString, %SeenString)\n")
        }

        // Array functions - use byval for SeenArray (> 16 bytes)
        output.append("declare %SeenArray @seen_arr_new_str()\n")
        output.append("declare i64 @seen_arr_length(ptr byval(%SeenArray) align 8)\n")
        output.append("declare i64 @seen_arr_length_ptr(ptr)\n")
        output.append("declare %SeenString @seen_arr_get_str(ptr byval(%SeenArray) align 8, i64)\n")
        output.append("declare ptr @seen_arr_get_diag(ptr byval(%SeenArray) align 8, i64)\n")
        output.append("declare ptr @seen_arr_get_ptr(ptr byval(%SeenArray) align 8, i64)\n")
        output.append("declare i64 @Array_push(ptr, ptr)\n")
        output.append("declare void @seen_arr_push_str(ptr, %SeenString)\n")
        // Note: args() returns via sret because SeenArray > 16 bytes
        if not isFuncDefinedInModule("args", definedFuncs) {
            output.append("declare void @args(ptr sret(%SeenArray) align 8)\n")
        }

        // C runtime primitive functions (extern fun __*) for stdlib
        // File I/O primitives
