fun llvmIrGenIsMainFunctionName(name: String) r: Bool {
    if name.length() != 4 {
        return false
    }
    return name.byteAt(0) == 109 and name.byteAt(1) == 97 and name.byteAt(2) == 105 and name.byteAt(3) == 110
}

fun getIrgenTraceTimeSeconds() r: Int {
    let result: CommandResult = runCommand("date +%s")
    if commandWasSuccessful(result) {
        let out = commandOutput(result).trim()
        if out.length() > 0 {
            return out.toInt()
        }
    }
    return 0
}

// Host platform detection (cached, detected once)
var g_hostTargetTriple: String = ""
var g_hostDataLayout: String = ""

fun detectHostPlatform() r: Void {
    if g_hostTargetTriple != "" {
        return
    }
    let unameS: CommandResult = runCommand("uname -s")
    let unameM: CommandResult = runCommand("uname -m")
    var os = "linux"
    var arch = "x86_64"
    if commandWasSuccessful(unameS) {
        if unameS.output.contains("Darwin") {
            os = "darwin"
        }
    }
    if commandWasSuccessful(unameM) {
        if unameM.output.contains("arm64") or unameM.output.contains("aarch64") {
            arch = "arm64"
        }
    }
    if os == "darwin" {
        if arch == "arm64" {
            g_hostTargetTriple = "arm64-apple-macosx14.0"
            g_hostDataLayout = "e-m:o-i64:64-i128:128-n32:64-S128"
        } else {
            g_hostTargetTriple = "x86_64-apple-macosx14.0"
            g_hostDataLayout = "e-m:o-p270:32:32-p271:32:32-p272:64:64-i64:64-i128:128-f80:128-n8:16:32:64-S128"
        }
    } else {
        if arch == "arm64" {
            g_hostTargetTriple = "aarch64-unknown-linux-gnu"
            g_hostDataLayout = "e-m:e-i8:8:32-i16:16:32-i64:64-i128:128-n32:64-S128"
        } else {
            g_hostTargetTriple = "x86_64-unknown-linux-gnu"
            g_hostDataLayout = "e-m:e-p270:32:32-p271:32:32-p272:64:64-i64:64-f80:128-n8:16:32:64-S128"
        }
    }
}

// Override host target triple and data layout for cross-compilation
fun overrideTargetTriple(triple: String, layout: String) r: Void {
    g_hostTargetTriple = triple
    g_hostDataLayout = layout
}

// Module-level profiling state (avoids changing struct layout for backward compat)
