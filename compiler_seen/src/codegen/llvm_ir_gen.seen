import process.process.{runCommand, CommandResult, commandWasSuccessful, commandOutput}

fun getIrgenTraceTimeSeconds() r: Int {
    let result: CommandResult = runCommand("date +%s")
    if commandWasSuccessful(result) {
        let out = commandOutput(result).trim()
        if out.length() > 0 {
            return out.toInt()
        }
    }
    return 0
}

// Host platform detection (cached, detected once)
var g_hostTargetTriple: String = ""
var g_hostDataLayout: String = ""

fun detectHostPlatform() r: Void {
    if g_hostTargetTriple != "" {
        return
    }
    let unameS: CommandResult = runCommand("uname -s")
    let unameM: CommandResult = runCommand("uname -m")
    var os = "linux"
    var arch = "x86_64"
    if commandWasSuccessful(unameS) {
        if unameS.output.contains("Darwin") {
            os = "darwin"
        }
    }
    if commandWasSuccessful(unameM) {
        if unameM.output.contains("arm64") or unameM.output.contains("aarch64") {
            arch = "arm64"
        }
    }
    if os == "darwin" {
        if arch == "arm64" {
            g_hostTargetTriple = "arm64-apple-macosx14.0"
            g_hostDataLayout = "e-m:o-i64:64-i128:128-n32:64-S128"
        } else {
            g_hostTargetTriple = "x86_64-apple-macosx14.0"
            g_hostDataLayout = "e-m:o-p270:32:32-p271:32:32-p272:64:64-i64:64-i128:128-f80:128-n8:16:32:64-S128"
        }
    } else {
        if arch == "arm64" {
            g_hostTargetTriple = "aarch64-unknown-linux-gnu"
            g_hostDataLayout = "e-m:e-i8:8:32-i16:16:32-i64:64-i128:128-n32:64-S128"
        } else {
            g_hostTargetTriple = "x86_64-unknown-linux-gnu"
            g_hostDataLayout = "e-m:e-p270:32:32-p271:32:32-p272:64:64-i64:64-f80:128-n8:16:32:64-S128"
        }
    }
}

// Override host target triple and data layout for cross-compilation
fun overrideTargetTriple(triple: String, layout: String) r: Void {
    g_hostTargetTriple = triple
    g_hostDataLayout = layout
}

// Panic on overflow flag - module-level to avoid changing class struct layout during bootstrap
var g_panicOnOverflow: Bool = false
// Async function registry - pipe-delimited strings (avoids adding class fields to LLVMIRGenerator)
var g_asyncFuncNames: String = ""
var g_asyncFuncRetTypes: String = ""
var g_asyncFuncCount: Int = 0

// Inheritance registry — pipe-delimited child:parent pairs
var g_inheritanceChildNames: String = ""
var g_inheritanceParentNames: String = ""
var g_inheritanceCount: Int = 0
// Current class's parent name (set during generateClass, used for super dispatch)
var g_currentClassParentName: String = ""

// Closure generation state
var g_closureCount: Int = 0
var g_closureDefs: String = ""

// --- Phase 9 Tier 4: Optimization Counters ---
var g_deadStatementsEliminated: Int = 0
var g_branchesEliminated: Int = 0
var g_constantsFolded: Int = 0
var g_cseHits: Int = 0
var g_cseCount: Int = 0
// String module-level vars (requires stage2+ compiler):
var g_cseKeys: String = ""
var g_cseValues: String = ""
// Fast CSE arrays — initialized in cseClear(), used instead of pipe strings
var g_cseKeysArr: Array<String> = Array<String>()
var g_cseValsArr: Array<String> = Array<String>()

// --- Phase 9 Tier 4: Additional Optimization Counters ---
var g_loopsOptimized: Int = 0
var g_deadStoresEliminated: Int = 0
var g_stringsDeduped: Int = 0
var g_allocsSunk: Int = 0
var g_escapedAllocsPromoted: Int = 0
var g_reductionChainsDetected: Int = 0
// ML heuristic weights (loaded from SEEN_ML_HEURISTICS env var)
var g_mlWeightsLoaded: Bool = false
var g_mlInlineThreshold: Int = 50
var g_mlUnrollThreshold: Int = 4
var g_mlVectorizeThreshold: Int = 8
// ML deterministic replay
var g_mlReplayEnabled: Bool = false
var g_mlReplayLog: String = ""
var g_mlReplayIdx: Int = 0
// Dead store tracking (pipe-delimited, per-block)
var g_lastStoreVars: String = ""
var g_lastStoreCount: Int = 0
// --- Phase 10: Activated optimization state ---
// Induction variable name set in generateWhileStatement, read in generateBinary for nuw flag
var g_inductionVarName: String = ""
// Dead store skip vars: pipe-delimited names of vars whose literal initializers should be skipped
var g_deadStoreSkipVars: String = ""
// Loop tile hints: "metaIdx:tileSize|metaIdx:tileSize|..." for per-loop unroll metadata
var g_loopTileHints: String = ""
// Reduction loop IDs: "metaIdx|metaIdx|..." for wider vectorize width
var g_reductionLoopIds: String = ""
// Nested loop IDs: "metaIdx|metaIdx|..." for loop distribute enable
var g_nestedLoopIds: String = ""
// Module constant mutability: pipe-delimited "0"/"1" entries parallel to moduleConstantNames
// "0" = immutable (let), "1" = mutable (var). Reset per-module.
var g_moduleConstMutable: String = ""
// Module constant Seen types: pipe-delimited full Seen types parallel to moduleConstantNames
var g_moduleConstSeenTypes: String = ""
// Cross-module function declares: pipe-delimited parallel arrays
// Populated during registerDeclarations (Pass 1), emitted in generateSingle (Pass 2)
var g_xmDeclareNames: String = ""
var g_xmDeclareStrs: String = ""
var g_xmDeclareCount: Int = 0
// Visibility tracking: pipe-delimited "public" or "private" parallel to g_xmDeclareNames
var g_xmDeclareVis: String = ""
var g_xmDeclareNamesArr: Array<String> = Array<String>()
var g_xmDeclareStrsArr: Array<String> = Array<String>()
var g_xmDeclareVisArr: Array<String> = Array<String>()
// Late-discovered user declares are found during Pass 2 when a direct-entry
// build references symbols that never appeared in Pass 1 declarations.
var g_lateXmDeclareNames: String = ""
var g_lateXmDeclareStrs: String = ""
var g_lateXmDeclareCount: Int = 0
// Cross-module constant registry: pipe-delimited parallel arrays
// Populated during registerDeclarations (Pass 1), used for external global stubs in generateSingle (Pass 2)
// NOT reset per-module — must persist across all modules like g_xmDeclareNames
var g_xmConstNames: String = ""
var g_xmConstTypes: String = ""
var g_xmConstMutable: String = ""
var g_xmConstSeenTypes: String = ""
var g_xmConstCount: Int = 0

// Defer statement tracking: array of deferred statement expressions per block scope
var g_deferCount: Int = 0
var g_deferExprs: Array<ParserExpressionNode> = Array<ParserExpressionNode>()

// Errdefer statement tracking: LIFO stack, emitted only on error return
var g_errdeferCount: Int = 0
var g_errdeferExprs: Array<ParserExpressionNode> = Array<ParserExpressionNode>()
var g_errdeferTempAlloca: String = ""
var g_irgenFieldInfoCacheKeys: Array<String> = Array<String>()
var g_irgenFieldInfoCacheIdxs: Array<Int> = Array<Int>()

fun findCachedIrgenFieldIndex(key: String) r: Int {
    var i = g_irgenFieldInfoCacheKeys.length() - 1
    while i >= 0 {
        if g_irgenFieldInfoCacheKeys[i] == key {
            return g_irgenFieldInfoCacheIdxs[i]
        }
        i = i - 1
    }
    return -1
}

fun cacheIrgenFieldIndex(key: String, idx: Int) r: Void {
    if idx < 0 { return }
    g_irgenFieldInfoCacheKeys.push(key)
    g_irgenFieldInfoCacheIdxs.push(idx)
}

// Cache-line aligned classes: pipe-delimited names
var g_cacheLineClasses: String = ""

// Unsafe block nesting counter
var g_insideUnsafe: Int = 0

// Boxed counters for register and block numbering
