}

fun getGlobalTypesLoadedFromHeaderImpl() r: Bool {
    return typesLoadedFromHeader
}

fun getGlobalStructLayoutAtImpl(index: Int) r: String {
    return structLayouts[index]
}

fun hasGeneratedClassWithGlobalStateImpl(className: String) r: Bool {
    var classIdx = 0
    while classIdx < generatedClasses.length() {
        if generatedClasses[classIdx] == className {
            return true
        }
        classIdx = classIdx + 1
    }
    return false
}

fun pushGeneratedClassWithGlobalStateImpl(className: String) r: Void {
    generatedClasses.push(className)
}

fun getGlobalStructMethodNamesImpl() r: Array<String> {
    return structMethodNames
}

fun getGlobalStructMethodRetTypesImpl() r: Array<String> {
    return structMethodRetTypes
}

fun getGlobalCurrentClassNameImpl() r: String {
    return currentClassName
}

fun getGlobalFuncNamesImpl() r: Array<String> {
    return funcNames
}

fun getGlobalFuncRetTypesImpl() r: Array<String> {
    return funcRetTypes
}

fun getFunctionReturnTypeWithGlobalStateImpl(name: String) r: String {
    return getFunctionReturnTypeStateImpl(name, funcNames, funcRetTypes)
}

fun inferMethodCallBoolSuffixWithGlobalStateImpl(callee: String) r: String {
    return inferMethodCallBoolSuffixImpl(callee, funcNames, funcRetTypes)
}

fun prepareFunctionGenerationIdentityWithGlobalStateImpl(fn: FunctionNode,
    resolvedFunctionReturnType: String)
    r: FunctionGenerationIdentitySnapshot {

    let snapshot = FunctionGenerationIdentitySnapshot.new()
    let registryBox = Array<String>()
    registryBox.push(getTraitImplRegistryStateImpl())
    let countBox = Array<Int>()
    countBox.push(getTraitImplCountStateImpl())
    snapshot.implFuncName = resolveImplementationFunctionNameImpl(fn,
        structNames, getDynTraitNamesStateImpl(), structMethodNames,
        structMethodRetTypes, registryBox, countBox)
    applyTraitImplStateImpl(registryBox[0], countBox[0])
    snapshot.traitImplRegistry = registryBox[0]
    snapshot.traitImplCount = countBox[0]

    if hasGeneratedFunctionNameImpl(generatedFunctions, snapshot.implFuncName) {
        snapshot.alreadyGenerated = 1
        return snapshot
    }
    if shouldSkipRuntimeBuiltinStubImpl(fn, snapshot.implFuncName) {
        snapshot.skipRuntimeBuiltinStub = 1
        return snapshot
    }

    generatedFunctions.push(snapshot.implFuncName)
    snapshot.resolvedFunctionReturnType = resolvedFunctionReturnType
    registerFunctionStateImpl(snapshot.implFuncName,
        snapshot.resolvedFunctionReturnType, funcNames, funcRetTypes)
    return snapshot
}

