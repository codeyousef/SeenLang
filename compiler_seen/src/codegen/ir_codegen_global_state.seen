fun syncCodegenStateFromGlobalStateImpl(state: CodegenState,
    output: StringBuilder, stringConstants: Array<String>,
    regBox: Array<Int>, blockBox: Array<Int>, varNames: Array<String>,
    varRegs: Array<String>, varTypes: Array<String>,
    functionOptions: FunctionLoweringOptions) r: Void {

    syncCodegenStateBridgeImpl(state, output, stringConstants, regBox,
        blockBox, varNames, varRegs, varTypes, functionOptions,
        structNames, structLayouts, structFieldNames, structFieldTypes,
        structLlvmFieldTypes, structSizes, structMethodNames,
        structMethodRetTypes, funcNames, funcRetTypes,
        classMethodBaseNames, typeHeaderPath, currentFunctionReturnType,
        currentClassName, blockTerminated, currentLoopCondLabel,
        currentLoopEndLabel, preAllocatedVars, preAllocatedTypes,
        preAllocatedRegs, declOrdinalNames, declOrdinalCounts,
        activeVarCount, stringConstantPrefix, generatedFunctions,
        generatedClasses, pendingArrayLiteralType, moduleConstantNames,
        moduleConstantValues, moduleConstantTypes)
}

fun applyGlobalCodegenStateBridgeSnapshotImpl(
    snapshot: CodegenStateBridgeSnapshot) r: Void {

    structNames = snapshot.structNames
    structLayouts = snapshot.structLayouts
    structFieldNames = snapshot.structFieldNames
    structFieldTypes = snapshot.structFieldTypes
    structLlvmFieldTypes = snapshot.structLlvmFieldTypes
    structSizes = snapshot.structSizes
    structMethodNames = snapshot.structMethodNames
    structMethodRetTypes = snapshot.structMethodRetTypes
    funcNames = snapshot.funcNames
    funcRetTypes = snapshot.funcRetTypes
    classMethodBaseNames = snapshot.classMethodBaseNames
    typeHeaderPath = snapshot.typeHeaderPath
    currentFunctionReturnType = snapshot.currentFunctionReturnType
    currentClassName = snapshot.currentClassName
    blockTerminated = snapshot.blockTerminated
    currentLoopCondLabel = snapshot.currentLoopCondLabel
    currentLoopEndLabel = snapshot.currentLoopEndLabel
    preAllocatedVars = snapshot.preAllocatedVars
    preAllocatedTypes = snapshot.preAllocatedTypes
    preAllocatedRegs = snapshot.preAllocatedRegs
    declOrdinalNames = snapshot.declOrdinalNames
    declOrdinalCounts = snapshot.declOrdinalCounts
    activeVarCount = snapshot.activeVarCount
    stringConstantPrefix = snapshot.stringConstantPrefix
    generatedFunctions = snapshot.generatedFunctions
    generatedClasses = snapshot.generatedClasses
    pendingArrayLiteralType = snapshot.pendingArrayLiteralType
    moduleConstantNames = snapshot.moduleConstantNames
    moduleConstantValues = snapshot.moduleConstantValues
    moduleConstantTypes = snapshot.moduleConstantTypes
}

fun emitMainFunctionEntryWithGlobalStateImpl(output: StringBuilder,
    regBox: Array<Int>, returnType: String) r: String {

    var mainReturnType = returnType
    if mainReturnType == "void" {
        mainReturnType = "i32"
    }

    var mainRetPrefix = "define "
    if mainReturnType == "i64" or mainReturnType == "double" or
        mainReturnType == "i1" {

        mainRetPrefix = "define noundef "
    }
    output.append(mainRetPrefix + mainReturnType +
        " @main(i32 %argc, ptr %argv) #0 {\n")
    output.append("entry:\n")
    output.append("  call void @seen_runtime_init(i32 %argc, ptr %argv)\n")

    preAllocatedRegs = emitPreAllocatedAllocasImpl(output, regBox,
        preAllocatedTypes, structNames, getFeatureTypeAliasNamesImpl(),
        getFeatureTypeAliasTargetsImpl(), getFeatureTypeAliasCountImpl(),
        getFeatureEnumTypeNamesImpl(), getFeatureReprCClassNamesImpl())
    return mainReturnType
}

fun beginDeclarationRegistrationWithGlobalStateImpl(
    program: ProgramNode) r: Void {

    beginDeclarationRegistrationPassImpl(program, structNames,
        structLayouts, structFieldNames, structFieldTypes,
        structLlvmFieldTypes, structSizes, structMethodNames,
        structMethodRetTypes)
}

fun createDeclarationItemContextWithGlobalStateImpl(
    typeAliasNames: String, typeAliasTargets: String,
    typeAliasCount: Int, reprCClassNames: String,
    floatParamFuncNames: Array<String>, floatParamParamIdxs: Array<Int>,
    declState: DeclarationPassState) r: DeclarationItemContext {

    return DeclarationItemContext.new(structNames, typeAliasNames,
        typeAliasTargets, typeAliasCount, reprCClassNames,
        floatParamFuncNames, floatParamParamIdxs, funcNames, funcRetTypes,
        declState)
}

fun initGlobalBootstrapStateImpl() r: Void {
    preAllocatedRegs = Array<String>()
    preAllocatedVars = Array<String>()
    preAllocatedTypes = Array<String>()
    activeVarCount = 0
    structNames = Array<String>()
    structLayouts = Array<String>()
    structFieldNames = Array<String>()
    structFieldTypes = Array<String>()
    structLlvmFieldTypes = Array<String>()
    structSizes = Array<Int>()
    structMethodNames = Array<String>()
    structMethodRetTypes = Array<String>()
    funcNames = Array<String>()
    funcRetTypes = Array<String>()
    classMethodBaseNames = Array<String>()
    typeHeaderPath = ""
    resetGlobalModuleScratchStateImpl()
    resetGlobalModuleConstantsImpl()
}
