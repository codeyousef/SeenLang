}

fun resetGlobalModuleConstantsImpl() r: Void {
    moduleConstantNames = Array<String>()
    moduleConstantValues = Array<String>()
    moduleConstantTypes = Array<String>()
}

fun resetGlobalModuleScratchStateImpl() r: Void {
    currentFunctionReturnType = ""
    currentClassName = ""
    blockTerminated = false
    currentLoopCondLabel = ""
    currentLoopEndLabel = ""
    preAllocatedVars = Array<String>()
    preAllocatedTypes = Array<String>()
    preAllocatedRegs = Array<String>()
    activeVarCount = 0
    declOrdinalNames = Array<String>()
    declOrdinalCounts = Array<Int>()
    stringConstantPrefix = ""
    generatedFunctions = Array<String>()
    generatedClasses = Array<String>()
    typesLoadedFromHeader = false
    runtimeDeclsLoaded = false
    pendingArrayLiteralType = ""
    classMethodBaseNames = Array<String>()
}

fun emitModulePrologueWithGlobalStateImpl(output: StringBuilder) r: Void {
    emitTargetModuleHeaderImpl(output)

    let headerLoadResult = tryLoadTypeHeaderIntoOutputImpl(output,
        typeHeaderPath, structNames, structLayouts, structFieldNames,
        structFieldTypes, structLlvmFieldTypes, structSizes,
        structMethodNames, structMethodRetTypes, moduleConstantNames,
        moduleConstantTypes, moduleConstantValues)
    if headerLoadResult.loaded {
        typesLoadedFromHeader = true
        runtimeDeclsLoaded = headerLoadResult.runtimeDeclsLoaded
        return
    }

    emitBuiltinTypeHeaderImpl(output, generatedClasses)
}

fun emitRuntimeDeclarationsWithGlobalStateImpl(output: StringBuilder,
    definedFuncs: Array<String>) r: Void {

    emitCoreRuntimeDecls(output, runtimeDeclsLoaded, definedFuncs)
    runtimeDeclsLoaded = true
    emitStringAndIODecls(output, definedFuncs)
    emitParserDecls(output, definedFuncs)
    emitTypecheckerDecls(output, runtimeDeclsLoaded, definedFuncs)
    emitMacroAndLspDecls(output, definedFuncs)
    emitFeatureDecls(output, definedFuncs)
}

fun emitGlobalVariablesWithGlobalStateImpl(output: StringBuilder,
    program: ProgramNode, moduleConstMutable: String,
    moduleConstSeenTypes: String) r: ModuleConstantRegistrySnapshot {

    return emitGlobalVariablesSnapshotImpl(output, program,
        moduleConstantNames, moduleConstantTypes, moduleConstantValues,
        moduleConstMutable, moduleConstSeenTypes)
}

fun emitCrossModuleConstantDeclaresWithGlobalStateImpl(output: StringBuilder,
    xmConstNames: String, xmConstTypes: String, xmConstCount: Int) r: Void {

    emitCrossModuleConstantDeclaresImpl(output, moduleConstantNames,
        xmConstNames, xmConstTypes, xmConstCount)
}

fun findModuleConstantWithGlobalStateImpl(name: String,
    moduleConstMutable: String, moduleConstSeenTypes: String,
    xmConstNames: String, xmConstTypes: String, xmConstMutable: String,
    xmConstSeenTypes: String, xmConstCount: Int)
    r: ModuleConstantRegistrySnapshot {

    return findModuleConstantSnapshotImpl(name, moduleConstantNames,
        moduleConstantTypes, moduleConstantValues, moduleConstMutable,
        moduleConstSeenTypes, xmConstNames, xmConstTypes, xmConstMutable,
        xmConstSeenTypes, xmConstCount)
}

fun getModuleConstantTypeWithGlobalStateImpl(idx: Int) r: String {
    if idx < 0 or idx >= moduleConstantTypes.length() {
        return ""
    }
    return moduleConstantTypes[idx]
}

fun tryInferModuleConstantVariableTypeWithGlobalStateImpl(name: String,
    moduleConstMutable: String, moduleConstSeenTypes: String,
    xmConstNames: String, xmConstTypes: String, xmConstMutable: String,
    xmConstSeenTypes: String, xmConstCount: Int)
    r: ModuleConstantRegistrySnapshot {

    if moduleConstantNames.length() == 0 and xmConstCount <= 0 {
        return ModuleConstantRegistrySnapshot.new(moduleConstMutable,
            moduleConstSeenTypes, "", -1)
    }
    return tryInferModuleConstantVariableTypeSnapshotImpl(name,
        moduleConstantNames, moduleConstantTypes, moduleConstantValues,
        moduleConstMutable, moduleConstSeenTypes, xmConstNames,
        xmConstTypes, xmConstMutable, xmConstSeenTypes, xmConstCount)
}

fun getGlobalStructNamesImpl() r: Array<String> {
    return structNames
}

fun getGlobalStructLayoutsImpl() r: Array<String> {
    return structLayouts
}

fun getGlobalStructFieldNamesImpl() r: Array<String> {
    return structFieldNames
}

fun getGlobalStructFieldTypesImpl() r: Array<String> {
