// ir_function_gen.seen — Function decorator handling, preamble generation, and
// expression codegen free functions extracted from llvm_ir_gen.seen
//
// Phase 1: generateLiteralFree (literal expression codegen)
// Phase 4 additions: function signature/default-return/coroutine helpers
// Future phases will add generateExpressionFree dispatch + more sub-generators

import parser.real_parser.{FunctionNode, ParserExpressionNode, StatementNode, BlockNode, ParamNode, TypeNode}
import codegen.ir_optimization.{getNextRegFn, getNextBlockFn, parseIntManual, selfCallCheck, mlShouldInlineWeighted}
import codegen.ir_method_receiver.{quoteIdentIfNeededImpl}
import codegen.ir_trait_registry.{appendTraitImplEntryImpl, autoRegisterTraitImplsImpl}
import codegen.ir_type_mapping.{isClassTypeImpl, mapTypeImpl}
import codegen.type_registry.{CodegenState, csGetNextReg, clearTransientFunctionLoweringOptions}
import codegen.ir_decl_registry.{registerFunctionStateImpl}
import codegen.ir_string_collect.{hexToDecimalImpl, trimSpacesImpl, getBaseTypeNameImpl, cacheStringConstUnchecked}
import codegen.ir_string_emit.{addStringConstantTableImpl}
import codegen.ir_string_emit.{getStringConstantIndexImpl}
import codegen.ir_string_emit.{findStringConstantIndexImpl}
import codegen.ir_function_param_meta.{buildFunctionParameterDeclsImpl, emitFunctionParameterAllocasImpl}
import codegen.ir_function_lowering.{configureFunctionLoweringOptionsImpl, shouldApplyFunctionInlineHeuristicsImpl, countFunctionInlineLoopKindsImpl, appendInlineDecisionAttrImpl, isHighRegisterPressureImpl, emitHighRegisterPressureNoteImpl}
import codegen.ir_function_usage.{hasGeneratedFunctionNameImpl, shouldSkipRuntimeBuiltinStubImpl}
import codegen.ir_type_info.{charToCodeStr}
import str.string.{StringBuilder}

fun ensureFunctionStringBoxValue(box: Array<String>) r: Void {
    if box.length() == 0 {
        box.push("")
    }
}

fun ensureFunctionIntBoxValue(box: Array<Int>) r: Void {
    if box.length() == 0 {
        box.push(0)
    }
}

class NestedScratchStateSnapshot {
    var output: StringBuilder
    var varNames: Array<String>
    var varRegs: Array<String>
    var varTypes: Array<String>
    var preAllocatedVars: Array<String>
    var preAllocatedTypes: Array<String>
    var preAllocatedRegs: Array<String>
    var declOrdinalNames: Array<String>
    var declOrdinalCounts: Array<Int>
    var activeVarCount: Int
    var nextReg: Int
    var blockTerminated: Int
    var currentFunctionReturnType: String

    static fun new() r: NestedScratchStateSnapshot {
        return NestedScratchStateSnapshot{
            output: StringBuilder.new(),
            varNames: Array<String>(),
            varRegs: Array<String>(),
            varTypes: Array<String>(),
            preAllocatedVars: Array<String>(),
            preAllocatedTypes: Array<String>(),
            preAllocatedRegs: Array<String>(),
            declOrdinalNames: Array<String>(),
            declOrdinalCounts: Array<Int>(),
            activeVarCount: 0,
            nextReg: 1,
            blockTerminated: 0,
            currentFunctionReturnType: ""
        }
    }
}

class FunctionInlineHeuristicsAnalysis {
    var funcAttrs: String
    var applied: Int
    var bodySize: Int
    var hasLoopsFlag: Int
    var nestDepth: Int
    var inlineDecision: String

    static fun new() r: FunctionInlineHeuristicsAnalysis {
        return FunctionInlineHeuristicsAnalysis{
            funcAttrs: "",
            applied: 0,
            bodySize: 0,
            hasLoopsFlag: 0,
            nestDepth: 0,
            inlineDecision: ""
        }
    }
}

class FunctionRegisterPressureAnalysis {
    var regPressureCount: Int
    var highPressure: Int

    static fun new() r: FunctionRegisterPressureAnalysis {
        return FunctionRegisterPressureAnalysis{
            regPressureCount: 0,
            highPressure: 0
        }
    }
}

class FunctionGenerationIdentitySnapshot {
    var implFuncName: String
    var resolvedFunctionReturnType: String
    var traitImplRegistry: String
    var traitImplCount: Int
    var alreadyGenerated: Int
    var skipRuntimeBuiltinStub: Int

    static fun new() r: FunctionGenerationIdentitySnapshot {
        return FunctionGenerationIdentitySnapshot{
            implFuncName: "",
            resolvedFunctionReturnType: "",
            traitImplRegistry: "",
            traitImplCount: 0,
            alreadyGenerated: 0,
            skipRuntimeBuiltinStub: 0
        }
    }
}

