class FunctionPreludeAnalysisSnapshot {
    var funcAttrs: String
    var inlineReplayDecision: Int
    var inlineFeatureLog: Int
    var inlineBodySize: Int
    var inlineCallCount: Int
    var inlineHasLoopsFlag: Int
    var inlineNestDepth: Int
    var inlineDecisionAction: String
    var inlineDecisionDetail: String
    var highPressure: Int
