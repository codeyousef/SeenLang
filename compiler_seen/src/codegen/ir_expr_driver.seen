import codegen.ir_codegen_global_state.{getCurrentFunctionReturnTypeWithGlobalStateImpl}
import codegen.ir_codegen_metrics_state.{g_branchesEliminated, g_constantsFolded, g_stringsDeduped, g_inductionVarName}
