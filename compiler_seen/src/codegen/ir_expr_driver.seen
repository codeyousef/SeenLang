class ExpressionDriverState {
    var boundsCheckEnabled: Int
    var boundsCheckLabelCount: Int
    var panicOnOverflow: Bool
    var inductionVarName: String
    var constantsFolded: Int
    var branchesEliminated: Int
    var stringsDeduped: Int
    var closureCount: Int
    var closureDefs: String
    var comptimeParamCount: Int
    var comptimeParamFuncNames: String
    var insideUnsafe: Int
    var currentClassParentName: String
    var asyncFuncNames: String
    var asyncFuncRetTypes: String
    var asyncFuncCount: Int
    var enumVariantNames: String
    var enumVariantTags: String
    var enumVariantFieldTypes: String
    var enumVariantFieldCounts: String
    var enumVariantParent: String
    var enumVariantCount: Int

    static fun new() r: ExpressionDriverState {
        return ExpressionDriverState{
            boundsCheckEnabled: 0,
            boundsCheckLabelCount: 0,
            panicOnOverflow: false,
            inductionVarName: "",
            constantsFolded: 0,
            branchesEliminated: 0,
            stringsDeduped: 0,
            closureCount: 0,
            closureDefs: "",
            comptimeParamCount: 0,
            comptimeParamFuncNames: "",
            insideUnsafe: 0,
            currentClassParentName: "",
            asyncFuncNames: "",
            asyncFuncRetTypes: "",
            asyncFuncCount: 0,
            enumVariantNames: "",
            enumVariantTags: "",
            enumVariantFieldTypes: "",
            enumVariantFieldCounts: "",
            enumVariantParent: "",
            enumVariantCount: 0
        }
    }
}

fun loadExpressionDriverStateFromGlobals() r: ExpressionDriverState {
    let state = ExpressionDriverState.new()
    state.boundsCheckEnabled = getFeatureBoundsCheckEnabledImpl()
    state.boundsCheckLabelCount = getFeatureBoundsCheckLabelCountImpl()
    state.panicOnOverflow = getFeaturePanicOnOverflowImpl()
    state.inductionVarName = g_inductionVarName
    state.constantsFolded = g_constantsFolded
    state.branchesEliminated = g_branchesEliminated
    state.stringsDeduped = g_stringsDeduped
    state.closureCount = getFeatureClosureCountImpl()
    state.closureDefs = getFeatureClosureDefsImpl()
    state.comptimeParamCount = getFeatureComptimeParamCountImpl()
    state.comptimeParamFuncNames = getFeatureComptimeParamFuncNamesImpl()
    state.insideUnsafe = getFeatureInsideUnsafeImpl()
    state.currentClassParentName = getFeatureCurrentClassParentNameImpl()
    state.asyncFuncNames = getFeatureAsyncFuncNamesImpl()
    state.asyncFuncRetTypes = getFeatureAsyncFuncRetTypesImpl()
    state.asyncFuncCount = getFeatureAsyncFuncCountImpl()
    state.enumVariantNames = getFeatureEnumVariantNamesImpl()
    state.enumVariantTags = getFeatureEnumVariantTagsImpl()
    state.enumVariantFieldTypes = getFeatureEnumVariantFieldTypesImpl()
    state.enumVariantFieldCounts = getFeatureEnumVariantFieldCountsImpl()
    state.enumVariantParent = getFeatureEnumVariantParentImpl()
    state.enumVariantCount = getFeatureEnumVariantCountImpl()
    return state
}

fun storeExpressionDriverStateToGlobals(state: ExpressionDriverState)
    r: Void {

    setFeatureBoundsCheckLabelCountImpl(state.boundsCheckLabelCount)
    g_constantsFolded = state.constantsFolded
    g_branchesEliminated = state.branchesEliminated
    g_stringsDeduped = state.stringsDeduped
    setFeatureClosureStateImpl(state.closureCount, state.closureDefs)
}

fun generateExpressionWithGlobalState(ctx: CodegenLoweringContext,
    output: StringBuilder, expr: ParserExpressionNode,
    varNames: Array<String>, varRegs: Array<String>,
    varTypes: Array<String>, stringConstants: Array<String>) r: String {

    let state = loadExpressionDriverStateFromGlobals()
    let result = generateExpressionState(ctx, output, expr, varNames,
        varRegs, varTypes, stringConstants, state)
    storeExpressionDriverStateToGlobals(state)
    return result
}

fun generateLiteralExpressionState(ctx: CodegenLoweringContext,
    expr: ParserExpressionNode, state: ExpressionDriverState) r: String {

    syncLoweringState(ctx)
    let litState = getSharedCodegenState()
    let litResult = generateLiteralFree(litState, expr)
    writeBackLoweringState(ctx)
    if expr.literalType == "String" and expr.literalValue.length() <= 15 {
        state.stringsDeduped = state.stringsDeduped + 1
        mlLogDecision("sso", "inlined", "len:" +
            expr.literalValue.length().toString())
    }
    return litResult
}

fun generateStringInterpolationState(ctx: CodegenLoweringContext,
    output: StringBuilder, expr: ParserExpressionNode,
    varNames: Array<String>, varRegs: Array<String>,
    varTypes: Array<String>, stringConstants: Array<String>,
    state: ExpressionDriverState) r: String {

    let numParts = expr.arguments.length()
    let numExprs = expr.operands.length()
    var partRegs = Array<String>()
    var exprRegs = Array<String>()
    var exprTypes = Array<String>()
    var i = 0
    while i < numParts {
        partRegs.push(generateLiteralExpressionState(ctx, expr.arguments[i],
            state))
        if i < numExprs {
            let interpExpr = expr.operands[i]
            exprTypes.push(inferLoweredExpressionType(ctx, interpExpr))
            exprRegs.push(generateExpressionState(ctx, output, interpExpr,
                varNames, varRegs, varTypes, stringConstants, state))
        }
        i = i + 1
    }
    return generateStringInterpolationFromPartsImpl(output,
        getFeatureRegBoxImpl(), partRegs, exprRegs, exprTypes)
}

fun generateConstructionExpressionState(ctx: CodegenLoweringContext,
    output: StringBuilder, expr: ParserExpressionNode,
    varNames: Array<String>, varRegs: Array<String>,
    varTypes: Array<String>,
    stringConstants: Array<String>, state: ExpressionDriverState) r: String {

    if expr.kind == "StructLiteral" {
        return generateStructLiteralState(ctx, output, expr, varNames,
            varTypes, stringConstants)
    }
    if expr.kind == "ArrayLiteral" {
        return generateArrayLiteralState(ctx, output, expr)
    }
    if expr.kind == "StringInterpolation" {
        return generateStringInterpolationState(ctx, output, expr, varNames,
            varRegs, varTypes, stringConstants, state)
    }
    return ""
}

fun generateConditionalExpressionState(ctx: CodegenLoweringContext,
    output: StringBuilder, expr: ParserExpressionNode,
    varNames: Array<String>, varRegs: Array<String>,
    varTypes: Array<String>, stringConstants: Array<String>,
    state: ExpressionDriverState) r: String {

    if expr.kind == "Elvis" or expr.kind == "NullCoalesce" {
        return generateElvisState(ctx, output, expr)
    }
    if expr.kind == "SafeNavigation" {
        return generateSafeNavigationState(ctx, output, expr, varNames,
            varRegs, varTypes, state.enumVariantNames,
            state.enumVariantParent, state.enumVariantTags,
            state.enumVariantFieldCounts, state.enumVariantCount)
    }
    if expr.kind == "WhenExpression" {
        return generateWhenExpressionState(ctx, output, expr, varNames,
            varRegs, stringConstants, state.enumVariantNames,
            state.enumVariantTags, state.enumVariantFieldTypes,
            state.enumVariantCount)
    }
    if expr.kind == "IfExpression" {
        return generateIfExpressionState(ctx, output, expr)
    }
    return ""
}

fun generateSpecialExpressionState(ctx: CodegenLoweringContext,
    output: StringBuilder, expr: ParserExpressionNode,
    varNames: Array<String>, varRegs: Array<String>,
    varTypes: Array<String>, state: ExpressionDriverState) r: String {

    if expr.kind == "Await" {
        return generateAwaitExpressionState(ctx, output, expr,
            state.asyncFuncNames, state.asyncFuncRetTypes,
            state.asyncFuncCount, getFeatureBlockBoxImpl())
    }
    if expr.kind == "Unary" {
        return generateUnaryState(ctx, output, expr, state.insideUnsafe,
            varNames, varRegs, varTypes)
    }
    if expr.kind == "Cast" {
        return emitCastSpecialExpressionState(ctx, output, expr)
    }
    if expr.kind == "IsExpression" {
        return emitIsExpressionTestState(ctx, output, expr,
            state.enumVariantNames, state.enumVariantTags,
            state.enumVariantCount)
    }
    if expr.kind == "Closure" {
        let closureResult = generateClosureState(ctx, output, expr,
            varNames, varRegs, varTypes, state.closureCount,
            state.closureDefs)
        state.closureCount = closureResult.closureCount
        state.closureDefs = closureResult.closureDefs
        return closureResult.resultReg
    }
    if expr.kind == "UiCallback" {
        let callbackResult = generateUiCallbackState(ctx, output, expr,
            state.closureCount, state.closureDefs)
        state.closureCount = callbackResult.closureCount
        state.closureDefs = callbackResult.closureDefs
        return callbackResult.resultReg
    }
    if expr.kind == "TryPropagate" {
        return emitTryPropagateExpressionState(ctx, output, expr,
            getCurrentFunctionReturnTypeWithGlobalStateImpl())
    }
    return ""
}

fun generateExpressionState(ctx: CodegenLoweringContext,
    output: StringBuilder, expr: ParserExpressionNode,
    varNames: Array<String>, varRegs: Array<String>,
    varTypes: Array<String>, stringConstants: Array<String>,
    state: ExpressionDriverState) r: String {

    if expr.kind == "Literal" {
        return generateLiteralExpressionState(ctx, expr, state)
    }
    if expr.kind == "Variable" or expr.kind == "VarExpr" {
        return generateVariableState(output, varNames, varRegs, varTypes,
            expr)
    }
    if expr.kind == "Binary" {
        let binaryResult = generateBinaryState(ctx, output, expr,
            state.boundsCheckLabelCount, state.panicOnOverflow,
            state.inductionVarName, varNames, varRegs, varTypes,
            stringConstants)
        state.boundsCheckLabelCount = binaryResult.boundsCheckLabelCount
        state.constantsFolded = state.constantsFolded +
            binaryResult.constantsFoldedDelta
        state.branchesEliminated = state.branchesEliminated +
            binaryResult.branchesEliminatedDelta
        return binaryResult.resultReg
    }
    if expr.kind == "Call" {
        let callReg = lowerCallExpression(ctx, expr)
        state.boundsCheckLabelCount = getFeatureBoundsCheckLabelCountImpl()
        return callReg
    }
    if expr.kind == "MethodCall" {
        return generateMethodCallState(ctx, output, expr, varNames, varRegs,
            varTypes, stringConstants)
    }
    if expr.kind == "MemberAccess" {
        return generateMemberAccessState(ctx, output, expr, varNames,
            varRegs, varTypes, state.enumVariantNames,
            state.enumVariantParent, state.enumVariantTags,
            state.enumVariantFieldCounts, state.enumVariantCount)
    }
    if expr.kind == "IndexAccess" {
        let indexResult = generateIndexAccessState(ctx, output, expr,
            varRegs, varTypes, state.boundsCheckEnabled,
            state.boundsCheckLabelCount)
        state.boundsCheckLabelCount = indexResult.boundsCheckLabelCount
        return indexResult.resultReg
    }
    let constructionReg = generateConstructionExpressionState(ctx, output,
        expr, varNames, varRegs, varTypes, stringConstants, state)
    if constructionReg != "" {
        return constructionReg
    }
    let conditionalReg = generateConditionalExpressionState(ctx, output,
        expr, varNames, varRegs, varTypes, stringConstants, state)
    if conditionalReg != "" {
        return conditionalReg
    }
    let specialReg = generateSpecialExpressionState(ctx, output, expr,
        varNames, varRegs, varTypes, state)
    if specialReg != "" {
        return specialReg
    }
    return "0"
}
