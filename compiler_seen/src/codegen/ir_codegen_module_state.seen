///
ir_codegen_module_state.seen - module constants, cross-module declares,
late declare state, and local lookup caches used by LLVM IR generation.
///

import parser.real_parser.{ProgramNode}
import str.string.{StringBuilder}
import codegen.ir_codegen_global_state.{resetGlobalModuleConstantsImpl, emitGlobalVariablesWithGlobalStateImpl, emitCrossModuleConstantDeclaresWithGlobalStateImpl, findModuleConstantWithGlobalStateImpl, getModuleConstantTypeWithGlobalStateImpl, tryInferModuleConstantVariableTypeWithGlobalStateImpl}
import codegen.ir_decl_registry.{DeclarationPassState, LateUserDeclareState, captureLateUserDeclareStateImpl, resetLateUserDeclareStateImpl, emitLateUserDeclaresStateImpl}
import codegen.ir_module_constants.{isModuleConstMutableImpl, getModuleConstSeenTypeImpl, resetModuleConstantGenerationStateImpl, moduleConstantInvariantLoadSuffixImpl}
import codegen.ir_module_emit.{emitCrossModuleFunctionDeclaresIndexedImpl}
import codegen.ir_field_registry.{findCachedIrgenFieldIndexImpl, cacheIrgenFieldIndexImpl, findCachedChainedPathTypeRecordImpl, cacheChainedPathTypeImpl, resetFieldLookupCacheStateImpl}

var g_moduleConstMutable: String = ""
var g_moduleConstSeenTypes: String = ""

var g_xmDeclareNames: String = ""
var g_xmDeclareStrs: String = ""
var g_xmDeclareCount: Int = 0
var g_xmDeclareVis: String = ""
var g_xmDeclareNamesArr: Array<String> = Array<String>()
var g_xmDeclareStrsArr: Array<String> = Array<String>()
var g_xmDeclareVisArr: Array<String> = Array<String>()

var g_lateXmDeclareNames: String = ""
var g_lateXmDeclareStrs: String = ""
var g_lateXmDeclareCount: Int = 0

var g_xmConstNames: String = ""
var g_xmConstTypes: String = ""
var g_xmConstMutable: String = ""
var g_xmConstSeenTypes: String = ""
var g_xmConstCount: Int = 0
var g_xmConstNamesArr: Array<String> = Array<String>()
var g_xmConstTypesArr: Array<String> = Array<String>()
var g_xmConstMutableArr: Array<String> = Array<String>()
var g_xmConstSeenTypesArr: Array<String> = Array<String>()

var g_irgenFieldInfoCacheKeyIds: Array<Int> = Array<Int>()
var g_irgenFieldInfoCacheIdxs: Array<Int> = Array<Int>()
var g_chainedPathTypeCacheKeyIds: Array<Int> = Array<Int>()
var g_chainedPathTypeCacheLens: Array<Int> = Array<Int>()
var g_chainedPathTypeCacheValues: Array<String> = Array<String>()

fun resetModuleBootstrapArraysImpl() r: Void {
    g_xmDeclareNamesArr = Array<String>()
    g_xmDeclareStrsArr = Array<String>()
    g_xmDeclareVisArr = Array<String>()
    g_xmConstNamesArr = Array<String>()
    g_xmConstTypesArr = Array<String>()
    g_xmConstMutableArr = Array<String>()
    g_xmConstSeenTypesArr = Array<String>()
    resetIrgenFieldLookupCaches()
}

fun findCachedIrgenFieldIndex(key: String) r: Int {
    return findCachedIrgenFieldIndexImpl(key, g_irgenFieldInfoCacheKeyIds,
        g_irgenFieldInfoCacheIdxs)
}

fun cacheIrgenFieldIndex(key: String, idx: Int) r: Void {
    cacheIrgenFieldIndexImpl(key, idx, g_irgenFieldInfoCacheKeyIds,
        g_irgenFieldInfoCacheIdxs)
}

fun findCachedChainedPathTypeRecord(key: String, structLen: Int) r: Int {
    return findCachedChainedPathTypeRecordImpl(key, structLen,
        g_chainedPathTypeCacheKeyIds, g_chainedPathTypeCacheLens)
}

fun cacheChainedPathType(key: String, structLen: Int, resultType: String) r: Void {
    cacheChainedPathTypeImpl(key, structLen, resultType,
        g_chainedPathTypeCacheKeyIds, g_chainedPathTypeCacheLens,
        g_chainedPathTypeCacheValues)
}

fun getCachedChainedPathTypeValue(index: Int) r: String {
    return g_chainedPathTypeCacheValues[index]
}

fun resetModuleConstantGenerationState() r: Void {
    let moduleConstState = resetModuleConstantGenerationStateImpl()
    resetGlobalModuleConstantsImpl()
    g_moduleConstMutable = moduleConstState.moduleConstMutable
    g_moduleConstSeenTypes = moduleConstState.moduleConstSeenTypes
}

fun emitProgramGlobalVariablesWithModuleStateImpl(output: StringBuilder,
    program: ProgramNode) r: Void {

    let moduleConstSnapshot = emitGlobalVariablesWithGlobalStateImpl(output,
        program, g_moduleConstMutable, g_moduleConstSeenTypes)
    g_moduleConstMutable = moduleConstSnapshot.moduleConstMutable
    g_moduleConstSeenTypes = moduleConstSnapshot.moduleConstSeenTypes
}

fun emitCrossModuleConstantDeclaresWithModuleStateImpl(
    output: StringBuilder) r: Void {

    emitCrossModuleConstantDeclaresWithGlobalStateImpl(output,
        g_xmConstNames, g_xmConstTypes, g_xmConstCount,
        g_xmConstNamesArr, g_xmConstTypesArr)
}

fun emitCrossModuleFunctionDeclaresWithModuleStateImpl(output: StringBuilder,
    definedFuncs: Array<String>) r: Void {

    emitCrossModuleFunctionDeclaresIndexedImpl(output, definedFuncs,
        g_xmDeclareNamesArr, g_xmDeclareStrsArr, g_xmDeclareCount)
}

fun findModuleConstantWithModuleStateImpl(name: String) r: Int {
    let moduleConstLookup = findModuleConstantWithGlobalStateImpl(name,
        g_moduleConstMutable, g_moduleConstSeenTypes, g_xmConstNames,
        g_xmConstTypes, g_xmConstMutable, g_xmConstSeenTypes,
        g_xmConstCount)
    g_moduleConstMutable = moduleConstLookup.moduleConstMutable
    g_moduleConstSeenTypes = moduleConstLookup.moduleConstSeenTypes
    return moduleConstLookup.constIndex
}

fun getModuleConstantTypeWithModuleStateImpl(idx: Int) r: String {
    return getModuleConstantTypeWithGlobalStateImpl(idx)
}

fun getModuleConstSeenTypeWithModuleStateImpl(idx: Int) r: String {
    return getModuleConstSeenTypeImpl(idx, g_moduleConstSeenTypes)
}

fun isModuleConstMutableWithModuleStateImpl(idx: Int) r: Bool {
    return isModuleConstMutableImpl(idx, g_moduleConstMutable)
}

fun moduleConstantInvariantLoadSuffixWithModuleStateImpl(idx: Int) r: String {
    return moduleConstantInvariantLoadSuffixImpl(idx, g_moduleConstMutable)
}

fun tryInferModuleConstantVariableTypeWithModuleStateImpl(
    name: String) r: String {

    let moduleConstLookup =
        tryInferModuleConstantVariableTypeWithGlobalStateImpl(name,
            g_moduleConstMutable, g_moduleConstSeenTypes, g_xmConstNames,
            g_xmConstTypes, g_xmConstMutable, g_xmConstSeenTypes,
            g_xmConstCount)
    g_moduleConstMutable = moduleConstLookup.moduleConstMutable
    g_moduleConstSeenTypes = moduleConstLookup.moduleConstSeenTypes
    return moduleConstLookup.seenType
}

fun resetLateUserDeclareState() r: Void {
    let lateState = resetLateUserDeclareStateImpl()
    g_lateXmDeclareNames = lateState.lateXmDeclareNames
    g_lateXmDeclareStrs = lateState.lateXmDeclareStrs
    g_lateXmDeclareCount = lateState.lateXmDeclareCount
}

fun captureModuleLateUserDeclareState() r: LateUserDeclareState {
    return captureLateUserDeclareStateImpl(g_lateXmDeclareNames,
        g_lateXmDeclareStrs, g_lateXmDeclareCount)
}

fun applyModuleLateUserDeclareState(lateState: LateUserDeclareState) r: Void {
    g_lateXmDeclareNames = lateState.lateXmDeclareNames
    g_lateXmDeclareStrs = lateState.lateXmDeclareStrs
    g_lateXmDeclareCount = lateState.lateXmDeclareCount
}

fun emitLateUserDeclaresWithModuleStateImpl(output: StringBuilder,
    definedFuncs: Array<String>) r: Void {

    emitLateUserDeclaresStateImpl(output, definedFuncs, g_lateXmDeclareNames,
        g_lateXmDeclareStrs, g_lateXmDeclareCount)
}

fun populateModuleDeclarationPassStateImpl(
    declState: DeclarationPassState) r: Void {

    declState.xmDeclareNames = g_xmDeclareNames
    declState.xmDeclareStrs = g_xmDeclareStrs
    declState.xmDeclareVis = g_xmDeclareVis
    declState.xmDeclareNamesArr = g_xmDeclareNamesArr
    declState.xmDeclareStrsArr = g_xmDeclareStrsArr
    declState.xmDeclareVisArr = g_xmDeclareVisArr
    declState.xmDeclareCount = g_xmDeclareCount
    declState.xmConstNames = g_xmConstNames
    declState.xmConstTypes = g_xmConstTypes
    declState.xmConstMutable = g_xmConstMutable
    declState.xmConstSeenTypes = g_xmConstSeenTypes
    declState.xmConstCount = g_xmConstCount
    declState.xmConstNamesArr = g_xmConstNamesArr
    declState.xmConstTypesArr = g_xmConstTypesArr
    declState.xmConstMutableArr = g_xmConstMutableArr
    declState.xmConstSeenTypesArr = g_xmConstSeenTypesArr
}

fun applyModuleDeclarationPassStateImpl(
    declState: DeclarationPassState) r: Void {

    g_xmDeclareNames = declState.xmDeclareNames
    g_xmDeclareStrs = declState.xmDeclareStrs
    g_xmDeclareVis = declState.xmDeclareVis
    g_xmDeclareNamesArr = declState.xmDeclareNamesArr
    g_xmDeclareStrsArr = declState.xmDeclareStrsArr
    g_xmDeclareVisArr = declState.xmDeclareVisArr
    g_xmDeclareCount = declState.xmDeclareCount
    g_xmConstNames = declState.xmConstNames
    g_xmConstTypes = declState.xmConstTypes
    g_xmConstMutable = declState.xmConstMutable
    g_xmConstSeenTypes = declState.xmConstSeenTypes
    g_xmConstCount = declState.xmConstCount
    g_xmConstNamesArr = declState.xmConstNamesArr
    g_xmConstTypesArr = declState.xmConstTypesArr
    g_xmConstMutableArr = declState.xmConstMutableArr
    g_xmConstSeenTypesArr = declState.xmConstSeenTypesArr
}

fun resetIrgenFieldLookupCaches() r: Void {
    let cacheState = resetFieldLookupCacheStateImpl()
    g_irgenFieldInfoCacheKeyIds = cacheState.fieldInfoCacheKeyIds
    g_irgenFieldInfoCacheIdxs = cacheState.fieldInfoCacheIdxs
    g_chainedPathTypeCacheKeyIds = cacheState.chainedPathTypeCacheKeyIds
    g_chainedPathTypeCacheLens = cacheState.chainedPathTypeCacheLens
    g_chainedPathTypeCacheValues = cacheState.chainedPathTypeCacheValues
}
