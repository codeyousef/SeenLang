///
E-graph Core Data Structure with Union-Find
Based on "egg: Fast and Extensible Equality Saturation" (Willsey et al.)
Uses integer-indexed arrays for stage1 compatibility
///

// An e-node: operation + children (e-class ids)
class ENode {
    let op: String              // operation name (e.g., "add", "mul", "const_0")
    let children: Array<Int>    // e-class ids of children

    static fun new(op: String, children: Array<Int>) r: ENode {
        return ENode{
            op: op,
            children: children
        }
    }

    // Check if two e-nodes are structurally equal
    fun equals(other: ENode) r: Bool {
        if this.op != other.op {
            return false
        }
        if this.children.length() != other.children.length() {
            return false
        }
        var i = 0
        while i < this.children.length() {
            if this.children[i] != other.children[i] {
                return false
            }
            i = i + 1
        }
        return true
    }
}

// E-graph: the core equality saturation data structure
class EGraph {
    // Union-find parent array (maps e-class id -> parent id)
    var parents: Array<Int>
    // Union-find rank array (for union by rank)
    var ranks: Array<Int>
    ///
    E-class id -> list of e-node indices in this class
    Stored as flattened: classNodes[id*maxNodesPerClass .. (id+1)*maxNodesPerClass]
    We use a simpler approach: one Array<Int> per class mapped by nodeClassMap
    ///
    var nodeOps: Array<String>        // e-node operation at index i
    var nodeChildrenFlat: Array<Int>  // flattened children: [numChildren, child0, child1, ...]
    var nodeChildrenOffsets: Array<Int> // offset into nodeChildrenFlat for node i
    var nodeClassId: Array<Int>       // which e-class does node i belong to?
    var nodeSignatureHashes: Array<Int> // hash-consing hash for op + canonical children
    var signatureBuckets: Array<Int>  // hash bucket -> first node index
    var signatureNext: Array<Int>     // node index -> next node in hash bucket
    var classNodeHeads: Array<Int>    // e-class id -> first node index
    var classNodeNext: Array<Int>     // node index -> next node in class list
    var numClasses: Int
    var activeClassCount: Int
    var numNodes: Int
    var dirty: Bool                   // needs rebuild?

    static fun new() r: EGraph {
        return EGraph{
            parents: Array<Int>(),
            ranks: Array<Int>(),
            nodeOps: Array<String>(),
            nodeChildrenFlat: Array<Int>(),
            nodeChildrenOffsets: Array<Int>(),
            nodeClassId: Array<Int>(),
            nodeSignatureHashes: Array<Int>(),
            signatureBuckets: EGraph.emptyBuckets(4096),
            signatureNext: Array<Int>(),
            classNodeHeads: Array<Int>(),
            classNodeNext: Array<Int>(),
            numClasses: 0,
            activeClassCount: 0,
            numNodes: 0,
            dirty: false
        }
    }

    static fun emptyBuckets(capacity: Int) r: Array<Int> {
        let buckets = Array<Int>(capacity)
        var i = 0
        while i < capacity {
            buckets.push(-1)
            i = i + 1
        }
        return buckets
    }

    // Find the canonical representative of an e-class (with path compression)
    fun find(id: Int) r: Int {
        if id < 0 {
            return id
        }
        if id >= this.parents.length() {
            return id
        }
        var current = id
        // Walk up to root
        while this.parents[current] != current {
            current = this.parents[current]
        }
        let root = current
        // Path compression: set all nodes on path to point directly to root
        current = id
        while this.parents[current] != root {
            let next = this.parents[current]
            this.parents[current] = root
            current = next
        }
        return root
    }

    ///
    Add an e-node to the graph, returning its e-class id
    If an equivalent node already exists, returns its class
    ///
    fun add(op: String, children: Array<Int>) r: Int {
        if this.dirty {
            this.rebuild()
        }

        // Canonicalize children
        var canonChildren = Array<Int>()
        var ci = 0
        while ci < children.length() {
            canonChildren.push(find(children[ci]))
            ci = ci + 1
        }

        let signatureHash = this.signatureHash(op, canonChildren)
        let bucket = this.signatureBucket(signatureHash)

        // Check if equivalent node already exists (deduplication)
        var ni = this.signatureBuckets[bucket]
        while ni >= 0 {
            if this.nodeOps[ni] == op {
                // Check if children match
                let offset = this.nodeChildrenOffsets[ni]
                let numKids = this.nodeChildrenFlat[offset]
                if numKids == canonChildren.length() {
                    var matchInt = 1
                    var ki = 0
                    while ki < numKids {
                        if find(this.nodeChildrenFlat[offset + 1 + ki]) != canonChildren[ki] {
                            matchInt = 0
                            ki = numKids  // break
                        }
                        ki = ki + 1
                    }
                    if matchInt == 1 {
                        return find(this.nodeClassId[ni])
                    }
                }
            }
            ni = this.signatureNext[ni]
        }

        // Create new e-class
        let classId = this.numClasses
        this.parents.push(classId)
        this.ranks.push(0)
        this.classNodeHeads.push(-1)
        this.numClasses = this.numClasses + 1
        this.activeClassCount = this.activeClassCount + 1

        // Create new e-node
        let nodeIdx = this.numNodes
        this.nodeOps.push(op)
        this.nodeClassId.push(classId)
        this.nodeSignatureHashes.push(signatureHash)
        let flatOffset = this.nodeChildrenFlat.length()
        this.nodeChildrenOffsets.push(flatOffset)
        this.nodeChildrenFlat.push(canonChildren.length())
        var cj = 0
        while cj < canonChildren.length() {
            this.nodeChildrenFlat.push(canonChildren[cj])
            cj = cj + 1
        }
        this.signatureNext.push(this.signatureBuckets[bucket])
        this.signatureBuckets[bucket] = nodeIdx
        this.classNodeNext.push(this.classNodeHeads[classId])
        this.classNodeHeads[classId] = nodeIdx
        this.numNodes = this.numNodes + 1
        this.ensureSignatureCapacity()

        return classId
    }

    // Merge two e-classes (union)
    fun merge(id1: Int, id2: Int) r: Int {
        let root1 = find(id1)
        let root2 = find(id2)
        if root1 == root2 {
            return root1
        }

        // Union by rank
        if this.ranks[root1] < this.ranks[root2] {
            this.parents[root1] = root2
            this.activeClassCount = this.activeClassCount - 1
            this.dirty = true
            return root2
        }
        if this.ranks[root1] > this.ranks[root2] {
            this.parents[root2] = root1
            this.activeClassCount = this.activeClassCount - 1
            this.dirty = true
            return root1
        }
        // Equal rank: pick root1 as new root, increment rank
        this.parents[root2] = root1
        this.ranks[root1] = this.ranks[root1] + 1
        this.activeClassCount = this.activeClassCount - 1
        this.dirty = true
        return root1
    }

    // Rebuild: re-canonicalize all e-nodes after merges
    fun rebuild() r: Bool {
        if not this.dirty {
            return false
        }
        // Re-canonicalize children of all nodes
        var ni = 0
        while ni < this.numNodes {
            let offset = this.nodeChildrenOffsets[ni]
            let numKids = this.nodeChildrenFlat[offset]
            var ki = 0
            while ki < numKids {
                this.nodeChildrenFlat[offset + 1 + ki] = find(this.nodeChildrenFlat[offset + 1 + ki])
                ki = ki + 1
            }
            // Re-canonicalize the node's class
            this.nodeClassId[ni] = find(this.nodeClassId[ni])
            this.nodeSignatureHashes[ni] = this.signatureHashNode(ni)
            ni = ni + 1
        }
        this.rebuildSignatureIndex()
        this.rebuildClassNodeIndex()
        this.dirty = false
        return true
    }

    // Get the operation of a node
    fun nodeOp(nodeIdx: Int) r: String {
        if nodeIdx < 0 {
            return ""
        }
        if nodeIdx >= this.numNodes {
            return ""
        }
        return this.nodeOps[nodeIdx]
    }

    // Get the children e-class ids of a node
    fun nodeChildren(nodeIdx: Int) r: Array<Int> {
        var result = Array<Int>()
        if nodeIdx < 0 {
            return result
        }
        if nodeIdx >= this.numNodes {
            return result
        }
        let offset = this.nodeChildrenOffsets[nodeIdx]
        let numKids = this.nodeChildrenFlat[offset]
        var ki = 0
        while ki < numKids {
            result.push(find(this.nodeChildrenFlat[offset + 1 + ki]))
            ki = ki + 1
        }
        return result
    }

    // Get all node indices belonging to an e-class
    fun classNodes(classId: Int) r: Array<Int> {
        if this.dirty {
            this.rebuild()
        }
        let canon = find(classId)
        var result = Array<Int>()
        if canon < 0 or canon >= this.classNodeHeads.length() {
            return result
        }
        var ni = this.classNodeHeads[canon]
        while ni >= 0 {
            result.push(ni)
            ni = this.classNodeNext[ni]
        }
        return result
    }

    // Get total number of e-classes
    fun classCount() r: Int {
        if this.activeClassCount < 0 {
            return 0
        }
        return this.activeClassCount
    }

    fun signatureHash(op: String, children: Array<Int>) r: Int {
        var hash = 2166136261
        var i = 0
        while i < op.length() {
            hash = hash ^ op.byteAt(i)
            hash = hash * 16777619
            i = i + 1
        }

        i = 0
        while i < children.length() {
            hash = hash ^ children[i]
            hash = hash * 16777619
            i = i + 1
        }
        return hash
    }

    fun signatureHashNode(nodeIdx: Int) r: Int {
        var hash = 2166136261
        let op = this.nodeOps[nodeIdx]
        var i = 0
        while i < op.length() {
            hash = hash ^ op.byteAt(i)
            hash = hash * 16777619
            i = i + 1
        }

        let offset = this.nodeChildrenOffsets[nodeIdx]
        let numKids = this.nodeChildrenFlat[offset]
        i = 0
        while i < numKids {
            hash = hash ^ this.nodeChildrenFlat[offset + 1 + i]
            hash = hash * 16777619
            i = i + 1
        }
        return hash
    }

    fun signatureBucket(hash: Int) r: Int {
        let mask = this.signatureBuckets.length() - 1
        return hash & mask
    }

    fun ensureSignatureCapacity() r: Void {
        if this.numNodes <= this.signatureBuckets.length() * 2 {
            return
        }
        this.signatureBuckets = EGraph.emptyBuckets(this.signatureBuckets.length() * 2)
        this.rebuildSignatureIndex()
    }

    fun rebuildSignatureIndex() r: Void {
        var i = 0
        while i < this.signatureBuckets.length() {
            this.signatureBuckets[i] = -1
            i = i + 1
        }

        this.signatureNext = Array<Int>(this.numNodes)
        i = 0
        while i < this.numNodes {
            this.signatureNext.push(-1)
            i = i + 1
        }

        i = 0
        while i < this.numNodes {
            let bucket = this.signatureBucket(this.nodeSignatureHashes[i])
            this.signatureNext[i] = this.signatureBuckets[bucket]
            this.signatureBuckets[bucket] = i
            i = i + 1
        }
    }

    fun rebuildClassNodeIndex() r: Void {
        this.classNodeHeads = EGraph.emptyBuckets(this.numClasses)
        this.classNodeNext = Array<Int>(this.numNodes)

        var i = 0
        while i < this.numNodes {
            this.classNodeNext.push(-1)
            i = i + 1
        }

        i = 0
        while i < this.numNodes {
            let classId = find(this.nodeClassId[i])
            this.nodeClassId[i] = classId
            this.classNodeNext[i] = this.classNodeHeads[classId]
            this.classNodeHeads[classId] = i
            i = i + 1
        }
    }
}
