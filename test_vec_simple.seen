import collections.vec.{Vec}

fun main() {
    println("Creating Vec...")
    let v = Vec.new()
    println("Vec created")

    println("Pushing 1...")
    v.push(1)
    println("After push 1, length: " + v.len().toString())

    println("Pushing 2...")
    v.push(2)
    println("After push 2, length: " + v.len().toString())

    println("Pushing 3...")
    v.push(3)
    println("After push 3, length: " + v.len().toString())

    println("Done")
}
