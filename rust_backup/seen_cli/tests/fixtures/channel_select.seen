fun Main() -> Int {
    let endpoints1 = Channel()
    let ch1 = endpoints1.Sender
    let rx1 = endpoints1.Receiver

    let endpoints2 = Channel()
    let ch2 = endpoints2.Sender
    let rx2 = endpoints2.Receiver

    scope {
        spawn {
            await send 1 to ch1
        }
        spawn {
            await send 2 to ch2
        }

        let first = select {
            rx1 -> _ => {
                println("1")
                1
            },
            rx2 -> _ => {
                println("2")
                2
            }
        }

        let second = select {
            rx1 -> _ => {
                println("1")
                1
            },
            rx2 -> _ => {
                println("2")
                2
            }
        }

        second + first
    }
}

Main()
