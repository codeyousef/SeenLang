{
  "comments": {
    "lineComment": "//",
    "blockComment": ["///", "///"]
  },
  "brackets": [
    ["{", "}"],
    ["[", "]"],
    ["(", ")"]
  ],
  "autoClosingPairs": [
    ["{", "}"],
    ["[", "]"],
    ["(", ")"],
    ["\"", "\""],
    ["'", "'"],
    ["`", "`"]
  ],
  "surroundingPairs": [
    ["{", "}"],
    ["[", "]"],
    ["(", ")"],
    ["\"", "\""],
    ["'", "'"],
    ["`", "`"]
  ],
  "indentationRules": {
    "increaseIndentPattern": "^\\s*(class|struct|data|enum|fun|if|else|for|while|match|loop|try|catch|finally|extension|interface|object|sealed|region|arena|defer|impl|trait|unsafe|parallel_for|when|comptime|\\{)\\s*$",
    "decreaseIndentPattern": "^\\s*(\\}|else|catch|finally)\\s*$"
  },
  "onEnterRules": [
    {
      "beforeText": "^\\s*///\\s*$",
      "action": {
        "indent": "none",
        "appendText": ""
      }
    },
    {
      "beforeText": "^\\s*.*\\{\\s*$",
      "afterText": "^\\s*\\}",
      "action": {
        "indent": "indentOutdent",
        "appendText": ""
      }
    },
    {
      "beforeText": "^\\s*.*\\{\\s*$",
      "action": {
        "indent": "indent",
        "appendText": ""
      }
    },
    {
      "beforeText": "^\\s*(fun|if|else|for|while|match|loop|class|struct|data|enum|interface|object|sealed|extension|region|arena|defer|try|catch|finally|impl|trait|unsafe|parallel_for|when|comptime)\\b.*$",
      "action": {
        "indent": "none"
      }
    },
    {
      "beforeText": "^\\s*//.*$",
      "action": {
        "indent": "none",
        "appendText": "// "
      }
    }
  ],
  "folding": {
    "markers": {
      "start": "^\\s*//\\s*#?region\\b",
      "end": "^\\s*//\\s*#?endregion\\b"
    }
  },
  "wordPattern": "(-?\\d*\\.\\d\\w*)|([^\\`\\~\\!\\@\\#\\%\\^\\&\\*\\(\\)\\-\\=\\+\\[\\{\\]\\}\\\\\\|\\;\\:\\'\\\"\\,\\.\\<\\>\\/\\?\\s]+)"
}
