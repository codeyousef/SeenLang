///
Synthetic: String-heavy workload (parsing, building, searching)
Represents: CLI tools, compilers, text processors
///

fun countLines(text: String) r: Int {
    var count = 0
    var i = 0
    while i < text.length() {
        if text.substring(i, i + 1) == "\n" {
            count = count + 1
        }
        i = i + 1
    }
    return count
}

fun buildCsv(rows: Int, cols: Int) r: String {
    var result = ""
    var r_idx = 0
    while r_idx < rows {
        var c_idx = 0
        while c_idx < cols {
            if c_idx > 0 {
                result = result + ","
            }
            result = result + r_idx.toString() + "_" + c_idx.toString()
            c_idx = c_idx + 1
        }
        result = result + "\n"
        r_idx = r_idx + 1
    }
    return result
}

fun findSubstring(haystack: String, needle: String) r: Int {
    var i = 0
    let needleLen = needle.length()
    let limit = haystack.length() - needleLen
    while i <= limit {
        let sub = haystack.substring(i, i + needleLen)
        if sub == needle {
            return i
        }
        i = i + 1
    }
    return 0 - 1
}

fun countOccurrences(text: String, pattern: String) r: Int {
    var count = 0
    var pos = 0
    let patLen = pattern.length()
    while pos <= text.length() - patLen {
        let sub = text.substring(pos, pos + patLen)
        if sub == pattern {
            count = count + 1
        }
        pos = pos + 1
    }
    return count
}

fun splitByDelimiter(text: String, delim: String) r: Array<String> {
    var parts = Array<String>()
    var start = 0
    var i = 0
    while i < text.length() {
        if text.substring(i, i + 1) == delim {
            parts.push(text.substring(start, i))
            start = i + 1
        }
        i = i + 1
    }
    if start < text.length() {
        parts.push(text.substring(start, text.length()))
    }
    return parts
}

fun padLeft(s: String, width: Int) r: String {
    var result = s
    while result.length() < width {
        result = " " + result
    }
    return result
}

fun repeatString(s: String, times: Int) r: String {
    var result = ""
    var i = 0
    while i < times {
        result = result + s
        i = i + 1
    }
    return result
}

fun main() r: Void {
    // Build a moderately large CSV
    let csv = buildCsv(50, 10)
    let lines = countLines(csv)
    println("CSV lines: " + lines.toString())

    // Parse it back
    let rows = splitByDelimiter(csv, "\n")
    var totalCells = 0
    var ri = 0
    while ri < rows.length() {
        let row = rows[ri]
        if row.length() > 0 {
            let cells = splitByDelimiter(row, ",")
            totalCells = totalCells + cells.length()
        }
        ri = ri + 1
    }
    println("Total cells: " + totalCells.toString())

    // Search operations
    let occurrences = countOccurrences(csv, "25")
    println("Occurrences of '25': " + occurrences.toString())

    let pos = findSubstring(csv, "30_5")
    println("Position of '30_5': " + pos.toString())

    // String building
    let padded = padLeft("hello", 20)
    println("Padded: '" + padded + "'")

    let repeated = repeatString("ab", 100)
    println("Repeated length: " + repeated.length().toString())
}
