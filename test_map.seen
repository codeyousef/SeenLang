import collections.map.{Map}
import core.option.{Option}

fun main() r: Int {
    println("Creating map...")
    var map: Map<String, Int> = Map.new()
    println("Adding entries...")
    map.put("hello", 1)
    println("Added 1")
    map.put("world", 2)
    println("Added 2")
    let len = map.size()
    println("Map size: " + len.toString())
    return 0
}
