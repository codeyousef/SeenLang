DEFAULT: no main function → triggers "missing main" error
(leave the file with only comments to see the error)
///

///
ERROR 1: Missing main
fun notMain() r: Int { return 0 }
///

///
ERROR 2: Working program (no errors)
fun main() r: Int {
    println("Hello, world!")
    return 0
}
