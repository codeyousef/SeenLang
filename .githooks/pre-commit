#!/bin/bash
# Pre-commit hook: Verify bootstrap before allowing commit of compiler changes
#
# This hook runs bootstrap verification when compiler files are modified.
# It prevents commits that would break the self-hosted compiler.
#
# To install: git config core.hooksPath .githooks
# To bypass (not recommended): git commit --no-verify

# Colors
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
NC='\033[0m'

# Check if any compiler files are being committed
COMPILER_FILES=$(git diff --cached --name-only | grep -E "^compiler_seen/src/" || true)

if [ -z "$COMPILER_FILES" ]; then
    # No compiler files changed, allow commit
    exit 0
fi

echo -e "${YELLOW}Compiler files changed - running bootstrap verification...${NC}"
echo ""
echo "Changed files:"
echo "$COMPILER_FILES" | head -10
TOTAL=$(echo "$COMPILER_FILES" | wc -l)
if [ "$TOTAL" -gt 10 ]; then
    echo "... and $((TOTAL - 10)) more"
fi
echo ""

# Check if frozen compiler exists
if [ ! -f "bootstrap/stage1_frozen" ]; then
    echo -e "${RED}ERROR: Frozen compiler not found at bootstrap/stage1_frozen${NC}"
    echo "Cannot verify bootstrap. Commit blocked."
    echo ""
    echo "To bypass (not recommended): git commit --no-verify"
    exit 1
fi

# Run safe rebuild in verification mode
FROZEN="bootstrap/stage1_frozen"
STAGE2="/tmp/precommit_stage2_$$"
STAGE3="/tmp/precommit_stage3_$$"
COMPILER_SOURCE="compiler_seen/src/main_compiler.seen"

# Build stage2
echo "Building stage2..."
rm -rf .seen_cache
if ! $FROZEN compile "$COMPILER_SOURCE" "$STAGE2" > /tmp/precommit_stage2.log 2>&1; then
    echo -e "${RED}ERROR: Stage2 build failed!${NC}"
    echo ""
    echo "Build output (last 20 lines):"
    tail -20 /tmp/precommit_stage2.log
    echo ""
    echo -e "${RED}COMMIT BLOCKED: Your changes break compilation.${NC}"
    rm -f "$STAGE2"
    exit 1
fi

# Build stage3
echo "Building stage3 (--fast)..."
rm -rf .seen_cache
if ! $STAGE2 compile "$COMPILER_SOURCE" "$STAGE3" --fast > /tmp/precommit_stage3.log 2>&1; then
    echo -e "${RED}ERROR: Stage3 build failed!${NC}"
    echo ""
    echo "Build output (last 20 lines):"
    tail -20 /tmp/precommit_stage3.log
    echo ""
    echo -e "${RED}COMMIT BLOCKED: Your changes break bootstrap.${NC}"
    rm -f "$STAGE2" "$STAGE3"
    exit 1
fi

# Verify bootstrap
echo "Verifying bootstrap..."
if diff "$STAGE2" "$STAGE3" > /dev/null 2>&1; then
    echo -e "${GREEN}Bootstrap verified (stage2 == stage3).${NC}"
    rm -f "$STAGE2" "$STAGE3"
    echo ""
    echo -e "${GREEN}Commit allowed.${NC}"
    exit 0
fi

# Try stage4 verification
echo "Stage2 != Stage3, checking stage4..."
STAGE4="/tmp/precommit_stage4_$$"

rm -rf .seen_cache
if ! $STAGE3 compile "$COMPILER_SOURCE" "$STAGE4" --fast > /tmp/precommit_stage4.log 2>&1; then
    echo -e "${RED}ERROR: Stage4 build failed!${NC}"
    rm -f "$STAGE2" "$STAGE3" "$STAGE4"
    exit 1
fi

if diff "$STAGE3" "$STAGE4" > /dev/null 2>&1; then
    echo -e "${GREEN}Bootstrap verified (stage3 == stage4).${NC}"
    rm -f "$STAGE2" "$STAGE3" "$STAGE4"
    echo ""
    echo -e "${GREEN}Commit allowed.${NC}"
    exit 0
fi

# Bootstrap failed
echo ""
echo -e "${RED}COMMIT BLOCKED: Bootstrap verification failed!${NC}"
echo ""
echo "Your changes break the self-hosted compiler."
echo ""
echo "Hashes:"
sha256sum "$STAGE2" "$STAGE3" "$STAGE4" 2>/dev/null || true
echo ""
echo "Options:"
echo "  1. Fix your changes to maintain bootstrap compatibility"
echo "  2. Use 'git commit --no-verify' to bypass (NOT RECOMMENDED)"
echo ""
rm -f "$STAGE2" "$STAGE3" "$STAGE4"
exit 1
