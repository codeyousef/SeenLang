extern fun __Print(s: String)
extern fun __PrintInt(n: Int)

class Chunk<T> {
    var values: Array<T>
}

class ChunkVec<T> {
    var chunks: Array<Chunk<T>>
    var capacities: Array<Int>
    var usage: Array<Int>
    var length: Int
    var totalCapacity: Int
    var nextChunkSize: Int
    
    static fun new() r: ChunkVec<T> {
        return ChunkVec{
            chunks: Array<Chunk<T>>(),
            capacities: Array<Int>(),
            usage: Array<Int>(),
            length: 0,
            totalCapacity: 0,
            nextChunkSize: 8
        }
    }
}

fun main() {
    __Print("Creating ChunkVec<Int>...\n")
    var v = ChunkVec<Int>.new()
    __Print("ChunkVec created\n")
    __Print("v.length = ")
    __PrintInt(v.length)
    __Print("\n")
    __Print("v.totalCapacity = ")
    __PrintInt(v.totalCapacity)
    __Print("\n")
    __Print("v.nextChunkSize = ")
    __PrintInt(v.nextChunkSize)
    __Print("\n")
}
