import env.env.{args}

fun GetCommandLineArgs() r: Array<String> {
    let rawArgs = args()
    var list: Array<String> = []
    var index = 0
    while index < rawArgs.length() {
        list.push(rawArgs[index])
        index = index + 1
    }
    return list
}

fun main() r: Int {
    let myArgs = GetCommandLineArgs()
    if myArgs.size() < 2 {
        return 1
    }
    return 0
}
