import io.file.{readText}

extern fun __Print(s: String)
extern fun __PrintInt(n: Int)

fun main() r: Int {
    let content = readText("test_stage1_compile.seen")
    __Print("Content length: ")
    __PrintInt(content.len())
    __Print("")
    __Print("First 20 chars: ")
    
    var i = 0
    while i < 20 and i < content.len() {
        let c = content.charAt(i)
        __Print(c.toString())
        i = i + 1
    }
    __Print("")
    return 0
}

main()
