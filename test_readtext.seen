import io.file.{readText}

extern fun __Print(s: String)
extern fun __PrintInt(n: Int)

fun main() {
    __Print("Starting...\n")
    let content = readText("test_simple_stage1.seen")
    __Print("Read file, len = ")
    __PrintInt(content.len())
    __Print("\n")
    __Print("Content: ")
    __Print(content)
    __Print("\n")
}
