        "public_delay_72_hours_elapsed",
        "fresh_source_proof",
        "immutable_scan_input"
      ]
    },
    {
      "from": "second-scanning",
      "to": "delayed",
      "requires": ["retryable_scanner_outage_or_inconclusive_result"]
