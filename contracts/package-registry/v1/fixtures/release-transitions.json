      "quarantined",
      "first-scanning",
      "delayed",
      "second-scanning",
      "ready",
      "active",
      "rejected"
    ],
    "visibility": ["private", "public"],
    "availability": [
      "unavailable",
      "available",
      "yanked",
      "security-quarantined"
    ],
    "retention": ["retained", "soft-deleted", "purged"]
