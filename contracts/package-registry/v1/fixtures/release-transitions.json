  "lifecycle_transitions": [
    {
      "from": "reserved",
      "to": "quarantined",
      "requires": [
        "identity_version_digest_reserved_atomically",
        "blob_in_quarantine"
      ]
    },
    {
      "from": "quarantined",
      "to": "first-scanning",
      "requires": ["sandbox_available", "immutable_scan_input"]
    },
    {
      "from": "first-scanning",
      "to": "quarantined",
