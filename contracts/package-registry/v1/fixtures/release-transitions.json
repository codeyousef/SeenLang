      "requires": [
        "second_scan_passed",
        "fresh_source_proof_verified",
        "integrity_reverified"
      ]
    },
    {
      "from": "ready",
      "to": "active",
      "requires": [
        "blob_promoted_before_metadata",
        "resolver_metadata_signed_and_published",
        "audit_event"
