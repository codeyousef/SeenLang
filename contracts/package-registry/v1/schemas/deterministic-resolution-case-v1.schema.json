{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "urn:seen:package-registry:v1:deterministic-resolution-case",
  "title": "Seen deterministic resolution case v1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "name",
    "mode",
    "package",
    "registry_origin",
    "requirements",
    "lock",
    "candidates",
    "expected"
  ],
  "properties": {
    "name": {"type": "string", "pattern": "^[a-z][a-z0-9_]{2,95}$"},
    "description": {"type": "string", "minLength": 1},
    "mode": {"enum": ["normal", "update", "frozen"]},
    "package": {"$ref": "#/$defs/identity"},
    "registry_origin": {"$ref": "#/$defs/registryOrigin"},
    "requirements": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["requester", "requirement"],
        "properties": {
          "requester": {"type": "string", "minLength": 1, "maxLength": 160},
          "requirement": {"$ref": "urn:seen:package-registry:v1:semver-requirement"}
        }
      }
    },
    "lock": {
      "oneOf": [
        {"type": "null"},
        {"$ref": "#/$defs/lockedCandidate"}
      ]
    },
    "candidates": {
      "type": "array",
      "items": {"$ref": "#/$defs/candidate"}
    },
    "expected": {
      "oneOf": [
        {"$ref": "#/$defs/selection"},
        {"$ref": "#/$defs/failure"}
      ]
    }
  },
  "$defs": {
    "identity": {
      "type": "string",
      "pattern": "^[a-z0-9](?:[a-z0-9-]{0,61}[a-z0-9])?/[a-z0-9](?:[a-z0-9-]{0,61}[a-z0-9])?$"
    },
    "registryOrigin": {
      "type": "string",
      "format": "uri",
      "pattern": "^https://[a-z0-9](?:[a-z0-9-]{0,61}[a-z0-9])?(?:\\.[a-z0-9](?:[a-z0-9-]{0,61}[a-z0-9])?)+(?:/[a-z0-9][a-z0-9._~-]*)+$"
    },
    "exactVersion": {
      "type": "string",
      "format": "semver-exact",
      "maxLength": 128,
      "pattern": "^(?:0|[1-9][0-9]*)\\.(?:0|[1-9][0-9]*)\\.(?:0|[1-9][0-9]*)(?:-(?:0|[1-9][0-9]*|[0-9A-Za-z-]*[A-Za-z-][0-9A-Za-z-]*)(?:\\.(?:0|[1-9][0-9]*|[0-9A-Za-z-]*[A-Za-z-][0-9A-Za-z-]*))*)?(?:\\+[0-9A-Za-z-]+(?:\\.[0-9A-Za-z-]+)*)?$"
    },
    "sha256": {"type": "string", "pattern": "^[0-9a-f]{64}$"},
    "candidate": {
      "type": "object",
      "additionalProperties": false,
      "required": ["version", "registry_origin", "archive_sha256", "availability"],
      "properties": {
        "version": {"$ref": "#/$defs/exactVersion"},
        "registry_origin": {"$ref": "#/$defs/registryOrigin"},
        "archive_sha256": {"$ref": "#/$defs/sha256"},
        "availability": {"enum": ["available", "yanked", "security-quarantined"]}
      }
    },
    "lockedCandidate": {
      "type": "object",
      "additionalProperties": false,
      "required": ["version", "registry_origin", "archive_sha256"],
      "properties": {
        "version": {"$ref": "#/$defs/exactVersion"},
        "registry_origin": {"$ref": "#/$defs/registryOrigin"},
        "archive_sha256": {"$ref": "#/$defs/sha256"}
      }
    },
    "selection": {
      "type": "object",
      "additionalProperties": false,
      "required": ["outcome", "version", "registry_origin", "archive_sha256", "from_lock", "write_lock"],
      "properties": {
        "outcome": {"const": "select"},
        "version": {"$ref": "#/$defs/exactVersion"},
        "registry_origin": {"$ref": "#/$defs/registryOrigin"},
        "archive_sha256": {"$ref": "#/$defs/sha256"},
        "from_lock": {"type": "boolean"},
        "write_lock": {"type": "boolean"}
      }
    },
    "failure": {
      "type": "object",
      "additionalProperties": false,
      "required": ["outcome", "error_code"],
      "properties": {
        "outcome": {"const": "error"},
        "error_code": {
          "enum": [
            "invalid_version_requirement",
            "no_matching_version",
            "dependency_constraint_conflict",
            "ambiguous_build_metadata",
            "registry_origin_mismatch",
            "locked_origin_mismatch",
            "lock_digest_mismatch",
            "lock_required",
            "locked_requirement_mismatch",
            "locked_release_quarantined",
            "metadata_equivocation"
          ]
        },
        "conflict_requesters": {
          "type": "array",
          "uniqueItems": true,
          "items": {"type": "string", "minLength": 1}
        }
      }
    }
  }
}
