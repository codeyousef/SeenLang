{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "urn:seen:package-registry:v1:error-envelope",
  "title": "Seen package registry error envelope v1",
  "description": "The stable error shape for every non-2xx API response. Clients branch on code and retryable, never on message.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "error"
  ],
  "properties": {
    "error": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "code",
        "message",
        "request_id",
        "occurred_at",
        "retryable",
        "retry_after_seconds",
        "details"
      ],
      "properties": {
        "code": {
          "$ref": "#/$defs/errorCode"
        },
        "message": {
          "type": "string",
          "minLength": 1,
          "maxLength": 512
        },
        "request_id": {
          "type": "string",
          "pattern": "^req_[A-Za-z0-9_-]{16,96}$"
        },
        "occurred_at": {
          "$ref": "#/$defs/utcTimestamp"
        },
        "retryable": {
          "type": "boolean"
        },
        "retry_after_seconds": {
          "type": [
            "integer",
            "null"
          ],
          "minimum": 1,
          "maximum": 86400
        },
        "details": {
          "type": "object",
          "maxProperties": 32,
          "additionalProperties": {
            "$ref": "#/$defs/detailValue"
          }
        }
      },
      "allOf": [
        {
          "if": {
            "properties": {
              "retryable": {
                "const": true
              }
            },
            "required": [
              "retryable"
            ]
          },
          "then": {
            "properties": {
              "retry_after_seconds": {
                "type": "integer"
              }
            }
          },
          "else": {
            "properties": {
              "retry_after_seconds": {
                "type": "null"
              }
            }
          }
        }
      ]
    }
  },
  "$defs": {
    "errorCode": {
      "enum": [
        "invalid_request",
        "invalid_package_identity",
        "invalid_version",
        "invalid_cursor",
        "page_limit_exceeded",
        "unauthenticated",
        "forbidden",
        "not_found",
        "package_already_exists",
        "version_already_reserved",
        "idempotency_key_required",
        "idempotency_key_reused",
        "digest_required",
        "digest_mismatch",
        "archive_too_large",
        "archive_rejected",
        "source_proof_invalid",
        "release_not_ready",
        "release_unavailable",
        "state_transition_forbidden",
        "rate_limited",
        "writer_disabled",
        "temporarily_unavailable",
        "internal_error"
      ]
    },
    "utcTimestamp": {
      "type": "string",
      "format": "date-time",
      "pattern": "^[0-9]{4}-[0-9]{2}-[0-9]{2}T[0-9]{2}:[0-9]{2}:[0-9]{2}(?:\\.[0-9]{1,9})?Z$"
    },
    "detailValue": {
      "anyOf": [
        {
          "type": "string",
          "maxLength": 512
        },
        {
          "type": "integer"
        },
        {
          "type": "number"
        },
        {
          "type": "boolean"
        },
        {
          "type": "null"
        },
        {
          "type": "array",
          "maxItems": 32,
          "items": {
            "type": [
              "string",
              "integer",
              "number",
              "boolean",
              "null"
            ]
          }
        }
      ]
    }
  }
}
