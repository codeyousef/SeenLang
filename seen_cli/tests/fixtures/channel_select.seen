fun Main() -> Int {
    let ch1 = Channel()
    let ch2 = Channel()

    scope {
        spawn {
            await send 1 to ch1
        }
        spawn {
            await send 2 to ch2
        }

        let first = select {
            ch1 -> _ => {
                println("1")
                1
            },
            ch2 -> _ => {
                println("2")
                2
            }
        }

        let second = select {
            ch1 -> _ => {
                println("1")
                1
            },
            ch2 -> _ => {
                println("2")
                2
            }
        }

        second + first
    }
}

Main()
